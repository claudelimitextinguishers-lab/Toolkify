---
interface Props {
  code: string;
  title: string;
  description: string;
  accent?: "coral" | "teal" | "rose" | "yellow";
}

const {
  code,
  title,
  description,
  accent = "coral",
} = Astro.props;

const accentCardClass = {
  coral: "card-feature-coral",
  teal: "card-feature-teal",
  rose: "card-feature-rose",
  yellow: "card-feature-yellow",
}[accent];
---

<section
  class="max-w-[1000px] w-full mx-auto px-4 md:px-8 py-16 md:py-28 flex-grow flex flex-col justify-center gap-12 animate-fade-in-up"
>
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
    <a href="/" class="hover:text-primary">Home</a>
    <span>/</span>
    <span class="text-brand-blue">Error {code}</span>
  </div>

  <div class={`${accentCardClass} flex flex-col gap-8 p-8 sm:p-14 rounded-xxxl`}>
    <div class="flex flex-col gap-4">
      <span
        class="font-display font-semibold tracking-tighter text-primary leading-none text-7xl sm:text-9xl"
      >
        {code}
      </span>
      <h1 class="font-display font-medium text-3xl sm:text-5xl tracking-tight text-primary">
        {title}
      </h1>
      <p class="text-lg text-slate max-w-2xl leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <a
        href="/"
        class="button-primary text-center py-3 px-8 text-base shadow-sm hover:scale-[1.02] active:scale-[0.98] transition-transform"
      >
        Back to Home
      </a>
      <button
        type="button"
        onclick="history.length > 1 ? history.back() : (window.location.href = '/')"
        class="button-secondary text-center py-3 px-8 text-base hover:scale-[1.02] active:scale-[0.98] transition-transform"
      >
        Go Back
      </button>
    </div>
  </div>
</section>
