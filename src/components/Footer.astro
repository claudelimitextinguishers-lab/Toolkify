---
---
<footer class="bg-footer-bg text-on-dark border-t border-charcoal py-16 px-4 md:px-8 mt-auto">
  <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-8">
    <!-- Brand Block -->
    <div class="lg:col-span-2 flex flex-col gap-4">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-brand-yellow rounded-sm flex items-center justify-center font-display font-semibold text-lg text-primary">
          B
        </div>
        <span class="font-display font-medium text-lg text-on-dark tracking-tight">BoardTools</span>
      </div>
      <p class="text-sm text-on-dark-muted leading-relaxed max-w-xs">
        The ultimate suite of client-side web utility tools. Free, completely secure, and running 100% locally in your browser.
      </p>
      
      <!-- Capterra/Rating badge mockup -->
      <div class="flex items-center gap-2 mt-2 p-3 bg-charcoal rounded-md border border-charcoal/50 max-w-[200px]">
        <div class="text-brand-yellow flex gap-0.5">
          <span class="text-sm">★</span>
          <span class="text-sm">★</span>
          <span class="text-sm">★</span>
          <span class="text-sm">★</span>
          <span class="text-sm">★</span>
        </div>
        <div class="text-xs text-on-dark-muted font-medium">
          4.9 / 5 rating
        </div>
      </div>
    </div>

    <!-- Col 1: Finance & Health -->
    <div class="flex flex-col gap-3">
      <h3 class="font-display text-sm font-semibold tracking-wider text-on-dark uppercase">Finance & Health</h3>
      <a href="/tools/finance/mortgage-payment" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Mortgage Calculator</a>
      <a href="/tools/finance/paycheck-calculator" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Paycheck Calculator</a>
      <a href="/tools/health/bmi-calculator" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">BMI Calculator</a>
      <a href="/tools/health/calorie-deficit" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Calorie Deficit</a>
    </div>

    <!-- Col 2: Engagement & Everyday -->
    <div class="flex flex-col gap-3">
      <h3 class="font-display text-sm font-semibold tracking-wider text-on-dark uppercase">Engagement & Everyday</h3>
      <a href="/tools/engagement/typing-test" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Typing Test</a>
      <a href="/tools/engagement/pomodoro-timer" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Pomodoro Timer</a>
      <a href="/tools/general/time-zone-converter" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Time Zone Converter</a>
      <a href="/tools/general/currency-converter" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Currency Converter</a>
    </div>

    <!-- Col 3: Developer Tools -->
    <div class="flex flex-col gap-3">
      <h3 class="font-display text-sm font-semibold tracking-wider text-on-dark uppercase">Developer Tools</h3>
      <a href="/tools/json-formatter" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">JSON Formatter</a>
      <a href="/tools/base64-url" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Base64 & URL Tool</a>
      <a href="/tools/uuid-hash" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">UUID & Hash Gen</a>
      <a href="/tools/developer/password-generator" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Password Generator</a>
    </div>

    <!-- Col 4: Audio & Diagnostics -->
    <div class="flex flex-col gap-3">
      <h3 class="font-display text-sm font-semibold tracking-wider text-on-dark uppercase">Audio & Diagnostics</h3>
      <a href="/tools/audio/white-noise" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">White Noise Gen</a>
      <a href="/tools/display/refresh-rate" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Refresh Rate Test</a>
      <a href="/tools/display/double-click" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Double Click Test</a>
      <a href="/tools/display/keyboard-latency" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Keyboard Latency</a>
    </div>

    <!-- Col 5: Platform & Security -->
    <div class="flex flex-col gap-3">
      <h3 class="font-display text-sm font-semibold tracking-wider text-on-dark uppercase">Security</h3>
      <span class="text-sm text-on-dark-muted">100% Client-Side</span>
      <a href="/tools/whiteboard" class="text-sm text-on-dark-muted hover:text-on-dark transition-colors">Live Whiteboard</a>
      <span class="text-xs px-2 py-1 bg-success-accent/20 text-success-accent rounded-full text-center font-medium max-w-[120px]">Secure Sandbox</span>
    </div>
  </div>

  <div class="max-w-[1280px] mx-auto mt-12 pt-8 border-t border-charcoal flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-on-dark-muted">
    <div>
      &copy; {new Date().getFullYear()} BoardTools. All rights reserved. Inspired by Miro.
    </div>
    <div class="flex flex-wrap gap-x-6 gap-y-2 justify-center">
      <a href="/privacy" class="hover:text-on-dark transition-colors">Privacy Policy</a>
      <span>•</span>
      <a href="/terms" class="hover:text-on-dark transition-colors">Terms & Conditions</a>
      <span>•</span>
      <span class="hover:text-on-dark cursor-help" title="All operations happen on your computer. None of your inputs, keys, or formatted text are uploaded.">Privacy Guarantee</span>
      <span>•</span>
      <span>Fully Static Site</span>
    </div>
  </div>
</footer>
