---
---
<footer class="bg-footer-bg text-on-dark border-t border-charcoal/80 py-16 px-4 md:px-8 mt-auto relative overflow-hidden">
  <!-- Subtle decorative grid background for the footer -->
  <div class="absolute inset-0 dot-grid opacity-[0.03] pointer-events-none"></div>

  <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 relative z-10">
    <!-- Brand Block (lg:col-span-3) -->
    <div class="lg:col-span-3 flex flex-col gap-5">
      <a href="/" class="flex items-center group cursor-pointer w-fit" aria-label="Toolkify home">
        <img src="/logo-dark.svg" alt="Toolkify" width="158" height="36" class="h-9 w-auto transition-transform duration-300 group-hover:scale-105" />
      </a>
      
      <p class="text-sm text-on-dark-muted leading-relaxed max-w-sm">
        The ultimate suite of client-side web utility tools. Free, completely secure, and running 100% locally in your browser. No trackers, no servers, just utility.
      </p>
      
      <!-- System Status -->
      <div class="flex flex-col gap-3 mt-1">
        <div class="flex items-center gap-2 px-1">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-success-accent"></span>
          </span>
          <span class="text-xs text-on-dark-muted font-medium">All tools locally active</span>
        </div>
      </div>
    </div>

    <!-- Links Columns (lg:col-span-6 Grid with 4 columns) -->
    <div class="lg:col-span-6 grid grid-cols-2 sm:grid-cols-4 gap-8">
      <!-- Col 1: Finance -->
      <div class="flex flex-col gap-3.5">
        <h3 class="font-display text-xs font-bold tracking-wider text-brand-yellow uppercase">Finance</h3>
        <ul class="flex flex-col gap-2.5">
          <li>
            <a href="/tools/finance/mortgage-payment" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Mortgage Pay</a>
          </li>
          <li>
            <a href="/tools/finance/paycheck-calculator" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Paycheck</a>
          </li>
          <li>
            <a href="/tools/finance/currency-converter" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Currency</a>
          </li>
          <li>
            <a href="/tools/health/calorie-deficit" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Calorie Deficit</a>
          </li>
        </ul>
      </div>

      <!-- Col 2: Everyday -->
      <div class="flex flex-col gap-3.5">
        <h3 class="font-display text-xs font-bold tracking-wider text-brand-yellow uppercase">Everyday</h3>
        <ul class="flex flex-col gap-2.5">
          <li>
            <a href="/tools/fun/typing-test" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Typing Test</a>
          </li>
          <li>
            <a href="/tools/fun/pomodoro-timer" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Pomodoro</a>
          </li>
          <li>
            <a href="/tools/general/time-zone-converter" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Time Zones</a>
          </li>
          <li>
            <a href="/tools/developer/randomizer-wheel" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Randomizer</a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Developer -->
      <div class="flex flex-col gap-3.5">
        <h3 class="font-display text-xs font-bold tracking-wider text-brand-yellow uppercase">Developer</h3>
        <ul class="flex flex-col gap-2.5">
          <li>
            <a href="/tools/json-formatter" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">JSON Formatter</a>
          </li>
          <li>
            <a href="/tools/base64-url" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Base64 & URL</a>
          </li>
          <li>
            <a href="/tools/uuid-hash" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">UUID & Hash</a>
          </li>
          <li>
            <a href="/tools/developer/password-generator" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Password Gen</a>
          </li>
        </ul>
      </div>

      <!-- Col 4: Diagnostics -->
      <div class="flex flex-col gap-3.5">
        <h3 class="font-display text-xs font-bold tracking-wider text-brand-yellow uppercase">Diagnostics</h3>
        <ul class="flex flex-col gap-2.5">
          <li>
            <a href="/tools/audio/white-noise" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">White Noise</a>
          </li>
          <li>
            <a href="/tools/display/refresh-rate" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Refresh Rate</a>
          </li>
          <li>
            <a href="/tools/display/double-click" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Double Click</a>
          </li>
          <li>
            <a href="/tools/display/keyboard-latency" class="text-sm text-on-dark-muted hover:text-on-dark hover:translate-x-1 transition-all duration-200 inline-block">Keyboard Latency</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Right Block: Suggest a Tool & Community (lg:col-span-3) -->
    <div class="lg:col-span-3 flex flex-col gap-5">
      <div class="flex flex-col gap-2">
        <h3 class="font-display text-xs font-bold tracking-wider text-brand-yellow uppercase">Suggest a Tool</h3>
        <p class="text-xs text-on-dark-muted leading-relaxed">
          Have an idea for a client-side utility? Send it over and we'll build it.
        </p>
      </div>

      <!-- Suggestion Box Form -->
      <form id="footer-suggest-form" class="flex flex-col gap-2">
        <div class="flex gap-2">
          <input 
            type="text" 
            id="footer-suggest-input"
            placeholder="Suggest a tool..." 
            required
            class="bg-charcoal/40 border border-charcoal text-on-dark placeholder-on-dark-muted rounded-full px-4 py-2 text-xs focus:outline-none focus:border-brand-yellow/50 focus:bg-charcoal/60 w-full transition-all duration-300"
          />
          <button 
            type="submit" 
            class="bg-brand-yellow hover:bg-brand-yellow-deep text-primary font-display font-medium text-xs px-4 py-2 rounded-full transition-all duration-300 flex items-center justify-center shrink-0 shadow-md cursor-pointer hover:scale-105 active:scale-95"
            aria-label="Submit tool suggestion"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </button>
        </div>
        <p class="text-[10px] text-on-dark-muted/65 italic">
          100% private. Opens default mail client.
        </p>
      </form>

      <!-- Interactive Platform Badges & Social Links -->
      <div class="flex flex-col gap-3 mt-1">
        <div class="flex items-center gap-3">
          <a href="/tools/whiteboard" class="flex items-center gap-1.5 text-xs text-brand-teal bg-brand-teal/10 hover:bg-brand-teal/20 border border-brand-teal/30 px-3 py-1.5 rounded-full transition-all duration-300 font-semibold">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-teal animate-pulse"></span>
            Live Whiteboard
          </a>
          <span class="text-[10px] uppercase font-bold tracking-wider px-2.5 py-1.5 bg-success-accent/10 border border-success-accent/30 text-success-accent rounded-full text-center">
            Secure Sandbox
          </span>
        </div>

        <!-- Social Icons Row -->
        <div class="flex items-center gap-3.5 mt-1 text-on-dark-muted">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-brand-yellow hover:scale-115 transition-all duration-300" aria-label="GitHub Profile">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
          <a href="mailto:claudelimitextinguishers@gmail.com" class="hover:text-brand-yellow hover:scale-115 transition-all duration-300" aria-label="Email Us">
            <svg class="w-5 h-5 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Metadata Row -->
  <div class="max-w-[1280px] mx-auto mt-16 pt-8 border-t border-charcoal/80 flex flex-col md:flex-row justify-between items-center gap-6 text-xs text-on-dark-muted relative z-10">
    <div class="flex items-center gap-2.5 font-medium">
      &copy; {new Date().getFullYear()} TOOLKIFY. All rights reserved.
      <span class="text-charcoal">•</span>
      <span class="text-on-dark-muted/80">Inspired by Miro</span>
    </div>
    <div class="flex flex-wrap gap-x-6 gap-y-2.5 justify-center items-center font-medium">
      <a href="/privacy" class="hover:text-on-dark transition-colors duration-200">Privacy Policy</a>
      <span class="text-charcoal">•</span>
      <a href="/terms" class="hover:text-on-dark transition-colors duration-200">Terms & Conditions</a>
      <span class="text-charcoal">•</span>
      <span class="hover:text-on-dark cursor-help transition-colors duration-200 flex items-center gap-1 group relative" title="All operations happen 100% on your computer. None of your inputs, keys, or formatted text are uploaded.">
        <span>Privacy Guarantee</span>
        <svg class="w-3.5 h-3.5 text-brand-teal/80 group-hover:text-brand-teal transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </span>
      <span class="text-charcoal">•</span>
      <span class="px-2 py-0.5 bg-charcoal/40 border border-charcoal rounded text-[10px] font-bold text-on-dark-muted/90">Fully Static Site</span>
    </div>
  </div>
</footer>

<!-- Footer Suggestion Permission Modal -->
<div id="footer-permission-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden animate-fade-in select-none">
  <div class="card-base max-w-sm w-full flex flex-col gap-5 p-6 border border-hairline-strong bg-canvas shadow-2xl animate-scale-up">
    <div class="flex items-center gap-3 text-brand-blue">
      <span class="text-2xl">✉</span>
      <h3 class="font-display font-semibold text-base text-primary">Open Mail Application?</h3>
    </div>
    <p class="text-xs text-slate leading-relaxed">
      We will open your default email service to send this tool suggestion to <span class="font-bold text-brand-blue select-all">claudelimitextinguishers@gmail.com</span>.
    </p>
    <p class="text-[11px] text-slate/80 bg-surface-soft p-3 rounded-lg border border-hairline italic">
      Note: Your suggestion will be reviewed and we will aim to build and add it to the website within 1 week.
    </p>
    <div class="flex items-center justify-end gap-3 mt-1">
      <button type="button" id="footer-modal-cancel" class="button-ghost py-1.5 px-3.5 text-xs font-semibold text-slate hover:bg-surface-soft rounded-lg cursor-pointer">
        Cancel
      </button>
      <button type="button" id="footer-modal-confirm" class="button-primary py-1.5 px-3.5 text-xs font-semibold hover:button-primary-active cursor-pointer">
        Open Mail Client
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('footer-suggest-form') as HTMLFormElement | null;
    const input = document.getElementById('footer-suggest-input') as HTMLInputElement | null;
    const modal = document.getElementById('footer-permission-modal');
    const modalConfirm = document.getElementById('footer-modal-confirm');
    const modalCancel = document.getElementById('footer-modal-cancel');
    
    let pendingMailto = '';

    if (form && input && modal) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const val = input.value.trim();
        if (!val) return;

        const subject = encodeURIComponent("Tool Suggestion - TOOLKIFY");
        const body = encodeURIComponent(`Hi TOOLKIFY team,\n\nI would like to suggest a new client-side tool: ${val}\n\nThank you!`);
        pendingMailto = `mailto:claudelimitextinguishers@gmail.com?subject=${subject}&body=${body}`;
        
        modal.classList.remove('hidden');
      });
    }

    if (modalCancel && modal) {
      modalCancel.addEventListener('click', () => {
        modal.classList.add('hidden');
        pendingMailto = '';
      });
    }

    if (modalConfirm && modal) {
      modalConfirm.addEventListener('click', () => {
        if (pendingMailto) {
          window.location.href = pendingMailto;
        }
        modal.classList.add('hidden');
        pendingMailto = '';
        if (input) {
          input.value = '';
        }
      });
    }
  });
</script>
