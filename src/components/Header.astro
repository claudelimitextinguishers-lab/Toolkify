---
import SearchOverlay from './SearchOverlay.astro';
import AnimatedLogo from './AnimatedLogo.astro';
const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 w-full h-[64px] border-b border-hairline bg-canvas/90 backdrop-blur-md">
  <div class="max-w-[1280px] h-full mx-auto px-4 md:px-8 flex items-center justify-between">
    <!-- Brand Logo -->
    <a href="/" class="flex items-center" aria-label="Toolkify home">
      <AnimatedLogo theme="auto" height={40} />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-6">
      <a href="/" class={`font-display text-[14px] font-medium transition-colors ${currentPath === '/' ? 'text-brand-blue' : 'text-slate hover:text-ink'}`}>Dashboard</a>
      <a href="/tools/whiteboard" class={`font-display text-[14px] font-medium transition-colors ${currentPath.includes('/tools/whiteboard') ? 'text-brand-blue' : 'text-slate hover:text-ink'}`}>Whiteboard</a>
      
      <!-- Categories Dropdown -->
      <div class="relative group/nav-item">
        <button class="font-display text-[14px] font-medium text-slate hover:text-ink flex items-center gap-1 cursor-pointer">
          Tool Categories
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 w-64 hidden group-hover/nav-item:block z-50">
          <div class="bg-canvas border border-hairline rounded-lg shadow-modal p-2">
            <a href="/?category=finance" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>💰</span> Finance & Tax</a>
            <a href="/?category=health" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>🏥</span> Health & Fitness</a>
            <a href="/?category=fun" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>⌨️</span> Fun Tools</a>
            <a href="/?category=developer" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>🔧</span> Developer & Text</a>
            <a href="/?category=audio" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>🎵</span> Audio Utilities</a>
            <a href="/?category=mobile" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>📱</span> Mobile Sensors</a>
            <a href="/?category=display" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>🖥️</span> Display & Input</a>
            <a href="/?category=general" class="block px-3 py-2 text-xs font-semibold text-slate hover:text-ink rounded-md hover:bg-surface flex items-center gap-2"><span>🌍</span> Everyday Utilities</a>
          </div>
        </div>
      </div>

      <a href="/about" class={`font-display text-[14px] font-medium transition-colors ${currentPath === '/about' ? 'text-brand-blue' : 'text-slate hover:text-ink'}`}>About Us</a>
      <a href="/contact" class={`font-display text-[14px] font-medium transition-colors ${currentPath === '/contact' ? 'text-brand-blue' : 'text-slate hover:text-ink'}`}>Contact Us</a>
    </nav>

    <!-- Right Side Actions -->
    <div class="flex items-center gap-3">
      <!-- Search Button (Magnifying Glass) -->
      <button 
        id="navbar-search-btn" 
        class="w-9 h-9 rounded-full flex items-center justify-center text-slate hover:text-brand-blue hover:bg-surface border border-hairline transition-all duration-200 cursor-pointer group" 
        aria-label="Search tools"
        title="Search tools (Ctrl+K)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <!-- Dark Mode Toggle -->
      <button 
        id="theme-toggle" 
        class="w-9 h-9 rounded-full flex items-center justify-center text-slate hover:text-ink hover:bg-surface border border-hairline transition-all duration-200 cursor-pointer" 
        aria-label="Toggle dark mode"
      >
        <!-- Sun Icon (shown in dark mode) -->
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden dark:block animate-rotate-in" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M14 12a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <!-- Moon Icon (shown in light mode) -->
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 block dark:hidden animate-scale-in" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <a href="/tools/whiteboard" class="button-primary hidden sm:inline-flex py-2 px-5 text-sm !rounded-full">
        Launch Whiteboard
      </a>
      
      <!-- Hamburger Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-md hover:bg-surface text-ink cursor-pointer" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div id="mobile-dropdown" class="hidden absolute top-[64px] left-0 w-full bg-canvas border-b border-hairline shadow-modal flex flex-col p-4 gap-4 z-40 lg:hidden overflow-y-auto max-h-[80vh]">
    <!-- Mobile Search Bar -->
    <button 
      id="mobile-search-btn"
      class="w-full flex items-center gap-3 px-4 py-3 bg-surface border border-hairline rounded-xl text-left cursor-pointer hover:border-brand-blue/30 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-stone shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <span class="text-sm text-stone font-display">Search tools…</span>
    </button>

    <a href="/" class="font-display font-medium text-slate hover:text-ink py-2 border-b border-hairline-soft">Dashboard</a>
    <a href="/tools/whiteboard" class="font-display font-medium text-slate hover:text-ink py-2 border-b border-hairline-soft">Interactive Whiteboard</a>
    <a href="/about" class="font-display font-medium text-slate hover:text-ink py-2 border-b border-hairline-soft">About Us</a>
    <a href="/contact" class="font-display font-medium text-slate hover:text-ink py-2 border-b border-hairline-soft">Contact Us</a>
    
    <div class="flex flex-col gap-2">
      <span class="text-xs font-semibold text-stone uppercase tracking-wider">Tool Categories</span>
      <div class="grid grid-cols-2 gap-2 pl-2">
        <a href="/?category=finance" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>💰</span> Finance</a>
        <a href="/?category=health" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>🏥</span> Health</a>
        <a href="/?category=fun" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>⌨️</span> Fun</a>
        <a href="/?category=developer" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>🔧</span> Developer</a>
        <a href="/?category=audio" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>🎵</span> Audio</a>
        <a href="/?category=mobile" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>📱</span> Mobile</a>
        <a href="/?category=display" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>🖥️</span> Display</a>
        <a href="/?category=general" class="text-xs font-medium text-slate hover:text-ink py-1.5 flex items-center gap-1.5"><span>🌍</span> Everyday</a>
      </div>
    </div>
    
    <a href="/tools/whiteboard" class="button-primary text-center py-2.5 w-full mt-2">
      Launch Whiteboard
    </a>
  </div>
</header>

<!-- Global Search Overlay -->
<SearchOverlay />

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const dropdown = document.getElementById('mobile-dropdown');
  const themeToggle = document.getElementById('theme-toggle');
  const navSearchBtn = document.getElementById('navbar-search-btn');
  const mobileSearchBtn = document.getElementById('mobile-search-btn');
  
  if (btn && dropdown) {
    btn.addEventListener('click', () => {
      dropdown.classList.toggle('hidden');
    });
  }

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      window.dispatchEvent(new Event('theme-change'));
    });
  }

  // Navbar search button opens overlay
  if (navSearchBtn) {
    navSearchBtn.addEventListener('click', () => {
      if (typeof (window as any).__openSearchOverlay === 'function') {
        (window as any).__openSearchOverlay();
      }
    });
  }

  // Mobile search button opens overlay  
  if (mobileSearchBtn) {
    mobileSearchBtn.addEventListener('click', () => {
      // Close mobile menu first
      if (dropdown) dropdown.classList.add('hidden');
      if (typeof (window as any).__openSearchOverlay === 'function') {
        (window as any).__openSearchOverlay();
      }
    });
  }
</script>
