---
---

<div 
  id="floating-request-container" 
  class="fixed bottom-6 right-6 z-40 hidden flex-col items-end gap-2 max-w-sm w-full font-sans select-none"
>
  <!-- Collapsed state bubble -->
  <div 
    id="request-collapsed-bubble" 
    class="flex items-center gap-3 bg-primary text-canvas px-4 py-3 rounded-full shadow-modal border border-charcoal cursor-pointer hover:-translate-y-0.5 transition-all duration-200"
  >
    <div class="flex items-center gap-2">
      <span class="text-base animate-bounce">💡</span>
      <span class="font-display font-medium text-xs tracking-tight">Need a custom tool? Request it!</span>
    </div>
    <button 
      id="close-collapsed-bubble" 
      class="text-on-dark-muted hover:text-on-dark font-bold text-sm cursor-pointer p-0.5" 
      title="Dismiss prompt"
      aria-label="Dismiss prompt"
    >
      &times;
    </button>
  </div>

  <!-- Expanded state card -->
  <div 
    id="request-expanded-card" 
    class="hidden flex-col gap-4 p-5 rounded-2xl bg-canvas border border-hairline shadow-modal w-[320px] sm:w-[340px] text-left animate-scale-in"
  >
    <div class="flex justify-between items-start">
      <div class="flex items-center gap-2">
        <span class="text-lg">💡</span>
        <h3 class="font-display font-semibold text-sm text-primary">Request a Custom Tool</h3>
      </div>
      <button 
        id="close-expanded-card" 
        class="text-stone hover:text-primary font-bold text-base cursor-pointer p-0.5"
        aria-label="Close form"
      >
        &times;
      </button>
    </div>
    
    <div id="popup-request-content" class="flex flex-col gap-3 py-1">
      <p class="text-xs text-slate leading-relaxed font-sans font-normal">
        To suggest a required tool, mail us.
      </p>
      <a 
        href="#" 
        id="popup-direct-email" 
        class="button-primary text-center w-full !py-2.5 !text-xs hover:button-primary-active block font-semibold transition-all mt-1"
      >
        To mail us click here.
      </a>
    </div>

    <!-- Popup success message -->
    <div id="popup-success-msg" class="hidden flex-col items-center justify-center text-center py-4 gap-2">
      <span class="w-8 h-8 rounded-full bg-success-accent/25 border border-success-accent text-success-accent flex items-center justify-center font-bold text-sm">✓</span>
      <span class="text-xs font-semibold text-primary">Mail Link Prepared!</span>
      <span class="text-[10px] text-slate">Please complete sending the email in your mail client.</span>
    </div>
  </div>
</div>

<!-- Request Tool Permission Confirmation Modal -->
<div id="popup-permission-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden animate-fade-in select-none">
  <div class="card-base max-w-sm w-full flex flex-col gap-5 p-6 border border-hairline-strong bg-canvas shadow-2xl animate-scale-up">
    <div class="flex items-center gap-3 text-brand-blue">
      <span class="text-2xl">✉</span>
      <h3 class="font-display font-semibold text-base text-primary">Open Mail Application?</h3>
    </div>
    <p class="text-xs text-slate leading-relaxed">
      We will open your default email service to send this tool request to <span class="font-bold text-brand-blue select-all">requests@boardtools.dev</span>.
    </p>
    <p class="text-[11px] text-slate/80 bg-surface-soft p-3 rounded-lg border border-hairline italic">
      Note: Your request will be reviewed and we will aim to build and add it to the website within 1 week.
    </p>
    <div class="flex items-center justify-end gap-3 mt-1">
      <button type="button" id="popup-modal-cancel" class="button-ghost py-1.5 px-3.5 text-xs font-semibold text-slate hover:bg-surface-soft rounded-lg cursor-pointer">
        Cancel
      </button>
      <button type="button" id="popup-modal-confirm" class="button-primary py-1.5 px-3.5 text-xs font-semibold hover:button-primary-active cursor-pointer">
        Open Mail Client
      </button>
    </div>
  </div>
</div>

<script>
  const container = document.getElementById('floating-request-container');
  const collapsed = document.getElementById('request-collapsed-bubble');
  const expanded = document.getElementById('request-expanded-card');
  const closeCollapsed = document.getElementById('close-collapsed-bubble');
  const closeExpanded = document.getElementById('close-expanded-card');
  const requestContent = document.getElementById('popup-request-content');
  const successMsg = document.getElementById('popup-success-msg');

  // Modal elements
  const popupModal = document.getElementById('popup-permission-modal');
  const popupCancel = document.getElementById('popup-modal-cancel');
  const popupConfirm = document.getElementById('popup-modal-confirm');
  let pendingMailto = '';

  function showPopupModal(mailtoUrl: string) {
    pendingMailto = mailtoUrl;
    if (popupModal) {
      popupModal.classList.remove('hidden');
    }
  }

  function hidePopupModal() {
    if (popupModal) {
      popupModal.classList.add('hidden');
    }
    pendingMailto = '';
  }

  if (popupCancel) {
    popupCancel.addEventListener('click', hidePopupModal);
  }

  if (popupConfirm) {
    popupConfirm.addEventListener('click', () => {
      if (pendingMailto) {
        window.location.href = pendingMailto;
      }
      hidePopupModal();

      // Show success state in card
      if (requestContent && successMsg) {
        requestContent.classList.add('hidden');
        successMsg.classList.remove('hidden');
        successMsg.classList.add('flex');

        setTimeout(() => {
          if (container) {
            container.classList.add('hidden');
          }
          sessionStorage.setItem('dismissed_request_popup', 'true');
        }, 3500);
      }
    });
  }

  // Load delay: Show popup after 3.5 seconds if not dismissed
  window.addEventListener('load', () => {
    const isDismissed = sessionStorage.getItem('dismissed_request_popup');
    if (!isDismissed && container) {
      setTimeout(() => {
        container.classList.remove('hidden');
        container.classList.add('flex');
        container.classList.add('animate-fade-in-up');
      }, 3500);
    }
  });

  // Expand popup on bubble click
  if (collapsed && expanded) {
    collapsed.addEventListener('click', (e) => {
      // Don't expand if click was on the close button
      if (e.target === closeCollapsed || closeCollapsed?.contains(e.target as Node)) {
        return;
      }
      collapsed.classList.add('hidden');
      expanded.classList.remove('hidden');
      expanded.classList.add('flex');
    });
  }

  // Close collapsed bubble
  if (closeCollapsed && container) {
    closeCollapsed.addEventListener('click', () => {
      container.classList.add('hidden');
      sessionStorage.setItem('dismissed_request_popup', 'true');
    });
  }

  // Close expanded card
  if (closeExpanded && container && collapsed && expanded) {
    closeExpanded.addEventListener('click', () => {
      expanded.classList.remove('flex');
      expanded.classList.add('hidden');
      collapsed.classList.remove('hidden');
      // Clicking close also dismisses it for future page views
      sessionStorage.setItem('dismissed_request_popup', 'true');
    });
  }

  // Direct email link in popup
  const directEmail = document.getElementById('popup-direct-email');
  if (directEmail) {
    directEmail.addEventListener('click', (e) => {
      e.preventDefault();
      const subject = encodeURIComponent('BoardTools Custom Tool Request');
      const body = encodeURIComponent(
        'Hi BoardTools Team,\n\n' +
        'I would like to suggest a custom tool:\n' +
        '- Tool Description: \n\n' +
        'Thank you!'
      );
      showPopupModal(`mailto:requests@boardtools.dev?subject=${subject}&body=${body}`);
    });
  }
</script>
