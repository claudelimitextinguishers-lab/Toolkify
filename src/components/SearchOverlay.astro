---

<!-- Search Overlay (Global, triggered from navbar) -->
<div 
  id="search-overlay" 
  class="fixed inset-0 z-[100] hidden" 
  role="dialog" 
  aria-modal="true" 
  aria-label="Search tools"
>
  <!-- Backdrop -->
  <div id="search-overlay-backdrop" class="absolute inset-0 bg-primary/60 backdrop-blur-sm"></div>
  
  <!-- Search Panel -->
  <div class="relative z-10 w-full max-w-2xl mx-auto mt-[12vh] px-4">
    <!-- Search Input Container -->
    <div class="bg-canvas rounded-2xl shadow-modal border border-hairline overflow-hidden animate-scale-in">
      <!-- Input Row -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-hairline">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          type="text" 
          id="overlay-search-input" 
          placeholder="Search 56+ tools… (e.g. JSON, mortgage, typing test)" 
          class="flex-1 bg-transparent text-primary text-base font-display font-medium placeholder:text-stone outline-none border-none"
          autocomplete="off"
          spellcheck="false"
        />
        <button 
          id="overlay-close-btn" 
          class="text-[10px] font-bold text-stone bg-surface border border-hairline rounded-md px-2 py-1 hover:bg-hairline transition-colors cursor-pointer select-none"
          aria-label="Close search"
        >
          <span class="hidden md:inline">ESC</span>
          <span class="inline md:hidden">✕</span>
        </button>
      </div>
      
      <!-- Results Container -->
      <div id="overlay-search-results" class="max-h-[50vh] overflow-y-auto">
        <!-- Hint State (shown when input is empty) -->
        <div id="overlay-hint-state" class="px-5 py-6 text-center">
          <p class="text-xs text-stone font-display">Start typing to search across all tools…</p>
          <div class="flex flex-wrap justify-center gap-2 mt-3">
            <button class="search-suggestion-pill px-3 py-1.5 bg-surface border border-hairline text-xs font-medium text-slate rounded-full hover:border-brand-blue hover:text-brand-blue transition-colors cursor-pointer">JSON</button>
            <button class="search-suggestion-pill px-3 py-1.5 bg-surface border border-hairline text-xs font-medium text-slate rounded-full hover:border-brand-blue hover:text-brand-blue transition-colors cursor-pointer">Mortgage</button>
            <button class="search-suggestion-pill px-3 py-1.5 bg-surface border border-hairline text-xs font-medium text-slate rounded-full hover:border-brand-blue hover:text-brand-blue transition-colors cursor-pointer">Typing Test</button>
            <button class="search-suggestion-pill px-3 py-1.5 bg-surface border border-hairline text-xs font-medium text-slate rounded-full hover:border-brand-blue hover:text-brand-blue transition-colors cursor-pointer">Password</button>
            <button class="search-suggestion-pill px-3 py-1.5 bg-surface border border-hairline text-xs font-medium text-slate rounded-full hover:border-brand-blue hover:text-brand-blue transition-colors cursor-pointer">Whiteboard</button>
          </div>
        </div>

        <!-- Results list (dynamically populated) -->
        <div id="overlay-results-list" class="hidden"></div>
        
        <!-- No Results State -->
        <div id="overlay-no-results" class="hidden px-5 py-8 text-center">
          <div class="w-12 h-12 mx-auto rounded-full bg-surface-yellow border border-yellow-light flex items-center justify-center text-lg mb-3">🔍</div>
          <p class="text-sm font-display font-medium text-primary mb-1">No tools found</p>
          <p class="text-xs text-slate mb-4">We don't have that tool yet, but you can request it!</p>
          <button 
            id="overlay-request-tool-btn" 
            class="button-primary !py-2.5 !px-6 !text-xs inline-flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Request This Tool
          </button>
        </div>
      </div>
    </div>

    <!-- Keyboard hint -->
    <p class="hidden md:block text-center text-[10px] text-on-dark-muted mt-3 font-display select-none">
      <span class="inline-flex items-center gap-1">
        <kbd class="bg-canvas/20 border border-canvas/10 rounded px-1.5 py-0.5 text-canvas/70 font-mono text-[9px]">↑</kbd>
        <kbd class="bg-canvas/20 border border-canvas/10 rounded px-1.5 py-0.5 text-canvas/70 font-mono text-[9px]">↓</kbd>
        to navigate
      </span>
      <span class="mx-2">·</span>
      <span class="inline-flex items-center gap-1">
        <kbd class="bg-canvas/20 border border-canvas/10 rounded px-1.5 py-0.5 text-canvas/70 font-mono text-[9px]">↵</kbd>
        to select
      </span>
      <span class="mx-2">·</span>
      <span class="inline-flex items-center gap-1">
        <kbd class="bg-canvas/20 border border-canvas/10 rounded px-1.5 py-0.5 text-canvas/70 font-mono text-[9px]">esc</kbd>
        to close
      </span>
    </p>
  </div>
</div>

<script define:vars={{ toolsJSON }}>
  window.__BOARDTOOLS_SEARCH_INDEX__ = JSON.parse(toolsJSON);
</script>

<script>
  // =============================================
  // GLOBAL SEARCH OVERLAY LOGIC
  // =============================================
  const overlay = document.getElementById('search-overlay');
  const overlayBackdrop = document.getElementById('search-overlay-backdrop');
  const overlayInput = document.getElementById('overlay-search-input') as HTMLInputElement | null;
  const overlayCloseBtn = document.getElementById('overlay-close-btn');
  const overlayHintState = document.getElementById('overlay-hint-state');
  const overlayResultsList = document.getElementById('overlay-results-list');
  const overlayNoResults = document.getElementById('overlay-no-results');
  const overlayRequestBtn = document.getElementById('overlay-request-tool-btn');
  const suggestionPills = document.querySelectorAll('.search-suggestion-pill');
  
  const tools: Array<{id: string, name: string, desc: string, category: string, path: string, icon: string, keywords: string}> = 
    (window as any).__BOARDTOOLS_SEARCH_INDEX__ || [];

  let overlayActiveIndex = -1;
  let overlayVisibleResults: HTMLElement[] = [];

  function openSearchOverlay() {
    if (!overlay) return;
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => overlayInput?.focus(), 50);
    overlayActiveIndex = -1;
  }

  function closeSearchOverlay() {
    if (!overlay) return;
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
    if (overlayInput) overlayInput.value = '';
    resetOverlayStates();
  }

  function resetOverlayStates() {
    overlayHintState?.classList.remove('hidden');
    overlayResultsList?.classList.add('hidden');
    overlayNoResults?.classList.add('hidden');
    if (overlayResultsList) overlayResultsList.innerHTML = '';
    overlayActiveIndex = -1;
    overlayVisibleResults = [];
  }

  function highlightMatch(text: string, query: string): string {
    if (!query) return text;
    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(regex, '<mark class="bg-brand-yellow/40 text-primary rounded-sm px-0.5">$1</mark>');
  }

  function renderOverlayResults(query: string) {
    if (!overlayResultsList || !overlayHintState || !overlayNoResults) return;
    
    if (!query.trim()) {
      resetOverlayStates();
      return;
    }

    const q = query.toLowerCase().trim();
    const matches = tools.filter(t => 
      t.name.toLowerCase().includes(q) || 
      t.keywords.toLowerCase().includes(q) || 
      t.desc.toLowerCase().includes(q) ||
      t.category.toLowerCase().includes(q)
    );

    overlayHintState.classList.add('hidden');

    if (matches.length > 0) {
      overlayNoResults.classList.add('hidden');
      overlayResultsList.classList.remove('hidden');
      
      // Group by category
      const grouped: Record<string, typeof matches> = {};
      matches.forEach(m => {
        if (!grouped[m.category]) grouped[m.category] = [];
        grouped[m.category].push(m);
      });

      let html = '';
      for (const [cat, items] of Object.entries(grouped)) {
        html += `<div class="px-5 pt-3 pb-1"><span class="text-[10px] font-bold text-stone uppercase tracking-wider">${cat}</span></div>`;
        items.forEach(item => {
          html += `
            <a href="${item.path}" class="overlay-result-item flex items-center gap-3 px-5 py-3 hover:bg-surface transition-colors cursor-pointer group" data-path="${item.path}">
              <span class="w-8 h-8 rounded-lg bg-surface border border-hairline flex items-center justify-center text-sm shrink-0 group-hover:border-brand-blue/30 transition-colors">${item.icon}</span>
              <div class="flex-1 min-w-0">
                <span class="text-sm font-display font-medium text-primary block truncate">${highlightMatch(item.name, query)}</span>
                <span class="text-[11px] text-stone block truncate">${highlightMatch(item.desc, query)}</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-hairline-strong group-hover:text-brand-blue shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>`;
        });
      }

      // Show match count
      html += `<div class="px-5 py-3 border-t border-hairline">
        <span class="text-[10px] text-stone">${matches.length} tool${matches.length !== 1 ? 's' : ''} found</span>
      </div>`;

      overlayResultsList.innerHTML = html;
      overlayVisibleResults = Array.from(overlayResultsList.querySelectorAll('.overlay-result-item'));
      overlayActiveIndex = -1;
    } else {
      overlayResultsList.classList.add('hidden');
      overlayNoResults.classList.remove('hidden');
      overlayVisibleResults = [];
      overlayActiveIndex = -1;
    }
  }

  function updateOverlayHighlight() {
    overlayVisibleResults.forEach((el, i) => {
      if (i === overlayActiveIndex) {
        el.classList.add('bg-surface');
        el.scrollIntoView({ block: 'nearest' });
      } else {
        el.classList.remove('bg-surface');
      }
    });
  }

  // Event: Search input
  overlayInput?.addEventListener('input', () => {
    renderOverlayResults(overlayInput.value);
  });

  // Event: Keyboard navigation
  overlayInput?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (overlayVisibleResults.length > 0) {
        overlayActiveIndex = Math.min(overlayActiveIndex + 1, overlayVisibleResults.length - 1);
        updateOverlayHighlight();
      }
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (overlayVisibleResults.length > 0) {
        overlayActiveIndex = Math.max(overlayActiveIndex - 1, 0);
        updateOverlayHighlight();
      }
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (overlayActiveIndex >= 0 && overlayVisibleResults[overlayActiveIndex]) {
        const href = overlayVisibleResults[overlayActiveIndex].getAttribute('href') || overlayVisibleResults[overlayActiveIndex].dataset.path;
        if (href) window.location.href = href;
      }
    }
  });

  // Event: Close button
  overlayCloseBtn?.addEventListener('click', closeSearchOverlay);

  // Event: Backdrop click
  overlayBackdrop?.addEventListener('click', closeSearchOverlay);

  // Event: Escape key (global)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay && !overlay.classList.contains('hidden')) {
      closeSearchOverlay();
    }
  });

  // Event: Suggestion pills
  suggestionPills.forEach(pill => {
    pill.addEventListener('click', () => {
      if (overlayInput) {
        overlayInput.value = pill.textContent?.trim() || '';
        renderOverlayResults(overlayInput.value);
        overlayInput.focus();
      }
    });
  });

  // Event: Request tool button — trigger the floating request popup
  overlayRequestBtn?.addEventListener('click', () => {
    closeSearchOverlay();
    // Trigger the existing RequestToolPopup
    const requestContainer = document.getElementById('floating-request-container');
    const requestCollapsed = document.getElementById('request-collapsed-bubble');
    const requestExpanded = document.getElementById('request-expanded-card');
    if (requestContainer && requestCollapsed && requestExpanded) {
      requestContainer.classList.remove('hidden');
      requestContainer.classList.add('flex');
      requestCollapsed.classList.add('hidden');
      requestExpanded.classList.remove('hidden');
      requestExpanded.classList.add('flex');
    }
  });

  // Event: Ctrl/Cmd+K shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (overlay?.classList.contains('hidden')) {
        openSearchOverlay();
      } else {
        closeSearchOverlay();
      }
    }
  });

  // Expose open function globally for navbar button
  (window as any).__openSearchOverlay = openSearchOverlay;
</script>
