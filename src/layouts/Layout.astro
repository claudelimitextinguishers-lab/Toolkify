---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequestToolPopup from '../components/RequestToolPopup.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	toolName?: string;
	toolCategory?: string;
	hideBanner?: boolean;
	keywords?: string;
	canonical?: string;
	ogImage?: string;
	ogType?: string;
}

const { 
	title = "TOOLKIFY - The Visual Workspace Tools Suite", 
	description = "A gorgeous Miro-inspired suite of client-side web utility tools including whiteboard, JSON formatter, contrast checker, base64 tool, and more. 100% private.",
	toolName,
	toolCategory,
	hideBanner = false,
	keywords,
	canonical,
	ogImage = "https://toolkify.com/og-default.png",
	ogType = "website"
} = Astro.props;

const siteName = "TOOLKIFY";
// Resolve a canonical URL: explicit prop wins, otherwise derive from the current request URL.
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? "https://toolkify.com").href;
const ogImageUrl = new URL(ogImage, Astro.site ?? "https://toolkify.com").href;
---
<!doctype html>
<html lang="en" class="h-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Theme Detection Script (blocking to prevent layout flash) -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph / Facebook -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={title} />
	</head>
	<body class="flex flex-col min-h-screen antialiased bg-canvas text-ink">
		<!-- Sticky Navigation Header -->
		<Header />

		<!-- Main content -->
		<main class="flex-grow flex flex-col">
			<slot />
		</main>

		<!-- Footer -->
		<Footer />

		<!-- Floating Request Tool Popup -->
		<RequestToolPopup />

		<!-- Activity Tracker for Workspace History -->
		<script is:inline define:vars={{ toolName, toolCategory }}>
			(() => {
				const path = window.location.pathname.replace(/\/$/, ""); // Strip trailing slash if present
				const normalizedPath = path === "" ? "/" : path;

				if (normalizedPath.startsWith('/tools/')) {
					const toolNameMap = {
						'/tools/whiteboard': 'Visual Whiteboard',
						'/tools/json-formatter': 'JSON Formatter',
						'/tools/base64-url': 'Base64 & URL Tool',
						'/tools/uuid-hash': 'UUID & Hash Gen',
						'/tools/contrast-checker': 'Contrast Checker',
						'/tools/svg-previewer': 'SVG Optimizer',
						'/tools/developer/name-generator': 'Name Generator'
					};
					const toolCategoryMap = {
						'/tools/whiteboard': 'collaboration',
						'/tools/json-formatter': 'developer',
						'/tools/base64-url': 'developer',
						'/tools/uuid-hash': 'developer',
						'/tools/contrast-checker': 'design',
						'/tools/svg-previewer': 'design',
						'/tools/developer/name-generator': 'developer'
					};
					const name = toolName || toolNameMap[normalizedPath];
					const category = toolCategory || toolCategoryMap[normalizedPath];
					if (name && category) {
						let recents = [];
						try {
							recents = JSON.parse(localStorage.getItem('recent_tools') || '[]');
						} catch (e) {}
						
						// Filter out this tool if already in list
						recents = recents.filter(t => t.path !== normalizedPath);
						// Prepend current tool
						recents.unshift({ name, path: normalizedPath, category, timestamp: Date.now() });
						// Limit to 4 recent tools
						recents = recents.slice(0, 4);
						localStorage.setItem('recent_tools', JSON.stringify(recents));
					}
				}
			})();
		</script>
	</body>
</html>
