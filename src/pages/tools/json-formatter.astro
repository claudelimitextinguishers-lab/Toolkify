---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="JSON Formatter, Validator & Minifier - BoardTools"
  description="Format, prettify, parse, and validate JSON inputs instantly. Free client-side tool with error line indicators and clipboard support."
>
  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-10 flex flex-col gap-6">
    <!-- Breadcrumb / Header -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
        <a href="/" class="hover:text-primary">Tools</a>
        <span>/</span>
        <span class="text-brand-blue">JSON Formatter</span>
      </div>
      <h1 class="font-display font-medium text-3xl tracking-tight text-primary">JSON Formatter & Validator</h1>
      <p class="text-sm text-slate">Format, beautify, validate, or minify raw JSON strings instantly in your browser.</p>
    </div>

    <!-- Interface Panel -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-stretch">
      <!-- Input Panel -->
      <div class="card-base flex flex-col gap-4 min-h-[400px]">
        <div class="flex items-center justify-between">
          <label for="json-input" class="font-display font-semibold text-sm text-primary flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Raw Input JSON
          </label>
          <div class="flex gap-2">
            <button id="btn-load-sample" class="text-xs text-brand-blue hover:underline cursor-pointer">Load Sample</button>
            <button id="btn-clear" class="text-xs text-stone hover:text-primary cursor-pointer">Clear</button>
          </div>
        </div>

        <textarea 
          id="json-input" 
          placeholder='Paste your raw JSON string here... e.g. {"name": "BoardTools", "version": 4}' 
          class="flex-grow w-full h-[350px] p-4 font-mono text-sm bg-surface-soft border border-hairline-strong rounded-lg outline-none focus:border-brand-blue"
        ></textarea>
      </div>

      <!-- Output Panel -->
      <div class="card-base flex flex-col gap-4 min-h-[400px]">
        <div class="flex items-center justify-between">
          <span class="font-display font-semibold text-sm text-primary flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-teal"></span>
            Formatted Output
          </span>
          <button 
            id="btn-copy" 
            class="button-secondary py-1 px-3 text-xs !rounded-md hover:bg-surface flex items-center gap-1.5 cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
            Copy
          </button>
        </div>

        <pre 
          id="json-output" 
          class="flex-grow w-full h-[350px] p-4 font-mono text-sm bg-surface border border-hairline rounded-lg overflow-auto select-all text-primary"
        ></pre>
      </div>
    </div>

    <!-- Quick Action Bar -->
    <div class="flex flex-wrap items-center justify-between gap-4 p-4 bg-surface rounded-xl border border-hairline">
      <div class="flex flex-wrap gap-2.5">
        <button 
          id="btn-beautify-2" 
          class="button-primary py-2 px-5 text-sm hover:button-primary-active cursor-pointer"
        >
          Format (2 Spaces)
        </button>
        <button 
          id="btn-beautify-4" 
          class="button-secondary py-2 px-5 text-sm hover:bg-canvas cursor-pointer"
        >
          Format (4 Spaces)
        </button>
        <button 
          id="btn-minify" 
          class="button-secondary py-2 px-5 text-sm hover:bg-canvas cursor-pointer"
        >
          Minify JSON
        </button>
      </div>

      <!-- Status Indicator -->
      <div id="validation-status" class="flex items-center gap-2 text-xs font-semibold">
        <!-- Will dynamically inject status tags -->
        <span class="bg-surface-yellow border border-yellow-light text-yellow-dark px-3 py-1 rounded-full">Waiting for input...</span>
      </div>
    </div>

    <!-- Detailed Validation Result Section -->
    <div id="error-panel" class="hidden card-base bg-brand-red/35 border-brand-red-dark flex-col gap-2">
      <h3 class="font-display font-semibold text-brand-red-dark text-sm">JSON Validation Error</h3>
      <p id="error-message" class="text-sm font-mono text-primary leading-relaxed"></p>
    </div>
  </section>
</Layout>

<script>
  const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement | null;
  const jsonOutput = document.getElementById('json-output');
  const errorPanel = document.getElementById('error-panel');
  const errorMessage = document.getElementById('error-message');
  const statusContainer = document.getElementById('validation-status');

  const btnClear = document.getElementById('btn-clear');
  const btnSample = document.getElementById('btn-load-sample');
  const btnCopy = document.getElementById('btn-copy');
  
  const btnBeautify2 = document.getElementById('btn-beautify-2');
  const btnBeautify4 = document.getElementById('btn-beautify-4');
  const btnMinify = document.getElementById('btn-minify');

  const sampleJSON = {
    appName: "BoardTools",
    version: "4.0.0",
    description: "Highly performant client-side toolbox suite.",
    features: [
      "Visual drawing board",
      "JSON structure checking",
      "URL Base64 conversion",
      "Contrast compliance rating"
    ],
    private: true,
    sandbox: {
      storage: "localStorage",
      offlineReady: true,
      encryption: null
    }
  };

  // Status updates
  function setStatus(type: 'idle' | 'success' | 'error', msg: string) {
    if (!statusContainer) return;
    
    if (type === 'idle') {
      statusContainer.innerHTML = `<span class="bg-surface-yellow border border-yellow-light text-yellow-dark px-3 py-1 rounded-full">${msg}</span>`;
      errorPanel?.classList.add('hidden');
    } else if (type === 'success') {
      statusContainer.innerHTML = `<span class="bg-success-accent/25 border border-success-accent text-moss-dark px-3 py-1 rounded-full">${msg}</span>`;
      errorPanel?.classList.add('hidden');
    } else if (type === 'error') {
      statusContainer.innerHTML = `<span class="bg-brand-red border border-brand-red-dark text-coral-dark px-3 py-1 rounded-full">${msg}</span>`;
      errorPanel?.classList.remove('hidden');
    }
  }

  // Formatting operations
  function processJSON(spaces: number | string) {
    if (!jsonInput || !jsonOutput) return;
    
    const value = jsonInput.value.trim();
    if (!value) {
      jsonOutput.textContent = '';
      setStatus('idle', 'Waiting for input...');
      return;
    }

    try {
      const parsed = JSON.parse(value);
      let formatted = '';
      
      if (spaces === 'minify') {
        formatted = JSON.stringify(parsed);
      } else {
        formatted = JSON.stringify(parsed, null, Number(spaces));
      }

      jsonOutput.textContent = formatted;
      setStatus('success', '✓ Valid JSON String');
    } catch (e: any) {
      jsonOutput.textContent = '';
      setStatus('error', '✗ Invalid JSON');
      if (errorMessage) {
        errorMessage.textContent = e.message || 'Unknown JSON formatting error.';
      }
    }
  }

  // Load sample data
  if (btnSample && jsonInput) {
    btnSample.addEventListener('click', () => {
      jsonInput.value = JSON.stringify(sampleJSON, null, 2);
      processJSON(2);
    });
  }

  // Clear data
  if (btnClear && jsonInput && jsonOutput) {
    btnClear.addEventListener('click', () => {
      jsonInput.value = '';
      jsonOutput.textContent = '';
      setStatus('idle', 'Waiting for input...');
    });
  }

  // Copy output clipboard
  if (btnCopy && jsonOutput) {
    btnCopy.addEventListener('click', () => {
      const text = jsonOutput.textContent || '';
      if (text) {
        navigator.clipboard.writeText(text).then(() => {
          const origHTML = btnCopy.innerHTML;
          btnCopy.innerHTML = '✓ Copied!';
          setTimeout(() => {
            btnCopy.innerHTML = origHTML;
          }, 1500);
        });
      }
    });
  }

  // Button hooks
  if (btnBeautify2) btnBeautify2.addEventListener('click', () => processJSON(2));
  if (btnBeautify4) btnBeautify4.addEventListener('click', () => processJSON(4));
  if (btnMinify) btnMinify.addEventListener('click', () => processJSON('minify'));

  // Live validator checking on input keyups
  if (jsonInput) {
    jsonInput.addEventListener('input', () => {
      // Run quick check without output formatting block
      const val = jsonInput.value.trim();
      if (!val) {
        if (jsonOutput) jsonOutput.textContent = '';
        setStatus('idle', 'Waiting for input...');
        return;
      }
      try {
        JSON.parse(val);
        setStatus('success', '✓ Valid JSON String');
      } catch (e: any) {
        setStatus('error', '✗ Invalid JSON');
        if (errorMessage) {
          errorMessage.textContent = e.message || 'Unknown JSON validation error.';
        }
      }
    });
  }
</script>
