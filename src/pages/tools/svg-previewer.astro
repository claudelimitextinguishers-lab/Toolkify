  // Pure SVG Optimizer Engine (Regular expression & DOM Parsing style)
  function optimizeSVG(svgText: string): string {
    let result = svgText;

    try {
      const parser = new DOMParser();
      const doc = parser.parseFromString(svgText, "image/svg+xml");
      const parserError = doc.querySelector("parsererror");
      if (parserError) return svgText; // Return unoptimized on error

      const svgNode = doc.documentElement;

      // 1. Comments & Metadata Cleaning
      if (optComments?.checked) {
        // XML Serializer strips doctypes/xml tags. Recursively strip comment nodes inside doc tree:
        const removeComments = (node: Node) => {
          let child = node.firstChild;
          while (child) {
            const next = child.nextSibling;
            if (child.nodeType === Node.COMMENT_NODE) {
              node.removeChild(child);
            } else if (child.nodeType === Node.ELEMENT_NODE) {
              removeComments(child);
            }
            child = next;
          }
        };
        removeComments(svgNode);

        // Remove typical metadata wrapper tags
        const metaTags = ["metadata", "desc", "title", "creator"];
        metaTags.forEach((tag) => {
          const els = svgNode.getElementsByTagName(tag);
          while (els.length > 0) {
            els[0].parentNode?.removeChild(els[0]);
          }
        });
      }

      // 2. Remove Hidden and Empty Elements
      if (optHidden?.checked) {
        const pruneTree = (element: Element) => {
          let child = element.firstElementChild;
          while (child) {
            const next = child.nextElementSibling;

            // Remove display="none"
            const display = child.getAttribute("display");
            const visibility = child.getAttribute("visibility");
            if (display === "none" || visibility === "hidden") {
              element.removeChild(child);
            } else {
              pruneTree(child);

              // Remove empty container groups (e.g. <g></g>)
              if (
                child.tagName.toLowerCase() === "g" &&
                child.children.length === 0 &&
                !child.hasAttribute("d")
              ) {
                element.removeChild(child);
              }
            }
            child = next;
          }
        };
        pruneTree(svgNode);

        // Second pass: recursively remove any newly-empty container groups from bottom up
        const cleanEmptyGroups = (element: Element) => {
          let child = element.firstElementChild;
          while (child) {
            const next = child.nextElementSibling;
            cleanEmptyGroups(child);
            if (
              child.tagName.toLowerCase() === "g" &&
              child.children.length === 0 &&
              !child.hasAttribute("d")
            ) {
              element.removeChild(child);
            }
            child = next;
          }
        };
        cleanEmptyGroups(svgNode);
      }

      // 3. Clean Inline CSS Styles (Styles attribute conversion)
      if (optStyles?.checked) {
        const convertStyles = (element: Element) => {
          const style = element.getAttribute("style");
          if (style) {
            const rules = style
              .split(";")
              .map((r) => r.trim())
              .filter(Boolean);
            rules.forEach((rule) => {
              const [prop, val] = rule.split(":").map((s) => s.trim());
              // Keep complex properties, but convert basic presentation attributes (fill, stroke, opacity)
              const allowedAttrs = [
                "fill",
                "stroke",
                "stroke-width",
                "stroke-linecap",
                "stroke-linejoin",
                "opacity",
                "display",
              ];
              if (prop && val && allowedAttrs.includes(prop)) {
                element.setAttribute(prop, val);
              }
            });
            element.removeAttribute("style");
          }
          // Recursively apply to kids
          for (let i = 0; i < element.children.length; i++) {
            convertStyles(element.children[i]);
          }
        };
        convertStyles(svgNode);
      }

      // 4. viewBox Adjustments
      if (optViewbox?.checked) {
        const w = svgNode.getAttribute("width");
        const h = svgNode.getAttribute("height");
        const viewbox = svgNode.getAttribute("viewBox");

        if (!viewbox && w && h) {
          const cleanW = parseFloat(w.replace(/[a-zA-Z]/g, ""));
          const cleanH = parseFloat(h.replace(/[a-zA-Z]/g, ""));
          if (!isNaN(cleanW) && !isNaN(cleanH)) {
            svgNode.setAttribute("viewBox", `0 0 ${cleanW} ${cleanH}`);
          }
        }
        // Remove redundant fixed size if viewBox exists
        if (svgNode.hasAttribute("viewBox")) {
          svgNode.removeAttribute("width");
          svgNode.removeAttribute("height");
        }
      }

      // Serialize back to raw XML
      const serializer = new XMLSerializer();
      result = serializer.serializeToString(doc);

      // 5. Precision optimization & path Minification via Regex
      const precisionVal = optPrecision?.value;
      if (precisionVal !== "keep") {
        const decimalPlaces = parseInt(precisionVal || "1", 10);
        // Match numbers, floating points, and coordinates inside 'd="..."', points="..."
        // Replace coordinates and floats to fixed decimal length
        const floatRegex = /(-?\d+\.\d+)/g;
        result = result.replace(floatRegex, (match) => {
          const val = parseFloat(match);
          return val.toFixed(decimalPlaces).replace(/\.0+$/, ""); // Remove trailing zero fractional components
        });
      }

      // Minify structural whitespace
      result = result.replace(/>\s+</g, "><").trim();
    } catch (e) {
      console.warn("Optimizer engine parser error: ", e);
    }

    return result;
  }

  // Update Size reduction metrics with a quick numbers ticking animations
  function updateStats(beforeSize: number, afterSize: number) {
    if (!statBeforeSize || !statAfterSize || !statPercentBadge) return;

    statBeforeSize.textContent = formatBytes(beforeSize);
    statAfterSize.textContent = formatBytes(afterSize);

    if (beforeSize === 0) {
      statPercentBadge.textContent = "0%";
      return;
    }

    const pct = Math.max(
      0,
      Math.round(((beforeSize - afterSize) / beforeSize) * 100),
    );

    // Ticking animation
    let current = 0;
    const interval = setInterval(() => {
      if (current >= pct) {
        statPercentBadge.textContent = `${pct}%`;
        clearInterval(interval);
      } else {
        current += Math.ceil((pct - current) / 4);
        statPercentBadge.textContent = `${current}%`;
      }
    }, 30);
  }

  function formatBytes(bytes: number): string {
    if (bytes === 0) return "0 B";
    const k = 1024;
    const sizes = ["B", "KB", "MB"];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + " " + sizes[i];
  }

  // Render original & optimized SVGs
  function renderSVGs() {
    if (!renderBefore || !renderAfter || !codeOutput) return;

    if (!originalCode) {
      renderBefore.innerHTML = `<span class="text-stone text-xs select-none">No input loaded</span>`;
      renderAfter.innerHTML = `<span class="text-stone text-xs select-none">Waiting...</span>`;
      codeOutput.textContent = "Select or paste an SVG file to optimize.";
      return;
    }

    // Single view rendering
    renderBefore.innerHTML = originalCode;
    renderAfter.innerHTML = optimizedCode;

    // Code preview rendering
    codeOutput.textContent = optimizedCode;

    // Add styles to scale preview svgs properly within the grid containers
    const beforeSVG = renderBefore.querySelector("svg");
    const afterSVG = renderAfter.querySelector("svg");

    if (beforeSVG)
      beforeSVG.setAttribute(
        "style",
        "max-width: 100%; max-height: 100%; object-fit: contain; width: 120px; height: 120px;",
      );
    if (afterSVG)
      afterSVG.setAttribute(
        "style",
        "max-width: 100%; max-height: 100%; object-fit: contain; width: 120px; height: 120px;",
      );

    syncWipeContent();
  }

  // Sync content into Wipe Layer slider
  function syncWipeContent() {
    if (!wipeBeforeContent || !wipeAfterContent) return;

    wipeBeforeContent.innerHTML = originalCode;
    wipeAfterContent.innerHTML = optimizedCode;

    const wBeforeSVG = wipeBeforeContent.querySelector("svg");
    const wAfterSVG = wipeAfterContent.querySelector("svg");

    if (wBeforeSVG)
      wBeforeSVG.setAttribute(
        "style",
        "max-width: 100%; max-height: 100%; object-fit: contain; width: 120px; height: 120px;",
      );
    if (wAfterSVG)
      wAfterSVG.setAttribute(
        "style",
        "max-width: 100%; max-height: 100%; object-fit: contain; width: 120px; height: 120px;",
      );
  }

  // Wipe slider logic drag/mouse interaction
  if (compareWipe) {
    let activeWipe = false;

    const moveSlider = (clientX: number) => {
      const rect = compareWipe.getBoundingClientRect();
      const x = Math.max(0, Math.min(clientX - rect.left, rect.width));
      const percentage = (x / rect.width) * 100;

      if (wipeHandle) wipeHandle.style.left = `${percentage}%`;
      if (wipeAfterLayer)
        wipeAfterLayer.style.clipPath = `polygon(${percentage}% 0, 100% 0, 100% 100%, ${percentage}% 100%)`;
    };

    compareWipe.addEventListener("mousedown", (e) => {
      activeWipe = true;
      moveSlider(e.clientX);
    });

    window.addEventListener("mousemove", (e) => {
      if (!activeWipe) return;
      moveSlider(e.clientX);
    });

    window.addEventListener("mouseup", () => {
      activeWipe = false;
    });

    // Touch events for mobile
    compareWipe.addEventListener("touchstart", (e) => {
      activeWipe = true;
      if (e.touches[0]) moveSlider(e.touches[0].clientX);
    });

    window.addEventListener("touchmove", (e) => {
      if (!activeWipe) return;
      if (e.touches[0]) moveSlider(e.touches[0].clientX);
    });

    window.addEventListener("touchend", () => {
      activeWipe = false;
    });
  }

  // Pixel Buffers Comparison for Diff warnings
  function detectVisualDiff() {
    if (!originalCode || !optimizedCode || !diffWarning) return;

    const imgOriginal = new Image();
    const imgOptimized = new Image();

    // Prepare SVG source blobs
    const blobOrig = new Blob([originalCode], { type: "image/svg+xml" });
    const blobOpt = new Blob([optimizedCode], { type: "image/svg+xml" });
    const urlOrig = URL.createObjectURL(blobOrig);
    const urlOpt = URL.createObjectURL(blobOpt);

    let loadedCount = 0;
    const compareCanvas = () => {
      loadedCount++;
      if (loadedCount < 2) return;

      const canvasWidth = 64;
      const canvasHeight = 64;

      const canvas1 = document.createElement("canvas");
      const canvas2 = document.createElement("canvas");
      canvas1.width = canvasWidth;
      canvas1.height = canvasHeight;
      canvas2.width = canvasWidth;
      canvas2.height = canvasHeight;

      const ctx1 = canvas1.getContext("2d");
      const ctx2 = canvas2.getContext("2d");

      if (ctx1 && ctx2) {
        ctx1.drawImage(imgOriginal, 0, 0, canvasWidth, canvasHeight);
        ctx2.drawImage(imgOptimized, 0, 0, canvasWidth, canvasHeight);

        const data1 = ctx1.getImageData(0, 0, canvasWidth, canvasHeight).data;
        const data2 = ctx2.getImageData(0, 0, canvasWidth, canvasHeight).data;

        let diffPixels = 0;
        // Compare every 4th element (RGBA) or pixel
        for (let i = 0; i < data1.length; i += 4) {
          const rDiff = Math.abs(data1[i] - data2[i]);
          const gDiff = Math.abs(data1[i + 1] - data2[i + 1]);
          const bDiff = Math.abs(data1[i + 2] - data2[i + 2]);
          const aDiff = Math.abs(data1[i + 3] - data2[i + 3]);

          if (rDiff > 20 || gDiff > 20 || bDiff > 20 || aDiff > 20) {
            diffPixels++;
          }
        }

        // Trigger warning if more than 2% of the pixels differ visual layout
        const tolerance = canvasWidth * canvasHeight * 0.02;
        if (diffPixels > tolerance) {
          diffWarning.classList.remove("hidden");
        } else {
          diffWarning.classList.add("hidden");
        }
      }

      // Cleanup
      URL.revokeObjectURL(urlOrig);
      URL.revokeObjectURL(urlOpt);
    };

    imgOriginal.onload = compareCanvas;
    imgOptimized.onload = compareCanvas;

    imgOriginal.src = urlOrig;
    imgOptimized.src = urlOpt;
  }

  // Update Batch UI queue
  function updateBatchQueueUI() {
    if (
      !batchQueueCount ||
      !batchTableBody ||
      !btnBatchDownload ||
      !batchTotalReduction ||
      !batchTotalSizeDiff
    )
      return;

    batchQueueCount.textContent = batchQueue.length.toString();

    if (batchQueue.length === 0) {
      batchTableBody.innerHTML = `
        <tr>
          <td colspan="5" class="py-6 text-center text-stone font-medium">No files uploaded yet. Drag & drop SVGs to begin.</td>
        </tr>
      `;
      btnBatchDownload.disabled = true;
      batchTotalReduction.textContent = "0%";
      batchTotalSizeDiff.textContent = "0 B saved";
      return;
    }

    btnBatchDownload.disabled = false;
    let totalBefore = 0;
    let totalAfter = 0;

    batchTableBody.innerHTML = "";
    batchQueue.forEach((file) => {
      totalBefore += file.originalSize;
      totalAfter += file.optimizedSize;

      const pct = Math.max(
        0,
        Math.round(
          ((file.originalSize - file.optimizedSize) / file.originalSize) * 100,
        ),
      );

      const tr = document.createElement("tr");
      tr.className = "border-b border-hairline-soft";
      tr.innerHTML = `
        <td class="py-3 font-medium text-primary max-w-xs truncate">${file.name}</td>
        <td class="py-3 text-center text-slate">${formatBytes(file.originalSize)}</td>
        <td class="py-3 text-center text-brand-teal font-semibold">${formatBytes(file.optimizedSize)}</td>
        <td class="py-3 text-center">
          <span class="bg-success-accent/15 text-moss-dark font-bold px-2 py-0.5 rounded-full text-[10px]">
            -${pct}%
          </span>
        </td>
        <td class="py-3 text-right">
          <button class="text-brand-blue font-semibold hover:underline cursor-pointer btn-single-batch-dl" data-id="${file.id}">
            Download
          </button>
        </td>
      `;
      batchTableBody.appendChild(tr);
    });

    // Setup action listener on dynamic table download button
    document.querySelectorAll(".btn-single-batch-dl").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const id = (e.target as HTMLElement).getAttribute("data-id");
        const file = batchQueue.find((f) => f.id === id);
        if (file) {
          const blob = new Blob([file.optimizedContent], {
            type: "image/svg+xml",
          });
          const url = URL.createObjectURL(blob);
          const link = document.createElement("a");
          link.download = `optimized_${file.name}`;
          link.href = url;
          link.click();
          URL.revokeObjectURL(url);
        }
      });
    });

    const totalPct = Math.max(
      0,
      Math.round(((totalBefore - totalAfter) / totalBefore) * 100),
    );
    batchTotalReduction.textContent = `${totalPct}%`;
    batchTotalSizeDiff.textContent = `${formatBytes(totalBefore - totalAfter)} saved total`;
  }

  // FAQ Accordion Toggle Interaction
  const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
  faqToggleButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      
      // Close other open accordions
      faqToggleButtons.forEach((otherBtn) => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute("aria-expanded", "false");
          const otherContent = otherBtn.nextElementSibling;
          if (otherContent) otherContent.classList.add("hidden");
          otherBtn.querySelector("svg")?.classList.remove("rotate-180");
        }
      });

      // Toggle current accordion
      btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
      const content = btn.nextElementSibling;
      if (content) {
        content.classList.toggle("hidden");
      }
      btn.querySelector("svg")?.classList.toggle("rotate-180");
    });
  });
</script>

<style>
  /* SVG custom Checkerboard Grid pattern for transparency renders */
  .checkered-grid {
    background-size: 16px 16px;
    background-image:
      linear-gradient(45deg, var(--color-surface) 25%, transparent 25%),
      linear-gradient(-45deg, var(--color-surface) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, var(--color-surface) 75%),
      linear-gradient(-45deg, transparent 75%, var(--color-surface) 75%);
    background-position:
      0 0,
      0 8px,
      8px -8px,
      -8px 0px;
  }
</style>
