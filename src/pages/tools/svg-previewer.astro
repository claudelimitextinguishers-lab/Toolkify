  function handleSingleFileUpload(file: File) {
    if (!file.name.endsWith(".svg")) {
      alert("Please upload a valid .svg vector file.");
      return;
    }
    const reader = new FileReader();
    reader.onload = (event) => {
      const text = event.target?.result as string;
      originalCode = text;
      if (svgInput) svgInput.value = text;
      triggerOptimization();
      scrollToOutput();
