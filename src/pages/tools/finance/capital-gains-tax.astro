    // Progressive calculation utility
    function calculateProgressive(
      taxable: number,
      brackets: { limit: number; rate: number }[],
    ) {
      let tax = 0;
      let prevLimit = 0;
      for (let b of brackets) {
        if (taxable > prevLimit) {
          const portion = Math.min(taxable, b.limit) - prevLimit;
          tax += portion * b.rate;
          prevLimit = b.limit;
        } else {
          break;
        }
      }
      return tax;
    }

