    // Calculation Engine
    function calculate() {
      currentBreakdownRows = [];

      // Clamp inputs to 0
      if (parseFloat(purchasePriceInput.value) < 0)
        purchasePriceInput.value = "0";
      if (parseFloat(salePriceInput.value) < 0) salePriceInput.value = "0";
      if (parseFloat(annualIncomeInput.value) < 0)
        annualIncomeInput.value = "0";
      if (parseFloat(improvementsInput.value) < 0)
        improvementsInput.value = "0";
      if (parseFloat(sellingFeesInput.value) < 0) sellingFeesInput.value = "0";

      const country = currencySelect.value;
      const purchasePrice = parseFloat(purchasePriceInput.value) || 0;
      const salePrice = parseFloat(salePriceInput.value) || 0;
      const improvements = parseFloat(improvementsInput.value) || 0;
      const sellingFees = parseFloat(sellingFeesInput.value) || 0;
      const annualIncome = parseFloat(annualIncomeInput.value) || 0;

      // Show warning if capital loss
      const capitalLossWarning = document.getElementById(
        "capital-loss-warning",
      );
      if (purchasePrice > salePrice) {
        if (capitalLossWarning) {
          capitalLossWarning.textContent =
            "Purchase price exceeds sale price: Capital loss detected (no tax owed).";
          capitalLossWarning.classList.add("block");
          capitalLossWarning.classList.remove("hidden");
        }
      } else {
        if (capitalLossWarning) {
          capitalLossWarning.classList.add("hidden");
          capitalLossWarning.classList.remove("block");
        }
      }

      let rawFilingStatus = filingStatusSelect.value;
      if (
        rawFilingStatus !== "single" &&
        rawFilingStatus !== "joint" &&
        rawFilingStatus !== "hoh"
      ) {
        rawFilingStatus = "single";
      }
      const filingStatus = rawFilingStatus as "single" | "joint" | "hoh";

      const totalBasis = purchasePrice + improvements;
      const netProceeds = salePrice - sellingFees;
      const grossGain = Math.max(0, netProceeds - totalBasis);

      // Dynamically set whatifSlider max
      whatifSlider.max = Math.max(salePrice * 3, 100000).toString();
      if (parseFloat(whatifSlider.value) > parseFloat(whatifSlider.max)) {
        whatifSlider.value = whatifSlider.max;
      }
      // NOTE: Calling updateWhatif() directly inside calculate() during initial load is safe even though
      // the what-if slider's input event listener hasn't been attached yet, since it's a direct function call.
      updateWhatif();

      let taxOwed = 0;
      let appliedBracket = "N/A";

      currentBreakdownRows.push(
        { label: "Sale Price", value: salePrice },
        { label: "Less: Selling Fees", value: sellingFees },
        { label: "Net Proceeds", value: netProceeds },
        { label: "Purchase Price", value: purchasePrice },
        { label: "Add: Improvements", value: improvements },
        { label: "Adjusted Basis Cost", value: totalBasis },
        { label: "Total Capital Gain", value: grossGain },
      );

      const breakdownRows = currentBreakdownRows;
      let bracketRows: { limit: string; rate: string }[] = [];
      let notes = "";

      // 1. UNITED STATES
      if (country === "USD") {
        const stateCode = stateSelect.value;
        const stateRate =
          stateCode !== "NONE" ? US_STATE_RATES[stateCode]?.rate || 0 : 0;

        let fedTax = 0;
        let niitTax = 0;

        if (!isHoldingLong) {
          // Short term stacked on ordinary income
          const ordinaryBrackets = US_FED_ORDINARY[filingStatus];
          const taxWithoutGain = calculateProgressive(
            annualIncome,
            ordinaryBrackets,
          );
          const taxWithGain = calculateProgressive(
            annualIncome + grossGain,
            ordinaryBrackets,
          );
          fedTax = Math.max(0, taxWithGain - taxWithoutGain);
          appliedBracket = "Short-Term Slabs";

          // Bracket visualization
          ordinaryBrackets.forEach((b) => {
            bracketRows.push({
              limit:
                b.limit === Infinity ? "Over" : `$${b.limit.toLocaleString()}`,
              rate: `${(b.rate * 100).toFixed(0)}%`,
            });
          });
        } else {
          // Long term stacked on ordinary income
          const ltcgBrackets = US_FED_LTCG[filingStatus];
          const combinedIncome = annualIncome + grossGain;

          let prevLimit = 0;

          for (let b of ltcgBrackets) {
            // Find portion of gain falling into this bracket
            // Slabs apply to combinedIncome
            const lowerBound = Math.max(annualIncome, prevLimit);
            const upperBound = Math.min(combinedIncome, b.limit);

            if (upperBound > lowerBound) {
              const portion = upperBound - lowerBound;
              fedTax += portion * b.rate;
            }
            prevLimit = b.limit;
          }
          appliedBracket = "Long-Term Preferential";

          ltcgBrackets.forEach((b) => {
            bracketRows.push({
              limit:
                b.limit === Infinity ? "Over" : `$${b.limit.toLocaleString()}`,
              rate: `${(b.rate * 100).toFixed(0)}%`,
            });
          });
        }

        // NIIT calculation
        let niitThreshold = 200000;
        if (filingStatus === "joint") {
          niitThreshold = 250000;
        }
        const magi = annualIncome + grossGain;
        if (magi > niitThreshold) {
          const excessMagi = magi - niitThreshold;
          const taxableNiitAmount = Math.min(grossGain, excessMagi);
          niitTax = taxableNiitAmount * 0.038;
        }

        const stateTax = grossGain * stateRate;
        taxOwed = fedTax + niitTax + stateTax;

        breakdownRows.push({
          label: "Federal Capital Gains Tax",
          value: fedTax,
        });
        if (niitTax > 0)
          breakdownRows.push({
            label: "Net Investment Income Tax (NIIT 3.8%)",
            value: niitTax,
          });
        if (stateTax > 0 && US_STATE_RATES[stateCode])
          breakdownRows.push({
            label: `${US_STATE_RATES[stateCode].name} State Tax`,
            value: stateTax,
          });

        notes = `State tax is calculated at a flat/marginal rate where applicable. NIIT triggers above $200k MAGI ($250k Joint).`;

        // 2. CANADA
      } else if (country === "CAD") {
        const provCode = stateSelect.value;
        const provData = CA_PROVINCES[provCode];
        let provBrackets = provData?.brackets;

        const warningEl = document.getElementById("province-warning");
        if (!provBrackets) {
          provBrackets = [];
          if (warningEl) {
            warningEl.textContent = `Warning: Missing tax bracket data for selected province/territory (${provCode}).`;
            warningEl.classList.add("block");
            warningEl.classList.remove("hidden");
          }
        } else {
          if (warningEl) {
            warningEl.classList.add("hidden");
            warningEl.classList.remove("block");
          }
        }

        // Canada 2024 new rules: 50% inclusion under $250k, 2/3 (66.67%) above $250k
        let taxableGain = 0;
        if (grossGain <= 250000) {
          taxableGain = grossGain * 0.5;
        } else {
          taxableGain = 250000 * 0.5 + (grossGain - 250000) * (2 / 3);
        }

        // Stacking taxable gain on ordinary income for Federal + Provincial tax
        const fedTaxWithout = calculateProgressive(
          annualIncome,
          CA_FED_BRACKETS,
        );
        const fedTaxWith = calculateProgressive(
          annualIncome + taxableGain,
          CA_FED_BRACKETS,
        );
        const fedTax = fedTaxWith - fedTaxWithout;

        const provTaxWithout = calculateProgressive(annualIncome, provBrackets);
        const provTaxWith = calculateProgressive(
          annualIncome + taxableGain,
          provBrackets,
        );
        const provTax = provTaxWith - provTaxWithout;

        taxOwed = fedTax + provTax;
        appliedBracket = `Avg Inclusion: ${((grossGain > 0 ? taxableGain / grossGain : 0.5) * 100).toFixed(1)}%`;

        breakdownRows.push({
          label: "Effective Taxable Gain (Included)",
          value: taxableGain,
        });
        breakdownRows.push({
          label: "Federal Income Tax on Gain",
          value: fedTax,
        });
        breakdownRows.push({
          label: "Provincial Income Tax on Gain",
          value: provTax,
        });

        CA_FED_BRACKETS.forEach((b) => {
          bracketRows.push({
            limit:
              b.limit === Infinity ? "Over" : `$${b.limit.toLocaleString()}`,
            rate: `${(b.rate * 100).toFixed(1)}%`,
          });
        });

        notes = `Canada taxes 50% of capital gains. Starting June 25, 2024, gains above $250,000 are subject to a 66.67% inclusion rate. Small business shares may qualify for the Lifetime Capital Gains Exemption (LCGE).`;

        // 3. UNITED KINGDOM
      } else if (country === "GBP") {
        // CGT allowance is Â£3,000
        const allowanceUsed = ukAllowanceCheckbox.checked;
        const allowance = allowanceUsed ? 0 : 3000;
        const taxableGain = Math.max(0, grossGain - allowance);

        const isRealEstate = selectedAsset === "real-estate";
        const primaryExempt = primaryResidenceCheckbox.checked;

        if (primaryExempt && isRealEstate) {
          taxOwed = 0;
          appliedBracket = "Private Residence Relief";
        } else {
          // Stacking on income to see basic/higher rate taxpayer threshold
          // Basic rate limit is Â£37,700 taxable (which corresponds to total income of Â£50,270 with Â£12,570 Personal Allowance)
          const taxableIncome = Math.max(0, annualIncome - 12570);
          const basicRateLimit = 37700;

          // Standard rates: 10% basic, 20% higher. Residential property: 18% basic, 24% higher
          const basicRate = isRealEstate ? 0.18 : 0.1;
          const higherRate = isRealEstate ? 0.24 : 0.2;

          let basicBandRemaining = Math.max(0, basicRateLimit - taxableIncome);

          let basicTaxable = Math.min(taxableGain, basicBandRemaining);
          let higherTaxable = Math.max(0, taxableGain - basicBandRemaining);

          taxOwed = basicTaxable * basicRate + higherTaxable * higherRate;
          appliedBracket =
            higherTaxable > 0
              ? "Higher Rate (20%/24%)"
              : "Basic Rate (10%/18%)";

          breakdownRows.push({
            label: "CGT Annual Allowance Offset",
            value: -allowance,
          });
          breakdownRows.push({ label: "Taxable Gain", value: taxableGain });
          if (basicTaxable > 0)
            breakdownRows.push({
              label: `Gain taxed at Basic Rate (${(basicRate * 100).toFixed(0)}%)`,
              value: basicTaxable * basicRate,
            });
          if (higherTaxable > 0)
            breakdownRows.push({
              label: `Gain taxed at Higher Rate (${(higherRate * 100).toFixed(0)}%)`,
              value: higherTaxable * higherRate,
            });

          bracketRows.push({
            limit: "Basic Rate Band",
            rate: `${(basicRate * 100).toFixed(0)}%`,
          });
          bracketRows.push({
            limit: "Higher/Additional",
            rate: `${(higherRate * 100).toFixed(0)}%`,
          });
        }

        notes = `UK allowance for 2024/25 is Â£3,000. Residential property CGT rates are 18% / 24% (reduced from 28% in 2024). Business Asset Disposal Relief (BADR) allows a flat 10% rate for qualifying shares.`;

        // 4. AUSTRALIA
      } else if (country === "AUD") {
        const isRealEstate = selectedAsset === "real-estate";
        const primaryExempt = primaryResidenceCheckbox.checked;

        if (primaryExempt && isRealEstate) {
          taxOwed = 0;
          appliedBracket = "Main Residence Exemption";
        } else {
          // 50% discount if held > 12 months
          const discountRate = isHoldingLong ? 0.5 : 1.0;
          const netTaxableGain = grossGain * discountRate;

          // Medicare levy: 2%
          const baseTaxWithout = calculateProgressive(annualIncome, AU_SLABS);
          const baseTaxWith = calculateProgressive(
            annualIncome + netTaxableGain,
            AU_SLABS,
          );
          const baseTax = baseTaxWith - baseTaxWithout;
          const medicareTax = netTaxableGain * 0.02;

          taxOwed = baseTax + medicareTax;
          appliedBracket = isHoldingLong
            ? "Discounted (50%) Slabs"
            : "Ordinary Income Slabs";

          breakdownRows.push({
            label: "CGT Holding Discount",
            value: isHoldingLong ? grossGain * 0.5 : 0,
          });
          breakdownRows.push({
            label: "Medicare Levy (2.0%)",
            value: medicareTax,
          });
          breakdownRows.push({ label: "Income Tax on Gain", value: baseTax });

          AU_SLABS.forEach((b) => {
            bracketRows.push({
              limit:
                b.limit === Infinity ? "Over" : `$${b.limit.toLocaleString()}`,
              rate: `${(b.rate * 100).toFixed(0)}%`,
            });
          });
        }

        notes = `Australia offers a 50% discount on capital gains for individuals holding assets for over 1 year. Net gain is added to taxable income and taxed at progressive tax rates + 2% Medicare levy. Note: Medicare Levy Surcharge is not modeled.`;

        // 5. EUROPE
      } else if (country === "EUR") {
        const ratePercent = parseFloat(euFlatRateSlider.value) || 25;
        const rateDecimal = ratePercent / 100;
        taxOwed = grossGain * rateDecimal;
        appliedBracket = `Flat Rate ${ratePercent}%`;

        breakdownRows.push({
          label: `European flat tax on gain`,
          value: taxOwed,
        });
        bracketRows.push({
          limit: "User-adjusted Flat Rate",
          rate: `${ratePercent}%`,
        });

        notes = `European capital gains tax rates vary widely by nation (e.g. Germany is ~26.375% Abgeltungsteuer, France is 30% flat tax). Adjust the slider to match your specific country.`;

        // 6. INDIA
      } else if (country === "INR") {
        let finalTax = 0;

        if (selectedAsset === "stocks" || selectedAsset === "funds") {
          // Equity / Equity Mutual Funds (Jul 2024 budget changes)
          if (!isHoldingLong) {
            finalTax = grossGain * 0.2; // Short Term Equity Flat 20%
            appliedBracket = "Equity STCG (20%)";
            breakdownRows.push({
              label: "Short Term Equity CG Tax (20%)",
              value: finalTax,
            });
          } else {
            // Long Term Equity 12.5% over â‚¹1.25L exemption
            const exemption = 125000;
            const taxableGain = Math.max(0, grossGain - exemption);
            finalTax = taxableGain * 0.125;
            appliedBracket = "Equity LTCG (12.5%)";
            breakdownRows.push({
              label: "LTCG Exemption (â‚¹1.25L)",
              value: Math.min(grossGain, exemption),
            });
            breakdownRows.push({
              label: "Long Term Equity CG Tax (12.5%)",
              value: finalTax,
            });
          }
        } else {
          // Real Estate / Debt / Others
          if (!isHoldingLong) {
            // Stack on ordinary income slabs
            const taxWithout = calculateProgressive(annualIncome, IN_SLABS);
            const taxWith = calculateProgressive(
              annualIncome + grossGain,
              IN_SLABS,
            );
            finalTax = taxWith - taxWithout;
            appliedBracket = "Slab Rates";
            breakdownRows.push({
              label: "Short Term Capital Slabs Tax",
              value: finalTax,
            });
          } else {
            // Long term Real Estate or Debt
            if (
              selectedAsset === "real-estate" &&
              inIndexationCheckbox.checked
            ) {
              // Pre-July 2024 assets option: 20% with indexation
              const factor = parseFloat(indexationMultiplier.value) || 1.0;
              const indexedBasis = totalBasis * factor;
              const indexedGain = Math.max(0, netProceeds - indexedBasis);
              finalTax = indexedGain * 0.2;
              appliedBracket = "LTCG 20% (Indexed)";
              breakdownRows.push({
                label: "Indexed Cost Basis",
                value: indexedBasis,
              });
              breakdownRows.push({
                label: "Indexed Capital Gain",
                value: indexedGain,
              });
              breakdownRows.push({
                label: "Tax at 20% with indexation",
                value: finalTax,
              });
            } else {
              // Standard post-July 2024 LTCG: 12.5% flat without indexation
              finalTax = grossGain * 0.125;
              appliedBracket = "LTCG 12.5% (Flat)";
              breakdownRows.push({
                label: "Long Term CG Tax (12.5%)",
                value: finalTax,
              });
            }
          }
        }

        // Add 4% Cess
        const cess = finalTax * 0.04;
        taxOwed = finalTax + cess;

        breakdownRows.push({
          label: "Health & Education Cess (4%)",
          value: cess,
        });

        IN_SLABS.forEach((b) => {
          bracketRows.push({
            limit:
              b.limit === Infinity
                ? "Over"
                : `â‚¹${b.limit.toLocaleString("en-IN")}`,
            rate: `${(b.rate * 100).toFixed(0)}%`,
          });
        });

        notes = `India budget 2024: Equity STCG is 20%, LTCG is 12.5% (with exemption up to â‚¹1.25L). Real estate LTCG is 12.5% without indexation (taxpayers can choose 20% with indexation for pre-Jul 2024 assets). Flat 4% cess applies.`;

        // 7. CUSTOM
      } else {
        // Simple default calculation
        taxOwed = grossGain * (isHoldingLong ? 0.15 : 0.25);
        appliedBracket = isHoldingLong
          ? "Custom LTCG (15%)"
          : "Custom STCG (25%)";
        breakdownRows.push({
          label: "Custom capital gains tax estimate",
          value: taxOwed,
        });
        notes =
          "Custom calculation uses a basic flat rate assumption (STCG: 25%, LTCG: 15%). Customize symbols in the advanced options.";
      }

      // Net profit after tax
      const netProfit = grossGain - taxOwed;
      const effectiveRate = grossGain > 0 ? (taxOwed / grossGain) * 100 : 0;
      currentEffectiveRateFraction = grossGain > 0 ? taxOwed / grossGain : 0;

      // Update Outputs
      if (taxOwedDisplay) taxOwedDisplay.textContent = formatCurrency(taxOwed);
      if (netProfitDisplay)
        netProfitDisplay.textContent = formatCurrency(netProfit);
      if (effectiveRateDisplay)
        effectiveRateDisplay.textContent = `${effectiveRate.toFixed(1)}%`;
      if (appliedBracketDisplay)
        appliedBracketDisplay.textContent = appliedBracket;

      const mobileVal = document.getElementById("mobile-summary-value");
      if (mobileVal) mobileVal.textContent = formatCurrency(taxOwed);

      // Donut SVG updates
      if (legendBasisVal)
        legendBasisVal.textContent = formatCurrency(totalBasis);
      if (legendTaxVal) legendTaxVal.textContent = formatCurrency(taxOwed);
      if (legendProfitVal)
        legendProfitVal.textContent = formatCurrency(netProfit);

      const totalValForChart = totalBasis + taxOwed + netProfit;
      if (totalValForChart > 0) {
        const basisPercent = (totalBasis / totalValForChart) * 100;
        const taxPercent = (taxOwed / totalValForChart) * 100;
        const profitPercent = (netProfit / totalValForChart) * 100;

        let accumOffset = 0;
        let svgHtml = "";

        // Cost segment (Basis)
        const costStroke = 2 * Math.PI * 40 * (basisPercent / 100);
        svgHtml += `<circle cx="50" cy="50" r="40" stroke="rgb(209, 213, 219)" stroke-width="12" stroke-dasharray="${costStroke} ${251.2 - costStroke}" stroke-dashoffset="-${accumOffset}" fill="transparent"></circle>`;
        accumOffset += costStroke;

        // Tax segment
        const taxStroke = 2 * Math.PI * 40 * (taxPercent / 100);
        svgHtml += `<circle cx="50" cy="50" r="40" stroke="var(--color-brand-coral)" stroke-width="12" stroke-dasharray="${taxStroke} ${251.2 - taxStroke}" stroke-dashoffset="-${accumOffset}" fill="transparent"></circle>`;
        accumOffset += taxStroke;

        // Profit segment
        const profitStroke = 2 * Math.PI * 40 * (profitPercent / 100);
        svgHtml += `<circle cx="50" cy="50" r="40" stroke="var(--color-success-accent)" stroke-width="12" stroke-dasharray="${profitStroke} ${251.2 - profitStroke}" stroke-dashoffset="-${accumOffset}" fill="transparent"></circle>`;

        if (donutSegments) donutSegments.innerHTML = svgHtml;
        if (donutPercent)
          donutPercent.textContent = `${profitPercent.toFixed(0)}%`;
      }

      // Populate breakdown table
      if (breakdownTableBody) {
        let tableHtml = "";
        breakdownRows.forEach((row) => {
          tableHtml += `
            <tr class="border-b border-hairline-soft hover:bg-surface-soft">
              <td class="py-2.5 px-3 text-slate font-medium">${row.label}</td>
              <td class="py-2.5 px-3 text-right font-bold text-primary">${formatCurrency(row.value)}</td>
            </tr>
          `;
        });
        breakdownTableBody.innerHTML = tableHtml;
      }

      // Populate reference brackets table
      if (refBracketsTbody) {
        if (bracketRows.length === 0) {
          refBracketsTbody.innerHTML = `<tr><td colspan="2" class="py-3 text-center text-stone">Flat tax rate structure. No brackets.</td></tr>`;
        } else {
          let bHtml = "";
          bracketRows.forEach((r) => {
            bHtml += `
              <tr class="border-b border-hairline-soft hover:bg-surface-soft">
                <td class="py-2 px-2.5 text-slate">${r.limit}</td>
                <td class="py-2 px-2.5 text-right font-bold text-primary">${r.rate}</td>
              </tr>
            `;
          });
          refBracketsTbody.innerHTML = bHtml;
        }
      }

      if (refBracketsTitle) {
        refBracketsTitle.textContent = `${country} Reference Brackets`;
      }

      if (countryNotesBox) {
        countryNotesBox.innerHTML = `
          <div class="card-feature-teal !p-3 !rounded-lg text-[11px] flex flex-col gap-1.5">
            <span class="font-bold text-moss-dark">Taxation Note Summary:</span>
            <span class="text-slate leading-relaxed">${notes}</span>
          </div>
        `;
      }

      // Save state to localStorage (debounced)
      saveState();
    }

    // Slider for What-If
    function updateWhatif() {
      const whatifVal = parseFloat(whatifSlider.value) || 0;
      if (whatifPriceDisplay)
        whatifPriceDisplay.textContent = formatCurrency(whatifVal);

      // Re-run simplified calculation logic for what-if
      const purchasePrice = parseFloat(purchasePriceInput.value) || 0;
      const improvements = parseFloat(improvementsInput.value) || 0;
      const sellingFees = parseFloat(sellingFeesInput.value) || 0;
      const totalBasis = purchasePrice + improvements;
      const netProceeds = whatifVal - sellingFees;
      const grossGain = Math.max(0, netProceeds - totalBasis);

      const estimatedTax = grossGain * currentEffectiveRateFraction;
      const estimatedProfit = grossGain - estimatedTax;

      if (whatifTax) whatifTax.textContent = formatCurrency(estimatedTax);
      if (whatifProfit)
        whatifProfit.textContent = formatCurrency(estimatedProfit);
    }

    function exportToCSV() {
      if (currentBreakdownRows.length === 0) return;
      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Item / Category,Value\r\n";

      currentBreakdownRows.forEach((row) => {
        csvContent += `"${row.label.replace(/"/g, '""')}",${row.value.toFixed(2)}\r\n`;
      });

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute(
        "download",
        `Capital_Gains_Tax_Breakdown_${Date.now()}.csv`,
      );
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    function exportToExcel() {
      if (currentBreakdownRows.length === 0) return;

      const isUnsupported = /MSIE|Trident|Edge\/\d./i.test(navigator.userAgent);
      if (isUnsupported) {
        console.warn(
          "Excel export might have limited compatibility on this browser. CSV export is recommended as a fallback.",
        );
      }

      let tableRows = "";
      currentBreakdownRows.forEach((row) => {
        tableRows += `
          <tr>
            <td>${row.label}</td>
            <td>${row.value.toFixed(2)}</td>
          </tr>
        `;
      });

      const html = `
        <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
        <head>
          <!--[if gte mso 9]>
          <xml>
            <x:ExcelWorkbook>
              <x:ExcelWorksheets>
                <x:ExcelWorksheet>
                  <x:Name>CGT Breakdown</x:Name>
                  <x:WorksheetOptions>
                    <x:DisplayGridlines/>
                  </x:WorksheetOptions>
                </x:ExcelWorksheet>
              </x:ExcelWorksheets>
            </x:ExcelWorkbook>
          </xml>
          <![endif]-->
          <style>
            table { border-collapse: collapse; }
            th, td { border: 1px solid #e2e8f0; padding: 8px; font-family: sans-serif; font-size: 12px; }
            th { background-color: #f7fafc; font-weight: bold; }
          </style>
        </head>
        <body>
          <table>
            <tr style="background-color: #f7fafc; font-weight: bold;">
              <td>Item / Category</td>
              <td>Value</td>
            </tr>
            ${tableRows}
          </table>
        </body>
        </html>
      `;

      const blob = new Blob([html], { type: "application/vnd.ms-excel" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `Capital_Gains_Tax_Breakdown_${Date.now()}.xls`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    // Save/Load state
    let saveStateTimeout: any = null;
    function saveState() {
      if (saveStateTimeout) clearTimeout(saveStateTimeout);
      saveStateTimeout = setTimeout(() => {
        if (typeof localStorage === "undefined") return;
        try {
          localStorage.setItem("cgt_country", currencySelect.value);
          localStorage.setItem("cgt_purchase_price", purchasePriceInput.value);
          localStorage.setItem("cgt_sale_price", salePriceInput.value);
          localStorage.setItem("cgt_income", annualIncomeInput.value);
          localStorage.setItem("cgt_holding_long", isHoldingLong.toString());
          localStorage.setItem("cgt_asset", selectedAsset);
          localStorage.setItem("cgt_purchase_date", purchaseDateInput.value);
          localStorage.setItem("cgt_sale_date", saleDateInput.value);
          localStorage.setItem("cgt_improvements", improvementsInput.value);
          localStorage.setItem("cgt_selling_fees", sellingFeesInput.value);
          localStorage.setItem("cgt_filing", filingStatusSelect.value);
          localStorage.setItem("cgt_state", stateSelect.value);
          localStorage.setItem("cgt_eu_flat_rate", euFlatRateSlider.value);
          localStorage.setItem(
            "cgt_custom_currency_symbol",
            customCurrencySymbolInput.value,
          );
          localStorage.setItem(
            "cgt_custom_currency_code",
            customCurrencyCodeInput.value,
          );
        } catch (e) {
          console.warn("localStorage save failed", e);
        }
      }, 400);
    }

    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const getSafeItem = (key: string, defaultValue: string = ""): string => {
        const paramKey = key.replace("cgt_", "");
        if (urlParams.has(paramKey)) {
          return urlParams.get(paramKey) || defaultValue;
        }
        if (typeof localStorage === "undefined") return defaultValue;
        try {
          return localStorage.getItem(key) || defaultValue;
        } catch (e) {
          return defaultValue;
        }
      };

      try {
        const country = getSafeItem("cgt_country");
        if (!country) return false;
        currencySelect.value = country;

        const asset = getSafeItem("cgt_asset", "stocks");
        selectedAsset = asset;

        // Populate options first
        updateLayoutForCountry();

        const state = getSafeItem("cgt_state");
        if (state && stateSelect) stateSelect.value = state;

        purchasePriceInput.value = getSafeItem("cgt_purchase_price", "10000");
        salePriceInput.value = getSafeItem("cgt_sale_price", "25000");
        annualIncomeInput.value = getSafeItem("cgt_income", "75000");

        const long = getSafeItem("cgt_holding_long");
        if (long) toggleHolding(long === "true");

        purchaseDateInput.value = getSafeItem("cgt_purchase_date", "");
        saleDateInput.value = getSafeItem("cgt_sale_date", "");
        improvementsInput.value = getSafeItem("cgt_improvements", "0");
        sellingFeesInput.value = getSafeItem("cgt_selling_fees", "0");
        filingStatusSelect.value = getSafeItem("cgt_filing", "single");

        euFlatRateSlider.value = getSafeItem("cgt_eu_flat_rate", "25");
        if (euFlatRateDisplay)
          euFlatRateDisplay.textContent = `${euFlatRateSlider.value}%`;
        customCurrencySymbolInput.value = getSafeItem("cgt_custom_currency_symbol", "$");
        customCurrencyCodeInput.value = getSafeItem("cgt_custom_currency_code", "USD");

        updateAssetSelection(selectedAsset);
        return true;
      } catch (e) {
        console.warn("localStorage load failed", e);
        return false;
      }
    }

    // Scroll offset utility
    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition =
        element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth",
      });
    }

    // Setup event listeners
    window.addEventListener("DOMContentLoaded", () => {
      // Asset preset selection
      document.querySelectorAll(".asset-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const asset = btn.getAttribute("data-asset") || "stocks";
          updateAssetSelection(asset);
        });
      });

      // Inputs
      [
        purchasePriceInput,
        salePriceInput,
        annualIncomeInput,
        improvementsInput,
        sellingFeesInput,
        filingStatusSelect,
        stateSelect,
        indexationMultiplier,
      ].forEach((input) => {
        input?.addEventListener("input", calculate);
        input?.addEventListener("change", calculate);
      });

      // Checkboxes
      [
        ukAllowanceCheckbox,
        primaryResidenceCheckbox,
        inIndexationCheckbox,
      ].forEach((box) => {
        box?.addEventListener("change", calculate);
      });

      inIndexationCheckbox?.addEventListener("change", () => {
        if (inIndexationCheckbox.checked) {
          indexationFactorsContainer?.classList.remove("hidden");
        } else {
          indexationFactorsContainer?.classList.add("hidden");
        }
      });

      // Holding period toggles
      holdingShortBtn?.addEventListener("click", () => {
        toggleHolding(false);
        calculate();
      });
      holdingLongBtn?.addEventListener("click", () => {
        toggleHolding(true);
        calculate();
      });

      // Dates
      purchaseDateInput.addEventListener("change", () => {
        syncDatesAndHolding();
        calculate();
      });
      saleDateInput.addEventListener("change", () => {
        syncDatesAndHolding();
        calculate();
      });

      // Country selector
      currencySelect.addEventListener("change", () => {
        updateLayoutForCountry();
        calculate();
      });

      customCurrencySymbolInput.addEventListener("input", () => {
        updateCurrencySymbols();
        calculate();
      });
      customCurrencyCodeInput.addEventListener("input", () => {
        updateCurrencySymbols();
        calculate();
      });

      // EU Rate Slider
      euFlatRateSlider.addEventListener("input", () => {
        if (euFlatRateDisplay)
          euFlatRateDisplay.textContent = `${euFlatRateSlider.value}%`;
        calculate();
      });

      // Advanced Toggle
      advancedToggleBtn?.addEventListener("click", () => {
        if (advancedPanel) {
          const isCollapsed = advancedPanel.classList.contains("max-h-0");
          if (isCollapsed) {
            advancedPanel.classList.remove("max-h-0");
            advancedPanel.classList.add("max-h-[2000px]");
            advancedChevron?.classList.add("rotate-180");
          } else {
            advancedPanel.classList.remove("max-h-[2000px]");
            advancedPanel.classList.add("max-h-0");
            advancedChevron?.classList.remove("rotate-180");
          }
        }
      });

      // What-if price analysis
      whatifSlider.addEventListener("input", updateWhatif);

      let copyTimeout: any = null;
      let copyOriginalText = "";

      // Copy results
      copyResultsBtn?.addEventListener("click", () => {
        const text =
          `Capital Gains Tax Calculation Results:\n` +
          `Asset: ${selectedAsset.toUpperCase()}\n` +
          `Purchase Price: ${purchasePriceInput.value}\n` +
          `Sale Price: ${salePriceInput.value}\n` +
          `Gain: ${formatCurrency(Math.max(0, parseFloat(salePriceInput.value) - parseFloat(purchasePriceInput.value)))}\n` +
          `Tax Owed: ${taxOwedDisplay?.textContent}\n` +
          `Net Profit: ${netProfitDisplay?.textContent}\n` +
          `Effective Tax Rate: ${effectiveRateDisplay?.textContent}`;
        navigator.clipboard.writeText(text);

        // Visual feedback
        if (copyTimeout) {
          clearTimeout(copyTimeout);
        } else {
          // NOTE: copyOriginalText only captures the icon's HTML once and won't reflect later changes to the SVG icon string
          copyOriginalText = copyResultsBtn.innerHTML;
        }
        copyResultsBtn.innerHTML = `<span>âœ“ Copied!</span>`;
        copyTimeout = setTimeout(() => {
          copyResultsBtn.innerHTML = copyOriginalText;
          copyTimeout = null;
        }, 2000);
      });

      // Reset
      resetBtn?.addEventListener("click", () => {
        if (typeof localStorage !== "undefined") {
          try {
            [
              "country",
              "purchase_price",
              "sale_price",
              "income",
              "holding_long",
              "asset",
              "purchase_date",
              "sale_date",
              "improvements",
              "selling_fees",
              "filing",
              "state",
              "eu_flat_rate",
              "custom_currency_symbol",
              "custom_currency_code",
            ].forEach((k) => localStorage.removeItem("cgt_" + k));
          } catch (e) {}
        }
        purchasePriceInput.value = "10000";
        salePriceInput.value = "25000";
        annualIncomeInput.value = "75000";
        purchaseDateInput.value = "";
        saleDateInput.value = "";
        improvementsInput.value = "0";
        sellingFeesInput.value = "0";
        filingStatusSelect.value = "single";
        currencySelect.value = "USD";
        ukAllowanceCheckbox.checked = false;
        primaryResidenceCheckbox.checked = false;
        inIndexationCheckbox.checked = false;
        euFlatRateSlider.value = "25";
        customCurrencySymbolInput.value = "$";
        customCurrencyCodeInput.value = "USD";

        toggleHolding(false);
        updateLayoutForCountry();
        updateAssetSelection("stocks");
      });

      // Scroll to results binding
      scrollToResultsBtn?.addEventListener("click", () => {
        scrollToElementWithOffset("detailed-breakdown-heading", 80);
      });

      const mobileScrollBtn = document.getElementById(
        "mobile-scroll-results-btn",
      );
      mobileScrollBtn?.addEventListener("click", () => {
        scrollToElementWithOffset("estimated-tax-card", 80);
      });

      // Export buttons listeners
      csvExportBtn?.addEventListener("click", exportToCSV);
      excelExportBtn?.addEventListener("click", exportToExcel);

      // Help Modal
      howItWorksBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.remove("hidden"),
      );
      closeModalBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.add("hidden"),
      );
      modalOkBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.add("hidden"),
      );

      // Share button copy link logic
      const shareBtn = document.getElementById("share-btn");
      shareBtn?.addEventListener("click", () => {
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set("country", currencySelect.value);
        url.searchParams.set("asset", selectedAsset);
        if (stateSelect) url.searchParams.set("state", stateSelect.value);
        url.searchParams.set("purchase_price", purchasePriceInput.value);
        url.searchParams.set("sale_price", salePriceInput.value);
        url.searchParams.set("income", annualIncomeInput.value);
        url.searchParams.set("holding_long", isHoldingLong ? "true" : "false");
        url.searchParams.set("purchase_date", purchaseDateInput.value);
        url.searchParams.set("sale_date", saleDateInput.value);
        url.searchParams.set("improvements", improvementsInput.value);
        url.searchParams.set("selling_fees", sellingFeesInput.value);
        url.searchParams.set("filing", filingStatusSelect.value);
        url.searchParams.set("eu_flat_rate", euFlatRateSlider.value);
        url.searchParams.set("custom_currency_symbol", customCurrencySymbolInput.value);
        url.searchParams.set("custom_currency_code", customCurrencyCodeInput.value);

        const shareData = {
          title: document.title || "Toolkify",
          url: url.toString()
        };

        if (navigator.share) {
          navigator.share(shareData).catch((err) => {
            if (err.name !== "AbortError") {
              copyToClipboard(url.toString());
            }
          });
        } else {
          copyToClipboard(url.toString());
        }

        function copyToClipboard(text: string) {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
          } else {
            fallbackCopy(text);
          }
        }

        function fallbackCopy(text: string) {
          const textArea = document.createElement("textarea");
          textArea.value = text;
          textArea.style.position = "fixed";
          textArea.style.opacity = "0";
          document.body.appendChild(textArea);
          textArea.select();
          try {
            document.execCommand("copy");
            showSuccess();
          } catch (err) {
            console.error(err);
          }
          document.body.removeChild(textArea);
        }

        function showSuccess() {
          if (shareBtn) {
            const span = shareBtn.querySelector("span");
            if (span) {
              const originalText = span.textContent || "Share";
              span.textContent = "Link Copied!";
              shareBtn.classList.add("text-success-accent", "border-success-accent");
              setTimeout(() => {
                span.textContent = originalText;
                shareBtn.classList.remove("text-success-accent", "border-success-accent");
              }, 2000);
            }
          }
        }
      });
      howItWorksModal?.addEventListener("click", (e) => {
        if (e.target === howItWorksModal) {
          howItWorksModal.classList.add("hidden");
        }
      });

      // Mobile sticky bar scroll sync
      const mobileStickyBar = document.getElementById("mobile-sticky-bar");
      const estimatedTaxCard = document.getElementById("estimated-tax-card");
      if (mobileStickyBar && estimatedTaxCard) {
        const handleScroll = () => {
          const rect = estimatedTaxCard.getBoundingClientRect();
          // Vanish when reached the estimated tax card (120px offset to account for navbar)
          if (rect.top <= 120) {
            mobileStickyBar.style.transform = "translateY(100%)";
          } else {
            mobileStickyBar.style.transform = "translateY(0)";
          }
        };
        window.addEventListener("scroll", handleScroll);
        handleScroll();
      }

      // FAQ Accordion Toggle Interaction
      const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
      faqToggleButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const expanded = btn.getAttribute("aria-expanded") === "true";
          
          // Close other open accordions
          faqToggleButtons.forEach((otherBtn) => {
            if (otherBtn !== btn) {
              otherBtn.setAttribute("aria-expanded", "false");
              const otherContent = otherBtn.nextElementSibling;
              if (otherContent) otherContent.classList.add("hidden");
              otherBtn.querySelector("svg")?.classList.remove("rotate-180");
            }
          });

          // Toggle current accordion
          btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
          const content = btn.nextElementSibling;
          if (content) {
            content.classList.toggle("hidden");
          }
          btn.querySelector("svg")?.classList.toggle("rotate-180");
        });
      });

      // Initial execution
      const restored = loadState();
      if (!restored) {
        updateLayoutForCountry();
        updateAssetSelection("stocks");
      }
    });
  </script>
</Layout>
