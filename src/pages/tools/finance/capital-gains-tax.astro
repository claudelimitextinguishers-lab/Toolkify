---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Capital Gains Tax Estimator";
const category = "finance";
const tier = "Finance & Tax";
const description =
  "Estimate capital gains taxes on profits from stocks, crypto, or real estate sales across multiple countries.";
---

<Layout
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Capital Gains Tax Estimator",
      "url": "/tools/finance/capital-gains-tax",
      "description": "Calculate capital gains taxes dynamically for stocks, crypto, or real estate. Supports U.S. ordinary/NIIT rates, Canada inclusion limits, UK allowances, Australia discounts, and India STCG/LTCG rules.",
      "applicationCategory": "FinancialApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section
    class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-6 flex flex-col gap-6 animate-fade-in-up pb-24 lg:pb-12"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-2">
      <nav
        class="flex items-center gap-1.5 text-xs font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-wrap items-center gap-3 mt-1">
        <h1
          class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-primary"
        >
          {name}
        </h1>
        <span
          class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-xs py-1 px-3 self-center rounded-full font-semibold uppercase"
          >{tier}</span
        >

        <button
          type="button"
          id="how-it-works-btn"
          class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle self-center animate-pulse"
          aria-label="How capital gains tax estimator works"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          <span>How it works</span>
        </button>
      </div>
      <p class="text-sm text-slate max-w-xl">
        {description}
      </p>
    </div>

    <!-- Mode / Toolbar (Pill Style) -->
    <div class="flex items-center justify-start border-b border-hairline pb-3">
      <button
        type="button"
        id="reset-btn"
        class="inline-flex items-center gap-1 text-xs font-semibold px-3.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3 h-3"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
          ></path>
        </svg>
        <span>Reset</span>
      </button>
    </div>

    <!-- Custom Currency Overlay (Hidden by default) -->
    <div
      id="custom-currency-container"
      class="grid grid-cols-2 gap-3 p-4 bg-surface rounded-xl border border-hairline hidden animate-fade-in-up"
    >
      <div class="flex flex-col gap-1.5">
        <label
          for="custom-currency-symbol"
          class="text-[10px] font-semibold text-slate">Currency Symbol</label
        >
        <input
          type="text"
          id="custom-currency-symbol"
          value="$"
          class="text-input"
          placeholder="e.g. $, £, €, ₹"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label
          for="custom-currency-code"
          class="text-[10px] font-semibold text-slate">Currency Code</label
        >
        <input
          type="text"
          id="custom-currency-code"
          value="USD"
          class="text-input"
          placeholder="e.g. USD, GBP, EUR"
        />
      </div>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left: Interactive Form (7 Columns) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="card-base flex flex-col gap-5">
          <h2
            class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2"
          >
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Asset & Profit details
          </h2>

          <!-- Asset Type preset buttons -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal">Asset Type</label
            >
            <div
              id="asset-type-container"
              class="grid grid-cols-2 sm:grid-cols-5 gap-2"
            >
              <button
                type="button"
                data-asset="stocks"
                class="asset-btn text-xs py-2 rounded-xl font-semibold border border-hairline bg-surface text-primary hover:bg-canvas transition-all active:scale-95"
                >📈 Stocks</button
              >
              <button
                type="button"
                data-asset="crypto"
                class="asset-btn text-xs py-2 rounded-xl font-semibold border border-hairline bg-surface text-primary hover:bg-canvas transition-all active:scale-95"
                >🪙 Crypto</button
              >
              <button
                type="button"
                data-asset="real-estate"
                class="asset-btn text-xs py-2 rounded-xl font-semibold border border-hairline bg-surface text-primary hover:bg-canvas transition-all active:scale-95"
                >🏠 Real Estate</button
              >
              <button
                type="button"
                data-asset="funds"
                class="asset-btn text-xs py-2 rounded-xl font-semibold border border-hairline bg-surface text-primary hover:bg-canvas transition-all active:scale-95"
                >💼 Funds</button
              >
              <button
                type="button"
                data-asset="other"
                class="asset-btn text-xs py-2 rounded-xl font-semibold border border-hairline bg-surface text-primary hover:bg-canvas transition-all active:scale-95"
                >📦 Other</button
              >
            </div>
          </div>

          <!-- Purchase & Sale Price -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center justify-between">
                <label
                  for="purchase-price"
                  class="text-xs font-semibold text-charcoal"
                  >Purchase Price</label
                >
                <select
                  id="currency-select"
                  class="text-[10px] font-bold py-0.5 px-2 rounded-full border border-hairline bg-surface hover:bg-canvas cursor-pointer transition-all outline-none"
                  aria-label="Currency and Country Select"
                >
                  <option value="USD" selected>$ USD</option>
                  <option value="CAD">$ CAD</option>
                  <option value="GBP">£ GBP</option>
                  <option value="AUD">$ AUD</option>
                  <option value="EUR">€ EUR</option>
                  <option value="INR">₹ INR</option>
                  <option value="Custom">Custom</option>
                </select>
              </div>
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol"
                  >$</span
                >
                <input
                  type="number"
                  id="purchase-price"
                  value="10000"
                  min="0"
                  class="text-input pl-7 font-mono text-sm"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="sale-price"
                class="text-xs font-semibold text-charcoal">Sale Price</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol"
                  >$</span
                >
                <input
                  type="number"
                  id="sale-price"
                  value="25000"
                  min="0"
                  class="text-input pl-7 font-mono text-sm"
                />
              </div>
              <div
                id="capital-loss-warning"
                class="hidden text-[10px] text-brand-blue font-semibold mt-1"
              >
              </div>
            </div>
          </div>

          <!-- Holding Period and Ordinary Annual Income -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label
                class="text-xs font-semibold text-charcoal flex justify-between"
              >
                <span>Holding Period</span>
                <span
                  id="holding-period-info-label"
                  class="text-[10px] text-stone font-normal"
                  >US Rules: > 1 year is Long-Term</span
                >
              </label>
              <div
                class="flex rounded-full bg-surface p-1 border border-hairline"
              >
                <button
                  type="button"
                  id="holding-short-btn"
                  class="flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas"
                  >Short-Term</button
                >
                <button
                  type="button"
                  id="holding-long-btn"
                  class="flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer text-slate"
                  >Long-Term</button
                >
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="annual-income"
                class="text-xs font-semibold text-charcoal flex justify-between"
              >
                <span>Annual Ordinary Income</span>
                <span class="text-[10px] text-stone font-normal"
                  >For tax brackets</span
                >
              </label>
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol"
                  >$</span
                >
                <input
                  type="number"
                  id="annual-income"
                  value="75000"
                  min="0"
                  class="text-input pl-7 font-mono text-sm"
                />
              </div>
            </div>
          </div>

          <!-- Advanced Options Accordion Toggle -->
          <div class="border-t border-hairline pt-4 mt-2">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-xs font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1.5">
                ⚙ Advanced Options +
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <!-- Advanced Panel content -->
            <div
              id="advanced-panel"
              class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-4 border-t border-hairline-soft mt-3 pt-4"
            >
              <!-- Dates Section -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label
                    for="purchase-date"
                    class="text-[11px] font-semibold text-slate"
                    >Purchase Date</label
                  >
                  <input
                    type="date"
                    id="purchase-date"
                    class="text-input text-xs"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label
                    for="sale-date"
                    class="text-[11px] font-semibold text-slate"
                    >Sale Date</label
                  >
                  <input
                    type="date"
                    id="sale-date"
                    class="text-input text-xs"
                  />
                </div>
              </div>

              <!-- Improvements & Selling Fees -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label
                    for="improvements"
                    class="text-[11px] font-semibold text-slate flex justify-between"
                  >
                    <span>Improvements / Costs added</span>
                    <span class="currency-symbol text-stone font-normal">$</span
                    >
                  </label>
                  <div class="relative">
                    <span
                      class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-xs currency-symbol"
                      >$</span
                    >
                    <input
                      type="number"
                      id="improvements"
                      value="0"
                      min="0"
                      class="text-input pl-6 text-xs"
                    />
                  </div>
                </div>

                <div class="flex flex-col gap-1.5">
                  <label
                    for="selling-fees"
                    class="text-[11px] font-semibold text-slate flex justify-between"
                  >
                    <span>Selling Fees / Commissions</span>
                    <span class="currency-symbol text-stone font-normal">$</span
                    >
                  </label>
                  <div class="relative">
                    <span
                      class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-xs currency-symbol"
                      >$</span
                    >
                    <input
                      type="number"
                      id="selling-fees"
                      value="0"
                      min="0"
                      class="text-input pl-6 text-xs"
                    />
                  </div>
                </div>
              </div>

              <!-- Filing Status & State/Province selectors -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div id="filing-status-container" class="flex flex-col gap-1.5">
                  <label
                    for="filing-status"
                    class="text-[11px] font-semibold text-slate"
                    >Filing Status</label
                  >
                  <select id="filing-status" class="text-input text-xs py-1.5">
                    <option value="single" selected>Single</option>
                    <option value="joint">Married / Joint</option>
                    <option value="hoh">Head of Household</option>
                  </select>
                </div>

                <div id="state-select-container" class="flex flex-col gap-1.5">
                  <label
                    for="state-select"
                    id="state-select-label"
                    class="text-[11px] font-semibold text-slate"
                    >State Tax Residency</label
                  >
                  <select id="state-select" class="text-input text-xs py-1.5">
                    <!-- Dynamic -->
                  </select>
                  <div
                    id="province-warning"
                    class="hidden text-[10px] text-brand-red font-semibold mt-1"
                  >
                  </div>
                </div>
              </div>

              <!-- Country-specific advanced toggles -->
              <div
                id="country-advanced-fields"
                class="flex flex-col gap-3 pt-2 border-t border-hairline-soft"
              >
                <!-- UK: Allowance toggle -->
                <div
                  id="field-uk-allowance"
                  class="hidden items-center justify-between py-1"
                >
                  <span class="text-xs font-semibold text-charcoal"
                    >CGT Annual Exempt Amount Used?</span
                  >
                  <input
                    type="checkbox"
                    id="uk-allowance-checkbox"
                    class="accent-brand-blue w-4 h-4 cursor-pointer"
                  />
                </div>

                <!-- UK/AUS: Primary Residence Exemption -->
                <div
                  id="field-primary-residence"
                  class="hidden items-center justify-between py-1"
                >
                  <span class="text-xs font-semibold text-charcoal"
                    >Eligible for Primary Residence Exemption?</span
                  >
                  <input
                    type="checkbox"
                    id="primary-residence-checkbox"
                    class="accent-brand-blue w-4 h-4 cursor-pointer"
                  />
                </div>

                <!-- India: Indexation toggle -->
                <div id="field-in-indexation" class="hidden flex-col gap-1.5">
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold text-charcoal"
                      >Use pre-July 2024 indexation (20% with indexation)?</span
                    >
                    <input
                      type="checkbox"
                      id="in-indexation-checkbox"
                      class="accent-brand-blue w-4 h-4 cursor-pointer"
                    />
                  </div>
                  <div
                    class="relative hidden"
                    id="indexation-factors-container"
                  >
                    <label
                      for="indexation-multiplier"
                      class="text-[10px] text-stone"
                      >Indexation multiplier factor (CII inflation ratio)</label
                    >
                    <input
                      type="number"
                      id="indexation-multiplier"
                      value="1.2"
                      step="0.01"
                      class="text-input text-xs"
                    />
                  </div>
                </div>

                <!-- Generic Europe flat tax rate slider -->
                <div id="field-eu-flat-rate" class="hidden flex-col gap-1.5">
                  <label
                    class="text-[11px] font-semibold text-slate flex justify-between"
                  >
                    <span>European Tax Rate</span>
                    <span id="eu-flat-rate-display" class="font-mono text-stone"
                      >25%</span
                    >
                  </label>
                  <input
                    type="range"
                    id="eu-flat-rate-slider"
                    min="0"
                    max="60"
                    value="25"
                    class="w-full cursor-pointer accent-brand-blue"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Output Pane Above Fold (5 Columns) -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <div
          id="estimated-tax-card"
          class="card-base bg-surface relative overflow-hidden flex flex-col gap-6 p-6"
        >
          <div
            class="absolute top-0 right-0 w-24 h-24 bg-success-accent/10 rounded-full blur-2xl"
          >
          </div>

          <div class="flex flex-col gap-1 z-10 text-center md:text-left">
            <span
              class="text-xs font-bold text-slate uppercase tracking-wider block"
              >Estimated Tax Owed</span
            >
            <div
              id="tax-owed-display"
              class="font-display font-medium text-4xl sm:text-5xl tracking-tight text-primary font-mono select-all"
            >
              $0.00
            </div>
          </div>

          <div
            class="grid grid-cols-3 gap-3 border-t border-hairline pt-4 z-10 font-mono"
          >
            <div class="flex flex-col">
              <span class="text-[9px] uppercase font-bold text-slate"
                >Net Profit</span
              >
              <span
                id="net-profit-display"
                class="font-semibold text-xs sm:text-sm text-success-accent select-all"
                >$0.00</span
              >
            </div>
            <div class="flex flex-col">
              <span class="text-[9px] uppercase font-bold text-slate"
                >Effective Rate</span
              >
              <span
                id="effective-rate-display"
                class="font-semibold text-xs sm:text-sm text-primary select-all"
                >0.0%</span
              >
            </div>
            <div class="flex flex-col">
              <span class="text-[9px] uppercase font-bold text-slate"
                >Applied Bracket</span
              >
              <span
                id="applied-bracket-display"
                class="font-semibold text-[10px] text-primary truncate"
                >Standard</span
              >
            </div>
          </div>

          <div
            class="flex flex-col items-center justify-center pt-2 border-t border-hairline z-10"
          >
            <div class="relative w-36 h-36">
              <svg
                id="donut-svg"
                class="w-full h-full transform -rotate-90"
                viewBox="0 0 100 100"
              >
                <circle
                  cx="50"
                  cy="50"
                  r="40"
                  stroke="var(--color-hairline)"
                  stroke-width="12"
                  fill="transparent"></circle>
                <g id="donut-segments"></g>
              </svg>
              <div
                class="absolute inset-0 flex flex-col items-center justify-center text-center"
              >
                <span class="text-[8px] text-stone font-semibold uppercase"
                  >Profit Kept</span
                >
                <span
                  id="donut-percent"
                  class="font-display font-bold text-base text-primary">0%</span
                >
              </div>
            </div>

            <div
              class="w-full flex flex-col gap-1.5 mt-4 text-[10px] text-slate"
            >
              <div class="flex items-center justify-between">
                <span class="flex items-center gap-1.5"
                  ><span class="w-2 h-2 rounded-full bg-slate-300"></span>Basis
                  Cost</span
                >
                <span id="legend-basis-val" class="font-semibold">$0.00</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="flex items-center gap-1.5"
                  ><span class="w-2 h-2 rounded-full bg-brand-coral"></span>Tax
                  Paid</span
                >
                <span id="legend-tax-val" class="font-semibold">$0.00</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="flex items-center gap-1.5"
                  ><span class="w-2 h-2 rounded-full bg-success-accent"
                  ></span>Net Profit</span
                >
                <span id="legend-profit-val" class="font-semibold">$0.00</span>
              </div>
            </div>
          </div>

          <button
            type="button"
            id="scroll-to-results-btn"
            class="w-full button-primary text-xs py-2 px-4 rounded-full text-center flex items-center justify-center gap-1 transition-all cursor-pointer"
          >
            <span>View Detailed Breakdown</span>
            <span>&rarr;</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Below Fold Detailed Results -->
    <div
      id="results-column"
      class="flex flex-col gap-6 mt-8 border-t border-hairline pt-8"
    >
      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-4"
      >
        <h2
          id="detailed-breakdown-heading"
          class="font-display font-semibold text-2xl text-primary flex items-center gap-2"
        >
          <span class="w-3 h-3 rounded-full bg-success-accent animate-pulse"
          ></span>
          Detailed Tax Breakdowns
        </h2>
        <div
          class="grid grid-cols-3 gap-2 w-full sm:flex sm:items-center sm:w-auto"
        >
          <button
            type="button"
            id="csv-export-btn"
            class="inline-flex items-center justify-center gap-1.5 text-[10px] sm:text-xs font-semibold px-2.5 sm:px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle truncate"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3 sm:w-3.5 sm:h-3.5 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            <span class="truncate">Export CSV</span>
          </button>
          <button
            type="button"
            id="excel-export-btn"
