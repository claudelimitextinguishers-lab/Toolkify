    // Country/Currency state updates
    function applyCountrySelection(currencyKey: string, skipCalculate = false) {
      const profile = COUNTRY_PROFILES[currencyKey] || COUNTRY_PROFILES["USD"];
      currentCurrency = currencyKey;

      if (currencyKey === "USD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "USD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (currencyKey === "CAD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "CAD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (currencyKey === "GBP") {
        currentCurrencySymbol = "£";
        currentCurrencyCode = "GBP";
        customCurrencyContainer?.classList.add("hidden");
      } else if (currencyKey === "AUD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "AUD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (currencyKey === "EUR") {
        currentCurrencySymbol = "€";
        currentCurrencyCode = "EUR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (currencyKey === "INR") {
        currentCurrencySymbol = "₹";
        currentCurrencyCode = "INR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (currencyKey === "Custom") {
        customCurrencyContainer?.classList.remove("hidden");
        currentCurrencySymbol = customCurrencySymbolInput?.value || "$";
        currentCurrencyCode = customCurrencyCodeInput?.value || "USD";
      }

      // Update prefixes
      if (currencyPrefix) currencyPrefix.textContent = currentCurrencySymbol;
      document.querySelectorAll(".currency-symbol").forEach(el => el.textContent = currentCurrencySymbol);

      // Apply Profile values
      interestRateRange.value = profile.defaultRate.toString();
      interestRateInput.value = profile.defaultRate.toString();
      if (interestRateValLabel) interestRateValLabel.textContent = `${profile.defaultRate.toFixed(2)}%`;
      if (rateHint) rateHint.textContent = profile.rateHint;

      loanTermRange.value = profile.defaultTerm.toString();
      loanTermInput.value = profile.defaultTerm.toString();
      updateLoanTermLabel(profile.defaultTerm);
      
      gracePeriodInput.value = profile.defaultGrace.toString();
      if (gracePeriodLabel) gracePeriodLabel.textContent = profile.gracePeriodLabel;

      if (currentPaymentLabel) currentPaymentLabel.textContent = `Current ${profile.paymentLabel}`;
      const heroLabel = document.getElementById("output-hero-label");
      if (heroLabel) heroLabel.textContent = profile.paymentLabel;

      // Populate Loan Types select
      if (loanTypeSelect) {
        loanTypeSelect.innerHTML = "";
        profile.loanTypes.forEach(t => {
          const opt = document.createElement("option");
          opt.value = t;
          opt.textContent = t;
          loanTypeSelect.appendChild(opt);
        });
      }

      // Context Box
      if (countryRuleTitle) countryRuleTitle.textContent = profile.ruleTitle;
      if (countryRuleText) countryRuleText.textContent = profile.ruleText;

      updatePresetsUI();
      if (!skipCalculate) {
        calculate();
      }
    }

