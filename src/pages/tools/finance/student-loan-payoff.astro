    // Save/Load Storage State
    function saveState() {
      try {
        localStorage.setItem("sl-currency", currentCurrency);
        localStorage.setItem("sl-balance", loanBalanceInput.value);
        localStorage.setItem("sl-rate", interestRateInput.value);
        localStorage.setItem("sl-current-payment", currentPaymentInput.value);
        localStorage.setItem("sl-extra-payment", extraPaymentInput.value);
        localStorage.setItem("sl-term", loanTermInput.value);
        localStorage.setItem("sl-grace", gracePeriodInput.value);
        localStorage.setItem("sl-fee", originationFeeInput.value);
        localStorage.setItem("sl-start", startDateInput.value);
        localStorage.setItem("sl-custom-sym", customCurrencySymbolInput.value);
        localStorage.setItem("sl-custom-code", customCurrencyCodeInput.value);
      } catch (e) {
        console.warn("Storage write failed", e);
      }
    }

    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const getSafeItem = (key: string): string | null => {
        const paramKey = key.replace("sl-", "");
        if (urlParams.has(paramKey)) {
          return urlParams.get(paramKey);
        }
        if (typeof localStorage === 'undefined') return null;
        try {
          return localStorage.getItem(key);
        } catch (e) {
          return null;
        }
      };

      try {
        const sCurr = getSafeItem("sl-currency");
        const sBal = getSafeItem("sl-balance");
        const sRate = getSafeItem("sl-rate");
        const sCurrPmt = getSafeItem("sl-current-payment");
        const sExtra = getSafeItem("sl-extra-payment");
        const sTerm = getSafeItem("sl-term");
        const sGrace = getSafeItem("sl-grace");
        const sFee = getSafeItem("sl-fee");
        const sStart = getSafeItem("sl-start");
        const sSym = getSafeItem("sl-custom-sym");
        const sCode = getSafeItem("sl-custom-code");

        if (sSym) customCurrencySymbolInput.value = sSym;
        if (sCode) customCurrencyCodeInput.value = sCode;
        if (sCurr) currencySelect.value = sCurr;
        
        applyCountrySelection(currencySelect.value, true);

        if (sBal) loanBalanceInput.value = sBal;
        if (sRate) {
          interestRateInput.value = sRate;
          interestRateRange.value = sRate;
          if (interestRateValLabel) interestRateValLabel.textContent = `${parseFloat(sRate).toFixed(2)}%`;
        }
        if (sCurrPmt) currentPaymentInput.value = sCurrPmt;
        if (sExtra) extraPaymentInput.value = sExtra;
        if (sTerm) {
          loanTermInput.value = sTerm;
          loanTermRange.value = sTerm;
          updateLoanTermLabel(parseInt(sTerm, 10));
        }
        if (sGrace) gracePeriodInput.value = sGrace;
        if (sFee) originationFeeInput.value = sFee;
        if (sStart) startDateInput.value = sStart;

        updatePresetsUI();
        calculate();
      } catch (e) {
        console.warn("Storage read failed", e);
      }
    }

    // Mathematical Engine
    function calculate() {
      saveState();

      const balanceInputVal = Math.max(0, parseFloat(loanBalanceInput.value) || 0);
      const interestRate = Math.max(0, parseFloat(interestRateInput.value) || 0) / 100;
      const extraPayment = Math.max(0, parseFloat(extraPaymentInput.value) || 0);
      const termYears = Math.max(1, parseInt(loanTermInput.value, 10) || 1);
      const gracePeriodMonths = Math.max(0, parseInt(gracePeriodInput.value, 10) || 0);
      const originationFeeRate = Math.max(0, parseFloat(originationFeeInput.value) || 0) / 100;

      // Initial Principal adjust with fees
      const feeAmount = balanceInputVal * originationFeeRate;
      let initialPrincipal = balanceInputVal + feeAmount;

      // Grace/Moratorium simulation
      let capitalizedInterest = 0;
      const isSubsidized = loanTypeSelect.value === "Federal Subsidized";
      const isCanadaInterestFree = currentCurrency === "CAD" && !loanTypeSelect.value.includes("Private");
      const isUKorAU = currentCurrency === "GBP" || currentCurrency === "AUD";

      // Accrued interest during grace
      if (gracePeriodMonths > 0 && !isSubsidized && !isCanadaInterestFree && !isUKorAU) {
        if (currentCurrency === "INR") {
          // India typically charges Simple Interest during moratorium, then capitalizes
          capitalizedInterest = initialPrincipal * (interestRate / 12) * gracePeriodMonths;
        } else {
          // Compound Monthly capitalization
          for (let m = 0; m < gracePeriodMonths; m++) {
            capitalizedInterest += (initialPrincipal + capitalizedInterest) * (interestRate / 12);
          }
        }
      }

      const totalBalanceAtStart = initialPrincipal + capitalizedInterest;
      const rMonthly = interestRate / 12;
      const totalMonths = termYears * 12;

      // Calculate Standard Monthly Payment
      let stdMonthly = 0;
      if (rMonthly === 0) {
        stdMonthly = totalBalanceAtStart / totalMonths;
      } else {
        stdMonthly = totalBalanceAtStart * (rMonthly * Math.pow(1 + rMonthly, totalMonths)) / (Math.pow(1 + rMonthly, totalMonths) - 1);
      }

      // Display Hero standard payoff indicators
      if (monthlyPaymentDisplay) monthlyPaymentDisplay.textContent = formatVal(stdMonthly);
      if (mobileSummaryValue) mobileSummaryValue.textContent = formatVal(stdMonthly);

      // Determine the user's defined Payment (defaults to standard if 0 or too low)
      const userEnteredPayment = parseFloat(currentPaymentInput.value) || 0;
      let customPayment = Math.max(0, userEnteredPayment);
      if (customPayment <= 0) {
        customPayment = stdMonthly;
      }

      // Infinite loop protection checks
      let warningMsg = "";
      if (rMonthly > 0 && userEnteredPayment > 0) {
        const stdInterestAccrued = totalBalanceAtStart * rMonthly;
        if (customPayment <= stdInterestAccrued && customPayment + extraPayment > stdInterestAccrued) {
          warningMsg = "Warning: The custom monthly payment is less than or equal to the monthly interest accrued. The loan balance will only decrease due to your extra payments.";
        } else if (customPayment + extraPayment <= stdInterestAccrued) {
          warningMsg = "Warning: The custom monthly payment (including extra payment) is less than or equal to the monthly interest accrued. The loan balance will never be paid off under this plan.";
        }
      }

      const warningEl = document.getElementById("payment-warning");
      const warningTextEl = document.getElementById("payment-warning-text");
      if (warningEl && warningTextEl) {
        if (warningMsg) {
          warningTextEl.textContent = warningMsg;
          warningEl.classList.remove("hidden");
        } else {
          warningEl.classList.add("hidden");
        }
      }

      // Amortization loops
      if (currentCurrency === "INR") {
        standardAmortizationData = simulateSchedule(initialPrincipal, rMonthly, stdMonthly, 0, gracePeriodMonths, startDateInput.value, capitalizedInterest);
        amortizationData = simulateSchedule(initialPrincipal, rMonthly, customPayment, extraPayment, gracePeriodMonths, startDateInput.value, capitalizedInterest);
      } else {
        standardAmortizationData = simulateSchedule(initialPrincipal, rMonthly, stdMonthly, 0, gracePeriodMonths, startDateInput.value);
        amortizationData = simulateSchedule(initialPrincipal, rMonthly, customPayment, extraPayment, gracePeriodMonths, startDateInput.value);
      }

      // Extract results from schedules
      const lastAcc = amortizationData[amortizationData.length - 1];

      const stdInterestPaid = standardAmortizationData.reduce((sum, row) => sum + row.interest, 0);
      const accInterestPaid = amortizationData.reduce((sum, row) => sum + row.interest, 0);

      const stdPayoffDurationMonths = standardAmortizationData.length;
      const accPayoffDurationMonths = amortizationData.length;

      // Standard Plan Cards UI update
      if (stdMonthlyPayment) stdMonthlyPayment.textContent = formatVal(stdMonthly);
      if (stdTotalInterest) stdTotalInterest.textContent = formatVal(stdInterestPaid);
      if (stdPayoffTime) stdPayoffTime.textContent = formatDuration(stdPayoffDurationMonths);
      if (stdTotalPaid) stdTotalPaid.textContent = formatVal(totalBalanceAtStart + stdInterestPaid);

      // Accelerated Plan Cards UI update
      const totalAccPayment = customPayment + extraPayment;
      if (accMonthlyPayment) accMonthlyPayment.textContent = formatVal(totalAccPayment);
      if (accTotalInterest) accTotalInterest.textContent = formatVal(accInterestPaid);
      if (accPayoffTime) accPayoffTime.textContent = formatDuration(accPayoffDurationMonths);
      
      const interestSavedVal = Math.max(0, stdInterestPaid - accInterestPaid);
      if (accInterestSaved) accInterestSaved.textContent = formatVal(interestSavedVal);

      const monthsSavedVal = Math.max(0, stdPayoffDurationMonths - accPayoffDurationMonths);
      if (accTimeSaved) {
        accTimeSaved.textContent = `${(monthsSavedVal / 12).toFixed(1)} Years (${monthsSavedVal} months)`;
      }

      // Dynamic Hero Output Panel Update
      if (payoffDateDisplay) payoffDateDisplay.textContent = lastAcc ? lastAcc.dateStr : "N/A";
      if (totalInterestDisplay) totalInterestDisplay.textContent = formatVal(accInterestPaid);
      if (payoffDurationDisplay) payoffDurationDisplay.textContent = formatDuration(accPayoffDurationMonths);

      // Redraw schedule tables and SVG
      renderAmortizationTable();
      renderSVGChart();
    }

    function formatDuration(months: number): string {
      const yrs = Math.floor(months / 12);
      const remainingMonths = months % 12;
      let out = "";
      if (yrs > 0) out += `${yrs} Year${yrs > 1 ? 's' : ''}`;
      if (remainingMonths > 0) {
        if (out) out += " ";
        out += `${remainingMonths} Month${remainingMonths > 1 ? 's' : ''}`;
      }
      return out || "0 Months";
    }

    /**
     * Amortization simulator
     * @param principal Initial loan principal
     * @param rMonthly Monthly interest rate
     * @param payment Scheduled monthly payment
     * @param extra Extra monthly payment
     * @param graceMonths Grace / moratorium period in months (applies to all loan types/currencies)
     * @param startDateStr Repayment start date string
     * @param capitalizedInterest Interest capitalized during grace (for INR only)
     */
    function simulateSchedule(
      principal: number,
      rMonthly: number,
      payment: number,
      extra: number,
      graceMonths: number,
      startDateStr: string,
      capitalizedInterest = 0
    ) {
      const schedule: any[] = [];
      let balance = principal;
      let currentDate;
      if (startDateStr) {
        currentDate = new Date(startDateStr.includes('T') ? startDateStr : `${startDateStr}T00:00:00`);
      } else {
        currentDate = new Date();
      }
      let index = 1;

      // Inject Grace period phase
      const isSubsidized = loanTypeSelect.value === "Federal Subsidized";
      const isCanadaInterestFree = currentCurrency === "CAD" && !loanTypeSelect.value.includes("Private");
      const isUKorAU = currentCurrency === "GBP" || currentCurrency === "AUD";

      if (currentCurrency === "INR") {
        for (let g = 0; g < graceMonths; g++) {
          const interestAccrued = principal * rMonthly;

          schedule.push({
            paymentNo: index++,
            dateStr: getMonthName(currentDate),
            payment: 0,
            interest: interestAccrued,
            principal: 0,
            balance: balance
          });
          currentDate.setMonth(currentDate.getMonth() + 1);
        }
        balance = principal + capitalizedInterest;
      } else {
        // Non-INR grace period compounding simulation
        if (graceMonths > 0 && !isSubsidized && !isCanadaInterestFree && !isUKorAU) {
          for (let g = 0; g < graceMonths; g++) {
            const interestAccrued = balance * rMonthly;
            balance += interestAccrued;
            schedule.push({
              paymentNo: index++,
              dateStr: getMonthName(currentDate),
              payment: 0,
              interest: interestAccrued,
              principal: 0,
              balance: balance
            });
            currentDate.setMonth(currentDate.getMonth() + 1);
          }
        }
      }

      // Repayment phase
      let safetyCount = 0;
      const maxPayments = 600; // 50 years max guard

      while (balance > 0.01 && safetyCount < maxPayments) {
        const interestAccrued = balance * rMonthly;
        if (rMonthly > 0 && (payment + extra) <= interestAccrued) {
          break;
        }
        safetyCount++;
        let scheduledPayment = Math.min(balance + interestAccrued, payment);
        let actualExtra = Math.min(balance + interestAccrued - scheduledPayment, extra);
        let totalPaid = scheduledPayment + actualExtra;

        let principalPaid = totalPaid - interestAccrued;
        if (principalPaid < 0) principalPaid = 0;
        
        balance = balance + interestAccrued - totalPaid;

        schedule.push({
          paymentNo: index++,
          dateStr: getMonthName(currentDate),
          payment: scheduledPayment,
          interest: interestAccrued,
          principal: principalPaid,
          balance: Math.max(0, balance)
        });
        currentDate.setMonth(currentDate.getMonth() + 1);
      }

      return schedule;
    }

    function getMonthName(dateObj: Date): string {
      return dateObj.toLocaleDateString("en-US", { month: "short", year: "numeric" });
    }

    // Render Table
    function renderAmortizationTable() {
      if (!amortizationTableBody) return;
      amortizationTableBody.innerHTML = "";

      const limit = showFullAmortization ? amortizationData.length : Math.min(6, amortizationData.length);

      for (let i = 0; i < limit; i++) {
        const row = amortizationData[i];
        const stdRow = standardAmortizationData[i] || { payment: 0, interest: 0 };
        
        const extraPmt = row.payment > 0 ? (parseFloat(extraPaymentInput.value) || 0) : 0;
        const tr = document.createElement("tr");
        tr.className = "border-b border-hairline font-mono text-[11px] text-charcoal hover:bg-surface-soft";
        tr.innerHTML = `
          <td class="py-2 px-3">${row.paymentNo}</td>
          <td class="py-2 px-3">${row.dateStr}</td>
          <td class="py-2 px-3 text-right">${formatVal(stdRow.payment)}</td>
          <td class="py-2 px-3 text-right">${formatVal(stdRow.interest)}</td>
          <td class="py-2 px-3 text-right">${formatVal(row.payment > 0 ? row.payment + extraPmt : 0)}</td>
          <td class="py-2 px-3 text-right">${formatVal(row.interest)}</td>
          <td class="py-2 px-3 text-right font-bold text-brand-blue">${formatVal(row.balance)}</td>
        `;
        amortizationTableBody.appendChild(tr);
      }

      if (toggleAmortizationBtn) {
        toggleAmortizationBtn.textContent = showFullAmortization
          ? `Show Compact View (First 6 payments)`
          : `Show Full Schedule (${amortizationData.length} payments)`;
      }
    }

    toggleAmortizationBtn?.addEventListener("click", () => {
      showFullAmortization = !showFullAmortization;
      renderAmortizationTable();
    });

    // Render SVG Payoff Chart
    function renderSVGChart() {
      const svg = document.getElementById("growth-svg");
      if (!svg) return;
      svg.innerHTML = "";

      const width = 600;
      const height = 260;
      const padding = { top: 20, right: 30, bottom: 30, left: 60 };

      const totalPayments = Math.max(standardAmortizationData.length, amortizationData.length);
      if (totalPayments <= 1) return;

      let maxBal = parseFloat(loanBalanceInput.value) || 0;
      if (standardAmortizationData.length > 0 || amortizationData.length > 0) {
        const stdBalances = standardAmortizationData.map(r => r.balance);
        const accBalances = amortizationData.map(r => r.balance);
        maxBal = Math.max(
          ...(stdBalances.length > 0 ? stdBalances : [0]),
          ...(accBalances.length > 0 ? accBalances : [0]),
          maxBal
        );
      }

      // Drawing Helper Coordinates
      const getX = (i: number) => padding.left + (i / (totalPayments - 1)) * (width - padding.left - padding.right);
      const getY = (bal: number) => padding.top + (1 - (bal / maxBal)) * (height - padding.top - padding.bottom);

      // Grid Lines & Y-axis labels
      for (let i = 0; i <= 4; i++) {
        const val = (maxBal * i) / 4;
        const y = getY(val);
        
        // Horizontal gridline
        const grid = document.createElementNS("http://www.w3.org/2000/svg", "line");
        grid.setAttribute("x1", padding.left.toString());
        grid.setAttribute("y1", y.toString());
        grid.setAttribute("x2", (width - padding.right).toString());
        grid.setAttribute("y2", y.toString());
        grid.setAttribute("stroke", "var(--color-hairline-soft)");
        grid.setAttribute("stroke-dasharray", "4");
        svg.appendChild(grid);

        // Y label
        const txt = document.createElementNS("http://www.w3.org/2000/svg", "text");
        txt.setAttribute("x", (padding.left - 8).toString());
        txt.setAttribute("y", (y + 4).toString());
        txt.setAttribute("text-anchor", "end");
        txt.setAttribute("fill", "var(--color-stone)");
        txt.setAttribute("font-size", "9px");
        txt.setAttribute("font-family", "monospace");
        txt.textContent = formatVal(val).split(".")[0];
        svg.appendChild(txt);
      }

      // X-axis ticks (Year markers)
      const yrsTotal = Math.ceil(totalPayments / 12);
      const tickStep = Math.max(1, Math.ceil(yrsTotal / 8));

      for (let yVal = 0; yVal <= yrsTotal; yVal += tickStep) {
        const i = Math.min(yVal * 12, totalPayments - 1);
        const x = getX(i);

        const tick = document.createElementNS("http://www.w3.org/2000/svg", "line");
        tick.setAttribute("x1", x.toString());
        tick.setAttribute("y1", (height - padding.bottom).toString());
        tick.setAttribute("x2", x.toString());
        tick.setAttribute("y2", (height - padding.bottom + 4).toString());
        tick.setAttribute("stroke", "var(--color-hairline)");
        svg.appendChild(tick);

        const txt = document.createElementNS("http://www.w3.org/2000/svg", "text");
        txt.setAttribute("x", x.toString());
        txt.setAttribute("y", (height - padding.bottom + 16).toString());
        txt.setAttribute("text-anchor", "middle");
        txt.setAttribute("fill", "var(--color-stone)");
        txt.setAttribute("font-size", "9px");
        txt.setAttribute("font-family", "Roobert PRO, sans-serif");
        txt.textContent = `Yr ${yVal}`;
        svg.appendChild(txt);
      }

      // Payoff curves: Standard curve (dotted/grey) and Accelerated curve (blue)
      if (standardAmortizationData.length > 1) {
        const stdPath = document.createElementNS("http://www.w3.org/2000/svg", "path");
        let d = `M ${getX(0)} ${getY(parseFloat(loanBalanceInput.value) || 0)}`;
        standardAmortizationData.forEach((row, i) => {
          d += ` L ${getX(i)} ${getY(row.balance)}`;
        });
        stdPath.setAttribute("d", d);
        stdPath.setAttribute("fill", "none");
        stdPath.setAttribute("stroke", "var(--color-stone)");
        stdPath.setAttribute("stroke-width", "2");
        stdPath.setAttribute("stroke-dasharray", "4");
        svg.appendChild(stdPath);
      }

      if (amortizationData.length > 1) {
        const accPath = document.createElementNS("http://www.w3.org/2000/svg", "path");
        let d = `M ${getX(0)} ${getY(parseFloat(loanBalanceInput.value) || 0)}`;
        amortizationData.forEach((row, i) => {
          d += ` L ${getX(i)} ${getY(row.balance)}`;
        });
        accPath.setAttribute("d", d);
        accPath.setAttribute("fill", "none");
        accPath.setAttribute("stroke", "var(--color-brand-blue)");
        accPath.setAttribute("stroke-width", "3");
        svg.appendChild(accPath);
      }
    }

    // Export CSV
    function triggerCsvExport() {
      let csv = "Payment No,Date,Standard Payment,Standard Interest,Accelerated Payment,Accelerated Interest,Accelerated Remaining Balance\n";
      amortizationData.forEach((row, i) => {
        const stdRow = standardAmortizationData[i] || { payment: 0, interest: 0 };
        const extraPmt = row.payment > 0 ? (parseFloat(extraPaymentInput.value) || 0) : 0;
        csv += `${row.paymentNo},"${row.dateStr}",${stdRow.payment.toFixed(2)},${stdRow.interest.toFixed(2)},${(row.payment > 0 ? row.payment + extraPmt : 0).toFixed(2)},${row.interest.toFixed(2)},${row.balance.toFixed(2)}\n`;
      });

      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const link = document.createElement("a");
      const url = URL.createObjectURL(blob);
      link.setAttribute("href", url);
      link.setAttribute("download", `student_loan_payoff_schedule_${currentCurrencyCode}.csv`);
      link.style.visibility = "hidden";
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    // Export Excel (.xls HTML format)
    function exportToExcel() {
      let html = `<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">`;
      html += `<head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Amortization Schedule</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head>`;
      html += `<body><table>`;
      html += `<thead>`;
      html += `<tr style="background-color: #f1f5f9; font-weight: bold;">`;
      html += `<th>Payment No</th><th>Date</th><th>Standard Payment</th><th>Standard Interest</th><th>With Extra Payment</th><th>Extra Interest</th><th>Accelerated Balance</th>`;
      html += `</tr>`;
      html += `</thead><tbody>`;
      
      amortizationData.forEach((row, i) => {
        const stdRow = standardAmortizationData[i] || { payment: 0, interest: 0 };
        const extraPmt = row.payment > 0 ? (parseFloat(extraPaymentInput.value) || 0) : 0;
        html += `<tr>`;
        html += `<td>${row.paymentNo}</td>`;
        html += `<td>${row.dateStr}</td>`;
        html += `<td>${stdRow.payment.toFixed(2)}</td>`;
        html += `<td>${stdRow.interest.toFixed(2)}</td>`;
        html += `<td>${(row.payment > 0 ? row.payment + extraPmt : 0).toFixed(2)}</td>`;
        html += `<td>${row.interest.toFixed(2)}</td>`;
        html += `<td>${row.balance.toFixed(2)}</td>`;
        html += `</tr>`;
      });
      
      html += `</tbody></table></body></html>`;

      const blob = new Blob([html], { type: "application/vnd.ms-excel;charset=utf-8;" });
      const link = document.createElement("a");
      const url = URL.createObjectURL(blob);
      link.setAttribute("href", url);
      link.setAttribute("download", `student_loan_payoff_schedule_${currentCurrencyCode}.xls`);
      link.style.visibility = "hidden";
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    csvExportBtn?.addEventListener("click", triggerCsvExport);
    tableCsvExportBtn?.addEventListener("click", triggerCsvExport);
    tableExcelExportBtn?.addEventListener("click", exportToExcel);

    // Copy Results
    copyResultsBtn?.addEventListener("click", () => {
      const summaryText = `Student Loan Payoff Calculator Analysis (${currentCurrencyCode})
------------------------------------------------------
Loan Balance: ${formatVal(parseFloat(loanBalanceInput.value) || 0)}
Annual Interest Rate: ${interestRateInput.value}%
Grace Period: ${gracePeriodInput.value} months

STANDARD PLAN:
- Monthly Repayment: ${stdMonthlyPayment?.textContent || ""}
- Total Interest Paid: ${stdTotalInterest?.textContent || ""}
- Repayment Term: ${stdPayoffTime?.textContent || ""}

SAVINGS PLAN (With Extra Payments):
- Monthly Repayment (incl. Extra): ${accMonthlyPayment?.textContent || ""}
- Accelerated Payoff: ${accPayoffTime?.textContent || ""}
- Interest Saved: ${accInterestSaved?.textContent || ""}
- Time Saved: ${accTimeSaved?.textContent || ""}
------------------------------------------------------
Calculated at BoardTools.app`;

      navigator.clipboard.writeText(summaryText).then(() => {
        const prevText = copyResultsBtn.innerHTML;
        copyResultsBtn.innerHTML = `<span>✔ Copied!</span>`;
        setTimeout(() => {
          copyResultsBtn.innerHTML = prevText;
        }, 2000);
      });
    });

    // Chart tooltip event listeners
    const svgEl = document.getElementById("growth-svg");
    const tooltipEl = document.getElementById("chart-tooltip");
    if (svgEl && tooltipEl) {
      svgEl.addEventListener("mousemove", (e) => {
        const mouseEvent = e as MouseEvent;
        const totalPayments = Math.max(standardAmortizationData.length, amortizationData.length);
        if (totalPayments <= 1) return;

        const rect = svgEl.getBoundingClientRect();
        const mouseX = mouseEvent.clientX - rect.left;
        
        const width = 600;
        const padding = { top: 20, right: 30, bottom: 30, left: 60 };
        const svgX = mouseX * (width / rect.width);
        
        const chartWidth = width - padding.left - padding.right;
        const ratio = (svgX - padding.left) / chartWidth;
        const i = Math.round(ratio * (totalPayments - 1));
        
        if (i >= 0 && i < totalPayments) {
          const stdPoint = standardAmortizationData[i];
          const accPoint = amortizationData[i];
          
          let content = "";
          if (stdPoint || accPoint) {
            const dateStr = (stdPoint || accPoint).dateStr;
            content += `<div class="font-bold border-b border-canvas/20 pb-0.5 mb-1">${dateStr}</div>`;
            if (stdPoint) {
              content += `<div>Std: ${formatVal(stdPoint.balance)}</div>`;
            }
            if (accPoint) {
              content += `<div class="text-brand-blue font-semibold">Extra: ${formatVal(accPoint.balance)}</div>`;
            }
          }
          
          tooltipEl.innerHTML = content;
          
          // Temporarily display the tooltip invisibly to get its dimensions
          tooltipEl.style.visibility = "hidden";
          tooltipEl.style.display = "block";
          
          const tooltipWidth = tooltipEl.offsetWidth;
          const tooltipHeight = tooltipEl.offsetHeight;
          
          let leftPos = mouseEvent.clientX - rect.left + 15;
          let topPos = mouseEvent.clientY - rect.top + 15;
          if (leftPos + tooltipWidth > rect.width) {
            leftPos = mouseEvent.clientX - rect.left - tooltipWidth - 15;
          }
          if (topPos + tooltipHeight > rect.height) {
            topPos = mouseEvent.clientY - rect.top - tooltipHeight - 15;
          }
          
          tooltipEl.style.left = `${leftPos}px`;
          tooltipEl.style.top = `${topPos}px`;

          tooltipEl.classList.remove("hidden");
          tooltipEl.style.visibility = "";
          tooltipEl.style.display = "";
        } else {
          tooltipEl.classList.add("hidden");
        }
      });
      
      svgEl.addEventListener("mouseleave", () => {
        tooltipEl.classList.add("hidden");
      });
    }

    // Initialize defaults on start
    setDefaultStartDate();
    loadState();

    // Toggle mobile sticky bar visibility based on scroll position/results section visibility
    const heroSection = document.getElementById("hero-section");
    const mobileStickyBar = document.getElementById("mobile-sticky-bar");
    if (heroSection && mobileStickyBar) {
      window.addEventListener("scroll", () => {
        const heroRect = heroSection.getBoundingClientRect();
        if (window.scrollY > 100 && heroRect.top > 90) {
          mobileStickyBar.classList.remove("translate-y-full");
        } else {
          mobileStickyBar.classList.add("translate-y-full");
        }
      });
    }
  </script>
</Layout>
