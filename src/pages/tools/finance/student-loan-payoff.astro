---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Student Loan Payoff Calculator";
const category = "finance";
const tier = "Finance & Tax";

// On-page tool description (visible in header)
const description = "Free student loan payoff calculator with extra payments. Estimate your payoff date, total interest, and how long to pay off student loans across multiple loans.";

// SEO-optimized metadata
const seoTitle = "Student Loan Payoff Calculator with Extra Payments";
const seoDescription = "Free student loan payoff calculator with extra payments. See your payoff date, total interest, and savings for multiple loans, with Excel and CSV export.";
const seoKeywords = "student loan payoff calculator, student loan payoff calculator with extra payments, student loan payoff calculator extra payments, student loan payoff calculator multiple loans, student loan payoff calculator excel, early student loan payoff calculator, estimated student loan payoff calculator, student loan calculator, student loan calculator payoff, student loan calculator repayment, bankrate student loan calculator, student loan calculator payment, refinance student loan calculator, private student loan calculator, pay off student loan calculator, how long to pay off student loan calculator, student loan calculator with extra payments";
const canonicalUrl = "https://boardtools.app/tools/finance/student-loan-payoff";
---

<Layout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonical={canonicalUrl}
  ogType="website"
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Student Loan Payoff Calculator",
      "url": "https://boardtools.app/tools/finance/student-loan-payoff",
      "description": "Free student loan payoff calculator with extra payments. Estimate your payoff date, total interest paid, and savings across multiple loans with an amortization schedule, payoff curve chart, and Excel/CSV export.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "keywords": "student loan payoff calculator, student loan payoff calculator with extra payments, student loan payoff calculator multiple loans, student loan payoff calculator excel, early student loan payoff calculator, student loan calculator, refinance student loan calculator, private student loan calculator",
      "featureList": [
        "Student loan payoff calculator with extra payments",
        "Multiple loan and multi-currency support",
        "Early payoff and interest savings analysis",
        "Amortization schedule with Excel and CSV export",
        "Interactive payoff curve chart"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- FAQ Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does a student loan payoff calculator with extra payments work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A student loan payoff calculator with extra payments models how additional monthly contributions reduce your principal faster. By comparing a standard repayment plan against an accelerated plan, it estimates your new payoff date, the total interest you save, and how many months or years you cut from the loan term."
          }
        },
        {
          "@type": "Question",
          "name": "Can I use this calculator for multiple student loans?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. You can combine the balances of multiple loans into a single weighted figure, or run the student loan payoff calculator once per loan to plan each repayment separately and compare payoff timelines."
          }
        },
        {
          "@type": "Question",
          "name": "How long will it take to pay off my student loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Enter your balance, interest rate, monthly payment, and any extra payment. The calculator shows exactly how long it takes to pay off the student loan under both the standard and accelerated plans, down to the projected payoff month and year."
          }
        },
        {
          "@type": "Question",
          "name": "Can I export the student loan repayment schedule to Excel?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The full amortization schedule can be exported to Excel (.xls) or CSV, so you can keep your own student loan payoff calculator in Excel or share the repayment plan."
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-3 flex flex-col gap-4 animate-fade-in-up pb-24 lg:pb-12">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav class="flex items-center gap-1.5 text-xs font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-2xl sm:text-3xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2.5 rounded-full font-semibold uppercase shrink-0">{tier}</span>
        </div>
        
        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How student loan calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left Column: Inputs (7 Columns) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="card-base flex flex-col gap-5">
          <h2 class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Loan Information
          </h2>

          <!-- Row 1: Loan Balance & Currency Select -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center justify-between">
                <label for="loan-balance" class="text-xs font-semibold text-charcoal">
                  Loan Balance
                </label>
                <!-- Currency Select -->
                <select
                  id="currency-select"
                  class="text-[10px] font-semibold py-1 px-2.5 rounded-full border border-hairline bg-surface hover:bg-canvas cursor-pointer transition-all outline-none"
                  aria-label="Currency Select"
                >
                  <option value="USD" selected>$ USD</option>
                  <option value="CAD">$ CAD</option>
                  <option value="GBP">£ GBP</option>
                  <option value="AUD">$ AUD</option>
                  <option value="EUR">€ EUR</option>
                  <option value="INR">₹ INR</option>
                  <option value="Custom">Custom / Other</option>
                </select>
              </div>
              <div class="relative">
                <span id="currency-prefix" class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol">$</span>
                <input
                  type="number"
                  id="loan-balance"
                  value="30000"
                  min="500"
                  max="10000000"
                  step="500"
                  class="text-input pl-7 font-mono text-sm"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
            </div>

            <!-- Annual Interest Rate with Slider -->
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-charcoal flex justify-between">
                <span>Annual Interest Rate</span>
                <span id="interest-rate-val" class="font-mono text-stone font-bold">5.50%</span>
              </label>
              <div class="flex items-center gap-3">
                <input
                  type="range"
                  id="interest-rate-range"
                  min="0.1"
                  max="20"
                  value="5.5"
                  step="0.05"
                  class="w-full cursor-pointer accent-brand-blue"
                  aria-label="Interest Rate Slider"
                />
                <div class="relative w-20 shrink-0">
                  <input
                    type="number"
                    id="interest-rate-input"
                    min="0.1"
                    max="30"
                    value="5.5"
                    step="0.01"
                    class="text-input pr-5 py-1 text-xs text-center font-mono h-8"
                    inputmode="decimal"
                  />
                  <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
                </div>
              </div>
              <div id="rate-hint" class="text-[10px] text-brand-blue font-semibold">
                Typical federal student loan rate.
              </div>
            </div>
          </div>

          <!-- Custom Currency Inputs (Hidden by default) -->
          <div id="custom-currency-container" class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft hidden animate-fade-in-up">
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-symbol" class="text-[10px] font-semibold text-slate">Currency Symbol</label>
              <input type="text" id="custom-currency-symbol" value="$" class="text-input" placeholder="e.g. $, £, €, ₹" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-code" class="text-[10px] font-semibold text-slate">Currency Code</label>
              <input type="text" id="custom-currency-code" value="USD" class="text-input" placeholder="e.g. USD, GBP, EUR" />
            </div>
          </div>

          <!-- Row 2: Current Monthly Payment & Extra Monthly Payment -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="current-payment" class="text-xs font-semibold text-charcoal flex justify-between">
                <span id="current-payment-label">Current Monthly Payment</span>
                <span class="text-[10px] text-stone font-normal">(Auto-calculated if 0)</span>
              </label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol">$</span>
                <input
                  type="number"
                  id="current-payment"
                  value="0"
                  min="0"
                  max="100000"
                  step="10"
                  class="text-input pl-7 font-mono text-sm"
                  inputmode="numeric"
                  placeholder="Calculated"
                  autocomplete="off"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="extra-payment" class="text-xs font-semibold text-charcoal flex justify-between">
                <span>Extra Monthly Payment</span>
                <span class="text-[10px] text-success-accent font-semibold">Payoff Acceleration</span>
              </label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol">$</span>
                <input
                  type="number"
                  id="extra-payment"
                  value="100"
                  min="0"
                  max="100000"
                  step="10"
                  class="text-input pl-7 font-mono text-sm bg-surface-pricing-featured"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
            </div>
          </div>

          <!-- Row 3: Loan Term presets & slider -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Loan Term</span>
              <span id="loan-term-val" class="font-mono text-stone font-bold">10 years (120 months)</span>
            </label>
            <div class="grid grid-cols-6 gap-1">
              {
                [5, 10, 15, 20, 25, 30].map((years) => (
                  <button
                    type="button"
                    class="preset-term-btn text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer border border-hairline text-slate bg-canvas hover:border-hairline-strong active:scale-95 flex items-center justify-center"
                    data-term={years}
                  >
                    {years}y
                  </button>
                ))
              }
            </div>
            <div class="flex items-center gap-3 mt-1.5">
              <input
                type="range"
                id="loan-term-range"
                min="1"
                max="30"
                value="10"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Loan Term Custom Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="loan-term-input"
                  min="1"
                  max="40"
                  value="10"
                  class="text-input pr-8 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">yrs</span>
              </div>
            </div>
          </div>

          <!-- Collapsible Advanced Options Toggle -->
          <div class="border-t border-hairline pt-4 mt-2">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-xs font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1.5">
                ⚙ Advanced Options +
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <!-- Advanced Panel content -->
            <div
              id="advanced-panel"
              class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-4 border-t border-hairline-soft mt-3 pt-4"
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Loan Type select -->
                <div class="flex flex-col gap-1.5">
                  <label for="loan-type" class="text-[11px] font-semibold text-slate">
                    Loan Type
                  </label>
                  <select id="loan-type" class="text-input py-1 text-xs font-medium">
                    <!-- Loaded dynamically per country -->
                  </select>
                </div>

                <!-- Grace / Moratorium Period (months) -->
                <div class="flex flex-col gap-1.5">
                  <label for="grace-period" id="grace-period-label" class="text-[11px] font-semibold text-slate">
                    Grace Period (months)
                  </label>
                  <div class="relative">
                    <input
                      type="number"
                      id="grace-period"
                      value="0"
                      min="0"
                      max="120"
                      step="1"
                      class="text-input pr-12 font-mono text-xs"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-xs">months</span>
                  </div>
                </div>
              </div>

              <!-- Origination Fee & Start Date -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label for="origination-fee" class="text-[11px] font-semibold text-slate">
                    Origination / Processing Fee (%)
                  </label>
                  <div class="relative">
                    <input
                      type="number"
                      id="origination-fee"
                      value="0"
                      min="0"
                      max="10"
                      step="0.05"
                      class="text-input pr-6 font-mono text-xs"
                      inputmode="decimal"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-xs">%</span>
                  </div>
                </div>

                <div class="flex flex-col gap-1.5">
                  <label for="start-date" class="text-[11px] font-semibold text-slate">
                    Repayment Start Date
                  </label>
                  <input
                    type="date"
                    id="start-date"
                    class="text-input font-mono text-xs"
                    autocomplete="off"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Sidebar outputs / hero outputs (5 Columns) -->
      <div id="hero-section" class="lg:col-span-5 flex flex-col gap-6">
        <!-- Core Key Outputs Pane -->
        <div class="card-feature-teal flex flex-col justify-between bg-surface relative overflow-hidden rounded-xl p-6 border border-hairline-soft min-h-[360px]">
          <div class="absolute top-0 right-0 w-32 h-32 bg-teal-light/20 rounded-full blur-3xl"></div>
          
          <div class="flex flex-col gap-5 z-10">
            <div>
              <span id="output-hero-label" class="text-xs font-bold text-moss-dark uppercase tracking-wider block">Monthly Payment</span>
              <div id="monthly-payment-display" class="font-display font-medium text-4xl sm:text-5xl tracking-tight text-primary transition-all duration-300 select-all font-mono">
                $0.00
              </div>
              <span id="monthly-payment-subtitle" class="text-[10px] text-slate block mt-1">Based on standard amortization term</span>
            </div>

            <!-- Basic stats row -->
            <div class="grid grid-cols-2 gap-4 border-t border-moss-dark/15 pt-4 mt-2">
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-moss-dark/80">Payoff Date</span>
                <span id="payoff-date-display" class="font-display font-semibold text-base text-primary select-all">December 2036</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-moss-dark/80">Total Interest Paid</span>
                <span id="total-interest-display" class="font-display font-semibold text-base text-primary font-mono select-all">$0.00</span>
              </div>
            </div>

            <div class="flex flex-col border-t border-moss-dark/15 pt-4">
              <span class="text-[10px] uppercase font-bold text-moss-dark/80">Payoff Duration</span>
              <span id="payoff-duration-display" class="font-display font-semibold text-base text-primary select-all">10 Years</span>
            </div>
          </div>

          <div class="mt-6 z-10">
            <button
              type="button"
              id="view-results-btn"
              class="w-full button-primary !text-xs !py-3 !px-4 hover:bg-charcoal active:scale-98 shadow-subtle flex items-center justify-center gap-1.5 transition-all duration-300"
            >
              <span>View Detailed Results</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7-7-7m14-6l-7 7-7-7"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Results Section (Always below inputs, scrolled to via "View Results") -->
    <div id="results-column" class="flex flex-col gap-6 mt-8 border-t border-hairline pt-8">
      <div id="payment-warning" class="hidden p-4 bg-surface border border-brand-red/30 text-brand-red-dark rounded-xl text-xs font-semibold flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-red-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span id="payment-warning-text"></span>
      </div>

      <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-3">
        <h2 class="font-display font-semibold text-2xl text-primary flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-success-accent animate-pulse"></span>
          Repayment Analysis & Comparison
        </h2>

        <!-- Exports -->
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="copy-results-btn"
            class="inline-flex items-center gap-1 text-xs font-semibold px-3.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
            </svg>
            <span>Copy Results</span>
          </button>
          <button
            type="button"
            id="csv-export-btn"
            class="inline-flex items-center gap-1 text-xs font-semibold px-3.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span>Export CSV</span>
          </button>
        </div>
      </div>

      <!-- Comparison Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Standard Plan Card -->
        <div class="card-base bg-surface-soft border border-hairline p-6 flex flex-col gap-4">
          <h3 class="font-display font-semibold text-base text-primary flex items-center gap-2 border-b border-hairline-soft pb-2">
            <span class="w-2.5 h-2.5 rounded-full bg-slate"></span>
            Standard Repayment Plan
          </h3>
          <div class="flex flex-col gap-3">
            <div class="flex justify-between items-center text-xs">
              <span class="text-slate font-medium">Monthly Repayment:</span>
