    // Range-Numeric synchronizers
    function setupSync(rangeEl: HTMLInputElement, inputEl: HTMLInputElement, valLabel: HTMLElement | null, suffix: string) {
      rangeEl.addEventListener("input", () => {
        inputEl.value = rangeEl.value;
        if (valLabel) {
          valLabel.textContent = `${parseFloat(rangeEl.value).toFixed(suffix === "y" ? 0 : 2)}${suffix}`;
        }
        updatePresetsUI();
        calculate();
      });
      inputEl.addEventListener("input", () => {
        const val = Math.min(parseFloat(inputEl.value) || 0, parseFloat(rangeEl.max));
        rangeEl.value = val.toString();
        if (valLabel) {
          valLabel.textContent = `${val.toFixed(suffix === "y" ? 0 : 2)}${suffix}`;
        }
        updatePresetsUI();
        calculate();
      });
    }
    setupSync(interestRateRange, interestRateInput, interestRateValLabel, "%");
    setupSync(loanTermRange, loanTermInput, null, "y");

    loanTermRange.addEventListener("input", () => {
