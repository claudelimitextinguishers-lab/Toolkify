      age: number;
      salary: number;
      additions: number;
      match: number;
      balance: number;
      realBalance: number;
    }[] = [];

    // Helper functions
    function formatCurrency(amount: number): string {
      const config = COUNTRY_DATA[currentCurrency] || COUNTRY_DATA.Custom;
      const symbol =
        currentCurrency === "Custom"
          ? customCurrencySymbolInput?.value || "$"
          : config.currencySymbol;

      // Formatting options
      const formatted = amount.toLocaleString(undefined, {
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      });
      return `${symbol}${formatted}`;
    }

    function updateFilingAndAccountOptions() {
      const config = COUNTRY_DATA[currentCurrency] || COUNTRY_DATA.Custom;

      // Update Account Types Select
      if (accountTypeSelect) {
        accountTypeSelect.innerHTML = "";
        config.accountTypes.forEach((t) => {
          const opt = document.createElement("option");
          opt.value = t.id;
          opt.textContent = t.name;
          accountTypeSelect.appendChild(opt);
        });
      }

      // Update Filing Statuses Select
      if (filingStatusSelect) {
        filingStatusSelect.innerHTML = "";
        config.filingStatuses.forEach((s) => {
          const opt = document.createElement("option");
          opt.value = s.id;
          opt.textContent = s.name;
          filingStatusSelect.appendChild(opt);
        });
      }

      // Update Tax Note
      if (taxNoteContent) {
        taxNoteContent.textContent = config.taxNote;
      }

      // Update Tool Title dynamically
      if (toolTitle) {
        toolTitle.textContent = `${config.toolTitle} & Retirement Savings`;
      }
    }

    function calculate() {
      const config = COUNTRY_DATA[currentCurrency] || COUNTRY_DATA.Custom;

      const currAge = parseInt(currentAgeInput.value, 10) || 25;
      let retAge = parseInt(retirementAgeInput.value, 10) || 65;

      if (retAge <= currAge) {
        retAge = currAge + 1;
        retirementAgeInput.value = retAge.toString();
        retirementAgeRange.value = retAge.toString();
        if (retirementAgeValLabel)
          retirementAgeValLabel.textContent = `${retAge} yrs`;
      }

      const currentBalance = parseFloat(currentBalanceInput.value) || 0;
      let salary = parseFloat(annualSalaryInput.value) || 0;
      const contribRate = (parseFloat(yourContributionInput.value) || 0) / 100;
      const matchRate = (parseFloat(employerMatchInput.value) || 0) / 100;
      const matchLimit = (parseFloat(employerMatchLimitInput.value) || 0) / 100;
      const expectedReturn = (parseFloat(expectedReturnInput.value) || 0) / 100;
      const inflationRate = (parseFloat(inflationRateInput.value) || 0) / 100;
      const salaryGrowth = (parseFloat(salaryGrowthInput.value) || 0) / 100;

      // Limits setup
      const isCatchup = catchupToggle.checked;
      let limitCap = config.limitNormal;

      // Update labels with real-time numbers
      const annualContribEst = salary * contribRate;
      if (yourContributionValLabel) {
        yourContributionValLabel.textContent = `${(contribRate * 100).toFixed(1)}% (${formatCurrency(annualContribEst)}/yr)`;
      }

      // Projections loop variables
      let balance = currentBalance;
      let totalContributed = 0;
      let totalMatch = 0;
      projectionYearsData = [];

      const yearsToRetire = retAge - currAge;

      // Compounding return calculation setup
      const monthlyReturn = Math.pow(1 + expectedReturn, 1 / 12) - 1;

      // Warnings state check
      let warningTriggered = false;

      for (let y = 0; y < yearsToRetire; y++) {
        const age = currAge + y;
        const currentYearSalary = salary * Math.pow(1 + salaryGrowth, y);

        // Local limits check per age
        let localizedLimit = config.limitNormal;
        if (isCatchup && age >= config.catchupAge) {
          localizedLimit = config.limitCatchup;
          limitCap = config.limitCatchup;
        }

        let yourAnnualContribution = currentYearSalary * contribRate;
        if (yourAnnualContribution > localizedLimit) {
          yourAnnualContribution = localizedLimit;
          warningTriggered = true;
        }

        // Match calculation: capped at match limit as percentage of salary
        const baseMatchAmount = currentYearSalary * matchLimit;
        const actualMatchInput = currentYearSalary * contribRate;
        const matchEligible = Math.min(actualMatchInput, baseMatchAmount);
        const employerAnnualMatch = matchEligible * matchRate;

        totalContributed += yourAnnualContribution;
        totalMatch += employerAnnualMatch;

        // Apply contributions and compound monthly
        const annualAdditions = yourAnnualContribution + employerAnnualMatch;
        const monthlyAddition = annualAdditions / 12;

        for (let m = 0; m < 12; m++) {
          balance = (balance + monthlyAddition) * (1 + monthlyReturn);
        }

        // Real balance (inflation adjusted)
        const realBalance = balance / Math.pow(1 + inflationRate, y + 1);

        projectionYearsData.push({
          age: age + 1,
          salary: currentYearSalary,
          additions: yourAnnualContribution,
          match: employerAnnualMatch,
          balance: balance,
          realBalance: realBalance,
        });
      }

      // Warning display logic
      if (contributionWarning && warningText) {
        if (warningTriggered) {
          contributionWarning.classList.remove("hidden");
          warningText.textContent = `You are hitting the annual tax-advantaged contribution cap of ${formatCurrency(limitCap)} (or age 50+ catch-up cap of ${formatCurrency(config.limitCatchup)}) for ${config.countryName}. Any excess savings will not be projected.`;
        } else {
          contributionWarning.classList.add("hidden");
        }
      }

      // Display Hero outputs
      if (projectedBalanceDisplay)
        projectedBalanceDisplay.textContent = formatCurrency(balance);
      if (totalContributedDisplay)
        totalContributedDisplay.textContent = formatCurrency(totalContributed);
      if (totalMatchDisplay)
        totalMatchDisplay.textContent = formatCurrency(totalMatch);

      // Monthly retirement income (4% rule)
      const monthlyIncome = (balance * 0.04) / 12;
      if (monthlyIncomeDisplay)
        monthlyIncomeDisplay.textContent = `${formatCurrency(monthlyIncome)}/mo`;

      // Real vs Nominal details
      const inflationLoss =
        balance -
        (projectionYearsData[projectionYearsData.length - 1]?.realBalance ||
          balance);
      const lossPct = balance > 0 ? (inflationLoss / balance) * 100 : 0;

      if (nominalBalanceVal)
        nominalBalanceVal.textContent = formatCurrency(balance);
      if (realBalanceVal)
        realBalanceVal.textContent = formatCurrency(
          projectionYearsData[projectionYearsData.length - 1]?.realBalance ||
            balance,
        );
      if (inflationLossPct)
        inflationLossPct.textContent = `${lossPct.toFixed(1)}%`;

      // Mobile sticky update
      const mobileVal = document.getElementById("mobile-summary-value");
      if (mobileVal) mobileVal.textContent = formatCurrency(balance);

      renderGrowthTable();
      renderChart(totalContributed, totalMatch, balance);
      saveState();
    }

    function renderGrowthTable() {
      if (!growthTableBody) return;

      const rowsToShow = showFullGrowth
        ? projectionYearsData
        : projectionYearsData.slice(0, 6);
      let html = "";

      rowsToShow.forEach((row) => {
        html += `
          <tr class="border-b border-hairline hover:bg-surface/50 font-mono text-[11px] text-charcoal">
            <td class="py-2.5 px-3 font-semibold text-slate">${row.age}</td>
            <td class="py-2.5 px-3 text-right">${formatCurrency(row.salary)}</td>
            <td class="py-2.5 px-3 text-right">${formatCurrency(row.additions)}</td>
            <td class="py-2.5 px-3 text-right">${formatCurrency(row.match)}</td>
            <td class="py-2.5 px-3 text-right text-primary font-semibold">${formatCurrency(row.balance)}</td>
            <td class="py-2.5 px-3 text-right text-brand-blue font-semibold">${formatCurrency(row.realBalance)}</td>
          </tr>
        `;
      });

      growthTableBody.innerHTML = html;

      // Update button label
      if (toggleGrowthBtn) {
        toggleGrowthBtn.textContent = showFullGrowth
          ? "Collapse Schedule"
          : `Show Full Schedule (${projectionYearsData.length} years)`;
      }
    }

    // Chart Renderer: Draw SVG stacked bar chart
    function renderChart(contrib: number, match: number, total: number) {
      const svg = document.getElementById("growth-chart-svg");
      if (!svg) return;

      const data = projectionYearsData;
      if (data.length === 0) return;

      // Draw responsive SVG bars
      const width = 500;
      const height = 200;
      const paddingLeft = 40;
      const paddingRight = 10;
      const paddingTop = 20;
      const paddingBottom = 20;

      const plotWidth = width - paddingLeft - paddingRight;
      const plotHeight = height - paddingTop - paddingBottom;

      // Find max balance to scale Y axis
      const maxBalance = Math.max(...data.map((d) => d.balance));

      // Calculate step for X axis (draw ~10 bars max to avoid overcrowding)
      const step = Math.max(1, Math.ceil(data.length / 15));

      let chartContentHtml = "";

      // Draw grid lines
      const gridCount = 4;
      for (let i = 0; i <= gridCount; i++) {
        const yVal = (i / gridCount) * maxBalance;
        const yPos = height - paddingBottom - (i / gridCount) * plotHeight;

        // Lines
        chartContentHtml += `
          <line x1="${paddingLeft}" y1="${yPos}" x2="${width - paddingRight}" y2="${yPos}" stroke="var(--color-hairline)" stroke-width="1" stroke-dasharray="2,2" />
          <text x="${paddingLeft - 5}" y="${yPos + 4}" font-size="8" fill="var(--color-stone)" text-anchor="end" font-family="monospace">
            ${formatCurrency(yVal)}
          </text>
        `;
      }

      // Draw Bars
      const barWidth = Math.max(2, (plotWidth / data.length) * 0.7);

      data.forEach((d, idx) => {
        const xPos = paddingLeft + (idx / data.length) * plotWidth;

        const scale = plotHeight / maxBalance;
        const contribHeight = d.additions * scale;
        const matchHeight = d.match * scale;
        const growthHeight = Math.max(0, (d.balance - d.additions - d.match) * scale);

        // Draw stacked parts (bottom: contributions, middle: match, top: interest)
        const yContrib = height - paddingBottom - contribHeight;
        const yMatch = yContrib - matchHeight;
        const yGrowth = yMatch - growthHeight;

        chartContentHtml += `
          <rect x="${xPos}" y="${yContrib}" width="${barWidth}" height="${contribHeight}" fill="#4262ff" rx="1" />
          <rect x="${xPos}" y="${yMatch}" width="${barWidth}" height="${matchHeight}" fill="#0fbcb0" rx="1" />
          <rect x="${xPos}" y="${yGrowth}" width="${barWidth}" height="${growthHeight}" fill="#fcb900" rx="1" />
        `;

        // Age labels on X axis
        if (idx % step === 0 || idx === data.length - 1) {
          chartContentHtml += `
            <text x="${xPos + barWidth / 2}" y="${height - 5}" font-size="8" fill="var(--color-slate)" text-anchor="middle" font-family="monospace">
              ${d.age}
            </text>
          `;
        }
      });

      svg.innerHTML = chartContentHtml;
    }

    // Sync input range & value fields
    function syncRangeInput(
      rangeEl: HTMLInputElement,
      inputEl: HTMLInputElement,
      labelEl: HTMLElement | null,
      formatter: (v: number) => string,
    ) {
      rangeEl.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        inputEl.value = val;
        if (labelEl) labelEl.textContent = formatter(parseFloat(val));
        calculate();
      });

      inputEl.addEventListener("input", (e) => {
        let val = parseFloat((e.target as HTMLInputElement).value) || 0;
        const min = parseFloat(inputEl.min || "0");
        const max = parseFloat(inputEl.max || "100");
        val = Math.max(min, Math.min(max, val));
        rangeEl.value = val.toString();
        if (labelEl) labelEl.textContent = formatter(val);
        calculate();
      });
    }

    function exportToCSV() {
      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent +=
        "Age,Nominal Salary,Your Additions,Employer Match,End Balance (Nominal),End Balance (Real)\r\n";

      projectionYearsData.forEach((row) => {
        csvContent += `${row.age},${row.salary.toFixed(2)},${row.additions.toFixed(2)},${row.match.toFixed(2)},${row.balance.toFixed(2)},${row.realBalance.toFixed(2)}\r\n`;
      });

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", `Retirement_Projection_${Date.now()}.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    function exportToExcel() {
      if (projectionYearsData.length === 0) return;

      let tableRows = "";
      projectionYearsData.forEach((row) => {
        tableRows += `
          <tr>
            <td>${row.age}</td>
            <td>${row.salary.toFixed(2)}</td>
            <td>${row.additions.toFixed(2)}</td>
            <td>${row.match.toFixed(2)}</td>
            <td>${row.balance.toFixed(2)}</td>
            <td>${row.realBalance.toFixed(2)}</td>
          </tr>
        `;
      });

      const html = `
        <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
        <head>
          <!--[if gte mso 9]>
          <xml>
            <x:ExcelWorkbook>
              <x:ExcelWorksheets>
                <x:ExcelWorksheet>
                  <x:Name>Retirement Schedule</x:Name>
                  <x:WorksheetOptions>
                    <x:DisplayGridlines/>
                  </x:WorksheetOptions>
                </x:ExcelWorksheet>
              </x:ExcelWorksheets>
            </x:ExcelWorkbook>
          </xml>
          <![endif]-->
          <style>
            table { border-collapse: collapse; }
            th, td { border: 1px solid #e2e8f0; padding: 8px; font-family: sans-serif; font-size: 12px; }
            th { background-color: #f7fafc; font-weight: bold; }
          </style>
        </head>
        <body>
          <table>
            <tr style="background-color: #f7fafc; font-weight: bold;">
              <td>Age</td>
              <td>Nominal Salary</td>
              <td>Your Additions</td>
              <td>Employer Match</td>
              <td>End Balance (Nominal)</td>
              <td>End Balance (Real)</td>
            </tr>
            ${tableRows}
          </table>
        </body>
        </html>
      `;

      const blob = new Blob([html], { type: "application/vnd.ms-excel" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `Retirement_Schedule_${Date.now()}.xls`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    function copyToClipboard() {
      let text =
        "Age\tSalary\tContributions\tEmployer Match\tNominal Balance\tReal Balance\n";
      projectionYearsData.forEach((row) => {
        text += `${row.age}\t${row.salary.toFixed(0)}\t${row.additions.toFixed(0)}\t${row.match.toFixed(0)}\t${row.balance.toFixed(0)}\t${row.realBalance.toFixed(0)}\n`;
      });

      navigator.clipboard
        .writeText(text)
        .then(() => {
          if (copyResultsBtn) {
            const prevText = copyResultsBtn.innerHTML;
            copyResultsBtn.innerHTML = `<span>✔ Copied!</span>`;
            setTimeout(() => {
              copyResultsBtn.innerHTML = prevText;
            }, 2000);
          }
        })
        .catch((err) => {
          console.error("Could not copy text: ", err);
        });
    }

    // LocalStorage Load/Save
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const getSafeItem = (key: string): string | null => {
        const paramKey = key.replace("retirement-", "");
        if (urlParams.has(paramKey)) {
          return urlParams.get(paramKey);
        }
        if (typeof localStorage === "undefined") return null;
        try {
          return localStorage.getItem(key);
        } catch (e) {
          return null;
        }
      };

      const savedCurrency = getSafeItem("retirement-currency");
      const savedAge = getSafeItem("retirement-age-val");
      const savedRetAge = getSafeItem("retirement-retage-val");
      const savedBalance = getSafeItem("retirement-balance");
      const savedSalary = getSafeItem("retirement-salary");
      const savedContrib = getSafeItem("retirement-contrib");
      const savedMatch = getSafeItem("retirement-match");
      const savedMatchLimit = getSafeItem("retirement-matchlimit");
      const savedReturn = getSafeItem("retirement-return");
      const savedInflation = getSafeItem("retirement-inflation");
      const savedGrowth = getSafeItem("retirement-growth");
      const savedCatchup = getSafeItem("retirement-catchup");

      if (savedCurrency !== null) {
        currentCurrency = savedCurrency;
        currencySelect.value = savedCurrency;
      }
      if (savedAge !== null) {
        currentAgeInput.value = savedAge;
        currentAgeRange.value = savedAge;
      }
      if (savedRetAge !== null) {
        retirementAgeInput.value = savedRetAge;
        retirementAgeRange.value = savedRetAge;
      }
      if (savedBalance !== null) currentBalanceInput.value = savedBalance;
      if (savedSalary !== null) annualSalaryInput.value = savedSalary;
      if (savedContrib !== null) {
        yourContributionInput.value = savedContrib;
        yourContributionRange.value = savedContrib;
      }
      if (savedMatch !== null) employerMatchInput.value = savedMatch;
      if (savedMatchLimit !== null)
        employerMatchLimitInput.value = savedMatchLimit;
      if (savedReturn !== null) {
        expectedReturnInput.value = savedReturn;
        expectedReturnRange.value = savedReturn;
      }
      if (savedInflation !== null) inflationRateInput.value = savedInflation;
      if (savedGrowth !== null) salaryGrowthInput.value = savedGrowth;
      if (savedCatchup !== null)
        catchupToggle.checked = savedCatchup === "true";

      // Reformat symbols and trigger first calculations
      updateFilingAndAccountOptions();
      updateCurrencyLabels();
    }

    function saveState() {
      if (typeof localStorage === "undefined") return;

      const setSafeItem = (key: string, val: string) => {
        try {
          localStorage.setItem(key, val);
        } catch (e) {}
      };

      setSafeItem("retirement-currency", currentCurrency);
      setSafeItem("retirement-age-val", currentAgeInput.value);
      setSafeItem("retirement-retage-val", retirementAgeInput.value);
      setSafeItem("retirement-balance", currentBalanceInput.value);
      setSafeItem("retirement-salary", annualSalaryInput.value);
      setSafeItem("retirement-contrib", yourContributionInput.value);
      setSafeItem("retirement-match", employerMatchInput.value);
      setSafeItem("retirement-matchlimit", employerMatchLimitInput.value);
      setSafeItem("retirement-return", expectedReturnInput.value);
      setSafeItem("retirement-inflation", inflationRateInput.value);
      setSafeItem("retirement-growth", salaryGrowthInput.value);
      setSafeItem(
        "retirement-catchup",
        catchupToggle.checked ? "true" : "false",
      );
    }

    function updateCurrencyLabels() {
      const config = COUNTRY_DATA[currentCurrency] || COUNTRY_DATA.Custom;
      const symbol =
        currentCurrency === "Custom"
          ? customCurrencySymbolInput?.value || "$"
          : config.currencySymbol;

      // Update all elements with class 'currency-symbol'
      document.querySelectorAll(".currency-symbol").forEach((el) => {
        el.textContent = symbol;
      });
    }

    // Set defaults per country
    function handleCountryChange() {
      currentCurrency = currencySelect.value;
      const config = COUNTRY_DATA[currentCurrency] || COUNTRY_DATA.Custom;

      // Pre-fill employer match limits based on country defaults
      employerMatchInput.value = config.defaultMatchRate.toString();
      employerMatchLimitInput.value = config.defaultMatchLimit.toString();

      // Show/Hide custom currency box
      if (currentCurrency === "Custom") {
        customCurrencyContainer?.classList.remove("hidden");
      } else {
        customCurrencyContainer?.classList.add("hidden");
      }

      // Configure catchup toggle description based on selection
      const catchupDesc = document.getElementById("catchup-description");
      if (catchupDesc) {
        if (currentCurrency === "USD") {
          catchupDesc.textContent =
            "Enable higher annual limit for age 50+ (adds $7,500)";
        } else {
          catchupDesc.textContent = `Enable catch-up contribution limits (Not supported or customized for ${config.countryName})`;
        }
      }

      updateFilingAndAccountOptions();
      updateCurrencyLabels();
      calculate();
    }

    // DOM Loaded Listeners
    window.addEventListener("DOMContentLoaded", () => {
      loadState();

      // Sync range & values
      syncRangeInput(
        currentAgeRange,
        currentAgeInput,
        currentAgeValLabel,
        (v) => `${v} yrs`,
      );
      syncRangeInput(
        retirementAgeRange,
        retirementAgeInput,
        retirementAgeValLabel,
        (v) => `${v} yrs`,
      );
      syncRangeInput(
        yourContributionRange,
        yourContributionInput,
        null,
        (v) => `${v}%`,
      );
      syncRangeInput(
        expectedReturnRange,
        expectedReturnInput,
        expectedReturnValLabel,
        (v) => `${v.toFixed(2)}%`,
      );

      // Inputs listeners
      currentBalanceInput.addEventListener("input", calculate);
      annualSalaryInput.addEventListener("input", calculate);
      employerMatchInput.addEventListener("input", calculate);
      employerMatchLimitInput.addEventListener("input", calculate);
      inflationRateInput.addEventListener("input", calculate);
      salaryGrowthInput.addEventListener("input", calculate);
      catchupToggle.addEventListener("change", calculate);
      accountTypeSelect?.addEventListener("change", calculate);
      filingStatusSelect?.addEventListener("change", calculate);

      // Presets
      presetAgeButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const val = btn.getAttribute("data-age") || "65";
          retirementAgeInput.value = val;
          retirementAgeRange.value = val;
          if (retirementAgeValLabel)
            retirementAgeValLabel.textContent = `${val} yrs`;
          calculate();
        });
      });

      // Currency Select
      currencySelect?.addEventListener("change", handleCountryChange);
      customCurrencySymbolInput?.addEventListener("input", () => {
        updateCurrencyLabels();
        calculate();
      });
      customCurrencyCodeInput?.addEventListener("input", () => {
        calculate();
      });

      // Advanced Toggle
      advancedToggleBtn?.addEventListener("click", () => {
        if (advancedPanel) {
          const isCollapsed = advancedPanel.classList.contains("max-h-0");
          if (isCollapsed) {
            advancedPanel.classList.remove("max-h-0");
            advancedPanel.classList.add("max-h-[2000px]");
            advancedChevron?.classList.add("rotate-180");
          } else {
            advancedPanel.classList.remove("max-h-[2000px]");
            advancedPanel.classList.add("max-h-0");
            advancedChevron?.classList.remove("rotate-180");
          }
        }
      });

      // Growth table toggle
      toggleGrowthBtn?.addEventListener("click", () => {
        showFullGrowth = !showFullGrowth;
        renderGrowthTable();
      });

      // Exports
      csvExportBtn?.addEventListener("click", exportToCSV);
      excelExportBtn?.addEventListener("click", exportToExcel);
      copyResultsBtn?.addEventListener("click", copyToClipboard);

      // Reset action
      resetBtn?.addEventListener("click", () => {
        if (typeof localStorage !== "undefined") {
          try {
            [
              "currency",
              "age-val",
              "retage-val",
              "balance",
              "salary",
              "contrib",
              "match",
              "matchlimit",
              "return",
              "inflation",
              "growth",
              "catchup",
            ].forEach((k) => localStorage.removeItem("retirement-" + k));
          } catch (e) {}
        }
        currentAgeInput.value = "25";
        currentAgeRange.value = "25";
        if (currentAgeValLabel) currentAgeValLabel.textContent = "25 yrs";
        retirementAgeInput.value = "65";
        retirementAgeRange.value = "65";
        if (retirementAgeValLabel) retirementAgeValLabel.textContent = "65 yrs";
        currentBalanceInput.value = "10000";
        annualSalaryInput.value = "75000";
        yourContributionInput.value = "8";
        yourContributionRange.value = "8";
        expectedReturnInput.value = "7";
        expectedReturnRange.value = "7";
        if (expectedReturnValLabel)
          expectedReturnValLabel.textContent = "7.00%";
        inflationRateInput.value = "2.5";
        salaryGrowthInput.value = "3.0";
        catchupToggle.checked = false;
        currencySelect.value = "USD";
        currentCurrency = "USD";

        handleCountryChange();
      });

      // Modals
      howItWorksBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.remove("hidden"),
      );
      closeModalBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.add("hidden"),
      );
      modalOkBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.add("hidden"),
      );

      // Share button copy link logic
      const shareBtn = document.getElementById("share-btn");
      shareBtn?.addEventListener("click", () => {
        const url = new URL(window.location.origin + window.location.pathname);
        if (currencySelect) url.searchParams.set("currency", currencySelect.value);
        url.searchParams.set("age-val", currentAgeInput.value);
        url.searchParams.set("retage-val", retirementAgeInput.value);
        url.searchParams.set("balance", currentBalanceInput.value);
        url.searchParams.set("salary", annualSalaryInput.value);
        url.searchParams.set("contrib", yourContributionInput.value);
        url.searchParams.set("match", employerMatchInput.value);
        url.searchParams.set("matchlimit", employerMatchLimitInput.value);
        url.searchParams.set("return", expectedReturnInput.value);
        url.searchParams.set("inflation", inflationRateInput.value);
        url.searchParams.set("growth", salaryGrowthInput.value);
        url.searchParams.set("catchup", catchupToggle.checked ? "true" : "false");

        const shareData = {
          title: document.title || "Toolkify",
          url: url.toString()
        };

        if (navigator.share) {
          navigator.share(shareData).catch((err) => {
            if (err.name !== "AbortError") {
              copyToClipboard(url.toString());
            }
          });
        } else {
          copyToClipboard(url.toString());
        }

        function copyToClipboard(text: string) {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
          } else {
            fallbackCopy(text);
          }
        }

        function fallbackCopy(text: string) {
          const textArea = document.createElement("textarea");
          textArea.value = text;
          textArea.style.position = "fixed";
          textArea.style.opacity = "0";
          document.body.appendChild(textArea);
          textArea.select();
          try {
            document.execCommand("copy");
            showSuccess();
          } catch (err) {
            console.error(err);
          }
          document.body.removeChild(textArea);
        }

        function showSuccess() {
          if (shareBtn) {
            const span = shareBtn.querySelector("span");
            if (span) {
              const originalText = span.textContent || "Share";
              span.textContent = "Link Copied!";
              shareBtn.classList.add("text-success-accent", "border-success-accent");
              setTimeout(() => {
                span.textContent = originalText;
                shareBtn.classList.remove("text-success-accent", "border-success-accent");
              }, 2000);
            }
          }
        }
      });

      // Scroll helpers
      const scrollResultsBtn = document.getElementById("scroll-results-btn");
      const resultsColumn = document.getElementById("results-column");
      if (scrollResultsBtn && resultsColumn) {
        scrollResultsBtn.addEventListener("click", () => {
          resultsColumn.scrollIntoView({ behavior: "smooth" });
        });
      }

      const mobileScrollBtn = document.getElementById(
        "mobile-scroll-results-btn",
      );
      const heroSummaryCard = document.getElementById("hero-summary-card");
      if (mobileScrollBtn && heroSummaryCard) {
        mobileScrollBtn.addEventListener("click", () => {
          heroSummaryCard.scrollIntoView({ behavior: "smooth" });
        });
      }

      // Mobile sticky bar scroll check
      const mobileStickyBar = document.getElementById("mobile-sticky-bar");
      if (mobileStickyBar && heroSummaryCard) {
        const handleScroll = () => {
          const rect = heroSummaryCard.getBoundingClientRect();
          if (rect.top <= window.innerHeight - 80) {
            mobileStickyBar.style.transform = "translateY(100%)";
          } else {
            mobileStickyBar.style.transform = "translateY(0)";
          }
        };
        window.addEventListener("scroll", handleScroll);
        handleScroll();
      }

      // FAQ Accordion Toggle Interaction
      const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
      faqToggleButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const expanded = btn.getAttribute("aria-expanded") === "true";
          
          // Close other open accordions
          faqToggleButtons.forEach((otherBtn) => {
            if (otherBtn !== btn) {
              otherBtn.setAttribute("aria-expanded", "false");
              const otherContent = otherBtn.nextElementSibling;
              if (otherContent) otherContent.classList.add("hidden");
              otherBtn.querySelector("svg")?.classList.remove("rotate-180");
            }
          });

          // Toggle current accordion
          btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
          const content = btn.nextElementSibling;
          if (content) {
            content.classList.toggle("hidden");
          }
          btn.querySelector("svg")?.classList.toggle("rotate-180");
        });
      });

      // Initial run
      calculate();
    });
  </script>
</Layout>
