  // Sync double inputs - Purchase mode
  function syncDownPayment(source: "dollar" | "percent" | "price") {
    const price = parseFloat(homePriceInput.value) || 0;
    const dpDollar = parseFloat(downPaymentDollarInput.value) || 0;
    const dpPercent = parseFloat(downPaymentPercentInput.value) || 0;

    if (source === "price") {
      const newDollar = Math.round(price * (dpPercent / 100));
      downPaymentDollarInput.value = newDollar.toString();
      downPaymentPercentSlider.value = dpPercent.toString();
    } else if (source === "dollar") {
      if (price > 0) {
        const percent = Math.min(100, Math.max(0, (dpDollar / price) * 100));
        downPaymentPercentInput.value = percent.toFixed(1);
        downPaymentPercentSlider.value = percent.toFixed(1);
      } else {
        downPaymentPercentInput.value = "0";
        downPaymentPercentSlider.value = "0";
      }
    } else if (source === "percent") {
      const computedDollar = Math.round(price * (dpPercent / 100));
      downPaymentDollarInput.value = computedDollar.toString();
      downPaymentPercentSlider.value = dpPercent.toString();
    }
  }

  function syncPropertyTaxes(source: "dollar" | "rate") {
    const price = parseFloat(homePriceInput.value) || 0;
    const taxDollar = parseFloat(propertyTaxDollarInput.value) || 0;
    const taxRate = parseFloat(propertyTaxRateInput.value) || 0;

    if (source === "rate") {
      propertyTaxDollarInput.value = Math.round(
        price * (taxRate / 100),
      ).toString();
    } else if (source === "dollar") {
      if (price > 0) {
        propertyTaxRateInput.value = ((taxDollar / price) * 100).toFixed(2);
      } else {
        propertyTaxRateInput.value = "0";
      }
    }
  }

