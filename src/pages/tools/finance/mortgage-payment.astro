  // Chart Grid Lines drawing
  function renderChartGrid(w: number, h: number, p: number) {
    if (!chartGridLines) return;
    let gridHtml = "";
    for (let i = 1; i <= 4; i++) {
      const x = p + (i / 5) * (w - 2 * p);
      gridHtml += `<line x1="${x}" y1="${p}" x2="${x}" y2="${h - p}" stroke="var(--color-hairline-soft)" stroke-width="1" />`;
    }
    for (let i = 1; i <= 3; i++) {
      const y = p + (i / 4) * (h - p);
      gridHtml += `<line x1="${p}" y1="${y}" x2="${w - p}" y2="${y}" stroke="var(--color-hairline-soft)" stroke-width="1" />`;
    }
    chartGridLines.innerHTML = gridHtml;
  }

  // Interactive mouse & touch tracer
  function setupChartTracer(
    schedule: any[],
    xScale: Function,
    yScale: Function,
    len: number,
    w: number,
    p: number,
    tooltipHtmlFn: Function,
  ) {
    if (!amortizationSvg) return;

    // Clear old listeners by cloning element
    const newSvg = amortizationSvg.cloneNode(true) as SVGSVGElement;
    amortizationSvg.parentNode?.replaceChild(newSvg, amortizationSvg);

    // Re-query new elements inside the cloned tree
    const traceLine = newSvg.querySelector(
      "#chart-trace-line",
    ) as SVGLineElement;
    const dotBal = newSvg.querySelector(
      "#chart-trace-dot-bal",
    ) as SVGCircleElement;
    const dotInt = newSvg.querySelector(
      "#chart-trace-dot-int",
    ) as SVGCircleElement;

    function handleMove(clientX: number) {
      const rect = newSvg.getBoundingClientRect();
      const svgX = ((clientX - rect.left) / rect.width) * w;

      const usableW = w - 2 * p;
      let pct = (svgX - p) / usableW;
      pct = Math.max(0, Math.min(1, pct));

      const idx = Math.min(len - 1, Math.floor(pct * len));
      const data = schedule[idx];
      if (!data) return;

      const xPos = p + (idx / (len - 1)) * usableW;
      const yBal = yScale(data.balance);
      const yInt = yScale(data.totalInterest);

      traceLine?.setAttribute("x1", xPos.toString());
      traceLine?.setAttribute("x2", xPos.toString());
      traceLine?.classList.remove("hidden");

      dotBal?.setAttribute("cx", xPos.toString());
      dotBal?.setAttribute("cy", yBal.toString());
      dotBal?.classList.remove("hidden");

      dotInt?.setAttribute("cx", xPos.toString());
      dotInt?.setAttribute("cy", yInt.toString());
      dotInt?.classList.remove("hidden");

      const parentElement = newSvg.parentElement;
      if (chartTooltip && parentElement) {
        chartTooltip.innerHTML = tooltipHtmlFn(data);
        chartTooltip.classList.remove("hidden");

        const parentRect = parentElement.getBoundingClientRect();
        const tooltipW = 120; // estimated width of the tooltip in pixels
        const tracerPixelX =
          rect.left - parentRect.left + (xPos / w) * rect.width;
        const containerW = parentRect.width;

        if (tracerPixelX > containerW - tooltipW - 20) {
          chartTooltip.style.left = `${tracerPixelX - tooltipW - 15}px`;
        } else {
          chartTooltip.style.left = `${tracerPixelX + 15}px`;
        }
        chartTooltip.style.top = `20px`;
      }
    }

    newSvg.addEventListener("mousemove", (e: MouseEvent) => {
      handleMove(e.clientX);
    });

    newSvg.addEventListener(
      "touchmove",
      (e: TouchEvent) => {
        if (e.touches && e.touches[0]) {
          // Prevent screen drag scroll during chart trace interaction
          e.preventDefault();
          handleMove(e.touches[0].clientX);
        }
      },
      { passive: false },
    );

    newSvg.addEventListener(
      "touchstart",
      (e: TouchEvent) => {
        if (e.touches && e.touches[0]) {
          handleMove(e.touches[0].clientX);
        }
      },
      { passive: true },
    );

    newSvg.addEventListener("mouseleave", () => {
      traceLine?.classList.add("hidden");
      dotBal?.classList.add("hidden");
      dotInt?.classList.add("hidden");
      chartTooltip?.classList.add("hidden");
    });

    newSvg.addEventListener("touchend", () => {
      traceLine?.classList.add("hidden");
      dotBal?.classList.add("hidden");
      dotInt?.classList.add("hidden");
      chartTooltip?.classList.add("hidden");
    });
  }

  // Amortization Donut draw
  function renderDonutChart(
    pi: number,
    taxes: number,
    ins: number,
    hoa: number,
    pmi: number,
  ) {
    const total = pi + taxes + ins + hoa + pmi;
    if (total === 0 || !donutSegments) return;

    if (donutPercent) {
      donutPercent.textContent = `${((pi / total) * 100).toFixed(0)}%`;
    }

    const list = [
      { color: colors.pi, val: pi },
      { color: colors.taxes, val: taxes },
      { color: colors.insurance, val: ins },
      { color: colors.hoa, val: hoa },
      { color: colors.pmi, val: pmi },
    ].filter((s) => s.val > 0);

    const r = 40;
    const c = 2 * Math.PI * r;
    let offset = 0;
    let html = "";

    list.forEach((seg) => {
      const length = (seg.val / total) * c;
      html += `<circle cx="50" cy="50" r="${r}" stroke="${seg.color}" stroke-width="12" stroke-dasharray="${length} ${c}" stroke-dashoffset="${-offset}" fill="transparent" />`;
      offset += length;
    });

    donutSegments.innerHTML = html;
  }

  // Render Amortization Schedule Table & headers
  function renderScheduleTable() {
    if (!tableBody || !tableHead) return;

    let headHtml = "";
    let bodyHtml = "";

    if (currentMode === "purchase" || currentMode === "affordability") {
      headHtml = `
        <tr class="bg-surface text-stone border-b border-hairline uppercase text-[10px] font-bold tracking-wider font-mono">
          <th class="py-3 px-4" data-col="period">Period</th>
          <th class="py-3 px-4 text-right" data-col="payment">Payment</th>
          <th class="py-3 px-4 text-right" data-col="principal">Principal</th>
          <th class="py-3 px-4 text-right" data-col="interest">Interest</th>
          <th class="py-3 px-4 text-right" data-col="extra">Extra Payment</th>
          <th class="py-3 px-4 text-right" data-col="pmi">PMI Paid</th>
          <th class="py-3 px-4 text-right" data-col="total-interest">Total Interest</th>
          <th class="py-3 px-4 text-right" data-col="balance">Remaining Balance</th>
        </tr>
      `;

      if (scheduleViewMode === "annual") {
        const yrMap = new Map<number, any[]>();
