---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Mortgage Calculator";
const category = "finance";
const tier = "Finance & Tax";

// On-page SEO metadata
const pageTitle =
  "Mortgage Calculator - Free Home Loan Payment, Affordability & Refinance Calculator";
const description =
  "Free mortgage calculator with taxes, PMI, HOA and extra payments. Estimate your monthly home mortgage payment, check affordability, compare refinance savings, and analyze rent vs buy.";
const canonicalUrl = "https://toolkify.app/tools/finance/mortgage-payment";
const ogImage = "/og/mortgage-calculator.png";
const keywords =
  "mortgage calculator, simple mortgage calculator, home mortgage calculator, free mortgage calculator, monthly mortgage calculator, mortgage calculator with taxes, mortgage calculator with extra payments, 30 year mortgage calculator, house mortgage calculator, commercial mortgage calculator, mortgage affordability calculator, home affordability calculator, house affordability calculator, affordability calculator, home loan affordability calculator, housing affordability calculator, mortgage refinance calculator, refinance savings calculator, mortgage refinance savings calculator, refinance mortgage calculator, refinance calculator, rent vs buy calculator, rent vs buy house, rent vs buy home, rent vs buy calc";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Mortgage Calculator",
      "alternateName": "Home Mortgage Payment, Affordability & Refinance Calculator",
      "url": "https://toolkify.app/tools/finance/mortgage-payment",
      "description": "Free mortgage calculator to estimate monthly home loan payments with property taxes, insurance, HOA fees, PMI and extra payments. Includes a mortgage affordability calculator, refinance savings calculator, and rent vs buy calculator.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Monthly mortgage payment calculator with taxes and PMI",
        "Mortgage affordability calculator",
        "Mortgage refinance savings calculator",
        "Rent vs buy calculator",
        "Extra payments and amortization schedule"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "1280"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Finance & Tax Tools",
          "item": "https://toolkify.app/#finance"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Mortgage Calculator",
          "item": "https://toolkify.app/tools/finance/mortgage-payment"
        }
      ]
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much mortgage can I afford calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A mortgage affordability calculator estimates the maximum home price and loan size you can support. Lenders look at your Debt-to-Income (DTI) ratio, typically capping housing costs (PITI) at 28% of your gross monthly income (front-end DTI) and all recurring monthly debt payments at 36% to 43% (back-end DTI).</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to pay off mortgage in 5 years calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To pay off your mortgage in 5 years, you must significantly increase your monthly principal payments. A payoff calculator helps you determine the exact extra payment needed each month. For a typical 30-year loan, you will need to pay roughly 4 to 5 times the scheduled principal payment monthly to clear the balance in 5 years.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to pay off mortgage in 10 years calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Paying off a mortgage in 10 years requires refinancing to a 10-year term or making additional monthly principal prepayments on your current loan. Use our extra payments planner to calculate how much extra cash to apply each month to retire the debt in exactly 120 months and see the massive interest savings.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to pay off mortgage in 15 years calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A 15-year mortgage payoff calculator demonstrates the impact of either choosing a 15-year fixed term from the start or adding extra payments to a 30-year loan. Shorter terms yield lower interest rates and faster equity accumulation, saving you tens of thousands of dollars in lifetime interest.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much mortgage can I qualify for calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A qualification calculator analyzes your financial profile—including credit score, gross income, monthly debt payments, and down payment cash—to estimate the maximum loan size lenders will approve. This keeps your home search within a realistic buying budget.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Should I refinance my mortgage calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Use a refinance savings calculator to compare your current interest rate and monthly payment against new market rates. Refinancing makes sense if the monthly interest savings cover the upfront closing costs (typically 2% to 5% of the loan amount) before you plan to sell or move.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to pay off mortgage faster calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To pay off your mortgage faster, apply extra payments directly toward your loan's principal balance. Even small additions, such as making bi-weekly payments or rounding up your monthly check, can shorten your term by years. Use the extra payments calculator to see your exact payoff timeline.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How long to pay off mortgage calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>How long it takes to pay off your mortgage depends on your amortization schedule and any extra payments. A payoff calculator maps your remaining balance, interest rate, and monthly contribution to project the exact year and month your loan will be fully paid off.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to calculate mortgage affordability?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Mortgage affordability is calculated using the 28/36 rule. Multiply your gross monthly income by 28% to find the maximum recommended housing payment (including taxes, insurance, and HOA). Then, multiply your income by 36% (or up to 43-50% for standard underwriting) and subtract existing monthly debt payments to find the absolute limit.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to calculate car affordability?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To calculate car affordability, a general guideline is the 10% to 15% rule. Keep your monthly car payment under 10% to 15% of your take-home (net) monthly income, and ensure total transportation costs (loan, insurance, fuel, maintenance) do not exceed 20% of net pay.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How do interest rates affect affordability?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Higher interest rates increase the interest portion of your monthly payment, reducing the maximum principal amount you can borrow. For example, a 1% rate hike can reduce your buying power and maximum affordable home price by approximately 9% to 10% for the same monthly budget.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How do I compare loan terms for affordability?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Compare shorter loan terms (e.g., 15 years) against longer terms (e.g., 30 years) by looking at both the monthly payment and total lifetime cost. A 15-year term has higher monthly payments but lower interest rates and drastically lower lifetime interest costs, whereas a 30-year term offers lower, more manageable monthly payments.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to refinance student loans?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To refinance student loans, you apply for a new loan with a private lender to pay off your existing federal or private student debt. Refinancing can lower your interest rate, change your term, or combine multiple payments into one, though it may mean giving up federal protections.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Can you refinance a car loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, you can refinance a car loan to secure a lower interest rate, reduce your monthly payment, or adjust the loan term. This is especially beneficial if your credit score has improved or market interest rates have dropped since you purchased the vehicle.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much does it cost to refinance a mortgage?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Refinancing a mortgage typically costs 2% to 5% of the new loan amount. These closing costs cover home appraisals, loan origination fees, title search services, credit checks, and recording fees. Use a refinance calculator to determine how long it will take to break even.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does refinance mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Refinancing means replacing an existing debt obligation with a new loan under different terms. The new loan pays off the old balance completely, and you begin making payments on the new loan, ideally benefiting from a lower rate, lower payments, or a different term.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does it mean to refinance a house?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Refinancing a house involves replacing your current home mortgage with a new one. Homeowners do this to take advantage of lower interest rates, shorten the length of their loan, convert from an adjustable-rate to a fixed-rate mortgage, or cash out a portion of their home equity.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Can you refinance with bad credit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, you can refinance with bad credit, although options may be limited and interest rates may be higher. You might qualify for government-backed programs like FHA Streamline Refinance, VA Interest Rate Reduction Refinance Loans (IRRRL), or by using a co-signer.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to refinance auto loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To refinance an auto loan, gather your current loan details, check your credit score, shop around with banks or credit unions for competitive refinance rates, submit an application with the chosen lender, and use the new loan to pay off your existing auto debt.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "When to rent vs buy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Renting is generally better if you plan to stay in a home for a short duration (usually under 3 to 5 years), as buying carries heavy transactional and selling fees. Buying becomes more financially advantageous the longer you stay, allowing appreciation and equity buildup to exceed purchase costs.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How do I calculate the cost to rent vs buy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To compare renting and buying, you weigh total rent paid (plus what you could earn investing your down payment) against total ownership costs (mortgage, property tax, insurance, maintenance and selling fees) minus the equity and appreciation you gain. The Rent vs Buy calculator runs this comparison automatically.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "When to rent vs buy a home?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Decide to rent or buy a home based on your financial readiness, career stability, local market prices, and personal plans. Renting offers flexibility and predictable costs, while buying offers stability, tax advantages, and wealth generation through home equity.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Traditional vs buy vs rent: which saves you more?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Which option saves you more depends on your holding period and market conditions. Renting and investing the difference often saves more over short periods (1 to 4 years). Over longer periods (5+ years), buying historically saves more money due to leverage, equity build-up, and home price appreciation.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is the best rent vs buy calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The best rent vs buy calculator goes beyond comparing simple monthly payments. It models rent inflation, property appreciation, home maintenance, transaction costs, tax implications, and the opportunity cost of investing your down payment cash rather than using it for a home purchase.</p>"
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-3 flex flex-col gap-4 animate-fade-in-up pb-24 lg:pb-12"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav
        class="flex items-center gap-2 text-xs font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-2xl sm:text-3xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2.5 rounded-full font-semibold uppercase shrink-0"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How mortgage payment calculator works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mode Selector Tabs (Miro Pill Style) -->
    <div class="relative w-full">
      <div
        class="flex border-b border-hairline overflow-x-auto no-scrollbar py-2 pr-12 scroll-smooth"
        role="tablist"
      >
        <button
          type="button"
          class="btn-mode pill-tab pill-tab-active mr-2 shrink-0 whitespace-nowrap"
          data-mode="purchase"
          role="tab"
          aria-selected="true"
          aria-controls="inputs-purchase">💰 Purchase & Payment</button
        >
        <button
          type="button"
          class="btn-mode pill-tab mr-2 shrink-0 whitespace-nowrap"
          data-mode="affordability"
          role="tab"
          aria-selected="false"
          aria-controls="inputs-affordability">🏠 Affordability Limit</button
        >
        <button
          type="button"
          class="btn-mode pill-tab mr-2 shrink-0 whitespace-nowrap"
          data-mode="refinance"
          role="tab"
          aria-selected="false"
          aria-controls="inputs-refinance">🔄 Refinance Savings</button
        >
        <button
          type="button"
          class="btn-mode pill-tab mr-2 shrink-0 whitespace-nowrap"
          data-mode="rent-buy"
          role="tab"
          aria-selected="false"
          aria-controls="inputs-rent-buy">🏢 Rent vs. Buy</button
        >
      </div>
      <!-- Right edge fade/shadow as a scroll hint -->
      <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-canvas to-transparent z-10"></div>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      <!-- Left Column: Dynamic Forms (5 cols) -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <!-- Form A: Purchase Parameters -->
        <div id="inputs-purchase" class="card-base flex flex-col gap-5">
          <h2
            class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2"
          >
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Purchase Parameters
          </h2>

          <div class="flex flex-col gap-1.5">
            <label
              for="home-price"
              class="text-xs font-semibold text-charcoal flex justify-between"
            >
              <span>Home Price</span>
              <span id="home-price-val" class="font-mono text-stone font-normal"
                >$400,000</span
              >
            </label>
            <input
              type="number"
              id="home-price"
              value="400000"
              min="10000"
              max="10000000"
              step="5000"
              class="text-input"
              inputmode="numeric"
              autocomplete="off"
            />
            <input
              type="range"
              id="home-price-range"
              min="50000"
              max="2000000"
              value="400000"
              step="10000"
              class="hidden sm:block w-full cursor-pointer accent-brand-blue py-2"
              aria-label="Home Price Slider"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label
              class="text-xs font-semibold text-charcoal flex justify-between"
            >
              <span>Down Payment</span>
              <span
                id="down-payment-val"
                class="font-mono text-stone font-normal">$80,000 (20.0%)</span
              >
            </label>
            <div class="grid grid-cols-1 sm:grid-cols-12 gap-2">
              <div class="col-span-12 sm:col-span-7 relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm"
                  >$</span
                >
                <input
                  type="number"
                  id="down-payment-dollar"
                  value="80000"
                  min="0"
                  class="text-input pl-7"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
              <div class="col-span-12 sm:col-span-5 relative">
                <input
                  type="number"
                  id="down-payment-percent"
                  value="20"
                  min="0"
                  max="100"
                  step="0.1"
                  class="text-input pr-7"
                  inputmode="decimal"
                  autocomplete="off"
                />
                <span
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-stone text-sm"
                  >%</span
                >
              </div>
            </div>
            <input
              type="range"
              id="down-payment-percent-range"
              min="0"
              max="100"
              value="20"
              step="0.5"
              class="hidden sm:block w-full cursor-pointer accent-brand-blue py-2"
              aria-label="Down Payment Percentage Slider"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label
              for="interest-rate"
              class="text-xs font-semibold text-charcoal flex justify-between"
            >
              <span>Interest Rate (Annual)</span>
              <span
                id="interest-rate-val"
                class="font-mono text-stone font-normal">6.5%</span
              >
            </label>
            <input
              type="number"
              id="interest-rate"
              value="6.5"
              min="0.1"
              max="25"
              step="0.01"
              class="text-input"
              inputmode="decimal"
              autocomplete="off"
            />
            <input
              type="range"
              id="interest-rate-range"
              min="1"
              max="15"
              value="6.5"
              step="0.1"
              class="hidden sm:block w-full cursor-pointer accent-brand-blue py-2"
              aria-label="Interest Rate Slider"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal">Loan Term</label>
            <div class="grid grid-cols-4 gap-2">
              <button type="button" class="btn-term pill-tab" data-term="30"
                >30 Yrs</button
              >
              <button type="button" class="btn-term pill-tab" data-term="20"
                >20 Yrs</button
              >
              <button type="button" class="btn-term pill-tab" data-term="15"
                >15 Yrs</button
              >
              <button type="button" class="btn-term pill-tab" data-term="10"
                >10 Yrs</button
              >
            </div>
            <div class="flex items-center gap-3 mt-1">
              <input
                type="range"
                id="loan-term-range"
                min="1"
                max="40"
                value="30"
                step="1"
                class="flex-grow cursor-pointer accent-brand-blue py-2"
                aria-label="Custom Term Slider"
              />
              <span
                id="loan-term-val"
                class="text-xs font-mono font-bold text-stone w-16 text-right"
                >30 years</span
              >
            </div>
          </div>

          <!-- Accordion DTI Ratio Income Checker (Collapsible) -->
          <div class="border-t border-hairline pt-3">
            <button
              type="button"
              id="accordion-dti-btn"
              class="w-full text-left font-display font-semibold text-sm text-primary flex items-center justify-between cursor-pointer"
            >
              <span class="flex items-center gap-1.5"
                ><span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>DTI Income Checker (Optional)</span
              >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-stone transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path></svg
              >
            </button>
            <div
              id="accordion-dti-content"
              class="hidden flex flex-col gap-3 mt-3 border-t border-hairline-soft pt-3"
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                <div class="flex flex-col gap-1">
                  <label
                    for="purchase-gross-income"
                    class="text-[10px] font-semibold text-slate"
                    >Gross Monthly Income</label
                  >
                  <div class="relative">
                    <span
                      class="absolute left-2.5 top-1/2 -translate-y-1/2 text-stone text-xs"
                      >$</span
