  // Mode A: Purchase & DTI Calculator
  function calculatePurchase() {
    const price = parseFloat(homePriceInput.value) || 0;
    const dpDollar = parseFloat(downPaymentDollarInput.value) || 0;
    const loanAmount = Math.max(0, price - dpDollar);

    const rate = parseFloat(interestRateInput.value) || 0;
    const r = rate / 12 / 100;
    const n = purchaseLoanTerm * 12;

    const propertyTaxAnnual = parseFloat(propertyTaxDollarInput.value) || 0;
    const taxMonthly = propertyTaxAnnual / 12;

    const homeInsuranceAnnual = parseFloat(homeInsuranceInput.value) || 0;
    const insMonthly = homeInsuranceAnnual / 12;

    const hoaMonthly = parseFloat(hoaFeesInput.value) || 0;
    const pmiRate = parseFloat(pmiRateInput.value) || 0;

    const startMonth = parseInt(startMonthSelect.value) || 0;
    const startYear = parseInt(startYearInput.value) || 2026;

    const extraMonthly = parseFloat(extraMonthlyInput.value) || 0;
    const extraAnnual = parseFloat(extraAnnualInput.value) || 0;
    const extraOnetime = parseFloat(extraOneTimeInput.value) || 0;
    const extraOnetimeMonth = parseInt(extraOneTimeMonthSelect.value) || 0;
    const extraOnetimeYear = parseInt(extraOneTimeYearInput.value) || 2026;

    // Income & debts DTI check
    const grossIncome = parseFloat(purchaseGrossIncome.value) || 0;
    const debts = parseFloat(purchaseMonthlyDebts.value) || 0;

    // Standard P&I
    let monthlyPI = 0;
    if (loanAmount > 0) {
      monthlyPI =
        r === 0
          ? loanAmount / n
          : (loanAmount * (r * Math.pow(1 + r, n))) / (Math.pow(1 + r, n) - 1);
    }

    let initialPMI = 0;
    if (loanAmount > 0.8 * price && pmiRate > 0) {
      initialPMI = (loanAmount * (pmiRate / 100)) / 12;
    }

    // Baseline (No Extra) vs Accelerated Schedules
    const baseline = runAmortizationSolver(
      loanAmount,
      r,
      n,
      startMonth,
      startYear,
      taxMonthly,
      insMonthly,
      hoaMonthly,
      pmiRate,
      price,
      0,
      0,
      { amount: 0, month: 0, year: 0 },
    );
    const accelerated = runAmortizationSolver(
      loanAmount,
      r,
      n,
      startMonth,
      startYear,
      taxMonthly,
      insMonthly,
      hoaMonthly,
      pmiRate,
      price,
      extraMonthly,
      extraAnnual,
      {
        amount: extraOnetime,
        month: extraOnetimeMonth,
        year: extraOnetimeYear,
      },
    );

    exportDataList = accelerated.schedule;

    // Display first month total PITI
    const totalPITI =
      monthlyPI + taxMonthly + insMonthly + hoaMonthly + initialPMI;
    if (monthlyPaymentDisplay)
      monthlyPaymentDisplay.textContent = formatCurrency(Math.round(totalPITI));
    if (loanAmountBadge)
      loanAmountBadge.textContent = `Loan Amount: ${formatCurrency(loanAmount)}`;

    // Sync input displays
    if (homePriceValLabel)
      homePriceValLabel.textContent = formatCurrency(price);
    if (downPaymentValLabel) {
      const pct = price > 0 ? (dpDollar / price) * 100 : 0;
      downPaymentValLabel.textContent = `${formatCurrency(dpDollar)} (${pct.toFixed(1)}%)`;
    }
    if (interestRateValLabel)
      interestRateValLabel.textContent = `${rate.toFixed(2)}%`;
    if (taxAnnualValLabel)
      taxAnnualValLabel.textContent = `${formatCurrency(propertyTaxAnnual)}/yr`;

    // Elements breakdown lists
    if (breakdownPI) breakdownPI.textContent = formatCurrency(monthlyPI);
    if (breakdownTaxes) breakdownTaxes.textContent = formatCurrency(taxMonthly);
    if (breakdownInsurance)
      breakdownInsurance.textContent = formatCurrency(insMonthly);
    if (breakdownHOA) breakdownHOA.textContent = formatCurrency(hoaMonthly);
    if (breakdownPMI) breakdownPMI.textContent = formatCurrency(initialPMI);

    // Dynamic Donut SVG redrawing
    renderDonutChart(monthlyPI, taxMonthly, insMonthly, hoaMonthly, initialPMI);

    // Repayment duration display (uses accelerated schedule so extra payments are reflected)
    const repaymentDurationText = document.getElementById(
      "repayment-duration-text",
    );
    if (repaymentDurationText) {
      const totalMonths = accelerated.schedule.length;
      const repayYrs = Math.floor(totalMonths / 12);
      const repayMos = totalMonths % 12;
      let durStr = "";
      if (repayYrs > 0) durStr += `${repayYrs} yr${repayYrs !== 1 ? "s" : ""}`;
      if (repayMos > 0)
        durStr += `${repayYrs > 0 ? " " : ""}${repayMos} mo${repayMos !== 1 ? "s" : ""}`;
      if (!durStr) durStr = "N/A";
      repaymentDurationText.textContent = durStr;
    }

    // Extra payments dashboards
    const hasPrepayments =
      extraMonthly > 0 || extraAnnual > 0 || extraOnetime > 0;
    if (hasPrepayments && savingsDashboard) {
      savingsDashboard.classList.remove("hidden");
      const interestSaved = Math.max(
        0,
        baseline.totalInterest - accelerated.totalInterest,
      );
      const monthsSaved = Math.max(
        0,
        baseline.schedule.length - accelerated.schedule.length,
      );
      const yrs = Math.floor(monthsSaved / 12);
      const mos = monthsSaved % 12;

      let savingsTimeStr = "";
      if (yrs > 0) savingsTimeStr += `${yrs} Yr${yrs > 1 ? "s" : ""} `;
      if (mos > 0 || yrs === 0)
        savingsTimeStr += `${mos} Mo${mos > 1 ? "s" : ""}`;

      if (savingsInterestVal)
        savingsInterestVal.textContent = formatCurrency(
          Math.round(interestSaved),
        );
      if (savingsTimeVal) savingsTimeVal.textContent = savingsTimeStr;

      if (savingsPayoffDateVal) {
        const lastRow = accelerated.schedule[accelerated.schedule.length - 1];
        savingsPayoffDateVal.textContent = lastRow
          ? `${lastRow.monthName} ${lastRow.year}`
          : "N/A";
      }
    } else {
      savingsDashboard?.classList.add("hidden");
    }

    // Dynamic DTI Gauges
    if (grossIncome > 0 && dtiOverlayCard) {
      dtiOverlayCard.classList.remove("hidden");
      const frontRatio = (totalPITI / grossIncome) * 100;
      const backRatio = ((totalPITI + debts) / grossIncome) * 100;

      if (dtiFrontText) dtiFrontText.textContent = `${frontRatio.toFixed(1)}%`;
      if (dtiBackText) dtiBackText.textContent = `${backRatio.toFixed(1)}%`;

      if (dtiFrontBar)
        dtiFrontBar.style.width = `${Math.min(100, frontRatio)}%`;
      if (dtiBackBar) dtiBackBar.style.width = `${Math.min(100, backRatio)}%`;

      // Set DTI eval status and colors
      if (dtiEvaluationStatus) {
        if (backRatio <= 36) {
          dtiEvaluationStatus.textContent = "Excellent DTI";
          dtiEvaluationStatus.className =
            "badge-tag-purple !bg-teal-light !text-moss-dark";
        } else if (backRatio <= 43) {
          dtiEvaluationStatus.textContent = "Moderate DTI";
          dtiEvaluationStatus.className =
            "badge-tag-purple !bg-yellow-light !text-yellow-dark";
        } else {
          dtiEvaluationStatus.textContent = "High DTI";
          dtiEvaluationStatus.className =
            "badge-tag-purple !bg-coral-light !text-coral-dark";
        }
      }
    } else {
      dtiOverlayCard?.classList.add("hidden");
    }

    // Update Mobile sticky bar
    const mobileSummaryTitle = document.getElementById("mobile-summary-title");
    const mobileSummaryValue = document.getElementById("mobile-summary-value");
    if (mobileSummaryTitle)
      mobileSummaryTitle.textContent = "Estimated Monthly";
    if (mobileSummaryValue)
      mobileSummaryValue.textContent = formatCurrency(Math.round(totalPITI));

    // Draw SVG schedule path
    if (crossoverChartTitle)
      crossoverChartTitle.textContent =
        "Amortization Trend Workspace (Balance vs Interest)";
    renderAmortizationChart(accelerated.schedule, loanAmount);
    renderScheduleTable();
  }

  // Mode B: Affordability Calculator Engine
  function calculateAffordability() {
    const annualIncome = parseFloat(affGrossIncome.value) || 0;
    const monthlyIncome = annualIncome / 12;
    const debts = parseFloat(affMonthlyDebts.value) || 0;
    const cash = parseFloat(affCash.value) || 0;

    const rate = parseFloat(affRate.value) || 0;
    const r = rate / 12 / 100;
    const years = parseInt(affTermSelect.value) || 30;
    const n = years * 12;

    const dtiLimitMode = affDtiMode.value;
    const taxRate = parseFloat(affTaxRate.value) || 0;
    const insAnnual = parseFloat(affInsurance.value) || 0;
    const insMonthly = insAnnual / 12;
    const hoaMonthly = parseFloat(affHOA.value) || 0;
    const pmiRate = parseFloat(affPMIRate.value) || 0;

    // Sync slider display text
    if (affIncomeVal) affIncomeVal.textContent = formatCurrency(annualIncome);
    if (affDebtsVal) affDebtsVal.textContent = `${formatCurrency(debts)}/mo`;
    if (affCashVal) affCashVal.textContent = formatCurrency(cash);

    // Compute maximum PITI allowed by Front-End & Back-End bounds
    const maxPITIFront = monthlyIncome * 0.28;
    let dtiFactor = 0.43;
    if (dtiLimitMode === "conservative") dtiFactor = 0.36;
    else if (dtiLimitMode === "aggressive") dtiFactor = 0.5;

    const maxPITIBack = monthlyIncome * dtiFactor - debts;
    const maxPITI = Math.max(0, Math.min(maxPITIFront, maxPITIBack));

    // Deduct fixed non-loan expenses (Taxes, Insurance, HOA) and solve for P&I + PMI
    const fixedExpenses = insMonthly + hoaMonthly;
    const maxAvailablePIAndPMI = Math.max(0, maxPITI - fixedExpenses);

    const f =
      r === 0 ? 1 / n : (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const t = taxRate / 100 / 12;
    const p = pmiRate / 100 / 12;

    // Let's back solve max Loan L.
    // L = (PIAndPMI_Limit - Cash * t) / (f + t + p)
    let maxLoan = 0;
    let pmiApplied = false;

    // 1. Assume PMI is active (Loan > 80% of Home Value, i.e., cash < 20% of Home value)
    const loanAssumingPMI = (maxAvailablePIAndPMI - cash * t) / (f + t + p);
    const priceAssumingPMI = loanAssumingPMI + cash;

    if (loanAssumingPMI > 0 && cash < 0.2 * priceAssumingPMI) {
      maxLoan = loanAssumingPMI;
      pmiApplied = true;
    } else {
      // 2. Assume PMI is NOT active
      const loanNoPMI = (maxAvailablePIAndPMI - cash * t) / (f + t);
      maxLoan = Math.max(0, loanNoPMI);
      pmiApplied = false;
    }

    const maxHomePrice = maxLoan + cash;

    // Output displays
    if (affMaxPrice)
      affMaxPrice.textContent = formatCurrency(Math.round(maxHomePrice));
    if (affLoanAmountBadge) {
      affLoanAmountBadge.textContent = `Max Loan: ${formatCurrency(Math.round(maxLoan))} | Down Payment Cash: ${formatCurrency(cash)}`;
    }
    if (affMaxPITI)
      affMaxPITI.textContent = `${formatCurrency(Math.round(maxPITI))}/mo`;

    const monthlyPI = maxLoan * f;
    const monthlyTax = maxHomePrice * t;
    const monthlyPMI = pmiApplied ? maxLoan * p : 0;

    if (affMaxPI) affMaxPI.textContent = formatCurrency(monthlyPI);
    if (affTaxBreakdown)
      affTaxBreakdown.textContent = formatCurrency(monthlyTax);
    if (affInsuranceBreakdown)
      affInsuranceBreakdown.textContent = formatCurrency(insMonthly);
    if (affHoaBreakdown)
      affHoaBreakdown.textContent = formatCurrency(hoaMonthly);
    if (affPmiBreakdown)
      affPmiBreakdown.textContent = formatCurrency(monthlyPMI);

    // Approval Gauges
    const frontRatioVal =
      monthlyIncome > 0 ? (maxPITI / monthlyIncome) * 100 : 0;
    const backRatioVal =
      monthlyIncome > 0 ? ((maxPITI + debts) / monthlyIncome) * 100 : 0;

    if (affFrontRatioVal)
      affFrontRatioVal.textContent = `${frontRatioVal.toFixed(1)}%`;
    if (affBackRatioVal)
      affBackRatioVal.textContent = `${backRatioVal.toFixed(1)}%`;

    if (affFrontRatioBar)
      affFrontRatioBar.style.width = `${Math.min(100, (frontRatioVal / 28) * 100)}%`;
    if (affBackRatioBar)
      affBackRatioBar.style.width = `${Math.min(100, (backRatioVal / (dtiFactor * 100)) * 100)}%`;
    if (affBackRatioMarker)
      affBackRatioMarker.style.left = `${dtiFactor * 100}%`;
    if (affBackDtiLimitLabel)
      affBackDtiLimitLabel.textContent = `Lender Limit Target: ${dtiFactor * 100}%. Your settings cap borrowing at this ratio.`;

    // Update Mobile sticky bar
    const mobileSummaryTitle = document.getElementById("mobile-summary-title");
    const mobileSummaryValue = document.getElementById("mobile-summary-value");
    if (mobileSummaryTitle) mobileSummaryTitle.textContent = "Max Home Budget";
    if (mobileSummaryValue)
      mobileSummaryValue.textContent = formatCurrency(Math.round(maxHomePrice));

    // Solve schedule for table
    const affSchedule = runAmortizationSolver(
      maxLoan,
      r,
      n,
      2,
      2026,
      monthlyTax,
      insMonthly,
      hoaMonthly,
      pmiApplied ? pmiRate : 0,
      maxHomePrice,
      0,
      0,
      { amount: 0, month: 0, year: 0 },
    );
    exportDataList = affSchedule.schedule;

    // Donut chart & schedule rendering
    if (crossoverChartTitle)
      crossoverChartTitle.textContent = "Affordable Mortgage Schedule Trend";
    renderAmortizationChart(affSchedule.schedule, maxLoan);
    renderDonutChart(monthlyPI, monthlyTax, insMonthly, hoaMonthly, monthlyPMI);
    renderScheduleTable();
  }

  // Mode C: Refinance Breakeven Solver
  function calculateRefinance() {
    const balance = parseFloat(refiBalance.value) || 0;
    const curRate = parseFloat(refiCurrentRate.value) || 0;
    const curTermYrs = parseFloat(refiRemainingTerm.value) || 0;
    const curTermMonths = Math.max(1, curTermYrs * 12);

    const newRate = parseFloat(refiNewRate.value) || 0;
    const newTermYrs = parseInt(refiNewTerm.value) || 30;
    const newTermMonths = Math.max(1, newTermYrs * 12);

    const fees = parseFloat(refiClosingCosts.value) || 0;

    // Sync input ranges text
    if (refiBalanceVal) refiBalanceVal.textContent = formatCurrency(balance);
    if (refiCostsVal) refiCostsVal.textContent = formatCurrency(fees);

    const rCur = curRate / 12 / 100;
    const rNew = newRate / 12 / 100;

    // Payments
    const payCur =
      rCur === 0
        ? balance / curTermMonths
        : (balance * (rCur * Math.pow(1 + rCur, curTermMonths))) /
          (Math.pow(1 + rCur, curTermMonths) - 1);
    const payNew =
      rNew === 0
        ? balance / newTermMonths
        : (balance * (rNew * Math.pow(1 + rNew, newTermMonths))) /
          (Math.pow(1 + rNew, newTermMonths) - 1);

    const savings = payCur - payNew;
    const curTotalCost = payCur * curTermMonths;
    const newTotalCost = payNew * newTermMonths + fees;
    const lifetimeSavingsVal = curTotalCost - newTotalCost;

    if (refiMonthlySavings)
      refiMonthlySavings.textContent =
        savings > 0 ? formatCurrency(savings) : "$0";
    if (refiLifetimeSavings)
      refiLifetimeSavings.textContent = formatCurrency(lifetimeSavingsVal);
    if (refiCurrentPayment)
      refiCurrentPayment.textContent = formatCurrency(payCur);
    if (refiCurrentCost)
      refiCurrentCost.textContent = formatCurrency(curTotalCost);
    if (refiNewPayment) refiNewPayment.textContent = formatCurrency(payNew);
    if (refiNewCost) refiNewCost.textContent = formatCurrency(newTotalCost);

    // Breakeven Months
    let breakeven = 0;
    if (savings > 0) {
      breakeven = Math.ceil(fees / savings);
      if (refiBreakevenMonths)
        refiBreakevenMonths.textContent = breakeven.toString();
      refiBreakevenCard?.classList.remove("hidden");
    } else {
      if (refiBreakevenMonths) refiBreakevenMonths.textContent = "Never";
      refiBreakevenCard?.classList.add("hidden");
    }

    // Update Mobile sticky bar
    const mobileSummaryTitle = document.getElementById("mobile-summary-title");
    const mobileSummaryValue = document.getElementById("mobile-summary-value");
    if (mobileSummaryTitle)
      mobileSummaryTitle.textContent = "Refi Monthly Savings";
    if (mobileSummaryValue)
      mobileSummaryValue.textContent =
        savings > 0 ? formatCurrency(Math.round(savings)) : "$0";

    // Build schedules for line chart
    const timelineLen = Math.max(curTermMonths, newTermMonths);
    const refiSchedule: any[] = [];
    let currentCumCost = 0;
    let refiCumCost = fees;

    for (let m = 1; m <= timelineLen; m++) {
      if (m <= curTermMonths) {
        currentCumCost += payCur;
      }
      if (m <= newTermMonths) {
        refiCumCost += payNew;
      }

      refiSchedule.push({
        monthNumber: m,
        year: Math.floor((m - 1) / 12) + 1,
        monthName: monthNames[(m - 1) % 12],
        balance: currentCumCost, // hijacking property names to reuse charting module
        totalInterest: refiCumCost,
      });
    }
    let refiRemainingBalance = balance;
    currentCumCost = 0;
    refiCumCost = fees;

    exportDataList = [];
    for (let m = 1; m <= timelineLen; m++) {
      if (m <= curTermMonths) {
        currentCumCost += payCur;
      }

      let principal = 0;
      let interest = 0;
      let payment = 0;

      if (m <= newTermMonths) {
        if (refiRemainingBalance > 0) {
          interest = refiRemainingBalance * rNew;
          principal = payNew - interest;
          if (principal > refiRemainingBalance) {
            principal = refiRemainingBalance;
          }
          payment = principal + interest;
          refiRemainingBalance = Math.max(0, refiRemainingBalance - principal);
        }
        refiCumCost += payment;
      }

      exportDataList.push({
        monthNumber: m,
        year: Math.floor((m - 1) / 12) + 1,
        monthName: monthNames[(m - 1) % 12],
        payment: payment,
        principal: principal,
        interest: interest,
        currentCumCost: currentCumCost,
        refiCumCost: refiCumCost,
        balance: refiRemainingBalance,
      });
    }

    if (crossoverChartTitle)
      crossoverChartTitle.textContent =
        "Refinance Cost Intersection (Current vs. Refi)";
    renderRefiCrossoverChart(
      refiSchedule,
      curTotalCost,
      newTotalCost,
      breakeven,
    );
    renderScheduleTable();
  }

  // Mode D: Rent vs Buy solver
  function calculateRentBuy() {
    const rent = parseFloat(rentbuyRent.value) || 0;
    const rentIncrease = parseFloat(rentbuyRentIncrease.value) || 0;
    const renterIns = parseFloat(rentbuyRenterIns.value) || 0;

    const price = parseFloat(rentbuyPrice.value) || 0;
    const dp = parseFloat(rentbuyDP.value) || 0;
    const rate = parseFloat(rentbuyRate.value) || 0;
    const term = parseInt(rentbuyHoldingSlider.value) || 10;
    const termMonths = term * 12;

    const marketReturn = parseFloat(rentbuyReturn.value) || 0;
    const holdingYrs = parseInt(rentbuyHoldingSlider.value) || 10;

    // Labels sync
    if (rentbuyRentVal) rentbuyRentVal.textContent = formatCurrency(rent);
    if (rentbuyPriceVal) rentbuyPriceVal.textContent = formatCurrency(price);
    if (rentbuyHoldingVal)
      rentbuyHoldingVal.textContent = `${holdingYrs} years`;

    const rBuy = rate / 12 / 100;
    const loanAmount = Math.max(0, price - dp);
    const n = purchaseLoanTerm * 12; // buy is based on user entered loan term
    const monthlyPI =
      rBuy === 0
        ? loanAmount / n
        : (loanAmount * (rBuy * Math.pow(1 + rBuy, n))) /
          (Math.pow(1 + rBuy, n) - 1);

    // Initial tax and insurance defaults from inputs
    const taxRate = parseFloat(propertyTaxRateInput.value) || 1.2;
    const taxMonthly = (price * (taxRate / 100)) / 12;
    const insAnnual = parseFloat(homeInsuranceInput.value) || 1200;
    const insMonthly = insAnnual / 12;
    const buyMonthlyPITI = monthlyPI + taxMonthly + insMonthly;

    // Simulation over Holding years
    let rentCashFlow = dp + price * 0.02; // Renter starts with down cash + closing costs invested
    let renterTotalSpent = 0;

    let buyTotalSpent = dp + price * 0.02; // Down cash + buying closing costs
    let buyRemainingLoan = loanAmount;
    let buyerInvestedSavings = 0;
    let currentHomeValue = price;

    const rentBuyTimeline: any[] = [];
    const appreciationRate = parseFloat(rentbuyAppreciation.value) || 3.5;
    const maintenanceRate = parseFloat(rentbuyMaintenance.value) || 1.0;

    for (let yr = 1; yr <= holdingYrs; yr++) {
      const currentYearRent = rent * Math.pow(1 + rentIncrease / 100, yr - 1);
      const annualRentPaid = currentYearRent * 12;
      renterTotalSpent += annualRentPaid + renterIns;

      // Rent savings grows in index funds
      rentCashFlow = rentCashFlow * (1 + marketReturn / 100);

      // Buying costs (Mortgage + Maintenance from inputs)
      const annualMaintenance = currentHomeValue * (maintenanceRate / 100);
      const annualBuySpent = buyMonthlyPITI * 12 + annualMaintenance;
      buyTotalSpent += annualBuySpent;

      // Amortize loan for 12 months
      for (let m = 1; m <= 12; m++) {
        const interest = buyRemainingLoan * rBuy;
        const principal = Math.min(buyRemainingLoan, monthlyPI - interest);
        buyRemainingLoan = Math.max(0, buyRemainingLoan - principal);
      }

      // Appreciate Home
      currentHomeValue = currentHomeValue * (1 + appreciationRate / 100);

      // Invest monthly difference: renter vs buyer opportunity savings
      const renterMonthlyOutlay = currentYearRent + renterIns / 12;
      const buyerMonthlyOutlay = buyMonthlyPITI + annualMaintenance / 12;

      if (buyerMonthlyOutlay > renterMonthlyOutlay) {
        // Renter saves/invests difference
        const diff = (buyerMonthlyOutlay - renterMonthlyOutlay) * 12;
        rentCashFlow += diff;
      } else {
        // Buyer saves/invests difference
        const diff = (renterMonthlyOutlay - buyerMonthlyOutlay) * 12;
        buyerInvestedSavings += diff;
      }
      buyerInvestedSavings = buyerInvestedSavings * (1 + marketReturn / 100);

      // Recovered Equity if buyer sells this year (less 6% agent costs)
      const sellingCosts = currentHomeValue * 0.06;
      const recoveredEquity = Math.max(
        0,
        currentHomeValue - sellingCosts - buyRemainingLoan,
      );
      const buyerTotalWealth = recoveredEquity + buyerInvestedSavings;

      rentBuyTimeline.push({
        year: yr,
        monthNumber: yr,
        monthName: `Yr ${yr}`,
        balance: rentCashFlow, // Renter net assets (Line 1)
        totalInterest: buyerTotalWealth, // Buyer net assets (Line 2)
        rentPaid: annualRentPaid,
        homeValue: currentHomeValue,
        loanBalance: buyRemainingLoan,
        totalRentSpent: renterTotalSpent,
        totalBuySpent: buyTotalSpent,
      });
    }

    const renterNetWorth = rentCashFlow;
    const buyerNetWorth =
      rentBuyTimeline[rentBuyTimeline.length - 1].totalInterest;
    const diffVal = Math.round(Math.abs(buyerNetWorth - renterNetWorth));

    if (rentbuyConclusionTitle && rentbuyConclusionDesc) {
      if (buyerNetWorth > renterNetWorth) {
        rentbuyConclusionTitle.textContent =
          "Buying is the superior financial decision!";
        rentbuyConclusionDesc.textContent = `Over a holding period of ${holdingYrs} years, purchasing this home will save you approximately ${formatCurrency(diffVal)} in net wealth compared to renting.`;
      } else {
        rentbuyConclusionTitle.textContent =
          "Renting is the superior financial decision!";
        rentbuyConclusionDesc.textContent = `Over a holding period of ${holdingYrs} years, renting this property will save you approximately ${formatCurrency(diffVal)} in net wealth compared to buying.`;
      }
    }

    if (rentbuyRentCosts)
      rentbuyRentCosts.textContent = formatCurrency(
        Math.round(renterTotalSpent),
      );
    if (rentbuyRentAssets)
      rentbuyRentAssets.textContent = formatCurrency(
        Math.round(renterNetWorth),
      );
    if (rentbuyBuyCosts)
      rentbuyBuyCosts.textContent = formatCurrency(Math.round(buyTotalSpent));
    if (rentbuyBuyAssets)
      rentbuyBuyAssets.textContent = formatCurrency(Math.round(buyerNetWorth));

    // Update Mobile sticky bar
    const mobileSummaryTitle = document.getElementById("mobile-summary-title");
    const mobileSummaryValue = document.getElementById("mobile-summary-value");
    if (mobileSummaryTitle) {
      mobileSummaryTitle.textContent =
        buyerNetWorth > renterNetWorth ? "Buy Net Savings" : "Rent Net Savings";
    }
    if (mobileSummaryValue) {
      mobileSummaryValue.textContent = formatCurrency(diffVal);
    }

    exportDataList = rentBuyTimeline.map((row) => ({
      monthNumber: row.year,
      year: row.year,
      monthName: row.monthName,
      payment: row.rentPaid,
      principal: row.homeValue,
      interest: row.loanBalance,
      pmi: 0,
      extra: 0,
      totalInterest: row.balance,
      balance: row.totalInterest,
    }));

    if (crossoverChartTitle)
      crossoverChartTitle.textContent =
        "Net Wealth Growth Comparison (Renter vs. Buyer)";
    renderRentBuyCrossoverChart(rentBuyTimeline, renterNetWorth, buyerNetWorth);
    renderScheduleTable();
  }

  // Amortization Schedule Engine
  function runAmortizationSolver(
    P: number,
    r: number,
    n: number,
    startMonth: number,
    startYear: number,
    taxes: number,
    ins: number,
    hoa: number,
    pmiRate: number,
    homePrice: number,
    extraMonthly: number,
    extraAnnual: number,
    extraOneTime: { amount: number; month: number; year: number },
  ) {
    let balance = P;
    const schedule = [];
    let totalInterest = 0;
    let currentMonth = startMonth;
    let currentYear = startYear;

    const originalPMI = pmiRate > 0 && P > 0.8 * homePrice;

    for (let m = 1; m <= n; m++) {
      if (balance <= 0.01) break;

      const interest = balance * r;
      const basePI = (P * (r * Math.pow(1 + r, n))) / (Math.pow(1 + r, n) - 1);
      const basePayment = r === 0 ? P / n : basePI;

      let principal = basePayment - interest;
      if (principal > balance) {
        principal = balance;
      }

      let pmi = 0;
      if (balance > 0.8 * homePrice && originalPMI) {
        pmi = (P * (pmiRate / 100)) / 12;
      }

      let extra = extraMonthly;
      if (m > 1 && (m - 1) % 12 === 0) {
        extra += extraAnnual;
      }
      if (
        extraOneTime.amount > 0 &&
        extraOneTime.year === currentYear &&
        extraOneTime.month === currentMonth
      ) {
        extra += extraOneTime.amount;
      }

      let totalPrincipalPaid = principal + extra;
      if (totalPrincipalPaid > balance) {
        extra = Math.max(0, balance - principal);
        totalPrincipalPaid = balance;
      }

      balance = Math.max(0, balance - totalPrincipalPaid);
      totalInterest += interest;

      schedule.push({
        monthNumber: m,
        year: currentYear,
        monthName: monthNames[currentMonth],
        interest,
        principal,
        pmi,
        extra,
        payment: principal + interest + pmi + taxes + ins + hoa + extra,
        totalInterest,
        balance,
      });

      currentMonth++;
      if (currentMonth > 11) {
        currentMonth = 0;
        currentYear++;
      }
    }

    return { schedule, totalInterest };
  }

  // Draw Amortization line chart (Mode Purchase & Affordability)
  function renderAmortizationChart(schedule: any[], initialLoan: number) {
    if (
      schedule.length === 0 ||
      !chartBalancePath ||
      !chartInterestPath ||
      !chartGridLines
    )
      return;

    // Reset colors
    chartBalancePath.setAttribute("stroke", colors.pi);
    chartInterestPath.setAttribute("stroke", colors.taxes);

    const width = 600;
    const height = 200;
    const padding = 15;
    const maxVal = initialLoan;
    const totalMonths = schedule.length;
    const step = Math.max(1, Math.floor(totalMonths / 35));
    const points: any[] = [];

    for (let i = 0; i < totalMonths; i += step) {
      points.push(schedule[i]);
    }
    if (points[points.length - 1] !== schedule[totalMonths - 1]) {
      points.push(schedule[totalMonths - 1]);
    }

    const xScale = (idx: number) =>
      padding + (idx / (points.length - 1)) * (width - 2 * padding);
    const yScale = (val: number) =>
      height - padding - (val / maxVal) * (height - 2 * padding);

    let balancePathStr = `M ${xScale(0)} ${yScale(initialLoan)} `;
    points.forEach((p, idx) => {
      balancePathStr += `L ${xScale(idx)} ${yScale(p.balance)} `;
    });
    balancePathStr += `L ${xScale(points.length - 1)} ${yScale(0)} L ${xScale(0)} ${yScale(0)} Z`;
    chartBalancePath.setAttribute("d", balancePathStr);

    let interestPathStr = `M ${xScale(0)} ${yScale(0)} `;
    points.forEach((p, idx) => {
      interestPathStr += `L ${xScale(idx)} ${yScale(p.totalInterest)} `;
    });
    interestPathStr += `L ${xScale(points.length - 1)} ${yScale(0)} Z`;
    chartInterestPath.setAttribute("d", interestPathStr);

    // Labels
    const totalYears = Math.ceil(totalMonths / 12);
    if (chartMidLabel)
      chartMidLabel.textContent = `${Math.round(totalYears / 2)} Yrs`;
    if (chartEndLabel) chartEndLabel.textContent = `${totalYears} Yrs`;

    const chartStartLabel = document.getElementById("chart-start-label");
    if (chartStartLabel) chartStartLabel.textContent = "0 Yrs";

    updateYAxisLabels(maxVal);

    renderChartGrid(width, height, padding);

    // Trace events
    setupChartTracer(
      schedule,
      xScale,
      yScale,
      totalMonths,
      width,
      padding,
      (point: any) => `
      <div class="font-bold border-b border-canvas/20 pb-1 mb-1">${point.monthName} ${point.year}</div>
      <div>Balance: <span class="text-brand-blue font-bold">${formatCurrency(Math.round(point.balance))}</span></div>
      <div>Cum. Interest: <span class="text-brand-coral font-bold">${formatCurrency(Math.round(point.totalInterest))}</span></div>
    `,
    );
  }

