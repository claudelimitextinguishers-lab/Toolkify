  function setMode(mode: string) {
    const btn = document.querySelector(`[data-mode="${mode}"]`) as HTMLButtonElement;
    if (btn) btn.click();
  }

  function loadState() {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has("mode")) {
      const mode = urlParams.get("mode");
      if (mode) setMode(mode);

      if (urlParams.has("price")) {
        homePriceInput.value = urlParams.get("price") || "400000";
        if (homePriceSlider) homePriceSlider.value = urlParams.get("price") || "400000";
        if (homePriceValLabel) homePriceValLabel.textContent = "$" + parseInt(homePriceInput.value).toLocaleString();
      }
      if (urlParams.has("down")) {
        downPaymentDollarInput.value = urlParams.get("down") || "80000";
      }
      if (urlParams.has("down_pct")) {
        downPaymentPercentInput.value = urlParams.get("down_pct") || "20";
        if (downPaymentPercentSlider) downPaymentPercentSlider.value = urlParams.get("down_pct") || "20";
      }
      if (urlParams.has("rate")) {
        interestRateInput.value = urlParams.get("rate") || "6.5";
        if (interestRateSlider) interestRateSlider.value = urlParams.get("rate") || "6.5";
      }
      if (urlParams.has("term")) {
        purchaseLoanTerm = parseInt(urlParams.get("term") || "30", 10);
      }
      // Affordability mode inputs
      if (urlParams.has("income")) {
        affGrossIncome.value = urlParams.get("income") || "100000";
        if (affGrossIncomeSlider) affGrossIncomeSlider.value = urlParams.get("income") || "100000";
      }
      if (urlParams.has("debts")) {
        affMonthlyDebts.value = urlParams.get("debts") || "500";
        if (affMonthlyDebtsSlider) affMonthlyDebtsSlider.value = urlParams.get("debts") || "500";
      }
      if (urlParams.has("cash")) {
        affCash.value = urlParams.get("cash") || "60000";
        if (affCashSlider) affCashSlider.value = urlParams.get("cash") || "60000";
      }
      // Refinance mode inputs
      if (urlParams.has("refi_bal")) {
        refiBalance.value = urlParams.get("refi_bal") || "300000";
        if (refiBalanceSlider) refiBalanceSlider.value = urlParams.get("refi_bal") || "300000";
      }
      if (urlParams.has("refi_cur_rate")) {
        refiCurrentRate.value = urlParams.get("refi_cur_rate") || "7.5";
      }
      if (urlParams.has("refi_new_rate")) {
        refiNewRate.value = urlParams.get("refi_new_rate") || "6.0";
      }
      // Rent vs Buy inputs
      if (urlParams.has("rent")) {
        rentbuyRent.value = urlParams.get("rent") || "2000";
        if (rentbuyRentSlider) rentbuyRentSlider.value = urlParams.get("rent") || "2000";
      }
      if (urlParams.has("rent_price")) {
        rentbuyPrice.value = urlParams.get("rent_price") || "350000";
        if (rentbuyPriceSlider) rentbuyPriceSlider.value = urlParams.get("rent_price") || "350000";
      }
    }
  }

  // FAQ Accordion Toggle Interaction
  const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
  faqToggleButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      
      // Close other open accordions
      faqToggleButtons.forEach((otherBtn) => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute("aria-expanded", "false");
          const otherContent = otherBtn.nextElementSibling;
          if (otherContent) otherContent.classList.add("hidden");
          otherBtn.querySelector("svg")?.classList.remove("rotate-180");
        }
      });

      // Toggle current accordion
      btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
      const content = btn.nextElementSibling;
      if (content) {
        content.classList.toggle("hidden");
      }
      btn.querySelector("svg")?.classList.toggle("rotate-180");
    });
  });

  loadState();
  syncPurchaseTermButtons(purchaseLoanTerm);
  calculate();
  renderScenariosBoard();
</script>
