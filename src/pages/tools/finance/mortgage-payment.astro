  // Formatting currencies
  function formatCurrency(amount: number) {
    return (
      "$" +
      amount.toLocaleString(undefined, {
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      })
    );
  }

  // Formatting currencies in short form (e.g. $100k)
  function formatShortCurrency(val: number) {
    if (val >= 1000000) {
      return `$${(val / 1000000).toFixed(1).replace(/\.0$/, "")}M`;
    }
    if (val >= 1000) {
      return `$${(val / 1000).toFixed(0)}k`;
    }
    return `$${val}`;
  }

  // Update Y-axis labels dynamically
  function updateYAxisLabels(maxVal: number) {
    const yLabelsContainer = document.getElementById("chart-y-labels");
    if (!yLabelsContainer) return;
    
    const label4 = formatShortCurrency(maxVal);
    const label3 = formatShortCurrency(maxVal * 0.75);
    const label2 = formatShortCurrency(maxVal * 0.5);
    const label1 = formatShortCurrency(maxVal * 0.25);
    const label0 = "$0";

    yLabelsContainer.innerHTML = `
      <span class="leading-none">${label4}</span>
      <span class="leading-none">${label3}</span>
      <span class="leading-none">${label2}</span>
      <span class="leading-none">${label1}</span>
      <span class="leading-none">${label0}</span>
    `;
  }

  // Scenario Board Interface
  interface Scenario {
    id: number;
    mode: string;
    title: string;
    colorIndex: number;
    metrics: { label: string; value: string }[];
    inputs: any;
  }

  function getScenarios(): Scenario[] {
    const data = localStorage.getItem("toolkify_suite_scenarios");
    return data ? JSON.parse(data) : [];
  }

  function saveScenarios(scenarios: Scenario[]) {
    localStorage.setItem(
      "toolkify_suite_scenarios",
      JSON.stringify(scenarios),
    );
    renderScenariosBoard();
  }

  function pinScenario(
    mode: "purchase" | "affordability" | "refinance" | "rent-buy",
  ) {
    const scenarios = getScenarios();
    const id = Date.now();
    const colorIndex = scenarios.length % stickyPastelColors.length;

    let title = "";
    let metrics: { label: string; value: string }[] = [];
    let inputsObj: any = {};

    if (mode === "purchase") {
      const price = parseFloat(homePriceInput.value) || 0;
      const rate = parseFloat(interestRateInput.value) || 0;
      const paymentText = monthlyPaymentDisplay?.textContent || "$0";
      title = `Purchase: $${Math.round(price / 1000)}K @ ${rate}%`;
      metrics = [
        { label: "Monthly Payment", value: paymentText },
        {
          label: "Loan Amount",
          value:
            loanAmountBadge?.textContent?.replace("Loan Amount: ", "") || "$0",
        },
        {
          label: "Property Tax",
          value:
            formatCurrency(parseFloat(propertyTaxDollarInput.value) / 12) +
            "/mo",
        },
        { label: "Interest Rate", value: `${rate}%` },
      ];
      inputsObj = {
        mode,
        price,
        dpDollar: parseFloat(downPaymentDollarInput.value),
        dpPercent: parseFloat(downPaymentPercentInput.value),
        rate,
        term: purchaseLoanTerm,
        gross: parseFloat(purchaseGrossIncome.value),
        debts: parseFloat(purchaseMonthlyDebts.value),
      };
    } else if (mode === "affordability") {
      const annualIncome = parseFloat(affGrossIncome.value) || 0;
      const maxPriceText = affMaxPrice?.textContent || "$0";
      title = `Affordability: $${Math.round(annualIncome / 1000)}K Income`;
      metrics = [
        { label: "Max Home Price", value: maxPriceText },
        {
          label: "Down Payment Cash",
          value: formatCurrency(parseFloat(affCash.value)),
        },
        { label: "Housing Limit", value: affMaxPITI?.textContent || "$0" },
        { label: "Interest rate", value: `${affRate.value}%` },
      ];
      inputsObj = {
        mode,
        income: annualIncome,
        debts: parseFloat(affMonthlyDebts.value),
        cash: parseFloat(affCash.value),
        rate: parseFloat(affRate.value),
        term: affTermSelect.value,
        dtiMode: affDtiMode.value,
      };
    }

    const newScenario: Scenario = {
      id,
      mode,
      title,
      colorIndex,
      metrics,
      inputs: inputsObj,
    };
    scenarios.push(newScenario);
    saveScenarios(scenarios);
  }

  function loadScenario(id: number) {
    const scenarios = getScenarios();
    const sc = scenarios.find((s) => s.id === id);
    if (!sc) return;

    const btn = document.querySelector(
      `.btn-mode[data-mode="${sc.mode}"]`,
    ) as HTMLButtonElement;
    if (btn) btn.click();

    if (sc.mode === "purchase") {
      homePriceInput.value = sc.inputs.price.toString();
      homePriceSlider.value = sc.inputs.price.toString();
      downPaymentDollarInput.value = sc.inputs.dpDollar.toString();
      downPaymentPercentInput.value = sc.inputs.dpPercent.toString();
      downPaymentPercentSlider.value = sc.inputs.dpPercent.toString();
      interestRateInput.value = sc.inputs.rate.toString();
      interestRateSlider.value = sc.inputs.rate.toString();
      loanTermSlider.value = sc.inputs.term.toString();
      purchaseGrossIncome.value = sc.inputs.gross.toString();
      purchaseMonthlyDebts.value = sc.inputs.debts.toString();
      purchaseLoanTerm = sc.inputs.term;
      if (loanTermVal) loanTermVal.textContent = `${sc.inputs.term} years`;
      syncPurchaseTermButtons(sc.inputs.term);
    } else if (sc.mode === "affordability") {
      affGrossIncome.value = sc.inputs.income.toString();
      affGrossIncomeSlider.value = sc.inputs.income.toString();
      affMonthlyDebts.value = sc.inputs.debts.toString();
      affMonthlyDebtsSlider.value = sc.inputs.debts.toString();
      affCash.value = sc.inputs.cash.toString();
      affCashSlider.value = sc.inputs.cash.toString();
      affRate.value = sc.inputs.rate.toString();
      affTermSelect.value = sc.inputs.term;
      affDtiMode.value = sc.inputs.dtiMode;
    }

    calculate();
  }

  function renderScenariosBoard() {
    if (!scenariosBoardGrid) return;
    const scenarios = getScenarios();

    if (sandboxToggleTitle) {
      sandboxToggleTitle.textContent = `Compare Saved Scenarios (${scenarios.length})`;
    }

    if (scenarios.length === 0) {
      if (scenariosEmptyState) scenariosEmptyState.classList.remove("hidden");
      const emptyStateHtml = scenariosEmptyState?.outerHTML || "";
      scenariosBoardGrid.innerHTML = emptyStateHtml;
      return;
    }

    if (scenariosEmptyState) scenariosEmptyState.classList.add("hidden");

    let gridHtml = "";
    scenarios.forEach((sc) => {
      const color = stickyPastelColors[sc.colorIndex];
      let metricsHtml = "";
      sc.metrics.forEach((m) => {
        metricsHtml += `
          <div>
            <span class="text-[9px] opacity-60 font-semibold block uppercase">${m.label}</span>
            <span class="font-display font-bold text-sm text-primary">${m.value}</span>
          </div>
        `;
      });

      gridHtml += `
        <div class="relative ${color.bg} rounded-xl p-5 shadow-subtle border flex flex-col justify-between gap-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-card animate-scale-in">
          <button type="button" class="btn-delete-scenario absolute top-3 right-3 text-primary/40 hover:text-brand-red-dark hover:scale-110 transition-all cursor-pointer text-xs font-semibold p-1" data-id="${sc.id}" title="Remove variant">✕</button>
          
          <div class="flex flex-col gap-1 pr-6">
            <span class="text-[9px] uppercase font-bold tracking-wider opacity-60">Variant: ${sc.mode.toUpperCase()}</span>
            <input type="text" class="font-display font-bold text-xs bg-transparent border-b border-transparent hover:border-primary/20 focus:border-brand-blue outline-none text-primary pb-0.5 truncate w-full" value="${sc.title}" data-id="${sc.id}" />
          </div>

          <div class="grid grid-cols-2 gap-3 text-xs border-t border-primary/5 pt-3">
            ${metricsHtml}
          </div>

          <button type="button" class="btn-load-scenario mt-1 w-full py-1.5 px-3 bg-primary/95 text-canvas text-xs font-semibold rounded-md shadow-subtle hover:bg-primary active:scale-95 transition-all text-center cursor-pointer" data-id="${sc.id}">Load Workspace</button>
        </div>
      `;
    });

    scenariosBoardGrid.innerHTML = gridHtml;

    // Attach hooks
    scenariosBoardGrid.querySelectorAll(".btn-load-scenario").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const id = parseInt(
          (e.currentTarget as HTMLButtonElement).dataset.id || "0",
        );
        loadScenario(id);
      });
    });

    scenariosBoardGrid
      .querySelectorAll(".btn-delete-scenario")
      .forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const id = parseInt(
            (e.currentTarget as HTMLButtonElement).dataset.id || "0",
          );
          let list = getScenarios().filter((s) => s.id !== id);
          list.forEach(
            (s, idx) => (s.colorIndex = idx % stickyPastelColors.length),
          );
          saveScenarios(list);
        });
      });

    scenariosBoardGrid
      .querySelectorAll('input[type="text"]')
      .forEach((input) => {
        input.addEventListener("change", (e) => {
          const target = e.target as HTMLInputElement;
          const id = parseInt(target.dataset.id || "0");
          const newTitle = target.value.trim();
          if (newTitle) {
            const list = getScenarios();
            const match = list.find((s) => s.id === id);
            if (match) {
              match.title = newTitle;
              saveScenarios(list);
            }
          }
        });
      });
  }

