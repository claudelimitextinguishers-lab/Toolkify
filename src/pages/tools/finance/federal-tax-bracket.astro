---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Federal Tax Bracket Calculator";
const category = "finance";
const tier = "Finance & Tax";

// On-page SEO metadata
const pageTitle =
  "Federal Tax Bracket Calculator – Free 2026 Tax Estimator";
const description =
  "Free federal tax bracket calculator. Estimate your federal income tax, marginal & effective rate, and see how each bracket is taxed by income and filing status.";
const canonicalUrl =
  "https://toolkify.app/tools/finance/federal-tax-bracket";
const ogImage = "/og/federal-tax-bracket-calculator.png";
const keywords =
  "federal tax bracket calculator, federal income tax bracket calculator, federal tax calculator, state and federal tax calculator, estimated federal tax calculator, federal tax calculator paycheck, federal income tax calculator, tax bracket calculator, marginal tax rate calculator, effective tax rate calculator, federal tax brackets 2026, federal tax brackets 2025, how much federal tax do i owe, income tax bracket calculator, us federal income tax calculator";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Federal Tax Bracket Calculator",
      "alternateName": "Federal Income Tax Bracket Calculator 2026",
      "url": "https://toolkify.app/tools/finance/federal-tax-bracket",
      "description": "Free federal tax bracket calculator and federal income tax calculator. Estimate your federal income tax, marginal tax rate, and effective tax rate using official inflation-adjusted brackets, with standard or itemized deductions and a stacked-bracket visualization.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Federal tax bracket calculator with 2024, 2025, and 2026 brackets",
        "Federal income tax bracket calculator by income and filing status",
        "Marginal tax rate and effective tax rate calculator",
        "Estimated federal tax calculator with standard or itemized deductions",
        "Federal tax calculator for paycheck and annual income planning",
        "Stacked bracket visualization and per-bracket tax breakdown"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "1620"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Finance & Tax Tools",
          "item": "https://toolkify.app/tools/finance"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Federal Tax Bracket Calculator",
          "item": "https://toolkify.app/tools/finance/federal-tax-bracket"
        }
      ]
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "what is the federal income tax bracket",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A federal income tax bracket is a range of income levels taxed at a specific rate. The United States uses a progressive tax system, meaning your income is taxed in progressive bands. As you earn more, your income moves into higher brackets with higher rates (ranging from 10% to 37%), but only the portion of income within each bracket's thresholds is taxed at that specific rate."
          }
        },
        {
          "@type": "Question",
          "name": "how much federal tax should i pay calculator",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "How much federal income tax you should pay is calculated based on your total annual gross income, minus any pre-tax deductions (like 401k or HSA contributions) and either the standard deduction or itemized deductions. Using a federal income tax calculator, you can enter these details to determine your taxable income, apply the progressive tax brackets, and estimate the exact amount of federal tax you owe."
          }
        },
        {
          "@type": "Question",
          "name": "how much state and federal tax calculator",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A state and federal tax calculator estimates your total annual tax liability by calculating both your U.S. federal income tax and your state's income tax. While federal taxes are uniform across the country, state taxes vary widely—some states have flat rates, some have progressive brackets, and others have no state income tax at all."
          }
        },
        {
          "@type": "Question",
          "name": "what is my federal tax rate calculator",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A tax rate calculator shows both your marginal tax rate (the tax bracket of your highest dollar earned) and your effective tax rate (the actual percentage of your total income paid in taxes). Since tax brackets are progressive, your effective tax rate is always lower than your marginal tax rate."
          }
        },
        {
          "@type": "Question",
          "name": "what federal tax bracket am i in",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To find out what federal tax bracket you are in, you need to calculate your taxable income (gross income minus standard or itemized deductions) and compare it to the IRS tax tables for your filing status (Single, Married Filing Jointly, Married Filing Separately, or Head of Household). Your bracket corresponds to the rate applied to your highest dollar of taxable income."
          }
        },
        {
          "@type": "Question",
          "name": "what is the highest federal tax bracket",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The highest federal income tax bracket in the United States is 37%. This top rate applies to taxable incomes exceeding inflation-adjusted thresholds (for 2026, over $640,600 for Single filers and over $768,700 for Married Filing Jointly)."
          }
        },
        {
          "@type": "Question",
          "name": "what is the federal tax bracket",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The U.S. federal tax bracket system consists of seven tax rates: 10%, 12%, 22%, 24%, 32%, 35%, and 37%. The IRS adjusts the income thresholds for these brackets annually to account for inflation, ensuring that taxpayers do not face \"bracket creep\" simply due to cost-of-living adjustments."
          }
        },
        {
          "@type": "Question",
          "name": "what is the lowest federal tax bracket",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The lowest federal tax bracket is 10%. This rate applies to the first portion of your taxable income (for 2026, the first $12,400 for Single filers and the first $24,800 for Married Filing Jointly) after standard or itemized deductions are applied."
          }
        },
        {
          "@type": "Question",
          "name": "does the federal tax bracket include social security and medicare",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, federal income tax brackets do not include Social Security and Medicare taxes. Those are FICA (Federal Insurance Contributions Act) payroll taxes, which are calculated separately at flat rates: 6.2% for Social Security (up to a wage cap) and 1.45% for Medicare (with an additional 0.9% for high earners), typically deducted automatically from your paycheck."
          }
        },
        {
          "@type": "Question",
          "name": "how to determine federal tax bracket",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To determine your federal tax bracket:</p><ol><li>Calculate your gross income for the year.</li><li>Subtract pre-tax contributions (401k, HSA) and standard or itemized deductions to find your taxable income.</li><li>Match your taxable income and filing status against the IRS tax bracket tables. The highest bracket your taxable income reaches is your marginal tax bracket.</li></ol>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-3 flex flex-col gap-4 animate-fade-in-up pb-24 lg:pb-12">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav class="flex items-center gap-1.5 text-xs font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-2xl sm:text-3xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2.5 rounded-full font-semibold uppercase shrink-0">{tier}</span>
        </div>
        
        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How tax bracket calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mode / Action Header -->
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-hairline pb-2">
      <div class="flex items-center gap-2">
        <label for="tax-year" class="text-xs font-bold text-slate uppercase tracking-wider">
          Tax Year
        </label>
        <select
          id="tax-year"
          class="text-xs font-semibold bg-canvas border border-hairline text-primary rounded-md py-1 px-2.5 focus:outline-none focus:ring-1 focus:ring-brand-blue cursor-pointer"
        >
          <option value="2026" selected>2026 (Filed in 2027)</option>
          <option value="2025">2025 (Filed in 2026)</option>
          <option value="2024">2024 (Filed in 2025)</option>
        </select>
      </div>
    </div>  

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left: Inputs (5 Columns) -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="card-base flex flex-col gap-5">
          <h2 class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Income & Filing Details
          </h2>

          <!-- Filing Status -->
          <div class="flex flex-col gap-1.5">
            <label for="filing-status" class="text-xs font-semibold text-charcoal">
              Filing Status
            </label>
            <select id="filing-status" class="text-input" aria-label="Filing Status">
              <option value="single" selected>Single</option>
              <option value="mfj">Married Filing Jointly</option>
              <option value="mfs">Married Filing Separately</option>
              <option value="hoh">Head of Household</option>
            </select>
          </div>

          <!-- Annual Gross Income -->
          <div class="flex flex-col gap-1.5">
            <label for="gross-income" class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Annual Gross Income</span>
              <span class="text-stone font-normal">USD ($)</span>
            </label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium">$</span>
              <input
                type="text"
                id="gross-income"
                value="75,000"
                class="text-input pl-7 font-mono text-sm"
                inputmode="numeric"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Pre-Tax Deductions -->
          <div class="flex flex-col gap-1.5">
            <label for="pretax-deductions" class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Pre-Tax Deductions (401k, HSA, etc.)</span>
              <span class="text-stone font-normal">USD ($)</span>
            </label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium">$</span>
              <input
                type="text"
                id="pretax-deductions"
                value="5,000"
                class="text-input pl-7 font-mono text-sm"
                inputmode="numeric"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Deduction Type Toggle -->
          <div class="flex flex-col gap-2 pt-2 border-t border-hairline-soft">
            <div class="flex items-center justify-between text-xs font-semibold text-charcoal">
              <span>Federal Deduction Method</span>
              <div class="flex rounded-full bg-surface p-0.5 border border-hairline">
                <button
                  type="button"
                  id="deduction-toggle-standard"
                  class="text-[10px] px-3.5 py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
                >
                  Standard
                </button>
                <button
                  type="button"
                  id="deduction-toggle-itemized"
                  class="text-[10px] px-3.5 py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate"
                >
                  Itemized
                </button>
              </div>
            </div>

            <!-- Standard Deduction Display -->
            <div id="standard-deduction-wrapper" class="flex flex-col gap-1">
              <label for="standard-deduction-amt" class="text-[10px] font-semibold text-slate">Auto-filled Standard Deduction</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-xs font-medium">$</span>
                <input
                  type="text"
                  id="standard-deduction-amt"
                  value="16,100"
                  class="text-input pl-7 font-mono text-xs bg-surface text-stone cursor-not-allowed"
                  disabled
                  readonly
                />
              </div>
            </div>

            <!-- Itemized Deduction Input -->
            <div id="itemized-deduction-wrapper" class="flex flex-col gap-1 hidden">
              <label for="itemized-deduction-amt" class="text-[10px] font-semibold text-slate">Enter Itemized Deductions</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-xs font-medium">$</span>
                <input
                  type="text"
                  id="itemized-deduction-amt"
                  value="18,000"
                  class="text-input pl-7 font-mono text-xs"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
            </div>

            <div id="deduction-feedback" class="text-[11px] text-stone font-mono mt-1">
              Total Deductions: $21,100 (reduces your taxable income)
            </div>
          </div>
        </div>

        <!-- Calculation Guide Card -->
        <div class="card-base bg-surface-soft flex flex-col gap-4">
          <h3 class="font-display font-semibold text-base text-primary">Deductions and Taxable Income</h3>
          <div class="flex flex-col gap-2.5 text-xs text-slate leading-relaxed">
            <p>
              Your tax is not calculated on your total gross income, but on your <strong>taxable income</strong>.
            </p>
            <div class="p-3 bg-canvas rounded-lg border border-hairline font-mono text-[11px] text-charcoal flex flex-col gap-1 shadow-subtle">
              <div class="flex justify-between">
                <span>Gross Income:</span>
                <span id="formula-gross">$75,000</span>
              </div>
              <div class="flex justify-between text-brand-red-dark">
                <span>- Pre-Tax Deductions:</span>
                <span id="formula-pretax">-$5,000</span>
              </div>
              <div class="flex justify-between text-brand-red-dark">
                <span>- Fed Deduction:</span>
                <span id="formula-fed">-$16,100</span>
              </div>
              <div class="flex justify-between border-t border-hairline-strong pt-1 font-bold text-success-accent">
                <span>= Taxable Income:</span>
                <span id="formula-taxable">$53,900</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Results (7 Columns) -->
      <div id="results-column" class="lg:col-span-7 flex flex-col gap-6">
        <!-- Results Summary Hero Card -->
        <div class="card-base flex flex-col justify-between bg-surface relative overflow-hidden rounded-xl p-6">
          <div class="absolute top-0 right-0 w-32 h-32 bg-success-accent/10 rounded-full blur-3xl"></div>
          
          <div class="flex flex-col gap-5 z-10">
            <div class="flex items-center justify-between border-b border-hairline-soft pb-3">
              <div>
                <span class="text-xs font-bold text-slate uppercase tracking-wider block">Estimated Federal Tax Owed</span>
                <div id="tax-owed-display" class="font-display font-medium text-4xl sm:text-5xl tracking-tight text-primary transition-all duration-300 select-all font-mono">
                  $7,330
                </div>
              </div>
              <div class="text-right">
                <span class="text-xs font-bold text-slate uppercase tracking-wider block">You Keep</span>
                <div id="you-keep-display" class="font-display font-bold text-3xl sm:text-4xl text-success-accent font-mono">
                  90.2%
                </div>
              </div>
            </div>

            <!-- Basic stats row -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate">Effective Rate</span>
                <span id="effective-rate-display" class="font-display font-semibold text-base text-primary font-mono select-all">9.77%</span>
                <span class="text-[8px] text-stone leading-tight mt-0.5" title="Total Tax Owed divided by Gross Income">Tax / Gross Income</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate">Marginal Rate</span>
                <span id="marginal-rate-display" class="font-display font-semibold text-base text-primary font-mono select-all">22.0%</span>
                <span class="text-[8px] text-stone leading-tight mt-0.5" title="The bracket your highest dollar is taxed in">Top Bracket Rate</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate">Taxable Income</span>
                <span id="taxable-income-display" class="font-display font-semibold text-base text-primary font-mono select-all">$53,900</span>
                <span class="text-[8px] text-stone leading-tight mt-0.5">Subject to brackets</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate">After-Tax Income</span>
                <span id="after-tax-display" class="font-display font-semibold text-base text-success-accent font-mono select-all">$67,670</span>
                <span class="text-[8px] text-stone leading-tight mt-0.5">Gross minus Fed Tax</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Visual Bar Chart Card -->
        <div class="card-base flex flex-col gap-4">
          <h3 class="text-xs font-semibold text-slate uppercase tracking-wider pb-1 border-b border-hairline-soft">
            Income Distribution Across Brackets
          </h3>
          <div class="flex flex-col gap-3">
            <!-- Progress Bar Container -->
            <div id="bracket-chart-bar" class="w-full h-8 rounded-lg overflow-hidden flex bg-surface border border-hairline shadow-subtle">
              <!-- JS will inject segments dynamically -->
            </div>
            
            <!-- Legend indicators -->
            <div id="bracket-chart-legend" class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs pt-1">
              <!-- JS populated legend -->
            </div>
          </div>
        </div>

        <!-- Bracket Breakdown Table Card -->
        <div class="card-base flex flex-col gap-4 p-4 sm:p-6">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-hairline pb-2">
            <h3 class="font-display font-semibold text-base text-primary">
              Detailed Bracket Breakdown
            </h3>
            <div class="flex items-center gap-2">
              <button
                type="button"
                id="csv-export-btn"
                class="inline-flex items-center justify-center gap-1.5 text-[10px] sm:text-xs font-semibold px-2.5 sm:px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle truncate"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-3.5 sm:h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <span>Export CSV</span>
              </button>
              <button
                type="button"
                id="excel-export-btn"
                class="inline-flex items-center justify-center gap-1.5 text-[10px] sm:text-xs font-semibold px-2.5 sm:px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle truncate"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-3.5 sm:h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <span>Export Excel</span>
              </button>
            </div>
          </div>

          <div class="w-full overflow-x-auto">
            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="bg-surface text-stone border-b border-hairline uppercase text-[10px] font-bold tracking-wider font-mono">
                  <th class="py-2.5 px-3">Rate</th>
                  <th class="py-2.5 px-3">Taxable Range</th>
                  <th class="py-2.5 px-3 text-right">Income in Bracket</th>
                  <th class="py-2.5 px-3 text-right">Tax Owed</th>
                </tr>
              </thead>
              <tbody id="breakdown-table-body">
                <!-- JS populated rows -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

