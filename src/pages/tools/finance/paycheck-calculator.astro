    let customTaxSettings: any = null;
    let customBrackets: { limit: number; rate: number }[] = [];

    // Populating State / Province / Regime selector
    function initializeStates() {
      if (!stateSelect || !stateSelectContainer || !stateSelectLabel) return;
      
      const labelEl = document.getElementById("state-override-checkbox-label");

      if (currentCountry === "US") {
        if (labelEl) labelEl.textContent = "Override with custom flat state rate";
        stateSelectContainer.classList.remove("hidden");
        stateSelectLabel.textContent = "State Tax Residency";
        let html = "";
        Object.keys(STATE_TAX_DATA).forEach((code) => {
          const state = STATE_TAX_DATA[code as keyof typeof STATE_TAX_DATA];
          const isSelected = code === "CA" ? "selected" : "";
          html += `<option value="${code}" ${isSelected}>${state.name} (${code})</option>`;
        });
        stateSelect.innerHTML = html;
      } else if (currentCountry === "Custom") {
        if (labelEl) labelEl.textContent = "Override with custom flat regional rate";
        stateSelectContainer.classList.add("hidden");
      } else {
        if (labelEl) labelEl.textContent = "Override with custom flat regional rate";
        const cData = OTHER_COUNTRIES_TAX_DATA[currentCountry as keyof typeof OTHER_COUNTRIES_TAX_DATA] as any;
        if (cData) {
          stateSelectContainer.classList.remove("hidden");
          stateSelectLabel.textContent = cData.regionLabel;
          let html = "";
          Object.keys(cData.regions).forEach((code) => {
            const reg = cData.regions[code as keyof typeof cData.regions] as any;
            const isSelected = code === cData.defaultRegion ? "selected" : "";
            html += `<option value="${code}" ${isSelected}>${reg.name}</option>`;
          });
          stateSelect.innerHTML = html;
        } else {
          stateSelectContainer.classList.add("hidden");
        }
      }
    }

