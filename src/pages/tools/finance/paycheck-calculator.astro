    // Calculation Engine
    function calculate() {
      // 1. Gross Annual Income
      let annualGross = 0;
      if (salaryMode === "annual") {
        annualGross = parseFloat(annualSalaryInput.value) || 0;
      } else {
        const rate = parseFloat(hourlyRateInput.value) || 0;
        const hours = parseFloat(hoursWeekInput.value) || 0;
        annualGross = rate * hours * 52;
        if (hourlyEquivalentVal) {
          hourlyEquivalentVal.textContent = formatCurrency(annualGross) + "/yr";
        }
      }

      // 2. Frequency Config
      const freq = payFrequencySelect.value;
      let payPeriods = 26;
      let freqLabel = "Bi-weekly Paycheck";
      if (freq === "weekly") { payPeriods = 52; freqLabel = "Weekly Paycheck"; }
      else if (freq === "semimonthly") { payPeriods = 24; freqLabel = "Semi-monthly Paycheck"; }
      else if (freq === "monthly") { payPeriods = 12; freqLabel = "Monthly Paycheck"; }

      if (paycheckFrequencyBadge) {
        paycheckFrequencyBadge.textContent = `${freqLabel} (${payPeriods}/yr)`;
      }

      const paycheckGross = annualGross / payPeriods;

      // 3. Deductions
      const status = filingStatusSelect.value;

      // 401(k) / retirement plan deduction
      const val401k = parseFloat(ded401kInput.value) || 0;
      const unit401k = ded401kUnitSelect.value;
      let ded401kPerPaycheck = 0;

      if (unit401k === "percent") {
        ded401kPerPaycheck = paycheckGross * (val401k / 100);
        if (ded401kUnitIndicator) ded401kUnitIndicator.textContent = "%";
        if (ded401kCalcVal) ded401kCalcVal.textContent = `${val401k.toFixed(1)}% (${formatCurrency(ded401kPerPaycheck)}/pay)`;
      } else {
        ded401kPerPaycheck = val401k;
        if (ded401kUnitIndicator) ded401kUnitIndicator.textContent = "$";
        const percentEquivalent = paycheckGross > 0 ? (ded401kPerPaycheck / paycheckGross) * 100 : 0;
        if (ded401kCalcVal) ded401kCalcVal.textContent = `${percentEquivalent.toFixed(1)}% (${formatCurrency(ded401kPerPaycheck)}/pay)`;
      }

      const dedHealthPerPaycheck = parseFloat(dedHealthInput.value) || 0;
      const dedHsaPerPaycheck = parseFloat(dedHsaInput.value) || 0;

      const annual401k = ded401kPerPaycheck * payPeriods;
      const annualHealth = dedHealthPerPaycheck * payPeriods;
      const annualHSA = dedHsaPerPaycheck * payPeriods;

      // Tax output variables
      let annualSS = 0;
      let annualMedicare = 0;
      let annualFedTax = 0;
      let annualStateTax = 0;
      let annualLocalTax = 0;

      // 4. Calculations
      if (currentCountry === "US") {
        const stdDed = FED_STANDARD_DEDUCTIONS[status as keyof typeof FED_STANDARD_DEDUCTIONS] || 14600;

        let annualFicaBase = annualGross;
        if (isDeductionsHealthPretax) annualFicaBase -= annualHealth;
        if (isDeductionsHsaPretax) annualFicaBase -= annualHSA;
        annualFicaBase = Math.max(0, annualFicaBase);

        annualSS = Math.min(annualFicaBase, 168600) * 0.062;

        const medThreshold = status === "joint" ? 250000 : 200000;
        if (annualFicaBase > medThreshold) {
          annualMedicare = (medThreshold * 0.0145) + ((annualFicaBase - medThreshold) * 0.0235);
        } else {
          annualMedicare = annualFicaBase * 0.0145;
        }

        let preTaxDeds = 0;
        if (isDeductions401kPretax) preTaxDeds += annual401k;
        if (isDeductionsHealthPretax) preTaxDeds += annualHealth;
        if (isDeductionsHsaPretax) preTaxDeds += annualHSA;

        let fedTaxable = annualGross - preTaxDeds - stdDed;
        fedTaxable = Math.max(0, fedTaxable);

        annualFedTax = calculateProgressiveTax(fedTaxable, FED_BRACKETS[status as keyof typeof FED_BRACKETS] || FED_BRACKETS.single);

        const stateCode = stateSelect.value;
        const stateData = STATE_TAX_DATA[stateCode as keyof typeof STATE_TAX_DATA] as any;

        let stateTaxable = annualGross - preTaxDeds;
        stateTaxable = Math.max(0, stateTaxable);

        if (stateOverrideCheckbox && stateOverrideCheckbox.checked) {
          const customRate = parseFloat(stateOverrideRateInput.value) || 0;
          annualStateTax = stateTaxable * (customRate / 100);
        } else if (stateData) {
          if (stateData.type === "flat" && stateData.rate !== undefined) {
            annualStateTax = stateTaxable * stateData.rate;
          } else if (stateData.type === "progressive" && stateData.brackets) {
            const brackets = stateData.brackets[status as keyof typeof stateData.brackets] || stateData.brackets.single;
            annualStateTax = calculateProgressiveTax(stateTaxable, brackets);
            if (stateData.CA_MentalHealthSurcharge && stateTaxable > 1000000) {
              annualStateTax += (stateTaxable - 1000000) * 0.01;
            }
            if (stateData.MA_Surtax && stateTaxable > 1000000) {
              annualStateTax += (stateTaxable - 1000000) * 0.04;
            }
          }
        }

        const localRate = parseFloat(localTaxRateInput.value) || 0;
        annualLocalTax = fedTaxable * (localRate / 100);

      } else if (currentCountry === "Custom" && customTaxSettings) {
        const stdDed = customTaxSettings.stdDeduction;

        let annualFicaBase = annualGross;
        if (isDeductionsHealthPretax) annualFicaBase -= annualHealth;
        if (isDeductionsHsaPretax) annualFicaBase -= annualHSA;
        annualFicaBase = Math.max(0, annualFicaBase);

        annualSS = Math.min(annualFicaBase, customTaxSettings.ssCap) * (customTaxSettings.ssRate / 100);

        if (annualFicaBase > customTaxSettings.medThreshold) {
          annualMedicare = (customTaxSettings.medThreshold * (customTaxSettings.medRate / 100)) + 
                           ((annualFicaBase - customTaxSettings.medThreshold) * ((customTaxSettings.medRate + customTaxSettings.medSurtax) / 100));
        } else {
          annualMedicare = annualFicaBase * (customTaxSettings.medRate / 100);
        }

        let preTaxDeds = 0;
        if (isDeductions401kPretax) preTaxDeds += annual401k;
        if (isDeductionsHealthPretax) preTaxDeds += annualHealth;
        if (isDeductionsHsaPretax) preTaxDeds += annualHSA;

        let taxable = annualGross - preTaxDeds - stdDed;
        taxable = Math.max(0, taxable);

        annualFedTax = calculateProgressiveTax(taxable, customTaxSettings.brackets);
        annualStateTax = taxable * (customTaxSettings.stateFlat / 100);
        
        const localRate = parseFloat(localTaxRateInput.value) || 0;
        annualLocalTax = taxable * (localRate / 100);

      } else {
        const cData = OTHER_COUNTRIES_TAX_DATA[currentCountry as keyof typeof OTHER_COUNTRIES_TAX_DATA] as any;
        if (cData) {
          const regionCode = stateSelect.value;
          let preTaxDeds = 0;
          if (isDeductions401kPretax) preTaxDeds += annual401k;
          if (isDeductionsHealthPretax) preTaxDeds += annualHealth;
          if (isDeductionsHsaPretax) preTaxDeds += annualHSA;

          if (currentCountry === "CA") {
            let fBase = annualGross;
            if (isDeductionsHealthPretax) fBase -= annualHealth;
            if (isDeductionsHsaPretax) fBase -= annualHSA;
            fBase = Math.max(0, fBase);

            annualSS = (fBase > cData.socialRates.cppExempt) 
              ? Math.min(fBase - cData.socialRates.cppExempt, cData.socialRates.cppMaxWage - cData.socialRates.cppExempt) * cData.socialRates.cppRate
              : 0;
            annualMedicare = Math.min(fBase, cData.socialRates.eiMaxWage) * cData.socialRates.eiRate;

            let taxable = annualGross - preTaxDeds - cData.fedStdDeduction;
            taxable = Math.max(0, taxable);

            annualFedTax = calculateProgressiveTax(taxable, cData.fedBrackets);

            const rData = cData.regions[regionCode as keyof typeof cData.regions] as any;
            if (rData && rData.brackets) {
              annualStateTax = calculateProgressiveTax(taxable, rData.brackets);
            }
          } else if (currentCountry === "GB") {
            let taxable = annualGross - preTaxDeds;
            let personalAllowance = cData.defaultStdDeduction;
            if (taxable > 100000) {
              personalAllowance = Math.max(0, cData.defaultStdDeduction - (taxable - 100000) / 2);
            }
            taxable = Math.max(0, taxable - personalAllowance);

            const rData = cData.regions[regionCode as keyof typeof cData.regions] as any;
            if (rData && rData.brackets) {
              annualFedTax = calculateProgressiveTax(taxable, rData.brackets);
            }
            annualStateTax = 0;

            let niBase = annualGross;
            if (isDeductionsHealthPretax) niBase -= annualHealth;
            if (isDeductionsHsaPretax) niBase -= annualHSA;
            niBase = Math.max(0, niBase);

            const limits = cData.socialRates;
            if (niBase > limits.niLowerLimit) {
              const middlePortion = Math.min(niBase, limits.niUpperLimit) - limits.niLowerLimit;
              annualSS = middlePortion * limits.niRateBetweenLimits;
              if (niBase > limits.niUpperLimit) {
                annualSS += (niBase - limits.niUpperLimit) * limits.niRateAboveLimit;
              }
            }
          } else if (currentCountry === "AU") {
            let taxable = annualGross - preTaxDeds;
            taxable = Math.max(0, taxable);
            annualFedTax = calculateProgressiveTax(taxable, cData.fedBrackets);
            annualSS = taxable * cData.medicareLevy;
            annualStateTax = 0;
          } else if (currentCountry === "DE") {
            let pensionBase = Math.min(annualGross, cData.socialRates.pensionCap);
            let healthBase = Math.min(annualGross, cData.socialRates.healthCap);
            
            const pensionContr = pensionBase * cData.socialRates.pensionRate;
            const unempContr = pensionBase * cData.socialRates.unempRate;
            const healthContr = healthBase * cData.socialRates.healthRate;
            const careContr = healthBase * cData.socialRates.careRate;

            annualSS = pensionContr + unempContr;
            annualMedicare = healthContr + careContr;
            annualStateTax = 0;

            const rData = cData.regions[regionCode as keyof typeof cData.regions] as any;
            let stdDed = rData ? rData.stdDeduction : cData.defaultStdDeduction;
            
            let taxable = annualGross - preTaxDeds - (annualSS + annualMedicare) - stdDed;
            taxable = Math.max(0, taxable);

            if (rData && rData.brackets) {
              annualFedTax = calculateProgressiveTax(taxable, rData.brackets);
            }
          } else if (currentCountry === "IN") {
            const rData = cData.regions[regionCode as keyof typeof cData.regions] as any;
            let stdDed = rData ? rData.stdDeduction : cData.defaultStdDeduction;
            
            let taxable = annualGross - preTaxDeds - stdDed;
            taxable = Math.max(0, taxable);

            if (rData && rData.brackets) {
              annualFedTax = calculateProgressiveTax(taxable, rData.brackets);
            }
            annualSS = 0;
            annualMedicare = annualFedTax * cData.cessRate;
            annualStateTax = 0;
          }
        }
      }

      // Net Take-Home calculations
      const totalDeds = annual401k + annualHealth + annualHSA;
      const totalTaxes = annualFedTax + annualStateTax + annualLocalTax + annualSS + annualMedicare;
      const annualTakeHome = Math.max(0, annualGross - totalTaxes - totalDeds);

      const paycheckTakeHome = annualTakeHome / payPeriods;
      const paycheckFedTax = annualFedTax / payPeriods;
      const paycheckStateTax = annualStateTax / payPeriods;
      const paycheckLocalTax = annualLocalTax / payPeriods;
      const paycheckSS = annualSS / payPeriods;
      const paycheckMedicare = annualMedicare / payPeriods;
      const paycheckFica = paycheckSS + paycheckMedicare;
      const paycheck401k = annual401k / payPeriods;
      const paycheckHealth = annualHealth / payPeriods;
      const paycheckHSA = annualHSA / payPeriods;
      const paycheckTotalDeds = totalDeds / payPeriods;

      lastCalculatedResults = {
        freq,
        status,
        stateCode: stateSelect ? stateSelect.value : "",
        payPeriods,
        annualGross,
        paycheckGross,
        annualFedTax,
        paycheckFedTax,
        annualStateTax,
        paycheckStateTax,
        annualLocalTax,
        paycheckLocalTax,
        annualSS,
        paycheckSS,
        annualMedicare,
        paycheckMedicare,
        annualFica: annualSS + annualMedicare,
        paycheckFica,
        annual401k,
        paycheck401k,
        annualHealth,
        paycheckHealth,
        annualHSA,
        paycheckHSA,
        annualTakeHome,
        paycheckTakeHome,
        totalDeds,
        paycheckTotalDeds
      };

      // 5. Update UI displays
      if (takeHomePaycheckDisplay) takeHomePaycheckDisplay.textContent = formatCurrency(paycheckTakeHome);
      if (takeHomeAnnualDisplay) takeHomeAnnualDisplay.textContent = `Annual Take-Home: ${formatCurrency(annualTakeHome)}/yr`;
      
      const mobileVal = document.getElementById("mobile-summary-value");
      if (mobileVal) mobileVal.textContent = formatCurrency(paycheckTakeHome);

      // Update gross slider value labels and other currency displays
      if (annualSalaryVal) {
        annualSalaryVal.textContent = formatCurrency(parseFloat(annualSalaryInput.value) || 0);
      }
      if (hourlyRateVal) {
        hourlyRateVal.textContent = `${currentCurrencySymbol}${parseFloat(hourlyRateInput.value || "0").toFixed(2)}/hr`;
      }
      if (hourlyEquivalentVal) {
        hourlyEquivalentVal.textContent = formatCurrency(annualGross) + "/yr";
      }

      // Update deduction prefix symbols
      const dedHealthSymbol = document.getElementById("ded-health-symbol");
      const dedHsaSymbol = document.getElementById("ded-hsa-symbol");
      if (dedHealthSymbol) dedHealthSymbol.textContent = currentCurrencySymbol;
      if (dedHsaSymbol) dedHsaSymbol.textContent = currentCurrencySymbol;

      // Update retirement select option text
      const optionDollar = ded401kUnitSelect?.querySelector('option[value="dollar"]');
      if (optionDollar) optionDollar.textContent = `${currentCurrencySymbol} Cash`;

      updateSummaryTable(lastCalculatedResults);

      renderDonutChart(
        annualTakeHome,
        annualFedTax,
        annualStateTax,
        annualLocalTax,
        annualSS + annualMedicare,
        totalDeds
      );
    }

