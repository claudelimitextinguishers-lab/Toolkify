    // Connect Input & Sliders
    function syncInputRange(inputId: string, rangeId: string, valueElId: string, formatFn: Function) {
      const input = document.getElementById(inputId) as HTMLInputElement;
      const range = document.getElementById(rangeId) as HTMLInputElement;
      const valEl = document.getElementById(valueElId);

      if (!input || !range) return;

      input.addEventListener("input", () => {
        let val = parseFloat(input.value) || 0;
        range.value = val.toString();
        if (valEl) valEl.textContent = formatFn(val);
        calculate();
      });

      range.addEventListener("input", () => {
        let val = parseFloat(range.value) || 0;
        input.value = val.toString();
        if (valEl) valEl.textContent = formatFn(val);
        calculate();
      });
    }

    // Toggle Deduction treatments
    function setupPrepostToggle(preBtnId: string, postBtnId: string, onToggle: Function) {
      const preBtn = document.getElementById(preBtnId);
      const postBtn = document.getElementById(postBtnId);
      if (!preBtn || !postBtn) return;

      preBtn.addEventListener("click", () => {
        preBtn.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas";
        postBtn.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate";
        onToggle(true);
      });

      postBtn.addEventListener("click", () => {
        postBtn.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas";
        preBtn.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate";
        onToggle(false);
      });
    }

    // Progressive calculation
    function calculateProgressiveTax(taxable: number, brackets: any[]) {
      let tax = 0;
      let prevLimit = 0;
      for (let i = 0; i < brackets.length; i++) {
        const b = brackets[i];
        const limit = b.limit;
        const rate = b.rate;
        if (taxable > prevLimit) {
          const portion = Math.min(taxable, limit) - prevLimit;
          tax += portion * rate;
          prevLimit = limit;
        } else {
          break;
        }
      }
      return tax;
    }

    // Dynamic currency format
    function formatCurrency(amount: number) {
      const locale = currentCurrencyCode === "INR" ? "en-IN" : undefined;
      return (
        currentCurrencySymbol +
        amount.toLocaleString(locale, {
          minimumFractionDigits: 0,
          maximumFractionDigits: 0,
        })
      );
    }

    // Custom Brackets Table Render
    function renderCustomBracketsTable() {
      if (!customBracketsTbody) return;
      let html = "";
      customBrackets.forEach((b, idx) => {
        const limitStr = b.limit === Infinity ? "" : b.limit;
        const rateStr = (b.rate * 100).toFixed(1);
        html += `
          <tr class="border-b border-hairline-soft">
            <td class="py-1 px-2">
              <input type="number" class="bracket-limit-input text-input !h-8 text-xs py-1 px-2 w-full" value="${limitStr}" placeholder="Max Limit" data-idx="${idx}" />
            </td>
            <td class="py-1 px-2 text-right">
              <div class="relative">
                <input type="number" class="bracket-rate-input text-input !h-8 text-xs py-1 pr-6 pl-2 text-right w-full" value="${rateStr}" step="0.1" data-idx="${idx}" />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
              </div>
            </td>
            <td class="py-1 px-2 text-center">
              <button type="button" class="btn-delete-bracket text-brand-red-dark hover:scale-110 transition-all font-semibold p-1 cursor-pointer text-xs" data-idx="${idx}">✕</button>
            </td>
          </tr>
        `;
      });
      customBracketsTbody.innerHTML = html;

      // Event handlers
      customBracketsTbody.querySelectorAll(".bracket-limit-input").forEach((inp) => {
        inp.addEventListener("change", (e) => {
          const target = e.currentTarget as HTMLInputElement;
          const idx = parseInt(target.dataset.idx || "0");
          const val = parseFloat(target.value);
          customBrackets[idx].limit = isNaN(val) ? Infinity : val;
        });
      });

      customBracketsTbody.querySelectorAll(".bracket-rate-input").forEach((inp) => {
        inp.addEventListener("change", (e) => {
          const target = e.currentTarget as HTMLInputElement;
          const idx = parseInt(target.dataset.idx || "0");
          const val = parseFloat(target.value);
          customBrackets[idx].rate = isNaN(val) ? 0.0 : val / 100;
        });
      });

      customBracketsTbody.querySelectorAll(".btn-delete-bracket").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const idx = parseInt(target.dataset.idx || "0");
          customBrackets.splice(idx, 1);
          renderCustomBracketsTable();
        });
      });
    }

    if (addBracketRowBtn) {
      addBracketRowBtn.addEventListener("click", () => {
        customBrackets.push({ limit: Infinity, rate: 0.10 });
        if (customBrackets.length > 1) {
