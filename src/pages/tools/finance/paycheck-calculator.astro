          is401kPretax: isDeductions401kPretax,
          valHealth: dedHealthInput.value,
          isHealthPretax: isDeductionsHealthPretax,
          valHsa: dedHsaInput.value,
          isHsaPretax: isDeductionsHsaPretax
        };

        scenarios.push({
          id,
          title,
          mode: salaryMode,
          colorIndex,
          metrics,
          inputs
        });

        savePinnedScenarios(scenarios);
      });
    }

    function loadScenario(inputs: any) {
      if (!inputs) return;

      currentCountry = inputs.countryCode || "US";
      if (countrySelect) countrySelect.value = currentCountry;
      customCountryName = inputs.customCountryName || "Custom";
      if (customCountryNameInput) customCountryNameInput.value = customCountryName === "Custom" ? "" : customCountryName;
      customTaxSettings = inputs.customTaxSettings || null;
      customBrackets = inputs.customBrackets || [];

      // Update dropdown states visibility
      if (currentCountry === "US") {
        if (stateSelectContainer) stateSelectContainer.classList.remove("hidden");
        if (stateOverrideContainer) stateOverrideContainer.classList.remove("hidden");
        if (localTaxContainer) localTaxContainer.classList.remove("hidden");
        if (customCountryNameContainer) customCountryNameContainer.classList.add("hidden");
      } else if (currentCountry === "Custom") {
        if (stateSelectContainer) stateSelectContainer.classList.add("hidden");
        if (stateOverrideContainer) stateOverrideContainer.classList.add("hidden");
        if (localTaxContainer) localTaxContainer.classList.add("hidden");
        if (customCountryNameContainer) customCountryNameContainer.classList.remove("hidden");
      } else {
        if (stateSelectContainer) stateSelectContainer.classList.remove("hidden");
        if (stateOverrideContainer) stateOverrideContainer.classList.add("hidden");
        if (localTaxContainer) localTaxContainer.classList.add("hidden");
        if (customCountryNameContainer) customCountryNameContainer.classList.add("hidden");
      }

      initializeStates();

      salaryMode = inputs.salaryMode;
      if (salaryMode === "annual") {
        modeAnnualBtn?.click();
      } else {
        modeHourlyBtn?.click();
      }

      annualSalaryInput.value = inputs.annualVal || "80000";
      annualSalaryRange.value = inputs.annualVal || "80000";
      if (annualSalaryVal) annualSalaryVal.textContent = formatCurrency(parseFloat(inputs.annualVal));

      hourlyRateInput.value = inputs.hourlyVal || "40";
      hourlyRateRange.value = inputs.hourlyVal || "40";
      if (hourlyRateVal) hourlyRateVal.textContent = `${currentCurrencySymbol}${parseFloat(inputs.hourlyVal).toFixed(2)}/hr`;

      hoursWeekInput.value = inputs.hoursVal || "40";
      hoursWeekRange.value = inputs.hoursVal || "40";
      if (hoursWeekVal) hoursWeekVal.textContent = `${inputs.hoursVal} hrs`;

      payFrequencySelect.value = inputs.freq || "biweekly";
      filingStatusSelect.value = inputs.status || "single";
      stateSelect.value = inputs.stateCode || "";

      if (stateOverrideCheckbox) {
        stateOverrideCheckbox.checked = !!inputs.override;
        stateOverrideRateInput.value = inputs.overrideRate || "5";
        toggleStateOverrideDisplay();
      }

      localTaxRateInput.value = inputs.localRate || "0";

      // Deductions
      ded401kInput.value = inputs.val401k || "6";
      ded401kUnitSelect.value = inputs.unit401k || "percent";
      isDeductions401kPretax = inputs.is401kPretax !== false;
      syncToggleBtnStyles("ded-401k-pretax-btn", "ded-401k-posttax-btn", isDeductions401kPretax);

      dedHealthInput.value = inputs.valHealth || "100";
      isDeductionsHealthPretax = inputs.isHealthPretax !== false;
      syncToggleBtnStyles("ded-health-pretax-btn", "ded-health-posttax-btn", isDeductionsHealthPretax);

      dedHsaInput.value = inputs.valHsa || "50";
      isDeductionsHsaPretax = inputs.isHsaPretax !== false;
      syncToggleBtnStyles("ded-hsa-pretax-btn", "ded-hsa-posttax-btn", isDeductionsHsaPretax);

      calculate();
    }

    function syncToggleBtnStyles(preId: string, postId: string, isPre: boolean) {
      const pre = document.getElementById(preId);
      const post = document.getElementById(postId);
      if (!pre || !post) return;
      if (isPre) {
        pre.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas";
        post.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate";
      } else {
        post.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas";
        pre.className = "flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate";
      }
    }

    function renderScenariosGrid() {
      if (!scenariosBoardGrid) return;
      const list = getPinnedScenarios();

      if (sandboxToggleTitle) {
        sandboxToggleTitle.textContent = `Saved Scenarios Board (${list.length})`;
      }

      if (list.length === 0) {
        if (scenariosEmptyState) scenariosEmptyState.classList.remove("hidden");
        scenariosBoardGrid.innerHTML = scenariosEmptyState?.outerHTML || "";
        return;
      }

      if (scenariosEmptyState) scenariosEmptyState.classList.add("hidden");

      let html = "";
      list.forEach((sc) => {
        const color = stickyPastelColors[sc.colorIndex] || stickyPastelColors[0];
        let metricsHtml = "";
        sc.metrics.forEach((m) => {
          metricsHtml += `
            <div>
              <span class="text-[9px] opacity-60 font-semibold block uppercase">${m.label}</span>
              <span class="font-display font-bold text-sm text-primary">${m.value}</span>
            </div>
          `;
        });

        html += `
          <div class="relative ${color.bg} rounded-xl p-5 shadow-subtle border ${color.border} flex flex-col justify-between gap-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-card animate-scale-in">
            <button
              type="button"
              class="btn-delete-scenario absolute top-3 right-3 text-primary/40 hover:text-brand-red-dark hover:scale-110 transition-all cursor-pointer text-xs font-semibold p-1"
              data-id="${sc.id}"
              title="Remove scenario"
            >
              ✕
            </button>
            <div class="flex flex-col gap-1 pr-6">
              <span class="text-[9px] uppercase font-bold tracking-wider opacity-60">Scenario Detail</span>
              <input
                type="text"
                class="font-display font-bold text-xs bg-transparent border-b border-transparent hover:border-primary/20 focus:border-brand-blue outline-none text-primary pb-0.5 truncate w-full"
                value="${sc.title}"
                data-id="${sc.id}"
              />
            </div>
            <div class="grid grid-cols-2 gap-3 text-xs border-t border-primary/5 pt-3">
              ${metricsHtml}
            </div>
            <button
              type="button"
              class="btn-load-scenario mt-1 w-full py-1.5 px-3 bg-primary/95 text-canvas text-xs font-semibold rounded-md shadow-subtle hover:bg-primary active:scale-95 transition-all text-center cursor-pointer"
              data-id="${sc.id}"
            >
              Load Scenario
            </button>
          </div>
        `;
      });

      scenariosBoardGrid.innerHTML = html;

      // Event triggers
      scenariosBoardGrid.querySelectorAll(".btn-load-scenario").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const id = parseInt(target.dataset.id || "0");
          const sc = getPinnedScenarios().find(s => s.id === id);
          if (sc) loadScenario(sc.inputs);
        });
      });

      scenariosBoardGrid.querySelectorAll(".btn-delete-scenario").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const id = parseInt(target.dataset.id || "0");
          const remaining = getPinnedScenarios().filter(s => s.id !== id);
          savePinnedScenarios(remaining);
        });
      });

      scenariosBoardGrid.querySelectorAll("input").forEach((inp) => {
        inp.addEventListener("change", (e) => {
          const target = e.currentTarget as HTMLInputElement;
          const id = parseInt(target.dataset.id || "0");
          const value = target.value;
          const currentList = getPinnedScenarios();
          const targetScenario = currentList.find(s => s.id === id);
          if (targetScenario) {
            targetScenario.title = value;
            savePinnedScenarios(currentList);
          }
        });
      });
    }

    function toggleStateOverrideDisplay() {
      if (stateOverrideCheckbox && stateOverrideCheckbox.checked) {
        stateOverrideRateContainer?.classList.remove("hidden");
        stateOverrideRateContainer?.classList.add("flex");
      } else {
        stateOverrideRateContainer?.classList.add("hidden");
        stateOverrideRateContainer?.classList.remove("flex");
      }
    }

    // Connect everything on load
    window.addEventListener("DOMContentLoaded", () => {
      initializeStates();

      // Sliders Sync
      syncInputRange("annual-salary-input", "annual-salary-range", "annual-salary-val", (v: number) => formatCurrency(v));
      syncInputRange("hourly-rate-input", "hourly-rate-range", "hourly-rate-val", (v: number) => `${currentCurrencySymbol}${v.toFixed(2)}/hr`);
      syncInputRange("hours-week-input", "hours-week-range", "hours-week-val", (v: number) => `${v} hrs`);

      // Selection changes
      payFrequencySelect?.addEventListener("change", calculate);
      filingStatusSelect?.addEventListener("change", calculate);
      stateSelect?.addEventListener("change", calculate);
      if (customCountryNameInput) {
        customCountryNameInput.addEventListener("input", () => {
          customCountryName = customCountryNameInput.value.trim() || "Custom Country";
          calculate();
        });
      }

      // State tax override checkboxes
      if (stateOverrideCheckbox) {
        stateOverrideCheckbox.addEventListener("change", () => {
          toggleStateOverrideDisplay();
          calculate();
        });
      }
      stateOverrideRateInput?.addEventListener("input", calculate);
      localTaxRateInput?.addEventListener("input", calculate);

      // Deduction triggers
      ded401kInput?.addEventListener("input", calculate);
      ded401kUnitSelect?.addEventListener("change", calculate);
      dedHealthInput?.addEventListener("input", calculate);
      dedHsaInput?.addEventListener("input", calculate);

      setupPrepostToggle("ded-401k-pretax-btn", "ded-401k-posttax-btn", (v: boolean) => {
        isDeductions401kPretax = v;
        calculate();
      });

      setupPrepostToggle("ded-health-pretax-btn", "ded-health-posttax-btn", (v: boolean) => {
        isDeductionsHealthPretax = v;
        calculate();
      });

      setupPrepostToggle("ded-hsa-pretax-btn", "ded-hsa-posttax-btn", (v: boolean) => {
        isDeductionsHsaPretax = v;
        calculate();
      });

      // Mobile scroll indicators
      const mobileStickyBar = document.getElementById("mobile-sticky-bar");
      const resultsColumn = document.getElementById("results-column");
      if (mobileStickyBar && resultsColumn) {
        window.addEventListener("scroll", () => {
          const rect = resultsColumn.getBoundingClientRect();
          if (rect.top <= window.innerHeight - 80) {
            mobileStickyBar.style.transform = "translateY(100%)";
          } else {
            mobileStickyBar.style.transform = "translateY(0)";
          }
        });
      }

      const mobileScrollBtn = document.getElementById("mobile-scroll-results-btn");
      if (mobileScrollBtn && resultsColumn) {
        mobileScrollBtn.addEventListener("click", () => {
          resultsColumn.scrollIntoView({ behavior: "smooth" });
        });
      }

      // Pinboard initialization
      renderScenariosGrid();

      // Default calculation
      calculate();
    });
  </script>
</Layout>
