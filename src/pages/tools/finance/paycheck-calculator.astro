---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Paycheck & Take-Home Salary Calculator";
const category = "finance";
const tier = "Finance & Tax";
const description =
  "Estimate your net take-home salary after national, regional, and local income taxes, social security contributions, and pre-tax or post-tax deductions across multiple countries.";
---

<Layout
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Paycheck & Take-Home Salary Calculator",
      "url": "https://boardtools.app/tools/finance/paycheck-calculator",
      "description": "Calculate paycheck earnings, national/federal taxes, regional/state/province taxes, and social security deductions with pre-tax & post-tax benefits toggles and responsive SVG donut charts across multiple countries.",
      "applicationCategory": "FinancialApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section
    class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-8 flex flex-col gap-6 animate-fade-in-up pb-24 lg:pb-12"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-2">
      <nav
        class="flex items-center gap-2 text-xs font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3 mt-1">
        <h1
          class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-primary"
        >
          {name}
        </h1>
        <span
          class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-xs py-1 px-3 self-center rounded-full font-semibold uppercase"
          >{tier}</span
        >

        <button
          type="button"
          id="how-it-works-btn"
          class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle self-center animate-pulse"
          aria-label="How paycheck calculator works"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path></svg
          >
          <span>How it works</span>
        </button>
      </div>
      <p class="text-sm text-slate max-w-xl">
        {description}
      </p>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      <!-- Left Column: Dynamic Forms (5 cols) -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="card-base flex flex-col gap-5">
          <h2
            class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2"
          >
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Salary & Filing Status
          </h2>

          <!-- Salary Mode Tabs (Miro Pill Style) -->
          <div class="flex rounded-full bg-surface p-1 border border-hairline w-full">
            <button
              type="button"
              id="mode-annual-btn"
              class="flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas"
            >
              Annual Salary
            </button>
            <button
              type="button"
              id="mode-hourly-btn"
              class="flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer text-slate hover:text-primary"
            >
              Hourly Wage
            </button>
          </div>

          <!-- Annual Input Block -->
          <div id="annual-wage-container" class="flex flex-col gap-1.5">
            <label
              for="annual-salary-input"
              class="text-xs font-semibold text-charcoal flex justify-between"
            >
              <span>Gross Annual Salary</span>
              <span id="annual-salary-val" class="font-mono text-stone font-normal"
                >$80,000</span
              >
            </label>
            <input
              type="number"
              id="annual-salary-input"
              value="80000"
              min="5000"
              max="1000000"
              step="1000"
              class="text-input"
              inputmode="numeric"
              autocomplete="off"
            />
            <input
              type="range"
              id="annual-salary-range"
              min="10000"
              max="300000"
              value="80000"
              step="1000"
              class="hidden sm:block w-full cursor-pointer accent-brand-blue py-2"
              aria-label="Annual Salary Slider"
            />
          </div>

          <!-- Hourly Input Block (Hidden by default) -->
          <div id="hourly-wage-container" class="flex flex-col gap-3 hidden">
            <div class="flex flex-col gap-1.5">
              <label
                for="hourly-rate-input"
                class="text-xs font-semibold text-charcoal flex justify-between"
              >
                <span>Hourly Rate</span>
                <span id="hourly-rate-val" class="font-mono text-stone font-normal"
                  >$40.00/hr</span
                >
              </label>
              <input
                type="number"
                id="hourly-rate-input"
                value="40"
                min="5"
                max="500"
                step="0.5"
                class="text-input"
                inputmode="decimal"
                autocomplete="off"
              />
              <input
                type="range"
                id="hourly-rate-range"
                min="10"
                max="150"
                value="40"
                step="0.5"
                class="hidden sm:block w-full cursor-pointer accent-brand-blue py-2"
                aria-label="Hourly Rate Slider"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="hours-week-input"
                class="text-xs font-semibold text-charcoal flex justify-between"
              >
                <span>Hours Per Week</span>
                <span id="hours-week-val" class="font-mono text-stone font-normal"
                  >40 hrs</span
                >
              </label>
              <input
                type="number"
                id="hours-week-input"
                value="40"
                min="1"
                max="100"
                step="1"
                class="text-input"
                inputmode="numeric"
                autocomplete="off"
              />
              <input
                type="range"
                id="hours-week-range"
                min="10"
                max="80"
                value="40"
                step="1"
                class="hidden sm:block w-full cursor-pointer accent-brand-blue py-2"
                aria-label="Hours per Week Slider"
              />
            </div>

            <div
              id="hourly-conversion-label"
              class="text-xs text-brand-blue bg-surface-pricing-featured px-3 py-2 rounded-lg font-semibold flex justify-between items-center"
            >
              <span>Equivalent Annual Pay:</span>
              <span id="hourly-equivalent-val" class="font-mono">$83,200/yr</span>
            </div>
          </div>

          <!-- Other core inputs -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="pay-frequency" class="text-xs font-semibold text-charcoal"
                >Pay Frequency</label
              >
              <select id="pay-frequency" class="text-input" aria-label="Pay Frequency">
                <option value="weekly">Weekly (52/yr)</option>
                <option value="biweekly" selected>Bi-weekly (26/yr)</option>
                <option value="semimonthly">Semi-monthly (24/yr)</option>
                <option value="monthly">Monthly (12/yr)</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="filing-status" class="text-xs font-semibold text-charcoal"
                >Filing Status</label
              >
              <select id="filing-status" class="text-input" aria-label="Filing Status">
                <option value="single" selected>Single</option>
                <option value="joint">Married Filing Jointly</option>
                <option value="hoh">Head of Household</option>
              </select>
            </div>
          </div>

          <!-- Country Selection -->
          <div class="flex flex-col gap-1.5 pt-2 border-t border-hairline-soft">
            <label for="country-select" class="text-xs font-semibold text-charcoal"
              >Country</label
            >
            <select id="country-select" class="text-input" aria-label="Country Select">
              <option value="US" selected>United States (USD)</option>
              <option value="CA">Canada (CAD)</option>
              <option value="GB">United Kingdom (GBP)</option>
              <option value="AU">Australia (AUD)</option>
              <option value="DE">Germany (EUR)</option>
              <option value="IN">India (INR)</option>
              <option value="Custom">Custom / Other</option>
            </select>
          </div>

          <!-- Custom Country Input -->
          <div id="custom-country-name-container" class="flex flex-col gap-1.5 pt-2 border-t border-hairline-soft hidden animate-fade-in-up">
            <label for="custom-country-name" class="text-xs font-semibold text-charcoal"
              >Custom Country Name</label
            >
            <input
              type="text"
              id="custom-country-name"
              placeholder="e.g. France, Japan"
              class="text-input"
              autocomplete="off"
            />
          </div>

          <!-- State Selection -->
          <div id="state-select-container" class="flex flex-col gap-1.5 pt-2 border-t border-hairline-soft">
            <label for="state-select" id="state-select-label" class="text-xs font-semibold text-charcoal"
              >State Tax Residency</label
            >
            <select id="state-select" class="text-input" aria-label="State Select">
              <!-- JS will populate dynamically -->
            </select>
          </div>

          <!-- Custom State Override -->
          <div id="state-override-container" class="flex flex-col gap-2 bg-surface p-3 rounded-xl border border-hairline-soft">
            <label class="flex items-center gap-2 text-xs font-semibold text-charcoal cursor-pointer">
              <input type="checkbox" id="state-override-checkbox" class="accent-brand-blue cursor-pointer" />
              <span id="state-override-checkbox-label">Override with custom flat state rate</span>
            </label>
            <div id="state-override-rate-container" class="hidden items-center gap-2">
              <div class="relative flex-grow">
                <input
                  type="number"
                  id="state-override-rate"
                  value="5"
                  min="0"
                  max="20"
                  step="0.1"
                  class="text-input pr-7"
                  inputmode="decimal"
                  placeholder="Custom rate %"
                />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-stone text-sm">%</span>
              </div>
            </div>
          </div>

          <!-- Local Tax input -->
          <div id="local-tax-container" class="flex flex-col gap-1.5">
            <label
              for="local-tax-rate"
              id="local-tax-label"
              class="text-xs font-semibold text-charcoal flex justify-between"
            >
              <span>Local / City Income Tax Rate</span>
              <span class="text-stone font-normal">flat %</span>
            </label>
            <div class="relative">
              <input
                type="number"
                id="local-tax-rate"
                value="0"
                min="0"
                max="10"
                step="0.05"
                class="text-input pr-7"
                inputmode="decimal"
                placeholder="e.g. 1.5"
              />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-stone text-sm">%</span>
            </div>
          </div>

          <!-- Customize Tax Details Button -->
          <div class="flex justify-end pt-2 border-t border-hairline-soft">
            <button
              type="button"
              id="toggle-custom-tax-btn"
              class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-2 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>Customize Tax Details</span>
            </button>
          </div>


          <!-- Accordion Pre/Post Tax Deductions (Collapsible) -->
          <div class="border-t border-hairline pt-3">
            <button
              type="button"
              id="accordion-deductions-btn"
              class="w-full text-left font-display font-semibold text-sm text-primary flex items-center justify-between cursor-pointer"
            >
              <span class="flex items-center gap-1.5"
                ><span class="w-2.5 h-2.5 rounded-full bg-brand-teal"></span>Deductions & Benefits (Optional)</span
              >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                id="accordion-arrow"
                class="w-4 h-4 text-stone transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path></svg
              >
            </button>
            <div
              id="accordion-deductions-content"
              class="hidden flex flex-col gap-4 mt-4 border-t border-hairline-soft pt-4"
            >
              <!-- 401(k) -->
              <div class="flex flex-col gap-2">
                <label for="ded-401k" class="text-xs font-semibold text-charcoal flex justify-between">
                  <span id="ded-401k-label">401(k) Retirement Account</span>
                  <span id="ded-401k-calc-val" class="font-mono text-stone font-normal">6.0%</span>
                </label>
                <div class="grid grid-cols-12 gap-2">
                  <div class="col-span-8 relative">
                    <input
                      type="number"
                      id="ded-401k"
                      value="6"
                      min="0"
                      class="text-input pr-8"
                      inputmode="decimal"
                    />
                    <span id="ded-401k-unit-indicator" class="absolute right-3 top-1/2 -translate-y-1/2 text-stone text-sm">%</span>
                  </div>
                  <div class="col-span-4">
                    <select id="ded-401k-unit" class="text-input py-1 text-xs" aria-label="401k Unit">
                      <option value="percent">% of Pay</option>
                      <option value="dollar">$ Cash</option>
                    </select>
                  </div>
                </div>
                <!-- Pre/Post toggler widget -->
                <div class="flex items-center justify-between text-xs mt-1">
                  <span class="text-slate font-medium">Tax treatment:</span>
                  <div class="flex rounded-full bg-surface p-0.5 border border-hairline w-36">
                    <button
                      type="button"
                      id="ded-401k-pretax-btn"
                      class="flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas"
                    >
                      Pre-Tax
                    </button>
                    <button
                      type="button"
                      id="ded-401k-posttax-btn"
                      class="flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate"
                    >
                      Post-Tax
                    </button>
                  </div>
                </div>
              </div>

              <!-- Health Insurance -->
              <div class="flex flex-col gap-2 pt-3 border-t border-hairline-soft">
                <label for="ded-health" class="text-xs font-semibold text-charcoal">
                  <span id="ded-health-label">Health Insurance Premium</span> <span class="text-stone font-normal">(per paycheck)</span>
                </label>
                <div class="relative">
                  <span id="ded-health-symbol" class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm">$</span>
                  <input
                    type="number"
                    id="ded-health"
                    value="100"
                    min="0"
                    class="text-input pl-7"
                    inputmode="numeric"
                  />
                </div>
                <div class="flex items-center justify-between text-xs mt-1">
                  <span class="text-slate font-medium">Tax treatment:</span>
                  <div class="flex rounded-full bg-surface p-0.5 border border-hairline w-36">
                    <button
                      type="button"
                      id="ded-health-pretax-btn"
                      class="flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas"
                    >
                      Pre-Tax
                    </button>
                    <button
                      type="button"
                      id="ded-health-posttax-btn"
                      class="flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate"
                    >
                      Post-Tax
                    </button>
                  </div>
                </div>
              </div>

              <!-- HSA -->
              <div class="flex flex-col gap-2 pt-3 border-t border-hairline-soft">
                <label for="ded-hsa" class="text-xs font-semibold text-charcoal">
                  <span id="ded-hsa-label">HSA Premium contribution</span> <span class="text-stone font-normal">(per paycheck)</span>
                </label>
                <div class="relative">
                  <span id="ded-hsa-symbol" class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm">$</span>
                  <input
                    type="number"
                    id="ded-hsa"
                    value="50"
                    min="0"
                    class="text-input pl-7"
                    inputmode="numeric"
                  />
                </div>
                <div class="flex items-center justify-between text-xs mt-1">
                  <span class="text-slate font-medium">Tax treatment:</span>
                  <div class="flex rounded-full bg-surface p-0.5 border border-hairline w-36">
                    <button
                      type="button"
                      id="ded-hsa-pretax-btn"
                      class="flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas"
                    >
                      Pre-Tax
                    </button>
                    <button
                      type="button"
                      id="ded-hsa-posttax-btn"
                      class="flex-1 text-center text-[10px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate"
                    >
                      Post-Tax
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Collapsible Custom Tax Panel -->
        <div id="custom-tax-card" class="card-base flex flex-col gap-4 hidden border border-brand-teal/20 bg-surface/50">
          <h3 class="font-display font-semibold text-base text-primary flex items-center justify-between pb-2 border-b border-hairline">
            <span class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-teal"></span>
              Custom Tax Settings
            </span>
            <button type="button" id="close-custom-tax-btn" class="text-stone hover:text-primary transition-all text-xs font-bold cursor-pointer">✕</button>
          </h3>

          <!-- Currency & Code -->
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-symbol" class="text-[10px] font-semibold text-slate">Currency Symbol</label>
              <input type="text" id="custom-currency-symbol" value="$" class="text-input" placeholder="e.g. $, £, €, ₹" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-code" class="text-[10px] font-semibold text-slate">Currency Code</label>
              <input type="text" id="custom-currency-code" value="USD" class="text-input" placeholder="e.g. USD, GBP, EUR" />
            </div>
          </div>

          <!-- Tax-free Allowance / Std Deduction -->
          <div class="flex flex-col gap-1.5">
            <label for="custom-std-deduction" class="text-[10px] font-semibold text-slate">Standard Allowance / Deduction</label>
            <input type="number" id="custom-std-deduction" value="14600" min="0" class="text-input" />
          </div>

          <!-- National Brackets Table -->
          <div class="flex flex-col gap-1.5">
            <span class="text-[10px] font-semibold text-slate">National Income Tax Brackets</span>
            <div class="overflow-x-auto border border-hairline rounded-lg">
              <table class="w-full text-xs text-left border-collapse">
                <thead>
                  <tr class="bg-surface text-stone border-b border-hairline font-bold">
                    <th class="py-1.5 px-2">Income Limit</th>
                    <th class="py-1.5 px-2 text-right">Rate %</th>
                    <th class="py-1.5 px-2 text-center">Action</th>
                  </tr>
                </thead>
                <tbody id="custom-brackets-tbody">
                  <!-- JS will dynamically add rows here -->
                </tbody>
              </table>
            </div>
            <button type="button" id="add-bracket-row-btn" class="inline-flex items-center justify-center gap-1 py-1.5 px-3 bg-surface hover:bg-hairline text-xs font-semibold text-slate hover:text-primary rounded-lg border border-hairline-soft transition-all cursor-pointer">
              + Add Bracket
            </button>
          </div>

          <!-- Social Security and Medicare caps/rates -->
          <div class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft">
            <div class="flex flex-col gap-1.5">
              <label for="custom-ss-rate" class="text-[10px] font-semibold text-slate">Social Security Rate (%)</label>
              <input type="number" id="custom-ss-rate" value="6.2" min="0" max="50" step="0.01" class="text-input" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-ss-cap" class="text-[10px] font-semibold text-slate">Max Taxable Wage Cap</label>
              <input type="number" id="custom-ss-cap" value="168600" min="0" class="text-input" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label for="custom-med-rate" class="text-[10px] font-semibold text-slate">Medicare / Health Rate (%)</label>
              <input type="number" id="custom-med-rate" value="1.45" min="0" max="50" step="0.01" class="text-input" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-med-threshold" class="text-[10px] font-semibold text-slate">Surtax Threshold</label>
              <input type="number" id="custom-med-threshold" value="200000" min="0" class="text-input" />
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label for="custom-med-surtax" class="text-[10px] font-semibold text-slate">Additional Surtax (%)</label>
              <input type="number" id="custom-med-surtax" value="0.9" min="0" max="10" step="0.01" class="text-input" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-state-flat" class="text-[10px] font-semibold text-slate">State / Regional Flat Rate (%)</label>
