    // Pinned scenarios board structures
    interface PinboardScenario {
      id: number;
      title: string;
      mode: string;
      colorIndex: number;
      metrics: { label: string; value: string }[];
      inputs: any;
    }

    const stickyPastelColors = [
      { bg: "bg-teal-light dark:bg-teal-light", border: "border-brand-teal/20" },
      { bg: "bg-rose-light dark:bg-rose-light", border: "border-brand-rose/20" },
      { bg: "bg-coral-light dark:bg-coral-light", border: "border-brand-coral/20" },
      { bg: "bg-surface-yellow dark:bg-surface-yellow", border: "border-brand-yellow/20" }
    ];

    function getPinnedScenarios(): PinboardScenario[] {
      const data = localStorage.getItem("boardtools_paycheck_scenarios");
      return data ? JSON.parse(data) : [];
    }

    function savePinnedScenarios(list: PinboardScenario[]) {
      localStorage.setItem("boardtools_paycheck_scenarios", JSON.stringify(list));
      renderScenariosGrid();
    }

