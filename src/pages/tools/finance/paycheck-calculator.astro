      }

      const rows = [
        { name: "Gross Pay", pay: res.paycheckGross, ann: res.annualGross, style: "font-semibold text-primary" },
        { name: retirementLabel, pay: -res.paycheck401k, ann: -res.annual401k, style: "text-slate", isDed: true, isPre: isDeductions401kPretax },
        { name: healthLabel, pay: -res.paycheckHealth, ann: -res.annualHealth, style: "text-slate", isDed: true, isPre: isDeductionsHealthPretax },
        { name: hsaLabel, pay: -res.paycheckHSA, ann: -res.annualHSA, style: "text-slate", isDed: true, isPre: isDeductionsHsaPretax },
        { name: ssLabel, pay: -res.paycheckSS, ann: -res.annualSS, style: "text-slate" },
        { name: medLabel, pay: -res.paycheckMedicare, ann: -res.annualMedicare, style: "text-slate" },
        { name: fedLabel, pay: -res.paycheckFedTax, ann: -res.annualFedTax, style: "text-slate" },
        { name: stateLabel, pay: -res.paycheckStateTax, ann: -res.annualStateTax, style: "text-slate" },
        { name: "Local / City Tax", pay: -res.paycheckLocalTax, ann: -res.annualLocalTax, style: "text-slate" },
        { name: "Estimated Take-Home Pay", pay: res.paycheckTakeHome, ann: res.annualTakeHome, style: "font-bold text-success-accent bg-success-accent/5" }
      ];

      let html = "";
      rows.forEach((r) => {
        if (!r.name) return; // skip row if label is empty
        
        if (Math.abs(r.pay) === 0 && (r.isDed || r.name.includes("Local") || r.name.includes("Cess") || r.name.includes("residency"))) {
          return;
