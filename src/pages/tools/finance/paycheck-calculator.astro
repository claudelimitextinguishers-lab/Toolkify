      pinScenarioBtn.addEventListener("click", () => {
        if (!lastCalculatedResults) return;
        const res = lastCalculatedResults;
        const scenarios = getPinnedScenarios();
        const id = Date.now();
        const colorIndex = scenarios.length % stickyPastelColors.length;

        const grossFormatted = formatCurrency(res.annualGross);
        const takehomeFormatted = formatCurrency(res.paycheckTakeHome);

        const countryLabel = currentCountry === "Custom" ? customCountryName : currentCountry;
        let title = `${countryLabel} - ${stateSelect.value || ""}: ${grossFormatted}`;
        if (salaryMode === "hourly") {
          title = `${countryLabel} - ${stateSelect.value || ""}: $${hourlyRateInput.value}/hr`;
        }

        const metrics = [
          { label: "Net Pay / paycheck", value: takehomeFormatted },
          { label: "Gross Salary (Annual)", value: grossFormatted },
          { label: "Filing Status", value: filingStatusSelect.value.toUpperCase() },
          { label: "State/Region Tax", value: formatCurrency(res.paycheckStateTax) }
        ];

        const inputs = {
          countryCode: currentCountry,
          customCountryName,
          customTaxSettings,
          customBrackets,
          salaryMode,
          annualVal: annualSalaryInput.value,
          hourlyVal: hourlyRateInput.value,
          hoursVal: hoursWeekInput.value,
          freq: payFrequencySelect.value,
          status: filingStatusSelect.value,
          stateCode: stateSelect.value,
          override: stateOverrideCheckbox ? stateOverrideCheckbox.checked : false,
          overrideRate: stateOverrideRateInput ? stateOverrideRateInput.value : "5",
          localRate: localTaxRateInput.value,
          val401k: ded401kInput.value,
