            <td class="py-1 sm:py-2.5 px-0 sm:px-3 text-right font-mono whitespace-nowrap sm:table-cell flex justify-between items-center mt-0.5 sm:mt-0">
              <span class="sm:hidden text-[9px] text-stone uppercase font-bold font-sans">Annual Summary</span>
              <span>${fmtAnn}</span>
            </td>
          </tr>
        `;
      });

      breakdownTableBody.innerHTML = html;
    }

    // Donut chart renderer
    function renderDonutChart(takeHome: number, fedTax: number, stateTax: number, localTax: number, fica: number, deductions: number) {
      const total = takeHome + fedTax + stateTax + localTax + fica + deductions;
      if (total === 0 || !donutSegments) return;

      const pctTakehome = (takeHome / total) * 100;
      if (donutPercent) {
        donutPercent.textContent = `${pctTakehome.toFixed(0)}%`;
      }

      const periods = lastCalculatedResults ? lastCalculatedResults.payPeriods : 26;
      if (legendTakehome) legendTakehome.textContent = `${formatCurrency(takeHome/periods)} (${pctTakehome.toFixed(1)}%)`;
      if (legendFedtax) legendFedtax.textContent = `${formatCurrency(fedTax/periods)} (${((fedTax/total)*100).toFixed(1)}%)`;
      if (legendStatetax) legendStatetax.textContent = `${formatCurrency(stateTax/periods)} (${((stateTax/total)*100).toFixed(1)}%)`;
      if (legendLocaltax) legendLocaltax.textContent = `${formatCurrency(localTax/periods)} (${((localTax/total)*100).toFixed(1)}%)`;
      if (legendFica) legendFica.textContent = `${formatCurrency(fica/periods)} (${((fica/total)*100).toFixed(1)}%)`;
      if (legendDeductions) legendDeductions.textContent = `${formatCurrency(deductions/periods)} (${((deductions/total)*100).toFixed(1)}%)`;

      const list = [
        { color: "var(--color-success-accent)", val: takeHome },
        { color: "var(--color-brand-coral)", val: fedTax },
        { color: "var(--color-brand-yellow-deep)", val: stateTax },
        { color: "var(--color-brand-rose)", val: localTax },
        { color: "var(--color-brand-teal)", val: fica },
        { color: "var(--color-muted)", val: deductions },
      ].filter((s) => s.val > 0);

      const r = 40;
      const c = 2 * Math.PI * r;
      let offset = 0;
      let html = "";

      list.forEach((seg) => {
        const length = (seg.val / total) * c;
        html += `<circle cx="50" cy="50" r="${r}" stroke="${seg.color}" stroke-width="12" stroke-dasharray="${length} ${c}" stroke-dashoffset="${-offset}" fill="transparent" />`;
        offset += length;
      });

      donutSegments.innerHTML = html;
    }

