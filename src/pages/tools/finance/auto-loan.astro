---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Auto Loan Calculator";
const category = "finance";
const tier = "Finance & Tax";

// On-page SEO metadata
const pageTitle =
  "Auto Loan Calculator - Free Car Payment & Refinance Calculator";
const description =
  "Free auto loan calculator to estimate your monthly car payment with trade-in, down payment, sales tax and fees. Compare 60 & 84 month terms, extra payments and refinancing.";
const canonicalUrl = "https://toolkify.app/tools/finance/auto-loan";
const ogImage = "/og/auto-loan-calculator.png";
const keywords =
  "auto loan calculator, bankrate auto loan calculator, refinance auto loan calculator, car auto loan calculator, auto loan calculator texas, auto loan calculator payment, auto loan calculator with extra payments, simple auto loan calculator, 84 month auto loan calculator, auto loan calculator google, online auto loan calculator, auto loan calculator refinance";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Auto Loan Calculator",
      "alternateName": "Car Loan Payment & Refinance Calculator",
      "url": "https://toolkify.app/tools/finance/auto-loan",
      "description": "Free auto loan calculator with trade-in, down payment, sales tax, fees, balloon payments, extra payments and refinancing for new and used cars in USD and INR.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Monthly car payment calculator with sales tax and fees",
        "Trade-in value and down payment support",
        "Auto loan calculator with extra payments",
        "60, 72 and 84 month auto loan terms",
        "Refinance auto loan calculator comparison",
        "Total interest and full amortization breakdown"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "1485"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Finance & Tax Tools",
          "item": "https://toolkify.app/#finance"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Auto Loan Calculator",
          "item": "https://toolkify.app/tools/finance/auto-loan"
        }
      ]
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an auto loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>An auto loan is a secured loan used to purchase a vehicle. The lender provides the funds to buy the car, and you agree to pay back the principal plus interest over a set term (typically 24 to 84 months). The vehicle serves as collateral, meaning the lender can repossess it if you default on the payments.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to get an auto loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To get an auto loan, check your credit score first to understand the interest rates you qualify for. Gather necessary financial documents (proof of income, identity, and residence), determine your budget, shop around with multiple lenders (banks, credit unions, online lenders) to get pre-approved, choose the best offer, and complete the application.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to get a car loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Getting a car loan involves checking your credit profile, establishing a budget and down payment amount, getting pre-approved by bank or credit union lenders, choosing a vehicle that meets the lender's guidelines, and finalizing the loan terms at the dealership or with your chosen financial institution.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to get a car loan with bad credit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To get a car loan with bad credit, you should save for a larger down payment, consider finding a creditworthy co-signer, check with credit unions (which offer more flexible underwriting), check subprime car loan specialists, and verify your credit report to correct any errors before applying.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Where to get an auto loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>You can get an auto loan from local credit unions, traditional banks, online auto lenders, or directly through dealership finance departments. Credit unions and online lenders often offer the most competitive interest rates.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a good auto loan rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A good auto loan rate depends on your credit score and current market conditions. For individuals with excellent credit (720+), a good rate is typically near the prime rate. Rates generally increase for used vehicles and for borrowers with lower credit scores.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How often are you required to make payments on an auto loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Auto loans typically require payments once a month. However, some lenders allow bi-weekly payment options, which can align better with bi-weekly pay cycles and slightly accelerate your payoff timeline.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Is auto loan interest tax deductible?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>No, auto loan interest for personal-use vehicles is not tax-deductible. It is only tax-deductible if the vehicle is used for business purposes, in which case you can deduct the portion of interest corresponding to business usage.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Car loan interest deduction?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The car loan interest deduction is limited strictly to business vehicles or business-related vehicle expenses. If you are self-employed or run a business and use your car for work, you may deduct a portion of the interest paid on the loan.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Should i pay off my car loan early?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Paying off a car loan early is usually a good idea if the interest rate is high or if you want to free up monthly cash flow. However, if your loan rate is very low (e.g., 0% to 2.9%) and you can earn a higher return by investing your money elsewhere, it may make sense to pay the standard schedule.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "If i pay extra on my car loan does it go to principal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, extra payments typically go toward the principal balance, but you should specify to your lender that you want the additional funds applied directly to the principal rather than prepaying the next month's payment.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to pay off car loan faster?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To pay off your car loan faster, make bi-weekly payments, round up your monthly payment amount, apply extra cash like bonuses or tax refunds directly to the principal, or refinance to a shorter loan term with a lower interest rate.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Can you refinance a car loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, you can refinance a car loan. Refinancing replaces your current loan with a new one under different terms, which can lower your interest rate, change your monthly payment, or adjust the term length.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to refinance auto loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To refinance an auto loan, check your current loan balance, rate, and remaining term. Review your credit score, shop around for competitive rates, submit applications to lenders for pre-approval, accept an offer, and use the new loan to pay off the old debt.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to refinance a car loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Refinancing a car loan involves shopping around for lenders who offer better rates than your current lender, applying for a refinance loan, and completing the paperwork to have the new lender pay off the balance of your original loan.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Should i refinance my auto loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>You should refinance your auto loan if interest rates have dropped since your initial purchase, your credit score has improved, you need to lower your monthly payments by extending the term, or you want to shorten the term to pay off the car sooner.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to sell a car with a loan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To sell a car with a loan, find out the payoff amount from your lender. If selling to a dealer, they will handle paying off the loan directly. If selling to a private party, you can complete the transaction at your lender's branch, where the buyer pays the bank directly, and the bank releases the title.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-3 flex flex-col gap-4 animate-fade-in-up pb-24 lg:pb-12">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav class="flex items-center gap-1.5 text-xs font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-2xl sm:text-3xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2.5 rounded-full font-semibold uppercase shrink-0">{tier}</span>
        </div>
        
        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How auto loan calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mode / New vs Used Toggle (Miro Pill Style) -->
    <div class="flex items-center justify-between border-b border-hairline pb-2">
      <div class="flex rounded-full bg-surface p-1 border border-hairline">
        <button
          type="button"
          id="cond-new-btn"
          class="text-xs px-4 py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas"
        >
          🚗 New Car
        </button>
        <button
          type="button"
          id="cond-used-btn"
          class="text-xs px-4 py-1.5 rounded-full font-semibold transition-all cursor-pointer text-slate"
        >
          🚙 Used Car
        </button>
      </div>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left: Interactive Form (7 Columns) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="card-base flex flex-col gap-5">
          <h2 class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Purchase Details
          </h2>

          <!-- Row 1: Vehicle Price & Trade-in Value -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center justify-between">
                <label for="vehicle-price" class="text-xs font-semibold text-charcoal">
                  Vehicle Price
                </label>
                <!-- Currency Select -->
                <select
                  id="currency-select"
                  class="text-[10px] font-semibold py-1 px-2.5 rounded-full border border-hairline bg-surface hover:bg-canvas cursor-pointer transition-all outline-none"
                  aria-label="Currency Select"
                >
                  <option value="USD" selected>$ USD</option>
                  <option value="CAD">$ CAD</option>
                  <option value="GBP">£ GBP</option>
                  <option value="AUD">$ AUD</option>
                  <option value="EUR">€ EUR</option>
                  <option value="INR">₹ INR</option>
                  <option value="Custom">Custom / Other</option>
                </select>
              </div>
              <div class="relative">
                <span id="currency-prefix" class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol">$</span>
                <input
                  type="number"
                  id="vehicle-price"
                  value="35000"
                  min="500"
                  max="10000000"
                  step="500"
                  class="text-input pl-7 font-mono text-sm"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="trade-in" class="text-xs font-semibold text-charcoal flex justify-between">
                <span>Trade-in Value</span>
                <span class="currency-label text-stone font-normal">USD ($)</span>
              </label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol">$</span>
                <input
                  type="number"
                  id="trade-in"
                  value="5000"
                  min="0"
                  max="1000000"
                  step="100"
                  class="text-input pl-7 font-mono text-sm"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
            </div>
          </div>

          <!-- Custom Currency Inputs (Hidden by default) -->
          <div id="custom-currency-container" class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft hidden animate-fade-in-up">
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-symbol" class="text-[10px] font-semibold text-slate">Currency Symbol</label>
              <input type="text" id="custom-currency-symbol" value="$" class="text-input" placeholder="e.g. $, £, €, ₹" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-code" class="text-[10px] font-semibold text-slate">Currency Code</label>
              <input type="text" id="custom-currency-code" value="USD" class="text-input" placeholder="e.g. USD, GBP, EUR" />
            </div>
          </div>

          <!-- Row 2: Down Payment with $ / % Toggle -->
          <div class="flex flex-col gap-1.5">
            <div class="flex items-center justify-between text-xs font-semibold text-charcoal">
              <span>Down Payment</span>
              <div class="flex rounded-full bg-surface p-0.5 border border-hairline">
                <button
                  type="button"
                  id="down-payment-toggle-dollar"
                  class="text-[10px] px-3 py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
                >
                  $
                </button>
                <button
                  type="button"
                  id="down-payment-toggle-percent"
                  class="text-[10px] px-3 py-1 rounded-full font-bold transition-all cursor-pointer text-slate"
                >
                  %
                </button>
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Dollar input -->
              <div class="relative" id="down-payment-dollar-wrapper">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium currency-symbol">$</span>
                <input
                  type="number"
                  id="down-payment-dollar"
                  value="7000"
                  min="0"
                  class="text-input pl-7 font-mono text-sm"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
              <!-- Percentage input -->
              <div class="relative" id="down-payment-percent-wrapper">
                <input
                  type="number"
                  id="down-payment-percent"
                  value="20"
                  min="0"
                  max="100"
                  step="0.1"
                  class="text-input pr-7 font-mono text-sm"
                  inputmode="decimal"
                  autocomplete="off"
                />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-stone text-sm font-medium">%</span>
              </div>
              
              <!-- Extra info element (Calculated amount/percentage dynamically) -->
              <div class="flex items-center text-xs text-stone font-mono sm:col-span-2" id="down-payment-feedback">
                Down Payment: $7,000 (20.0% of vehicle price)
              </div>
            </div>
          </div>

          <!-- Row 3: Loan Term presets & slider -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Loan Term</span>
              <span id="loan-term-val" class="font-mono text-stone font-bold">60 months (5 years)</span>
            </label>
            <div class="grid grid-cols-6 gap-1">
              {
                [24, 36, 48, 60, 72, 84].map((months) => (
                  <button
                    type="button"
                    class="preset-term-btn text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer border border-hairline text-slate bg-canvas hover:border-hairline-strong active:scale-95 flex items-center justify-center"
                    data-term={months}
                  >
                    {months}m
                  </button>
                ))
              }
            </div>
            <div class="flex items-center gap-3 mt-1.5">
              <input
                type="range"
                id="loan-term-range"
                min="12"
                max="96"
                value="60"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Loan Term Custom Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="loan-term-input"
                  min="12"
                  max="96"
                  value="60"
                  class="text-input pr-8 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">mo</span>
              </div>
            </div>
          </div>

          <!-- Row 4: Annual Interest Rate with Slider -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Annual Interest Rate</span>
              <span id="interest-rate-val" class="font-mono text-stone font-bold">5.50%</span>
            </label>
            <div class="flex items-center gap-3">
              <input
                type="range"
                id="interest-rate-range"
                min="0.1"
                max="25"
                value="5.5"
                step="0.05"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Interest Rate Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="interest-rate-input"
                  min="0.1"
                  max="25"
                  value="5.5"
                  step="0.01"
                  class="text-input pr-5 py-1 text-xs text-center font-mono h-8"
                  inputmode="decimal"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
              </div>
            </div>
            <div id="condition-hint" class="text-[11px] text-brand-blue font-semibold">
              Typical rate for new car financing.
            </div>
          </div>

          <!-- Row 5: Loan Start Date -->
          <div class="flex flex-col gap-1.5">
            <label for="loan-start-date" class="text-xs font-semibold text-charcoal">
              First Payment / Start Date
            </label>
            <input
              type="date"
              id="loan-start-date"
              class="text-input font-mono text-sm"
              autocomplete="off"
            />
          </div>

          <!-- Collapsible Advanced Options Toggle -->
          <div class="border-t border-hairline pt-4 mt-2">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-xs font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1.5">
                ⚙ Advanced Options (Taxes, Fees, Balloon Payment)
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <!-- Advanced Panel content -->
            <div
              id="advanced-panel"
              class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-4 border-t border-hairline-soft mt-3 pt-4"
            >
              <!-- Credit Score Range -->
              <div class="flex flex-col gap-1.5">
                <label for="credit-score" class="text-[11px] font-semibold text-slate">
                  Estimated Credit Score Range
                </label>
                <select id="credit-score" class="text-input py-1 text-xs font-medium">
                  <option value="excellent">Excellent (720 - 850)</option>
                  <option value="good" selected>Good (690 - 719)</option>
                  <option value="fair">Fair (630 - 689)</option>
                  <option value="poor">Poor (300 - 629)</option>
                </select>
              </div>

              <!-- Credit Score Rate suggestion box -->
              <div id="credit-rate-alert" class="card-feature-teal !p-3 !rounded-lg text-[11px] flex flex-col gap-1">
                <span class="font-bold text-moss-dark">Credit Profile suggestion:</span>
                <span id="credit-rate-text" class="text-slate leading-relaxed">
                  Loading credit recommendation...
                </span>
              </div>

              <!-- Taxes & Fees Row -->
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
