    const currencySelect = document.getElementById("currency-select") as HTMLSelectElement;
    const customCurrencySymbolInput = document.getElementById("custom-currency-symbol") as HTMLInputElement;
    const customCurrencyCodeInput = document.getElementById("custom-currency-code") as HTMLInputElement;
    const customCurrencyContainer = document.getElementById("custom-currency-container");
    const currencyPrefix = document.getElementById("currency-prefix");
    const creditScoreSelect = document.getElementById("credit-score") as HTMLSelectElement;
    const creditRateText = document.getElementById("credit-rate-text");

    const salesTaxInput = document.getElementById("sales-tax") as HTMLInputElement;
    const docFeesInput = document.getElementById("doc-fees") as HTMLInputElement;
    const regFeesInput = document.getElementById("reg-fees") as HTMLInputElement;
    const balloonPaymentInput = document.getElementById("balloon-payment") as HTMLInputElement;

    // Outputs
    const monthlyPaymentDisplay = document.getElementById("monthly-payment-display");
    const loanAmountDisplay = document.getElementById("loan-amount-display");
    const totalInterestDisplay = document.getElementById("total-interest-display");
    const totalCostDisplay = document.getElementById("total-cost-display");
    const effectiveAprDisplay = document.getElementById("effective-apr-display");
    const payoffDateDisplay = document.getElementById("payoff-date-display");

    const legendPrincipalVal = document.getElementById("legend-principal-val");
    const legendInterestVal = document.getElementById("legend-interest-val");
    const legendDownpaymentVal = document.getElementById("legend-downpayment-val");

    const donutSvg = document.getElementById("donut-svg");
    const donutSegments = document.getElementById("donut-segments");
    const donutPercent = document.getElementById("donut-percent");

    const amortizationTableBody = document.getElementById("amortization-table-body");
    const toggleAmortizationBtn = document.getElementById("toggle-amortization-btn") as HTMLButtonElement;
    const csvExportBtn = document.getElementById("csv-export-btn");
    const excelExportBtn = document.getElementById("excel-export-btn");
    const resetBtn = document.getElementById("reset-btn");

    // Modal
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    // State Variables
    let currentCurrency = "USD";
    let currentCurrencySymbol = "$";
    let currentCurrencyCode = "USD";
    let isDownPaymentPercentMode = false;
    let isUsedVehicle = false;
    let showFullAmortization = false;
    let amortizationData: any[] = [];

    // Credit score average interest rates guidelines (typical)
    const CREDIT_RATES_SUGGESTION: Record<string, { newRange: string; usedRange: string; newAvg: number; usedAvg: number }> = {
      excellent: { newRange: "5.0% - 6.2%", usedRange: "5.8% - 7.0%", newAvg: 5.5, usedAvg: 6.4 },
      good: { newRange: "6.2% - 7.5%", usedRange: "7.0% - 9.0%", newAvg: 6.8, usedAvg: 8.0 },
      fair: { newRange: "7.5% - 11.5%", usedRange: "9.0% - 13.5%", newAvg: 9.5, usedAvg: 11.2 },
      poor: { newRange: "11.5% - 18.0%", usedRange: "13.5% - 21.0%", newAvg: 14.8, usedAvg: 17.5 }
    };

    // Set Default Start Date to next month
    function setDefaultStartDate() {
      const d = new Date();
      d.setMonth(d.getMonth() + 1);
      // Format to YYYY-MM-DD
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = "01"; // Default to 1st of month
      const year = d.getFullYear();
      loanStartDateInput.value = `${year}-${month}-${day}`;
    }

    // Toggle Down Payment mode
    function setDownPaymentMode(isPercent: boolean) {
      isDownPaymentPercentMode = isPercent;
      if (isPercent) {
        downPaymentPercentWrapper?.classList.remove("hidden");
        downPaymentDollarWrapper?.classList.add("hidden");
        downPaymentTogglePercent?.classList.add("bg-primary", "text-canvas");
        downPaymentTogglePercent?.classList.remove("text-slate");
        downPaymentToggleDollar?.classList.remove("bg-primary", "text-canvas");
        downPaymentToggleDollar?.classList.add("text-slate");
      } else {
        downPaymentPercentWrapper?.classList.add("hidden");
        downPaymentDollarWrapper?.classList.remove("hidden");
        downPaymentToggleDollar?.classList.add("bg-primary", "text-canvas");
        downPaymentToggleDollar?.classList.remove("text-slate");
        downPaymentTogglePercent?.classList.remove("bg-primary", "text-canvas");
        downPaymentTogglePercent?.classList.add("text-slate");
      }
      calculate();
    }

    // Update Condition UI (New vs Used)
    function setVehicleCondition(isUsed: boolean, skipInputUpdate = false) {
      isUsedVehicle = isUsed;
      if (isUsed) {
        condUsedBtn?.classList.add("bg-primary", "text-canvas");
        condUsedBtn?.classList.remove("text-slate");
        condNewBtn?.classList.remove("bg-primary", "text-canvas");
        condNewBtn?.classList.add("text-slate");
        if (conditionHint) conditionHint.textContent = "Typical rate for used car financing (usually higher).";
      } else {
        condNewBtn?.classList.add("bg-primary", "text-canvas");
        condNewBtn?.classList.remove("text-slate");
        condUsedBtn?.classList.remove("bg-primary", "text-canvas");
        condUsedBtn?.classList.add("text-slate");
        if (conditionHint) conditionHint.textContent = "Typical rate for new car financing.";
      }
      updateCreditHint();
      if (!skipInputUpdate) {
        // Automatically adjust interest rate based on averages
        const score = creditScoreSelect.value;
        const avg = isUsed ? CREDIT_RATES_SUGGESTION[score].usedAvg : CREDIT_RATES_SUGGESTION[score].newAvg;
        interestRateInput.value = avg.toString();
        interestRateRange.value = avg.toString();
        if (interestRateValLabel) interestRateValLabel.textContent = `${avg.toFixed(2)}%`;
      }
      calculate();
    }

