              <td>Interest Paid</td>
              <td>Remaining Balance</td>
            </tr>
            ${tableRows}
          </table>
        </body>
        </html>
      `;

      const blob = new Blob([html], { type: "application/vnd.ms-excel" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `Amortization_Schedule_${termVal}m_${Date.now()}.xls`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    // DOM Loaded listeners binding
    window.addEventListener("DOMContentLoaded", () => {
      loadState();

      // Sliders bindings
      syncRangeInput(loanTermRange, loanTermInput, loanTermValLabel, (v) => {
        const years = v / 12;
        const yearStr = (v % 12 === 0) ? years.toFixed(0) : years.toFixed(1);
        return `${v} months (${yearStr} years)`;
      });
      syncRangeInput(interestRateRange, interestRateInput, interestRateValLabel, (v) => `${v.toFixed(2)}%`);

      // Core Inputs
      vehiclePriceInput.addEventListener("input", calculate);
      tradeInInput.addEventListener("input", calculate);
      downPaymentDollar.addEventListener("input", calculate);
      downPaymentPercent.addEventListener("input", calculate);

      // Down Payment toggle binds
      downPaymentToggleDollar?.addEventListener("click", () => setDownPaymentMode(false));
      downPaymentTogglePercent?.addEventListener("click", () => setDownPaymentMode(true));

      // Presets term
      presetTermButtons.forEach(btn => {
        btn.addEventListener("click", () => {
          const val = btn.getAttribute("data-term") || "60";
          loanTermInput.value = val;
          loanTermRange.value = val;
          if (loanTermValLabel) {
            const num = parseInt(val, 10);
            const years = num / 12;
            const yearStr = (num % 12 === 0) ? years.toFixed(0) : years.toFixed(1);
            loanTermValLabel.textContent = `${num} months (${yearStr} years)`;
          }
          updateActivePresetButton();
          calculate();
        });
      });

      // Conditions
      condNewBtn?.addEventListener("click", () => setVehicleCondition(false));
      condUsedBtn?.addEventListener("click", () => setVehicleCondition(true));

      loanStartDateInput.addEventListener("input", calculate);

      // Advanced Toggle action
      advancedToggleBtn?.addEventListener("click", () => {
        if (advancedPanel) {
          const isCollapsed = advancedPanel.classList.contains("max-h-0");
          if (isCollapsed) {
            advancedPanel.classList.remove("max-h-0");
            advancedPanel.classList.add("max-h-[2000px]");
            advancedChevron?.classList.add("rotate-180");
          } else {
            advancedPanel.classList.remove("max-h-[2000px]");
            advancedPanel.classList.add("max-h-0");
            advancedChevron?.classList.remove("rotate-180");
          }
        }
      });

      // Advanced inputs
      currencySelect?.addEventListener("change", () => {
        updateCurrencyFormatting();
        calculate();
      });

      customCurrencySymbolInput?.addEventListener("input", () => {
        if (currentCurrency === "Custom") {
          currentCurrencySymbol = customCurrencySymbolInput.value || "$";
          if (currencyPrefix) currencyPrefix.textContent = currentCurrencySymbol;
          updateCurrencyFormatting();
          calculate();
        }
      });

      customCurrencyCodeInput?.addEventListener("input", () => {
        if (currentCurrency === "Custom") {
          currentCurrencyCode = customCurrencyCodeInput.value || "USD";
          updateCurrencyFormatting();
          calculate();
        }
      });

      creditScoreSelect.addEventListener("change", () => {
        updateCreditHint();
        // Trigger auto update of suggests
        const score = creditScoreSelect.value;
        const avg = isUsedVehicle ? CREDIT_RATES_SUGGESTION[score].usedAvg : CREDIT_RATES_SUGGESTION[score].newAvg;
        interestRateInput.value = avg.toString();
        interestRateRange.value = avg.toString();
        if (interestRateValLabel) interestRateValLabel.textContent = `${avg.toFixed(2)}%`;
        calculate();
      });

      salesTaxInput.addEventListener("input", calculate);
      docFeesInput.addEventListener("input", calculate);
      regFeesInput.addEventListener("input", calculate);
      balloonPaymentInput.addEventListener("input", calculate);

      // Amortization toggle
      toggleAmortizationBtn.addEventListener("click", () => {
        showFullAmortization = !showFullAmortization;
        renderAmortizationTable();
      });

      // Export CSV & Excel listeners
      csvExportBtn?.addEventListener("click", exportToCSV);
      excelExportBtn?.addEventListener("click", exportToExcel);

      // Reset
      resetBtn?.addEventListener("click", () => {
        if (typeof localStorage !== 'undefined') {
          try {
            ['price','trade','downtype','downval','term','rate','condition','start','currency','custom-symbol','custom-code','credit','tax','doc','reg','balloon'].forEach(k => localStorage.removeItem('autoloan-' + k));
          } catch (e) {
            console.warn("Failed targeting keys in localStorage", e);
          }
        }
        vehiclePriceInput.value = "35000";
        tradeInInput.value = "5000";
        downPaymentDollar.value = "7000";
        downPaymentPercent.value = "20";
        loanTermInput.value = "60";
        loanTermRange.value = "60";
        interestRateInput.value = "5.5";
        interestRateRange.value = "5.5";
        if (currencySelect) {
          currencySelect.value = "USD";
        }
        if (customCurrencySymbolInput) customCurrencySymbolInput.value = "$";
        if (customCurrencyCodeInput) customCurrencyCodeInput.value = "USD";
        creditScoreSelect.value = "good";
        salesTaxInput.value = "6.25";
        docFeesInput.value = "150";
        regFeesInput.value = "250";
        balloonPaymentInput.value = "0";

        isDownPaymentPercentMode = false;
        isUsedVehicle = false;
        showFullAmortization = false;

        setDefaultStartDate();
        setDownPaymentMode(false);
        setVehicleCondition(false, true);
        updateCurrencyFormatting();
        updateCreditHint();
        calculate();
      });

      // Modal guides
      howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
      closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
      modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

      // Share button copy link logic
      const shareBtn = document.getElementById("share-btn");
      shareBtn?.addEventListener("click", () => {
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set("price", vehiclePriceInput.value);
        url.searchParams.set("trade", tradeInInput.value);
        url.searchParams.set("downtype", isDownPaymentPercentMode ? "percent" : "dollar");
        url.searchParams.set("downval", isDownPaymentPercentMode ? downPaymentPercent.value : downPaymentDollar.value);
        url.searchParams.set("term", loanTermInput.value);
        url.searchParams.set("rate", interestRateInput.value);
        url.searchParams.set("condition", isUsedVehicle ? "used" : "new");
        url.searchParams.set("start", loanStartDateInput.value);
        if (currencySelect) url.searchParams.set("currency", currencySelect.value);
        if (customCurrencySymbolInput) url.searchParams.set("custom-symbol", customCurrencySymbolInput.value);
        if (customCurrencyCodeInput) url.searchParams.set("custom-code", customCurrencyCodeInput.value);
        url.searchParams.set("credit", creditScoreSelect.value);
        url.searchParams.set("tax", salesTaxInput.value);
        url.searchParams.set("doc", docFeesInput.value);
        url.searchParams.set("reg", regFeesInput.value);
        url.searchParams.set("balloon", balloonPaymentInput.value);

        const shareData = {
          title: document.title || "Toolkify",
          url: url.toString()
        };

        if (navigator.share) {
          navigator.share(shareData).catch((err) => {
            if (err.name !== "AbortError") {
              copyToClipboard(url.toString());
            }
          });
        } else {
          copyToClipboard(url.toString());
        }

        function copyToClipboard(text: string) {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
          } else {
            fallbackCopy(text);
          }
        }

        function fallbackCopy(text: string) {
          const textArea = document.createElement("textarea");
          textArea.value = text;
          textArea.style.position = "fixed";
          textArea.style.opacity = "0";
          document.body.appendChild(textArea);
          textArea.select();
          try {
            document.execCommand("copy");
            showSuccess();
          } catch (err) {
            console.error(err);
          }
          document.body.removeChild(textArea);
        }

        function showSuccess() {
          if (shareBtn) {
            const span = shareBtn.querySelector("span");
            if (span) {
              const originalText = span.textContent || "Share";
              span.textContent = "Link Copied!";
              shareBtn.classList.add("text-success-accent", "border-success-accent");
              setTimeout(() => {
                span.textContent = originalText;
                shareBtn.classList.remove("text-success-accent", "border-success-accent");
              }, 2000);
            }
          }
        }
      });

      // Mobile sticky bar scroll sync
      const mobileStickyBar = document.getElementById("mobile-sticky-bar");
      const resultsColumn = document.getElementById("results-column");
      if (mobileStickyBar && resultsColumn) {
        const handleScroll = () => {
          const rect = resultsColumn.getBoundingClientRect();
          // Hide when results section is in view
          if (rect.top <= window.innerHeight - 80) {
            mobileStickyBar.style.transform = "translateY(100%)";
          } else {
            mobileStickyBar.style.transform = "translateY(0)";
          }
        };
        window.addEventListener("scroll", handleScroll);
        handleScroll();
      }

    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }

      const mobileScrollBtn = document.getElementById("mobile-scroll-results-btn");
      if (mobileScrollBtn && resultsColumn) {
        mobileScrollBtn.addEventListener("click", () => {
          scrollToElementWithOffset("results-column", 80);
        });
      }

      // FAQ Accordion Toggle Interaction
      const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
      faqToggleButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const expanded = btn.getAttribute("aria-expanded") === "true";
          
          // Close other open accordions
          faqToggleButtons.forEach((otherBtn) => {
            if (otherBtn !== btn) {
              otherBtn.setAttribute("aria-expanded", "false");
              const otherContent = otherBtn.nextElementSibling;
              if (otherContent) otherContent.classList.add("hidden");
              otherBtn.querySelector("svg")?.classList.remove("rotate-180");
            }
          });

          // Toggle current accordion
          btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
          const content = btn.nextElementSibling;
          if (content) {
            content.classList.toggle("hidden");
          }
          btn.querySelector("svg")?.classList.toggle("rotate-180");
        });
      });

      // Initial execution
      updateActivePresetButton();
      calculate();
    });
  </script>
</Layout>
