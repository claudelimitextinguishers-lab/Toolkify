    // High fidelity currency formatting helper
    function formatCurrency(val: number): string {
      const locale = currentCurrencyCode === "INR" ? "en-IN" : undefined;
      return (
        currentCurrencySymbol +
        val.toLocaleString(locale, {
          minimumFractionDigits: currentCurrencyCode === "INR" ? 0 : 2,
          maximumFractionDigits: currentCurrencyCode === "INR" ? 0 : 2
        })
      );
    }

    // Newton-Raphson Solver for Internal Rate of Return (IRR) to determine true APR
    function solveEffectiveAPR(
      financedPrincipal: number, // Net Loan Amount (includes fees/taxes if financed)
      actualPricePaid: number,   // Cash price that is borrowing (Price - TradeIn - DownPayment)
      monthlyPayment: number,
      balloon: number,
      termMonths: number
    ): number {
      // The true APR equates the cash Price difference (actualPricePaid) to the present value of payments:
      // actualPricePaid = Sum_{k=1}^n [ MonthlyPayment / (1 + r)^k ] + Balloon / (1 + r)^n
      // Solve for r (monthly rate), APR = r * 12 * 100
      
      const target = actualPricePaid;
      if (target <= 0 || monthlyPayment <= 0) return 0;

      let r = 0.05 / 12; // Initial guess (5% annual)
      const maxIterations = 100;
      const tolerance = 1e-7;

      for (let i = 0; i < maxIterations; i++) {
        let pv = 0;
        let df_dr = 0; // Derivative w.r.t r
        
        for (let k = 1; k <= termMonths; k++) {
          const discount = Math.pow(1 + r, -k);
          pv += monthlyPayment * discount;
          df_dr -= k * monthlyPayment * discount / (1 + r);
        }
        
        const balloonDiscount = Math.pow(1 + r, -termMonths);
        pv += balloon * balloonDiscount;
        df_dr -= termMonths * balloon * balloonDiscount / (1 + r);

        const diff = pv - target;
        if (Math.abs(diff) < tolerance) {
          break;
        }

        if (df_dr === 0) break;
        r = r - diff / df_dr;

        // Keep rate in logical boundary
        if (r < -0.99) r = -0.99;
      }

      const annualRate = r * 12 * 100;
      return Math.max(0, annualRate);
    }

    // Main Calculator math engine
    function calculate() {
      const price = Math.max(0, parseFloat(vehiclePriceInput.value) || 0);
      const tradeIn = Math.max(0, parseFloat(tradeInInput.value) || 0);
      
      // Handle down payment dual modes
      let downPayment = 0;
      if (isDownPaymentPercentMode) {
        const pct = Math.min(100, Math.max(0, parseFloat(downPaymentPercent.value) || 0));
        downPayment = (price * pct) / 100;
        downPayment = Math.min(downPayment, Math.max(0, price - tradeIn));
        downPaymentDollar.value = Math.round(downPayment).toString();
      } else {
        downPayment = Math.min(price, Math.max(0, parseFloat(downPaymentDollar.value) || 0));
        const pct = price > 0 ? (downPayment / price) * 100 : 0;
        downPaymentPercent.value = pct.toFixed(1);
      }

      // Feedback label
      if (downPaymentFeedback) {
        const pctVal = price > 0 ? ((downPayment / price) * 100).toFixed(1) : "0.0";
        downPaymentFeedback.textContent = `Down Payment: ${formatCurrency(downPayment)} (${pctVal}% of vehicle price)`;
      }

      const term = Math.max(1, parseInt(loanTermInput.value, 10) || 12);
      const rate = Math.max(0, parseFloat(interestRateInput.value) || 0);

      // Advanced options values
      const taxRate = Math.max(0, parseFloat(salesTaxInput.value) || 0);
      const docFees = Math.max(0, parseFloat(docFeesInput.value) || 0);
      const regFees = Math.max(0, parseFloat(regFeesInput.value) || 0);

      // Sales Tax is calculated on (Vehicle Price - Trade-in Value) (tax credits standard in most states)
      const taxablePrice = Math.max(0, price - tradeIn);
      const salesTax = (taxablePrice * taxRate) / 100;

      // Net Loan Amount
      const fees = docFees + regFees;
      downPayment = Math.min(downPayment, price);
      const loanAmount = Math.max(0, price - downPayment - tradeIn + salesTax + fees);
      const balloon = Math.min(loanAmount, Math.max(0, parseFloat(balloonPaymentInput.value) || 0));

      // Monthly payment formula w/ balloon
      let monthlyPayment = 0;
      const monthlyRate = rate / (12 * 100);

      if (loanAmount > 0) {
        if (monthlyRate === 0) {
          monthlyPayment = (loanAmount - balloon) / term;
        } else {
          // Standard Balloon payment formula
          const discountFactor = Math.pow(1 + monthlyRate, -term);
          monthlyPayment = ((loanAmount - balloon * discountFactor) * monthlyRate) / (1 - discountFactor);
        }
      }

      // Total Cost breakdown
      // Total installments + balloon + down payment + trade-in
      const totalInstallments = monthlyPayment * term;
      const totalCost = totalInstallments + balloon + downPayment;
      const totalInterest = Math.max(0, (totalInstallments + balloon) - loanAmount);

      // Calculate Effective APR (includes doc fees to reveal exact real economic costs)
      const cashDifference = price - downPayment - tradeIn;
      const effectiveAPR = solveEffectiveAPR(loanAmount, cashDifference, monthlyPayment, balloon, term);

      // Payoff Date
      let payoffText = "N/A";
      const startDateVal = loanStartDateInput.value;
      const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
      if (startDateVal && dateRegex.test(startDateVal)) {
        const parts = startDateVal.split("-");
        const startDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
        startDate.setMonth(startDate.getMonth() + term);
        const formatOptions: Intl.DateTimeFormatOptions = { month: 'long', year: 'numeric' };
        payoffText = startDate.toLocaleDateString('en-US', formatOptions);
      }

      // Update Outputs DOM
      if (monthlyPaymentDisplay) monthlyPaymentDisplay.textContent = formatCurrency(monthlyPayment);
      if (loanAmountDisplay) loanAmountDisplay.textContent = formatCurrency(loanAmount);
      if (totalInterestDisplay) totalInterestDisplay.textContent = formatCurrency(totalInterest);
      if (totalCostDisplay) totalCostDisplay.textContent = formatCurrency(totalCost);
      if (effectiveAprDisplay) {
        // If there are zero fees, APR is identical to interest rate
        const aprToDisplay = fees > 0 ? effectiveAPR : rate;
        effectiveAprDisplay.textContent = `${aprToDisplay.toFixed(2)}%`;
      }
      if (payoffDateDisplay) payoffDateDisplay.textContent = payoffText;

      // Update Mobile Summary HUD
      const mobileHUDVal = document.getElementById("mobile-summary-value");
      if (mobileHUDVal) mobileHUDVal.textContent = formatCurrency(monthlyPayment);

      // Amortization Schedule Data Generation
      generateAmortizationData(loanAmount, monthlyRate, monthlyPayment, term, balloon);

      // Render Charts/Donut
      renderDonutChart(loanAmount, totalInterest, downPayment, salesTax + fees);

      // Save to localStorage
      saveState();
    }

    // Generate Amortization Table array
    function generateAmortizationData(principal: number, monthlyRate: number, monthlyPayment: number, term: number, balloon: number) {
      amortizationData = [];
      let balance = principal;
      const startDateVal = loanStartDateInput.value;
      let currentDate = new Date();
      const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
      let hasValidDate = false;
      if (startDateVal && dateRegex.test(startDateVal)) {
        const parts = startDateVal.split("-");
        currentDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
        hasValidDate = true;
      }

      for (let i = 1; i <= term; i++) {
        const interest = balance * monthlyRate;
        let principalPaid = monthlyPayment - interest;
        
        // Final row adjustment
        if (i === term) {
          principalPaid = balance - balloon;
          balance = balloon;
        } else {
          balance = balance - principalPaid;
          if (balance < 0.01) balance = 0;
        }

        const dateOptions: Intl.DateTimeFormatOptions = { month: 'short', year: 'numeric' };
        const dateStr = hasValidDate ? currentDate.toLocaleDateString('en-US', dateOptions) : "N/A";

        amortizationData.push({
          num: i,
          date: dateStr,
          payment: monthlyPayment,
          principal: principalPaid,
          interest: interest,
          balance: i === term ? balloon : balance
        });

        if (hasValidDate) {
          currentDate.setMonth(currentDate.getMonth() + 1);
        }
      }

      renderAmortizationTable();
    }

    // Render schedule to DOM
    function renderAmortizationTable() {
      if (!amortizationTableBody) return;
      const rowsToShow = showFullAmortization ? amortizationData.length : Math.min(6, amortizationData.length);
      
      let html = "";
      for (let i = 0; i < rowsToShow; i++) {
        const row = amortizationData[i];
        html += `
          <tr class="border-b border-hairline-soft font-mono text-[11px] text-slate hover:bg-surface-soft transition-all">
            <td class="py-2 px-3 font-semibold text-primary">${row.num}</td>
            <td class="py-2 px-3">${row.date}</td>
            <td class="py-2 px-3 text-right text-primary font-semibold">${formatCurrency(row.payment)}</td>
            <td class="py-2 px-3 text-right">${formatCurrency(row.principal)}</td>
            <td class="py-2 px-3 text-right text-brand-coral">${formatCurrency(row.interest)}</td>
            <td class="py-2 px-3 text-right text-primary font-semibold">${formatCurrency(row.balance)}</td>
          </tr>
        `;
      }
      amortizationTableBody.innerHTML = html;

      // Update button label
      if (toggleAmortizationBtn) {
        toggleAmortizationBtn.textContent = showFullAmortization 
          ? "Collapse Schedule" 
          : `Show Full Schedule (${amortizationData.length} payments)`;
      }
    }

    // SVG Donut Chart Visual
    function renderDonutChart(principal: number, interest: number, downPayment: number, taxAndFees: number) {
      if (!donutSegments) return;

      const total = principal + interest + downPayment + taxAndFees;
      if (total === 0) return;

      const pPct = (principal / total) * 100;
      const iPct = (interest / total) * 100;
      const dPct = (downPayment / total) * 100;
      const tfPct = (taxAndFees / total) * 100;

      // Update Legends labels
      if (legendPrincipalVal) legendPrincipalVal.textContent = `${formatCurrency(principal)} (${pPct.toFixed(1)}%)`;
      if (legendInterestVal) legendInterestVal.textContent = `${formatCurrency(interest)} (${iPct.toFixed(1)}%)`;
      if (legendDownpaymentVal) legendDownpaymentVal.textContent = `${formatCurrency(downPayment)} (${dPct.toFixed(1)}%)`;
      
      const tfEl = document.getElementById("legend-taxfees-val");
      if (tfEl) tfEl.textContent = `${formatCurrency(taxAndFees)} (${tfPct.toFixed(1)}%)`;

      if (donutPercent) donutPercent.textContent = `${pPct.toFixed(0)}%`;

      // Draw SVG segments
      let accumulatedPercent = 0;
      let svgHtml = "";
      const radius = 40;
      const circumference = 2 * Math.PI * radius;

      const slices = [
        { pct: pPct, color: "var(--color-brand-blue, #4262ff)" },
        { pct: iPct, color: "var(--color-brand-coral, #ff9999)" },
        { pct: dPct, color: "var(--color-brand-yellow-deep, #fcb900)" },
        { pct: tfPct, color: "var(--color-brand-teal, #0fbcb0)" }
      ];

      slices.forEach(slice => {
        if (slice.pct <= 0) return;
        const strokeDashArray = `${(slice.pct / 100) * circumference} ${circumference}`;
        const strokeDashOffset = -((accumulatedPercent / 100) * circumference);
        
        svgHtml += `
          <circle
            cx="50"
            cy="50"
            r="${radius}"
            stroke="${slice.color}"
            stroke-width="12"
            fill="transparent"
            stroke-dasharray="${strokeDashArray}"
            stroke-dashoffset="${strokeDashOffset}"
            stroke-linecap="round"
            class="transition-all duration-500"
          />
        `;
        accumulatedPercent += slice.pct;
      });

      donutSegments.innerHTML = svgHtml;
    }

    // Active Highlight Preset Buttons
    function updateActivePresetButton() {
      const term = parseInt(loanTermInput.value, 10);
      presetTermButtons.forEach(btn => {
        const val = parseInt(btn.getAttribute("data-term") || "0", 10);
        if (val === term) {
          btn.classList.add("bg-primary", "text-canvas", "border-primary");
          btn.classList.remove("bg-canvas", "text-slate", "border-hairline");
        } else {
          btn.classList.remove("bg-primary", "text-canvas", "border-primary");
          btn.classList.add("bg-canvas", "text-slate", "border-hairline");
        }
      });
    }

    // Sync input range & value fields
    function syncRangeInput(rangeEl: HTMLInputElement, inputEl: HTMLInputElement, labelEl: HTMLElement | null, formatter: (v: number) => string) {
      rangeEl.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        inputEl.value = val;
        if (labelEl) labelEl.textContent = formatter(parseFloat(val));
        calculate();
        updateActivePresetButton();
      });

      inputEl.addEventListener("input", (e) => {
        let val = parseFloat((e.target as HTMLInputElement).value) || 0;
        const min = parseFloat(inputEl.min || "0");
        const max = parseFloat(inputEl.max || "100");
        val = Math.max(min, Math.min(max, val));
        rangeEl.value = val.toString();
        if (labelEl) labelEl.textContent = formatter(val);
        calculate();
        updateActivePresetButton();
      });
    }

    // LocalStorage Load/Save
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const getSafeItem = (key: string): string | null => {
        const paramKey = key.replace("autoloan-", "");
        if (urlParams.has(paramKey)) {
          return urlParams.get(paramKey);
        }
        if (typeof localStorage === 'undefined') return null;
        try {
          return localStorage.getItem(key);
        } catch (e) {
          console.warn(`Failed reading ${key} from localStorage`, e);
          return null;
        }
      };

      const savedPrice = getSafeItem("autoloan-price");
      const savedTrade = getSafeItem("autoloan-trade");
      const savedDownType = getSafeItem("autoloan-downtype");
      const savedDownVal = getSafeItem("autoloan-downval");
      const savedTerm = getSafeItem("autoloan-term");
      const savedRate = getSafeItem("autoloan-rate");
      const savedCondition = getSafeItem("autoloan-condition");
      const savedStart = getSafeItem("autoloan-start");
      const savedCurrency = getSafeItem("autoloan-currency");
      const savedCustomSymbol = getSafeItem("autoloan-custom-symbol");
      const savedCustomCode = getSafeItem("autoloan-custom-code");
      const savedCredit = getSafeItem("autoloan-credit");
      const savedTax = getSafeItem("autoloan-tax");
      const savedDoc = getSafeItem("autoloan-doc");
      const savedReg = getSafeItem("autoloan-reg");
      const savedBalloon = getSafeItem("autoloan-balloon");

      if (savedPrice !== null) vehiclePriceInput.value = savedPrice;
      if (savedTrade !== null) tradeInInput.value = savedTrade;
      if (savedDownType !== null) {
        isDownPaymentPercentMode = savedDownType === "percent";
      }
      if (savedDownVal !== null) {
        if (isDownPaymentPercentMode) {
          downPaymentPercent.value = savedDownVal;
        } else {
          downPaymentDollar.value = savedDownVal;
        }
      }
      if (savedTerm !== null) {
        loanTermInput.value = savedTerm;
        loanTermRange.value = savedTerm;
      }
      if (savedRate !== null) {
        interestRateInput.value = savedRate;
        interestRateRange.value = savedRate;
      }
      if (savedCondition !== null) {
        isUsedVehicle = savedCondition === "used";
      }
      if (savedStart !== null) {
        loanStartDateInput.value = savedStart;
      } else {
        setDefaultStartDate();
      }
      if (savedCustomSymbol && customCurrencySymbolInput) {
        customCurrencySymbolInput.value = savedCustomSymbol;
      }
      if (savedCustomCode && customCurrencyCodeInput) {
        customCurrencyCodeInput.value = savedCustomCode;
      }
      if (savedCurrency && currencySelect) {
        currencySelect.value = savedCurrency;
      }
      if (savedCredit !== null) {
        creditScoreSelect.value = savedCredit;
      }
      if (savedTax !== null) salesTaxInput.value = savedTax;
      if (savedDoc !== null) docFeesInput.value = savedDoc;
      if (savedReg !== null) regFeesInput.value = savedReg;
      if (savedBalloon !== null) balloonPaymentInput.value = savedBalloon;

      // Apply visual updates
      setDownPaymentMode(isDownPaymentPercentMode);
      setVehicleCondition(isUsedVehicle, true);
      updateCurrencyFormatting();
      updateCreditHint();
    }

    function saveState() {
      if (typeof localStorage === 'undefined') return;
      
      const setSafeItem = (key: string, val: string) => {
        try {
          localStorage.setItem(key, val);
        } catch (e) {
          console.warn(`Failed saving ${key} to localStorage`, e);
        }
      };

      setSafeItem("autoloan-price", vehiclePriceInput.value);
      setSafeItem("autoloan-trade", tradeInInput.value);
      setSafeItem("autoloan-downtype", isDownPaymentPercentMode ? "percent" : "dollar");
      setSafeItem("autoloan-downval", isDownPaymentPercentMode ? downPaymentPercent.value : downPaymentDollar.value);
      setSafeItem("autoloan-term", loanTermInput.value);
      setSafeItem("autoloan-rate", interestRateInput.value);
      setSafeItem("autoloan-condition", isUsedVehicle ? "used" : "new");
      setSafeItem("autoloan-start", loanStartDateInput.value);
      setSafeItem("autoloan-currency", currentCurrency);
      setSafeItem("autoloan-custom-symbol", currentCurrencySymbol);
      setSafeItem("autoloan-custom-code", currentCurrencyCode);
      setSafeItem("autoloan-credit", creditScoreSelect.value);
      setSafeItem("autoloan-tax", salesTaxInput.value);
      setSafeItem("autoloan-doc", docFeesInput.value);
      setSafeItem("autoloan-reg", regFeesInput.value);
      setSafeItem("autoloan-balloon", balloonPaymentInput.value);
    }

    // Export CSV Amortization schedule
    function exportToCSV() {
      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Payment #,Date,Payment,Principal,Interest,Remaining Balance\r\n";

      amortizationData.forEach(row => {
        const cleanPayment = row.payment.toFixed(2);
        const cleanPrincipal = row.principal.toFixed(2);
        const cleanInterest = row.interest.toFixed(2);
        const cleanBalance = row.balance.toFixed(2);
        csvContent += `${row.num},${row.date},${cleanPayment},${cleanPrincipal},${cleanInterest},${cleanBalance}\r\n`;
      });

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", `Amortization_Schedule_${loanTermInput.value}m.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

