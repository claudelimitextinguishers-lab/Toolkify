  <script>
    // DOM Elements
    const vehiclePriceInput = document.getElementById("vehicle-price") as HTMLInputElement;
    const tradeInInput = document.getElementById("trade-in") as HTMLInputElement;
    const downPaymentDollar = document.getElementById("down-payment-dollar") as HTMLInputElement;
