---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Compound Interest Calculator";
const category = "finance";
const tier = "Finance & Tax";

// On-page SEO metadata
const pageTitle =
  "Compound Interest Calculator - Free Daily & Monthly Calculator";
const description =
  "Free compound interest calculator with extra contributions, daily, monthly & annual compounding, withdrawals and inflation. See how your savings, 401k or investments grow.";
const canonicalUrl =
  "https://boardtools.app/tools/finance/compound-interest";
const ogImage = "/og/compound-interest-calculator.png";
const keywords =
  "compound interest calculator, daily compound interest calculator, best compound interest calculator, online compound interest calculator, compound interest calculator with extra contributions, compound interest calculator with additional contributions, compound interest calculator excel, real compound interest calculator, compound interest calculator calculator, loan compound interest calculator, monthly compound interest calculator, bankrate compound interest calculator, compound interest calculator with withdrawals, 401k compound interest calculator, continuous compound interest calculator, compound interest calculator monthly, compound interest calculator 401k, compound interest calculator daily, annual compound interest calculator";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Compound Interest Calculator",
      "alternateName": "Daily, Monthly & Annual Compound Interest Calculator",
      "url": "https://boardtools.app/tools/finance/compound-interest",
      "description": "Free compound interest calculator with extra contributions, withdrawals, daily, monthly, annual and continuous compounding, inflation adjustment, dynamic charts, and a year-by-year growth breakdown.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Daily, monthly, annual and continuous compound interest",
        "Compound interest calculator with extra contributions",
        "Compound interest calculator with withdrawals",
        "401k and retirement growth projections",
        "Inflation-adjusted real returns",
        "Year-by-year growth breakdown and charts"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "2130"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://boardtools.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Finance & Tax Tools",
          "item": "https://boardtools.app/#finance"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Compound Interest Calculator",
          "item": "https://boardtools.app/tools/finance/compound-interest"
        }
      ]
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does this compound interest calculator work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Enter your starting balance, interest rate, time period and compounding frequency, and the calculator applies the compound interest formula A = P(1 + r/n)^(nt) to project your future value. You can add regular extra contributions, model withdrawals, and adjust for inflation to see your real, after-inflation balance."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between daily and monthly compounding?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Daily compounding adds interest to your balance 365 times a year, while monthly compounding does so 12 times a year. The more frequently interest compounds, the faster your money grows. Use this daily compound interest calculator or switch to monthly, annual, or continuous compounding to compare the results."
          }
        },
        {
          "@type": "Question",
          "name": "Can I add extra monthly contributions or withdrawals?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. This is a compound interest calculator with extra contributions and withdrawals. Add a recurring monthly or annual deposit to model regular saving, or schedule withdrawals to see how drawing down funds affects long-term growth — perfect for planning a 401k or retirement pot."
          }
        },
        {
          "@type": "Question",
          "name": "Is this compound interest calculator free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. This is a 100% free, online compound interest calculator that runs entirely in your browser. No sign-up is required and your numbers never leave your device."
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-3 flex flex-col gap-4 animate-fade-in-up pb-24 lg:pb-16"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav
        class="flex items-center gap-1.5 text-[10px] sm:text-xs font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-2xl sm:text-3xl tracking-tight text-primary">
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2.5 rounded-full font-semibold uppercase shrink-0"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="info-modal-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How it works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Above the Fold: Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 sm:gap-8 items-stretch">
      <!-- Left Column: Inputs (7 Cols) -->
      <div class="lg:col-span-7 flex flex-col gap-4 sm:gap-5">
        <div class="card-base p-4 sm:p-5 flex flex-col gap-4 sm:gap-5">
          <h2 class="font-display font-semibold text-base sm:text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Investment Parameters
          </h2>

          <!-- Currency & Principal Amount -->
          <div class="flex flex-col gap-1.5">
            <div class="flex items-center justify-between">
              <label for="principal-amount" class="text-[11px] font-semibold text-charcoal">
                Initial Investment (Principal)
              </label>
              <!-- Currency Select -->
              <select
                id="currency-select"
                class="text-[10px] font-semibold py-1 px-2.5 rounded-full border border-hairline bg-surface hover:bg-canvas cursor-pointer transition-all outline-none"
                aria-label="Currency Select"
              >
                <option value="USD" selected>$ USD</option>
                <option value="CAD">$ CAD</option>
                <option value="GBP">£ GBP</option>
                <option value="AUD">$ AUD</option>
                <option value="EUR">€ EUR</option>
                <option value="INR">₹ INR</option>
                <option value="Custom">Custom / Other</option>
              </select>
            </div>
            <div class="relative">
              <span id="currency-prefix" class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-semibold">$</span>
              <input
                type="number"
                id="principal-amount"
                value="10000"
                min="0"
                max="1000000000"
                step="100"
                class="text-input pl-7 text-sm font-mono"
                inputmode="numeric"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Custom Currency Inputs (Hidden by default) -->
          <div id="custom-currency-container" class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft hidden animate-fade-in-up">
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-symbol" class="text-[10px] font-semibold text-slate">Currency Symbol</label>
              <input type="text" id="custom-currency-symbol" value="$" class="text-input" placeholder="e.g. $, £, €, ₹" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-code" class="text-[10px] font-semibold text-slate">Currency Code</label>
              <input type="text" id="custom-currency-code" value="USD" class="text-input" placeholder="e.g. USD, GBP, EUR" />
            </div>
          </div>

          <!-- Annual Interest Rate slider + numeric input -->
          <div class="flex flex-col gap-1.5">
            <div class="flex items-center justify-between text-[11px] font-semibold text-charcoal">
              <span>Annual Interest Rate (%)</span>
              <span id="interest-rate-label" class="font-mono text-stone font-bold">8.0%</span>
            </div>
            <div class="flex items-center gap-3">
              <input
                type="range"
                id="interest-rate-range"
                min="0.1"
                max="30"
                value="8.0"
                step="0.1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Interest Rate Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="interest-rate"
                  min="0.1"
                  max="100"
                  value="8.0"
                  step="0.01"
                  class="text-input pr-5 py-1 text-xs text-center font-mono h-8"
                  inputmode="decimal"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
              </div>
            </div>
          </div>

          <!-- Time Horizon (Years) presets + slider -->
          <div class="flex flex-col gap-1.5">
            <div class="flex items-center justify-between text-[11px] font-semibold text-charcoal">
              <span>Time Period (Years)</span>
              <span id="time-period-label" class="font-mono text-stone font-bold">10 years</span>
            </div>
            <!-- Quick Presets -->
            <div class="grid grid-cols-6 gap-1">
              {
                [1, 3, 5, 10, 20, 30].map((yr) => (
                  <button
                    type="button"
                    class="preset-year-btn text-[10px] sm:text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer border border-hairline text-slate bg-canvas hover:border-hairline-strong active:scale-95 flex items-center justify-center"
                    data-year={yr}
                  >
                    {yr}y
                  </button>
                ))
              }
            </div>
            <div class="flex items-center gap-3 mt-1">
              <input
                type="range"
                id="time-period-range"
                min="1"
                max="50"
                value="10"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Time Horizon Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="time-period"
                  min="1"
                  max="100"
                  value="10"
                  class="text-input pr-6 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">yrs</span>
              </div>
            </div>
          </div>

          <!-- Compounding Frequency -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal">Compounding Frequency</label>
            <div class="grid grid-cols-4 gap-1">
              {
                ['Daily', 'Monthly', 'Quarterly', 'Annually'].map((freq) => (
                  <button
                    type="button"
                    class="compound-freq-btn text-[10px] sm:text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer border border-hairline text-slate bg-canvas hover:border-hairline-strong active:scale-95 flex items-center justify-center"
                    data-freq={freq.toLowerCase()}
                  >
                    {freq}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Regular Contributions -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="contribution-amount" class="text-[11px] font-semibold text-charcoal">
                Regular Contribution Additions
              </label>
              <div class="relative">
                <span class="currency-symbol absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-semibold">$</span>
                <input
                  type="number"
                  id="contribution-amount"
                  value="500"
                  min="0"
                  max="100000000"
                  step="10"
                  class="text-input pl-7 text-sm font-mono"
                  inputmode="numeric"
                  autocomplete="off"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-[11px] font-semibold text-charcoal">Contribution Frequency</label>
              <div class="flex rounded-full bg-surface p-0.5 border border-hairline h-11 items-center">
                <button
                  type="button"
                  id="contrib-monthly"
                  class="w-1/2 text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
                >
                  Monthly
                </button>
                <button
                  type="button"
                  id="contrib-annually"
                  class="w-1/2 text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate"
                >
                  Annually
                </button>
              </div>
            </div>
          </div>

          <!-- Advanced Toggle Options Section -->
          <div class="border-t border-hairline pt-3 mt-1">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-xs font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1.5">
                ⚙ Advanced Options (Inflation, Taxes, Timings)
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <!-- Advanced Options Panel (Expands smoothly) -->
            <div
              id="advanced-panel"
              class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-4 border-t border-hairline-soft mt-3 pt-3"
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label class="text-[11px] font-semibold text-slate">Contribution Timing</label>
                  <div class="flex rounded-full bg-surface p-0.5 border border-hairline h-9 items-center">
                    <button
                      type="button"
                      id="timing-beginning"
                      class="w-1/2 text-[10px] py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
                    >
                      Beginning
                    </button>
                    <button
                      type="button"
                      id="timing-end"
                      class="w-1/2 text-[10px] py-1 rounded-full font-bold transition-all cursor-pointer text-slate"
                    >
                      End of Period
                    </button>
                  </div>
                </div>

                <div class="flex flex-col gap-1.5">
                  <label for="start-date" class="text-[11px] font-semibold text-slate">
                    Calculation Start Date
                  </label>
                  <input
                    type="date"
                    id="start-date"
                    class="text-input !h-9 text-xs font-mono"
                    autocomplete="off"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <label for="inflation-rate" class="text-[11px] font-semibold text-slate">
                    Annual Inflation Rate (%)
                  </label>
                  <div class="relative">
                    <input
                      type="number"
                      id="inflation-rate"
                      value="0.0"
                      min="0"
                      max="50"
                      step="0.1"
                      class="text-input !h-9 text-xs font-mono pr-6"
                      inputmode="decimal"
                      placeholder="0.0"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-xs">%</span>
                  </div>
                </div>

                <div class="flex flex-col gap-1.5">
                  <label for="tax-rate" class="text-[11px] font-semibold text-slate">
                    Estimated Tax Rate (%)
                  </label>
                  <div class="relative">
                    <input
                      type="number"
                      id="tax-rate"
                      value="0.0"
                      min="0"
                      max="100"
                      step="0.1"
                      class="text-input !h-9 text-xs font-mono pr-6"
                      inputmode="decimal"
                      placeholder="0.0"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-xs">%</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Quick Core Outputs Hero (5 Cols) -->
      <div id="hero-section" class="lg:col-span-5 flex flex-col gap-4 sm:gap-5 justify-between">
        <div class="card-feature-teal p-5 sm:p-6 flex flex-col justify-between h-full relative overflow-hidden rounded-xl">
          <div class="absolute top-0 right-0 w-32 h-32 bg-teal-light/20 rounded-full blur-2xl"></div>

          <div class="flex flex-col gap-5 z-10">
            <!-- Hero Future Value -->
            <div class="flex flex-col">
              <span class="text-[10px] sm:text-xs font-bold text-moss-dark/70 uppercase tracking-wider block">Projected Future Value</span>
              <div
                id="hero-future-value"
                class="font-display font-semibold text-3xl sm:text-4xl lg:text-5xl text-primary font-mono select-all transition-all duration-300"
              >
                $0.00
              </div>
            </div>

            <!-- Total Principal & Total Interest Breakdown -->
            <div class="grid grid-cols-2 gap-4 pb-4 border-b border-moss-dark/10">
              <div class="flex flex-col">
                <span class="text-[9px] uppercase font-bold text-moss-dark/70 tracking-wider">Total Contributed</span>
                <span id="hero-contributed" class="font-display font-semibold text-base sm:text-lg text-primary font-mono select-all">$0.00</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[9px] uppercase font-bold text-moss-dark/70 tracking-wider">Total Interest</span>
                <span id="hero-interest" class="font-display font-semibold text-base sm:text-lg text-primary font-mono select-all">$0.00</span>
              </div>
            </div>

            <!-- Advanced Metrics indicators (shown dynamically below fold but highlighted here) -->
            <div class="flex flex-col gap-2 pt-1 text-[11px] text-moss-dark/95">
              <div class="flex justify-between items-center hidden" id="adjusted-real-badge">
                <span>Real Purchasing Power (Adjusted for Inflation):</span>
                <span id="badge-real-val" class="font-bold font-mono">$0.00</span>
              </div>
              <div class="flex justify-between items-center hidden" id="adjusted-tax-badge">
                <span>Estimated Value After Tax:</span>
                <span id="badge-tax-val" class="font-bold font-mono">$0.00</span>
              </div>
              <div class="flex justify-between items-center">
                <span>Target Maturity Date:</span>
                <span id="badge-target-date" class="font-semibold font-mono">June 2036</span>
              </div>
            </div>
          </div>

          <!-- Bottom View Results action -->
          <div class="mt-6 z-10">
            <button
              type="button"
              id="view-results-btn"
              class="w-full button-primary !text-xs !py-2.5 !px-4 hover:bg-charcoal active:scale-98 shadow-subtle flex items-center justify-center gap-1"
            >
              <span>View Detailed Results</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7-7-7m14-6l-7 7-7-7"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Below the Fold: Results & Amortization Section -->
    <div id="results-section" class="flex flex-col gap-6 mt-6 border-t border-hairline pt-6">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <h2 class="font-display font-semibold text-xl sm:text-2xl text-primary flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-success-accent animate-pulse"></span>
          Detailed Projection Breakdown
        </h2>
        
        <!-- Action Buttons -->
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="copy-results-btn"
            class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
