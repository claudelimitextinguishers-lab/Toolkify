        html += `<td>${row.contributionsThisYear.toFixed(2)}</td>`;
        html += `<td>${row.interestThisYear.toFixed(2)}</td>`;
        html += `<td>${row.cumulativeContributions.toFixed(2)}</td>`;
        html += `<td>${row.cumulativeInterest.toFixed(2)}</td>`;
        html += `<td>${row.endingBalance.toFixed(2)}</td>`;
