    }

    // Register Event Listeners
    principalInput?.addEventListener("input", calculate);
    
    // Sliders sync with numeric fields
    interestRange?.addEventListener("input", (e) => {
      interestInput.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    interestInput?.addEventListener("input", (e) => {
      interestRange.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    interestInput?.addEventListener("blur", () => {
      interestInput.value = Math.max(0.1, Math.min(100, parseFloat(interestInput.value) || 8)).toFixed(2);
      interestRange.value = interestInput.value;
      calculate();
    });

    timeRange?.addEventListener("input", (e) => {
      timeInput.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    timeInput?.addEventListener("input", (e) => {
      timeRange.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    timeInput?.addEventListener("blur", () => {
      timeInput.value = Math.max(1, Math.min(100, parseInt(timeInput.value, 10) || 10)).toString();
      timeRange.value = timeInput.value;
      calculate();
    });

    contribInput?.addEventListener("input", calculate);
    startDateInput?.addEventListener("input", calculate);
    inflationInput?.addEventListener("input", calculate);
    taxInput?.addEventListener("input", calculate);

    // Currency controls
    currencySelect?.addEventListener("change", updateCurrencyFromSelect);
    customCurrencySymbolInput?.addEventListener("input", () => {
      if (currentCurrency === "Custom") {
        currentCurrencySymbol = customCurrencySymbolInput.value || "$";
        if (currencyPrefix) currencyPrefix.textContent = currentCurrencySymbol;
        currencySymbols.forEach(el => el.textContent = currentCurrencySymbol);
        calculate();
      }
    });
    customCurrencyCodeInput?.addEventListener("input", () => {
      if (currentCurrency === "Custom") {
        currentCurrencyCode = customCurrencyCodeInput.value || "USD";
        calculate();
      }
    });

    // Quick presets
    presetYearButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const val = btn.getAttribute("data-year") || "10";
        timeInput.value = val;
        timeRange.value = val;
        updatePresetsUI();
        calculate();
      });
    });

    compoundFreqButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const freq = btn.getAttribute("data-freq") || "monthly";
        currentCompounding = freq;
        updatePresetsUI();
        calculate();
      });
    });

    contribMonthlyBtn?.addEventListener("click", () => toggleContribFreq(false));
    contribAnnuallyBtn?.addEventListener("click", () => toggleContribFreq(true));
    timingBeginningBtn?.addEventListener("click", () => toggleTiming(true));
    timingEndBtn?.addEventListener("click", () => toggleTiming(false));

    // Advanced Options accordion
    advancedToggleBtn?.addEventListener("click", () => {
      const isCollapsed = advancedPanel?.style.maxHeight === "0px" || !advancedPanel?.style.maxHeight;
      if (isCollapsed && advancedPanel && advancedChevron) {
        advancedPanel.style.maxHeight = "500px";
        advancedChevron.style.transform = "rotate(180deg)";
      } else if (advancedPanel && advancedChevron) {
        advancedPanel.style.maxHeight = "0px";
        advancedChevron.style.transform = "rotate(0deg)";
      }
    });

    // Detailed table show / collapse trigger
    toggleScheduleBtn?.addEventListener("click", () => {
      showFullSchedule = !showFullSchedule;
      renderTable();
    });

    // Copy, CSV & Reset
    copyResultsBtn?.addEventListener("click", copyResults);
    csvExportBtn?.addEventListener("click", exportToCSV);
    tableCsvExportBtn?.addEventListener("click", exportToCSV);
    tableExcelExportBtn?.addEventListener("click", exportToExcel);

    resetBtn?.addEventListener("click", () => {
      principalInput.value = "10000";
      interestInput.value = "8.0";
      interestRange.value = "8.0";
      timeInput.value = "10";
      timeRange.value = "10";
      contribInput.value = "500";
      inflationInput.value = "0.0";
      taxInput.value = "0.0";
      currentCompounding = "monthly";
      isAnnualContribution = false;
      isBeginningTiming = true;
      showFullSchedule = false;
      setDefaultStartDate();
      if (currencySelect) {
        currencySelect.value = "USD";
      }
      if (customCurrencySymbolInput) customCurrencySymbolInput.value = "$";
      if (customCurrencyCodeInput) customCurrencyCodeInput.value = "USD";
      updateCurrencyFromSelect();
      toggleContribFreq(false);
      toggleTiming(true);
      updatePresetsUI();
      calculate();
    });

    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }

    // Scroll buttons
    viewResultsBtn?.addEventListener("click", () => {
      scrollToElementWithOffset("results-section", 80);
    });
    mobileScrollBtn?.addEventListener("click", () => {
      scrollToElementWithOffset("hero-section", 80);
    });

    // Sticky mobile bar scroll reveal
    window.addEventListener("scroll", () => {
      const stickyBar = document.getElementById("mobile-sticky-bar");
      const heroSection = document.getElementById("hero-section");
      if (stickyBar && heroSection) {
        const heroRect = heroSection.getBoundingClientRect();
        if (window.scrollY > 100 && heroRect.top > 90) {
          stickyBar.style.transform = "translateY(0)";
        } else {
          stickyBar.style.transform = "translateY(100%)";
        }
      }
    });

    // Info Modal Events
    infoModalBtn?.addEventListener("click", () => {
      infoModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      infoModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      infoModal?.classList.add("hidden");
    });

    // Share button copy link logic
    const shareBtn = document.getElementById("share-btn");
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      if (currencySelect) url.searchParams.set("currency", currencySelect.value);
      if (customCurrencySymbolInput) url.searchParams.set("custom-symbol", customCurrencySymbolInput.value);
      if (customCurrencyCodeInput) url.searchParams.set("custom-code", customCurrencyCodeInput.value);
      url.searchParams.set("principal", principalInput.value);
      url.searchParams.set("interest", interestInput.value);
      url.searchParams.set("time", timeInput.value);
      url.searchParams.set("compounding", currentCompounding);
      url.searchParams.set("contrib", contribInput.value);
      url.searchParams.set("contrib-freq", isAnnualContribution ? "annually" : "monthly");
      url.searchParams.set("timing", isBeginningTiming ? "beginning" : "end");
      url.searchParams.set("start-date", startDateInput.value);
      url.searchParams.set("inflation", inflationInput.value);
      url.searchParams.set("tax", taxInput.value);

      const shareData = {
        title: document.title || "Toolkify",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      // Show success popup helper
      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });
    infoModal?.addEventListener("click", (e) => {
      if (e.target === infoModal) {
        infoModal.classList.add("hidden");
      }
    });

    // Initialize Page
    setDefaultStartDate();
    loadState();
    updatePresetsUI();
    calculate();
  </script>
</Layout>
