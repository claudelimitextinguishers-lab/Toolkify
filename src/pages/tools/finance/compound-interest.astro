      html += `<tr style="background-color: #f1f5f9; font-weight: bold;">`;
      html += `<th>Year</th><th>Contributions (Yr)</th><th>Interest Earned (Yr)</th><th>Cumulative Contributed</th><th>Cumulative Interest</th><th>Ending Balance</th>`;
      html += `</tr>`;
      html += `</thead><tbody>`;
      
      yearlyScheduleData.forEach(row => {
        html += `<tr>`;
