      <!-- Growth Schedule Table Card -->
      <div class="card-base flex flex-col gap-4 p-4 sm:p-5 mt-2">
        <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 border-b border-hairline pb-2">
          <h3 class="font-display font-semibold text-sm sm:text-base text-primary">Annual Compounding Growth Schedule</h3>
        </div>

        <div class="w-full overflow-x-auto">
          <table class="w-full text-left text-xs border-collapse">
