  <!-- Mobile Sticky Summary Bar (lg:hidden) -->
  <div
    id="mobile-sticky-bar"
    class="fixed bottom-0 left-0 right-0 z-40 bg-canvas/95 backdrop-blur-md border-t border-hairline py-3 px-4 flex items-center justify-between shadow-[0_-4px_12px_rgba(5,0,56,0.06)] lg:hidden transition-transform duration-300 translate-y-0"
  >
    <div class="flex flex-col">
      <span class="text-[10px] uppercase font-bold text-stone">Future Value</span>
      <span id="mobile-summary-value" class="font-display font-bold text-lg text-primary font-mono">$0.00</span>
    </div>
    <button
      type="button"
      id="mobile-scroll-results-btn"
      class="button-primary text-xs !py-2 !px-4 !rounded-full shadow-subtle hover:scale-105 active:scale-95 transition-all cursor-pointer"
    >
      View Results &rarr;
    </button>
  </div>

  <!-- Help / Info Modal -->
  <div
    id="info-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto">
      <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
        <h3 class="font-display font-semibold text-lg text-primary">How Compound Interest Works</h3>
        <button
          type="button"
          id="close-modal-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >
          ✕
        </button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">1. What is Compound Interest?</h4>
        <p>
          Unlike simple interest, which is earned only on the initial principal, compound interest is earned on both the initial principal and all accumulated interest from previous periods. It creates an exponential growth curve.
        </p>

        <h4 class="font-semibold text-primary">2. The Impact of Compounding Frequency</h4>
        <p>
          The more frequently interest compounds (e.g., Daily vs Annually), the faster your balance grows. Daily compounding yields slightly more than monthly or annual compounding because gains are reinvested sooner.
        </p>

        <h4 class="font-semibold text-primary">3. Regular Contributions & Timing</h4>
        <p>
          Adding regular contributions dramatically multiplies the final returns. Making contributions at the **Beginning** of compounding periods rather than the **End** gives your cash an extra period to earn interest, noticeably increasing final future value over long time horizons.
        </p>

        <h4 class="font-semibold text-primary">4. Real Value vs Nominal Value</h4>
        <p>
          Inflation reduces the purchasing power of your money over time. While your nominal balance grows to a large number, the **Real Value** adjusts that future sum to show what it would buy in today's dollars.
        </p>

        <h4 class="font-semibold text-primary">5. Tax Drag</h4>
        <p>
          Taxes on investment gains reduce the final amount you take home. Our engine simulates a post-tax return where the tax rate is applied to the earned interest portion at the end of the term.
        </p>
      </div>
      <button
        type="button"
        id="modal-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
      </button>
    </div>
  </div>

  <!-- Client-side script logic -->
  <script>
    // State variables
    let currentCurrency = "USD";
    let currentCurrencySymbol = "$";
    let currentCurrencyCode = "USD";
    let isAnnualContribution = false;
    let currentCompounding = "monthly";
    let isBeginningTiming = true;
    let showFullSchedule = false;
    let yearlyScheduleData: any[] = [];

    // DOM Elements
    const principalInput = document.getElementById("principal-amount") as HTMLInputElement;
    const interestRange = document.getElementById("interest-rate-range") as HTMLInputElement;
    const interestInput = document.getElementById("interest-rate") as HTMLInputElement;
    const interestLabel = document.getElementById("interest-rate-label");
    const timeRange = document.getElementById("time-period-range") as HTMLInputElement;
    const timeInput = document.getElementById("time-period") as HTMLInputElement;
    const timeLabel = document.getElementById("time-period-label");
    const contribInput = document.getElementById("contribution-amount") as HTMLInputElement;
    const startDateInput = document.getElementById("start-date") as HTMLInputElement;
    const inflationInput = document.getElementById("inflation-rate") as HTMLInputElement;
    const taxInput = document.getElementById("tax-rate") as HTMLInputElement;

    const currencySelect = document.getElementById("currency-select") as HTMLSelectElement;
    const customCurrencySymbolInput = document.getElementById("custom-currency-symbol") as HTMLInputElement;
    const customCurrencyCodeInput = document.getElementById("custom-currency-code") as HTMLInputElement;
    const customCurrencyContainer = document.getElementById("custom-currency-container");
    const currencyPrefix = document.getElementById("currency-prefix");
    const currencySymbols = document.querySelectorAll(".currency-symbol");

    const presetYearButtons = document.querySelectorAll(".preset-year-btn");
    const compoundFreqButtons = document.querySelectorAll(".compound-freq-btn");
    const contribMonthlyBtn = document.getElementById("contrib-monthly");
    const contribAnnuallyBtn = document.getElementById("contrib-annually");

    const timingBeginningBtn = document.getElementById("timing-beginning");
    const timingEndBtn = document.getElementById("timing-end");

    const advancedToggleBtn = document.getElementById("advanced-toggle-btn");
    const advancedPanel = document.getElementById("advanced-panel");
    const advancedChevron = document.getElementById("advanced-chevron");

    const heroFutureValue = document.getElementById("hero-future-value");
    const heroContributed = document.getElementById("hero-contributed");
    const heroInterest = document.getElementById("hero-interest");
    const badgeRealVal = document.getElementById("badge-real-val");
    const badgeTaxVal = document.getElementById("badge-tax-val");
    const badgeTargetDate = document.getElementById("badge-target-date");
    const adjustedRealBadge = document.getElementById("adjusted-real-badge");
    const adjustedTaxBadge = document.getElementById("adjusted-tax-badge");

    const impactNominalVal = document.getElementById("impact-nominal-val");
    const impactRealVal = document.getElementById("impact-real-val");
    const inflationImpactDesc = document.getElementById("inflation-impact-desc");
    const impactPretaxGains = document.getElementById("impact-pretax-gains");
    const impactPosttaxVal = document.getElementById("impact-posttax-val");
    const taxImpactDesc = document.getElementById("tax-impact-desc");

    const tableBody = document.getElementById("growth-table-body");
    const toggleScheduleBtn = document.getElementById("toggle-schedule-btn") as HTMLButtonElement;
    const copyResultsBtn = document.getElementById("copy-results-btn");
    const csvExportBtn = document.getElementById("csv-export-btn");
    const resetBtn = document.getElementById("reset-btn");
    const viewResultsBtn = document.getElementById("view-results-btn");
    const mobileScrollBtn = document.getElementById("mobile-scroll-results-btn");

    const infoModalBtn = document.getElementById("info-modal-btn");
    const infoModal = document.getElementById("info-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    // Currency Formatting Utility
    function formatVal(value: number): string {
      const locale = currentCurrencyCode === "INR" ? "en-IN" : undefined;
      return (
        currentCurrencySymbol +
        value.toLocaleString(locale, {
          minimumFractionDigits: 0,
          maximumFractionDigits: 0,
        })
      );
    }

    // Set Default Start Date
    function setDefaultStartDate() {
      const d = new Date();
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      startDateInput.value = `${d.getFullYear()}-${month}-${day}`;
    }

    // Calculate Maturity Date
    function getMaturityDate(years: number): string {
      const start = startDateInput.value ? new Date(startDateInput.value) : new Date();
      start.setFullYear(start.getFullYear() + years);
      return start.toLocaleDateString("en-US", { month: "long", year: "numeric" });
    }

    // Update Presets UI Highlight
    function updatePresetsUI() {
      const timeYr = parseInt(timeInput.value, 10);
      presetYearButtons.forEach(btn => {
        const val = parseInt(btn.getAttribute("data-year") || "0", 10);
        if (val === timeYr) {
          btn.classList.add("bg-primary", "text-canvas", "border-primary");
          btn.classList.remove("bg-canvas", "text-slate", "border-hairline");
        } else {
          btn.classList.remove("bg-primary", "text-canvas", "border-primary");
          btn.classList.add("bg-canvas", "text-slate", "border-hairline");
        }
      });

      compoundFreqButtons.forEach(btn => {
        const val = btn.getAttribute("data-freq");
        if (val === currentCompounding) {
          btn.classList.add("bg-primary", "text-canvas", "border-primary");
          btn.classList.remove("bg-canvas", "text-slate", "border-hairline");
        } else {
          btn.classList.remove("bg-primary", "text-canvas", "border-primary");
          btn.classList.add("bg-canvas", "text-slate", "border-hairline");
        }
      });
    }

    // Local Storage State Persistence
    function loadState() {
      try {
        const savedCurrency = localStorage.getItem("ci-calc-currency");
        const savedCustomSymbol = localStorage.getItem("ci-calc-custom-symbol");
        const savedCustomCode = localStorage.getItem("ci-calc-custom-code");
        const savedPrincipal = localStorage.getItem("ci-calc-principal");
        const savedInterest = localStorage.getItem("ci-calc-interest");
        const savedTime = localStorage.getItem("ci-calc-time");
        const savedCompounding = localStorage.getItem("ci-calc-compounding");
        const savedContrib = localStorage.getItem("ci-calc-contrib");
        const savedContribFreq = localStorage.getItem("ci-calc-contrib-freq");
        const savedTiming = localStorage.getItem("ci-calc-timing");
        const savedStartDate = localStorage.getItem("ci-calc-start-date");
        const savedInflation = localStorage.getItem("ci-calc-inflation");
        const savedTax = localStorage.getItem("ci-calc-tax");

        if (savedCustomSymbol && customCurrencySymbolInput) {
          customCurrencySymbolInput.value = savedCustomSymbol;
        }
        if (savedCustomCode && customCurrencyCodeInput) {
          customCurrencyCodeInput.value = savedCustomCode;
        }
        if (savedCurrency && currencySelect) {
          currencySelect.value = savedCurrency;
        }
        updateCurrencyFromSelect();

        if (savedPrincipal) principalInput.value = savedPrincipal;
        if (savedInterest) {
          interestInput.value = savedInterest;
          interestRange.value = savedInterest;
        }
        if (savedTime) {
          timeInput.value = savedTime;
          timeRange.value = savedTime;
        }
        if (savedCompounding) currentCompounding = savedCompounding;
        if (savedContrib) contribInput.value = savedContrib;
        if (savedContribFreq) toggleContribFreq(savedContribFreq === "annually");
        if (savedTiming) toggleTiming(savedTiming === "beginning");
        if (savedStartDate) startDateInput.value = savedStartDate;
        if (savedInflation) inflationInput.value = savedInflation;
        if (savedTax) taxInput.value = savedTax;
      } catch (e) {
        console.warn("Storage read failure", e);
      }
    }

    // Save State Persistence
    function saveState() {
      try {
        localStorage.setItem("ci-calc-currency", currentCurrency);
        localStorage.setItem("ci-calc-custom-symbol", currentCurrencySymbol);
        localStorage.setItem("ci-calc-custom-code", currentCurrencyCode);
        localStorage.setItem("ci-calc-principal", principalInput.value);
        localStorage.setItem("ci-calc-interest", interestInput.value);
        localStorage.setItem("ci-calc-time", timeInput.value);
        localStorage.setItem("ci-calc-compounding", currentCompounding);
        localStorage.setItem("ci-calc-contrib", contribInput.value);
        localStorage.setItem("ci-calc-contrib-freq", isAnnualContribution ? "annually" : "monthly");
        localStorage.setItem("ci-calc-timing", isBeginningTiming ? "beginning" : "end");
        localStorage.setItem("ci-calc-start-date", startDateInput.value);
        localStorage.setItem("ci-calc-inflation", inflationInput.value);
        localStorage.setItem("ci-calc-tax", taxInput.value);
      } catch (e) {
        console.warn("Storage write failure", e);
      }
    }

    // Update Currency Choice
    function updateCurrencyFromSelect() {
      if (!currencySelect) return;
      const val = currencySelect.value;
      currentCurrency = val;

      if (val === "USD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "USD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "CAD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "CAD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "GBP") {
        currentCurrencySymbol = "£";
        currentCurrencyCode = "GBP";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "AUD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "AUD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "EUR") {
        currentCurrencySymbol = "€";
        currentCurrencyCode = "EUR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "INR") {
        currentCurrencySymbol = "₹";
        currentCurrencyCode = "INR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "Custom") {
        customCurrencyContainer?.classList.remove("hidden");
        currentCurrencySymbol = customCurrencySymbolInput?.value || "$";
        currentCurrencyCode = customCurrencyCodeInput?.value || "USD";
      }

      if (currencyPrefix) currencyPrefix.textContent = currentCurrencySymbol;
      currencySymbols.forEach(el => el.textContent = currentCurrencySymbol);
      calculate();
    }

    // Toggle timing options
    function toggleTiming(isBeginning: boolean) {
      isBeginningTiming = isBeginning;
      if (isBeginning) {
        timingBeginningBtn?.classList.add("bg-primary", "text-canvas");
        timingBeginningBtn?.classList.remove("text-slate");
        timingEndBtn?.classList.remove("bg-primary", "text-canvas");
        timingEndBtn?.classList.add("text-slate");
      } else {
        timingEndBtn?.classList.add("bg-primary", "text-canvas");
        timingEndBtn?.classList.remove("text-slate");
        timingBeginningBtn?.classList.remove("bg-primary", "text-canvas");
        timingBeginningBtn?.classList.add("text-slate");
      }
      calculate();
    }

    // Toggle contribution frequency
    function toggleContribFreq(isAnnual: boolean) {
      isAnnualContribution = isAnnual;
      if (isAnnual) {
        contribAnnuallyBtn?.classList.add("bg-primary", "text-canvas");
        contribAnnuallyBtn?.classList.remove("text-slate");
        contribMonthlyBtn?.classList.remove("bg-primary", "text-canvas");
        contribMonthlyBtn?.classList.add("text-slate");
      } else {
        contribMonthlyBtn?.classList.add("bg-primary", "text-canvas");
        contribMonthlyBtn?.classList.remove("text-slate");
        contribAnnuallyBtn?.classList.remove("bg-primary", "text-canvas");
        contribAnnuallyBtn?.classList.add("text-slate");
      }
      calculate();
    }

    // Main Calculations Engine
    function calculate() {
      const principal = Math.max(0, parseFloat(principalInput.value) || 0);
      const interestRate = Math.max(0, parseFloat(interestInput.value) || 0) / 100;
      const years = Math.max(1, parseInt(timeInput.value, 10) || 1);
      const contribution = Math.max(0, parseFloat(contribInput.value) || 0);
      const inflationRate = Math.max(0, parseFloat(inflationInput.value) || 0) / 100;
      const taxRate = Math.max(0, parseFloat(taxInput.value) || 0) / 100;

      // Update Labels
      if (interestLabel) interestLabel.textContent = `${(interestRate * 100).toFixed(1)}%`;
      if (timeLabel) timeLabel.textContent = `${years} year${years > 1 ? 's' : ''}`;

      // Reset array data
      yearlyScheduleData = [];

      let balance = principal;
      let cumContributions = principal;
      let cumInterest = 0;

      // Loop year-by-year, and month-by-month inside
      for (let y = 1; y <= years; y++) {
        let yrContrib = 0;
        let yrInterestStart = cumInterest;
        let yrContribStart = cumContributions;

        for (let m = 1; m <= 12; m++) {
          // Monthly Contributions
          if (!isAnnualContribution) {
            if (isBeginningTiming) {
              balance += contribution;
              cumContributions += contribution;
              yrContrib += contribution;
            }
          }

          // Annual Contributions at Month 1 (Beginning)
          if (isAnnualContribution && m === 1 && isBeginningTiming) {
            balance += contribution;
            cumContributions += contribution;
            yrContrib += contribution;
          }

          // Compounding Growth Calculations
          let compoundFactor = 0;
          if (currentCompounding === "monthly") {
            compoundFactor = interestRate / 12;
            balance *= (1 + compoundFactor);
          } else if (currentCompounding === "quarterly" && m % 3 === 0) {
            compoundFactor = interestRate / 4;
            balance *= (1 + compoundFactor);
          } else if (currentCompounding === "annually" && m === 12) {
            compoundFactor = interestRate;
            balance *= (1 + compoundFactor);
          } else if (currentCompounding === "daily") {
            const daysInMonth = 30.436875;
            compoundFactor = Math.pow(1 + interestRate / 365, daysInMonth) - 1;
            balance *= (1 + compoundFactor);
          }

          // Monthly Contributions (End of period)
          if (!isAnnualContribution && !isBeginningTiming) {
            balance += contribution;
            cumContributions += contribution;
            yrContrib += contribution;
          }

          // Annual Contributions at Month 12 (End of period)
          if (isAnnualContribution && m === 12 && !isBeginningTiming) {
            balance += contribution;
            cumContributions += contribution;
            yrContrib += contribution;
          }
        }

        const totalGrowthThisYear = balance - yrContribStart - yrContrib;
        cumInterest += totalGrowthThisYear;

        yearlyScheduleData.push({
          year: y,
          contributionsThisYear: yrContrib,
          interestThisYear: totalGrowthThisYear,
          cumulativeContributions: cumContributions,
          cumulativeInterest: cumInterest,
          endingBalance: balance
        });
      }

      // Calculations details outputs
      const futureVal = balance;
      const totalContributed = cumContributions;
      const totalInterest = futureVal - totalContributed;

      // Inflation adjustment: FV / (1 + inf)^years
      const realValue = futureVal / Math.pow(1 + inflationRate, years);
      // Tax adjustment: principal + contributions + (totalInterest * (1 - taxRate))
      const postTaxValue = totalContributed + (totalInterest * (1 - taxRate));

      // Display key numbers above the fold
      if (heroFutureValue) heroFutureValue.textContent = formatVal(futureVal);
      if (heroContributed) heroContributed.textContent = formatVal(totalContributed);
      if (heroInterest) heroInterest.textContent = formatVal(totalInterest);

      const formattedMaturity = getMaturityDate(years);
      if (badgeTargetDate) badgeTargetDate.textContent = formattedMaturity;

      // Mobile sticky update
      const mobileVal = document.getElementById("mobile-summary-value");
      if (mobileVal) mobileVal.textContent = formatVal(futureVal);

      // Inflation impact block
      if (inflationRate > 0) {
        adjustedRealBadge?.classList.remove("hidden");
        if (badgeRealVal) badgeRealVal.textContent = formatVal(realValue);
        if (impactNominalVal) impactNominalVal.textContent = formatVal(futureVal);
        if (impactRealVal) impactRealVal.textContent = formatVal(realValue);
        if (inflationImpactDesc) {
          const loss = futureVal - realValue;
          inflationImpactDesc.innerHTML = `Over ${years} years, inflation of ${(inflationRate*100).toFixed(1)}% reduces your purchasing power by <strong class="text-brand-blue">${formatVal(loss)}</strong> in today's money.`;
        }
      } else {
        adjustedRealBadge?.classList.add("hidden");
        if (impactNominalVal) impactNominalVal.textContent = formatVal(futureVal);
        if (impactRealVal) impactRealVal.textContent = formatVal(futureVal);
        if (inflationImpactDesc) {
          inflationImpactDesc.textContent = "Enter an inflation rate in Advanced Options to calculate real returns adjusted for future purchasing power.";
        }
      }

      // Tax impact block
      if (taxRate > 0) {
        adjustedTaxBadge?.classList.remove("hidden");
        if (badgeTaxVal) badgeTaxVal.textContent = formatVal(postTaxValue);
        if (impactPretaxGains) impactPretaxGains.textContent = formatVal(totalInterest);
        if (impactPosttaxVal) impactPosttaxVal.textContent = formatVal(postTaxValue);
        if (taxImpactDesc) {
          const taxesPaid = totalInterest * taxRate;
          taxImpactDesc.innerHTML = `Estimated tax liability on accumulated gains at maturity is <strong class="text-brand-coral">${formatVal(taxesPaid)}</strong> (calculated at ${(taxRate*100).toFixed(1)}%).`;
        }
      } else {
        adjustedTaxBadge?.classList.add("hidden");
        if (impactPretaxGains) impactPretaxGains.textContent = formatVal(totalInterest);
        if (impactPosttaxVal) impactPosttaxVal.textContent = formatVal(futureVal);
        if (taxImpactDesc) {
          taxImpactDesc.textContent = "Enter a tax rate in Advanced Options to check estimated post-tax investment values.";
        }
      }

      renderTable();
      renderChart(principal, futureVal);
      saveState();
    }

    // Render Table Rows (dynamic limits)
    function renderTable() {
      if (!tableBody) return;
      tableBody.innerHTML = "";

      const visibleRows = showFullSchedule ? yearlyScheduleData.length : Math.min(5, yearlyScheduleData.length);

      for (let i = 0; i < visibleRows; i++) {
        const row = yearlyScheduleData[i];
        const tr = document.createElement("tr");
        tr.className = "border-b border-hairline-soft hover:bg-surface-soft/40 font-mono transition-colors";
        tr.innerHTML = `
          <td class="py-2.5 px-3 font-semibold text-primary">Year ${row.year}</td>
          <td class="py-2.5 px-3 text-right text-slate">${formatVal(row.contributionsThisYear)}</td>
          <td class="py-2.5 px-3 text-right text-success-accent">+${formatVal(row.interestThisYear)}</td>
          <td class="py-2.5 px-3 text-right text-slate">${formatVal(row.cumulativeContributions)}</td>
          <td class="py-2.5 px-3 text-right text-slate">${formatVal(row.cumulativeInterest)}</td>
          <td class="py-2.5 px-3 text-right font-bold text-primary">${formatVal(row.endingBalance)}</td>
        `;
        tableBody.appendChild(tr);
      }

      if (toggleScheduleBtn) {
        if (showFullSchedule) {
          toggleScheduleBtn.textContent = `Collapse Schedule (Show 5 Years)`;
        } else {
          toggleScheduleBtn.textContent = `Show Full Year-by-Year Schedule (${yearlyScheduleData.length} Years)`;
        }
      }
    }

    // Render SVG Stacked Bar Chart
    function renderChart(principal: number, futureVal: number) {
      const svg = document.getElementById("growth-svg");
      if (!svg) return;
      svg.innerHTML = "";

      const numYears = yearlyScheduleData.length;
      const width = 600;
      const height = 260;
      const paddingLeft = 60;
      const paddingRight = 20;
      const paddingTop = 20;
      const paddingBottom = 30;

      const chartWidth = width - paddingLeft - paddingRight;
      const chartHeight = height - paddingTop - paddingBottom;

      const maxVal = futureVal || 1000;

      // Add Grid Lines
      const gridCount = 5;
      for (let i = 0; i <= gridCount; i++) {
        const yVal = maxVal * (i / gridCount);
        const yPos = height - paddingBottom - (chartHeight * (i / gridCount));

        // Line
        const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
        line.setAttribute("x1", paddingLeft.toString());
        line.setAttribute("y1", yPos.toString());
        line.setAttribute("x2", (width - paddingRight).toString());
        line.setAttribute("y2", yPos.toString());
        line.setAttribute("stroke", "var(--color-hairline-soft)");
        line.setAttribute("stroke-width", "1");
        if (i > 0) line.setAttribute("stroke-dasharray", "3,3");
        svg.appendChild(line);

        // Text Y labels
        const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
        text.setAttribute("x", (paddingLeft - 8).toString());
        text.setAttribute("y", (yPos + 4).toString());
        text.setAttribute("text-anchor", "end");
        text.setAttribute("font-size", "9px");
        text.setAttribute("font-family", "monospace");
        text.setAttribute("fill", "var(--color-stone)");

        // Format short numbers
        let formattedLabel = formatVal(yVal);
        if (yVal >= 1000000) formattedLabel = currentCurrencySymbol + (yVal / 1000000).toFixed(1) + "M";
        else if (yVal >= 1000) formattedLabel = currentCurrencySymbol + (yVal / 1000).toFixed(0) + "K";
        text.textContent = formattedLabel;
        svg.appendChild(text);
      }

      // Render Bar Columns
      const barWidth = Math.max(4, Math.floor(chartWidth / numYears) - 4);
      const tooltip = document.getElementById("chart-tooltip");

      yearlyScheduleData.forEach((data, index) => {
        const xPos = paddingLeft + (index * (chartWidth / numYears)) + ((chartWidth / numYears - barWidth) / 2);

        // Segment ratios
        const balanceTotal = data.endingBalance;
        const interestAmt = data.cumulativeInterest;
        const contribAmt = data.cumulativeContributions - principal;
        const principalAmt = principal;

        // Heights
        const hPrincipal = (principalAmt / maxVal) * chartHeight;
        const hContrib = (contribAmt / maxVal) * chartHeight;
        const hInterest = (interestAmt / maxVal) * chartHeight;

        const yPrincipal = height - paddingBottom - hPrincipal;
        const yContrib = yPrincipal - hContrib;
        const yInterest = yContrib - hInterest;

        // Principal Segment (Blue)
        const rectPrincipal = document.createElementNS("http://www.w3.org/2000/svg", "rect");
        rectPrincipal.setAttribute("x", xPos.toString());
        rectPrincipal.setAttribute("y", yPrincipal.toString());
        rectPrincipal.setAttribute("width", barWidth.toString());
        rectPrincipal.setAttribute("height", hPrincipal.toString());
        rectPrincipal.setAttribute("fill", "#4262ff"); // brand blue
        svg.appendChild(rectPrincipal);

        // Contributions Segment (Coral)
        if (hContrib > 0) {
          const rectContrib = document.createElementNS("http://www.w3.org/2000/svg", "rect");
          rectContrib.setAttribute("x", xPos.toString());
          rectContrib.setAttribute("y", yContrib.toString());
          rectContrib.setAttribute("width", barWidth.toString());
          rectContrib.setAttribute("height", hContrib.toString());
          rectContrib.setAttribute("fill", "#ff9999"); // brand coral
          svg.appendChild(rectContrib);
        }

        // Interest Segment (Yellow)
        if (hInterest > 0) {
          const rectInterest = document.createElementNS("http://www.w3.org/2000/svg", "rect");
          rectInterest.setAttribute("x", xPos.toString());
          rectInterest.setAttribute("y", yInterest.toString());
          rectInterest.setAttribute("width", barWidth.toString());
          rectInterest.setAttribute("height", hInterest.toString());
          rectInterest.setAttribute("fill", "#fcb900"); // yellow deep
          svg.appendChild(rectInterest);
        }

        // Invisible trigger bar for tooltip interactions
        const trigger = document.createElementNS("http://www.w3.org/2000/svg", "rect");
        trigger.setAttribute("x", xPos.toString());
        trigger.setAttribute("y", paddingTop.toString());
        trigger.setAttribute("width", barWidth.toString());
        trigger.setAttribute("height", chartHeight.toString());
        trigger.setAttribute("fill", "transparent");
        trigger.style.cursor = "pointer";

        trigger.addEventListener("mouseenter", (e) => {
          if (tooltip) {
            tooltip.classList.remove("hidden");
            tooltip.innerHTML = `
              <div class="font-bold text-center border-b border-hairline pb-1 mb-1 text-primary">Year ${data.year}</div>
              <div>Principal: <span class="font-semibold text-brand-blue">${formatVal(principalAmt)}</span></div>
              <div>Contributions: <span class="font-semibold text-brand-coral">${formatVal(contribAmt)}</span></div>
              <div>Interest: <span class="font-semibold text-brand-yellow-deep">${formatVal(interestAmt)}</span></div>
              <div class="font-bold pt-1 border-t border-hairline mt-1">Total: <span class="text-success-accent">${formatVal(balanceTotal)}</span></div>
            `;
            
            // move positioning AFTER removing hidden, so offsetWidth is readable
            const rect = (e.target as SVGElement).getBoundingClientRect();
            const parentRect = tooltip.parentElement?.getBoundingClientRect();
            if (parentRect) {
              let tooltipLeft = rect.left - parentRect.left + (barWidth / 2) - 60;
              const tooltipTop = rect.top - parentRect.top - 100;
              
              // Clamp left and right edges so tooltip doesn't overflow parent container
              tooltipLeft = Math.max(5, tooltipLeft);
              const tooltipWidth = tooltip.offsetWidth || 120;
              if (tooltipLeft + tooltipWidth > parentRect.width - 5) {
                tooltipLeft = parentRect.width - tooltipWidth - 5;
              }
              
              tooltip.style.left = `${tooltipLeft}px`;
              tooltip.style.top = `${Math.max(5, tooltipTop)}px`;
            }
          }
        });

        trigger.addEventListener("mouseleave", () => {
          tooltip?.classList.add("hidden");
        });

        svg.appendChild(trigger);

        // Add X Labels dynamically (Years)
        if (numYears <= 15 || (index % Math.ceil(numYears / 10) === 0) || index === numYears - 1) {
          const textX = document.createElementNS("http://www.w3.org/2000/svg", "text");
          textX.setAttribute("x", (xPos + barWidth / 2).toString());
          textX.setAttribute("y", (height - paddingBottom + 16).toString());
          textX.setAttribute("text-anchor", "middle");
          textX.setAttribute("font-size", "9px");
          textX.setAttribute("font-family", "monospace");
          textX.setAttribute("fill", "var(--color-slate)");
          textX.textContent = `Yr ${data.year}`;
          svg.appendChild(textX);
        }
      });
    }

    // Export CSV Utility
    function exportToCSV() {
      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Year,Annual Contributions,Annual Interest,Cumulative Contributions,Cumulative Interest,Ending Balance\n";

      yearlyScheduleData.forEach(row => {
        csvContent += `${row.year},${row.contributionsThisYear.toFixed(2)},${row.interestThisYear.toFixed(2)},${row.cumulativeContributions.toFixed(2)},${row.cumulativeInterest.toFixed(2)},${row.endingBalance.toFixed(2)}\n`;
      });

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", `compound_interest_schedule_${currentCurrency}.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    // Copy Results Utility
    function copyResults() {
      const text = `
Compound Interest Projection Summary:
------------------------------------
Maturity Date: ${getMaturityDate(parseInt(timeInput.value, 10))}
Projected Future Value: ${heroFutureValue?.textContent}
Total Contributed: ${heroContributed?.textContent}
Total Interest Earned: ${heroInterest?.textContent}
Inflation Adjusted Value: ${badgeRealVal?.textContent || "N/A"}
Post-Tax Value: ${badgeTaxVal?.textContent || "N/A"}
Calculated 100% privately via BoardTools.
      `.trim();

      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyResultsBtn ? copyResultsBtn.innerHTML : "";
        if (copyResultsBtn) {
          copyResultsBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-success-accent">Copied!</span>
          `;
          setTimeout(() => {
            copyResultsBtn.innerHTML = originalText;
          }, 2000);
        }
      });
    }

    // Register Event Listeners
    principalInput?.addEventListener("input", calculate);
    
    // Sliders sync with numeric fields
    interestRange?.addEventListener("input", (e) => {
      interestInput.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    interestInput?.addEventListener("input", (e) => {
      interestRange.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    interestInput?.addEventListener("blur", () => {
      interestInput.value = Math.max(0.1, Math.min(100, parseFloat(interestInput.value) || 8)).toFixed(2);
      interestRange.value = interestInput.value;
      calculate();
    });

    timeRange?.addEventListener("input", (e) => {
      timeInput.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    timeInput?.addEventListener("input", (e) => {
      timeRange.value = (e.target as HTMLInputElement).value;
      calculate();
    });
    timeInput?.addEventListener("blur", () => {
      timeInput.value = Math.max(1, Math.min(100, parseInt(timeInput.value, 10) || 10)).toString();
      timeRange.value = timeInput.value;
      calculate();
    });

    contribInput?.addEventListener("input", calculate);
    startDateInput?.addEventListener("input", calculate);
    inflationInput?.addEventListener("input", calculate);
    taxInput?.addEventListener("input", calculate);

    // Currency controls
    currencySelect?.addEventListener("change", updateCurrencyFromSelect);
    customCurrencySymbolInput?.addEventListener("input", () => {
      if (currentCurrency === "Custom") {
        currentCurrencySymbol = customCurrencySymbolInput.value || "$";
        if (currencyPrefix) currencyPrefix.textContent = currentCurrencySymbol;
        currencySymbols.forEach(el => el.textContent = currentCurrencySymbol);
        calculate();
      }
    });
    customCurrencyCodeInput?.addEventListener("input", () => {
      if (currentCurrency === "Custom") {
        currentCurrencyCode = customCurrencyCodeInput.value || "USD";
        calculate();
      }
    });

    // Quick presets
    presetYearButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const val = btn.getAttribute("data-year") || "10";
        timeInput.value = val;
        timeRange.value = val;
        updatePresetsUI();
        calculate();
      });
    });

    compoundFreqButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const freq = btn.getAttribute("data-freq") || "monthly";
        currentCompounding = freq;
        updatePresetsUI();
        calculate();
      });
    });

    contribMonthlyBtn?.addEventListener("click", () => toggleContribFreq(false));
    contribAnnuallyBtn?.addEventListener("click", () => toggleContribFreq(true));
    timingBeginningBtn?.addEventListener("click", () => toggleTiming(true));
    timingEndBtn?.addEventListener("click", () => toggleTiming(false));

    // Advanced Options accordion
    advancedToggleBtn?.addEventListener("click", () => {
      const isCollapsed = advancedPanel?.style.maxHeight === "0px" || !advancedPanel?.style.maxHeight;
      if (isCollapsed && advancedPanel && advancedChevron) {
        advancedPanel.style.maxHeight = "500px";
        advancedChevron.style.transform = "rotate(180deg)";
      } else if (advancedPanel && advancedChevron) {
        advancedPanel.style.maxHeight = "0px";
        advancedChevron.style.transform = "rotate(0deg)";
      }
    });

    // Detailed table show / collapse trigger
    toggleScheduleBtn?.addEventListener("click", () => {
      showFullSchedule = !showFullSchedule;
      renderTable();
    });

    // Copy, CSV & Reset
    copyResultsBtn?.addEventListener("click", copyResults);
    csvExportBtn?.addEventListener("click", exportToCSV);

    resetBtn?.addEventListener("click", () => {
      principalInput.value = "10000";
      interestInput.value = "8.0";
      interestRange.value = "8.0";
      timeInput.value = "10";
      timeRange.value = "10";
      contribInput.value = "500";
      inflationInput.value = "0.0";
      taxInput.value = "0.0";
      currentCompounding = "monthly";
      isAnnualContribution = false;
      isBeginningTiming = true;
      showFullSchedule = false;
      setDefaultStartDate();
      if (currencySelect) {
        currencySelect.value = "USD";
      }
      if (customCurrencySymbolInput) customCurrencySymbolInput.value = "$";
      if (customCurrencyCodeInput) customCurrencyCodeInput.value = "USD";
      updateCurrencyFromSelect();
      toggleContribFreq(false);
      toggleTiming(true);
      updatePresetsUI();
      calculate();
    });

    // Scroll buttons
    viewResultsBtn?.addEventListener("click", () => {
      document.getElementById("results-section")?.scrollIntoView({ behavior: "smooth" });
    });
    mobileScrollBtn?.addEventListener("click", () => {
      document.getElementById("results-section")?.scrollIntoView({ behavior: "smooth" });
    });

    // Sticky mobile bar scroll reveal
    window.addEventListener("scroll", () => {
      const stickyBar = document.getElementById("mobile-sticky-bar");
      const resultsSection = document.getElementById("results-section");
      if (stickyBar && resultsSection) {
        const threshold = resultsSection.getBoundingClientRect().top + window.scrollY - 300;
        if (window.scrollY > 150 && window.scrollY < threshold) {
          stickyBar.style.transform = "translateY(0)";
        } else {
          stickyBar.style.transform = "translateY(100%)";
        }
      }
    });

    // Info Modal Events
    infoModalBtn?.addEventListener("click", () => {
      infoModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      infoModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      infoModal?.classList.add("hidden");
    });
    infoModal?.addEventListener("click", (e) => {
      if (e.target === infoModal) {
        infoModal.classList.add("hidden");
      }
    });

    // Initialize Page
    setDefaultStartDate();
    loadState();
    updatePresetsUI();
    calculate();
  </script>
</Layout>
