    // State Variables
    let currentFromCurrency = "USD";
    let currentToCurrency = "EUR";
    let currentActiveTarget: "from" | "to" = "from";
    let swapRotation = 0;

    // Local Storage keys matching pattern
    const STORAGE_KEY_PREFIX = "toolkify:currency-converter";
    const KEY_FROM = `${STORAGE_KEY_PREFIX}:from`;
    const KEY_TO = `${STORAGE_KEY_PREFIX}:to`;
    const KEY_AMOUNT = `${STORAGE_KEY_PREFIX}:amount`;
    const KEY_FAVORITE = `${STORAGE_KEY_PREFIX}:favorite-pair`;

    // Initialize State from Storage or Defaults
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      // Check saved favorite default pair
      const savedFavorite = localStorage.getItem(KEY_FAVORITE);
      let defaultFrom = "USD";
      let defaultTo = "EUR";
      
      if (savedFavorite) {
        const parts = savedFavorite.split(":");
        if (parts.length === 2 && RATES[parts[0]] && RATES[parts[1]]) {
          defaultFrom = parts[0];
          defaultTo = parts[1];
        }
      }

      currentFromCurrency = urlParams.get("from") || localStorage.getItem(KEY_FROM) || defaultFrom;
      currentToCurrency = urlParams.get("to") || localStorage.getItem(KEY_TO) || defaultTo;

      // Avoid same currency conflict
      if (currentFromCurrency === currentToCurrency) {
        currentToCurrency = currentFromCurrency === "USD" ? "EUR" : "USD";
      }

      const savedAmount = urlParams.get("amount") || localStorage.getItem(KEY_AMOUNT) || "100";
      fromAmountEl.value = savedAmount;

      updateButtonUI();
      performConversion("from");
      updateFavoriteUI();
    }

    // Save Selection State
    function saveState() {
      localStorage.setItem(KEY_FROM, currentFromCurrency);
      localStorage.setItem(KEY_TO, currentToCurrency);
      localStorage.setItem(KEY_AMOUNT, fromAmountEl.value);
    }

    // Check if Reduced Motion is enabled
    function isReducedMotion(): boolean {
      return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    }

    // Animated Counter-Up for Conversion Target Output
    let animationFrameId: number | null = null;
    function animateValue(element: HTMLInputElement, startVal: number, endVal: number, decimals: number) {
      if (animationFrameId !== null) {
        cancelAnimationFrame(animationFrameId);
      }

      if (isReducedMotion() || startVal === endVal) {
        element.value = endVal.toFixed(decimals);
        return;
      }

      const duration = 250; // Short satisfying counter-up
      const startTime = performance.now();

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        // Ease Out Quad
        const easeProgress = progress * (2 - progress);
        const currentVal = startVal + (endVal - startVal) * easeProgress;
        element.value = currentVal.toFixed(decimals);

        if (progress < 1) {
          animationFrameId = requestAnimationFrame(update);
        } else {
          element.value = endVal.toFixed(decimals);
          animationFrameId = null;
        }
      }

      animationFrameId = requestAnimationFrame(update);
    }

    // Bidirectional Core Conversion
    function performConversion(source: "from" | "to") {
      const fromRate = RATES[currentFromCurrency];
      const toRate = RATES[currentToCurrency];
      
      const fromDecimals = CURRENCY_DETAILS[currentFromCurrency]?.precision ?? 2;
      const toDecimals = CURRENCY_DETAILS[currentToCurrency]?.precision ?? 2;

      if (source === "from") {
        const val = parseFloat(fromAmountEl.value);
        if (isNaN(val)) {
          toAmountEl.value = "";
          return;
        }
        // Cross multiplication: EUR = USD * (EUR_rate / USD_rate)
        const result = val * (toRate / fromRate);
        const currentToVal = parseFloat(toAmountEl.value) || 0;
        animateValue(toAmountEl, currentToVal, result, toDecimals);
      } else {
        const val = parseFloat(toAmountEl.value);
        if (isNaN(val)) {
          fromAmountEl.value = "";
          return;
        }
        const result = val * (fromRate / toRate);
        const currentFromVal = parseFloat(fromAmountEl.value) || 0;
        animateValue(fromAmountEl, currentFromVal, result, fromDecimals);
      }

      saveState();
      updateComparisonList();
    }

