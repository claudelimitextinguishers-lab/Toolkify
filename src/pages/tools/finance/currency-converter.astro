    // Search and Render Picker currencies
    function renderPickerList(searchQuery: string) {
      pickerList.innerHTML = "";
      const q = searchQuery.toLowerCase().trim();

      const sortedKeys = Object.keys(CURRENCY_DETAILS).sort();

      sortedKeys.forEach(code => {
        const details = CURRENCY_DETAILS[code];
        const isMatch = code.toLowerCase().includes(q) || 
                        details.name.toLowerCase().includes(q) || 
                        details.country.toLowerCase().includes(q);

        if (!isMatch) return;

        // Skip currency if selected in the other slot to avoid conversion to itself
        const isCurrentlyUsedInOtherTarget = (currentActiveTarget === "from" && code === currentToCurrency) ||
                                            (currentActiveTarget === "to" && code === currentFromCurrency);
        
        if (isCurrentlyUsedInOtherTarget) return;

        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "flex items-center justify-between p-2 rounded hover:bg-surface text-left cursor-pointer transition-all w-full select-none";
        
        // Highlight active one
        const isActive = (currentActiveTarget === "from" && code === currentFromCurrency) ||
                         (currentActiveTarget === "to" && code === currentToCurrency);
        if (isActive) {
          btn.classList.add("bg-surface-pricing-featured", "font-semibold");
        }

        btn.innerHTML = `
          <span class="flex items-center gap-2">
            <span class="text-base select-none">${details.flag}</span>
            <span class="font-mono font-bold">${code}</span>
            <span class="text-stone text-[11px] truncate max-w-[130px]">${details.name}</span>
          </span>
          <span class="text-[10px] font-mono text-slate bg-hairline-soft px-1 rounded">${details.symbol}</span>
        `;

        btn.addEventListener("click", () => {
          if (currentActiveTarget === "from") {
            currentFromCurrency = code;
          } else {
            currentToCurrency = code;
          }
          updateButtonUI();
          performConversion("from");
          updateFavoriteUI();
          closePicker();
        });

        pickerList.appendChild(btn);
      });
    }

    // Swapping Actions
    function handleSwap() {
      // Rotation Animation
      swapRotation += 180;
      if (!isReducedMotion()) {
        swapIcon.style.transform = `rotate(${swapRotation}deg)`;
      }

      // Flip currencies
      const temp = currentFromCurrency;
      currentFromCurrency = currentToCurrency;
      currentToCurrency = temp;

      // Flip values
      const fromVal = fromAmountEl.value;
      const toVal = toAmountEl.value;
      fromAmountEl.value = toVal;
      toAmountEl.value = fromVal;

      updateButtonUI();
      performConversion("from");
      updateFavoriteUI();
    }

    // Favorites LocalStorage features
    function handleSetFavorite() {
      const pairString = `${currentFromCurrency}:${currentToCurrency}`;
      const currentFavorite = localStorage.getItem(KEY_FAVORITE);

      if (currentFavorite === pairString) {
        // Toggle off
        localStorage.removeItem(KEY_FAVORITE);
      } else {
        localStorage.setItem(KEY_FAVORITE, pairString);
      }
      updateFavoriteUI();
    }

    // Update Favorites star UI
    function updateFavoriteUI() {
      const pairString = `${currentFromCurrency}:${currentToCurrency}`;
      const isFav = localStorage.getItem(KEY_FAVORITE) === pairString;
      
      if (isFav) {
        favoriteIcon.textContent = "★";
        favoriteIcon.className = "text-brand-yellow font-bold text-xs animate-scale-in";
        favoriteText.textContent = "Default Saved";
      } else {
        favoriteIcon.textContent = "☆";
        favoriteIcon.className = "text-slate";
        favoriteText.textContent = "Set Default";
      }
    }

    // Copy formatted result to clipboard
    function handleCopy() {
      const fromInfo = CURRENCY_DETAILS[currentFromCurrency];
      const toInfo = CURRENCY_DETAILS[currentToCurrency];
      const fromVal = parseFloat(fromAmountEl.value) || 0;
      const toVal = parseFloat(toAmountEl.value) || 0;
      
      const formattedFrom = `${fromInfo.symbol}${fromVal.toFixed(fromInfo.precision)} ${currentFromCurrency}`;
      const formattedTo = `${toInfo.symbol}${toVal.toFixed(toInfo.precision)} ${currentToCurrency}`;

      const text = `${formattedFrom} = ${formattedTo} (Reference rate static as of July 5, 2026)`;
      
      navigator.clipboard.writeText(text).then(() => {
        // Subtle micro UI feedback
        const copySpan = copyBtn.querySelector("span");
        if (copySpan) {
          const originalText = copySpan.textContent;
          copySpan.textContent = "Copied!";
          copySpan.classList.add("text-brand-blue");
          setTimeout(() => {
            copySpan.textContent = originalText;
            copySpan.classList.remove("text-brand-blue");
          }, 1500);
        }
      });
    }

    // Comparison List: dynamic matching
    function updateComparisonList() {
      const fromVal = parseFloat(fromAmountEl.value);
      if (isNaN(fromVal)) {
        compareList.innerHTML = `<span class="text-stone text-[11px] px-2 py-4">Enter a conversion amount to compare.</span>`;
        return;
      }

      compareBaseAmount.textContent = `${fromVal.toFixed(CURRENCY_DETAILS[currentFromCurrency].precision)} ${currentFromCurrency}`;

      // Pick a selection of standard major target currencies
      const targets = ["USD", "EUR", "GBP", "JPY", "INR", "AUD", "CAD", "CHF", "CNY", "SGD"].filter(c => c !== currentFromCurrency);

      compareList.innerHTML = "";
      
      targets.forEach(code => {
        const details = CURRENCY_DETAILS[code];
        const rate = RATES[code];
        const fromRate = RATES[currentFromCurrency];
        
        // Calculate Cross conversion
        const result = fromVal * (rate / fromRate);
        const formattedResult = `${details.symbol}${result.toFixed(details.precision)}`;

        const row = document.createElement("div");
        row.className = "flex items-center justify-between p-2 bg-surface rounded hover:bg-hairline-soft transition-all text-xs border border-hairline-soft cursor-pointer";
        row.innerHTML = `
          <span class="flex items-center gap-1.5 font-semibold text-primary">
            <span class="select-none">${details.flag}</span>
            <span class="font-mono text-[11px]">${code}</span>
            <span class="text-[10px] text-stone font-normal truncate max-w-[80px]">${details.name}</span>
          </span>
          <span class="font-mono font-bold text-primary select-all">${formattedResult}</span>
        `;
        
        // Quick swap target to this on row click
        row.addEventListener("click", () => {
          currentToCurrency = code;
          updateButtonUI();
          performConversion("from");
          updateFavoriteUI();
        });

        compareList.appendChild(row);
      });
    }

    // Rate Table Tab logic
    function renderRateTableList(searchQuery: string) {
      rateTableList.innerHTML = "";
      const q = searchQuery.toLowerCase().trim();

      const sortedKeys = Object.keys(RATES).sort();

      sortedKeys.forEach(code => {
        const details = CURRENCY_DETAILS[code];
        const rate = RATES[code];

        const isMatch = code.toLowerCase().includes(q) || details.name.toLowerCase().includes(q);
        if (!isMatch) return;

        const row = document.createElement("div");
        row.className = "flex items-center justify-between p-1.5 border-b border-hairline-soft hover:bg-surface rounded transition-all text-[11px]";
        row.innerHTML = `
          <span class="flex items-center gap-1.5 text-slate">
            <span>${details.flag}</span>
            <span class="font-mono font-bold text-primary">${code}</span>
            <span class="text-stone text-[10px] truncate max-w-[120px]">${details.name}</span>
          </span>
          <span class="font-mono text-primary font-bold">1 USD = ${rate.toFixed(4)} ${details.symbol}</span>
        `;
        rateTableList.appendChild(row);
      });
    }

    // Tab Buttons Interactions
    tabCompareBtn.addEventListener("click", () => {
      tabCompareBtn.className = "flex-1 text-center text-[11px] py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabTableBtn.className = "flex-1 text-center text-[11px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate hover:text-primary";
      tabCompareContent.classList.remove("hidden");
      tabTableContent.classList.add("hidden");
    });

    tabTableBtn.addEventListener("click", () => {
      tabTableBtn.className = "flex-1 text-center text-[11px] py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabCompareBtn.className = "flex-1 text-center text-[11px] py-1 rounded-full font-semibold transition-all cursor-pointer text-slate hover:text-primary";
      tabTableContent.classList.remove("hidden");
      tabCompareContent.classList.add("hidden");
      renderRateTableList("");
    });

    // Preset Amount Chips Click Handler
    document.querySelectorAll(".preset-chip").forEach(chip => {
      chip.addEventListener("click", (e) => {
        const amt = (e.currentTarget as HTMLButtonElement).dataset.amount;
        if (amt) {
          fromAmountEl.value = amt;
          performConversion("from");
        }
      });
    });

    // Reset button exact contract (clears local values and resets storage)
    resetBtn.addEventListener("click", () => {
      localStorage.removeItem(KEY_FROM);
      localStorage.removeItem(KEY_TO);
      localStorage.removeItem(KEY_AMOUNT);
      
      // Default selections
      fromAmountEl.value = "100";
      currentFromCurrency = "USD";
      currentToCurrency = "EUR";

      updateButtonUI();
      performConversion("from");
      updateFavoriteUI();
    });

    // Modal Action Bindings
    howItWorksBtn.addEventListener("click", () => {
      howItWorksModal.classList.remove("hidden");
    });

    closeModalBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });

    modalOkBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });

    howItWorksModal.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // Share button copy link logic
    const shareBtn = document.getElementById("share-btn");
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("from", currentFromCurrency);
      url.searchParams.set("to", currentToCurrency);
      url.searchParams.set("amount", fromAmountEl.value);

      const shareData = {
        title: document.title || "Toolkify",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Picker Button Openings
    fromCurrencyBtn.addEventListener("click", () => openPicker("from"));
    toCurrencyBtn.addEventListener("click", () => openPicker("to"));
    closePickerBtn.addEventListener("click", closePicker);

    // Search bar event listeners
    pickerSearch.addEventListener("input", (e) => {
      renderPickerList((e.target as HTMLInputElement).value);
    });

    tableSearch.addEventListener("input", (e) => {
      renderRateTableList((e.target as HTMLInputElement).value);
    });

    // Bidirectional keyboard triggers
    fromAmountEl.addEventListener("input", () => performConversion("from"));
    toAmountEl.addEventListener("input", () => performConversion("to"));
    swapBtn.addEventListener("click", handleSwap);
    favoriteBtn.addEventListener("click", handleSetFavorite);
    copyBtn.addEventListener("click", handleCopy);

    // Close picker when clicking outside
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (
        !currencyPicker.contains(target) &&
        !fromCurrencyBtn.contains(target) &&
        !toCurrencyBtn.contains(target) &&
        !currencyPicker.classList.contains("hidden")
      ) {
        closePicker();
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Load and Start Conversion
    loadState();
  </script>
</Layout>
