  <!-- Script block for client logic -->
  <script>
    // Inputs
    const currencySelect = document.getElementById("currency-select") as HTMLSelectElement;
    const customCurrencySymbolInput = document.getElementById("custom-currency-symbol") as HTMLInputElement;
    const customCurrencyCodeInput = document.getElementById("custom-currency-code") as HTMLInputElement;
    const customCurrencyContainer = document.getElementById("custom-currency-container");

    const monthlyAmtRange = document.getElementById("monthly-amt-range") as HTMLInputElement;
    const monthlyAmtInput = document.getElementById("monthly-amt-input") as HTMLInputElement;

    const rateRange = document.getElementById("rate-range") as HTMLInputElement;
    const rateInput = document.getElementById("rate-input") as HTMLInputElement;
    const rateDisplayVal = document.getElementById("rate-display-val");

    const durationRange = document.getElementById("duration-range") as HTMLInputElement;
    const durationInput = document.getElementById("duration-input") as HTMLInputElement;
    const durationDisplayVal = document.getElementById("duration-display-val");

    const advancedToggleBtn = document.getElementById("advanced-toggle-btn");
    const advancedPanel = document.getElementById("advanced-panel");
    const advancedChevron = document.getElementById("advanced-chevron");

    const enableStepUp = document.getElementById("enable-step-up") as HTMLInputElement;
    const stepUpControls = document.getElementById("step-up-controls");
    const stepUpPctRange = document.getElementById("step-up-pct-range") as HTMLInputElement;
    const stepUpPctInput = document.getElementById("step-up-pct-input") as HTMLInputElement;
    const stepUpPctVal = document.getElementById("step-up-pct-val");

    const lumpSumInput = document.getElementById("lump-sum-input") as HTMLInputElement;
    const compoundingSelect = document.getElementById("compounding-select") as HTMLSelectElement;

    // Outputs
    const maturityDisplay = document.getElementById("maturity-display");
    const investedDisplay = document.getElementById("invested-display");
    const returnsDisplay = document.getElementById("returns-display");
    const completionDateDisplay = document.getElementById("completion-date-display");

    // Donut SVG
    const donutSegments = document.getElementById("donut-segments");
    const donutPercent = document.getElementById("donut-percent");
    const legendInvestedVal = document.getElementById("legend-invested-val");
    const legendReturnsVal = document.getElementById("legend-returns-val");

    // Actions & What-if
    const csvExportBtn = document.getElementById("csv-export-btn");
    const excelExportBtn = document.getElementById("excel-export-btn");
    const copyResultsBtn = document.getElementById("copy-results-btn");
    const resetBtn = document.getElementById("reset-btn");
    const scheduleTableBody = document.getElementById("schedule-table-body");

    const whatifMonthlySlider = document.getElementById("whatif-monthly-slider") as HTMLInputElement;
    const whatifMonthlyDisplay = document.getElementById("whatif-monthly-display");
    const whatifRateSlider = document.getElementById("whatif-rate-slider") as HTMLInputElement;
    const whatifRateDisplay = document.getElementById("whatif-rate-display");
    const whatifMaturityVal = document.getElementById("whatif-maturity-val");
    const whatifInvestedVal = document.getElementById("whatif-invested-val");
    const whatifDiffVal = document.getElementById("whatif-diff-val");

    // Modal
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    // State Variables
    let currentCurrency = "INR";
    let currentCurrencySymbol = "₹";
    let currentCurrencyCode = "INR";

    let calculatedInvested = 0;
    let calculatedMaturity = 0;
    let scheduleData: any[] = [];

    let copyTimeout: any = null;
    let copyOriginalText = "";

    // Currency updates
    function updateCurrencyFormatting() {
      if (!currencySelect) return;
      const val = currencySelect.value;
      currentCurrency = val;

      if (val === "INR") {
        currentCurrencySymbol = "₹";
        currentCurrencyCode = "INR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "USD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "USD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "CAD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "CAD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "GBP") {
        currentCurrencySymbol = "£";
        currentCurrencyCode = "GBP";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "AUD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "AUD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "EUR") {
        currentCurrencySymbol = "€";
        currentCurrencyCode = "EUR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "Custom") {
        customCurrencyContainer?.classList.remove("hidden");
        currentCurrencySymbol = customCurrencySymbolInput?.value || "₹";
        currentCurrencyCode = customCurrencyCodeInput?.value || "INR";
      }

      const symbols = document.querySelectorAll(".currency-symbol");
      const labels = document.querySelectorAll(".currency-label");
      
      const symbolChar = currentCurrencySymbol;
      const labelText = `${currentCurrency} (${symbolChar})`;

      symbols.forEach(el => el.textContent = symbolChar);
      labels.forEach(el => el.textContent = labelText);

      // Adjust input bounds/steps dynamically
      if (currentCurrencyCode === "INR") {
        monthlyAmtRange.max = "1000000";
        monthlyAmtInput.max = "1000000";
        monthlyAmtRange.step = "500";
        whatifMonthlySlider.max = "1000000";
        whatifMonthlySlider.step = "500";
        lumpSumInput.max = "100000000";
        lumpSumInput.step = "5000";
      } else {
        monthlyAmtRange.max = "100000";
        monthlyAmtInput.max = "100000";
        monthlyAmtRange.step = "50";
        whatifMonthlySlider.max = "100000";
        whatifMonthlySlider.step = "50";
        lumpSumInput.max = "10000000";
        lumpSumInput.step = "250";
      }
    }

    // High fidelity formatter
    function formatCurrency(val: number): string {
      const locale = currentCurrencyCode === "INR" ? "en-IN" : "en-US";
      const isINR = currentCurrencyCode === "INR";
      return (
        currentCurrencySymbol +
        val.toLocaleString(locale, {
          minimumFractionDigits: isINR ? 0 : 2,
          maximumFractionDigits: isINR ? 0 : 2
        })
      );
    }

    // Core Compounding Engine
    function runSIPEngine(
      baseSIP: number,
      annualRate: number,
      totalYears: number,
      stepUpPct: number,
      lumpSum: number,
      compoundingFreq: string
    ) {
      const totalMonths = totalYears * 12;
      let balance = lumpSum;
      let totalInvested = lumpSum;
      let currentMonthlyContrib = baseSIP;

      // Rate conversions
      // Standard monthly compounding: monthly rate is annualRate / 12
      // Yearly compounding frequency: monthly rate = (1 + annualRate)^(1/12) - 1
      let monthlyRate = 0;
      if (compoundingFreq === "monthly") {
        monthlyRate = annualRate / 12 / 100;
      } else {
        monthlyRate = Math.pow(1 + annualRate / 100, 1 / 12) - 1;
      }

      const yearBreakdown = [];
      let yearInvested = lumpSum;

      for (let month = 1; month <= totalMonths; month++) {
        // Apply annual step-up increment boundary
        if (month > 1 && (month - 1) % 12 === 0) {
          currentMonthlyContrib = currentMonthlyContrib * (1 + stepUpPct / 100);
        }

        // Add monthly investment to contribution totals
        totalInvested += currentMonthlyContrib;
        yearInvested += currentMonthlyContrib;

        // Compound returns at beginning of month (standard annuity due)
        balance = (balance + currentMonthlyContrib) * (1 + monthlyRate);

        // Record yearly metrics
        if (month % 12 === 0) {
          const yearNum = month / 12;
          const yearEndBal = balance;
          const yearReturns = Math.max(0, yearEndBal - totalInvested);

          yearBreakdown.push({
            year: yearNum,
            monthlyInvestment: currentMonthlyContrib,
            cumulativeInvested: totalInvested,
            wealthGained: yearReturns,
            balance: yearEndBal
          });
        }
      }

      return {
        totalInvested: Math.round(totalInvested),
        maturityValue: Math.round(balance),
        yearsBreakdown: yearBreakdown
      };
    }

    // Main Calculation orchestrator
    function calculate() {
      // Clamping inputs to valid (non-negative) numbers
      if (parseFloat(monthlyAmtInput.value) < 0) monthlyAmtInput.value = "0";
      if (parseFloat(durationInput.value) < 0) durationInput.value = "0";
      if (parseFloat(lumpSumInput.value) < 0) lumpSumInput.value = "0";
      if (parseFloat(stepUpPctInput.value) < 0) stepUpPctInput.value = "0";

      const baseSIP = Math.max(0, parseFloat(monthlyAmtInput.value) || 0);
      const rate = Math.max(0.1, parseFloat(rateInput.value) || 0.1);
      const years = Math.max(1, parseInt(durationInput.value, 10) || 1);
      
      const isStepUp = enableStepUp.checked;
      const stepUpPct = isStepUp ? (parseFloat(stepUpPctInput.value) || 0) : 0;
      const lumpSum = Math.max(0, parseFloat(lumpSumInput.value) || 0);
      const frequency = compoundingSelect.value;

      // Run engine
      const results = runSIPEngine(baseSIP, rate, years, stepUpPct, lumpSum, frequency);

      calculatedInvested = results.totalInvested;
      calculatedMaturity = results.maturityValue;
      scheduleData = results.yearsBreakdown;

      const estimatedReturns = Math.max(0, calculatedMaturity - calculatedInvested);

      // DOM Outputs
      if (maturityDisplay) maturityDisplay.textContent = formatCurrency(calculatedMaturity);
      if (investedDisplay) investedDisplay.textContent = formatCurrency(calculatedInvested);
      if (returnsDisplay) returnsDisplay.textContent = formatCurrency(estimatedReturns);

      // Mobile sticky HUD
      const mobileHUDVal = document.getElementById("mobile-summary-value");
      if (mobileHUDVal) mobileHUDVal.textContent = formatCurrency(calculatedMaturity);

      // Estimated Date
      const d = new Date();
      d.setFullYear(d.getFullYear() + years);
      const formatOptions: Intl.DateTimeFormatOptions = { month: 'long', year: 'numeric' };
      if (completionDateDisplay) completionDateDisplay.textContent = d.toLocaleDateString('en-US', formatOptions);

      // Sync sensitivity default values if not interacted
      if (document.activeElement !== whatifMonthlySlider && document.activeElement !== whatifRateSlider) {
        whatifMonthlySlider.value = baseSIP.toString();
        whatifRateSlider.value = rate.toString();
      }

      // Render chart, breakdown, and sensitivity
      renderDonutChart(calculatedInvested, estimatedReturns);
      renderTable();
      calculateWhatIf();
      saveState();
    }

    // Donut SVG Render
    function renderDonutChart(invested: number, returns: number) {
      if (!donutSegments) return;

      const total = invested + returns;
      if (total === 0) return;

      const investedPct = (invested / total) * 100;
      const returnsPct = (returns / total) * 100;

      if (legendInvestedVal) legendInvestedVal.textContent = `${formatCurrency(invested)} (${investedPct.toFixed(1)}%)`;
      if (legendReturnsVal) legendReturnsVal.textContent = `${formatCurrency(returns)} (${returnsPct.toFixed(1)}%)`;
      if (donutPercent) donutPercent.textContent = `${returnsPct.toFixed(0)}%`;

      const radius = 40;
      const circumference = 2 * Math.PI * radius;
      
      const slices = [
        { pct: investedPct, color: "var(--color-brand-blue, #4262ff)" },
        { pct: returnsPct, color: "var(--color-success-accent, #00b473)" }
      ];

      let accumulatedPercent = 0;
      let svgHtml = "";

      slices.forEach(slice => {
        if (slice.pct <= 0) return;
        const strokeDashArray = `${(slice.pct / 100) * circumference} ${circumference}`;
        const strokeDashOffset = -((accumulatedPercent / 100) * circumference);

        svgHtml += `
          <circle
            cx="50"
            cy="50"
            r="${radius}"
            stroke="${slice.color}"
            stroke-width="12"
            fill="transparent"
            stroke-dasharray="${strokeDashArray}"
            stroke-dashoffset="${strokeDashOffset}"
            stroke-linecap="round"
            class="transition-all duration-300"
          />
        `;
        accumulatedPercent += slice.pct;
      });

      donutSegments.innerHTML = svgHtml;
    }

    // Render Growth Table
    function renderTable() {
      if (!scheduleTableBody) return;
      let html = "";

      scheduleData.forEach(row => {
        html += `
          <tr class="border-b border-hairline-soft font-mono text-[11px] text-slate hover:bg-surface-soft transition-all">
            <td class="py-2.5 px-3 font-semibold text-primary">Year ${row.year}</td>
            <td class="py-2.5 px-3 text-right">${formatCurrency(row.monthlyInvestment)}</td>
            <td class="py-2.5 px-3 text-right">${formatCurrency(row.cumulativeInvested)}</td>
            <td class="py-2.5 px-3 text-right text-success-accent">${formatCurrency(row.wealthGained)}</td>
            <td class="py-2.5 px-3 text-right text-primary font-bold">${formatCurrency(row.balance)}</td>
          </tr>
        `;
      });

      scheduleTableBody.innerHTML = html;
    }

    // What If Calculation
    function calculateWhatIf() {
      const whatifMonthly = parseFloat(whatifMonthlySlider.value) || 0;
      const whatifRate = parseFloat(whatifRateSlider.value) || 0.1;
      const years = Math.max(1, parseInt(durationInput.value, 10) || 1);
      const isStepUp = enableStepUp.checked;
      const stepUpPct = isStepUp ? (parseFloat(stepUpPctInput.value) || 0) : 0;
      const lumpSum = Math.max(0, parseFloat(lumpSumInput.value) || 0);
      const frequency = compoundingSelect.value;

      const results = runSIPEngine(whatifMonthly, whatifRate, years, stepUpPct, lumpSum, frequency);

      if (whatifMonthlyDisplay) whatifMonthlyDisplay.textContent = formatCurrency(whatifMonthly);
      if (whatifRateDisplay) whatifRateDisplay.textContent = `${whatifRate.toFixed(1)}%`;

      if (whatifMaturityVal) whatifMaturityVal.textContent = formatCurrency(results.maturityValue);
      if (whatifInvestedVal) whatifInvestedVal.textContent = formatCurrency(results.totalInvested);

      const diff = results.maturityValue - calculatedMaturity;
      if (whatifDiffVal) {
        const sign = diff >= 0 ? "+" : "";
        whatifDiffVal.textContent = sign + formatCurrency(diff);
        if (diff >= 0) {
          whatifDiffVal.className = "font-semibold text-sm text-success-accent";
        } else {
          whatifDiffVal.className = "font-semibold text-sm text-brand-red-dark";
        }
      }
    }

    // Export Helpers
    function exportToCSV() {
      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Year,Monthly Investment,Cumulative Invested,Wealth Gained,Year-End Balance\r\n";

      scheduleData.forEach(row => {
        csvContent += `${row.year},${row.monthlyInvestment},${row.cumulativeInvested},${row.wealthGained},${row.balance}\r\n`;
      });

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", `SIP_Return_Schedule_${durationInput.value}y_${Date.now()}.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    function exportToExcel() {
      if (scheduleData.length === 0) return;
      const termVal = durationInput.value;
      const currencySymbol = currentCurrencySymbol;
      
      let tableRows = "";
      scheduleData.forEach(row => {
        tableRows += `
          <tr>
            <td>Year ${row.year}</td>
            <td>${row.monthlyInvestment}</td>
            <td>${row.cumulativeInvested}</td>
            <td>${row.wealthGained}</td>
            <td>${row.balance}</td>
          </tr>
        `;
      });

      const html = `
        <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
        <head>
          <!--[if gte mso 9]>
          <xml>
            <x:ExcelWorkbook>
              <x:ExcelWorksheets>
                <x:ExcelWorksheet>
                  <x:Name>SIP Breakdown</x:Name>
                  <x:WorksheetOptions>
                    <x:DisplayGridlines/>
                  </x:WorksheetOptions>
                </x:ExcelWorksheet>
              </x:ExcelWorksheets>
            </x:ExcelWorkbook>
          </xml>
          <![endif]-->
          <style>
            table { border-collapse: collapse; }
            th, td { border: 1px solid #e2e8f0; padding: 8px; font-family: sans-serif; font-size: 12px; }
            th { background-color: #f7fafc; font-weight: bold; }
          </style>
        </head>
        <body>
          <table>
            <tr style="font-size: 14px; font-weight: bold; background-color: #edf2f7;">
              <td colspan="5">SIP Returns Schedule (${termVal} Years, Currency: ${currentCurrency} ${currencySymbol})</td>
            </tr>
            <tr style="background-color: #f7fafc; font-weight: bold;">
              <td>Year</td>
              <td>Monthly Investment</td>
              <td>Cumulative Invested</td>
              <td>Wealth Gained</td>
              <td>Year-End Balance</td>
            </tr>
            ${tableRows}
          </table>
        </body>
        </html>
      `;

      const blob = new Blob([html], { type: "application/vnd.ms-excel" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `SIP_Return_Schedule_${termVal}y_${Date.now()}.xls`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    // Copy Results trigger
    function copyResults() {
      const summaryText = 
`SIP Return Calculation Summary
--------------------------------
Monthly Investment: ${formatCurrency(parseFloat(monthlyAmtInput.value) || 0)}
Expected Returns Rate: ${parseFloat(rateInput.value).toFixed(2)}%
Duration: ${durationInput.value} years
Annual Step-up: ${enableStepUp.checked ? stepUpPctInput.value + '%' : 'Disabled'}
Initial Lump Sum: ${formatCurrency(parseFloat(lumpSumInput.value) || 0)}

Maturity Value: ${formatCurrency(calculatedMaturity)}
Total Invested: ${formatCurrency(calculatedInvested)}
Wealth Gained: ${formatCurrency(Math.max(0, calculatedMaturity - calculatedInvested))}
Generated by BoardTools SIP Return Calculator`;

      navigator.clipboard.writeText(summaryText)
        .then(() => {
          if (copyResultsBtn) {
            if (copyTimeout) {
              clearTimeout(copyTimeout);
            } else {
              copyOriginalText = copyResultsBtn.innerHTML;
            }
            copyResultsBtn.innerHTML = "✓ Copied!";
            copyTimeout = setTimeout(() => {
              copyResultsBtn.innerHTML = copyOriginalText;
              copyTimeout = null;
            }, 2000);
          }
        })
        .catch(err => {
          console.error("Failed to copy text", err);
        });
    }

    // Range Sync
    function syncRangeInput(rangeEl: HTMLInputElement, inputEl: HTMLInputElement, labelEl: HTMLElement | null, formatter: (v: number) => string) {
      rangeEl.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        inputEl.value = val;
        if (labelEl) labelEl.textContent = formatter(parseFloat(val));
        calculate();
      });

      inputEl.addEventListener("input", (e) => {
        let val = parseFloat((e.target as HTMLInputElement).value) || 0;
        const min = parseFloat(inputEl.min || "0");
        const max = parseFloat(inputEl.max || "100");
        val = Math.max(min, Math.min(max, val));
        rangeEl.value = val.toString();
        if (labelEl) labelEl.textContent = formatter(val);
        calculate();
      });
    }

    // Local Storage State
    function loadState() {
      const getSafeItem = (key: string): string | null => {
        if (typeof localStorage === 'undefined') return null;
        try {
          return localStorage.getItem(key);
        } catch (e) {
          return null;
        }
      };

      const savedAmt = getSafeItem("sip-amt");
      const savedRate = getSafeItem("sip-rate");
      const savedDuration = getSafeItem("sip-duration");
      const savedCurrency = getSafeItem("sip-currency");
      const savedCustomSymbol = getSafeItem("sip-custom-symbol");
      const savedCustomCode = getSafeItem("sip-custom-code");
      const savedStepUpEnabled = getSafeItem("sip-stepup-enabled");
      const savedStepUpVal = getSafeItem("sip-stepup-val");
      const savedLump = getSafeItem("sip-lump");
      const savedFreq = getSafeItem("sip-freq");

      if (savedCurrency && currencySelect) {
        currencySelect.value = savedCurrency;
      }
      if (savedCustomSymbol && customCurrencySymbolInput) {
        customCurrencySymbolInput.value = savedCustomSymbol;
      }
      if (savedCustomCode && customCurrencyCodeInput) {
        customCurrencyCodeInput.value = savedCustomCode;
      }
      updateCurrencyFormatting();

      if (savedAmt !== null) {
        monthlyAmtInput.value = savedAmt;
        monthlyAmtRange.value = savedAmt;
      }
      if (savedRate !== null) {
        rateInput.value = savedRate;
        rateRange.value = savedRate;
        if (rateDisplayVal) rateDisplayVal.textContent = `${parseFloat(savedRate).toFixed(2)}%`;
      }
      if (savedDuration !== null) {
        durationInput.value = savedDuration;
        durationRange.value = savedDuration;
        if (durationDisplayVal) durationDisplayVal.textContent = `${savedDuration} years (${parseInt(savedDuration) * 12} months)`;
      }
      if (savedStepUpEnabled !== null) {
        enableStepUp.checked = savedStepUpEnabled === "true";
      }
      if (savedStepUpVal !== null) {
        stepUpPctInput.value = savedStepUpVal;
        stepUpPctRange.value = savedStepUpVal;
        if (stepUpPctVal) stepUpPctVal.textContent = `${savedStepUpVal}%`;
      }
      if (savedLump !== null) {
        lumpSumInput.value = savedLump;
      }
      if (savedFreq && compoundingSelect) {
        compoundingSelect.value = savedFreq;
      }

      // Step-up layout state toggle
      if (enableStepUp.checked) {
        stepUpControls?.classList.remove("hidden");
      } else {
        stepUpControls?.classList.add("hidden");
      }
    }

    let saveStateTimeout: any = null;
    function saveState() {
      if (saveStateTimeout) clearTimeout(saveStateTimeout);
      saveStateTimeout = setTimeout(() => {
        if (typeof localStorage === 'undefined') return;
        
        const setSafeItem = (key: string, val: string) => {
          try {
            localStorage.setItem(key, val);
          } catch (e) {}
        };

        setSafeItem("sip-amt", monthlyAmtInput.value);
        setSafeItem("sip-rate", rateInput.value);
        setSafeItem("sip-duration", durationInput.value);
        setSafeItem("sip-currency", currentCurrency);
        setSafeItem("sip-custom-symbol", currentCurrencySymbol);
        setSafeItem("sip-custom-code", currentCurrencyCode);
        setSafeItem("sip-stepup-enabled", enableStepUp.checked.toString());
        setSafeItem("sip-stepup-val", stepUpPctInput.value);
        setSafeItem("sip-lump", lumpSumInput.value);
        setSafeItem("sip-freq", compoundingSelect.value);
      }, 400);
    }

    // Scroll to with offset
    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }

    // Event Bindings
    window.addEventListener("DOMContentLoaded", () => {
      loadState();

      // Sliders bindings
      syncRangeInput(monthlyAmtRange, monthlyAmtInput, null, (v) => v.toString());
      syncRangeInput(rateRange, rateInput, rateDisplayVal, (v) => `${v.toFixed(2)}%`);
      syncRangeInput(durationRange, durationInput, durationDisplayVal, (v) => `${v} years (${v * 12} months)`);
      syncRangeInput(stepUpPctRange, stepUpPctInput, stepUpPctVal, (v) => `${v}%`);

      // Inputs calculate triggers
      monthlyAmtInput.addEventListener("input", calculate);
      rateInput.addEventListener("input", calculate);
      durationInput.addEventListener("input", calculate);
      lumpSumInput.addEventListener("input", calculate);
      compoundingSelect.addEventListener("change", calculate);

      // Enable step up toggle action
      enableStepUp.addEventListener("change", () => {
        if (enableStepUp.checked) {
          stepUpControls?.classList.remove("hidden");
        } else {
          stepUpControls?.classList.add("hidden");
        }
        calculate();
      });

      // Currency Select
      currencySelect?.addEventListener("change", () => {
        updateCurrencyFormatting();
        calculate();
      });

      customCurrencySymbolInput?.addEventListener("input", () => {
        if (currentCurrency === "Custom") {
          currentCurrencySymbol = customCurrencySymbolInput.value || "₹";
          updateCurrencyFormatting();
          calculate();
        }
      });

      customCurrencyCodeInput?.addEventListener("input", () => {
        if (currentCurrency === "Custom") {
          currentCurrencyCode = customCurrencyCodeInput.value || "INR";
          updateCurrencyFormatting();
          calculate();
        }
      });

      // Advanced Options Toggle
      advancedToggleBtn?.addEventListener("click", () => {
        if (advancedPanel) {
          const isCollapsed = advancedPanel.classList.contains("max-h-0");
          if (isCollapsed) {
            advancedPanel.classList.remove("max-h-0");
            advancedPanel.classList.add("max-h-[1000px]");
            advancedChevron?.classList.add("rotate-180");
          } else {
            advancedPanel.classList.remove("max-h-[1000px]");
            advancedPanel.classList.add("max-h-0");
            advancedChevron?.classList.remove("rotate-180");
          }
        }
      });

      // Sensitivity Sliders bindings
      whatifMonthlySlider.addEventListener("input", () => {
        calculateWhatIf();
      });
      whatifRateSlider.addEventListener("input", () => {
        calculateWhatIf();
      });

      // Export Actions
      csvExportBtn?.addEventListener("click", exportToCSV);
      excelExportBtn?.addEventListener("click", exportToExcel);
      copyResultsBtn?.addEventListener("click", copyResults);

      // Reset action
      resetBtn?.addEventListener("click", () => {
        if (typeof localStorage !== 'undefined') {
          try {
            ['amt','rate','duration','currency','custom-symbol','custom-code','stepup-enabled','stepup-val','lump','freq'].forEach(k => localStorage.removeItem('sip-' + k));
          } catch (e) {}
        }

        monthlyAmtInput.value = "25000";
        monthlyAmtRange.value = "25000";
        rateInput.value = "12";
        rateRange.value = "12";
        if (rateDisplayVal) rateDisplayVal.textContent = "12.00%";
        durationInput.value = "10";
        durationRange.value = "10";
        if (durationDisplayVal) durationDisplayVal.textContent = "10 years (120 months)";
        
        enableStepUp.checked = false;
        stepUpControls?.classList.add("hidden");
        stepUpPctInput.value = "10";
        stepUpPctRange.value = "10";
        if (stepUpPctVal) stepUpPctVal.textContent = "10%";
        
        lumpSumInput.value = "0";
        compoundingSelect.value = "monthly";
        
        if (currencySelect) currencySelect.value = "INR";
        if (customCurrencySymbolInput) customCurrencySymbolInput.value = "₹";
        if (customCurrencyCodeInput) customCurrencyCodeInput.value = "INR";

        updateCurrencyFormatting();
        calculate();
      });

      // Modal Binds
      howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
      closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
      modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

      // Mobile sticky bar scroll sync
      const mobileStickyBar = document.getElementById("mobile-sticky-bar");
      const resultsColumn = document.getElementById("results-column");
      if (mobileStickyBar && resultsColumn) {
        const handleScroll = () => {
          const rect = resultsColumn.getBoundingClientRect();
          if (rect.top <= window.innerHeight - 80) {
            mobileStickyBar.style.transform = "translateY(100%)";
          } else {
            mobileStickyBar.style.transform = "translateY(0)";
          }
        };
        window.addEventListener("scroll", handleScroll);
        handleScroll();
      }

      const mobileScrollBtn = document.getElementById("mobile-scroll-results-btn");
      if (mobileScrollBtn && resultsColumn) {
        mobileScrollBtn.addEventListener("click", () => {
          scrollToElementWithOffset("results-column", 80);
        });
      }

      // Initial execution
      calculate();
    });
  </script>
</Layout>
