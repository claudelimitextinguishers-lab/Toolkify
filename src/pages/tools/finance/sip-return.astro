---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "SIP Return Calculator";
const category = "finance";
const tier = "Finance & Tax";
const description = "Calculate prospective returns and final maturity value on Systematic Investment Plans (SIP) with annual step-up contribution growth and lump-sum top-up options.";
---

<Layout 
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "SIP Return Calculator",
      "url": "https://boardtools.app/tools/finance/sip-return",
      "description": "Premium interactive Systematic Investment Plan (SIP) return calculator supporting annual step-up percentages, lump-sum top-ups, CSV/Excel exports, and dynamic what-if sensitivity comparisons.",
      "applicationCategory": "FinancialApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-6 flex flex-col gap-6 animate-fade-in-up pb-24 lg:pb-12">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-2">
      <nav class="flex items-center gap-1.5 text-xs font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-wrap items-center gap-3 mt-1">
        <h1 class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-primary">
          {name}
        </h1>
        <span class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-xs py-1 px-3 self-center rounded-full font-semibold uppercase">{tier}</span>
        
        <button
          type="button"
          id="how-it-works-btn"
          class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle self-center animate-pulse"
          aria-label="How SIP calculator works"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>How it works</span>
        </button>
      </div>
      <p class="text-sm text-slate max-w-xl">
        {description}
      </p>
    </div>

    <!-- Toolbar: Reset Button -->
    <div class="flex items-center justify-start border-b border-hairline pb-3">
      <button
        type="button"
        id="reset-btn"
        class="inline-flex items-center gap-1 text-xs font-semibold px-3.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
        </svg>
        <span>Reset</span>
      </button>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left: Interactive Form (7 Columns) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="card-base flex flex-col gap-5">
          <h2 class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Investment Parameters
          </h2>

          <!-- Currency & Initial Settings Row -->
          <div class="flex items-center justify-between">
            <label for="currency-select" class="text-xs font-semibold text-charcoal">Select Currency</label>
            <select
              id="currency-select"
              class="text-xs font-semibold py-0.5 px-2 rounded-full border border-hairline bg-surface hover:bg-canvas cursor-pointer transition-all outline-none"
              aria-label="Currency Select"
            >
              <option value="INR" selected>₹ INR</option>
              <option value="USD">$ USD</option>
              <option value="CAD">$ CAD</option>
              <option value="GBP">£ GBP</option>
              <option value="AUD">$ AUD</option>
              <option value="EUR">€ EUR</option>
              <option value="Custom">Custom / Other</option>
            </select>
          </div>

          <!-- Custom Currency Inputs (Hidden by default) -->
          <div id="custom-currency-container" class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft hidden animate-fade-in-up">
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-symbol" class="text-[10px] font-semibold text-slate">Currency Symbol</label>
              <input type="text" id="custom-currency-symbol" value="₹" class="text-input" placeholder="e.g. $, £, €, ₹" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-code" class="text-[10px] font-semibold text-slate">Currency Code</label>
              <input type="text" id="custom-currency-code" value="INR" class="text-input" placeholder="e.g. USD, GBP, EUR, INR" />
            </div>
          </div>

          <!-- Monthly Investment Slider & Input -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Monthly Investment</span>
              <span class="currency-label text-stone font-semibold">INR (₹)</span>
            </label>
            <div class="flex items-center gap-3">
              <input
                type="range"
                id="monthly-amt-range"
                min="500"
                max="1000000"
                value="25000"
                step="500"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Monthly Investment Slider"
              />
              <div class="relative w-28 shrink-0">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-xs font-medium currency-symbol">₹</span>
                <input
                  type="number"
                  id="monthly-amt-input"
                  min="500"
                  max="10000000"
                  value="25000"
                  step="500"
                  class="text-input pl-6 pr-2 py-1 text-xs text-right font-mono h-8 w-full"
                  inputmode="numeric"
                />
              </div>
            </div>
          </div>

          <!-- Expected Annual Return Rate Slider & Input -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Expected Annual Return Rate</span>
              <span id="rate-display-val" class="font-mono text-stone font-bold">12.00%</span>
            </label>
            <div class="flex items-center gap-3">
              <input
                type="range"
                id="rate-range"
                min="1"
                max="30"
                value="12"
                step="0.1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Expected Annual Return Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="rate-input"
                  min="1"
                  max="30"
                  value="12"
                  step="0.05"
                  class="text-input pr-5 py-1 text-xs text-center font-mono h-8 w-full"
                  inputmode="decimal"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
              </div>
            </div>
          </div>

          <!-- Investment Duration (Years) Slider & Input -->
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-charcoal flex justify-between">
              <span>Investment Duration</span>
              <span id="duration-display-val" class="font-mono text-stone font-bold">10 years (120 months)</span>
            </label>
            <div class="flex items-center gap-3">
              <input
                type="range"
                id="duration-range"
                min="1"
                max="40"
                value="10"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Investment Duration Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="duration-input"
                  min="1"
                  max="40"
                  value="10"
                  step="1"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8 w-full"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">yrs</span>
              </div>
            </div>
          </div>

          <!-- Advanced Collapsible Section (Step-up, Lump Sum, Compounding Freq) -->
          <div class="border-t border-hairline pt-4 mt-2">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-xs font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1.5">
                ⚙ Advanced Parameters (Step-up, Lump sum, Frequency)
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div
              id="advanced-panel"
              class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-4 border-t border-hairline-soft mt-3 pt-4"
            >
              <!-- Step-up SIP Section -->
              <div class="flex flex-col gap-2 p-3 bg-surface rounded-xl border border-hairline">
                <div class="flex items-center justify-between">
                  <span class="text-xs font-semibold text-charcoal">Enable Annual Step-up Contribution?</span>
                  <input
                    type="checkbox"
                    id="enable-step-up"
                    class="accent-brand-blue w-4 h-4 cursor-pointer"
                  />
                </div>
                <div id="step-up-controls" class="hidden flex-col gap-2 pt-2 border-t border-hairline-soft animate-fade-in-up">
                  <div class="flex items-center justify-between">
                    <label class="text-[11px] font-semibold text-slate">Annual Step-up Increment</label>
                    <span id="step-up-pct-val" class="text-xs font-mono font-bold text-stone">10%</span>
                  </div>
                  <div class="flex items-center gap-3">
                    <input
                      type="range"
                      id="step-up-pct-range"
                      min="1"
                      max="50"
                      value="10"
                      step="1"
                      class="w-full cursor-pointer accent-brand-blue"
                      aria-label="Annual Step up slider"
                    />
                    <div class="relative w-16 shrink-0">
                      <input
                        type="number"
                        id="step-up-pct-input"
                        min="1"
                        max="50"
                        value="10"
                        class="text-input pr-5 py-1 text-xs text-center font-mono h-8 w-full"
                        inputmode="numeric"
                      />
                      <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
                    </div>
                  </div>
                  <p class="text-[10px] text-stone leading-relaxed">
                    Automatically increases your monthly investment contribution by this percentage once every year.
                  </p>
                </div>
              </div>

              <!-- Lump Sum Top-up -->
              <div class="flex flex-col gap-1.5">
                <label for="lump-sum-input" class="text-[11px] font-semibold text-slate flex justify-between">
                  <span>One-time Lump Sum Top-up (Initial Investment)</span>
                  <span class="currency-label text-stone">INR (₹)</span>
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-xs font-medium currency-symbol">₹</span>
                  <input
                    type="number"
                    id="lump-sum-input"
                    value="0"
                    min="0"
                    max="100000000"
                    step="5000"
                    class="text-input pl-6 pr-2 font-mono text-xs w-full"
                    inputmode="numeric"
                  />
                </div>
              </div>

              <!-- Compounding Frequency -->
              <div class="flex flex-col gap-1.5">
                <label for="compounding-select" class="text-[11px] font-semibold text-slate">Compounding Frequency</label>
                <select id="compounding-select" class="text-input py-1 text-xs font-medium">
                  <option value="monthly" selected>Monthly Compounding (Standard for Mutual Funds)</option>
                  <option value="yearly">Yearly Compounding</option>
                </select>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Guide Panel (5 Columns) -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="card-base bg-surface-soft flex flex-col gap-4">
          <h3 class="font-display font-semibold text-base text-primary">SIP Calculation Guide</h3>
          <div class="flex flex-col gap-2.5 text-xs text-slate leading-relaxed">
            <ol class="list-decimal pl-4 flex flex-col gap-1.5">
              <li><strong>Set investment parameters:</strong> Adjust the monthly SIP contribution amount, duration, and target interest rate using the sliders or direct inputs.</li>
              <li><strong>Toggle Advanced Options</strong> to include an annual step-up increment matching your salary increases or a one-time lump-sum top-up at the start.</li>
              <li><strong>Verify outputs below</strong> instantly: review total contributions, returns generated, and final maturity wealth.</li>
              <li><strong>Export or copy results</strong> using the buttons in the breakdown section. Adjust live parameters in the What-If block.</li>
            </ol>
          </div>
        </div>

        <!-- Privacy Assurance Card -->
        <div class="card-feature-yellow flex flex-col gap-3">
          <span class="badge-tag-yellow bg-yellow-light text-yellow-dark self-start">SECURITY ASSURED</span>
          <h3 class="font-display font-semibold text-base text-primary">Private Client-Side Sandbox</h3>
          <p class="text-xs text-slate leading-relaxed">
            All calculation engines, data tables, and variables process strictly inside your web browser sandbox. No user inputs are ever logged, sent, or saved online.
          </p>
        </div>
      </div>
    </div>

    <!-- Results Section -->
    <div id="results-column" class="flex flex-col gap-6 mt-8 border-t border-hairline pt-8">
      <div class="flex items-center justify-between">
        <h2 class="font-display font-semibold text-2xl text-primary flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-success-accent animate-pulse"></span>
          Returns Summary & Maturity Value
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        <!-- Left: Financial Figures (6 Columns) -->
        <div class="lg:col-span-6 card-base flex flex-col justify-between bg-surface relative overflow-hidden rounded-xl p-6">
          <div class="absolute top-0 right-0 w-32 h-32 bg-success-accent/10 rounded-full blur-3xl"></div>
          
          <div class="flex flex-col gap-4 z-10">
            <div>
              <span class="text-xs font-bold text-slate uppercase tracking-wider block">Estimated Maturity Value</span>
              <div id="maturity-display" class="font-display font-medium text-4xl sm:text-5xl tracking-tight text-primary transition-all duration-300 select-all font-mono">
                ₹0
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 border-t border-hairline pt-4 mt-2">
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate">Total Invested Amount</span>
                <span id="invested-display" class="font-display font-semibold text-base text-primary font-mono select-all">₹0</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate">Estimated Wealth Gained</span>
                <span id="returns-display" class="font-display font-semibold text-base text-success-accent font-mono select-all">₹0</span>
              </div>
            </div>

            <div class="flex flex-col border-t border-hairline pt-4">
              <span class="text-[10px] uppercase font-bold text-slate">Target Completion Date</span>
              <span id="completion-date-display" class="font-display font-semibold text-base text-primary">June 2036</span>
            </div>
          </div>
        </div>

        <!-- Right: Donut SVG Chart (6 Columns) -->
        <div class="lg:col-span-6 card-base grid grid-cols-1 sm:grid-cols-12 gap-6 items-center">
          <div class="sm:col-span-5 flex flex-col items-center justify-center min-h-[160px]">
            <div class="relative w-40 h-40">
              <svg id="donut-svg" class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="40" stroke="var(--color-hairline)" stroke-width="12" fill="transparent"></circle>
                <g id="donut-segments"></g>
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
                <span class="text-[9px] text-stone font-semibold uppercase">Wealth Ratio</span>
                <span id="donut-percent" class="font-display font-bold text-lg text-primary">0%</span>
              </div>
            </div>
          </div>

          <!-- Legends -->
          <div class="sm:col-span-7 flex flex-col gap-3">
            <h3 class="text-xs font-semibold text-slate uppercase tracking-wider pb-1 border-b border-hairline-soft">
              Portfolio Composition
            </h3>
            <ul class="flex flex-col gap-2">
              <li class="flex items-center justify-between text-xs">
                <span class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
                  <span class="text-charcoal font-medium">Total Invested</span>
                </span>
                <span id="legend-invested-val" class="font-mono font-semibold">₹0 (0%)</span>
              </li>
              <li class="flex items-center justify-between text-xs">
                <span class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-success-accent"></span>
                  <span class="text-charcoal font-medium">Estimated Wealth Gained</span>
                </span>
                <span id="legend-returns-val" class="font-mono font-semibold">₹0 (0%)</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Schedule & Detailed Table Card -->
      <div class="card-base flex flex-col gap-4 p-4 sm:p-6 mt-4">
        <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 border-b border-hairline pb-2">
          <h3 class="font-display font-semibold text-base text-primary">Year-by-Year Growth Breakdown</h3>
          <div class="grid grid-cols-3 gap-1.5 sm:flex sm:items-center sm:gap-2 w-full sm:w-auto">
            <button
              type="button"
              id="csv-export-btn"
              class="inline-flex items-center justify-center gap-1 sm:gap-1.5 text-[10px] sm:text-xs font-semibold px-2 sm:px-3.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle w-full"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
              </svg>
              <span><span class="hidden sm:inline">Export </span>CSV</span>
            </button>
            <button
              type="button"
              id="excel-export-btn"
              class="inline-flex items-center justify-center gap-1 sm:gap-1.5 text-[10px] sm:text-xs font-semibold px-2 sm:px-3.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle w-full"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <span><span class="hidden sm:inline">Export </span>Excel</span>
            </button>
            <button
              type="button"
              id="copy-results-btn"
              class="inline-flex items-center justify-center gap-1 sm:gap-1.5 text-[10px] sm:text-xs font-semibold px-2 sm:px-3.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle w-full"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
              </svg>
              <span>Copy<span class="hidden sm:inline"> Results</span></span>
            </button>
          </div>
        </div>

        <div class="w-full overflow-x-auto">
          <table class="w-full text-left text-xs border-collapse">
            <thead>
              <tr class="bg-surface text-stone border-b border-hairline uppercase text-[10px] font-bold tracking-wider font-mono">
                <th class="py-2.5 px-3">Year</th>
                <th class="py-2.5 px-3 text-right">Monthly Investment</th>
                <th class="py-2.5 px-3 text-right">Cumulative Invested</th>
                <th class="py-2.5 px-3 text-right">Wealth Gained</th>
                <th class="py-2.5 px-3 text-right">Year-End Balance</th>
              </tr>
            </thead>
            <tbody id="schedule-table-body">
              <!-- Dynamically populated year-by-year schedule -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Live Sensitivity / What-if block -->
      <div class="card-base flex flex-col gap-4 p-5 sm:p-6 mt-4">
        <h3 class="font-display font-semibold text-base text-primary">What-If / Sensitivity Analysis</h3>
        <p class="text-xs text-slate">See how adjusting key variables impacts your final maturity value compared to your baseline plan.</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-2 border-t border-hairline-soft pt-4">
          <!-- Adjust investment slider -->
          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between text-xs font-semibold">
              <span>What-If Monthly Investment</span>
              <span id="whatif-monthly-display" class="font-mono text-brand-blue">₹0</span>
            </div>
            <input
              type="range"
              id="whatif-monthly-slider"
              min="500"
              max="200000"
              step="500"
              value="25000"
              class="w-full cursor-pointer accent-brand-blue"
            />
          </div>

          <!-- Adjust expected rate slider -->
          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between text-xs font-semibold">
