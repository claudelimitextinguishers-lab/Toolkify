---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Tip & Split Calculator";
const category = "finance";
const tier = "Finance & Tax";
const description =
  "Quickly calculate tip percentages, customize gratuities, and split bills dynamically among friends or colleagues.";
---

<Layout
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Tip & Split Calculator",
      "url": "https://boardtools.app/tools/finance/tip-calculator",
      "description": "Interactive real-time tip calculator and bill splitter with quick presets, custom tip controls, and instant per-person breakdowns.",
      "applicationCategory": "FinancialApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section
    class="max-w-[760px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex items-center gap-2 mt-0.5">
        <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
          {name}
        </h1>
        <span
          class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase"
          >{tier}</span
        >
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col gap-3">
          <!-- Bill Amount -->
          <div class="flex flex-col gap-1">
            <div class="flex items-center justify-between">
              <label for="bill-amount" class="text-[11px] font-semibold text-charcoal">
                Bill Amount
              </label>
              <!-- Currency Select -->
              <select
                id="currency-select"
                class="text-[10px] font-semibold py-1 px-2.5 rounded-full border border-hairline bg-surface hover:bg-canvas cursor-pointer transition-all outline-none"
                aria-label="Currency Select"
              >
                <option value="USD" selected>$ USD</option>
                <option value="CAD">$ CAD</option>
                <option value="GBP">£ GBP</option>
                <option value="AUD">$ AUD</option>
                <option value="EUR">€ EUR</option>
                <option value="INR">₹ INR</option>
                <option value="Custom">Custom / Other</option>
              </select>
            </div>
            <div class="relative">
              <span id="currency-prefix" class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-semibold">$</span>
              <input
                type="number"
                id="bill-amount"
                value="100.00"
                min="0.01"
                max="1000000"
                step="0.01"
                class="text-input pl-7 text-sm font-mono"
                inputmode="decimal"
                placeholder="0.00"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Custom Currency Inputs (Hidden by default) -->
          <div id="custom-currency-container" class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft hidden animate-fade-in-up">
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-symbol" class="text-[10px] font-semibold text-slate">Currency Symbol</label>
              <input type="text" id="custom-currency-symbol" value="$" class="text-input" placeholder="e.g. $, £, €, ₹" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-code" class="text-[10px] font-semibold text-slate">Currency Code</label>
              <input type="text" id="custom-currency-code" value="USD" class="text-input" placeholder="e.g. USD, GBP, EUR" />
            </div>
          </div>

          <!-- Tip Percentage Presets & Custom -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal flex justify-between">
              <span>Tip Percentage</span>
              <span id="tip-pct-label" class="font-mono text-stone font-semibold">15%</span>
            </label>
            
            <!-- Quick Presets -->
            <div class="grid grid-cols-5 gap-1">
              {
                [10, 15, 18, 20, 25].map((pct) => (
                  <button
                    type="button"
                    class="preset-btn text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer border border-hairline text-slate bg-canvas hover:border-hairline-strong active:scale-95 flex items-center justify-center"
                    data-pct={pct}
                  >
                    {pct}%
                  </button>
                ))
              }
            </div>

            <!-- Custom Tip Slider -->
            <div class="flex items-center gap-2 mt-1">
              <input
                type="range"
                id="tip-range"
                min="0"
                max="100"
                value="15"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Custom Tip Slider"
              />
              <div class="relative w-16 shrink-0">
                <input
                  type="number"
                  id="tip-custom-input"
                  min="0"
                  max="100"
                  value="15"
                  class="text-input pr-5 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
              </div>
            </div>
          </div>

          <!-- Number of People to Split -->
          <div class="flex flex-col gap-1">
            <label for="split-people" class="text-[11px] font-semibold text-charcoal">
              Split Bill (Number of People)
            </label>
            <div class="flex items-center gap-2">
              <button
                type="button"
                id="split-minus"
                class="w-9 h-9 flex items-center justify-center border border-hairline hover:border-hairline-strong text-slate hover:text-primary rounded-full transition-all cursor-pointer font-bold text-sm bg-canvas active:scale-90"
              >
                −
              </button>
              <input
                type="number"
                id="split-people"
                value="1"
                min="1"
                max="100"
                step="1"
                class="text-input text-center text-sm font-mono h-9 py-1 flex-grow"
                inputmode="numeric"
                autocomplete="off"
              />
              <button
                type="button"
                id="split-plus"
                class="w-9 h-9 flex items-center justify-center border border-hairline hover:border-hairline-strong text-slate hover:text-primary rounded-full transition-all cursor-pointer font-bold text-sm bg-canvas active:scale-90"
              >
                +
              </button>
            </div>
          </div>
        </div>

        <!-- Right Pane: Outputs -->
        <div class="card-feature-teal flex flex-col justify-between p-4 sm:p-5 relative overflow-hidden rounded-xl">
          <div class="absolute top-0 right-0 w-24 h-24 bg-teal-light/20 rounded-full blur-xl"></div>
          
          <div class="flex flex-col gap-2.5 z-10">
            <!-- Grand Totals -->
            <div class="grid grid-cols-2 gap-4 pb-2 border-b border-moss-dark/10">
              <div class="flex flex-col">
                <span class="text-[9px] uppercase font-bold text-moss-dark/70 tracking-wider">Tip Amount</span>
                <span id="output-tip-total" class="font-display font-semibold text-lg sm:text-xl text-primary font-mono select-all">$0.00</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[9px] uppercase font-bold text-moss-dark/70 tracking-wider">Total Bill</span>
                <span id="output-bill-total" class="font-display font-semibold text-lg sm:text-xl text-primary font-mono select-all">$0.00</span>
              </div>
            </div>

            <!-- Per Person Breakdowns -->
            <div class="flex flex-col gap-2 pt-1">
              <div class="flex items-center justify-between">
                <div class="flex flex-col">
                  <span class="text-[10px] font-semibold text-moss-dark">Tip Per Person</span>
                  <span class="text-[8px] text-moss-dark/60 font-medium">Split share of tip</span>
                </div>
                <span id="output-tip-person" class="font-display font-bold text-xl sm:text-2xl text-primary font-mono select-all">$0.00</span>
              </div>

              <div class="flex items-center justify-between pt-1 border-t border-moss-dark/5">
                <div class="flex flex-col">
                  <span class="text-[10px] font-semibold text-moss-dark">Total Per Person</span>
                  <span class="text-[8px] text-moss-dark/60 font-medium">Split share of bill + tip</span>
                </div>
                <span id="output-total-person" class="font-display font-bold text-2xl sm:text-3xl text-primary font-mono select-all">$0.00</span>
              </div>
            </div>
          </div>

          <!-- Quick Actions / Reset -->
          <div class="flex items-center justify-between gap-2 mt-4 z-10">
            <button
              type="button"
              id="reset-btn"
              class="w-full text-center text-xs py-1.5 px-3 bg-canvas/40 hover:bg-canvas/80 text-moss-dark rounded-full font-semibold border border-moss-dark/15 transition-all cursor-pointer"
            >
              Reset
            </button>
          </div>
        </div>

      </div>
    </div>

    <!-- Security & Privacy Guard Footer Tag -->
    <div class="flex items-center justify-between text-[10px] text-slate px-1">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        100% Private, Client-Side Calculations
      </span>
      <span>v1.0.0</span>
    </div>
  </section>

  <script>
    // State variables
    let currentCurrency = "USD";
    let currentCurrencySymbol = "$";
    let currentCurrencyCode = "USD";
    let currentTipPct = 15;

    // DOM Elements
    const billAmountInput = document.getElementById("bill-amount") as HTMLInputElement;
    const tipPctLabel = document.getElementById("tip-pct-label");
    const presetButtons = document.querySelectorAll(".preset-btn");
    const tipRange = document.getElementById("tip-range") as HTMLInputElement;
    const tipCustomInput = document.getElementById("tip-custom-input") as HTMLInputElement;
    const splitPeopleInput = document.getElementById("split-people") as HTMLInputElement;
    const splitMinusBtn = document.getElementById("split-minus");
    const splitPlusBtn = document.getElementById("split-plus");
    
    const outputTipTotal = document.getElementById("output-tip-total");
    const outputBillTotal = document.getElementById("output-bill-total");
    const outputTipPerson = document.getElementById("output-tip-person");
    const outputTotalPerson = document.getElementById("output-total-person");
    const resetBtn = document.getElementById("reset-btn");

    const currencySelect = document.getElementById("currency-select") as HTMLSelectElement;
    const customCurrencySymbolInput = document.getElementById("custom-currency-symbol") as HTMLInputElement;
    const customCurrencyCodeInput = document.getElementById("custom-currency-code") as HTMLInputElement;
    const customCurrencyContainer = document.getElementById("custom-currency-container");
    const currencyPrefix = document.getElementById("currency-prefix");

    // Load initial values from localStorage if available
    function loadState() {
      try {
        const savedCurrency = localStorage.getItem("tip-calculator-currency");
        const savedCustomSymbol = localStorage.getItem("tip-calculator-custom-symbol");
        const savedCustomCode = localStorage.getItem("tip-calculator-custom-code");
        const savedTip = localStorage.getItem("tip-calculator-tip-pct");
        const savedSplit = localStorage.getItem("tip-calculator-split");
        const savedBill = localStorage.getItem("tip-calculator-bill");

        if (savedCustomSymbol && customCurrencySymbolInput) {
          customCurrencySymbolInput.value = savedCustomSymbol;
        }
        if (savedCustomCode && customCurrencyCodeInput) {
          customCurrencyCodeInput.value = savedCustomCode;
        }
        if (savedCurrency && currencySelect) {
          currencySelect.value = savedCurrency;
        }
        updateCurrencyFromSelect();

        if (savedTip !== null) {
          currentTipPct = parseInt(savedTip, 10);
          tipRange.value = currentTipPct.toString();
          tipCustomInput.value = currentTipPct.toString();
        }
        if (savedSplit !== null) {
          const parsedSplit = parseInt(savedSplit, 10) || 1;
          const clampedSplit = Math.min(100, Math.max(1, parsedSplit));
          splitPeopleInput.value = clampedSplit.toString();
        }
        if (savedBill !== null) {
          billAmountInput.value = savedBill;
        }
      } catch (e) {
        console.warn("Failed to load state from localStorage:", e);
      }
      updateActivePresetButton();
    }

    // Save values to localStorage
    function saveState() {
      try {
        localStorage.setItem("tip-calculator-currency", currentCurrency);
        localStorage.setItem("tip-calculator-custom-symbol", currentCurrencySymbol);
        localStorage.setItem("tip-calculator-custom-code", currentCurrencyCode);
        localStorage.setItem("tip-calculator-tip-pct", currentTipPct.toString());
        localStorage.setItem("tip-calculator-split", splitPeopleInput.value);
        localStorage.setItem("tip-calculator-bill", billAmountInput.value);
      } catch (e) {
        console.warn("Failed to save state to localStorage:", e);
      }
    }

    // Update Currency Choice
    function updateCurrencyFromSelect() {
      if (!currencySelect) return;
      const val = currencySelect.value;
      currentCurrency = val;

      if (val === "USD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "USD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "CAD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "CAD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "GBP") {
        currentCurrencySymbol = "£";
        currentCurrencyCode = "GBP";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "AUD") {
        currentCurrencySymbol = "$";
        currentCurrencyCode = "AUD";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "EUR") {
        currentCurrencySymbol = "€";
        currentCurrencyCode = "EUR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "INR") {
        currentCurrencySymbol = "₹";
        currentCurrencyCode = "INR";
        customCurrencyContainer?.classList.add("hidden");
      } else if (val === "Custom") {
        customCurrencyContainer?.classList.remove("hidden");
        currentCurrencySymbol = customCurrencySymbolInput?.value || "$";
        currentCurrencyCode = customCurrencyCodeInput?.value || "USD";
      }

      if (currencyPrefix) currencyPrefix.textContent = currentCurrencySymbol;
      calculate();
    }

    // High fidelity currency calculation
    function calculate() {
      const bill = Math.max(0, parseFloat(billAmountInput.value) || 0);
      const split = Math.max(1, parseInt(splitPeopleInput.value, 10) || 1);
      
      const tipAmount = (bill * currentTipPct) / 100;
      const totalBill = bill + tipAmount;
      
      const tipPerPerson = tipAmount / split;
      const totalPerPerson = totalBill / split;

      // Update output elements
      if (outputTipTotal) outputTipTotal.textContent = formatCurrency(tipAmount);
      if (outputBillTotal) outputBillTotal.textContent = formatCurrency(totalBill);
      if (outputTipPerson) outputTipPerson.textContent = formatCurrency(tipPerPerson);
      if (outputTotalPerson) outputTotalPerson.textContent = formatCurrency(totalPerPerson);

      if (tipPctLabel) tipPctLabel.textContent = `${currentTipPct}%`;

      saveState();
    }

    // Format utility helper
    function formatCurrency(val: number): string {
      const locale = currentCurrencyCode === "INR" ? "en-IN" : undefined;
      return (
        currentCurrencySymbol +
        val.toLocaleString(locale, {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        })
      );
    }

    // Active button highlight toggle
    function updateActivePresetButton() {
      presetButtons.forEach(btn => {
        const pct = parseInt(btn.getAttribute("data-pct") || "0", 10);
        if (pct === currentTipPct) {
          btn.classList.add("bg-primary", "text-canvas", "border-primary");
          btn.classList.remove("bg-canvas", "text-slate", "border-hairline");
        } else {
          btn.classList.remove("bg-primary", "text-canvas", "border-primary");
          btn.classList.add("bg-canvas", "text-slate", "border-hairline");
        }
      });
    }

    // Set tip percentage from preset or custom input
    function setTipPercentage(pct: number, skipInputUpdate = false) {
      currentTipPct = Math.min(100, Math.max(0, pct));
      tipRange.value = currentTipPct.toString();
      if (!skipInputUpdate) {
        tipCustomInput.value = currentTipPct.toString();
      }
      updateActivePresetButton();
      calculate();
    }

    // Register Event Listeners
    billAmountInput?.addEventListener("input", calculate);

    presetButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const pct = parseInt(btn.getAttribute("data-pct") || "0", 10);
        setTipPercentage(pct);
      });
    });

    tipRange?.addEventListener("input", (e) => {
      const val = parseInt((e.target as HTMLInputElement).value, 10);
      setTipPercentage(val);
    });

    tipCustomInput?.addEventListener("input", (e) => {
      const val = parseInt((e.target as HTMLInputElement).value, 10) || 0;
      setTipPercentage(val, true);
    });

    tipCustomInput?.addEventListener("blur", () => {
      tipCustomInput.value = currentTipPct.toString();
    });

    splitMinusBtn?.addEventListener("click", () => {
      const current = parseInt(splitPeopleInput.value, 10) || 1;
      if (current > 1) {
        splitPeopleInput.value = (current - 1).toString();
        calculate();
      }
    });

    splitPlusBtn?.addEventListener("click", () => {
      const current = parseInt(splitPeopleInput.value, 10) || 1;
      if (current < 100) {
        splitPeopleInput.value = (current + 1).toString();
        calculate();
      }
    });

    splitPeopleInput?.addEventListener("input", () => {
      let current = parseInt(splitPeopleInput.value, 10);
      if (!isNaN(current)) {
        if (current > 100) {
          splitPeopleInput.value = "100";
        } else if (current < 1) {
          splitPeopleInput.value = "1";
        }
      }
      calculate();
    });

    // Currency controls
    currencySelect?.addEventListener("change", updateCurrencyFromSelect);
    customCurrencySymbolInput?.addEventListener("input", () => {
      if (currentCurrency === "Custom") {
        currentCurrencySymbol = customCurrencySymbolInput.value || "$";
        if (currencyPrefix) currencyPrefix.textContent = currentCurrencySymbol;
        calculate();
      }
    });
    customCurrencyCodeInput?.addEventListener("input", () => {
      if (currentCurrency === "Custom") {
        currentCurrencyCode = customCurrencyCodeInput.value || "USD";
        calculate();
      }
    });

    resetBtn?.addEventListener("click", () => {
      billAmountInput.value = "100.00";
      splitPeopleInput.value = "1";
      if (currencySelect) {
        currencySelect.value = "USD";
      }
      if (customCurrencySymbolInput) customCurrencySymbolInput.value = "$";
      if (customCurrencyCodeInput) customCurrencyCodeInput.value = "USD";
      updateCurrencyFromSelect();
      setTipPercentage(15);
      calculate();
    });

    // Initialize Page
    loadState();
    calculate();
  </script>
</Layout>
