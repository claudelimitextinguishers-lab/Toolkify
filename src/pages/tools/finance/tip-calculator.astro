---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Tip & Split Calculator";
const category = "finance";
const tier = "Finance & Tax";

// On-page SEO metadata
const pageTitle =
  "Tip & Split Calculator - Free Tip Calculator & Bill Split Calculator";
const description =
  "Free Tip & Split Calculator to find the perfect tip and split any bill between friends. Restaurant, nail salon & group bill split calculator with per-person totals.";
const canonicalUrl = "https://toolkify.app/tools/finance/tip-calculator";
const ogImage = "/og/tip-split-calculator.png";
const keywords =
  "tip & split calculator, tip calculator, tip calculator google, tip calculator how much to tip, google tip calculator, tip calculator iphone, restaurant tip calculator, tattoo tip calculator, nail salon tip calculator, tax and tip calculator, free tip calculator, ez tip calculator, simple tip calculator, split calculator, rent split calculator, mini split calculator, stock split calculator, bill split calculator, split bill calculator, group bill split calculator, 50/50 split calculator, group expense calculator, 4 way bill split calculator, dinner bill split calculator, 3 way bill split calculator, 4 way split calculator, group expense splitting, split bill app";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Tip & Split Calculator",
      "alternateName": "Tip Calculator & Bill Split Calculator",
      "url": "https://toolkify.app/tools/finance/tip-calculator",
      "description": "Free Tip & Split Calculator and bill splitter with quick tip presets, custom tip controls, tax support, multi-currency formatting and instant per-person breakdowns for groups.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Restaurant tip calculator with quick percentage presets",
        "Custom tip slider for nail salon, tattoo and service tips",
        "Bill split calculator for 2, 3, 4 or more people",
        "Per-person tip and total breakdown",
        "Multi-currency support (USD, GBP, EUR, INR, CAD, AUD)",
        "100% private client-side calculations"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "1640"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Finance & Tax Tools",
          "item": "https://toolkify.app/#finance"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Tip & Split Calculator",
          "item": "https://toolkify.app/tools/finance/tip-calculator"
        }
      ]
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Tip calculator how much to tip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To calculate how much to tip, multiply the pre-tax bill amount by your desired tip percentage (typically 15% to 20% for standard service in the US). For example, a 20% tip on a $50 bill is $10.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Tip calculator how much to tip on $1?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>When using a tip calculator to tip on a $1 bill or transaction, a standard 15% to 20% tip is about $0.15 to $0.20. However, for very small transactions, many people choose to leave a minimum tip of $1.00 to show appreciation to the service provider.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Tip calculator how much to tip for takeout?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>While takeout tipping is optional, a standard tip for food takeout is typically 10% to 15% of the bill, or a flat $2 to $5 for large or complex orders, to thank the staff who packaged and prepared your order.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Tip calculator how much to tip movers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A standard tip for movers is 10% to 20% of the total move cost, split among the crew, or about $20 to $50 per mover per day depending on the difficulty and duration of the move.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much to tip waitress calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A waitress calculator typically uses standard restaurant tipping rates of 18% to 22% for good to excellent table service, and a minimum of 15% for standard service in the United States.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much to tip calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A general how much to tip calculator applies standard industry rates: 18% to 20% for restaurants, 15% to 20% for hair salons and nail salons, 10% to 20% for delivery and movers, and $1 to $2 per drink for bartenders.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much to tip hairdresser calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>When calculating a tip for a hairdresser, the standard etiquette is to tip 15% to 20% of the total service cost, depending on your satisfaction and the complexity of the service (e.g., coloring, styling, or cuts).</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much to tip nail salon calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>For a nail salon calculator, the standard tipping rate is 15% to 20% of the total bill. For example, on a $50 manicure, a standard 20% tip would be $10.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split bills with spouse calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To split bills with your spouse, a calculator can split costs either 50/50, proportionally based on income (e.g., one spouse earns 60% and pays 60%), or by leaving individual personal expenses separate while splitting shared household expenses equally.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split rent with a couple calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>When splitting rent with a couple in a shared house, a common calculator method splits rent based on bedroom usage and common space usage. Often, the couple pays 60% to 66% of the rent (since they occupy one bedroom but two people use the common spaces), while the single roommate pays 34% to 40%.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split tips by hours calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To split tips by hours worked, add up the total hours worked by all employees, divide the total tips collected by the total hours to find the hourly tip rate, and then multiply each employee's worked hours by that hourly rate.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split bills based on income calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To split bills proportionally based on income, add both incomes together to find the household total, divide each individual's income by the total to find their percentage share, and multiply that percentage by the total bill amount.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split up your paycheck calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A paycheck budget calculator often splits your income using the 50/30/20 rule: 50% for needs (rent, utilities, groceries), 30% for wants (dining out, entertainment), and 20% for savings and debt repayment.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split rent with roommates calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A roommate rent calculator splits rent based on private room square footage, amenities (like a private bathroom or balcony), and equal division of common living areas, ensuring everyone pays a fair share for what they use.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split a bill calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A split-a-bill calculator divides the subtotal, tax, and tip evenly among a group of diners, or calculates individual shares based on what each person ordered plus their proportional share of tax and tip.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to split money calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A money splitting calculator divides any sum of money among multiple parties. It can divide the total equally, proportionally based on custom percentages, or by inputting specific shares or expenses to calculate who owes what to whom.</p>"
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[760px] w-full mx-auto px-4 py-3 flex flex-col gap-4 animate-fade-in-up pb-16"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase shrink-0"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How tip calculator works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-red-dark hover:border-brand-red rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col gap-3">
          <!-- Bill Amount -->
          <div class="flex flex-col gap-1">
            <div class="flex items-center justify-between">
              <label for="bill-amount" class="text-[11px] font-semibold text-charcoal">
                Bill Amount
              </label>
              <!-- Currency Select -->
              <select
                id="currency-select"
                class="text-[10px] font-semibold py-1 px-2.5 rounded-full border border-hairline bg-surface hover:bg-canvas cursor-pointer transition-all outline-none"
                aria-label="Currency Select"
              >
                <option value="USD" selected>$ USD</option>
                <option value="CAD">$ CAD</option>
                <option value="GBP">£ GBP</option>
                <option value="AUD">$ AUD</option>
                <option value="EUR">€ EUR</option>
                <option value="INR">₹ INR</option>
                <option value="Custom">Custom / Other</option>
              </select>
            </div>
            <div class="relative">
              <span id="currency-prefix" class="absolute left-3 top-1/2 -translate-y-1/2 text-stone text-sm font-semibold">$</span>
              <input
                type="number"
                id="bill-amount"
                value="100.00"
                min="0.01"
                max="1000000"
                step="0.01"
                class="text-input pl-7 text-sm font-mono"
                inputmode="decimal"
                placeholder="0.00"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Custom Currency Inputs (Hidden by default) -->
          <div id="custom-currency-container" class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft hidden animate-fade-in-up">
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-symbol" class="text-[10px] font-semibold text-slate">Currency Symbol</label>
              <input type="text" id="custom-currency-symbol" value="$" class="text-input" placeholder="e.g. $, £, €, ₹" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="custom-currency-code" class="text-[10px] font-semibold text-slate">Currency Code</label>
              <input type="text" id="custom-currency-code" value="USD" class="text-input" placeholder="e.g. USD, GBP, EUR" />
            </div>
          </div>

          <!-- Tip Percentage Presets & Custom -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal flex justify-between">
              <span>Tip Percentage</span>
              <span id="tip-pct-label" class="font-mono text-stone font-semibold">15%</span>
            </label>
            
            <!-- Quick Presets -->
            <div class="grid grid-cols-5 gap-1">
              {
                [10, 15, 18, 20, 25].map((pct) => (
                  <button
                    type="button"
                    class="preset-btn text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer border border-hairline text-slate bg-canvas hover:border-hairline-strong active:scale-95 flex items-center justify-center"
                    data-pct={pct}
                  >
                    {pct}%
                  </button>
                ))
              }
            </div>

            <!-- Custom Tip Slider -->
            <div class="flex items-center gap-2 mt-1">
              <input
                type="range"
                id="tip-range"
                min="0"
                max="100"
                value="15"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Custom Tip Slider"
              />
              <div class="relative w-16 shrink-0">
                <input
                  type="number"
                  id="tip-custom-input"
                  min="0"
                  max="100"
                  value="15"
                  class="text-input pr-5 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
              </div>
            </div>
          </div>

          <!-- Number of People to Split -->
          <div class="flex flex-col gap-1">
            <label for="split-people" class="text-[11px] font-semibold text-charcoal">
              Split Bill (Number of People)
            </label>
            <div class="flex items-center gap-2">
              <button
                type="button"
                id="split-minus"
                class="w-9 h-9 flex items-center justify-center border border-hairline hover:border-hairline-strong text-slate hover:text-primary rounded-full transition-all cursor-pointer font-bold text-sm bg-canvas active:scale-90"
              >
                −
              </button>
              <input
                type="number"
                id="split-people"
                value="1"
                min="1"
                max="100"
                step="1"
                class="text-input text-center text-sm font-mono h-9 py-1 flex-grow"
                inputmode="numeric"
                autocomplete="off"
              />
              <button
                type="button"
                id="split-plus"
                class="w-9 h-9 flex items-center justify-center border border-hairline hover:border-hairline-strong text-slate hover:text-primary rounded-full transition-all cursor-pointer font-bold text-sm bg-canvas active:scale-90"
              >
                +
              </button>
            </div>
          </div>
        </div>

        <!-- Right Pane: Outputs -->
        <div class="card-feature-teal flex flex-col justify-between p-4 sm:p-5 relative overflow-hidden rounded-xl">
          <div class="absolute top-0 right-0 w-24 h-24 bg-teal-light/20 rounded-full blur-xl"></div>
          
          <div class="flex flex-col gap-2.5 z-10">
            <!-- Grand Totals -->
            <div class="grid grid-cols-2 gap-4 pb-2 border-b border-moss-dark/10">
              <div class="flex flex-col">
                <span class="text-[9px] uppercase font-bold text-moss-dark/70 tracking-wider">Tip Amount</span>
                <span id="output-tip-total" class="font-display font-semibold text-lg sm:text-xl text-primary font-mono select-all">$0.00</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[9px] uppercase font-bold text-moss-dark/70 tracking-wider">Total Bill</span>
                <span id="output-bill-total" class="font-display font-semibold text-lg sm:text-xl text-primary font-mono select-all">$0.00</span>
              </div>
            </div>

            <!-- Per Person Breakdowns -->
            <div class="flex flex-col gap-2 pt-1">
              <div class="flex items-center justify-between">
                <div class="flex flex-col">
                  <span class="text-[10px] font-semibold text-moss-dark">Tip Per Person</span>
                  <span class="text-[8px] text-moss-dark/60 font-medium">Split share of tip</span>
                </div>
                <span id="output-tip-person" class="font-display font-bold text-xl sm:text-2xl text-primary font-mono select-all">$0.00</span>
              </div>

              <div class="flex items-center justify-between pt-1 border-t border-moss-dark/5">
                <div class="flex flex-col">
                  <span class="text-[10px] font-semibold text-moss-dark">Total Per Person</span>
                  <span class="text-[8px] text-moss-dark/60 font-medium">Split share of bill + tip</span>
                </div>
                <span id="output-total-person" class="font-display font-bold text-2xl sm:text-3xl text-primary font-mono select-all">$0.00</span>
              </div>
            </div>
          </div>

          <!-- Quick Actions / Reset -->
          <div class="flex items-center justify-between gap-2 mt-4 z-10">
            <button
              type="button"
              id="reset-btn"
              class="w-full text-center text-xs py-1.5 px-3 bg-canvas/40 hover:bg-canvas/80 text-moss-dark rounded-full font-semibold border border-moss-dark/15 transition-all cursor-pointer"
            >
              Reset
            </button>
          </div>
        </div>

      </div>
    </div>

    <RelatedTools currentSlug="tip-calculator" />

    <!-- Security & Privacy Guard Footer Tag -->
    <div class="flex items-center justify-between text-[10px] text-slate px-1">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        100% Private, Client-Side Calculations
      </span>
      <span>v1.0.0</span>
    </div>
  </section>

  <!-- SEO Content Article -->
  <section
    class="max-w-[760px] w-full mx-auto px-4 pb-20 flex flex-col gap-8 text-slate"
    aria-labelledby="about-tool-heading"
  >
    <article class="flex flex-col gap-4">
      <h2
        id="about-tool-heading"
        class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight"
      >
        Free Tip & Split Calculator for Any Bill
      </h2>
      <p class="text-sm leading-relaxed">
        The <strong>Tip &amp; Split Calculator</strong> is a fast, free tip
        calculator and bill split calculator that figures out the perfect
        gratuity and divides the cost between everyone at the table. Whether you
        are wondering <em>how much to tip</em> after dinner, splitting a check
        with friends, or working out shared costs for a group, this tool gives
        you an instant, accurate per-person breakdown. It runs entirely in your
        browser, works on iPhone, Android, and desktop, and never sends your
        numbers anywhere &mdash; making it a genuinely private, simple tip
        calculator you can trust with every bill.
      </p>
      <p class="text-sm leading-relaxed">
        Unlike the basic Google tip calculator, this is a complete split bill
        app built for real life. Enter your bill amount, tap a quick tip
        preset, choose how many people are sharing the cost, and you instantly
        see the tip amount, the total bill, the tip per person, and the total
        per person. There is no sign-up, no ads getting in the way, and no math
        to do in your head. It is the kind of EZ tip calculator you can pull up
        in seconds the moment the check arrives.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        How to Use the Tip Calculator
      </h3>
      <p class="text-sm leading-relaxed">
        Using this restaurant tip calculator takes three steps. First, type in
        your bill amount &mdash; use the pre-tax subtotal if you prefer to tip
        before tax, or the final total if you want a tax and tip calculator that
        works on the post-tax amount. Second, pick your tip percentage from the
        10%, 15%, 18%, 20%, and 25% presets, or drag the custom slider to set
        any value you like. Third, set the number of people, and the split
        calculator does the rest. Every result updates live as you type, so you
        can compare scenarios in real time.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        How Much Should You Tip?
      </h3>
      <p class="text-sm leading-relaxed">
        In the United States, a standard restaurant tip is 15% to 20% of the
        bill, with 20% widely considered the mark of good service. Service tips
        come up far beyond restaurants, though. A nail salon tip calculator
        scenario usually lands around 15&ndash;20%, and many people use a tattoo
        tip calculator approach of 15&ndash;25% (or more) to thank a great
        artist. Because every situation is different, the custom slider lets you
        answer the "tip calculator how much to tip" question for your own
        budget, the quality of service, and local customs &mdash; no preset
        required.
      </p>

