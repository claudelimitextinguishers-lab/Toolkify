---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Light Meter";
const category = "mobile";
const tier = "Mobile Sensor Tools";
const description = "Measure ambient light levels in real-time. Uses the native Ambient Light Sensor API if supported, or falls back to camera-frame brightness estimation with privacy-safe processing.";

const pageTitle = "Light Meter - Free Online Lux & Light Level Meter App";
const canonicalUrl = "https://toolkify.com/tools/mobile/light-meter";
const ogImage = "/og/light-meter.png";
const keywords = "light meter, what is a light meter, light meter app, light meter photography, best light meter app, how to use a light meter, how do you read a light meter, lux meter, measure light, lux sensor, ambient light sensor, camera light meter";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
