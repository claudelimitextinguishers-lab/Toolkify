  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Elements
      const btnReset = document.getElementById("reset-btn");
      const shareBtn = document.getElementById("share-btn");
      const btnHowItWorks = document.getElementById("how-it-works-btn");
      const modalHowItWorks = document.getElementById("how-it-works-modal");
      const btnCloseModal = document.getElementById("close-modal-btn");
      const btnModalOk = document.getElementById("modal-ok-btn");

      const tabSensor = document.getElementById("mode-sensor-btn");
      const tabCamera = document.getElementById("mode-camera-btn");
      const statusBadge = document.getElementById("status-badge");
      const statusBadgeText = document.getElementById("status-badge-text");
      const unsupportedBanner = document.getElementById("unsupported-banner");

      const gaugeFill = document.getElementById("gauge-fill") as unknown as SVGCircleElement;
      const readoutCategory = document.getElementById("readout-category");
      const readoutValue = document.getElementById("readout-value");
      const readoutUnit = document.getElementById("readout-unit");
      const modeGuidelineDesc = document.getElementById("mode-guideline-desc");

      const btnCaptureToggle = document.getElementById("capture-toggle-btn");
      const captureToggleText = document.getElementById("capture-toggle-text");
      const captureToggleIcon = document.getElementById("capture-toggle-icon");
      const cameraSelect = document.getElementById("camera-select") as HTMLSelectElement;
      const deniedPanel = document.getElementById("permission-denied-panel");
      const cameraThumbnailContainer = document.getElementById("camera-thumbnail-container");
      const videoFeed = document.getElementById("video-feed") as HTMLVideoElement;

      // Stats
      const statMin = document.getElementById("stat-min");
      const statMax = document.getElementById("stat-max");
      const statAvg = document.getElementById("stat-avg");
      const btnResetPeaks = document.getElementById("reset-peaks-btn");

      // Photography helpers
      const photoEv = document.getElementById("photo-ev");
      const photoAperture = document.getElementById("photo-aperture");
      const photoShutter = document.getElementById("photo-shutter");

      // History log
      const historyLogBody = document.getElementById("history-log-body");
      const btnExportCsv = document.getElementById("export-csv-btn") as HTMLButtonElement;

      // State Variables
      let currentMode: "sensor" | "camera" = "sensor";
      let isCapturing = false;
      let sensorInstance: any = null;
      let cameraStream: MediaStream | null = null;
      let sampleIntervalId: any = null;

      // Statistics session counters
      let currentReading = 0;
      let sessionMin = Infinity;
      let sessionMax = -Infinity;
      let sessionSum = 0;
      let sessionCount = 0;
      let sessionHistory: Array<{ timestamp: string, mode: string, value: number, formatted: string }> = [];

      // Offscreen canvas for sampling camera frame luminance
      const canvas = document.createElement("canvas");
      const ctx = canvas.getContext("2d");

      // Verbatim How it works modal interactions (Matches requirement 1)
      btnHowItWorks?.addEventListener("click", () => {
        modalHowItWorks?.classList.remove("hidden");
      });
      btnCloseModal?.addEventListener("click", () => {
        modalHowItWorks?.classList.add("hidden");
      });
      btnModalOk?.addEventListener("click", () => {
        modalHowItWorks?.classList.add("hidden");
      });
      modalHowItWorks?.addEventListener("click", (e) => {
        if (e.target === modalHowItWorks) {
          modalHowItWorks.classList.add("hidden");
        }
      });

      // Check AmbientLightSensor Support
      const hasSensorSupport = "AmbientLightSensor" in window;

      // Load saved preferences or URL param
      const urlParams = new URLSearchParams(window.location.search);
      const get = (lsKey: string, urlKey: string): string | null => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        if (typeof localStorage === 'undefined') return null;
        try { return localStorage.getItem(lsKey); } catch (e) { return null; }
      };

      const savedMode = get("toolkify:light-meter:mode", "mode");
      if (savedMode === "camera" || !hasSensorSupport) {
        setMode("camera");
      } else {
        setMode("sensor");
      }

      // Switch tabs
      tabSensor?.addEventListener("click", () => setMode("sensor"));
      tabCamera?.addEventListener("click", () => setMode("camera"));

      function setMode(mode: "sensor" | "camera") {
        if (isCapturing) {
          stopCapture();
        }

        currentMode = mode;
        localStorage.setItem("toolkify:light-meter:mode", mode);
        resetPeaks();

        if (mode === "sensor") {
          tabSensor?.classList.add("bg-primary", "text-canvas");
          tabSensor?.classList.remove("text-slate");
          tabCamera?.classList.remove("bg-primary", "text-canvas");
          tabCamera?.classList.add("text-slate");

          cameraSelect?.classList.add("hidden");
          cameraThumbnailContainer?.classList.add("hidden");
          readoutUnit!.textContent = "Lux";
          modeGuidelineDesc!.textContent = "Uses the native browser AmbientLightSensor API to measure authentic physical Lux values.";

          if (!hasSensorSupport) {
            unsupportedBanner?.classList.remove("hidden");
            updateBadge("Unsupported", "bg-brand-red/10 border-brand-red text-brand-red");
          } else {
            unsupportedBanner?.classList.add("hidden");
            updateBadge("Sensor Available", "bg-brand-teal/10 border-brand-teal text-moss-dark");
          }
        } else {
          tabCamera?.classList.add("bg-primary", "text-canvas");
          tabCamera?.classList.remove("text-slate");
          tabSensor?.classList.remove("bg-primary", "text-canvas");
          tabSensor?.classList.add("text-slate");

          unsupportedBanner?.classList.add("hidden");
          cameraSelect?.classList.remove("hidden");
          readoutUnit!.textContent = "% Brightness";
          modeGuidelineDesc!.textContent = "Analyzes camera pixel average luminance at 3Hz. Displayed on a relative 0-100% scale.";
          updateBadge("Camera Ready", "bg-brand-blue/10 border-brand-blue text-brand-blue");
        }

        resetDisplay();
      }

      function updateBadge(text: string, classes: string) {
        if (statusBadge && statusBadgeText) {
          statusBadge.className = `inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full border ${classes}`;
          statusBadgeText.textContent = text;
        }
      }

      function resetDisplay() {
        currentReading = 0;
        readoutValue!.textContent = "0";
        readoutCategory!.textContent = "Lighter";
        updateGauge(0);
        updateExposureHelper(0);
      }

      // Start & Stop capture toggle
      btnCaptureToggle?.addEventListener("click", () => {
        if (isCapturing) {
          stopCapture();
        } else {
          startCapture();
        }
      });

      async function startCapture() {
        deniedPanel?.classList.add("hidden");
        
        if (currentMode === "sensor") {
          if (!hasSensorSupport) {
            alert("Ambient Light Sensor is not supported in this browser. Please switch to Camera mode.");
            return;
          }

          try {
            // @ts-ignore
            sensorInstance = new AmbientLightSensor({ frequency: 5 });
            sensorInstance.addEventListener("reading", () => {
              const luxValue = sensorInstance.lux;
              handleNewReading(luxValue);
            });
            sensorInstance.addEventListener("error", (event: any) => {
              console.error("Sensor error", event);
              updateBadge("Sensor Restricted", "bg-brand-red/10 border-brand-red text-brand-red");
              stopCapture();
            });

            sensorInstance.start();
            isCapturing = true;
            toggleCaptureUI(true);
            updateBadge("Sensor Live", "bg-success-accent/10 border-success-accent text-success-accent");
          } catch (e) {
            console.error("Failed to start AmbientLightSensor", e);
            updateBadge("Sensor Error", "bg-brand-red/10 border-brand-red text-brand-red");
          }
        } else {
          // Camera Capture Path
          const facingMode = cameraSelect?.value || "environment";
          try {
            cameraStream = await navigator.mediaDevices.getUserMedia({
              video: { facingMode: facingMode }
            });

            videoFeed.srcObject = cameraStream;
            videoFeed.onloadedmetadata = () => {
              videoFeed.play();
            };

            cameraThumbnailContainer?.classList.remove("hidden");
            isCapturing = true;
            toggleCaptureUI(true);
            updateBadge("Estimator Live", "bg-success-accent/10 border-success-accent text-success-accent");

            // Setup frame sampler running 3 times per second (3Hz)
            sampleIntervalId = setInterval(sampleCameraFrame, 333);
          } catch (err) {
            console.error("Camera access failed", err);
            deniedPanel?.classList.remove("hidden");
            updateBadge("Camera Denied", "bg-brand-red/10 border-brand-red text-brand-red");
          }
        }
      }

      function stopCapture() {
        isCapturing = false;
        toggleCaptureUI(false);

        // Stop Ambient Sensor
        if (sensorInstance) {
          try {
            sensorInstance.stop();
          } catch (e) {}
          sensorInstance = null;
        }

        // Stop Camera Streams
        if (sampleIntervalId) {
          clearInterval(sampleIntervalId);
          sampleIntervalId = null;
        }

        if (cameraStream) {
          cameraStream.getTracks().forEach(track => track.stop());
          cameraStream = null;
        }

        videoFeed.srcObject = null;
        cameraThumbnailContainer?.classList.add("hidden");

        if (currentMode === "sensor") {
          updateBadge("Sensor Available", "bg-brand-teal/10 border-brand-teal text-moss-dark");
        } else {
          updateBadge("Camera Ready", "bg-brand-blue/10 border-brand-blue text-brand-blue");
        }
      }

      function toggleCaptureUI(active: boolean) {
        if (active) {
          captureToggleText!.textContent = "Pause Capture";
          captureToggleIcon?.classList.add("bg-success-accent");
          captureToggleIcon?.classList.remove("bg-slate");
          btnCaptureToggle?.classList.add("bg-charcoal");
        } else {
          captureToggleText!.textContent = "Start Capture";
          captureToggleIcon?.classList.remove("bg-success-accent");
          captureToggleIcon?.classList.add("bg-slate");
          btnCaptureToggle?.classList.remove("bg-charcoal");
        }
      }

      // Sample camera frame to calculate relative average luminance
      function sampleCameraFrame() {
        if (!videoFeed || videoFeed.paused || videoFeed.ended) return;

        const width = 80;
        const height = 60;
        canvas.width = width;
        canvas.height = height;

        if (ctx) {
          try {
            ctx.drawImage(videoFeed, 0, 0, width, height);
            const imgData = ctx.getImageData(0, 0, width, height);
            const data = imgData.data;

            let luminanceTotal = 0;
            let count = 0;

            for (let i = 0; i < data.length; i += 4) {
              const r = data[i];
              const g = data[i+1];
              const b = data[i+2];
              // Standard BT.601 weights for relative luminance
              const l = 0.299 * r + 0.587 * g + 0.114 * b;
              luminanceTotal += l;
              count++;
            }

            const averageLuminance = count > 0 ? (luminanceTotal / count) : 0;
            // Map average (0-255) to relative brightness scale 0-100
            const relativeBrightness = Math.round((averageLuminance / 255) * 100);
            
            // Light smoothing to prevent sudden micro-exposure jumps
            const smoothed = Math.round(currentReading * 0.4 + relativeBrightness * 0.6);

            handleNewReading(smoothed);
          } catch (e) {
            console.error("Frame sample error", e);
          }
        }
      }

      // Handle new light reading & update state
      function handleNewReading(val: number) {
        currentReading = val;
        
        // Update stats
        if (val < sessionMin) sessionMin = val;
        if (val > sessionMax) sessionMax = val;
        sessionSum += val;
        sessionCount++;

        // Update readouts
        readoutValue!.textContent = val.toString();
        
        const isLux = currentMode === "sensor";
        updateGauge(val, isLux);
        updateStats();

        // Categorize brightness
        let category = "Medium";
        if (isLux) {
          if (val < 10) category = "Very Low (Night)";
          else if (val < 100) category = "Low (Dim Indoors)";
          else if (val < 500) category = "Medium (Typical Indoor)";
          else if (val < 2000) category = "High (Overcast Day)";
          else category = "Very High (Direct Sun)";
        } else {
          if (val < 20) category = "Low (Dark)";
          else if (val < 55) category = "Medium (Indoor)";
          else if (val < 80) category = "Bright (Daylight)";
          else category = "Very Bright (Sun)";
        }
        readoutCategory!.textContent = category;

        // Update photographic calculations
        updateExposureHelper(val);

        // Record history at moderate interval or reading jumps
        logHistoryReading(val, isLux ? "Sensor (Lux)" : "Camera (Relative)");
      }

      function updateGauge(val: number, isLux = false) {
        if (!gaugeFill) return;
        
        // Map value to gauge percent (0 to 1)
        let percent = 0;
        if (isLux) {
          // Logarithmic scale for physical Lux since it spans 0 to 100,000+
          if (val > 0) {
            percent = Math.min(Math.log10(val) / 5.0, 1.0); // max 100,000 lux
          }
        } else {
          percent = val / 100;
        }

        // Circular stroke math
        const radius = 40;
        const circumference = 2 * Math.PI * radius; // ~251.2
        const offset = circumference - (percent * circumference);
        gaugeFill.style.strokeDashoffset = offset.toString();
      }

      function updateStats() {
        statMin!.textContent = sessionMin === Infinity ? "â€”" : sessionMin + (currentMode === "sensor" ? " lx" : "%");
        statMax!.textContent = sessionMax === -Infinity ? "â€”" : sessionMax + (currentMode === "sensor" ? " lx" : "%");
        
        const avg = sessionCount > 0 ? Math.round(sessionSum / sessionCount) : 0;
        statAvg!.textContent = sessionCount === 0 ? "â€”" : avg + (currentMode === "sensor" ? " lx" : "%");
      }

      // Exposure Helper calculations (standard photographic logic)
      function updateExposureHelper(val: number) {
        if (val === 0) {
          photoEv!.textContent = "â€”";
          photoShutter!.textContent = "â€”";
          return;
        }

        let ev100 = 0;
        if (currentMode === "sensor") {
          // EV100 = log2(Lux / 2.5) standard calculation
          ev100 = Math.round(Math.log2(val / 2.5) * 10) / 10;
        } else {
          // Convert 0-100 estimate to a pseudo EV range between -2 and 14
          ev100 = Math.round((-2 + (val / 100) * 16) * 10) / 10;
        }

        photoEv!.textContent = ev100.toFixed(1);

        // Calculate shutter speed assuming ISO 100 and aperture f/8
        // Speed = (Aperture^2 * 100) / (ISO * 2^(EV100))
        // N^2 / t = L * S / K => t = N^2 * K / (L * S) = f^2 * 2.5 / (Lux)
        // With standard constants: t = 64 / (2^EV100)
        const denominator = Math.pow(2, ev100);
        if (denominator > 0) {
          const shutterSec = 64 / denominator;
          
          let speedStr = "";
          if (shutterSec > 30) {
            speedStr = "Very Long Exposure";
          } else if (shutterSec >= 1) {
            speedStr = `${Math.round(shutterSec * 10) / 10}s`;
          } else {
            const denominatorFrac = Math.round(1 / shutterSec);
            speedStr = `1/${denominatorFrac}s`;
          }
          photoShutter!.textContent = speedStr;
        } else {
          photoShutter!.textContent = "Bulb";
        }
      }

      // Log a session measurement
      let lastLogTime = 0;
      function logHistoryReading(val: number, modeLabel: string) {
        const now = Date.now();
        // Log at most once every 3 seconds to avoid grid overload
        if (now - lastLogTime < 3000) return;
        lastLogTime = now;

        const timeStr = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const entry = {
          timestamp: timeStr,
          mode: modeLabel,
          value: val,
          formatted: val + (currentMode === "sensor" ? " lx" : "%")
        };

        sessionHistory.unshift(entry); // Complete list is kept for CSV export

        // Render top 5 table rows in UI
        const visibleHistory = sessionHistory.slice(0, 5);
        historyLogBody!.innerHTML = visibleHistory.map(entry => `
          <tr class="hover:bg-surface-soft transition-colors">
            <td class="p-2 text-slate">${entry.timestamp}</td>
            <td class="p-2 text-slate">${entry.mode}</td>
            <td class="p-2 text-right font-semibold">${entry.formatted}</td>
          </tr>
        `).join("");

        btnExportCsv.disabled = false;
      }

      btnResetPeaks?.addEventListener("click", () => {
        resetPeaks();
      });

      function resetPeaks() {
        sessionMin = Infinity;
        sessionMax = -Infinity;
        sessionSum = 0;
        sessionCount = 0;
        updateStats();
      }

      // Export log as CSV format
      btnExportCsv?.addEventListener("click", () => {
        if (sessionHistory.length === 0) return;

        let csvContent = "data:text/csv;charset=utf-8,";
        csvContent += "Timestamp,Mode,Reading\r\n";

        sessionHistory.forEach(row => {
          csvContent += `"${row.timestamp}","${row.mode}","${row.value}"\r\n`;
        });

        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", `light_meter_readings_${Date.now()}.csv`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      });

      // Camera Facing Mode Mid-Session Restart
      cameraSelect?.addEventListener("change", () => {
        if (currentMode === "camera" && isCapturing) {
          stopCapture();
          startCapture();
        }
      });

      // Verbatim Reset button interaction implementation (Satisfies requirement 1)
      btnReset?.addEventListener("click", () => {
        // Clear URL parameters
        if (window.history.pushState) {
          const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
          window.history.pushState({path:newurl}, '', newurl);
        }

        stopCapture();
        resetPeaks();
        resetDisplay();
        
        if (cameraSelect) {
          cameraSelect.value = "environment";
        }
        
        sessionHistory = [];
        historyLogBody!.innerHTML = `
          <tr>
            <td colspan="3" class="p-4 text-center text-slate italic">No readings logged yet. Start capturing to log.</td>
          </tr>
        `;
        btnExportCsv.disabled = true;

        localStorage.removeItem("toolkify:light-meter:mode");
      });

      // Share Event Listener
      shareBtn?.addEventListener("click", () => {
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set("mode", currentMode);

        const shareData = {
          title: document.title || "Light Meter",
          url: url.toString()
        };

        if (navigator.share) {
          navigator.share(shareData).catch((err) => {
            if (err.name !== "AbortError") {
              copyToClipboard(url.toString());
            }
          });
        } else {
          copyToClipboard(url.toString());
        }

        function copyToClipboard(text: string) {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
          } else {
            fallbackCopy(text);
          }
        }

        function fallbackCopy(text: string) {
          const textArea = document.createElement("textarea");
          textArea.value = text;
          textArea.style.position = "fixed";
          textArea.style.opacity = "0";
          document.body.appendChild(textArea);
          textArea.select();
          try {
            document.execCommand("copy");
            showSuccess();
          } catch (err) {
            console.error(err);
          }
          document.body.removeChild(textArea);
        }

        function showSuccess() {
          if (shareBtn) {
            const span = shareBtn.querySelector("span");
            if (span) {
              const originalText = span.textContent || "Share";
              span.textContent = "Link Copied!";
              shareBtn.classList.add("text-success-accent", "border-success-accent");
              setTimeout(() => {
                span.textContent = originalText;
                shareBtn.classList.remove("text-success-accent", "border-success-accent");
              }, 2000);
            }
          }
        }
      });

      // FAQ Accordion Toggle Interaction
      const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
      faqToggleButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const expanded = btn.getAttribute("aria-expanded") === "true";
          
          // Close other open accordions
          faqToggleButtons.forEach((otherBtn) => {
            if (otherBtn !== btn) {
              otherBtn.setAttribute("aria-expanded", "false");
              const otherContent = otherBtn.nextElementSibling;
              if (otherContent) otherContent.classList.add("hidden");
              otherBtn.querySelector("svg")?.classList.remove("rotate-180");
            }
          });

          // Toggle current accordion
          btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
          const content = btn.nextElementSibling;
          if (content) {
            content.classList.toggle("hidden");
          }
          btn.querySelector("svg")?.classList.toggle("rotate-180");
        });
      });

      // Close streams on visibility/tab loss
      document.addEventListener("visibilitychange", () => {
        if (document.hidden && isCapturing) {
          stopCapture();
        }
      });
    });
  </script>
</Layout>
