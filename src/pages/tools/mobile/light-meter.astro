  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Light Meter",
      "alternateName": "Ambient Lux Meter & Camera Brightness Estimator",
      "url": "https://toolkify.com/tools/mobile/light-meter",
      "description": "Free, privacy-first web-based light meter. Leverages the native Ambient Light Sensor API for true Lux readings, or falls back to camera-frame brightness estimation with smooth readings and real-time statistics.",
