        <button id="retry-permission-btn" class="button-secondary text-xs py-1.5 px-4 cursor-pointer rounded-full font-semibold">
          Try Again
        </button>
      </div>

      <div id="sensor-simulation-banner" class="hidden flex items-center justify-between px-3 py-2 border border-brand-yellow-deep/30 rounded-lg bg-surface-yellow text-[11px] text-slate">
        <div class="flex items-center gap-2">
          <span>âš ï¸ <strong>Demo Simulation Mode:</strong> Accelerometer hardware not detected (common on desktop). Using mock motion waves.</span>
        </div>
        <button id="toggle-sim-off-btn" class="text-brand-blue hover:underline font-semibold cursor-pointer">
          Use Real API
        </button>
      </div>

      <!-- MAIN SENSOR INTERFACE -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-stretch">
        
        <!-- Interactive Form / Live Visualizer Panel -->
        <div class="lg:col-span-8 flex flex-col gap-4">
          
          <!-- Mode, Controls, and Shake Thresholds adjacent to main display for mobile zero-scroll -->
          <div class="flex flex-wrap items-center justify-between gap-3 bg-surface p-3 rounded-xl border border-hairline-soft">
            
            <!-- Sensor Modes -->
            <div class="flex flex-col gap-1">
