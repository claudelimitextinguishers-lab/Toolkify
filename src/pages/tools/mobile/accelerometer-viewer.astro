                <label for="shake-threshold-input" class="text-[10px] font-semibold text-slate">Shake Threshold (m/sÂ²)</label>
                <input
                  type="number"
                  id="shake-threshold-input"
                  min="0.5"
                  max="50"
                  step="0.5"
                  value="12.0"
                  class="text-input h-7 py-0.5 px-2 text-[11px] w-20 border border-hairline-strong bg-canvas rounded-md"
                />
              </div>

              <div class="flex flex-col gap-1">
                <span class="text-[10px] font-semibold text-slate block">&nbsp;</span>
                <div class="flex gap-2">
