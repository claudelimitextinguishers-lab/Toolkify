---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Accelerometer Viewer";
const category = "mobile";
const tier = "Mobile Sensor Tools";
const description = "Use our free online accelerometer viewer to measure real-time 3-axis motion and gravity. Record, graph, and export sensor data logs from your mobile device.";
const pageTitle = "Accelerometer Viewer - Free Online 3-Axis Sensor & Logger";
const keywords = "accelerometer, accelerometer sensor, what is an accelerometer, accelerometer definition, how does an accelerometer work, accelerometer what does it do, 3 axis accelerometer, accelerometer logger, what does an accelerometer measure";
const canonicalUrl = "https://toolkify.com/tools/mobile/accelerometer-viewer";
const ogImage = "/og/accelerometer-viewer.png";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Accelerometer Viewer",
      "alternateName": "Browser Accelerometer & Motion Plotter",
      "url": "https://toolkify.com/tools/mobile/accelerometer-viewer",
      "description": "Visualize and record real-time accelerometer data including gravity-compensated acceleration and gravity-inclusive values.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires DeviceMotionEvent API.",
      "featureList": [
        "Real-time X, Y, Z acceleration data at high refresh rates (~60Hz)",
        "Gravity-compensated vs. gravity-included measurement modes",
        "Total combined vector magnitude (G-Force representation)",
        "High-performance HTML5 Canvas rolling history graph",
        "Session recording with exportable CSV and JSON options",
        "Customizable shake/impact threshold flash triggers",
        "iOS 13+ permission integration and device simulation"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an accelerometer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>An accelerometer is a specialized sensor that measures proper accelerationâ€”the rate of change of velocity of a physical body relative to its own rest frame. It translates physical motion, tilts, and gravitational forces into readable digital data.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How does an accelerometer work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>An accelerometer works by utilizing micro-electromechanical systems (MEMS) in modern devices. Microscopic seismic masses suspended by silicon springs shift when the device moves, altering the electrical capacitance. The sensor measures this capacitance shift to calculate the exact direction and magnitude of acceleration.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Accelerometer: what does it do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>An accelerometer detects dynamic motion forces, including vibration, shake, tilt, and impact, as well as static forces like gravity. This allows applications to automate screen rotation, track physical steps, trigger airbag deployment, or run structural vibration analyses.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does an accelerometer measure?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>An accelerometer measures acceleration along three axes: X (lateral, side-to-side), Y (longitudinal, forward-backward), and Z (vertical, up-down). It can measure raw values (which include Earth's 9.81 m/sÂ² gravity force) or gravity-compensated values representing purely user-initiated movement.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much does an accelerometer cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Standard MEMS accelerometer chips used in modern consumer electronics cost between $1.00 and $5.00. Industrial-grade, high-precision 3-axis accelerometer loggers used for vibration monitoring or aerospace testing are much more rugged and can range from $100 to over $1,000.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to measure vibration using accelerometer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To measure vibration, mount the accelerometer securely to the target object, configure a high sampling rate (typically 50Hz to 100Hz+), and record the 3-axis acceleration. Analyzing the resulting log's peak amplitude and frequency shifts provides a detailed vibration profile.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How does accelerometer sensor work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>An accelerometer sensor works by converting physical force into electrical signals. It achieves this either through capacitive sensing (where motion shifts a microscopic mass to change electrical capacity) or piezoelectric sensing (where physical pressure on a crystal structure generates a proportional electrical charge).</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
