              <span class="text-[10px] font-semibold text-slate pl-1.5 uppercase">Y (Longitudinal)</span>
              <div class="pl-1.5">
                <div class="text-xl sm:text-2xl font-bold tracking-tight text-primary font-mono" id="y-value">0.00</div>
                <div class="text-[9px] text-stone mt-0.5 flex justify-between">
                  <span>Peak:</span>
                  <span class="font-semibold font-mono" id="y-peak">0.00</span>
                </div>
              </div>
            </div>

            <!-- Z Axis -->
            <div class="p-3 bg-canvas rounded-xl border border-hairline-soft shadow-subtle flex flex-col gap-1 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-1 h-full bg-brand-teal"></div>
              <span class="text-[10px] font-semibold text-slate pl-1.5 uppercase">Z (Vertical)</span>
              <div class="pl-1.5">
                <div class="text-xl sm:text-2xl font-bold tracking-tight text-primary font-mono" id="z-value">0.00</div>
                <div class="text-[9px] text-stone mt-0.5 flex justify-between">
                  <span>Peak:</span>
                  <span class="font-semibold font-mono" id="z-peak">0.00</span>
                </div>
              </div>
            </div>

            <!-- Combined Magnitude -->
            <div class="p-3 bg-canvas rounded-xl border border-hairline-soft shadow-subtle flex flex-col gap-1 relative overflow-hidden" id="magnitude-card">
              <div class="absolute top-0 left-0 w-1 h-full bg-primary animate-pulse"></div>
              <span class="text-[10px] font-semibold text-slate pl-1.5 uppercase">Total Magnitude</span>
              <div class="pl-1.5">
                <div class="text-xl sm:text-2xl font-bold tracking-tight text-primary font-mono" id="mag-value">0.00</div>
                <div class="text-[9px] text-stone mt-0.5 flex justify-between">
                  <span>Max Peak:</span>
                  <span class="font-semibold font-mono" id="mag-peak">0.00</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Real-time Canvas Graph Visualizer -->
          <div class="bg-canvas rounded-xl border border-hairline-soft p-3 relative flex flex-col gap-2 shadow-subtle">
            <div class="flex items-center justify-between">
              <span class="text-[10px] font-semibold text-slate uppercase tracking-wider">Live Waveform (m/sÂ²)</span>
              
              <!-- Checkboxes to show/hide lines -->
              <div class="flex items-center gap-3 text-[9px] font-semibold">
                <label class="flex items-center gap-1 cursor-pointer">
                  <input type="checkbox" id="chk-show-x" checked class="accent-brand-blue" />
                  <span class="text-brand-blue">X</span>
                </label>
                <label class="flex items-center gap-1 cursor-pointer">
                  <input type="checkbox" id="chk-show-y" checked class="accent-brand-coral" />
                  <span class="text-brand-coral">Y</span>
                </label>
                <label class="flex items-center gap-1 cursor-pointer">
                  <input type="checkbox" id="chk-show-z" checked class="accent-brand-teal" />
                  <span class="text-brand-teal">Z</span>
                </label>
                <label class="flex items-center gap-1 cursor-pointer">
                  <input type="checkbox" id="chk-show-mag" checked class="accent-slate" />
                  <span class="text-slate">Mag</span>
                </label>
              </div>
            </div>

            <!-- Canvas Element -->
            <canvas id="motion-canvas" class="w-full h-36 sm:h-44 bg-surface rounded-lg border border-hairline-soft cursor-pointer block"></canvas>
            
            <div class="text-[9px] text-stone flex justify-between">
              <span>Time-window: Last 6 seconds</span>
              <span>Click graph to pause rendering</span>
            </div>
          </div>

        </div>

        <!-- Documentation, Session Logs & Secondary Metrics Sidebar -->
        <div class="lg:col-span-4 flex flex-col gap-4">
          
          <!-- Shake/Impact Detection Trigger Box -->
          <div id="shake-impact-box" class="p-4 bg-canvas rounded-xl border border-hairline-soft shadow-subtle flex flex-col justify-center items-center text-center gap-2 transition-all duration-300">
            <span class="text-[10px] font-semibold text-slate uppercase tracking-wider">Impact Trigger Monitor</span>
