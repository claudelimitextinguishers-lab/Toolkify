              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- MAIN WORKSPACE CONTAINER -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 print:border-none print:shadow-none print:bg-transparent print:p-0">
      
      <!-- iOS Permission Request & Simulation Warning Banners -->
      <div id="sensor-permission-panel" class="hidden flex flex-col items-center justify-center p-4 sm:p-6 border border-dashed border-brand-blue/30 rounded-xl bg-surface-pricing-featured/30 text-center gap-2 sm:gap-3">
