---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Orientation Lock Check";
const category = "mobile";
const tier = "Mobile Sensor Tools";
const pageTitle = "Orientation Lock - Test Screen Rotation & Lock Status";
const description = "Test your screen orientation lock online. Check portrait orientation lock, screen angles, safe area insets, and verify if portrait orientation lock is not working.";
const canonicalUrl = "https://toolkify.app/tools/mobile/orientation-lock";
const ogImage = "/og/orientation-lock.png";
const keywords = "orientation lock, portrait orientation lock, portrait orientation lock button, what is portrait orientation lock, what does portrait orientation lock do, screen orientation lockscreen orientation lock, what does portrait orientation lock mean, portrait orientation lock not working, portrait orientation lock meaning, portrait orientation lock in settings";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Orientation Lock Check",
      "alternateName": "Screen Rotation Tester & Orientation API Checker",
      "url": "https://toolkify.app/tools/mobile/orientation-lock",
      "description": "A client-side screen orientation tester and rotation diagnostic tool. Analyzes screen angle, layout safe area insets, logs orientationchange events, and infers rotation-lock status using motion sensors.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires Screen Orientation API.",
      "featureList": [
        "Read live orientation type (portrait-primary, landscape-primary, etc.)",
        "Live screen angle indicator (0°, 90°, 180°, 270°)",
        "Phone silhouette visual rotation matching device physical state",
        "Best-effort rotation-lock status inference via accelerometer motion vs screen state",
        "Lock testing via screen.orientation.lock() API with clean exception reports",
        "Test sequence guided checklist for all 4 orientations",
        "Viewport dimension and CSS environment safe-area inset readouts",
        "Exportable text diagnostic summary and copy-to-clipboard logs"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Mobile",
          "item": "https://toolkify.app/tools/mobile"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Orientation Lock Check",
          "item": "https://toolkify.app/tools/mobile/orientation-lock"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is portrait orientation lock?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Portrait orientation lock is a mobile device feature that keeps the screen display locked in a vertical (portrait) position. When enabled, it prevents the screen from automatically rotating to landscape mode when the phone or tablet is tilted sideways.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does portrait orientation lock do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Portrait orientation lock disables the automatic screen rotation triggered by the device's physical sensors (like the accelerometer and gyroscope). It forces the user interface to stay in a vertical layout, which is highly useful when reading in bed, texting, or walking.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does portrait orientation lock mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Portrait orientation lock means that your device is locked to a vertical screen layout. Even if you turn your device horizontally or upside down, the display will not rotate, ensuring a stable and consistent viewing experience for vertical content.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Where is the portrait orientation lock button?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>On Apple iOS devices, the portrait orientation lock button is in the Control Center (swipe down from the top-right corner), represented by a padlock inside a circular arrow. On Android, the equivalent setting is typically in the Quick Settings dropdown (swipe down from the top of the screen) named 'Auto-rotate' or 'Portrait'. You can also find it under Display settings.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is orientation lock?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Orientation lock is a general software feature on mobile operating systems and web applications that restricts the display configuration to a specific mode, such as portrait or landscape. It prevents automatic screen re-rendering when physical device orientation changes.</p>"
          }
        }
      ]
    }
  </script>

