  <!-- Client-side Logic Script -->
  <script>
    // State definitions
    interface SequenceState {
      "portrait-primary": boolean;
      "landscape-primary": boolean;
      "portrait-secondary": boolean;
      "landscape-secondary": boolean;
    }

    interface LogItem {
      timestamp: string;
      event: string;
      details: string;
    }

    // Local Storage Keys (toolkify:{tool-slug}:{key})
    const LS_CHECKLIST = "toolkify:orientation-lock:test-sequence";

    let stateChecklist: SequenceState = {
      "portrait-primary": false,
      "landscape-primary": false,
      "portrait-secondary": false,
      "landscape-secondary": false
    };

    let eventLogs: LogItem[] = [];
    
    // Heuristic analysis buffers
    let motionHistory: { beta: number; gamma: number; timestamp: number }[] = [];
    let isRotationLocked: "unlocked" | "locked" | "unknown" = "unknown";
    let isSensorsEnabled = false;

    // DOM references
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const shareBtn = document.getElementById("share-btn") as HTMLButtonElement;
    const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;

    const lockInferenceBanner = document.getElementById("lock-inference-banner") as HTMLDivElement;
    const lockInferenceMsg = document.getElementById("lock-inference-msg") as HTMLSpanElement;
    const permissionPillBtnContainer = document.getElementById("permission-pill-btn-container") as HTMLSpanElement;
    const requestSensorsBtn = document.getElementById("request-sensors-btn") as HTMLButtonElement;

    const phoneVisualizerContainer = document.getElementById("phone-visualizer-container") as HTMLDivElement;
    const screenTime = document.getElementById("screen-time") as HTMLSpanElement;
    const screenIcon = document.getElementById("screen-icon") as HTMLSpanElement;
    const screenAngleText = document.getElementById("screen-angle-text") as HTMLSpanElement;

    const typeReadout = document.getElementById("type-readout") as HTMLSpanElement;
    const angleReadout = document.getElementById("angle-readout") as HTMLSpanElement;
    const testLockApiBtn = document.getElementById("test-lock-api-btn") as HTMLButtonElement;

    const apiResultBanner = document.getElementById("api-result-banner") as HTMLDivElement;
    const apiResultTitle = document.getElementById("api-result-title") as HTMLSpanElement;
    const apiResultDesc = document.getElementById("api-result-desc") as HTMLSpanElement;

    const resetChecklistBtn = document.getElementById("reset-checklist-btn") as HTMLButtonElement;
    const checklistSummaryBanner = document.getElementById("checklist-summary-banner") as HTMLDivElement;
    const copyDiagnosticsBtn = document.getElementById("copy-diagnostics-btn") as HTMLButtonElement;
    const eventLogContainer = document.getElementById("event-log-container") as HTMLDivElement;

    // Geometry Displays
    const geomViewport = document.getElementById("geom-viewport") as HTMLSpanElement;
    const geomScreen = document.getElementById("geom-screen") as HTMLSpanElement;
    const geomDpr = document.getElementById("geom-dpr") as HTMLSpanElement;
    const geomSafeTop = document.getElementById("geom-safe-top") as HTMLSpanElement;
    const geomSafeBottom = document.getElementById("geom-safe-bottom") as HTMLSpanElement;
    const geomSafeSide = document.getElementById("geom-safe-side") as HTMLSpanElement;

    // Load initial configuration
    function init() {
      // 1. Restore guided checklist from local storage or URL parameter
      const urlParams = new URLSearchParams(window.location.search);
      const checklistParam = urlParams.get("checklist");
      if (checklistParam) {
        stateChecklist = {
          "portrait-primary": checklistParam.includes("portrait-primary"),
          "landscape-primary": checklistParam.includes("landscape-primary"),
          "portrait-secondary": checklistParam.includes("portrait-secondary"),
          "landscape-secondary": checklistParam.includes("landscape-secondary")
        };
      } else {
        const savedChecklist = localStorage.getItem(LS_CHECKLIST);
        if (savedChecklist) {
          try {
            stateChecklist = JSON.parse(savedChecklist);
          } catch (e) {
            console.warn("Could not restore checklist", e);
          }
        }
      }
      updateChecklistUI();

      // 2. Setup screen clock timer
      updateClock();
      setInterval(updateClock, 1000);

      // 3. Populate initial screen details
      updateScreenReadouts(false);
      updateGeometries();

      // 4. Register event listeners
      window.addEventListener("resize", updateGeometries);
      
      // Screen Orientation API detection
      if (window.screen && window.screen.orientation) {
        window.screen.orientation.addEventListener("change", handleOrientationChange);
      } else {
        // Fallback for older browsers
        window.addEventListener("orientationchange", handleLegacyOrientationChange);
      }

      // Check device motion permissions or prompt on iOS
      checkSensorAvailability();

      // Add visual logging of starting status
      logEvent("init", `Initialized: type=${getOrientationType()}, angle=${getOrientationAngle()}°`);
    }

    // Update screen clock
    function updateClock() {
      const now = new Date();
      const hrs = String(now.getHours()).padStart(2, "0");
      const mins = String(now.getMinutes()).padStart(2, "0");
      if (screenTime) {
        screenTime.textContent = `${hrs}:${mins}`;
      }
    }

    // Read orientation metrics safely
    function getOrientationType(): string {
      if (window.screen && window.screen.orientation && window.screen.orientation.type) {
        return window.screen.orientation.type;
      }
      // Fallback calculations
      const orientation = window.orientation;
      if (orientation === 90) return "landscape-primary";
      if (orientation === -90 || orientation === 270) return "landscape-secondary";
      if (orientation === 180) return "portrait-secondary";
      return "portrait-primary";
    }

    function getOrientationAngle(): number {
      if (window.screen && window.screen.orientation && window.screen.orientation.angle !== undefined) {
        return window.screen.orientation.angle;
      }
      if (window.orientation !== undefined) {
        // Normalize iOS landscape modes
        const angle = Number(window.orientation);
        return angle < 0 ? angle + 360 : angle;
      }
      return 0;
    }

    // Process and display orientation information
    function updateScreenReadouts(fromEvent = false) {
      const type = getOrientationType();
      const angle = getOrientationAngle();

      // Readouts
      if (typeReadout) typeReadout.textContent = type;
      if (angleReadout) angleReadout.textContent = `${angle}°`;

      // Silhouette Rotation - match reported orientation angle
      if (phoneVisualizerContainer) {
        // Rotate silhouette matching the angle
        phoneVisualizerContainer.style.transform = `rotate(${angle}deg)`;
      }

      // Inside layout display updates
      if (screenAngleText) {
        screenAngleText.textContent = `${angle}° Angle`;
      }
      if (screenIcon) {
        // Change icon layout based on orientation aspect ratio
        if (type.startsWith("landscape")) {
          screenIcon.textContent = "💻"; // horizontal device feel
        } else {
          screenIcon.textContent = "📱"; // vertical phone feel
        }
      }

      // Checkoff checklist items on detection (only from genuine events)
      if (fromEvent && type in stateChecklist) {
        const key = type as keyof SequenceState;
        if (!stateChecklist[key]) {
          stateChecklist[key] = true;
          localStorage.setItem(LS_CHECKLIST, JSON.stringify(stateChecklist));
          updateChecklistUI();
        }
      }
    }

    // Handle Orientation API events
    function handleOrientationChange(e: Event) {
      const type = getOrientationType();
      const angle = getOrientationAngle();
      logEvent("screen.orientation.onchange", `Type: ${type} | Angle: ${angle}°`);
      
      // Since orientation updated successfully, we confirm rotation is unlocked
      updateLockStatus("unlocked");
      updateScreenReadouts(true);
      updateGeometries();
    }

    // Fallback orientation listener
    function handleLegacyOrientationChange() {
      const type = getOrientationType();
      const angle = getOrientationAngle();
      logEvent("orientationchange", `Type: ${type} | Angle: ${angle}°`);
      
      updateLockStatus("unlocked");
      updateScreenReadouts(true);
      updateGeometries();
    }

    // Event logger manager
    function logEvent(source: string, details: string) {
      const now = new Date();
      const timestamp = `${String(now.getHours()).padStart(2, "0")}:${String(now.getMinutes()).padStart(2, "0")}:${String(now.getSeconds()).padStart(2, "0")}.${String(now.getMilliseconds()).padStart(3, "0")}`;
      eventLogs.unshift({ timestamp, event: source, details });
      
      // Limit to 40 logs
      if (eventLogs.length > 40) {
        eventLogs.pop();
      }

      renderLogs();
    }

    function renderLogs() {
      if (!eventLogContainer) return;
      if (eventLogs.length === 0) {
        eventLogContainer.innerHTML = `<div class="text-stone italic text-center py-4">No events logged yet. Rotate device to generate logs.</div>`;
        return;
      }

      eventLogContainer.innerHTML = eventLogs
        .map(
          (item) => `
          <div class="border-b border-hairline-soft/40 pb-1 flex flex-col gap-0.5">
            <div class="flex justify-between items-center text-[9px]">
              <span class="text-stone font-semibold">${item.timestamp}</span>
              <span class="text-brand-blue font-bold uppercase tracking-wider">${item.event}</span>
            </div>
            <div class="text-[10px] text-primary truncate" title="${item.details}">${item.details}</div>
          </div>
        `
        )
        .join("");
    }

    // Checklist GUI updates
    function updateChecklistUI() {
      let allDone = true;
      Object.keys(stateChecklist).forEach((key) => {
        const itemVal = stateChecklist[key as keyof SequenceState];
        const element = document.getElementById(`check-${key}`);
        if (element) {
          const statusSpan = element.querySelector(".status-icon") as HTMLSpanElement;
          if (itemVal) {
            statusSpan.textContent = "✅ Completed";
            statusSpan.className = "status-icon text-xs font-bold text-success-accent";
            element.className = "flex justify-between items-center py-1 border-b border-hairline-soft text-primary font-medium";
          } else {
            statusSpan.textContent = "⬜ Pending";
            statusSpan.className = "status-icon text-xs text-slate";
            element.className = "flex justify-between items-center py-1 border-b border-hairline-soft text-slate";
            allDone = false;
          }
        }
      });

      if (checklistSummaryBanner) {
        if (allDone) {
          checklistSummaryBanner.classList.remove("hidden");
        } else {
          checklistSummaryBanner.classList.add("hidden");
        }
      }
    }

    let cachedProbe: HTMLDivElement | null = null;

    function getSafeInsetProbe(): HTMLDivElement {
      if (!cachedProbe) {
        cachedProbe = document.createElement("div");
        cachedProbe.style.position = "fixed";
        cachedProbe.style.top = "env(safe-area-inset-top, 0px)";
        cachedProbe.style.bottom = "env(safe-area-inset-bottom, 0px)";
        cachedProbe.style.left = "env(safe-area-inset-left, 0px)";
        cachedProbe.style.right = "env(safe-area-inset-right, 0px)";
        cachedProbe.style.visibility = "hidden";
        cachedProbe.style.pointerEvents = "none";
        document.body.appendChild(cachedProbe);
      }
      return cachedProbe;
    }

    // Geometry computation
    function updateGeometries() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const sw = window.screen.width;
      const sh = window.screen.height;
      const dpr = window.devicePixelRatio || 1;

      if (geomViewport) geomViewport.textContent = `${vw}x${vh}`;
      if (geomScreen) geomScreen.textContent = `${sw}x${sh}`;
      if (geomDpr) geomDpr.textContent = `${dpr.toFixed(1)}x`;

      // Read Safe Area Insets dynamically using cached probe
      const probe = getSafeInsetProbe();
      const computed = window.getComputedStyle(probe);
      const safeTop = computed.top !== "auto" ? computed.top : "0px";
      const safeBottom = computed.bottom !== "auto" ? computed.bottom : "0px";
      const safeLeft = computed.left !== "auto" ? computed.left : "0px";
      const safeRight = computed.right !== "auto" ? computed.right : "0px";

      if (geomSafeTop) geomSafeTop.textContent = safeTop;
      if (geomSafeBottom) geomSafeBottom.textContent = safeBottom;
      if (geomSafeSide) geomSafeSide.textContent = `${safeLeft} / ${safeRight}`;
    }

    // Rotation Lock Inference Heuristic
    let lastLockTriggerTime = 0;

    function handleDeviceOrientation(event: DeviceOrientationEvent) {
      const beta = event.beta; // X tilt
      const gamma = event.gamma; // Y tilt
      
      if (beta === null || gamma === null) return;

      const now = Date.now();
      motionHistory.push({ beta, gamma, timestamp: now });

      // Clean old samples (keep last 3 seconds of movement history)
      motionHistory = motionHistory.filter((item) => now - item.timestamp < 3000);

      if (motionHistory.length < 15) return; // need enough samples to form variance

      // Compute range of beta/gamma values to detect physical movement
      let maxBeta = -Infinity, minBeta = Infinity;
      let maxGamma = -Infinity, minGamma = Infinity;

      motionHistory.forEach((item) => {
        if (item.beta > maxBeta) maxBeta = item.beta;
        if (item.beta < minBeta) minBeta = item.beta;
        if (item.gamma > maxGamma) maxGamma = item.gamma;
        if (item.gamma < minGamma) minGamma = item.gamma;
      });

      const rangeBeta = maxBeta - minBeta;
      const rangeGamma = maxGamma - minGamma;
      const maxMotionRange = Math.max(rangeBeta, rangeGamma);

      // If physical rotation is occurring (variance > 25 degrees)
      if (maxMotionRange > 25) {
        // Look at screen orientation type
        const type = getOrientationType();
        
        // If physically rotating, but orientation state has not updated
        const timeElapsed = now - motionHistory[0].timestamp;
        if (timeElapsed > 1500) {
          // If we had motion but screen did not update orientation, lock is highly likely
          if (isRotationLocked !== "unlocked") {
            updateLockStatus("locked");
            lastLockTriggerTime = now;
          }
        }
      } else {
        // Decay check: if they stopped moving the device and it is locked, decay to "unknown" after 5s
        if (isRotationLocked === "locked" && now - lastLockTriggerTime > 5000) {
          updateLockStatus("unknown");
        }
      }
    }

    function updateLockStatus(status: "unlocked" | "locked" | "unknown") {
      isRotationLocked = status;
      lockInferenceBanner.className = `p-2.5 rounded-lg border flex items-center justify-between text-[11px] transition-all duration-300`;
      
      if (status === "locked") {
        lockInferenceBanner.classList.add("bg-brand-red", "border-brand-red-dark/30", "text-coral-dark");
        lockInferenceMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-brand-red-dark animate-pulse"></span> <strong>Rotation appears locked</strong> — Device rotated physically but screen remained stationary.`;
      } else if (status === "unlocked") {
        lockInferenceBanner.classList.add("bg-success-accent/15", "border-success-accent/40", "text-moss-dark");
        lockInferenceMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-success-accent"></span> <strong>Rotation appears unlocked</strong> — Screen is responding dynamically to physical movement.`;
      } else {
        lockInferenceBanner.classList.add("bg-surface-yellow", "border-yellow-light/80", "text-yellow-dark");
        lockInferenceMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-yellow-dark animate-pulse"></span> Awaiting device movement to verify rotation lock...`;
      }
    }

    // Sensor availability checks
    function checkSensorAvailability() {
      // Check if DeviceOrientation API exists
      if (window.DeviceOrientationEvent) {
        // iOS 13+ requires permissions
        if (
          typeof (DeviceOrientationEvent as any).requestPermission === "function"
        ) {
          // Show explicit enable sensors button inside status banner
          if (permissionPillBtnContainer) {
            permissionPillBtnContainer.classList.remove("hidden");
          }
        } else {
          // Automatic startup on normal android/web instances
          enableOrientationSensors();
        }
      } else {
        logEvent("sensor", "DeviceOrientation API not supported by browser/device.");
      }
    }

    function enableOrientationSensors() {
      window.addEventListener("deviceorientation", handleDeviceOrientation);
      isSensorsEnabled = true;
      logEvent("sensor", "Motion sensors enabled successfully.");
      if (permissionPillBtnContainer) {
        permissionPillBtnContainer.classList.add("hidden");
      }
    }

    // iOS explicit sensor request trigger
    requestSensorsBtn?.addEventListener("click", () => {
      const req = (DeviceOrientationEvent as any).requestPermission;
      if (typeof req === "function") {
        req()
          .then((response: string) => {
            if (response === "granted") {
              enableOrientationSensors();
            } else {
              logEvent("sensor", `Permission request denied: ${response}`);
            }
          })
          .catch((err: any) => {
            logEvent("sensor", `Permission exception: ${err}`);
          });
      }
    });

    // Test lock API call
    testLockApiBtn?.addEventListener("click", async () => {
      apiResultBanner.classList.remove("hidden");
      apiResultBanner.className = "p-2 rounded-lg border text-[10px] leading-relaxed transition-all duration-300 flex flex-col gap-0.5 animate-pulse bg-surface border-hairline text-slate";
      if (apiResultTitle) apiResultTitle.textContent = "Testing Lock API...";
      if (apiResultDesc) apiResultDesc.textContent = "Requesting fullscreen & orientation lock...";

      const orientation = (window.screen && window.screen.orientation) as any;
      if (orientation && typeof orientation.lock === "function") {
        const currentType = getOrientationType();
        try {
          // Request fullscreen first to satisfy browser security requirements
          if (!document.fullscreenElement) {
            await document.documentElement.requestFullscreen();
          }
          await orientation.lock(currentType);
          
          apiResultBanner.className = "p-2 rounded-lg border text-[10px] leading-relaxed transition-all duration-300 flex flex-col gap-0.5 bg-success-accent/15 border-success-accent/30 text-moss-dark";
          if (apiResultTitle) apiResultTitle.innerHTML = "✅ Lock API Success";
          if (apiResultDesc) apiResultDesc.textContent = `Screen locked to orientation type: ${currentType}. Exit fullscreen or click Reset to unlock.`;
          logEvent("screen.orientation.lock", `Successfully locked to ${currentType}`);
        } catch (err: any) {
          // If we entered fullscreen but lock failed, clean up fullscreen
          if (document.fullscreenElement) {
            try { await document.exitFullscreen(); } catch (_) {}
          }
          apiResultBanner.className = "p-2 rounded-lg border text-[10px] leading-relaxed transition-all duration-300 flex flex-col gap-0.5 bg-brand-red border-brand-red-dark/30 text-coral-dark";
          if (apiResultTitle) apiResultTitle.innerHTML = "❌ Lock API Rejected";
          if (apiResultDesc) {
            if (err.name === "NotSupportedError") {
              apiResultDesc.textContent = "Rejection: NotSupportedError. Locking screen is not supported on this device/browser.";
            } else if (err.name === "SecurityError") {
              apiResultDesc.textContent = "Rejection: SecurityError. Screen locking requires fullscreen mode or PWA installation context.";
            } else {
              apiResultDesc.textContent = `Rejection: ${err.message || err}`;
            }
          }
          logEvent("screen.orientation.lock", `Failed: ${err.name || err}`);
        }
      } else {
        apiResultBanner.className = "p-2 rounded-lg border text-[10px] leading-relaxed transition-all duration-300 flex flex-col gap-0.5 bg-brand-red border-brand-red-dark/30 text-coral-dark";
        if (apiResultTitle) apiResultTitle.innerHTML = "❌ API Unsupported";
        if (apiResultDesc) apiResultDesc.textContent = "Your browser does not implement screen.orientation.lock(). (Unsupported on iOS)";
        logEvent("screen.orientation.lock", "API unsupported on this browser.");
      }
    });

    // Reset button behavioral contract
    resetBtn?.addEventListener("click", () => {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // Clear logs
      eventLogs = [];
      renderLogs();

      // Reset diagnostic checklist state & remove from local storage
      stateChecklist = {
        "portrait-primary": false,
        "landscape-primary": false,
        "portrait-secondary": false,
        "landscape-secondary": false
      };
      localStorage.removeItem(LS_CHECKLIST);
      updateChecklistUI();

      // Clear lock status
      updateLockStatus("unknown");
      motionHistory = [];

      // Clear API tester feedback
      apiResultBanner.classList.add("hidden");

      // Attempt unlock orientation if API supported
      const orientation = (window.screen && window.screen.orientation) as any;
      if (orientation && typeof orientation.unlock === "function") {
        try {
          orientation.unlock();
          logEvent("screen.orientation.unlock", "Unlock orientation triggered.");
        } catch (e) {}
      }
      if (document.fullscreenElement) {
        document.exitFullscreen().catch(() => {});
      }

      // Re-read current orientation states
      updateScreenReadouts();
      logEvent("reset", "Diagnostic state and localStorage metrics cleared.");

      // Visual flash
      const cls = "bg-success-accent/40";
      lockInferenceBanner.classList.add(cls);
      setTimeout(() => {
        lockInferenceBanner.classList.remove(cls);
      }, 300);
    });

    // Share Event Listener
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      const completedList = Object.keys(stateChecklist).filter(k => stateChecklist[k as keyof SequenceState]).join(",");
      if (completedList) {
        url.searchParams.set("checklist", completedList);
      }

      const shareData = {
        title: document.title || "Orientation Lock Check",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Reset Checklist alone button
    resetChecklistBtn?.addEventListener("click", () => {
      stateChecklist = {
        "portrait-primary": false,
        "landscape-primary": false,
        "portrait-secondary": false,
        "landscape-secondary": false
      };
      localStorage.removeItem(LS_CHECKLIST);
      updateChecklistUI();
      updateScreenReadouts(); // checkoff current immediately
      logEvent("checklist", "Guided sequence checklist reset.");
    });

    // Export diagnostics details
    copyDiagnosticsBtn?.addEventListener("click", () => {
      const type = getOrientationType();
      const angle = getOrientationAngle();
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const sw = window.screen.width;
      const sh = window.screen.height;
      const dpr = window.devicePixelRatio || 1;

      let logText = `TOOLKIFY - Orientation Lock Check Diagnostics Summary\n`;
      logText += `Generated: ${new Date().toISOString()}\n`;
      logText += `--------------------------------------------------\n`;
      logText += `Current Orientation: ${type} (${angle}°)\n`;
      logText += `Inferred Lock State: ${isRotationLocked.toUpperCase()}\n`;
      logText += `Viewport Dimensions: ${vw}x${vh} (Screen: ${sw}x${sh})\n`;
      logText += `Device Pixel Ratio: ${dpr.toFixed(1)}x\n`;
      logText += `Sensors Enabled: ${isSensorsEnabled ? "YES" : "NO"}\n`;
      logText += `------------------ Checklist ---------------------\n`;
      logText += `Portrait-Primary: ${stateChecklist["portrait-primary"] ? "COMPLETED" : "PENDING"}\n`;
      logText += `Landscape-Primary: ${stateChecklist["landscape-primary"] ? "COMPLETED" : "PENDING"}\n`;
      logText += `Portrait-Secondary: ${stateChecklist["portrait-secondary"] ? "COMPLETED" : "PENDING"}\n`;
      logText += `Landscape-Secondary: ${stateChecklist["landscape-secondary"] ? "COMPLETED" : "PENDING"}\n`;
      logText += `------------------ Event Logs ---------------------\n`;
      
      if (eventLogs.length === 0) {
        logText += `No events recorded.\n`;
      } else {
        eventLogs.forEach((item) => {
          logText += `[${item.timestamp}] ${item.event}: ${item.details}\n`;
        });
      }

      navigator.clipboard.writeText(logText).then(() => {
        const origText = copyDiagnosticsBtn.textContent;
        copyDiagnosticsBtn.textContent = "Copied!";
        copyDiagnosticsBtn.className = "text-[9px] font-bold text-success-accent hover:underline cursor-pointer";
        setTimeout(() => {
          copyDiagnosticsBtn.textContent = origText;
          copyDiagnosticsBtn.className = "text-[9px] font-bold text-brand-blue hover:underline cursor-pointer";
        }, 2000);
      });
    });

    // Cleanup listeners on unmount
    window.addEventListener("beforeunload", () => {
      window.removeEventListener("resize", updateGeometries);
      window.removeEventListener("deviceorientation", handleDeviceOrientation);
      if (window.screen && window.screen.orientation) {
        window.screen.orientation.removeEventListener("change", handleOrientationChange);
      } else {
        window.removeEventListener("orientationchange", handleLegacyOrientationChange);
      }
    });

    // How it works modal event listeners
    howItWorksBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Initialize logic execution
    init();
  </script>
</Layout>
