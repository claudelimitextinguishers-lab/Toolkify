---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// On-page SEO metadata
const name = "Spirit Level / Bubble Level";
const category = "mobile";
const tier = "Mobile Sensor Tools";

const pageTitle = "Spirit Level / Bubble Level - Free Online Spirit Level Tool";
const description = "Free online spirit level / bubble level app. Use your device orientation sensors as a digital spirit level tool to measure tilt angles, slope, and calibrate offsets.";
const canonicalUrl = "https://toolkify.com/tools/mobile/spirit-level";
const ogImage = "/og/spirit-level.png";
const keywords = "Spirit Level / Bubble Level, Spirit Level, Bubble Level, spirit level tool, what is a spirit level, digital spirit level, the spirit level, best spirit level, spirit level bubble, tools spirit level, bubble level, bubble level tool, bubble level app, small bubble level, best bubble level";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Spirit Level / Bubble Level",
      "alternateName": "Digital Inclinometer & Carpenter Level",
      "url": "https://toolkify.com/tools/mobile/spirit-level",
      "description": "A high-precision client-side digital bubble level and carpenter level utilizing the device orientation gyroscopic sensors. Offers calibration offsets, vibration confirmation, and degree vs percent grade readouts.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires DeviceOrientation API.",
      "featureList": [
        "Circular 2-axis bubble level for flat surfaces",
        "Linear 1-axis carpenter's level for edges",
        "Sub-degree calibration and offset saving",
        "Toggle units between degrees and percent grade",
        "Adjustable level-tolerance sensitivity",
        "Optional haptic feedback / vibration confirmation",
        "Desktop interactive simulation fallback"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Mobile",
          "item": "https://toolkify.com/tools/mobile"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Spirit Level",
          "item": "https://toolkify.com/tools/mobile/spirit-level"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A spirit level is an instrument designed to indicate whether a surface is perfectly horizontal (level) or vertical (plumb). It traditionally features a sealed vial containing liquid and an air bubble that aligns between markings when flat.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why is it called a spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>It is called a spirit level because the fluid used inside the glass vial is typically an alcohol solution (such as ethanol). Alcohol is used because it has a low viscosity, allows the bubble to move quickly, and has a very low freezing point so the tool remains functional in sub-zero temperatures.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to use a spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To use a spirit level, place the body of the level flat on the surface you want to check. Look at the bubble vial: if the bubble rests exactly between the two parallel line markings, the surface is level. Adjust the object or surface until the bubble is perfectly centered.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to read a spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To read a spirit level, observe the position of the bubble relative to the two guide lines in the center of the vial. If the bubble is centered between the lines, the surface is horizontal. If the bubble is to the right, the right side is higher; if it is to the left, the left side is higher.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a spirit level used for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A spirit level is used to align items horizontally or vertically during construction, woodworking, DIY tasks, and appliance setups. It ensures structures, frames, shelves, bricks, and pipes are true, preventing leaning, sliding, or structural instability.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to measure slope with a spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To measure slope using a spirit level, place one end on the higher ground and lift the lower end until the bubble is centered. Measure the vertical gap between the lower end and the surface, then divide it by the length of the level. Alternatively, our digital level can automatically show percent grade (%) or degrees to instantly calculate the slope.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to calibrate a spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To calibrate a physical level, place it on a flat surface and mark the bubble position. Rotate it 180 degrees horizontally; if the bubble is in the same position, it is calibrated. For our online digital level, simply place your device on a flat surface and press the \"Calibrate Zero\" button to automatically apply and save an offset to correct any tilt.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Who invented the spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The spirit level was invented by Melchisédech Thévenot, a French scientist, librarian, and amateur physicist, around 1661. He filled a glass tube with alcohol and mounted it on a stone ruler to measure horizontal alignment.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to read spirit level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Reading a spirit level requires checking if the bubble is located precisely in the middle of the vial guidelines. Any shift left or right shows that the surface leans, and you must adjust the height of the surface until the bubble is dead-center.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Who invented the bubble level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The bubble level (also known as the spirit level) was invented by the French polymath Melchisédech Thévenot in 1661. Later, in the 18th century, English instrument maker Edward Troughton improved the design by curving the tube slightly for more sensitivity.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to read a bubble level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To read a bubble level, locate the fluid-filled vial on the tool. If the bubble is aligned exactly between the two center lines, the item is level. If it moves left or right, it shows which side is higher, prompting you to raise or lower the edges to level the item.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to read a level bubble?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To read a level bubble, examine the center vial. The bubble seeks the highest point. If the level bubble is centered, the surface is balanced. If it is offset, adjust the slant of the surface until the bubble rests perfectly within the two line markings.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "When was the bubble level invented?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The bubble level was invented in the year 1661 by Melchisédech Thévenot. His invention was later patented and gained widespread use in the late 17th century once glass manufacturing and precision marking techniques improved.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a bubble level used for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A bubble level is used to determine if a surface is perfectly parallel or perpendicular to the horizon. It is commonly used in home improvement projects, hanging art, assembling furniture, bricklaying, tiling, and installing structural foundations.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How accurate is a bubble level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A standard physical bubble level has an accuracy of about 0.5 millimeters per meter (or 0.029 degrees). High-precision digital levels and mobile sensors, when properly calibrated, can measure angular inclinations with an accuracy of up to 0.1 degrees depending on the sensor hardware.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to use a bubble level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To use a bubble level, place the flat side of the tool against the surface of your project. Check the bubble within the vial. If it rests directly between the lines, your project is level. If not, tilt your project toward the side the bubble is drifting from until it centers.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to read bubble level?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To read a bubble level, look straight down at the vial. Note where the bubble rests. If it sits perfectly centered between the line markers, it is level. If the bubble is off to one side, that side is elevated; you must adjust the height to achieve a level line.</p>"
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button (verbatim pattern from json-formatter.astro) -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How spirit level works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button (verbatim pattern from json-formatter.astro) -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-stretch">
      <!-- Left Column: Interactive Level (above fold optimization) -->
      <div class="lg:col-span-8 card-base flex flex-col gap-3 sm:gap-4 relative justify-between min-h-[380px] sm:min-h-[520px]">
        
        <!-- Live status notification banner / Simulation banner -->
        <div id="status-banner" class="hidden text-xs py-1.5 px-3 rounded-lg font-medium text-center transition-all">
          No gyroscope detected. Simulation mode active: click or drag level bubble.
        </div>

        <!-- Permission Dialog Screen (shown on iOS or initially) -->
        <div id="permission-screen" class="hidden flex-1 flex flex-col items-center justify-center text-center p-6 gap-5">
          <div class="w-16 h-16 rounded-full bg-blue-450/10 flex items-center justify-center text-3xl animate-bounce">
            📱
          </div>
          <div class="max-w-md flex flex-col gap-2">
            <h3 class="font-display font-semibold text-lg text-primary">Sensor Access Required</h3>
            <p class="text-xs text-slate leading-relaxed">
              TOOLKIFY Spirit Level needs access to your device's motion sensors to show real-time orientation. iOS requires manual confirmation.
            </p>
          </div>
          <button
            type="button"
            id="request-permission-btn"
            class="button-primary text-xs py-2.5 px-6 shadow-md hover:scale-105 active:scale-95 transition-all"
          >
            Enable Motion Sensors
          </button>
          <button
            type="button"
            id="skip-permission-btn"
            class="text-[11px] font-semibold text-slate hover:text-primary transition-colors underline"
          >
            Use Interactive Simulator Mode
          </button>
        </div>

        <!-- Live Level Workspace -->
        <div id="level-workspace" class="hidden flex-1 flex flex-col justify-between gap-4">
          
          <!-- Top Row: Mode indicator + giant numeric readout -->
          <div class="flex items-center justify-between border-b border-hairline-soft pb-3">
            <div class="flex flex-col">
              <span id="active-mode-label" class="text-[10px] uppercase font-bold tracking-wider text-slate">Circular Mode (2-Axis)</span>
              <span id="calibration-indicator" class="text-[9px] font-semibold text-brand-blue hidden">Calibrated Offset Applied</span>
            </div>
            
            <!-- Large Glanceable Readout -->
            <div class="flex items-baseline gap-2">
              <span id="primary-readout" class="font-display font-semibold text-4xl sm:text-5xl text-primary tabular-nums">0.0°</span>
              <span id="secondary-readout" class="text-xs font-medium text-slate tabular-nums hidden sm:inline"></span>
            </div>
          </div>

          <!-- The Visual Level Container -->
          <div class="flex-1 flex items-center justify-center py-2 relative min-h-[220px]">
            
            <!-- Dynamic Glowing Ring when Level -->
            <div id="level-glow" class="absolute inset-0 bg-success-accent/0 rounded-full blur-2xl transition-all duration-300 opacity-20 pointer-events-none scale-75"></div>

            <!-- 1. Circular Bubble Level View -->
            <div id="circular-level-container" class="relative w-48 h-48 sm:w-56 sm:h-56 rounded-full border border-hairline bg-surface-soft/60 shadow-inner flex items-center justify-center cursor-pointer select-none">
              <!-- Grid lines -->
              <div class="absolute w-full h-[1px] bg-hairline/40"></div>
              <div class="absolute h-full w-[1px] bg-hairline/40"></div>
              
              <!-- Center target rings -->
              <div class="absolute w-8 h-8 rounded-full border border-hairline-strong/30"></div>
              <div class="absolute w-16 h-16 rounded-full border border-hairline-strong/20"></div>
              
              <!-- Core center crosshair / boundary -->
              <div class="absolute w-3 h-3 rounded-full border border-primary/20"></div>
              
              <!-- Floating Bubble -->
              <div id="circular-bubble" class="absolute w-7 h-7 rounded-full bg-brand-blue/80 shadow-md border border-white/60 transition-transform duration-75 flex items-center justify-center">
                <!-- Highlight reflections -->
                <div class="w-1.5 h-1.5 bg-white/60 rounded-full absolute top-1 left-1.5"></div>
              </div>
            </div>

            <!-- 2. Linear / Carpenter's Level View -->
            <div id="linear-level-container" class="hidden relative w-full max-w-sm h-14 rounded-full border border-hairline bg-surface-soft/60 shadow-inner flex items-center justify-center cursor-pointer select-none overflow-hidden">
              <!-- Center indicator lines -->
              <div class="absolute top-0 bottom-0 left-[calc(50%-12px)] w-[1px] bg-hairline-strong/60"></div>
              <div class="absolute top-0 bottom-0 left-[calc(50%+12px)] w-[1px] bg-hairline-strong/60"></div>
              <div class="absolute top-0 bottom-0 left-1/2 w-[1px] bg-primary/20"></div>
              
              <!-- Sliding Tube Bubble -->
              <div id="linear-bubble" class="absolute w-9 h-9 rounded-full bg-brand-blue/80 shadow-md border border-white/60 transition-transform duration-75 flex items-center justify-center">
                <!-- Highlight reflections -->
                <div class="w-2.5 h-2.5 bg-white/60 rounded-full absolute top-1 left-2"></div>
              </div>
            </div>

          </div>

          <!-- Above-fold controls row -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 pt-2 border-t border-hairline-soft">
            <button
              type="button"
              id="calibrate-btn"
              class="inline-flex items-center justify-center gap-1 text-[11px] font-semibold py-2 px-3 bg-surface hover:bg-hairline text-slate hover:text-primary border border-hairline rounded-lg transition-all cursor-pointer shadow-subtle"
              title="Set current position as 0"
            >
              🎯 Calibrate Zero
            </button>
            
            <button
              type="button"
              id="mode-toggle-btn"
              class="inline-flex items-center justify-center gap-1 text-[11px] font-semibold py-2 px-3 bg-surface hover:bg-hairline text-slate hover:text-primary border border-hairline rounded-lg transition-all cursor-pointer shadow-subtle"
            >
              🔄 Circular / Linear
            </button>

            <button
              type="button"
              id="unit-toggle-btn"
              class="inline-flex items-center justify-center gap-1 text-[11px] font-semibold py-2 px-3 bg-surface hover:bg-hairline text-slate hover:text-primary border border-hairline rounded-lg transition-all cursor-pointer shadow-subtle"
            >
              📐 Unit: Degrees
            </button>

            <button
              type="button"
              id="haptics-toggle-btn"
              class="inline-flex items-center justify-center gap-1 text-[11px] font-semibold py-2 px-3 bg-surface hover:bg-hairline text-slate hover:text-primary border border-hairline rounded-lg transition-all cursor-pointer shadow-subtle"
            >
              📳 Haptics: On
            </button>
          </div>

          <!-- Advanced Adjustments (Inline & Compact) -->
          <div class="flex flex-wrap items-center justify-between gap-4 py-2 px-3 bg-surface/50 border border-hairline rounded-xl mt-1">
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-semibold text-slate uppercase">Tolerance Sensitivity</span>
              <span id="tolerance-val" class="text-xs font-bold text-brand-blue">0.5°</span>
            </div>
            <div class="flex-1 max-w-[180px]">
              <input 
                type="range" 
                id="tolerance-slider" 
                min="0.1" 
                max="2.0" 
                step="0.1" 
                value="0.5" 
                class="w-full h-1.5 bg-hairline rounded-lg appearance-none cursor-pointer accent-brand-blue" 
              />
            </div>
          </div>

        </div>

      </div>

      <!-- Right Column: Info & Details Sidebar -->
      <div class="lg:col-span-4 flex flex-col gap-4 print:hidden">
        
        <!-- Quick Specs panel -->
        <div class="card-base flex flex-col gap-3">
          <h3 class="font-display font-semibold text-sm text-primary">Live Sensor Output</h3>
          
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center py-1 border-b border-hairline-soft">
              <span class="text-xs text-slate">Roll (Gamma)</span>
              <span id="raw-gamma-display" class="text-xs font-mono font-semibold text-primary tabular-nums">0.0°</span>
            </div>
            <div class="flex justify-between items-center py-1 border-b border-hairline-soft">
              <span class="text-xs text-slate">Pitch (Beta)</span>
              <span id="raw-beta-display" class="text-xs font-mono font-semibold text-primary tabular-nums">0.0°</span>
            </div>
            <div id="offset-details" class="hidden flex-col gap-1 mt-1 bg-surface-yellow/50 p-2 rounded-lg border border-yellow-light/60">
              <span class="text-[10px] uppercase font-bold text-yellow-dark">Saved Offsets</span>
              <div class="flex justify-between text-[11px] text-slate font-mono">
                <span>Offset Beta: <span id="offset-beta-val">0.0</span></span>
                <span>Offset Gamma: <span id="offset-gamma-val">0.0</span></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Privacy Guard Feature Card -->
        <div class="card-feature-teal flex flex-col gap-2.5">
          <span class="badge-tag-purple bg-teal-light text-moss-dark self-start text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase">100% Private</span>
          <h3 class="font-display font-semibold text-sm text-primary">Local Sandbox Processing</h3>
          <p class="text-[11px] text-slate leading-relaxed">
            All physical sensor API computations happen immediately on your hardware. No accelerometer coordinates or motion variables are ever saved, stored, or streamed to outer servers.
          </p>
        </div>
      </div>
    </div>

    <RelatedTools currentSlug="spirit-level" />
  </section>

  <!-- SEO Content Article -->
  <section
    class="max-w-[760px] w-full mx-auto px-4 pb-12 flex flex-col gap-8 text-slate mt-8"
    aria-labelledby="about-tool-heading"
  >
    <article class="flex flex-col gap-4">
      <h2
        id="about-tool-heading"
        class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight"
      >
        Spirit Level / Bubble Level - The Ultimate Digital Alignment Tool
      </h2>
      <p class="text-sm leading-relaxed">
        A <strong>spirit level / bubble level</strong> is one of the most fundamental instruments in carpentry, construction, engineering, and home improvement DIY projects. Whether you are hanging a heavy picture frame, installing shelves, mounting a TV, or checking the slope of a drainage pipe, a reliable <strong>spirit level tool</strong> ensures that your work is perfectly aligned. With modern web technology, you no longer need to carry a bulky physical tool or purchase expensive hardware. You can turn your smartphone or mobile device into a high-precision, pocket-sized <strong>digital spirit level</strong> using our free online web app.
      </p>
      <p class="text-sm leading-relaxed">
        Our <strong>bubble level app</strong> is designed to run entirely in your mobile browser, utilizing the advanced physical gyroscopic and accelerometer sensors built directly into your device. As a fully client-side tool, it calculates exact tilt angles and orientation values locally in real-time. This means your sensor readings and calibration data are never sent to any external servers, ensuring 100% privacy while offering a sleek, premium, and distraction-free user interface.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        What is a Spirit Level and How Does It Work?
      </h3>
      <p class="text-sm leading-relaxed">
        To understand how a digital level works, it helps to ask: <strong>what is a spirit level</strong>? The traditional carpenter's level consists of a slightly curved, sealed glass tube (vial) filled with a liquid—typically ethanol, which is a type of spirit—leaving a small gas bubble inside. Because the liquid is denser than the gas, the <strong>spirit level bubble</strong> always rises to the highest point of the curved tube. When the instrument is placed on a completely flat, horizontal surface, the bubble rests precisely between two centering marks. If the surface tilts, the bubble drifts toward the elevated side.
      </p>
      <p class="text-sm leading-relaxed">
        A digital version, or <strong>tools spirit level</strong> app, replaces the glass vial and liquid bubble with digital sensors called Micro-Electro-Mechanical Systems (MEMS) accelerometers. These sensors measure the acceleration forces acting on the device relative to gravity. By analyzing these gravitational vectors, the web application calculates the precise angles of tilt in real-time and displays them on a visual interface that mimics the look and feel of a classic mechanical level.
      </p>

