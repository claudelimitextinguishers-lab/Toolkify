        <h4 class="font-semibold text-primary">3. Calibration & Accuracy</h4>
        <p>
          Due to protective phone cases and camera bumps, standard readings may hover off-balance even when flat. Tap <strong>Calibrate Zero</strong> to offset any current slant as the base point.
        </p>

        <h4 class="font-semibold text-primary">4. Units Explained</h4>
        <p>
          - <strong>Degrees (°)</strong>: Angular measurement, where 0° is true horizontal level.<br/>
          - <strong>Percent Grade (%)</strong>: Rise divided by run. A grade of 100% indicates a 45-degree angle (1 unit of vertical rise for every 1 unit of horizontal distance).
        </p>
      </div>
    </div>
  </div>

  <script>
    // Constants
    const LS_OFFSET_BETA = "toolkify:spirit-level:offset-beta";
    const LS_OFFSET_GAMMA = "toolkify:spirit-level:offset-gamma";
    const LS_UNIT = "toolkify:spirit-level:unit";
    const LS_MODE = "toolkify:spirit-level:mode";
    const LS_TOLERANCE = "toolkify:spirit-level:tolerance";
    const LS_HAPTICS = "toolkify:spirit-level:haptics";

    // App state
    let state = {
      offsetBeta: 0,
      offsetGamma: 0,
      unit: "deg", // 'deg' or 'percent'
      mode: "circular", // 'circular' or 'linear'
      tolerance: 0.5,
      haptics: true,
      rawBeta: 0,
      rawGamma: 0,
      calibratedBeta: 0,
      calibratedGamma: 0,
      isSimulated: false,
      permissionGranted: false
    };

    // Low-pass filter smoothing helper
    let smoothedBeta = 0;
    let smoothedGamma = 0;
    const filterAlpha = 0.18; // Response vs Jitter balance

    // DOM References
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const shareBtn = document.getElementById("share-btn") as HTMLButtonElement;
    const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    
    const permissionScreen = document.getElementById("permission-screen") as HTMLDivElement;
    const levelWorkspace = document.getElementById("level-workspace") as HTMLDivElement;
    const requestPermissionBtn = document.getElementById("request-permission-btn") as HTMLButtonElement;
    const skipPermissionBtn = document.getElementById("skip-permission-btn") as HTMLButtonElement;
    const statusBanner = document.getElementById("status-banner") as HTMLDivElement;

    const circularLevelContainer = document.getElementById("circular-level-container") as HTMLDivElement;
    const linearLevelContainer = document.getElementById("linear-level-container") as HTMLDivElement;
    const circularBubble = document.getElementById("circular-bubble") as HTMLDivElement;
    const linearBubble = document.getElementById("linear-bubble") as HTMLDivElement;
    const levelGlow = document.getElementById("level-glow") as HTMLDivElement;
    
    const activeModeLabel = document.getElementById("active-mode-label") as HTMLSpanElement;
    const calibrationIndicator = document.getElementById("calibration-indicator") as HTMLSpanElement;
    const primaryReadout = document.getElementById("primary-readout") as HTMLSpanElement;
    const secondaryReadout = document.getElementById("secondary-readout") as HTMLSpanElement;
    
    const calibrateBtn = document.getElementById("calibrate-btn") as HTMLButtonElement;
    const modeToggleBtn = document.getElementById("mode-toggle-btn") as HTMLButtonElement;
    const unitToggleBtn = document.getElementById("unit-toggle-btn") as HTMLButtonElement;
    const hapticsToggleBtn = document.getElementById("haptics-toggle-btn") as HTMLButtonElement;
    const toleranceSlider = document.getElementById("tolerance-slider") as HTMLInputElement;
    const toleranceVal = document.getElementById("tolerance-val") as HTMLSpanElement;

    const rawGammaDisplay = document.getElementById("raw-gamma-display") as HTMLSpanElement;
    const rawBetaDisplay = document.getElementById("raw-beta-display") as HTMLSpanElement;
    const offsetDetails = document.getElementById("offset-details") as HTMLDivElement;
    const offsetBetaVal = document.getElementById("offset-beta-val") as HTMLSpanElement;
    const offsetGammaVal = document.getElementById("offset-gamma-val") as HTMLSpanElement;

    // Load initial settings
    function loadSettings() {
      const urlParams = new URLSearchParams(window.location.search);
      const get = (lsKey: string, urlKey: string): string | null => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        if (typeof localStorage === 'undefined') return null;
        try { return localStorage.getItem(lsKey); } catch (e) { return null; }
      };

      state.offsetBeta = parseFloat(get(LS_OFFSET_BETA, "offsetBeta") || "0");
      state.offsetGamma = parseFloat(get(LS_OFFSET_GAMMA, "offsetGamma") || "0");
      state.unit = get(LS_UNIT, "unit") || "deg";
      state.mode = get(LS_MODE, "mode") || "circular";
      state.tolerance = parseFloat(get(LS_TOLERANCE, "tolerance") || "0.5");
      const hapticsVal = get(LS_HAPTICS, "haptics");
      state.haptics = (hapticsVal !== "false");

      toleranceSlider.value = state.tolerance.toString();
      toleranceVal.textContent = state.tolerance.toFixed(1) + "°";
      updateUIStrings();
    }

    // Save single settings helpers
    function saveSetting(key: string, val: any) {
      localStorage.setItem(key, String(val));
    }

    // Modal behavior verbatim
    howItWorksBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // Reset button behavioral contract
    resetBtn?.addEventListener("click", () => {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // Clear localStorage keys
      localStorage.removeItem(LS_OFFSET_BETA);
      localStorage.removeItem(LS_OFFSET_GAMMA);
      localStorage.removeItem(LS_UNIT);
      localStorage.removeItem(LS_MODE);
      localStorage.removeItem(LS_TOLERANCE);
      localStorage.removeItem(LS_HAPTICS);

      // Revert state
      state.offsetBeta = 0;
      state.offsetGamma = 0;
      state.unit = "deg";
      state.mode = "circular";
      state.tolerance = 0.5;
      state.haptics = true;

      // Update inputs & indicators
      toleranceSlider.value = "0.5";
      toleranceVal.textContent = "0.5°";
      
      updateUIStrings();
      updateSensorFlow();
    });

    // Share Event Listener
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("offsetBeta", state.offsetBeta.toString());
      url.searchParams.set("offsetGamma", state.offsetGamma.toString());
      url.searchParams.set("unit", state.unit);
      url.searchParams.set("mode", state.mode);
      url.searchParams.set("tolerance", state.tolerance.toString());
      url.searchParams.set("haptics", state.haptics.toString());

      const shareData = {
        title: document.title || "Spirit Level",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Toggle button handlers
    modeToggleBtn.addEventListener("click", () => {
      state.mode = state.mode === "circular" ? "linear" : "circular";
      saveSetting(LS_MODE, state.mode);
      updateUIStrings();
      updateSensorFlow();
    });

    unitToggleBtn.addEventListener("click", () => {
      state.unit = state.unit === "deg" ? "percent" : "deg";
      saveSetting(LS_UNIT, state.unit);
      updateUIStrings();
    });

    hapticsToggleBtn.addEventListener("click", () => {
      state.haptics = !state.haptics;
      saveSetting(LS_HAPTICS, state.haptics);
      updateUIStrings();
    });

    toleranceSlider.addEventListener("input", (e) => {
      const val = parseFloat((e.target as HTMLInputElement).value);
      state.tolerance = val;
      toleranceVal.textContent = val.toFixed(1) + "°";
      saveSetting(LS_TOLERANCE, val);
    });

    calibrateBtn.addEventListener("click", () => {
      // Store calibration offsets in raw, rotation-independent sensor coordinates
      state.offsetBeta = state.rawBeta;
      state.offsetGamma = state.rawGamma;
      saveSetting(LS_OFFSET_BETA, state.offsetBeta);
      saveSetting(LS_OFFSET_GAMMA, state.offsetGamma);
      updateUIStrings();
    });

    // Dynamic strings updates
    function updateUIStrings() {
      // Update Calibration visual hint
      if (Math.abs(state.offsetBeta) > 0.01 || Math.abs(state.offsetGamma) > 0.01) {
        calibrationIndicator.classList.remove("hidden");
        offsetDetails.classList.remove("hidden");
        offsetBetaVal.textContent = state.offsetBeta.toFixed(1);
        offsetGammaVal.textContent = state.offsetGamma.toFixed(1);
      } else {
        calibrationIndicator.classList.add("hidden");
        offsetDetails.classList.add("hidden");
      }

      // Modes
      if (state.mode === "circular") {
        activeModeLabel.textContent = "Circular Mode (2-Axis)";
        circularLevelContainer.classList.remove("hidden");
        linearLevelContainer.classList.add("hidden");
      } else {
        activeModeLabel.textContent = "Linear Tube Mode (1-Axis)";
        circularLevelContainer.classList.add("hidden");
        linearLevelContainer.classList.remove("hidden");
      }

      // Units
      unitToggleBtn.textContent = state.unit === "deg" ? "📐 Unit: Degrees" : "📐 Unit: % Grade";
      
      // Haptics
      hapticsToggleBtn.textContent = state.haptics ? "📳 Haptics: On" : "📴 Haptics: Off";
    }

    // Screen display transitions
    function showPermissionPrompt() {
      permissionScreen.classList.remove("hidden");
      levelWorkspace.classList.add("hidden");
    }

    function showLiveWorkspace() {
      permissionScreen.classList.add("hidden");
      levelWorkspace.classList.remove("hidden");
    }

    // Check device rotation direction
    function getRotationOffset() {
      if (window.screen && window.screen.orientation && window.screen.orientation.angle !== undefined) {
        return window.screen.orientation.angle;
      }
      if (window.orientation !== undefined) {
        return Number(window.orientation);
      }
      return 0;
    }

    // Main orientation reading update logic
    function handleOrientation(beta: number, gamma: number) {
      state.rawBeta = beta;
      state.rawGamma = gamma;

      // Apply calibration offsets before rotation-alignment transform
      let calibratedRawBeta = beta - state.offsetBeta;
      let calibratedRawGamma = gamma - state.offsetGamma;

      // Filter raw coordinates based on Device rotation Angle
      let rotationAngle = getRotationOffset();
      let alignedBeta = calibratedRawBeta;
      let alignedGamma = calibratedRawGamma;

      if (rotationAngle === 90) {
        alignedBeta = -calibratedRawGamma;
        alignedGamma = calibratedRawBeta;
      } else if (rotationAngle === -90 || rotationAngle === 270) {
        alignedBeta = calibratedRawGamma;
        alignedGamma = -calibratedRawBeta;
      } else if (rotationAngle === 180) {
        alignedBeta = -calibratedRawBeta;
        alignedGamma = -calibratedRawGamma;
      }

      state.calibratedBeta = alignedBeta;
      state.calibratedGamma = alignedGamma;

      // Apply low pass filter
      smoothedBeta = (state.calibratedBeta * filterAlpha) + (smoothedBeta * (1 - filterAlpha));
      smoothedGamma = (state.calibratedGamma * filterAlpha) + (smoothedGamma * (1 - filterAlpha));

      processTiltValues(smoothedBeta, smoothedGamma);
    }

    // Render loop helper
    let hapticThrottle = false;
    function processTiltValues(betaVal: number, gammaVal: number) {
      // Raw info displays
      rawBetaDisplay.textContent = state.rawBeta.toFixed(1) + "°";
      rawGammaDisplay.textContent = state.rawGamma.toFixed(1) + "°";

      // Compute total error tilt angle
      let tiltAngle = 0;
      if (state.mode === "circular") {
        // Compound angle error
        tiltAngle = Math.sqrt(betaVal * betaVal + gammaVal * gammaVal);
      } else {
        // Single axis horizontal tilt
        tiltAngle = Math.abs(gammaVal);
      }

      // Check level status against tolerance threshold
      const isTrueLevel = tiltAngle <= state.tolerance;

      // Formatted value display
      let formattedText = "";
      if (state.unit === "deg") {
        formattedText = tiltAngle.toFixed(1) + "°";
      } else {
        // Percentage Grade rise/run tan calculation
        const pct = Math.abs(Math.tan(tiltAngle * Math.PI / 180) * 100);
        formattedText = (pct > 999 ? ">999" : pct.toFixed(1)) + "%";
      }
      primaryReadout.textContent = formattedText;

      if (state.mode === "circular") {
        secondaryReadout.classList.remove("hidden");
        secondaryReadout.textContent = `X: ${gammaVal.toFixed(1)}° Y: ${betaVal.toFixed(1)}°`;
      } else {
        secondaryReadout.classList.add("hidden");
      }

      // Bubble UI update positions
      // Max displacement range
      if (state.mode === "circular") {
        const containerSize = circularLevelContainer.clientWidth || 192;
        const maxRadius = (containerSize / 2) - 14 - 4; // Subtracted bubble radius and border padding
        
        // Physical mapping: bubble moves to higher side. Offset proportional to minus angle.
        // Sensitivity factor mapping 20deg to full displacement
        const sensitivity = maxRadius / 20;
        let dx = -gammaVal * sensitivity;
        let dy = -betaVal * sensitivity;
        
        // Clip distance inside boundary circle
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > maxRadius) {
          dx = (dx / dist) * maxRadius;
          dy = (dy / dist) * maxRadius;
        }

        circularBubble.style.transform = `translate(${dx}px, ${dy}px)`;
      } else {
        const containerWidth = linearLevelContainer.clientWidth || 320;
        const maxOffset = (containerWidth / 2) - 18 - 8; // Max horizontal travel
        const sensitivity = maxOffset / 20;
        let dx = -gammaVal * sensitivity;
        if (dx > maxOffset) dx = maxOffset;
        if (dx < -maxOffset) dx = -maxOffset;

        linearBubble.style.transform = `translateX(${dx}px)`;
      }

      // Level trigger visual & haptics update
      if (isTrueLevel) {
        // High contrast active level state
        levelGlow.classList.add("scale-100", "bg-success-accent/30");
        levelGlow.classList.remove("scale-75", "bg-success-accent/0");

        circularBubble.classList.remove("bg-brand-blue/80");
        circularBubble.classList.add("bg-success-accent");
        linearBubble.classList.remove("bg-brand-blue/80");
        linearBubble.classList.add("bg-success-accent");

        if (state.haptics && !hapticThrottle) {
          if ("vibrate" in navigator) {
            navigator.vibrate(40); // Soft haptic bump
          }
          hapticThrottle = true;
          setTimeout(() => hapticThrottle = false, 1000); // Throttling vibration trigger
        }
      } else {
        levelGlow.classList.remove("scale-100", "bg-success-accent/30");
        levelGlow.classList.add("scale-75", "bg-success-accent/0");

        circularBubble.classList.add("bg-brand-blue/80");
        circularBubble.classList.remove("bg-success-accent");
        linearBubble.classList.add("bg-brand-blue/80");
        linearBubble.classList.remove("bg-success-accent");
      }
    }

    // Desktop/fallback manual drag simulation implementation
    let isDragging = false;
    let simulationInitialized = false;

    // Module-level event handlers for simulator to avoid stacking
    const circularMouseDown = (e: MouseEvent) => {
      isDragging = true;
      const rect = circularLevelContainer.getBoundingClientRect();
      triggerManualSimulation(e.clientX, e.clientY, rect, true);
    };

    const linearMouseDown = (e: MouseEvent) => {
      isDragging = true;
      const rect = linearLevelContainer.getBoundingClientRect();
      triggerManualSimulation(e.clientX, e.clientY, rect, false);
    };

    const windowMouseMove = (e: MouseEvent) => {
      if (!isDragging) return;
      if (state.mode === "circular") {
        const rect = circularLevelContainer.getBoundingClientRect();
        triggerManualSimulation(e.clientX, e.clientY, rect, true);
      } else {
        const rect = linearLevelContainer.getBoundingClientRect();
        triggerManualSimulation(e.clientX, e.clientY, rect, false);
      }
    };

    const windowMouseUp = () => {
      isDragging = false;
    };

    const circularTouchStart = (e: TouchEvent) => {
      isDragging = true;
      const touch = e.touches[0];
      const rect = circularLevelContainer.getBoundingClientRect();
      triggerManualSimulation(touch.clientX, touch.clientY, rect, true);
    };

    const circularTouchMove = (e: TouchEvent) => {
      if (!isDragging) return;
      const touch = e.touches[0];
      const rect = circularLevelContainer.getBoundingClientRect();
      triggerManualSimulation(touch.clientX, touch.clientY, rect, true);
    };

    const circularTouchEnd = () => {
      isDragging = false;
    };

    const linearTouchStart = (e: TouchEvent) => {
      isDragging = true;
      const touch = e.touches[0];
      const rect = linearLevelContainer.getBoundingClientRect();
      triggerManualSimulation(touch.clientX, touch.clientY, rect, false);
    };

    const linearTouchMove = (e: TouchEvent) => {
      if (!isDragging) return;
      const touch = e.touches[0];
      const rect = linearLevelContainer.getBoundingClientRect();
      triggerManualSimulation(touch.clientX, touch.clientY, rect, false);
    };

    const linearTouchEnd = () => {
      isDragging = false;
    };

    function triggerManualSimulation(clientX: number, clientY: number, rect: DOMRect, isCircularMode: boolean) {
      if (isCircularMode) {
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        
        // Calculate relative offsets mapping to simulated angles (scale to max 15 degs)
        const relX = (clientX - centerX) / (rect.width / 2);
        const relY = (clientY - centerY) / (rect.height / 2);
        
        // Bubble follows physical slope direction
        handleOrientation(-relY * 18, -relX * 18);
      } else {
        const centerX = rect.left + rect.width / 2;
        const relX = (clientX - centerX) / (rect.width / 2);
        handleOrientation(0, -relX * 18);
      }
    }

    function initSimulation() {
      state.isSimulated = true;
      statusBanner.classList.remove("hidden");
      statusBanner.className = "text-xs py-1.5 px-3 rounded-lg font-medium text-center bg-surface-yellow text-yellow-dark border border-yellow-light/60";

      if (simulationInitialized) return;
      simulationInitialized = true;

      circularLevelContainer.addEventListener("mousedown", circularMouseDown);
      linearLevelContainer.addEventListener("mousedown", linearMouseDown);
      window.addEventListener("mousemove", windowMouseMove);
      window.addEventListener("mouseup", windowMouseUp);

      circularLevelContainer.addEventListener("touchstart", circularTouchStart, { passive: true });
      circularLevelContainer.addEventListener("touchmove", circularTouchMove, { passive: true });
      circularLevelContainer.addEventListener("touchend", circularTouchEnd);

      linearLevelContainer.addEventListener("touchstart", linearTouchStart, { passive: true });
      linearLevelContainer.addEventListener("touchmove", linearTouchMove, { passive: true });
      linearLevelContainer.addEventListener("touchend", linearTouchEnd);
    }

    function removeSimulationListeners() {
      if (!simulationInitialized) return;
      simulationInitialized = false;

      circularLevelContainer.removeEventListener("mousedown", circularMouseDown);
      linearLevelContainer.removeEventListener("mousedown", linearMouseDown);
      window.removeEventListener("mousemove", windowMouseMove);
      window.removeEventListener("mouseup", windowMouseUp);

      circularLevelContainer.removeEventListener("touchstart", circularTouchStart);
      circularLevelContainer.removeEventListener("touchmove", circularTouchMove);
      circularLevelContainer.removeEventListener("touchend", circularTouchEnd);

      linearLevelContainer.removeEventListener("touchstart", linearTouchStart);
      linearLevelContainer.removeEventListener("touchmove", linearTouchMove);
      linearLevelContainer.removeEventListener("touchend", linearTouchEnd);
    }

    // Motion Sensor Initialization / Support Check
    let eventCount = 0;
    let sensorCheckTimer: any = null;

    function updateSensorFlow() {
      // Hide simulation banner and reset simulation status initially
      statusBanner.classList.add("hidden");
      state.isSimulated = false;
      removeSimulationListeners();

      // Clean previous listener & check timer
      window.removeEventListener("deviceorientation", onOrientationEvent);
      if (sensorCheckTimer) {
        clearTimeout(sensorCheckTimer);
        sensorCheckTimer = null;
      }
      eventCount = 0;

      // Check if iOS 13+ permission flow is required
      const deviceOrientationSupport = typeof window !== "undefined" && "DeviceOrientationEvent" in window;
      const requiresPermission = deviceOrientationSupport &&
        typeof (DeviceOrientationEvent as any).requestPermission === "function";

      if (requiresPermission) {
        showPermissionPrompt();
      } else if (deviceOrientationSupport) {
        // Direct event registration
        window.addEventListener("deviceorientation", onOrientationEvent);
        showLiveWorkspace();
        // Give 1.5s to verify if events actually emit, fallback if flat numbers are zero or silent
        sensorCheckTimer = setTimeout(() => {
          if (eventCount === 0) {
            // Truly zero events arrived in 1.5s -> assume desktop/sensorless fallback
            initSimulation();
          }
        }, 1500);
      } else {
        // Fallback for desktops / browsers without Gyroscope
        showLiveWorkspace();
        initSimulation();
      }
    }

    let consecutiveNullCount = 0;

    function onOrientationEvent(e: DeviceOrientationEvent) {
      eventCount++;
      if (e.beta === null || e.gamma === null) {
        consecutiveNullCount++;
        if (consecutiveNullCount >= 10) { // Require several consecutive null readings before assuming unavailable
          initSimulation();
        }
        return;
      }
      consecutiveNullCount = 0; // reset count on successful reading
      handleOrientation(e.beta, e.gamma);
    }

    // Permission button triggers
    requestPermissionBtn.addEventListener("click", () => {
      if (
        typeof DeviceOrientationEvent !== "undefined" &&
        typeof (DeviceOrientationEvent as any).requestPermission === "function"
      ) {
        (DeviceOrientationEvent as any).requestPermission()
          .then((response: string) => {
            if (response === "granted") {
              state.permissionGranted = true;
              window.addEventListener("deviceorientation", onOrientationEvent);
              showLiveWorkspace();
            } else {
              // Denied fallback
              statusBanner.textContent = "Permission denied. Switched to Interactive Simulation.";
              showLiveWorkspace();
              initSimulation();
            }
          })
          .catch((err: Error) => {
            console.error("Sensor request permission error", err);
            showLiveWorkspace();
            initSimulation();
          });
      } else {
        showLiveWorkspace();
        initSimulation();
      }
    });

    skipPermissionBtn.addEventListener("click", () => {
      showLiveWorkspace();
      initSimulation();
    });

    function cleanup() {
      window.removeEventListener("deviceorientation", onOrientationEvent);
      removeSimulationListeners();
      if (sensorCheckTimer) {
        clearTimeout(sensorCheckTimer);
        sensorCheckTimer = null;
      }
    }

    // Cleanup page listeners on navigation unmount
    window.addEventListener("beforeunload", cleanup);
    document.addEventListener("astro:before-preparation", cleanup);

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Startup Init
    loadSettings();
    updateSensorFlow();
  </script>
</Layout>
