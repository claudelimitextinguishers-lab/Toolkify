    const fallbackCard = document.getElementById('fallback-card');
    const activateSimulatorBtn = document.getElementById('activate-simulator-btn');

    // Initialize Tick Marks on SVG Rose dial dynamically
    function generateCompassTicks() {
      const group = document.getElementById('compass-ticks');
      if (!group) return;
      group.innerHTML = '';
      
      for (let angle = 0; angle < 360; angle += 5) {
        const rad = (angle - 90) * Math.PI / 180;
        const isMajor = angle % 30 === 0;
        const isMedium = angle % 10 === 0 && !isMajor;
        
        const rStart = isMajor ? 82 : (isMedium ? 85 : 87);
        const rEnd = 88;
        
        const x1 = 100 + rStart * Math.cos(rad);
        const y1 = 100 + rStart * Math.sin(rad);
        const x2 = 100 + rEnd * Math.cos(rad);
        const y2 = 100 + rEnd * Math.sin(rad);
        
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', x1.toFixed(2));
        line.setAttribute('y1', y1.toFixed(2));
        line.setAttribute('x2', x2.toFixed(2));
        line.setAttribute('y2', y2.toFixed(2));
        line.setAttribute('stroke', isMajor ? '#1c1c1e' : '#8e91a0');
        line.setAttribute('stroke-width', isMajor ? '1' : '0.5');
        group.appendChild(line);

        // Add small numbers for major angles
        if (isMajor && angle !== 0 && angle !== 90 && angle !== 180 && angle !== 270) {
          const rText = 72;
          const tx = 100 + rText * Math.cos(rad);
          const ty = 100 + rText * Math.sin(rad) + 2.5; // offset center alignment
          
          const txt = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          txt.setAttribute('x', tx.toFixed(2));
          txt.setAttribute('y', ty.toFixed(2));
          txt.setAttribute('text-anchor', 'middle');
          txt.setAttribute('font-size', '5');
          txt.setAttribute('font-family', 'monospace');
          txt.setAttribute('fill', '#6b6f7e');
          txt.textContent = angle.toString();
          group.appendChild(txt);
        }
      }
    }

    // DOM References
    const shareBtn = document.getElementById('share-btn');

    // Save and Load settings
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const get = (lsKey, urlKey) => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        if (typeof localStorage === 'undefined') return null;
        try { return localStorage.getItem(lsKey); } catch (e) { return null; }
      };

      state.refMode = get(KEY_REF_MODE, 'refMode') || 'magnetic';
      state.declinationValue = parseFloat(get(KEY_DECL_VAL, 'declVal')) || 0.0;
      state.declinationDirection = get(KEY_DECL_DIR, 'declDir') || 'E';
      
      const lockedVal = get(KEY_LOCKED_BEARING, 'lockedBearing');
      state.lockedBearing = lockedVal !== null ? parseFloat(lockedVal) : null;
      
      const targetLat = get(LS_PREFIX + 'target-lat', 'targetLat');
      const targetLng = get(LS_PREFIX + 'target-lng', 'targetLng');
      if (targetLat && targetLng) {
        targetLatInput.value = targetLat;
        targetLngInput.value = targetLng;
        const lat = parseFloat(targetLat);
        const lng = parseFloat(targetLng);
        if (!isNaN(lat) && !isNaN(lng)) {
          state.targetCoords = { lat, lon: lng };
        }
      }

      // Update config inputs/controls UI
      declinationInput.value = state.declinationValue;
      updateDeclinationButtons();
      updateRefModeUI();
      updateLockUI();
    }

    function saveState() {
      localStorage.setItem(KEY_REF_MODE, state.refMode);
      localStorage.setItem(KEY_DECL_VAL, state.declinationValue.toString());
      localStorage.setItem(KEY_DECL_DIR, state.declinationDirection);
      if (state.lockedBearing !== null) {
        localStorage.setItem(KEY_LOCKED_BEARING, state.lockedBearing.toString());
      } else {
        localStorage.removeItem(KEY_LOCKED_BEARING);
      }
      if (targetLatInput.value) {
        localStorage.setItem(LS_PREFIX + 'target-lat', targetLatInput.value);
      } else {
        localStorage.removeItem(LS_PREFIX + 'target-lat');
      }
      if (targetLngInput.value) {
        localStorage.setItem(LS_PREFIX + 'target-lng', targetLngInput.value);
      } else {
        localStorage.removeItem(LS_PREFIX + 'target-lng');
      }
    }

    function updateRefModeUI() {
      if (state.refMode === 'true') {
        refTrueBtn.className = "text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas shadow-subtle";
        refMagneticBtn.className = "text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-primary";
      } else {
        refMagneticBtn.className = "text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas shadow-subtle";
        refTrueBtn.className = "text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-primary";
      }
    }

    // Update declination button styling
    function updateDeclinationButtons() {
      if (state.declinationDirection === 'E') {
        declEastBtn.className = "px-2.5 py-1 text-[10px] font-bold rounded-md bg-canvas border border-hairline-soft shadow-xs text-primary cursor-pointer";
        declWestBtn.className = "px-2.5 py-1 text-[10px] font-bold rounded-md text-slate hover:text-primary cursor-pointer";
      } else {
        declWestBtn.className = "px-2.5 py-1 text-[10px] font-bold rounded-md bg-canvas border border-hairline-soft shadow-xs text-primary cursor-pointer";
        declEastBtn.className = "px-2.5 py-1 text-[10px] font-bold rounded-md text-slate hover:text-primary cursor-pointer";
      }
    }

    function updateLockUI() {
      if (state.lockedBearing !== null) {
        lockedBearingText.textContent = `Locked: ${Math.round(state.lockedBearing).toString().padStart(3, '0')}°`;
        lockedBearingText.classList.remove('hidden');
        clearLockBtn.classList.remove('hidden');
        bearingLockMarker.classList.remove('hidden');
        referenceDeviation.classList.remove('hidden');
        
        // Draw the locked bearing indicator on SVGs (it stays fixed relative to the dial)
        const marker = document.getElementById('bearing-lock-marker');
        if (marker) {
          // Adjust rotation inside dial relative to North (0 deg is top)
          marker.setAttribute('transform', `rotate(${state.lockedBearing}, 100, 100)`);
        }
      } else {
        lockedBearingText.classList.add('hidden');
        clearLockBtn.classList.add('hidden');
        bearingLockMarker.classList.add('hidden');
        referenceDeviation.classList.add('hidden');
      }
    }

    // Helper functions for Cardinal directions
    function getCardinal(deg) {
      const directions = ["N", "NNE", "NE", "ENE", "E", "ESE", "SE", "SSE", "S", "SSW", "SW", "WSW", "W", "WNW", "NW", "NNW"];
      const index = Math.round(deg / 22.5) % 16;
      return directions[index];
    }

    // Trigonometric Circular Averaging (Smoothing)
    function smoothAngle(newAngle) {
      headingHistory.push(newAngle * Math.PI / 180);
      if (headingHistory.length > SMOOTHING_FACTOR) {
        headingHistory.shift();
      }

      let sumSin = 0;
      let sumCos = 0;
      for (let rad of headingHistory) {
        sumSin += Math.sin(rad);
        sumCos += Math.cos(rad);
      }

      let avgRad = Math.atan2(sumSin, sumCos);
      let avgDeg = avgRad * 180 / Math.PI;
      return (avgDeg + 360) % 360;
    }

    // Main Compass Render Update
    function updateCompassDisplay(headingVal) {
      state.heading = headingVal;
      
      // Update numbers
      const displayVal = Math.round(headingVal) % 360;
      headingDegEl.textContent = displayVal.toString().padStart(3, '0');
      headingCardinalEl.textContent = getCardinal(displayVal);

      // Rotate the compass rose graphic (N/S/E/W rotates in opposite direction to align with pointer at top)
      compassGraphic.style.transform = `rotate(${-headingVal}deg)`;

      // Calculate locked bearing deviation
      if (state.lockedBearing !== null) {
        let deviation = (headingVal - state.lockedBearing);
        // Normalize deviation to -180 to 180
        deviation = ((deviation + 180) % 360) - 180;
        if (deviation < -180) deviation += 360;

        const roundDev = Math.round(deviation);
        if (roundDev === 0) {
          referenceDeviation.textContent = "ON COURSE (0°)";
          referenceDeviation.className = "text-[10px] font-bold text-success-accent tracking-wide mt-0.5";
        } else if (roundDev > 0) {
          referenceDeviation.textContent = `TURN LEFT ${roundDev}°`;
          referenceDeviation.className = "text-[10px] font-bold text-brand-coral tracking-wide mt-0.5";
        } else {
          referenceDeviation.textContent = `TURN RIGHT ${Math.abs(roundDev)}°`;
          referenceDeviation.className = "text-[10px] font-bold text-brand-blue tracking-wide mt-0.5";
        }
      }

      // Update Waypoint Target Indicators
      updateWaypointCalculations();
    }

    // Recompute True North adjustment and smoothing immediately from stored rawHeading
    function recomputeAndDisplay() {
      let finalHeading = state.rawHeading;

      // Apply true north declination calculation if chosen
      if (state.refMode === 'true') {
        const factor = state.declinationDirection === 'E' ? 1 : -1;
        const declVal = state.declinationValue * factor;
        finalHeading = (finalHeading + declVal + 360) % 360;
      }

      // Apply smoothing filter to prevent jitter
      const smoothed = smoothAngle(finalHeading);
      updateCompassDisplay(smoothed);
    }

    // Process Incoming Orientation Data
    function processOrientation(alpha, beta, gamma, absolute, webkitCompass) {
      let finalHeading = null;

      // Prioritize webkitCompassHeading on iOS Safari
      if (webkitCompass !== undefined && webkitCompass !== null) {
        finalHeading = webkitCompass;
        // iOS webkitCompassHeading already accounts for screen rotation angle!
      } else if (alpha !== null && alpha !== undefined) {
        // Fallback for Android/Standard browsers. standard alpha is counter-clockwise (360-alpha gives clockwise heading)
        finalHeading = (360 - alpha) % 360;

        // Adjust for mobile screen viewport rotation angle (only on standard alpha fallback path)
        let screenAngle = 0;
        if (window.screen && window.screen.orientation && window.screen.orientation.angle !== undefined) {
          screenAngle = window.screen.orientation.angle;
        } else if (window.orientation !== undefined) {
          screenAngle = window.orientation;
        }
        finalHeading = (finalHeading + screenAngle + 360) % 360;
      }

      if (finalHeading !== null) {
        state.rawHeading = finalHeading;
        recomputeAndDisplay();
        
        sensorStatusDot.className = "w-2 h-2 rounded-full bg-success-accent animate-pulse";
        sensorStatusText.textContent = "Active";
      }
    }

    // iOS and Android Permission Hooks
    let sensorCheckTimeout = null;
    let sensorsResponding = false;

    function handleOrientationEvent(event) {
      sensorsResponding = true;
      if (sensorCheckTimeout) {
        clearTimeout(sensorCheckTimeout);
        sensorCheckTimeout = null;
      }

      // Check accuracy metrics (e.g. iOS webkitCompassAccuracy)
      if (event.webkitCompassAccuracy !== undefined && event.webkitCompassAccuracy !== null) {
        state.accuracy = event.webkitCompassAccuracy;
        
        if (state.accuracy > 0 && state.accuracy <= 15) {
          accuracyDisplay.textContent = `Acc: ±${Math.round(state.accuracy)}°`;
          calibrationWarningBox.classList.add('hidden');
        } else if (state.accuracy > 15) {
          accuracyDisplay.textContent = `Acc: Poor (±${Math.round(state.accuracy)}°)`;
          calibrationWarningBox.classList.remove('hidden');
        } else {
          accuracyDisplay.textContent = `Acc: --`;
        }
      } else {
        accuracyDisplay.textContent = `Acc: Active`;
      }

      processOrientation(
        event.alpha, 
        event.beta, 
        event.gamma, 
        event.absolute, 
        event.webkitCompassHeading
      );
    }

    function initSensors() {
      // Try setting up listener
      if (window.DeviceOrientationEvent) {
        // Bind only ONE of deviceorientation / deviceorientationabsolute (absolute preferred when available)
        if ('ondeviceorientationabsolute' in window) {
          window.addEventListener('deviceorientationabsolute', handleOrientationEvent, true);
        } else {
          window.addEventListener('deviceorientation', handleOrientationEvent, true);
        }

        // Fallback timeout: If no sensor response in 1.2s, prompt fallback simulation
        sensorCheckTimeout = setTimeout(() => {
          if (!sensorsResponding && !state.simulatedMode) {
            sensorStatusDot.className = "w-2 h-2 rounded-full bg-brand-coral";
            sensorStatusText.textContent = "Offline / Simulation";
            permissionCard.classList.add('hidden');
            fallbackCard.classList.remove('hidden');
          }
        }, 1200);
      } else {
        permissionCard.classList.add('hidden');
        fallbackCard.classList.remove('hidden');
      }
    }

    // iOS 13+ Permission Handshake
    async function requestCompassPermission() {
      if (
        typeof DeviceOrientationEvent !== 'undefined' &&
        typeof DeviceOrientationEvent.requestPermission === 'function'
      ) {
        try {
          const response = await DeviceOrientationEvent.requestPermission();
          if (response === 'granted') {
            permissionCard.classList.add('hidden');
            initSensors();
          } else {
            permissionErrorHint.textContent = "Sensor permission denied. Please reset website access settings.";
            permissionErrorHint.classList.remove('hidden');
          }
        } catch (err) {
          console.error(err);
          permissionErrorHint.textContent = "Error: Use HTTPS or check hardware permissions.";
          permissionErrorHint.classList.remove('hidden');
        }
      } else {
        // Non iOS platforms or older iOS
        permissionCard.classList.add('hidden');
        initSensors();
      }
    }

    // Keyboard Simulator controls (For Desktop/Desktop Testing)
    let simAngle = 0;
    let isSimulatorListenerAttached = false;

    function handleSimKeydown(e) {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) {
        return;
      }
      if (e.key === 'ArrowLeft') {
        simAngle = (simAngle - 5 + 360) % 360;
        state.rawHeading = simAngle;
        recomputeAndDisplay();
      } else if (e.key === 'ArrowRight') {
        simAngle = (simAngle + 5) % 360;
        state.rawHeading = simAngle;
        recomputeAndDisplay();
      }
    }

    function startSimulator() {
      state.simulatedMode = true;
      fallbackCard.classList.add('hidden');
      permissionCard.classList.add('hidden');
      sensorStatusDot.className = "w-2 h-2 rounded-full bg-brand-teal animate-pulse";
      sensorStatusText.textContent = "Keyboard Sim";
      accuracyDisplay.textContent = `Acc: Sim`;

      // Mock user coordinates for simulation so waypoint navigation is previewable
      state.myCoords = { lat: 37.7749, lon: -122.4194 };
      gpsLatEl.textContent = state.myCoords.lat.toFixed(6);
      gpsLngEl.textContent = state.myCoords.lon.toFixed(6);
      gpsStatusRow.classList.remove('hidden');

      state.rawHeading = simAngle;
      recomputeAndDisplay();

      if (!isSimulatorListenerAttached) {
        document.addEventListener('keydown', handleSimKeydown);
        isSimulatorListenerAttached = true;
      }
    }

    function stopSimulator() {
      if (isSimulatorListenerAttached) {
        document.removeEventListener('keydown', handleSimKeydown);
        isSimulatorListenerAttached = false;
      }
    }

    // GPS & Waypoint Mathematics
    function calculateBearing(lat1, lon1, lat2, lon2) {
      const dLon = (lon2 - lon1) * Math.PI / 180;
      const lat1Rad = lat1 * Math.PI / 180;
      const lat2Rad = lat2 * Math.PI / 180;

      const y = Math.sin(dLon) * Math.cos(lat2Rad);
      const x = Math.cos(lat1Rad) * Math.sin(lat2Rad) -
                Math.sin(lat1Rad) * Math.cos(lat2Rad) * Math.cos(dLon);
      
      let bearing = Math.atan2(y, x) * 180 / Math.PI;
      return (bearing + 360) % 360;
    }

    function calculateDistance(lat1, lon1, lat2, lon2) {
      const R = 6371e3; // Earth's radius in meters
      const phi1 = lat1 * Math.PI / 180;
      const phi2 = lat2 * Math.PI / 180;
      const deltaPhi = (lat2 - lat1) * Math.PI / 180;
      const deltaLambda = (lon2 - lon1) * Math.PI / 180;

      const a = Math.sin(deltaPhi/2) * Math.sin(deltaPhi/2) +
                Math.cos(phi1) * Math.cos(phi2) *
                Math.sin(deltaLambda/2) * Math.sin(deltaLambda/2);
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));

      const d = R * c; // distance in meters
      if (d >= 1000) {
        return (d / 1000).toFixed(2) + ' km';
      }
      return Math.round(d) + ' m';
    }

    function updateWaypointCalculations() {
      if (!state.myCoords || !state.targetCoords) {
        waypointMarker.classList.add('hidden');
        return;
      }

      const bearing = calculateBearing(
        state.myCoords.lat, 
        state.myCoords.lon, 
        state.targetCoords.lat, 
        state.targetCoords.lon
      );

      const distance = calculateDistance(
        state.myCoords.lat, 
        state.myCoords.lon, 
        state.targetCoords.lat, 
        state.targetCoords.lon
      );

      wpTargetBearingEl.textContent = `${Math.round(bearing).toString().padStart(3, '0')}°`;
      wpDistanceEl.textContent = distance;

      // Angle relative to our current heading (e.g. where should the waypoint arrow point inside the dial)
      const relativeAngle = (bearing - state.heading + 360) % 360;
      
      // Update Waypoint Needle element placement on Compass rose
      waypointMarker.setAttribute('transform', `rotate(${bearing}, 100, 100)`);
      waypointMarker.classList.remove('hidden');

      // Relative angle warning deviation labels
      let relDeviation = ((bearing - state.heading + 180) % 360) - 180;
      if (relDeviation < -180) relDeviation += 360;
      const roundedRel = Math.round(relDeviation);

      if (Math.abs(roundedRel) <= 5) {
        wpRelativeDirEl.textContent = "AHEAD";
        wpRelativeDirEl.className = "font-mono font-bold text-success-accent";
      } else if (roundedRel > 0) {
        wpRelativeDirEl.textContent = `${roundedRel}° RIGHT`;
        wpRelativeDirEl.className = "font-mono font-bold text-brand-teal";
      } else {
        wpRelativeDirEl.textContent = `${Math.abs(roundedRel)}° LEFT`;
        wpRelativeDirEl.className = "font-mono font-bold text-brand-coral";
      }

      waypointStatsBox.classList.remove('hidden');
    }

    let gpsWatchId = null;

    function requestLocation() {
      if (navigator.geolocation) {
        if (gpsWatchId !== null) {
          navigator.geolocation.clearWatch(gpsWatchId);
        }
        gpsWatchId = navigator.geolocation.watchPosition(
          (pos) => {
            state.myCoords = {
              lat: pos.coords.latitude,
              lon: pos.coords.longitude
            };
            gpsLatEl.textContent = state.myCoords.lat.toFixed(6);
            gpsLngEl.textContent = state.myCoords.lon.toFixed(6);
            gpsStatusRow.classList.remove('hidden');
            
            enableGpsBtn.textContent = "📍 GPS Active / Connected";
            enableGpsBtn.className = "w-full bg-brand-teal/20 border border-brand-teal text-brand-teal text-xs font-semibold py-2 px-4 rounded-full transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-subtle";

            updateWaypointCalculations();
          },
          (err) => {
            console.error(err);
            alert("Unable to retrieve GPS coordinates. Verify website location access.");
          },
          { enableHighAccuracy: true }
        );
      } else {
        alert("Geolocation is not supported by your browser.");
      }
    }

    // Config Input Event Handlers
    function handleDeclinationChange() {
      const val = parseFloat(declinationInput.value) || 0;
      state.declinationValue = Math.min(180, Math.max(-180, val));
      declinationInput.value = state.declinationValue;
      saveState();
      recomputeAndDisplay();
    }

    // Event Bindings
    requestPermissionBtn.addEventListener('click', requestCompassPermission);
    permissionSkipBtn.addEventListener('click', () => {
      permissionCard.classList.add('hidden');
      startSimulator();
    });
    activateSimulatorBtn.addEventListener('click', startSimulator);

    // Reference Toggles
    refMagneticBtn.addEventListener('click', () => {
      state.refMode = 'magnetic';
      saveState();
      updateRefModeUI();
      recomputeAndDisplay();
    });

    refTrueBtn.addEventListener('click', () => {
      state.refMode = 'true';
      saveState();
      updateRefModeUI();
      recomputeAndDisplay();
    });

    declinationInput.addEventListener('input', handleDeclinationChange);

    declEastBtn.addEventListener('click', () => {
      state.declinationDirection = 'E';
      saveState();
      updateDeclinationButtons();
      recomputeAndDisplay();
    });

    declWestBtn.addEventListener('click', () => {
      state.declinationDirection = 'W';
      saveState();
      updateDeclinationButtons();
      recomputeAndDisplay();
    });

    // Course Locking
    lockHeadingBtn.addEventListener('click', () => {
      // Toggle or Lock current heading
      state.lockedBearing = state.heading;
      saveState();
      updateLockUI();
      recomputeAndDisplay();
    });

    clearLockBtn.addEventListener('click', () => {
      state.lockedBearing = null;
      saveState();
      updateLockUI();
      recomputeAndDisplay();
    });

    // GPS hooks
    enableGpsBtn.addEventListener('click', requestLocation);

    // Target coordinates changes trigger waypoint update
    [targetLatInput, targetLngInput].forEach(inp => {
      inp.addEventListener('input', () => {
        const lat = parseFloat(targetLatInput.value);
        const lng = parseFloat(targetLngInput.value);

        if (!isNaN(lat) && !isNaN(lng)) {
          state.targetCoords = { lat, lon: lng };
          updateWaypointCalculations();
        } else {
          state.targetCoords = null;
          waypointMarker.classList.add('hidden');
          waypointStatsBox.classList.add('hidden');
        }
        saveState();
      });
    });

    // Calibration warning dismiss
    dismissCalibrationBtn.addEventListener('click', () => {
      calibrationWarningBox.classList.add('hidden');
    });

    // Reset button hook (verbatim pattern matching requirement)
    resetBtn.addEventListener('click', () => {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // Stop GPS watch
      if (gpsWatchId !== null) {
        navigator.geolocation.clearWatch(gpsWatchId);
        gpsWatchId = null;
      }
      enableGpsBtn.textContent = "📍 Get Live GPS Position";
      enableGpsBtn.className = "w-full bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-teal hover:border-brand-teal text-xs font-semibold py-2 px-4 rounded-full transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-subtle";

      // Stop simulator
      stopSimulator();

      // Clear manual declination override
      state.declinationValue = 0.0;
      state.declinationDirection = 'E';
      declinationInput.value = '0';
      updateDeclinationButtons();

      // Reset display mode
      state.refMode = 'magnetic';
      updateRefModeUI();

      // Clear course lock
      state.lockedBearing = null;
      updateLockUI();

      // Clear target waypoint inputs and GPS coordinates
      state.myCoords = null;
      gpsLatEl.textContent = '--';
      gpsLngEl.textContent = '--';
      gpsStatusRow.classList.add('hidden');

      state.targetCoords = null;
      targetLatInput.value = '';
      targetLngInput.value = '';
      waypointMarker.classList.add('hidden');
      waypointStatsBox.classList.add('hidden');

      // Clear LocalStorage namespaces
      localStorage.removeItem(KEY_REF_MODE);
      localStorage.removeItem(KEY_DECL_VAL);
      localStorage.removeItem(KEY_DECL_DIR);
      localStorage.removeItem(KEY_LOCKED_BEARING);
      localStorage.removeItem(LS_PREFIX + 'target-lat');
      localStorage.removeItem(LS_PREFIX + 'target-lng');

      saveState();
      recomputeAndDisplay();

      // Restore initial permission UI states
      permissionCard.classList.remove('hidden');
      fallbackCard.classList.add('hidden');
      permissionErrorHint.classList.add('hidden');
    });

    // Share Event Listener
    shareBtn?.addEventListener('click', () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set('refMode', state.refMode);
      url.searchParams.set('declVal', state.declinationValue.toString());
      url.searchParams.set('declDir', state.declinationDirection);
      if (state.lockedBearing !== null) {
        url.searchParams.set('lockedBearing', state.lockedBearing.toString());
      }
      if (targetLatInput.value) {
        url.searchParams.set('targetLat', targetLatInput.value);
      }
      if (targetLngInput.value) {
        url.searchParams.set('targetLng', targetLngInput.value);
      }

      const shareData = {
        title: document.title || "Compass Rose",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== 'AbortError') {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // How it works modal event listeners (verbatim pattern matching)
    howItWorksBtn.addEventListener("click", () => {
      howItWorksModal.classList.remove("hidden");
    });
    closeModalBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });
    modalOkBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });
    howItWorksModal.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    function cleanup() {
      window.removeEventListener('deviceorientation', handleOrientationEvent, true);
      window.removeEventListener('deviceorientationabsolute', handleOrientationEvent, true);
      stopSimulator();
      if (gpsWatchId !== null) {
        navigator.geolocation.clearWatch(gpsWatchId);
        gpsWatchId = null;
      }
    }

    // Unload listeners cleanup contract
    window.addEventListener('beforeunload', cleanup);
    document.addEventListener("astro:before-preparation", cleanup);

    // Initialize layout tick marks and storage configs on load
    generateCompassTicks();
    loadState();

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });
  </script>
</Layout>
