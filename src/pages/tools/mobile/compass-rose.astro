---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Compass Rose";
const category = "mobile";
const tier = "Mobile Sensor Tools";
const description = "Free online digital compass rose tool. Find cardinal directions, practice compass rose drawing, learn the compass rose definition, and navigate with ease.";

// On-page SEO metadata
const pageTitle = "Compass Rose - Free Online Digital Compass & Orientation Tool";
const keywords = "compass rose, compass rose drawing, compass rose definition, compass rose dc, what is a compass rose, a compass rose, how to draw a compass rose, compass rose images, simple compass rose, easy compass rose, digital compass, online compass, bearing tool";
const ogImage = "/og/compass-rose.png";
const canonicalUrl = "https://toolkify.app/tools/mobile/compass-rose";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Compass Rose",
      "alternateName": "Digital Compass & Heading Lock",
      "url": "https://toolkify.app/tools/mobile/compass-rose",
      "description": "A web-based digital compass using live device orientation sensors. Features magnetic-to-true-north conversion, circular smoothing filters, target bearing locking, and GPS waypoint navigation.",
      "applicationCategory": "MobileApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires Device Orientation sensors. Requires HTML5.",
      "featureList": [
        "Real-time Device Orientation reading",
        "Circular smoothing algorithm for jitter-free orientation representation",
        "iOS 13+ DeviceOrientationEvent permission handshake",
        "Magnetic vs True North offsets with custom declination configuration",
        "Course correction bearing locks with error margin deviation indicators",
        "Waypoint finder utilizing live GPS bearing calculations",
        "High-contrast outdoors sunlight-readable vector design"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Mobile",
          "item": "https://toolkify.app/tools/mobile"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Compass Rose",
          "item": "https://toolkify.app/tools/mobile/compass-rose"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a compass rose",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A compass rose is a design or figure on a map, compass, monument, or chart used to display the orientation of the cardinal directions (North, South, East, and West) and their intermediate points.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to draw a compass rose",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To draw a compass rose, start with a central circle and mark the main axes (North, South, East, West). Draw large points (triangles) pointing to these axes, then add smaller points for the intercardinal directions (NE, SE, SW, NW). Shading one half of each point creates a classic 3D look.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does a compass rose look like",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A compass rose typically looks like a stylized star with points radiating from a central hub. The points are aligned with cardinal directions, with the North point usually being the largest or most decorated.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why is it called a compass rose",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>It is called a compass rose because the radiating points of the cardinal and intercardinal directions resemble the layered petals of a rose flower.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a compass rose on a map",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A compass rose on a map is a visual indicator that shows the map's orientation, helping users understand which direction is North, South, East, or West relative to the mapped terrain.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to make a compass rose",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To make a compass rose, you can draw one using a ruler and protractor, or generate one digitally using vector graphics. Start by laying out the cardinal axes, drawing star-like points, and labeling them with the corresponding direction letters.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does a compass rose show",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A compass rose shows the cardinal directions (North, South, East, West) and their intermediate bearings (like Northeast, Southwest), allowing navigators to determine their heading or orient a map.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is the purpose of a compass rose",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The purpose of a compass rose is to provide a clear, standardized reference for direction, enabling users to orient themselves, read maps correctly, and navigate accurately.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button (verbatim pattern from json-formatter.astro) -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How Compass Rose works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button (verbatim pattern from json-formatter.astro) -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main Workspace Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-stretch">
      
      <!-- Center Compass Widget - High-Contrast and Mobile-First Above the Fold -->
      <div class="lg:col-span-7 card-base flex flex-col items-center justify-center relative min-h-[380px] sm:min-h-[460px] p-3 sm:p-6 overflow-hidden">
        <!-- Permission Request / iOS Prompt Cover -->
        <div id="permission-card" class="absolute inset-0 bg-canvas/95 z-20 flex flex-col items-center justify-center text-center p-4 sm:p-6 transition-all duration-300">
          <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-full bg-yellow-light text-brand-yellow-deep flex items-center justify-center text-2xl font-bold mb-3 sm:mb-4 shadow-subtle">
            🧭
          </div>
          <h3 class="font-display font-semibold text-base sm:text-lg text-primary mb-1 sm:mb-2">Sensor Permission Required</h3>
          <p class="text-[11px] sm:text-xs text-slate max-w-sm mb-4 sm:mb-6 leading-relaxed">
            TOOLKIFY Compass Rose reads your device's physical magnetometer and gyroscope directly in your browser. Tap below to permit access.
          </p>
          <div class="flex flex-col gap-2 w-full max-w-xs">
            <button id="request-permission-btn" class="w-full bg-primary hover:bg-charcoal text-canvas text-xs font-semibold py-2 px-4 rounded-full transition-all cursor-pointer shadow-subtle">
              Enable Device Compass
            </button>
            <button id="permission-skip-btn" class="w-full text-slate hover:text-primary text-[10px] sm:text-[11px] font-medium py-1.5 transition-all cursor-pointer">
              Continue to Preview (Simulated Mode)
            </button>
          </div>
          <div id="permission-error-hint" class="hidden mt-4 text-xs text-brand-coral font-medium bg-brand-red/40 px-3 py-1.5 rounded-lg border border-brand-red-dark">
            Permission denied. Please verify settings or retry.
          </div>
        </div>

        <!-- Hardware Fallback Cover (No Magnetometer Detected) -->
        <div id="fallback-card" class="hidden absolute inset-0 bg-canvas/95 z-10 flex flex-col items-center justify-center text-center p-4 sm:p-6">
          <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-brand-red/20 text-brand-coral flex items-center justify-center text-lg font-bold mb-2 sm:mb-3">
            ⚠️
          </div>
          <h3 class="font-display font-semibold text-sm sm:text-base text-primary mb-1">Compass Sensor Unavailable</h3>
          <p class="text-[11px] sm:text-xs text-slate max-w-xs mb-3 sm:mb-4 leading-relaxed">
            We couldn't detect a physical orientation sensor. This is common on desktop PCs or when absolute orientation is blocked.
          </p>
          <button id="activate-simulator-btn" class="bg-surface hover:bg-hairline text-primary text-xs font-semibold py-1.5 px-4 border border-hairline-strong rounded-full transition-all cursor-pointer shadow-subtle">
            Activate Keyboard Simulator
          </button>
          <div class="text-[9px] sm:text-[10px] text-slate mt-2">
            Use <kbd class="px-1 py-0.5 bg-surface border border-hairline rounded font-mono text-[9px] shadow-xs">←</kbd> and <kbd class="px-1 py-0.5 bg-surface border border-hairline rounded font-mono text-[9px] shadow-xs">→</kbd> keys to rotate on Desktop.
          </div>
        </div>

        <!-- Top Status Bars (Glanceable stats above the compass) -->
        <div class="w-full flex justify-between items-center text-[9px] sm:text-[10px] font-semibold text-slate tracking-wider uppercase mb-2 sm:mb-4 absolute top-4 left-0 px-6">
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-success-accent animate-pulse" id="sensor-status-dot"></span>
            <span id="sensor-status-text">Calibrated</span>
          </div>
          <div id="accuracy-display" class="text-slate font-mono">
            Acc: --
          </div>
        </div>

        <!-- Huge Heading & Cardinal Readout -->
        <div class="text-center mt-4 sm:mt-6 mb-1 sm:mb-2 z-5">
          <div class="font-mono font-medium text-3xl sm:text-5xl tracking-tight text-primary flex items-baseline justify-center gap-1 select-none">
            <span id="heading-deg">000</span><span class="text-lg sm:text-2xl text-slate">°</span>
            <span id="heading-cardinal" class="ml-2 font-display font-bold text-xl sm:text-3xl text-brand-blue uppercase">N</span>
          </div>
          <div id="reference-deviation" class="text-[9px] sm:text-[10px] font-bold text-stone tracking-wide hidden mt-0.5">
            LOCK DEVIATION: --
          </div>
        </div>

        <!-- Smoothly Rotating Compass Rose SVG Container -->
        <div class="relative w-48 h-48 sm:w-72 sm:h-72 my-1 flex items-center justify-center select-none">
          <!-- Bearing Deviation Arc Background -->
          <div class="absolute inset-0 rounded-full border-2 border-dashed border-hairline pointer-events-none opacity-40"></div>

          <!-- Compass Needle Center Dial -->
          <svg id="compass-graphic" class="w-full h-full transform transition-transform duration-100 ease-out will-change-transform" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <!-- Outer Shadow Glow -->
              <radialGradient id="compass-glow" cx="50%" cy="50%" r="50%">
                <stop offset="70%" stop-color="#ffffff" stop-opacity="1" />
                <stop offset="100%" stop-color="#f7f8fa" stop-opacity="0.9" />
              </radialGradient>
              <!-- Needle Gradients -->
              <linearGradient id="needle-north" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#fcb900" />
                <stop offset="100%" stop-color="#ffd02f" />
              </linearGradient>
              <linearGradient id="needle-south" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#555a6a" />
                <stop offset="100%" stop-color="#8e91a0" />
              </linearGradient>
            </defs>

            <!-- Base Dial Backing -->
            <circle cx="100" cy="100" r="95" fill="url(#compass-glow)" stroke="#e0e2e8" stroke-width="1.5" />
            <circle cx="100" cy="100" r="88" fill="none" stroke="#eef0f3" stroke-width="3" />
            <circle cx="100" cy="100" r="76" fill="none" stroke="#e0e2e8" stroke-width="0.5" stroke-dasharray="2 2" />

            <!-- Bearing Lock Marker (Optional indicator relative to dial) -->
            <g id="bearing-lock-marker" class="hidden">
              <path d="M100 8 L103 16 L97 16 Z" fill="#ff9999" stroke="#600000" stroke-width="0.5" />
              <line x1="100" y1="16" x2="100" y2="100" stroke="#ff9999" stroke-width="1" stroke-dasharray="3 3" />
            </g>

            <!-- Waypoint Target Marker (Optional GPS direction indicator) -->
            <g id="waypoint-marker" class="hidden">
              <path d="M100 8 L104 20 L96 20 Z" fill="#0fbcb0" stroke="#187574" stroke-width="0.5" />
              <line x1="100" y1="20" x2="100" y2="100" stroke="#0fbcb0" stroke-width="1" stroke-dasharray="2 2" />
            </g>

            <!-- Compass Ticks (Every 30 degrees, minor every 5 degrees) -->
            <g id="compass-ticks" stroke="#6b6f7e" stroke-linecap="round"></g>

            <!-- Intercardinal & Cardinal Rose Lines -->
            <path d="M100 12 L100 188 M12 100 L188 100" stroke="#e0e2e8" stroke-width="1" />
            <path d="M38 38 L162 162 M38 162 L162 38" stroke="#eef0f3" stroke-width="0.75" stroke-dasharray="4 4" />

            <!-- Star Points / Rose Design -->
            <!-- North Point -->
            <polygon points="100,100 96,55 100,28" fill="#1c1c1e" />
            <polygon points="100,100 104,55 100,28" fill="#555a6a" />
            <!-- South Point -->
            <polygon points="100,100 96,145 100,172" fill="#555a6a" />
            <polygon points="100,100 104,145 100,172" fill="#a5a8b5" />
            <!-- East Point -->
            <polygon points="100,100 145,96 172,100" fill="#2c2c34" />
            <polygon points="100,100 145,104 172,100" fill="#6b6f7e" />
            <!-- West Point -->
            <polygon points="100,100 55,96 28,100" fill="#6b6f7e" />
            <polygon points="100,100 55,104 28,100" fill="#a5a8b5" />

            <!-- Core Letters (North / South / East / West) -->
            <text x="100" y="24" text-anchor="middle" font-family="Roobert PRO, system-ui" font-size="11" font-weight="800" fill="#ffd02f" stroke="#1c1c1e" stroke-width="1.5" paint-order="stroke fill">N</text>
            <text x="100" y="184" text-anchor="middle" font-family="Roobert PRO, system-ui" font-size="10" font-weight="700" fill="#2c2c34">S</text>
            <text x="180" y="103" text-anchor="middle" font-family="Roobert PRO, system-ui" font-size="10" font-weight="700" fill="#2c2c34">E</text>
            <text x="20" y="103" text-anchor="middle" font-family="Roobert PRO, system-ui" font-size="10" font-weight="700" fill="#2c2c34">W</text>

            <!-- Ordinal Labels -->
            <text x="150" y="55" text-anchor="middle" font-family="sans-serif" font-size="7" font-weight="700" fill="#6b6f7e">NE</text>
            <text x="150" y="152" text-anchor="middle" font-family="sans-serif" font-size="7" font-weight="700" fill="#6b6f7e">SE</text>
            <text x="50" y="152" text-anchor="middle" font-family="sans-serif" font-size="7" font-weight="700" fill="#6b6f7e">SW</text>
            <text x="50" y="55" text-anchor="middle" font-family="sans-serif" font-size="7" font-weight="700" fill="#6b6f7e">NW</text>
          </svg>

          <!-- Lubber's Line (Fixed Heading Pointer at top center) -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 flex flex-col items-center pointer-events-none z-10">
            <div class="w-1.5 h-6 bg-brand-coral rounded-full shadow-subtle"></div>
            <div class="w-2.5 h-2.5 bg-brand-coral rotate-45 -mt-1.5"></div>
          </div>
        </div>

        <!-- High-contrast calibration indicator warning -->
        <div id="calibration-warning-box" class="hidden w-full max-w-xs mt-4 flex items-center justify-between gap-2 p-2 bg-surface-yellow border border-brand-yellow-deep/50 rounded-lg animate-bounce select-none">
          <div class="flex items-center gap-2">
            <span class="text-sm">🔄</span>
            <div class="text-[10px] text-yellow-dark leading-tight">
              <strong class="font-bold block">Interference / Low Accuracy</strong>
              Calibrate by moving device in a figure-8 path.
            </div>
          </div>
          <button id="dismiss-calibration-btn" class="text-stone hover:text-primary font-bold text-xs p-1 cursor-pointer">✕</button>
        </div>
      </div>

      <!-- Left / Side Controls Workspace -->
      <div class="lg:col-span-5 flex flex-col gap-4">
        
        <!-- Accuracy & Settings Configurations Panel -->
        <div class="card-base flex flex-col gap-4">
          <h2 class="font-display font-semibold text-sm text-primary flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-brand-yellow"></span>
            Compass Configurations
          </h2>

          <!-- North Reference Toggle -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold text-slate uppercase tracking-wider">North Reference</label>
            <div class="grid grid-cols-2 gap-2 bg-surface p-0.5 rounded-full border border-hairline">
              <button
                type="button"
                id="ref-magnetic-btn"
                class="text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas shadow-subtle"
              >
                Magnetic North
              </button>
              <button
                type="button"
                id="ref-true-btn"
                class="text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-primary"
              >
                True North
              </button>
            </div>
          </div>

          <!-- Magnetic Declination Input Field -->
          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between items-center">
              <label for="declination-input" class="text-[10px] font-bold text-slate uppercase tracking-wider">Magnetic Declination</label>
              <span class="text-[10px] font-semibold text-brand-blue">Find local offset</span>
            </div>
            <div class="flex gap-2">
              <div class="relative flex-1">
                <input
                  type="number"
                  id="declination-input"
                  value="0"
                  step="0.1"
                  min="-180"
                  max="180"
                  class="w-full bg-canvas border border-hairline hover:border-hairline-strong focus:border-brand-blue focus:ring-1 focus:ring-brand-blue text-xs font-mono font-medium rounded-lg px-3 py-2 outline-none transition-all"
                  placeholder="e.g. 12.5 or -3.2"
                />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-semibold text-slate font-mono">°</span>
              </div>
              <div class="flex rounded-lg border border-hairline p-0.5 bg-surface">
                <button type="button" id="decl-east-btn" class="px-2.5 py-1 text-[10px] font-bold rounded-md bg-canvas border border-hairline-soft shadow-xs text-primary cursor-pointer">E</button>
                <button type="button" id="decl-west-btn" class="px-2.5 py-1 text-[10px] font-bold rounded-md text-slate hover:text-primary cursor-pointer">W</button>
              </div>
            </div>
            <p class="text-[10px] text-stone leading-normal">
              Adjusts Magnetic readings to represent Geographic True North. Add East declination (+) or West declination (-).
            </p>
          </div>

          <!-- Reference Course Lock Utility -->
          <div class="flex flex-col gap-2 pt-2 border-t border-hairline-soft">
            <div class="flex justify-between items-center">
              <span class="text-[10px] font-bold text-slate uppercase tracking-wider">Reference Bearing Lock</span>
              <span id="locked-bearing-text" class="text-[10px] font-mono font-semibold text-brand-coral bg-coral-light/30 px-2 py-0.5 rounded-full hidden">Locked: --°</span>
            </div>
            
            <div class="flex gap-2">
              <button
                type="button"
                id="lock-heading-btn"
                class="flex-1 bg-surface hover:bg-hairline text-primary text-xs font-semibold py-2 px-4 border border-hairline-strong rounded-full transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-subtle"
              >
                <span>🔒</span> Lock Heading
              </button>
              <button
                type="button"
                id="clear-lock-btn"
                class="text-slate hover:text-brand-coral hover:border-brand-coral bg-canvas border border-hairline text-xs font-semibold px-4 rounded-full transition-all cursor-pointer hidden"
              >
                Clear
              </button>
            </div>
            <p class="text-[10px] text-stone leading-normal">
