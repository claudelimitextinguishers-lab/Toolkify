  <script is:inline>
    (function () {
      'use strict';

      const STATE_KEY = 'toolkify_battery_health_state_v2';

      const state = {
        // estimator inputs
        age: 12,
        cyclesPerDay: 1.0,
        temp: 'warm',
        fastCharge: false,
        keepPlugged: false,
        designCapacity: null
      };

      // Live-monitor runtime (not persisted)
      let batterySamples = [];   // { t: ms, level: 0..1 }
      let sessionStart = null;   // { t, level }
      let wakeLock = null;
      let batteryRef = null;     // live BatteryManager reference
      let pollTimer = null;      // periodic re-read timer

      // ---- DOM refs ----
      const $ = (id) => document.getElementById(id);
      const apiStatusDot = $('api-status-dot');
      const apiStatusLabel = $('api-status-label');
      const modeBadge = $('mode-badge');
      const gaugeRing = $('gauge-level-ring');
      const gaugeText = $('gauge-level-text');
      const chargingStatusText = $('charging-status-text');

      const statState = $('stat-state');
      const statRate = $('stat-rate');
      const statTime = $('stat-time');
      const statSession = $('stat-session');
      const measureHint = $('measure-hint');
      const fallbackNotice = $('fallback-notice');
      const wakeToggle = $('wake-lock-toggle');

      const ageInput = $('device-age');
      const ageVal = $('age-val');
      const cyclesInput = $('cycles-day');
      const cyclesVal = $('cycles-val');
      const tempBtns = Array.prototype.slice.call(document.querySelectorAll('.temp-btn'));
      const fastInput = $('habit-fast');
      const pluggedInput = $('habit-plugged');
      const capacityInput = $('design-capacity');

      const estHealth = $('est-health');
      const estCondition = $('est-condition');
      const estBar = $('est-bar');
      const estCycles = $('est-cycles');
      const estCapacity = $('est-capacity');

      const shareBtn = $('share-btn');
      const resetBtn = $('reset-btn');
      const printReportBtn = $('print-report-btn');
      const howItWorksBtn = $('how-it-works-btn');
      const howItWorksModal = $('how-it-works-modal');
      const closeModalBtn = $('close-modal-btn');
      const modalOkBtn = $('modal-ok-btn');

      const CIRCUMFERENCE = 2 * Math.PI * 76; // 477.5

      // ---- helpers ----
      function haptic(ms) {
        try { if (navigator.vibrate) navigator.vibrate(ms || 8); } catch (e) {}
      }

      function ringColor(levelPct, charging) {
        if (charging) return '#00b473';        // success green while charging
        if (levelPct <= 15) return '#ff9999';  // coral low
        if (levelPct <= 40) return '#fcb900';  // amber
        return '#4262ff';                        // brand blue
      }

      function fmtDuration(seconds) {
        if (!isFinite(seconds) || seconds <= 0) return null;
        const h = Math.floor(seconds / 3600);
        const m = Math.round((seconds % 3600) / 60);
        if (h > 0) return h + 'h ' + m + 'm';
        return m + 'm';
      }

      // ---- gauge ----
      function drawGauge(levelPct, charging) {
        const clamped = Math.max(0, Math.min(100, levelPct));
        const offset = CIRCUMFERENCE - (clamped / 100) * CIRCUMFERENCE;
        gaugeRing.style.strokeDashoffset = String(offset);
        gaugeRing.setAttribute('stroke', ringColor(clamped, charging));
        gaugeText.innerHTML = Math.round(clamped) + '<span class="text-2xl align-top">%</span>';
      }

      // ================= LIVE MONITOR =================
      function computeMeasuredRate() {
        // Returns { perHour: signed %/h, remaining: seconds|null } or null
        if (batterySamples.length < 2) return null;
        const first = batterySamples[0];
        const last = batterySamples[batterySamples.length - 1];
        const hours = (last.t - first.t) / 3600000;
        const deltaPct = (last.level - first.level) * 100;
        if (hours <= 0 || Math.abs(deltaPct) < 1) return null; // need a real 1% step
        const perHour = deltaPct / hours; // negative => draining
        let remaining = null;
        if (perHour < 0) {
          remaining = (last.level * 100 / -perHour) * 3600;        // to empty
        } else if (perHour > 0) {
          remaining = ((1 - last.level) * 100 / perHour) * 3600;   // to full
        }
        return { perHour: perHour, remaining: remaining };
      }

      function renderLive(battery) {
        const levelPct = battery.level * 100;
        const charging = battery.charging;
        drawGauge(levelPct, charging);

        // State + charging line
        if (charging) {
          statState.textContent = levelPct >= 99.5 ? 'Charged / plugged in' : 'Charging';
          chargingStatusText.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-brand-yellow-deep"><path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.972 9.75h7.278a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.75a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 01.913-.143z" clip-rule="evenodd"/></svg> Charging';
        } else {
          statState.textContent = 'Discharging';
          chargingStatusText.textContent = 'On battery';
        }

        // Measured rate + time remaining (prefer our measurement, fall back to OS estimate)
        const measured = computeMeasuredRate();
        if (measured) {
          const abs = Math.abs(measured.perHour);
          statRate.textContent = (measured.perHour < 0 ? '−' : '+') + abs.toFixed(1) + '%/h';
          const rem = fmtDuration(measured.remaining);
          statTime.textContent = rem ? rem + (measured.perHour < 0 ? ' to empty' : ' to full') : '—';
          measureHint.textContent = 'Measured live from ' + batterySamples.length + ' samples.';
        } else {
          statRate.textContent = 'Measuring…';
          // OS-provided estimate as an interim value
          const osSeconds = charging ? battery.chargingTime : battery.dischargingTime;
          const osRem = fmtDuration(osSeconds);
          statTime.textContent = osRem ? osRem + (charging ? ' to full' : ' to empty') + ' (system)' : 'Unknown';
          measureHint.textContent = 'Waiting for a 1% change to measure your real drain rate…';
        }

        // Session change
        if (sessionStart) {
          const delta = Math.round((battery.level - sessionStart.level) * 100);
          const mins = Math.max(1, Math.round((Date.now() - sessionStart.t) / 60000));
          const sign = delta > 0 ? '+' : '';
          statSession.textContent = sign + delta + '% over ' + mins + 'm';
        }
      }

      function recordSample(battery) {
        const now = Date.now();
        if (!sessionStart) sessionStart = { t: now, level: battery.level };
        const last = batterySamples[batterySamples.length - 1];
        if (!last || last.level !== battery.level) {
          batterySamples.push({ t: now, level: battery.level });
          // keep memory bounded
          if (batterySamples.length > 200) batterySamples.shift();
        }
      }

      function initBattery() {
        if (!('getBattery' in navigator) || typeof navigator.getBattery !== 'function') {
          markUnsupported();
          return;
        }
        navigator.getBattery().then(function (battery) {
          apiStatusDot.className = 'w-2.5 h-2.5 rounded-full bg-success-accent';
          apiStatusLabel.textContent = 'Live battery data connected';
          modeBadge.textContent = 'Live API';
          fallbackNotice.classList.add('hidden');

          batteryRef = battery;
          recordSample(battery);
          renderLive(battery);

          function onChange() { recordSample(battery); renderLive(battery); }
          battery.addEventListener('levelchange', onChange);
          battery.addEventListener('chargingchange', function () { haptic(12); onChange(); });
          battery.addEventListener('chargingtimechange', onChange);
          battery.addEventListener('dischargingtimechange', onChange);

          // Some devices report a stale level at first (often 100%) and only
          // correct it a moment later WITHOUT firing an event. Re-read the live
          // properties a few times after load, then keep polling gently, so the
          // displayed percentage always reflects the true current charge.
          [400, 1200, 2500, 5000].forEach(function (delay) {
            setTimeout(function () { if (batteryRef) renderLive(batteryRef); }, delay);
          });
          if (pollTimer) clearInterval(pollTimer);
          pollTimer = setInterval(function () {
            if (batteryRef) { recordSample(batteryRef); renderLive(batteryRef); }
          }, 15000);

          // Re-sync whenever the user returns to the tab.
          document.addEventListener('visibilitychange', function () {
            if (document.visibilityState === 'visible' && batteryRef) renderLive(batteryRef);
          });
          window.addEventListener('focus', function () { if (batteryRef) renderLive(batteryRef); });
        }).catch(function () {
          markUnsupported();
        });
      }

      function markUnsupported() {
        apiStatusDot.className = 'w-2.5 h-2.5 rounded-full bg-brand-coral';
        apiStatusLabel.textContent = 'Live battery data unavailable';
        modeBadge.textContent = 'Estimate only';
        fallbackNotice.classList.remove('hidden');
        // Draw an empty (grey) ring WITHOUT touching the centre text.
        gaugeRing.style.strokeDashoffset = String(CIRCUMFERENCE);
        gaugeRing.setAttribute('stroke', '#e0e2e8');
        gaugeText.innerHTML = 'N/A';
        chargingStatusText.textContent = 'Use the estimator below';
        statState.textContent = 'Unavailable';
        statRate.textContent = '—';
        statTime.textContent = '—';
        statSession.textContent = '—';
        measureHint.textContent = 'This browser blocks battery access.';
      }

      // ---- Wake Lock ----
      async function requestWakeLock() {
        try {
          if ('wakeLock' in navigator) {
            wakeLock = await navigator.wakeLock.request('screen');
            wakeLock.addEventListener('release', function () { wakeLock = null; });
          }
        } catch (e) { wakeToggle.checked = false; }
      }
      function releaseWakeLock() {
        try { if (wakeLock) { wakeLock.release(); wakeLock = null; } } catch (e) {}
      }
      wakeToggle.addEventListener('change', function () {
        haptic();
        if (wakeToggle.checked) requestWakeLock(); else releaseWakeLock();
      });
      document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible' && wakeToggle.checked && !wakeLock) requestWakeLock();
      });

      // ================= HEALTH ESTIMATOR =================
      function computeHealth() {
        const tempMult = state.temp === 'cool' ? 0.8 : (state.temp === 'hot' ? 1.4 : 1.0);
        const cycles = Math.round(state.age * 30.44 * state.cyclesPerDay);

        // Cycle aging: ~0.04%/cycle baseline (≈20% loss at 500 cycles), scaled by heat.
        const cycleLoss = cycles * 0.04 * tempMult;
        // Calendar aging: ~3%/year baseline, scaled by heat.
        const calendarLoss = (state.age / 12) * 3 * tempMult;
        // Habit penalties.
        const habitLoss = (state.fastCharge ? 3 : 0) + (state.keepPlugged ? 4 : 0);

        let health = 100 - cycleLoss - calendarLoss - habitLoss;
        health = Math.max(40, Math.min(100, Math.round(health)));

        return { health: health, cycles: cycles };
      }

      function conditionFor(h) {
        if (h >= 90) return { label: 'Excellent', cls: 'text-success-accent', bg: 'bg-teal-light', color: '#00b473' };
        if (h >= 80) return { label: 'Good', cls: 'text-brand-blue', bg: 'bg-surface-pricing-featured', color: '#4262ff' };
        if (h >= 70) return { label: 'Fair', cls: 'text-brand-yellow-deep', bg: 'bg-yellow-light', color: '#fcb900' };
        return { label: 'Consider service', cls: 'text-brand-coral', bg: 'bg-coral-light', color: '#ff9999' };
      }

      function renderEstimator() {
        const r = computeHealth();
        const cond = conditionFor(r.health);

        estHealth.innerHTML = r.health + '<span class="text-lg align-top">%</span>';
        estCondition.textContent = cond.label;
        estCondition.className = 'text-[11px] font-bold py-1 px-2.5 rounded-full ' + cond.bg + ' ' + cond.cls;
        estBar.style.width = r.health + '%';
        estBar.style.backgroundColor = cond.color;
        estCycles.textContent = '~' + r.cycles.toLocaleString();

        if (state.designCapacity && state.designCapacity >= 500) {
          const nowCap = Math.round(state.designCapacity * r.health / 100);
          estCapacity.textContent = '~' + nowCap.toLocaleString() + ' mAh';
        } else {
          estCapacity.textContent = '~' + r.health + '% of new';
        }
      }

      function syncTempButtons() {
        tempBtns.forEach(function (b) {
          const active = b.getAttribute('data-temp') === state.temp;
          b.className = 'temp-btn min-h-[40px] text-[11px] font-semibold rounded-lg border transition-all ' +
            (active ? 'border-brand-blue bg-surface-pricing-featured text-brand-blue' : 'border-hairline bg-surface text-slate');
        });
      }

      function syncInputsFromState() {
        ageInput.value = state.age;
        ageVal.textContent = state.age;
        cyclesInput.value = Math.round(state.cyclesPerDay * 10);
        cyclesVal.textContent = state.cyclesPerDay.toFixed(1);
        fastInput.checked = state.fastCharge;
        pluggedInput.checked = state.keepPlugged;
        capacityInput.value = state.designCapacity || '';
        syncTempButtons();
        renderEstimator();
      }

      // ---- persistence ----
      function saveState() {
        try { localStorage.setItem(STATE_KEY, JSON.stringify(state)); } catch (e) {}
      }
      function loadState() {
        try {
          const raw = localStorage.getItem(STATE_KEY);
          if (raw) {
            const p = JSON.parse(raw);
            if (typeof p.age === 'number') state.age = p.age;
            if (typeof p.cyclesPerDay === 'number') state.cyclesPerDay = p.cyclesPerDay;
            if (typeof p.temp === 'string') state.temp = p.temp;
            state.fastCharge = !!p.fastCharge;
            state.keepPlugged = !!p.keepPlugged;
            state.designCapacity = (typeof p.designCapacity === 'number') ? p.designCapacity : null;
          }
        } catch (e) {}
      }

      // ---- estimator input events ----
      ageInput.addEventListener('input', function (e) {
        state.age = parseInt(e.target.value, 10);
        ageVal.textContent = state.age;
        renderEstimator(); saveState();
      });
      cyclesInput.addEventListener('input', function (e) {
        state.cyclesPerDay = parseInt(e.target.value, 10) / 10;
        cyclesVal.textContent = state.cyclesPerDay.toFixed(1);
        renderEstimator(); saveState();
      });
      tempBtns.forEach(function (b) {
        b.addEventListener('click', function () {
          haptic();
          state.temp = b.getAttribute('data-temp');
          syncTempButtons(); renderEstimator(); saveState();
        });
      });
      fastInput.addEventListener('change', function () {
        state.fastCharge = fastInput.checked; renderEstimator(); saveState();
      });
      pluggedInput.addEventListener('change', function () {
        state.keepPlugged = pluggedInput.checked; renderEstimator(); saveState();
      });
      capacityInput.addEventListener('input', function () {
        const v = parseInt(capacityInput.value, 10);
        state.designCapacity = (v >= 500 && v <= 20000) ? v : null;
        renderEstimator(); saveState();
      });

      // ---- reset ----
      resetBtn.addEventListener('click', function () {
        haptic();
        state.age = 12; state.cyclesPerDay = 1.0; state.temp = 'warm';
        state.fastCharge = false; state.keepPlugged = false; state.designCapacity = null;
        try { localStorage.removeItem(STATE_KEY); } catch (e) {}
        syncInputsFromState();
      });

      // ---- print ----
      printReportBtn.addEventListener('click', function () { window.print(); });

      // ---- share ----
      shareBtn.addEventListener('click', function () {
        haptic();
        const url = new URL(window.location.origin + window.location.pathname);
        const shareData = { title: 'Battery Health Test', url: url.toString() };
        if (navigator.share) {
          navigator.share(shareData).catch(function (err) {
            if (err && err.name !== 'AbortError') copyToClipboard(url.toString());
          });
        } else {
          copyToClipboard(url.toString());
        }
      });
      function copyToClipboard(text) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showCopySuccess).catch(function () { fallbackCopy(text); });
        } else { fallbackCopy(text); }
      }
      function fallbackCopy(text) {
        const ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.select();
        try { document.execCommand('copy'); showCopySuccess(); } catch (e) {}
        document.body.removeChild(ta);
      }
      function showCopySuccess() {
        const span = shareBtn.querySelector('span');
        if (!span) return;
        const original = span.textContent;
        span.textContent = 'Copied!';
        shareBtn.classList.add('text-success-accent', 'border-success-accent');
        setTimeout(function () {
          span.textContent = original;
          shareBtn.classList.remove('text-success-accent', 'border-success-accent');
        }, 2000);
      }

      // ---- modal ----
      function openModal() { howItWorksModal.classList.remove('hidden'); }
      function closeModal() { howItWorksModal.classList.add('hidden'); }
      howItWorksBtn.addEventListener('click', openModal);
      closeModalBtn.addEventListener('click', closeModal);
      modalOkBtn.addEventListener('click', closeModal);
      howItWorksModal.addEventListener('click', function (e) { if (e.target === howItWorksModal) closeModal(); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });

      // ---- FAQ accordion ----
      const faqButtons = Array.prototype.slice.call(document.querySelectorAll('.faq-toggle-btn'));
      faqButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          faqButtons.forEach(function (other) {
            if (other !== btn) {
              other.setAttribute('aria-expanded', 'false');
              const oc = other.nextElementSibling;
              if (oc) oc.classList.add('hidden');
              const os = other.querySelector('svg'); if (os) os.classList.remove('rotate-180');
            }
          });
          btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          const content = btn.nextElementSibling;
          if (content) content.classList.toggle('hidden');
          const svg = btn.querySelector('svg'); if (svg) svg.classList.toggle('rotate-180');
        });
      });

      // ---- scan button: recompute estimate, then scroll to the estimator so the user can set it up ----
      const scanBtn = $('scan-btn');
      const estimatorTop = $('estimator-top');
      scanBtn.addEventListener('click', function () {
        haptic(15);
        const label = scanBtn.querySelector('span');
        const original = label ? label.textContent : '';
        if (label) label.textContent = 'Scanning…';
        scanBtn.disabled = true;
        scanBtn.classList.add('opacity-70');
        renderEstimator();
        setTimeout(function () {
          if (label) label.textContent = original;
          scanBtn.disabled = false;
          scanBtn.classList.remove('opacity-70');
          if (estimatorTop && estimatorTop.scrollIntoView) {
            estimatorTop.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
          estimatorTop.classList.add('ring-2', 'ring-brand-blue');
          setTimeout(function () { estimatorTop.classList.remove('ring-2', 'ring-brand-blue'); }, 1200);
        }, 550);
      });

      // ---- init ----
      loadState();
      syncInputsFromState();
      initBattery();
    })();
  </script>
</Layout>
