---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Battery Health Test";
const category = "mobile";
const tier = "Mobile Sensor Tools";
const description = "Read your phone or laptop's live battery status right in the browser — real charge level, charging state, and a measured drain rate. Plus a transparent battery-health estimator based on age and charging habits.";

const pageTitle = "Battery Health Test - Live Battery Status & Honest Health Estimate";
const canonicalUrl = "https://toolkify.com/tools/mobile/battery-health";
const ogImage = "/og/battery-health.png";
const keywords = "battery health, battery test, battery status api, phone battery test, battery drain rate, battery percentage, time remaining, battery health estimate, laptop battery, charge cycles";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Battery Health Test",
      "alternateName": "Live Battery Status Monitor & Health Estimator",
      "url": "https://toolkify.com/tools/mobile/battery-health",
      "description": "A privacy-first, in-browser battery tool. It reads your device's real battery level and charging state through the standard Battery Status API, measures your live drain and charge rate over time, and provides a transparent, model-based battery-health estimate from your device age and charging habits.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Live status requires a Chromium-based browser (Chrome, Edge, Opera, Samsung Internet) that supports the Battery Status API. Firefox and Safari/iOS do not expose battery data; the tool falls back to the manual estimator.",
      "featureList": [
        "Live battery level and charging state via the Battery Status API",
        "Measured drain and charge rate (percent per hour) computed from real samples",
        "System and measured time-to-full / time-to-empty estimates",
        "Screen Wake Lock so the reading stays visible while you watch it",
        "Transparent, science-based battery-health estimator (age + charging habits)",
        "Honest about limits: no fabricated temperature, voltage, or cycle-count readings",
        "100% client-side — no battery or device data leaves your browser"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolkify.com/" },
        { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://toolkify.com/tools" },
        { "@type": "ListItem", "position": 3, "name": "Mobile", "item": "https://toolkify.com/tools/mobile" },
        { "@type": "ListItem", "position": 4, "name": "Battery Health Test", "item": "https://toolkify.com/tools/mobile/battery-health" }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can a browser read my battery health or capacity?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>No. Browsers cannot read physical battery health, remaining capacity in mAh, cycle count, temperature, or voltage. The web Battery Status API only exposes four things: the current charge level (as a percentage), whether the device is charging, and rough time-to-full and time-to-empty values. This tool shows those real values and additionally measures your live drain rate. Any 'health percentage' here is a clearly-labelled estimate from the age and habits you enter, not a hardware reading.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why doesn't the live reading work on my iPhone or in Firefox?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Safari and all iOS browsers never implemented the Battery Status API, and Firefox removed it in 2017 to prevent fingerprinting. On those browsers there is no way for any website to read your battery level, so this tool automatically switches to its manual health estimator. Live battery status works on Chromium-based browsers: Chrome, Edge, Opera, and Samsung Internet.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How is the drain rate measured?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The tool timestamps every change in your battery percentage while the page is open, then divides the total percentage change by the elapsed time to give a real percent-per-hour figure. Because the operating system only reports whole-percent steps, the first accurate number appears after your level changes by at least one percent, so leaving the page open for a few minutes gives a more precise reading.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What actually degrades a lithium-ion battery?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Two things dominate: cycle aging (each full charge-discharge cycle wears the cell, with most phones rated to keep about 80% capacity after 500 cycles) and calendar aging (chemical decay over time regardless of use). Heat above about 35°C, sitting at 100% while plugged in, deep discharges to 0%, and frequent fast charging all accelerate both. The estimator on this page uses these factors, weighted from published lithium-ion research, to approximate wear.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How can I make my battery last longer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Keep the charge roughly between 20% and 80%, avoid leaving it plugged in at 100% overnight, keep it cool (don't game or run heavy loads while charging), and prefer slower charging when you're not in a hurry. These habits reduce both cycle and calendar aging.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1280px] w-full mx-auto px-3 sm:px-4 md:px-8 py-3 sm:py-10 flex flex-col gap-3 sm:gap-8 animate-fade-in-up pb-14 sm:pb-16 print:p-0">

    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface active:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface active:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How this tool works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface active:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset estimator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 sm:gap-6 items-start">

      <!-- Left: Live Battery Monitor -->
      <div class="lg:col-span-7 card-base flex flex-col gap-3.5 sm:gap-5 p-3.5 sm:p-6">

        <!-- Live Status Bar -->
        <div class="flex flex-row flex-wrap items-center justify-between gap-2 pb-2.5 sm:pb-3 border-b border-hairline-soft">
          <div class="flex items-center gap-2">
            <div id="api-status-dot" class="w-2.5 h-2.5 rounded-full bg-slate animate-pulse"></div>
            <span id="api-status-label" class="text-xs font-semibold text-slate uppercase tracking-wider">Detecting battery interface…</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-stone">Source:</span>
            <span id="mode-badge" class="bg-surface-pricing-featured text-brand-blue text-[10px] font-bold py-0.5 px-2 rounded-full uppercase">Checking</span>
          </div>
        </div>

        <!-- Big Gauge -->
        <div class="flex flex-col items-center justify-center gap-4">
          <div class="relative w-40 h-40 sm:w-56 sm:h-56 flex items-center justify-center">
            <svg class="w-full h-full transform -rotate-90" viewBox="0 0 176 176">
              <circle cx="88" cy="88" r="76" stroke="#e0e2e8" stroke-width="12" fill="none"></circle>
              <circle id="gauge-level-ring" cx="88" cy="88" r="76" stroke="#4262ff" stroke-dasharray="477.5" stroke-dashoffset="477.5" stroke-linecap="round" stroke-width="12" fill="none" class="transition-all duration-700 ease-out"></circle>
            </svg>
            <div class="absolute flex flex-col items-center text-center px-4">
              <span id="gauge-level-text" class="text-4xl sm:text-6xl font-display font-medium text-primary tabular-nums leading-none">--<span class="text-xl sm:text-2xl align-top">%</span></span>
              <span id="charging-status-text" class="mt-1.5 sm:mt-2 inline-flex items-center gap-1 text-[10px] sm:text-[11px] font-semibold text-slate uppercase tracking-wider">
                Reading battery…
              </span>
            </div>
          </div>

          <!-- Scan button: centered directly below the battery circle -->
          <button
            type="button"
            id="scan-btn"
            class="inline-flex items-center justify-center gap-2 bg-primary text-canvas font-semibold text-sm py-3 px-7 min-h-[46px] rounded-full hover:bg-charcoal active:scale-[0.98] transition-all cursor-pointer shadow-subtle"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
            <span>Run Health Scan</span>
          </button>
        </div>

        <!-- Live Telemetry (REAL values only) -->
        <div class="grid grid-cols-2 gap-2 sm:gap-3">
          <div class="p-2.5 sm:p-3 bg-surface rounded-lg border border-hairline-soft">
            <p class="text-[10px] font-semibold text-stone uppercase tracking-wide">State</p>
            <p id="stat-state" class="text-sm font-semibold text-primary mt-0.5">--</p>
          </div>
          <div class="p-2.5 sm:p-3 bg-surface rounded-lg border border-hairline-soft">
            <p class="text-[10px] font-semibold text-stone uppercase tracking-wide">Measured rate</p>
            <p id="stat-rate" class="text-sm font-semibold text-primary mt-0.5 tabular-nums">--</p>
          </div>
          <div class="p-2.5 sm:p-3 bg-surface rounded-lg border border-hairline-soft">
            <p class="text-[10px] font-semibold text-stone uppercase tracking-wide">Time remaining</p>
            <p id="stat-time" class="text-sm font-semibold text-primary mt-0.5 tabular-nums">--</p>
          </div>
          <div class="p-2.5 sm:p-3 bg-surface rounded-lg border border-hairline-soft">
            <p class="text-[10px] font-semibold text-stone uppercase tracking-wide">Change this session</p>
            <p id="stat-session" class="text-sm font-semibold text-primary mt-0.5 tabular-nums">--</p>
          </div>
        </div>

        <!-- Wake lock + measuring hint -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 pt-1">
          <label for="wake-lock-toggle" class="flex items-center gap-2.5 cursor-pointer select-none">
            <span class="relative inline-flex">
              <input type="checkbox" id="wake-lock-toggle" class="peer sr-only" />
              <span class="w-10 h-6 bg-hairline peer-checked:bg-brand-blue rounded-full transition-colors"></span>
              <span class="absolute left-0.5 top-0.5 w-5 h-5 bg-canvas rounded-full shadow-subtle transition-transform peer-checked:translate-x-4"></span>
            </span>
            <span class="text-xs font-semibold text-slate">Keep screen awake while monitoring</span>
          </label>
          <p id="measure-hint" class="text-[11px] text-stone leading-snug">Leave this open a few minutes for an accurate drain rate.</p>
        </div>

        <!-- Unsupported / fallback notice -->
        <div id="fallback-notice" class="hidden flex-col gap-1.5 p-3.5 rounded-xl border border-hairline bg-surface-soft">
          <p class="text-xs font-semibold text-primary flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" class="w-4 h-4 text-brand-yellow-deep">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            Live battery data isn't available in this browser
          </p>
          <p class="text-[11px] text-slate leading-relaxed">Safari, iOS browsers, and Firefox don't expose the Battery Status API. Your real level and drain rate can't be read here — but the health estimator on the right still works everywhere.</p>
        </div>
      </div>

      <!-- Right: Health Estimator + Compatibility -->
      <div class="lg:col-span-5 flex flex-col gap-3 sm:gap-6">

        <!-- Health Estimator -->
        <div id="estimator-top" class="card-base p-3.5 sm:p-6 flex flex-col gap-3.5 sm:gap-4 scroll-mt-24 transition-shadow">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-6 bg-brand-blue rounded-full"></span>
            <h2 class="text-sm font-semibold text-primary">Battery Health Estimator</h2>
          </div>
          <p class="text-[11px] text-slate leading-relaxed -mt-1">
            An <strong class="text-primary">estimate</strong>, not a hardware reading. It models lithium-ion wear from the details you provide below.
          </p>

          <div class="flex flex-col gap-4">
            <div class="flex flex-col gap-1.5">
              <div class="flex justify-between items-center">
                <label for="device-age" class="text-xs font-semibold text-slate">Device age (months)</label>
                <span id="age-val" class="text-xs font-bold text-primary tabular-nums">12</span>
              </div>
              <input type="range" id="device-age" min="1" max="72" value="12" class="w-full h-2 bg-hairline rounded-lg appearance-none cursor-pointer accent-brand-blue" />
            </div>

            <div class="flex flex-col gap-1.5">
              <div class="flex justify-between items-center">
                <label for="cycles-day" class="text-xs font-semibold text-slate">Full charge cycles per day</label>
                <span id="cycles-val" class="text-xs font-bold text-primary tabular-nums">1.0</span>
              </div>
              <input type="range" id="cycles-day" min="2" max="30" value="10" class="w-full h-2 bg-hairline rounded-lg appearance-none cursor-pointer accent-brand-blue" />
            </div>

            <div class="flex flex-col gap-1.5">
              <span class="text-xs font-semibold text-slate">Typical temperature</span>
              <div class="grid grid-cols-3 gap-2" role="radiogroup" aria-label="Typical temperature exposure">
                <button type="button" data-temp="cool" class="temp-btn min-h-[40px] text-[11px] font-semibold rounded-lg border border-hairline bg-surface text-slate transition-all">Cool</button>
                <button type="button" data-temp="warm" class="temp-btn min-h-[40px] text-[11px] font-semibold rounded-lg border border-hairline bg-surface text-slate transition-all">Warm</button>
                <button type="button" data-temp="hot" class="temp-btn min-h-[40px] text-[11px] font-semibold rounded-lg border border-hairline bg-surface text-slate transition-all">Hot</button>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label class="flex items-center justify-between gap-2 cursor-pointer select-none">
                <span class="text-xs font-semibold text-slate">Often fast-charges</span>
                <span class="relative inline-flex">
                  <input type="checkbox" id="habit-fast" class="peer sr-only" />
                  <span class="w-10 h-6 bg-hairline peer-checked:bg-brand-blue rounded-full transition-colors"></span>
                  <span class="absolute left-0.5 top-0.5 w-5 h-5 bg-canvas rounded-full shadow-subtle transition-transform peer-checked:translate-x-4"></span>
                </span>
              </label>
              <label class="flex items-center justify-between gap-2 cursor-pointer select-none">
                <span class="text-xs font-semibold text-slate">Often left plugged in at 100%</span>
                <span class="relative inline-flex">
                  <input type="checkbox" id="habit-plugged" class="peer sr-only" />
                  <span class="w-10 h-6 bg-hairline peer-checked:bg-brand-blue rounded-full transition-colors"></span>
                  <span class="absolute left-0.5 top-0.5 w-5 h-5 bg-canvas rounded-full shadow-subtle transition-transform peer-checked:translate-x-4"></span>
                </span>
              </label>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="design-capacity" class="text-xs font-semibold text-slate">Original capacity in mAh <span class="text-stone font-normal">(optional)</span></label>
              <input type="number" id="design-capacity" inputmode="numeric" min="500" max="20000" placeholder="e.g. 4500" class="w-full min-h-[44px] px-3 text-sm rounded-lg border border-hairline-strong bg-canvas text-primary focus:border-brand-blue focus:outline-none transition-colors" />
            </div>
          </div>

          <!-- Estimator Result -->
          <div id="est-result" class="mt-1 flex flex-col gap-3 p-4 rounded-xl border border-hairline bg-surface-soft scroll-mt-20">
            <div class="flex items-end justify-between">
              <div>
                <p class="text-[10px] font-semibold text-stone uppercase tracking-wide">Estimated health</p>
                <p id="est-health" class="text-3xl font-display font-medium text-primary tabular-nums leading-none mt-1">--<span class="text-lg align-top">%</span></p>
              </div>
              <span id="est-condition" class="text-[11px] font-bold py-1 px-2.5 rounded-full bg-surface-pricing-featured text-brand-blue">—</span>
            </div>
            <div class="w-full bg-hairline rounded-full h-2 overflow-hidden">
              <div id="est-bar" class="h-full w-0 rounded-full bg-brand-blue transition-all duration-500"></div>
            </div>
            <div class="grid grid-cols-2 gap-3 pt-1">
              <div>
                <p class="text-[10px] font-semibold text-stone uppercase tracking-wide">Est. cycles</p>
                <p id="est-cycles" class="text-sm font-semibold text-primary mt-0.5 tabular-nums">--</p>
              </div>
              <div>
                <p class="text-[10px] font-semibold text-stone uppercase tracking-wide">Est. capacity now</p>
                <p id="est-capacity" class="text-sm font-semibold text-primary mt-0.5 tabular-nums">--</p>
              </div>
            </div>
            <div class="flex items-center justify-between pt-1">
              <p class="text-[10px] text-stone leading-snug max-w-[70%]">Model-based approximation from published Li-ion aging data.</p>
              <button
                type="button"
                id="print-report-btn"
                class="text-[11px] font-semibold text-brand-blue hover:underline cursor-pointer flex items-center gap-1 shrink-0"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.617 0-1.11-.497-1.12-1.115L6.34 18m11.32 0h-11.32" />
                </svg>
                <span>Print</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Browser Compatibility (ACCURATE) -->
        <div class="card-base p-4 sm:p-6 bg-surface-soft flex flex-col gap-3">
          <h3 class="text-xs font-bold text-slate uppercase tracking-wider">Live-data Browser Support</h3>
          <ul class="flex flex-col gap-2 text-xs">
            <li class="flex items-center justify-between">
              <span class="text-stone">Chrome / Edge / Opera</span>
              <span class="text-success-accent font-semibold">Supported</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="text-stone">Samsung Internet</span>
              <span class="text-success-accent font-semibold">Supported</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="text-stone">Firefox</span>
              <span class="text-brand-coral font-semibold">Removed in 2017</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="text-stone">Safari / iOS (all browsers)</span>
              <span class="text-brand-coral font-semibold">Not supported</span>
            </li>
          </ul>
          <p class="text-[10px] text-stone leading-snug pt-1 border-t border-hairline-soft mt-1">Where live data is unavailable, the health estimator above still works on every browser.</p>
        </div>

        <!-- Longevity Tips -->
