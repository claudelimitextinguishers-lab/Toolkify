  <script>
    // State definitions
    interface FavoriteItem {
      id: string;
      label: string;
      freq: number;
      ref: number;
      wave: string;
    }

    let audioCtx: AudioContext | null = null;
    let oscNode: OscillatorNode | null = null;
    let gainNode: GainNode | null = null;
    let filterNode: BiquadFilterNode | null = null; // optional bandpass/lowpass

    // Two-tone comparison state
    let oscNode2: OscillatorNode | null = null;
    let gainNode2: GainNode | null = null;
    let altTimer: any = null;

    // Config parameters
    let targetFreq = 440.00;
    let currentFreq = 440.00; // for smooth interpolation
    let targetRefPitch = 440.00;
    let currentWaveform = "sine";
    let isPlaying = false;
    
    let isFineDragMode = false;
    let currentOctave = 4;
    let currentNoteIndex = 9; // A4 default

    // Strike decay parameters
    let strikeStartTime: number | null = null;
    let strikeAnimationId: number | null = null;
    const DECAY_DURATION = 5.0; // 5 seconds decay

    // Local Storage Naming Contract
    const LS_PREFIX = "toolkify:tuning-fork:";
    const KEY_FAVORITES = `${LS_PREFIX}favorites`;
    const KEY_FREQ = `${LS_PREFIX}freq`;
    const KEY_REF = `${LS_PREFIX}ref`;
    const KEY_WAVE = `${LS_PREFIX}wave`;

    const NOTES = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"];

    // DOM selectors
    const playStopBtn = document.getElementById("play-stop-btn") as HTMLButtonElement;
    const strikeForkBtn = document.getElementById("strike-fork-btn") as HTMLButtonElement;
    const playIcon = document.getElementById("play-icon") as unknown as SVGElement;
    const stopIcon = document.getElementById("stop-icon") as unknown as SVGElement;
    const playBtnText = document.getElementById("play-btn-text") as HTMLSpanElement;

    const waveformSelect = document.getElementById("waveform-select") as HTMLSelectElement;
    const freqInput = document.getElementById("freq-input") as HTMLInputElement;
    const freqSlider = document.getElementById("freq-slider") as HTMLInputElement;
    const freqDecBtn = document.getElementById("freq-dec-btn") as HTMLButtonElement;
    const freqIncBtn = document.getElementById("freq-inc-btn") as HTMLButtonElement;
    const toggleFineDrag = document.getElementById("toggle-fine-drag") as HTMLButtonElement;

    const refPitchSlider = document.getElementById("ref-pitch-slider") as HTMLInputElement;
    const refPitchVal = document.getElementById("ref-pitch-val") as HTMLSpanElement;
    const refPitchDisplay = document.getElementById("ref-pitch-display") as HTMLSpanElement;
    const resetRefBtn = document.getElementById("reset-ref-btn") as HTMLButtonElement;

    const octaveSelect = document.getElementById("octave-select") as HTMLSelectElement;
    const noteSelectorContainer = document.getElementById("note-selector-container") as HTMLDivElement;

    // Visualization elements
    const gaugeNeedle = document.getElementById("gauge-needle") as HTMLDivElement;
    const gaugeProgressArc = document.getElementById("gauge-progress-arc") as unknown as SVGPathElement;
    const freqReadout = document.getElementById("freq-readout") as HTMLSpanElement;
    const noteNameReadout = document.getElementById("note-name-readout") as HTMLSpanElement;
    const needleCenteredNote = document.getElementById("needle-centered-note") as HTMLSpanElement;
    const levelBar = document.getElementById("level-bar") as HTMLDivElement;
    const levelPercentage = document.getElementById("level-percentage") as HTMLSpanElement;
    const statusLight = document.getElementById("status-light") as HTMLSpanElement;
    const statusText = document.getElementById("status-text") as HTMLSpanElement;
    const rippleOverlay = document.getElementById("ripple-overlay") as HTMLDivElement;
    const tuningForkSvg = document.getElementById("tuning-fork-svg") as unknown as HTMLDivElement;
    const forkRipples = document.querySelectorAll(".fork-ripple");

    // Modals
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");
    const shortcutsBtn = document.getElementById("shortcuts-btn");
    const shortcutsModal = document.getElementById("shortcuts-modal") as HTMLDivElement;
    const closeShortcutsBtn = document.getElementById("close-shortcuts-btn");
    const toastMessage = document.getElementById("toast-message") as HTMLDivElement;
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;

    // Favorites
    const favoriteLabel = document.getElementById("favorite-label") as HTMLInputElement;
    const saveFavoriteBtn = document.getElementById("save-favorite-btn") as HTMLButtonElement;
    const favoritesContainer = document.getElementById("favorites-container") as HTMLDivElement;

    // Two-Tone DOM selectors
    const compareToneEnable = document.getElementById("compare-tone-enable") as HTMLInputElement;
    const compareTonePanel = document.getElementById("compare-tone-panel") as HTMLDivElement;
    const compareFreqInput = document.getElementById("compare-freq-input") as HTMLInputElement;
    const compareIntervalSelect = document.getElementById("compare-interval-select") as HTMLSelectElement;
    const compareModeRadios = document.getElementsByName("compare-mode") as NodeListOf<HTMLInputElement>;

    // Initial load
    function init() {
      // 1. Recover values from localStorage
      const savedFreq = localStorage.getItem(KEY_FREQ);
      const savedRef = localStorage.getItem(KEY_REF);
      const savedWave = localStorage.getItem(KEY_WAVE);

      if (savedFreq) {
        targetFreq = parseFloat(savedFreq);
        currentFreq = targetFreq;
        freqInput.value = targetFreq.toFixed(2);
      }
      if (savedRef) {
        targetRefPitch = parseFloat(savedRef);
        refPitchSlider.value = String(targetRefPitch);
        refPitchVal.textContent = `${targetRefPitch} Hz`;
        refPitchDisplay.textContent = `${targetRefRefined(targetRefPitch)} Hz`;
      }
      if (savedWave) {
        currentWaveform = savedWave;
        waveformSelect.value = savedWave;
      }

      // 2. Load from URL search parameters if available
      const urlParams = new URLSearchParams(window.location.search);
      const urlFreq = urlParams.get("freq");
      const urlRef = urlParams.get("ref");
      const urlWave = urlParams.get("wave");

      if (urlFreq) {
        targetFreq = parseFloat(urlFreq);
        currentFreq = targetFreq;
        freqInput.value = targetFreq.toFixed(2);
      }
      if (urlRef) {
        targetRefPitch = parseFloat(urlRef);
        refPitchSlider.value = String(targetRefPitch);
        refPitchVal.textContent = `${targetRefPitch} Hz`;
        refPitchDisplay.textContent = `${targetRefRefined(targetRefPitch)} Hz`;
      }
      if (urlWave) {
        currentWaveform = urlWave;
        waveformSelect.value = urlWave;
      }

      updateSliderBoundaries();
      renderNoteButtons();
      updateGauge(true);
      updateFavoritesList();
      refPitchDisplay.textContent = `${targetRefRefined(targetRefPitch)} Hz`;
    }

    function targetRefRefined(v: number): string {
      return v % 1 === 0 ? String(v) : v.toFixed(1);
    }

    // Mathematical calculations
    function calculateFreqFromNote(noteIndex: number, octave: number, refA4: number): number {
      // Index of A is 9. A4 is standard octave 4
      const d = (octave - 4) * 12 + (noteIndex - 9);
      return refA4 * Math.pow(2, d / 12);
    }

    // A440 Reference note to Hz
    function getNoteFromFrequency(freq: number, refA4: number): { noteIndex: number; octave: number; centDeviation: number } {
      const semitones = 12 * Math.log2(freq / refA4);
      const roundedSemitones = Math.round(semitones);
      const centDeviation = (semitones - roundedSemitones) * 100;

      // Note index & octave
      let noteIndex = (9 + roundedSemitones) % 12;
      if (noteIndex < 0) noteIndex += 12;

      const octave = 4 + Math.floor((9 + roundedSemitones) / 12);

      return { noteIndex, octave, centDeviation };
    }

    // Audio Engine initialization
    function initAudio() {
      if (audioCtx) return;
      
      const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;
      audioCtx = new AudioCtxClass();
      
      gainNode = audioCtx.createGain();
      gainNode.gain.setValueAtTime(0, audioCtx.currentTime);
      gainNode.connect(audioCtx.destination);

      statusLight.className = "w-2.5 h-2.5 rounded-full bg-success-accent";
      statusText.textContent = "Audio System Active";
    }

    // Click-free start / stop envelope
    function playTone() {
      initAudio();
      if (!audioCtx) return;

      if (audioCtx.state === "suspended") {
        audioCtx.resume();
      }

      // Stop existing if any
      stopToneEngine();

      if (strikeAnimationId) {
        cancelAnimationFrame(strikeAnimationId);
        strikeAnimationId = null;
      }
      strikeStartTime = null;
      tuningForkSvg.style.setProperty('--vibe-intensity', '1');

      const time = audioCtx.currentTime;

      // Main Oscillator
      oscNode = audioCtx.createOscillator();
      oscNode.type = currentWaveform as OscillatorType;
      oscNode.frequency.setValueAtTime(targetFreq, time);
      oscNode.connect(gainNode!);

      // Envelope Start
      gainNode!.gain.cancelScheduledValues(time);
      gainNode!.gain.setValueAtTime(0, time);
      
      // Short click-free linear attack
      const attackTime = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 0.005 : 0.02;
      const targetVolume = currentWaveform === "square" ? 0.08 : currentWaveform === "triangle" ? 0.18 : 0.15; // lower square to prevent ear fatigue
      
      gainNode!.gain.linearRampToValueAtTime(targetVolume, time + attackTime);
      oscNode.start(time);

      // Two-Tone Comparison Tone
      if (compareToneEnable.checked) {
        startSecondaryTone(time);
      }

      isPlaying = true;
      playStopBtn.classList.remove("bg-primary", "hover:bg-charcoal");
      playStopBtn.classList.add("bg-brand-coral", "hover:bg-coral-dark");
      playBtnText.textContent = "Stop Tone";
      playIcon.classList.add("hidden");
      stopIcon.classList.remove("hidden");

      // Animated tuning fork triggers
      tuningForkSvg?.classList.add("vibrating");
      forkRipples.forEach(r => r.classList.add("rippling"));

      // Trigger structural ringing animation (CSS ripple)
      triggerRingingVisual();
      animateVisualLevel(targetVolume);
    }

    function strikeTone() {
      initAudio();
      if (!audioCtx) return;

      if (audioCtx.state === "suspended") {
        audioCtx.resume();
      }

      // Stop existing
      stopToneEngine();
      if (strikeAnimationId) {
        cancelAnimationFrame(strikeAnimationId);
        strikeAnimationId = null;
      }

      const time = audioCtx.currentTime;
      strikeStartTime = time;

      // Main Oscillator
      oscNode = audioCtx.createOscillator();
      oscNode.type = currentWaveform as OscillatorType;
      oscNode.frequency.setValueAtTime(targetFreq, time);
      oscNode.connect(gainNode!);

      // Envelope Start - Strike
      gainNode!.gain.cancelScheduledValues(time);
      gainNode!.gain.setValueAtTime(0, time);
      
      // Near-instant attack to simulate mechanical strike
      gainNode!.gain.linearRampToValueAtTime(0.25, time + 0.004);
      // Exponential decay
      gainNode!.gain.exponentialRampToValueAtTime(0.0001, time + DECAY_DURATION);
      
      oscNode.start(time);
      isPlaying = true;

      // Two-Tone Comparison Tone in Strike mode (plays simultaneously if enabled)
      if (compareToneEnable.checked) {
        const secondaryFreq = parseFloat(compareFreqInput.value);
        gainNode2 = audioCtx.createGain();
        gainNode2.gain.setValueAtTime(0, time);
        gainNode2.connect(audioCtx.destination);
        
        oscNode2 = audioCtx.createOscillator();
        oscNode2.type = currentWaveform as OscillatorType;
        oscNode2.frequency.setValueAtTime(secondaryFreq, time);
        oscNode2.connect(gainNode2);

        gainNode2.gain.linearRampToValueAtTime(0.25, time + 0.004);
        gainNode2.gain.exponentialRampToValueAtTime(0.0001, time + DECAY_DURATION);
        
        oscNode2.start(time);
      }

      // Toggle UI State
      playStopBtn.classList.remove("bg-primary", "hover:bg-charcoal");
      playStopBtn.classList.add("bg-brand-coral", "hover:bg-coral-dark");
      playBtnText.textContent = "Stop Tone";
      playIcon.classList.add("hidden");
      stopIcon.classList.remove("hidden");

      tuningForkSvg?.classList.add("vibrating");
      forkRipples.forEach(r => r.classList.add("rippling"));
      triggerRingingVisual();

      // Decay loop
      function updateStrikeDecay() {
        if (!isPlaying || !strikeStartTime || !audioCtx) {
          tuningForkSvg.style.setProperty('--vibe-intensity', '0');
          return;
        }
        const elapsed = audioCtx.currentTime - strikeStartTime;
        const progress = Math.max(0, 1 - (elapsed / DECAY_DURATION));
        
        if (progress > 0) {
          tuningForkSvg.style.setProperty('--vibe-intensity', String(progress));
          
          // Update Level Meter
          levelBar.style.width = `${progress * 100}%`;
          levelPercentage.textContent = `${Math.round(progress * 100)}%`;
          
          strikeAnimationId = requestAnimationFrame(updateStrikeDecay);
        } else {
          stopTone();
        }
      }
      updateStrikeDecay();
    }

    function stopTone() {
      if (!audioCtx || !isPlaying) return;

      const time = audioCtx.currentTime;
      const releaseTime = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 0.005 : 0.02;

      // Smooth envelope ramp down to 0
      gainNode!.gain.cancelScheduledValues(time);
      gainNode!.gain.linearRampToValueAtTime(0, time + releaseTime);

      if (gainNode2) {
        gainNode2.gain.cancelScheduledValues(time);
        gainNode2.gain.linearRampToValueAtTime(0, time + releaseTime);
      }

      // Schedule exact stop
      const oscToStop = oscNode;
      const osc2ToStop = oscNode2;

      setTimeout(() => {
        try {
          if (oscToStop) oscToStop.stop();
          if (osc2ToStop) osc2ToStop.stop();
        } catch (e) {}
      }, (releaseTime + 0.01) * 1000);

      isPlaying = false;
      strikeStartTime = null;
      if (strikeAnimationId) {
        cancelAnimationFrame(strikeAnimationId);
        strikeAnimationId = null;
      }
      tuningForkSvg.style.setProperty('--vibe-intensity', '0');

      playStopBtn.classList.add("bg-primary", "hover:bg-charcoal");
      playStopBtn.classList.remove("bg-brand-coral", "hover:bg-coral-dark");
      playBtnText.textContent = "Start Tone";
      playIcon.classList.remove("hidden");
      stopIcon.classList.add("hidden");

      // Animated tuning fork resets
      tuningForkSvg?.classList.remove("vibrating");
      forkRipples.forEach(r => r.classList.remove("rippling"));

      clearInterval(altTimer);
      animateVisualLevel(0);
    }

    function stopToneEngine() {
      try {
        if (oscNode) {
          oscNode.stop();
          oscNode = null;
        }
        if (oscNode2) {
          oscNode2.stop();
          oscNode2 = null;
        }
        clearInterval(altTimer);
      } catch (e) {}
    }

    // Secondary oscillator comparison engine
    function startSecondaryTone(time: number) {
      if (!audioCtx) return;

      const secondaryFreq = parseFloat(compareFreqInput.value);
      
      gainNode2 = audioCtx.createGain();
      gainNode2.gain.setValueAtTime(0, time);
      gainNode2.connect(audioCtx.destination);

      oscNode2 = audioCtx.createOscillator();
      oscNode2.type = currentWaveform as OscillatorType;
      oscNode2.frequency.setValueAtTime(secondaryFreq, time);
      oscNode2.connect(gainNode2);

      const attackTime = 0.02;
      const targetVolume = currentWaveform === "square" ? 0.08 : currentWaveform === "triangle" ? 0.18 : 0.15;

      const compareMode = getCheckedRadioValue("compare-mode");
      if (compareMode === "simultaneous") {
        gainNode2.gain.linearRampToValueAtTime(targetVolume, time + attackTime);
        oscNode2.start(time);
      } else {
        // Alternating A/B mode
        oscNode2.start(time);
        let currentActive = 1;
        
        gainNode!.gain.setValueAtTime(targetVolume, time);
        gainNode2.gain.setValueAtTime(0, time);

        altTimer = setInterval(() => {
          if (!audioCtx || !isPlaying) return;
          const switchTime = audioCtx.currentTime;
          if (currentActive === 1) {
            gainNode!.gain.linearRampToValueAtTime(0, switchTime + 0.02);
            gainNode2!.gain.linearRampToValueAtTime(targetVolume, switchTime + 0.02);
            currentActive = 2;
          } else {
            gainNode2!.gain.linearRampToValueAtTime(0, switchTime + 0.02);
            gainNode!.gain.linearRampToValueAtTime(targetVolume, switchTime + 0.02);
            currentActive = 1;
          }
        }, 1000);
      }
    }

    function getCheckedRadioValue(name: string): string {
      for (let i = 0; i < compareModeRadios.length; i++) {
        if (compareModeRadios[i].checked) {
          return compareModeRadios[i].value;
        }
      }
      return "simultaneous";
    }

    // Envelope visualization level meter
    function animateVisualLevel(val: number) {
      if (val === 0) {
        levelBar.style.width = "0%";
        levelPercentage.textContent = "0%";
        return;
      }
      // Simulate level fluctuations or steady state
      levelBar.style.width = "100%";
      levelPercentage.textContent = "100%";
    }

    // Ripple ringing animation
    function triggerRingingVisual() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      rippleOverlay.className = "absolute inset-0 bg-brand-blue/15 pointer-events-none transition-none";
      setTimeout(() => {
        rippleOverlay.className = "absolute inset-0 bg-brand-blue/0 pointer-events-none transition-all duration-1000 ease-out";
      }, 50);
    }

    // Dynamic needle gauge & display sweeps
    function updateGauge(immediate = false) {
      // 1. Digital text updates
      freqReadout.textContent = targetFreq.toFixed(2);
      
      const { noteIndex, octave, centDeviation } = getNoteFromFrequency(targetFreq, targetRefPitch);
      noteNameReadout.textContent = `Note: ${NOTES[noteIndex]}${octave} (${centDeviation >= 0 ? '+' : ''}${centDeviation.toFixed(1)} cents)`;
      needleCenteredNote.textContent = `${NOTES[noteIndex]}${octave}`;

      // Set needle rotation
      // Center (0 cents deviation) is rotate(0deg)
      // Range: -50 cents to +50 cents maps to -60deg to +60deg
      let rotation = centDeviation * 1.2; // 50 * 1.2 = 60 degrees max
      if (rotation > 75) rotation = 75;
      if (rotation < -75) rotation = -75;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        gaugeNeedle.style.transition = "none";
        gaugeProgressArc.style.transition = "none";
      } else if (immediate) {
        gaugeNeedle.style.transition = "none";
        gaugeProgressArc.style.transition = "none";
      } else {
        gaugeNeedle.style.transition = "transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1)";
        gaugeProgressArc.style.transition = "stroke-dashoffset 0.3s cubic-bezier(0.25, 0.8, 0.25, 1)";
      }

      gaugeNeedle.style.transform = `rotate(${rotation}deg)`;

      // Map progress arc: dasharray is 126. 0 deviation is centered (offset 63)
      const maxOffset = 126;
      const targetPercent = (centDeviation + 50) / 100; // 0 to 1
      const offset = maxOffset - (targetPercent * maxOffset);
      gaugeProgressArc.style.strokeDashoffset = String(offset);

      // Sync active notes rendering
      syncSelectedNoteStates(noteIndex, octave);

      // If audio is active, dynamically update active oscillator pitch immediately
      if (audioCtx && isPlaying && oscNode) {
        oscNode.frequency.setTargetAtTime(targetFreq, audioCtx.currentTime, 0.05);
      }
    }

    function syncSelectedNoteStates(selectedIdx: number, octave: number) {
      octaveSelect.value = String(octave);
      const buttons = noteSelectorContainer.querySelectorAll("button");
      buttons.forEach((btn, idx) => {
        if (idx === selectedIdx) {
          btn.className = "bg-primary text-canvas text-xs font-bold w-11 h-11 rounded-full cursor-pointer transition-all active:scale-95 shadow-subtle shrink-0";
        } else {
          btn.className = "bg-canvas hover:bg-surface text-slate text-xs font-bold w-11 h-11 rounded-full cursor-pointer transition-all border border-hairline shrink-0";
        }
      });
    }

    // Render notes picker
    function renderNoteButtons() {
      noteSelectorContainer.innerHTML = "";
      NOTES.forEach((note, idx) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.textContent = note;
        btn.className = "bg-canvas hover:bg-surface text-slate text-xs font-bold w-11 h-11 rounded-full cursor-pointer transition-all border border-hairline shrink-0";
        btn.addEventListener("click", () => {
          currentNoteIndex = idx;
          currentOctave = parseInt(octaveSelect.value);
          const computed = calculateFreqFromNote(idx, currentOctave, targetRefPitch);
          setFrequencyValue(computed);
        });
        noteSelectorContainer.appendChild(btn);
      });
    }

    // Frequency state handling
    function setFrequencyValue(val: number) {
      if (val < 20) val = 20;
      if (val > 5000) val = 5000;
      targetFreq = val;

      freqInput.value = targetFreq.toFixed(2);
      
      // Update slider bounds dynamically if fine mode
      if (isFineDragMode) {
        freqSlider.value = String(targetFreq);
      } else {
        if (targetFreq <= 2000) {
          freqSlider.value = String(Math.round(targetFreq));
        }
      }

      localStorage.setItem(KEY_FREQ, String(targetFreq));
      updateGauge();
    }

    function updateSliderBoundaries() {
      if (isFineDragMode) {
        // Narrow slider window: ±5Hz around target
        const minVal = Math.max(20, targetFreq - 5);
        const maxVal = Math.min(5000, targetFreq + 5);
        freqSlider.min = String(minVal);
        freqSlider.max = String(maxVal);
        freqSlider.step = "0.01";
        freqSlider.value = String(targetFreq);
        toggleFineDrag.textContent = "Switch to Coarse Slider Mode";
      } else {
        freqSlider.min = "20";
        freqSlider.max = "2000";
        freqSlider.step = "1";
        freqSlider.value = String(Math.min(2000, Math.round(targetFreq)));
        toggleFineDrag.textContent = "Switch to Fine Slider Mode";
      }
    }

    // Listeners for frequency modifiers
    freqInput.addEventListener("change", () => {
      const val = parseFloat(freqInput.value);
      if (!isNaN(val)) {
        setFrequencyValue(val);
      }
    });

    freqSlider.addEventListener("input", () => {
      setFrequencyValue(parseFloat(freqSlider.value));
    });

    freqDecBtn.addEventListener("click", () => {
      setFrequencyValue(targetFreq - 1);
    });

    freqIncBtn.addEventListener("click", () => {
      setFrequencyValue(targetFreq + 1);
    });

    toggleFineDrag.addEventListener("click", () => {
      isFineDragMode = !isFineDragMode;
      updateSliderBoundaries();
    });

    // Waveform select change
    waveformSelect.addEventListener("change", () => {
      currentWaveform = waveformSelect.value;
      localStorage.setItem(KEY_WAVE, currentWaveform);
      if (oscNode && audioCtx) {
        oscNode.type = currentWaveform as OscillatorType;
      }
    });

    // A4 Calibration controls
    refPitchSlider.addEventListener("input", () => {
      targetRefPitch = parseInt(refPitchSlider.value);
      refPitchVal.textContent = `${targetRefPitch} Hz`;
      refPitchDisplay.textContent = `${targetRefPitch} Hz`;
      localStorage.setItem(KEY_REF, String(targetRefPitch));

      // Recompute and update frequency if note locked
      const computed = calculateFreqFromNote(currentNoteIndex, currentOctave, targetRefPitch);
      setFrequencyValue(computed);
    });

    resetRefBtn.addEventListener("click", () => {
      targetRefPitch = 440;
      refPitchSlider.value = "440";
      refPitchVal.textContent = "440 Hz";
      refPitchDisplay.textContent = "440 Hz";
      localStorage.setItem(KEY_REF, "440");

      const computed = calculateFreqFromNote(currentNoteIndex, currentOctave, targetRefPitch);
      setFrequencyValue(computed);
    });

    octaveSelect.addEventListener("change", () => {
      currentOctave = parseInt(octaveSelect.value);
      const computed = calculateFreqFromNote(currentNoteIndex, currentOctave, targetRefPitch);
      setFrequencyValue(computed);
    });

    // Audio Play Action listener
    playStopBtn.addEventListener("click", () => {
      if (isPlaying) {
        stopTone();
      } else {
        playTone();
      }
    });

    strikeForkBtn.addEventListener("click", () => {
      strikeTone();
    });

    // Favorites Logic
    saveFavoriteBtn.addEventListener("click", () => {
      const label = favoriteLabel.value.trim() || `${targetFreq.toFixed(1)}Hz Pitch`;
      
      const rawFavorites = localStorage.getItem(KEY_FAVORITES);
      let favorites: FavoriteItem[] = rawFavorites ? JSON.parse(rawFavorites) : [];

      const newItem: FavoriteItem = {
        id: Math.random().toString(36).substring(2, 9),
        label: label,
        freq: targetFreq,
        ref: targetRefPitch,
        wave: currentWaveform
      };

      favorites.unshift(newItem);
      localStorage.setItem(KEY_FAVORITES, JSON.stringify(favorites));

      favoriteLabel.value = "";
      updateFavoritesList();
      showToast("✓ Saved to favorites");
    });

    function updateFavoritesList() {
      const rawFavorites = localStorage.getItem(KEY_FAVORITES);
      if (!rawFavorites) {
        favoritesContainer.innerHTML = '<p class="text-[11px] text-stone italic">No saved frequencies yet.</p>';
        return;
      }

      const favorites: FavoriteItem[] = JSON.parse(rawFavorites);
      if (favorites.length === 0) {
        favoritesContainer.innerHTML = '<p class="text-[11px] text-stone italic">No saved frequencies yet.</p>';
        return;
      }

      favoritesContainer.innerHTML = "";
      favorites.forEach(item => {
        const row = document.createElement("div");
        row.className = "flex items-center justify-between gap-2 p-1.5 border border-hairline rounded-lg bg-surface-soft hover:bg-canvas transition-all";

        const loadBtn = document.createElement("button");
        loadBtn.type = "button";
        loadBtn.className = "text-left text-[11px] font-semibold text-slate hover:text-primary cursor-pointer truncate flex-grow pr-2";
        loadBtn.innerHTML = `<span class="text-primary font-bold">${item.freq.toFixed(1)}Hz</span> - ${item.label}`;
        loadBtn.addEventListener("click", () => {
          targetRefPitch = item.ref;
          refPitchSlider.value = String(item.ref);
          refPitchVal.textContent = `${item.ref} Hz`;
          refPitchDisplay.textContent = `${targetRefRefined(item.ref)} Hz`;
          
          currentWaveform = item.wave;
          waveformSelect.value = item.wave;
          
          setFrequencyValue(item.freq);
        });

        const deleteBtn = document.createElement("button");
        deleteBtn.type = "button";
        deleteBtn.className = "text-stone hover:text-brand-coral cursor-pointer text-xs px-1.5 font-bold transition-all";
        deleteBtn.textContent = "×";
        deleteBtn.addEventListener("click", () => {
          const raw = localStorage.getItem(KEY_FAVORITES);
          if (raw) {
            let list: FavoriteItem[] = JSON.parse(raw);
            list = list.filter(f => f.id !== item.id);
            localStorage.setItem(KEY_FAVORITES, JSON.stringify(list));
            updateFavoritesList();
          }
        });

        row.appendChild(loadBtn);
        row.appendChild(deleteBtn);
        favoritesContainer.appendChild(row);
      });
    }

    // Share link as URL query param
    const shareBtn = document.getElementById("share-btn");
    const btnShareInline = document.getElementById("btn-share-inline");
    
    function handleShare() {
      const shareUrl = `${window.location.origin}${window.location.pathname}?freq=${targetFreq.toFixed(2)}&ref=${targetRefPitch}&wave=${currentWaveform}`;
      
      const shareData = {
        title: document.title || "Tuning Fork",
        url: shareUrl
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(shareUrl);
          }
        });
      } else {
        copyToClipboard(shareUrl);
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
        showToast("✓ Link copied!");
      }
    }

    shareBtn?.addEventListener("click", handleShare);
    btnShareInline?.addEventListener("click", handleShare);

    function showToast(msg: string) {
      toastMessage.textContent = msg;
      toastMessage.classList.remove("opacity-0");
      toastMessage.classList.add("opacity-100");
      setTimeout(() => {
        toastMessage.classList.remove("opacity-100");
        toastMessage.classList.add("opacity-0");
      }, 2000);
    }

    // Reset button logic (verbatim implementation)
    resetBtn.addEventListener("click", () => {
      // Contract: stop tone, reset pitch/waveform, clear localStorage
      stopTone();
      stopToneEngine();

      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      targetFreq = 440.00;
      targetRefPitch = 440.00;
      currentWaveform = "sine";

      freqInput.value = "440.00";
      freqSlider.value = "440";
      refPitchSlider.value = "440";
      refPitchVal.textContent = "440 Hz";
      refPitchDisplay.textContent = "440 Hz";
      waveformSelect.value = "sine";

      // Clear local storage keys for this tool
      localStorage.removeItem(KEY_FREQ);
      localStorage.removeItem(KEY_REF);
      localStorage.removeItem(KEY_WAVE);
      localStorage.removeItem(KEY_FAVORITES);

      updateSliderBoundaries();
      updateGauge(true);
      updateFavoritesList();
      showToast("Tuning Fork Reset complete.");
    });

    // Preset button clicks
    const presetChips = document.querySelectorAll(".preset-chip");
    presetChips.forEach(btn => {
      btn.addEventListener("click", () => {
        // Toggle highlight state on click
        presetChips.forEach(c => c.className = "preset-chip bg-canvas hover:bg-surface text-slate text-[11px] font-bold py-1.5 px-3 rounded-full cursor-pointer hover:scale-105 active:scale-95 transition-all border border-hairline shrink-0");
        btn.className = "preset-chip bg-primary text-canvas text-[11px] font-bold py-1.5 px-3 rounded-full cursor-pointer hover:scale-105 active:scale-95 transition-all shadow-subtle border border-primary shrink-0";

        const val = parseFloat(btn.getAttribute("data-freq") || "440");
        setFrequencyValue(val);
      });
    });

    // Keyboard Shortcuts Guide
    shortcutsBtn?.addEventListener("click", () => {
      shortcutsModal.classList.remove("hidden");
    });
    closeShortcutsBtn?.addEventListener("click", () => {
      shortcutsModal.classList.add("hidden");
    });
    shortcutsModal.addEventListener("click", (e) => {
      if (e.target === shortcutsModal) {
        shortcutsModal.classList.add("hidden");
      }
    });

    // How it works modal interactions
    howItWorksBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // Keyboard controls
    window.addEventListener("keydown", (e) => {
      if (document.activeElement?.tagName === "INPUT" || document.activeElement?.tagName === "SELECT") {
        return; // ignore when typing in form controls
      }

      if (e.code === "Space") {
        e.preventDefault();
        if (isPlaying) {
          stopTone();
        } else {
          playTone();
        }
      } else if (e.code === "ArrowUp") {
        e.preventDefault();
        setFrequencyValue(targetFreq + 1.0);
      } else if (e.code === "ArrowDown") {
        e.preventDefault();
        setFrequencyValue(targetFreq - 1.0);
      } else if (e.code === "ArrowLeft") {
        e.preventDefault();
        setFrequencyValue(targetFreq - 0.1);
      } else if (e.code === "ArrowRight") {
        e.preventDefault();
        setFrequencyValue(targetFreq + 0.1);
      } else if (e.code === "Escape") {
        e.preventDefault();
        // Close modals first
        if (!shortcutsModal.classList.contains("hidden")) {
          shortcutsModal.classList.add("hidden");
        } else if (!howItWorksModal.classList.contains("hidden")) {
          howItWorksModal.classList.add("hidden");
        } else {
          // Reset calibration
          targetRefPitch = 440;
          refPitchSlider.value = "440";
          refPitchVal.textContent = "440 Hz";
          refPitchDisplay.textContent = "440 Hz";
          localStorage.setItem(KEY_REF, "440");
          const computed = calculateFreqFromNote(currentNoteIndex, currentOctave, targetRefPitch);
          setFrequencyValue(computed);
        }
      }
    });

    // Mobile touch Audio Context unlock
    document.addEventListener("touchstart", () => {
      if (audioCtx && audioCtx.state === "suspended") {
        audioCtx.resume();
      }
    }, { once: true });

    // Collapsible Two Tone Transition
    compareToneEnable.addEventListener("change", () => {
      if (compareToneEnable.checked) {
        compareTonePanel.classList.remove("hidden");
        compareTonePanel.classList.add("flex");
      } else {
        compareTonePanel.classList.add("hidden");
        compareTonePanel.classList.remove("flex");
      }
      
      // Sync live audio playing if checked/unchecked
      if (isPlaying && audioCtx) {
        if (compareToneEnable.checked) {
          startSecondaryTone(audioCtx.currentTime);
        } else {
          if (oscNode2) {
            oscNode2.stop();
            oscNode2 = null;
          }
          clearInterval(altTimer);
        }
      }
    });

    compareIntervalSelect.addEventListener("change", () => {
      const val = compareIntervalSelect.value;
      let ratio = 1.0;
      switch (val) {
        case "unison": ratio = 1.0; break;
        case "minor-second": ratio = 16/15; break;
        case "major-second": ratio = 9/8; break;
        case "major-third": ratio = 5/4; break;
        case "perfect-fourth": ratio = 4/3; break;
        case "tritone": ratio = 45/32; break;
        case "perfect-fifth": ratio = 3/2; break;
        case "octave": ratio = 2.0; break;
        default: ratio = 0; break;
      }
      
      if (ratio > 0) {
        compareFreqInput.value = (targetFreq * ratio).toFixed(2);
      } else {
        compareFreqInput.value = (targetFreq + 5.0).toFixed(2); // default custom beat
      }

      if (isPlaying && audioCtx && oscNode2) {
        oscNode2.frequency.setTargetAtTime(parseFloat(compareFreqInput.value), audioCtx.currentTime, 0.05);
      }
    });
    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    init();
  </script>
</Layout>

<style>
  @keyframes vibrate {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    20% { transform: translate(-0.5px, 0.5px) rotate(-0.2deg); }
    40% { transform: translate(-0.5px, -0.5px) rotate(0.2deg); }
    60% { transform: translate(0.5px, 0.5px) rotate(-0.2deg); }
    80% { transform: translate(0.5px, -0.5px) rotate(0.2deg); }
  }
  @keyframes prong-left-vibrate {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(calc(-3.5deg * var(--vibe-intensity, 1))); }
  }
  @keyframes prong-right-vibrate {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(calc(3.5deg * var(--vibe-intensity, 1))); }
  }
  .vibrating {
    animation: vibrate 0.04s linear infinite;
    color: var(--color-brand-blue) !important;
  }
  #left-prong-group {
    transform-origin: 30px 80px;
    transform-box: fill-box;
  }
  #right-prong-group {
    transform-origin: 70px 80px;
    transform-box: fill-box;
  }
  .vibrating #left-prong-group {
    animation: prong-left-vibrate 0.03s ease-in-out infinite;
  }
  .vibrating #right-prong-group {
    animation: prong-right-vibrate 0.03s ease-in-out infinite;
  }
  @keyframes ripple {
    0% { transform: scale(0.3); opacity: 0.9; }
    100% { transform: scale(2.5); opacity: 0; }
  }
  .rippling {
    animation: ripple 0.8s cubic-bezier(0.1, 0.8, 0.3, 1) infinite;
  }
</style>
