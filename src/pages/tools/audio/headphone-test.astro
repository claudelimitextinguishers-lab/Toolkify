<script>
  // DOM Elements and State
  let audioCtx: AudioContext | null = null;
  let masterGainNode: GainNode | null = null;
  let currentOscNode: OscillatorNode | null = null;
  let currentTestType: string | null = null;
  let currentGuidedStep = 1;
  let testInterval: any = null;
  let stepTimer: any = null;
  
  // Storage Keys
  const STORAGE_PREFIX = 'boardtools:headphone-test:';
  const HISTORY_KEY = `${STORAGE_PREFIX}history`;
  const DEVICE_KEY = `${STORAGE_PREFIX}device-name`;
  const VOLUME_KEY = `${STORAGE_PREFIX}volume`;

  // Get UI components
  const initAudioBtn = document.getElementById('init-audio-btn');
  const audioGate = document.getElementById('audio-gate');
  const masterVolumeInput = document.getElementById('master-volume') as HTMLInputElement;
  const volumeReadout = document.getElementById('volume-readout');
  const volumeWarning = document.getElementById('volume-warning');
  const deviceNameInput = document.getElementById('device-name') as HTMLInputElement;
  
  const shareBtn = document.getElementById('share-btn');
  const resetBtn = document.getElementById('reset-btn');
  const howItWorksBtn = document.getElementById('how-it-works-btn');
  const howItWorksModal = document.getElementById('how-it-works-modal');
  const closeModalBtn = document.getElementById('close-modal-btn');
  const modalOkBtn = document.getElementById('modal-ok-btn');

  const modeGuidedBtn = document.getElementById('mode-guided-btn');
  const modeIndividualBtn = document.getElementById('mode-individual-btn');
  const guidedPanel = document.getElementById('guided-suite-panel');
  const individualPanel = document.getElementById('individual-diagnostics-panel');
  
  const prevStepBtn = document.getElementById('prev-step-btn') as HTMLButtonElement;
  const nextStepBtn = document.getElementById('next-step-btn') as HTMLButtonElement;
  const stepIndexText = document.getElementById('step-index-text');
  const guidedStepBadge = document.getElementById('guided-step-badge');
  const guidedStepTitle = document.getElementById('guided-step-title');
  
  const historyList = document.getElementById('history-list');
  const clearHistoryBtn = document.getElementById('clear-history-btn');

  // Step indicator references
  const stepDots = document.querySelectorAll('.step-dot');

  // How it works modal toggling
  howItWorksBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.remove('hidden');
  });
  closeModalBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  modalOkBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  howItWorksModal?.addEventListener('click', (e) => {
    if (e.target === howItWorksModal) {
      howItWorksModal.classList.add('hidden');
    }
  });

  // Safe initialize AudioContext
  function initAudio() {
    if (!audioCtx) {
      try {
        const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;
        audioCtx = new AudioCtxClass();
        
        // Explicitly set stereo destination properties to prevent browser/OS mono downmixing
        if (audioCtx.destination) {
          try {
            audioCtx.destination.channelCount = 2;
            audioCtx.destination.channelCountMode = 'explicit';
            audioCtx.destination.channelInterpretation = 'speakers';
          } catch (e) {
            console.warn("Could not explicitly set stereo destination properties", e);
          }
        }

        masterGainNode = audioCtx.createGain();
        
        // Initial volume setup
        const vol = parseFloat(masterVolumeInput.value) / 100;
        masterGainNode.gain.setValueAtTime(vol * 0.5, audioCtx.currentTime); // safety scaling factor
        
        masterGainNode.connect(audioCtx.destination);
        
        if (audioGate) {
          audioGate.classList.add('hidden');
        }
      } catch (err) {
        console.error("Failed to initialize AudioContext", err);
      }
    } else if (audioCtx.state === 'suspended') {
      audioCtx.resume().then(() => {
        if (audioGate) {
          audioGate.classList.add('hidden');
        }
      });
    }
  }

  initAudioBtn?.addEventListener('click', initAudio);

  // Volume scale styling / warnings
  masterVolumeInput?.addEventListener('input', () => {
    const vol = parseInt(masterVolumeInput.value);
    if (volumeReadout) volumeReadout.textContent = `${vol}%`;
    
    if (vol >= 75) {
      volumeWarning?.classList.remove('hidden');
    } else {
      volumeWarning?.classList.add('hidden');
    }

    if (audioCtx && masterGainNode) {
      const dbScale = vol / 100;
      // safety limit master volume at max 0.6 standard scaling
      masterGainNode.gain.linearRampToValueAtTime(dbScale * 0.6, audioCtx.currentTime + 0.05);
    }
  });
  masterVolumeInput?.addEventListener('change', () => {
    localStorage.setItem(VOLUME_KEY, masterVolumeInput.value);
  });

  // Load state from URL parameters or LocalStorage
  const urlParams = new URLSearchParams(window.location.search);
  const paramVol = urlParams.get('vol');
  const paramDevice = urlParams.get('device');

  if (paramVol) {
    masterVolumeInput.value = paramVol;
  } else {
    const savedVol = localStorage.getItem(VOLUME_KEY);
    if (savedVol) masterVolumeInput.value = savedVol;
  }

  if (paramDevice) {
    deviceNameInput.value = paramDevice;
  } else {
    const savedDevice = localStorage.getItem(DEVICE_KEY);
    if (savedDevice) deviceNameInput.value = savedDevice;
  }

  // Update volume readout
  const initialVol = parseInt(masterVolumeInput.value);
  if (volumeReadout) volumeReadout.textContent = `${initialVol}%`;
  if (initialVol >= 75) {
    volumeWarning?.classList.remove('hidden');
  } else {
    volumeWarning?.classList.add('hidden');
  }

  // Device tagging auto save
  if (deviceNameInput) {
    deviceNameInput.addEventListener('input', () => {
      localStorage.setItem(DEVICE_KEY, deviceNameInput.value);
    });
  }

  // Diagnostic history management
  function loadHistory() {
    if (!historyList) return;
    try {
      const rawHistory = localStorage.getItem(HISTORY_KEY);
      const items = rawHistory ? JSON.parse(rawHistory) : [];
      
      if (items.length === 0) {
        historyList.innerHTML = `
          <div class="p-3 bg-surface rounded-lg text-center text-stone">
            No session logs recorded yet. Complete the guided suite to save diagnostic logs.
          </div>
        `;
        return;
      }

      historyList.innerHTML = items.map((item: any) => `
        <div class="p-3 border border-hairline rounded-lg bg-surface flex flex-col gap-1">
          <div class="flex justify-between items-center">
            <span class="font-bold text-primary">${item.device || 'Generic Device'}</span>
            <span class="text-[10px] text-stone">${new Date(item.timestamp).toLocaleDateString()}</span>
          </div>
          <div class="grid grid-cols-2 gap-1 text-[10px] mt-1 text-slate">
            <div>Stereo: ${item.results.stereo ? '✅ Pass' : '❌ Fail'}</div>
            <div>Sweep: ${item.results.sweep ? '✅ Pass' : '❌ Fail'}</div>
            <div>Bass: ${item.results.bass ? '✅ Pass' : '❌ Fail'}</div>
            <div>Dynamic: ${item.results.dynamic ? '✅ Pass' : '❌ Fail'}</div>
            <div>Rattle: ${item.results.rattle ? '✅ Pass' : '❌ Fail'}</div>
            <div>Crosstalk: ${item.results.crosstalk ? '✅ Pass' : '❌ Fail'}</div>
            <div>High Freq: ${item.results.highfreq ? '✅ Pass' : '❌ Fail'}</div>
          </div>
        </div>
      `).join('');
    } catch (e) {
      console.error(e);
    }
  }

  clearHistoryBtn?.addEventListener('click', () => {
    localStorage.removeItem(HISTORY_KEY);
    loadHistory();
  });

  // Switch display panel
  modeGuidedBtn?.addEventListener('click', () => {
    modeGuidedBtn.className = "flex-1 text-center text-xs py-2 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
    modeIndividualBtn!.className = "flex-1 text-center text-xs py-2 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-primary";
    guidedPanel?.classList.remove('hidden');
    individualPanel?.classList.add('hidden');
    stopAllAudio();
  });

  modeIndividualBtn?.addEventListener('click', () => {
    modeIndividualBtn.className = "flex-1 text-center text-xs py-2 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
    modeGuidedBtn!.className = "flex-1 text-center text-xs py-2 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-primary";
    individualPanel?.classList.remove('hidden');
    guidedPanel?.classList.add('hidden');
    stopAllAudio();
  });

  // Safe Oscillator helpers
  function stopAllAudio() {
    clearInterval(testInterval);
    clearTimeout(stepTimer);
    if (currentOscNode) {
      try {
        currentOscNode.stop();
        currentOscNode.disconnect();
      } catch(e){}
      currentOscNode = null;
    }
    currentTestType = null;

    // Reset Play icons
    document.querySelectorAll('.test-play-btn').forEach(btn => {
      btn.querySelector('.play-icon')?.classList.remove('hidden');
      btn.querySelector('.stop-icon')?.classList.add('hidden');
      btn.classList.remove('bg-brand-coral', 'hover:bg-brand-coral/80');
    });

    // Reset visualizer indicators
    document.getElementById('left-channel-indicator')?.classList.remove('pulse-left');
    document.getElementById('right-channel-indicator')?.classList.remove('pulse-right');
    document.querySelector('#left-channel-indicator .indicator-light')?.classList.add('opacity-0');
    document.querySelector('#right-channel-indicator .indicator-light')?.classList.add('opacity-0');
    
    // Reset crosstalk indicators
    document.getElementById('crosstalk-left-indicator')?.classList.remove('bg-brand-blue/10', 'border-brand-blue');
    document.getElementById('crosstalk-right-indicator')?.classList.remove('bg-brand-teal/10', 'border-brand-teal');
    const ctL = document.getElementById('crosstalk-left-label');
    if (ctL) ctL.textContent = "Idle";
    const ctR = document.getElementById('crosstalk-right-label');
    if (ctR) ctR.textContent = "Idle";

    // Reset warning pulse
    document.getElementById('distortion-warn-card')?.classList.remove('warning-pulse');

    // Reset progress sweep
    const sweepProgress = document.getElementById('sweep-progress-bar');
    if (sweepProgress) sweepProgress.style.width = '0%';
    const sweepReadout = document.getElementById('sweep-frequency-readout');
    if (sweepReadout) sweepReadout.textContent = '30 Hz';
  }

  // Audio Test Implementation Engines
  function runStereoTest() {
    initAudio();
    if (!audioCtx || !masterGainNode) return;
    
    currentTestType = "stereo";
    
    // Create individual gain nodes for left/right mapping via merger to guarantee true channel separation
    const osc = audioCtx.createOscillator();
    const testGain = audioCtx.createGain();
    const leftGain = audioCtx.createGain();
    const rightGain = audioCtx.createGain();
    const merger = audioCtx.createChannelMerger(2);
    
    osc.type = "sine";
    osc.frequency.setValueAtTime(440, audioCtx.currentTime); // 440 Hz standard A tone
    
    testGain.gain.setValueAtTime(0, audioCtx.currentTime);
    leftGain.gain.setValueAtTime(0, audioCtx.currentTime);
    rightGain.gain.setValueAtTime(0, audioCtx.currentTime);
    
    osc.connect(testGain);
    testGain.connect(leftGain);
    testGain.connect(rightGain);
    
    leftGain.connect(merger, 0, 0);  // Route left gain node output to Merger channel 0 (Left)
    rightGain.connect(merger, 0, 1); // Route right gain node output to Merger channel 1 (Right)
    
    merger.connect(masterGainNode);
    
    osc.start();
    currentOscNode = osc;

    let cycle = 0; // 0 = Left, 1 = Right, 2 = Both
    
    const leftInd = document.getElementById('left-channel-indicator');
    const rightInd = document.getElementById('right-channel-indicator');
    const leftLight = document.querySelector('#left-channel-indicator .indicator-light');
    const rightLight = document.querySelector('#right-channel-indicator .indicator-light');

    function executeCycle() {
      if (currentTestType !== "stereo") return;
      
      // Stop pulse classes
      leftInd?.classList.remove('pulse-left');
      rightInd?.classList.remove('pulse-right');
      leftLight?.classList.add('opacity-0');
      rightLight?.classList.add('opacity-0');

      // Ramp down current volume
      testGain.gain.exponentialRampToValueAtTime(0.001, audioCtx!.currentTime + 0.1);
      leftGain.gain.setValueAtTime(0, audioCtx!.currentTime + 0.1);
      rightGain.gain.setValueAtTime(0, audioCtx!.currentTime + 0.1);

      stepTimer = setTimeout(() => {
        if (currentTestType !== "stereo") return;
        
        if (cycle === 0) {
          // Left
          leftGain.gain.setValueAtTime(1.0, audioCtx!.currentTime);
          rightGain.gain.setValueAtTime(0.0, audioCtx!.currentTime);
          leftInd?.classList.add('pulse-left');
          leftLight?.classList.remove('opacity-0');
        } else if (cycle === 1) {
          // Right
          leftGain.gain.setValueAtTime(0.0, audioCtx!.currentTime);
          rightGain.gain.setValueAtTime(1.0, audioCtx!.currentTime);
          rightInd?.classList.add('pulse-right');
          rightLight?.classList.remove('opacity-0');
        } else {
          // Both
          leftGain.gain.setValueAtTime(1.0, audioCtx!.currentTime);
          rightGain.gain.setValueAtTime(1.0, audioCtx!.currentTime);
          leftInd?.classList.add('pulse-left');
          rightInd?.classList.add('pulse-right');
          leftLight?.classList.remove('opacity-0');
          rightLight?.classList.remove('opacity-0');
        }

        // Ramp volume up safely
        testGain.gain.exponentialRampToValueAtTime(0.2, audioCtx!.currentTime + 0.15);
        
        cycle = (cycle + 1) % 3;
      }, 150);
    }

    executeCycle();
    testInterval = setInterval(executeCycle, 2000);
  }

  function runSweepTest() {
    initAudio();
    if (!audioCtx || !masterGainNode) return;

    currentTestType = "sweep";
    const osc = audioCtx.createOscillator();
    const testGain = audioCtx.createGain();
    
    osc.type = "sine";
    osc.frequency.setValueAtTime(30, audioCtx.currentTime);
    
    // Safety gain ramp-up
    testGain.gain.setValueAtTime(0, audioCtx.currentTime);
    testGain.gain.linearRampToValueAtTime(0.15, audioCtx.currentTime + 0.2);
    
    osc.connect(testGain);
    testGain.connect(masterGainNode);
    
    const duration = 12; // 12 seconds logarithmic frequency ramp
    const startTime = audioCtx.currentTime + 0.2;
    const endTime = startTime + duration;

    // Logarithmic frequency sweep ramp
    osc.frequency.exponentialRampToValueAtTime(18000, endTime);
    
    osc.start();
    currentOscNode = osc;

    const progressBar = document.getElementById('sweep-progress-bar');
    const readout = document.getElementById('sweep-frequency-readout');
    const startRealTime = Date.now();

    function updateSweepUI() {
      if (currentTestType !== "sweep") return;
      const elapsed = (Date.now() - startRealTime) / 1000;
      const percent = Math.min((elapsed / duration) * 100, 100);
      
      if (progressBar) progressBar.style.width = `${percent}%`;
      
      // Calculate corresponding logarithmic frequency
      const startF = 30;
      const endF = 18000;
      const currentF = Math.round(startF * Math.pow(endF / startF, Math.min(elapsed, duration) / duration));
      
      if (readout) {
        if (currentF >= 1000) {
          readout.textContent = `${(currentF / 1000).toFixed(1)} kHz`;
        } else {
          readout.textContent = `${currentF} Hz`;
        }
      }

      if (elapsed < duration) {
        requestAnimationFrame(updateSweepUI);
      } else {
        stopAllAudio();
      }
    }

    requestAnimationFrame(updateSweepUI);
  }

  let selectedBassFreq = 60;
  // Handle frequency selector clicks
  document.querySelectorAll('.bass-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      document.querySelectorAll('.bass-btn').forEach(b => b.classList.remove('bg-brand-blue', 'text-canvas', 'border-brand-blue'));
      const target = e.currentTarget as HTMLButtonElement;
      target.classList.add('bg-brand-blue', 'text-canvas', 'border-brand-blue');
      selectedBassFreq = parseInt(target.getAttribute('data-freq') || '60');
      
      // Re-trigger if playing
      if (currentTestType === "bass") {
        stopAllAudio();
        runBassTest();
      }
    });
  });

  function runBassTest() {
    initAudio();
    if (!audioCtx || !masterGainNode) return;

    currentTestType = "bass";
    const osc = audioCtx.createOscillator();
    const testGain = audioCtx.createGain();
    
    osc.type = "sine";
    osc.frequency.setValueAtTime(selectedBassFreq, audioCtx.currentTime);
    
    testGain.gain.setValueAtTime(0, audioCtx.currentTime);
    
    osc.connect(testGain);
    testGain.connect(masterGainNode);
    osc.start();
    currentOscNode = osc;

    // Pulse low bass tones (0.6s on, 0.4s off)
    let isOn = false;
    function executePulse() {
      if (currentTestType !== "bass") return;
      if (isOn) {
        testGain.gain.exponentialRampToValueAtTime(0.001, audioCtx!.currentTime + 0.1);
      } else {
        testGain.gain.exponentialRampToValueAtTime(0.25, audioCtx!.currentTime + 0.1);
      }
      isOn = !isOn;
    }

    executePulse();
    testInterval = setInterval(executePulse, 500);
  }

  function runDynamicTest() {
    initAudio();
    if (!audioCtx || !masterGainNode) return;

    currentTestType = "dynamic";
    const osc = audioCtx.createOscillator();
    const testGain = audioCtx.createGain();
    
    osc.type = "sine";
    osc.frequency.setValueAtTime(1000, audioCtx.currentTime); // 1kHz standard calibration frequency
    testGain.gain.setValueAtTime(0, audioCtx.currentTime);
    
    osc.connect(testGain);
    testGain.connect(masterGainNode);
    osc.start();
    currentOscNode = osc;

    const steps = [
      { db: 0, amp: 0.25 },
      { db: -10, amp: 0.08 },
      { db: -20, amp: 0.025 },
      { db: -30, amp: 0.008 },
      { db: -40, amp: 0.0025 }
    ];

    let currentStepIdx = 0;
    
    function playStep() {
      if (currentTestType !== "dynamic") return;
      
      // Reset visual bars
      document.querySelectorAll('.dynamic-step').forEach(el => {
        el.querySelector('.bar')?.classList.replace('h-full', 'h-0');
      });

      if (currentStepIdx >= steps.length) {
        stopAllAudio();
        return;
      }

      const step = steps[currentStepIdx];
      const activeEl = document.querySelector(`.dynamic-step[data-db="${step.db}"]`);
      activeEl?.querySelector('.bar')?.classList.replace('h-0', 'h-full');

      // Ramp step safely
      testGain.gain.exponentialRampToValueAtTime(step.amp, audioCtx!.currentTime + 0.1);
      
      currentStepIdx++;
      stepTimer = setTimeout(() => {
        testGain.gain.exponentialRampToValueAtTime(0.001, audioCtx!.currentTime + 0.1);
        stepTimer = setTimeout(playStep, 300); // silent gap
      }, 1800);
    }

    playStep();
  }

  function runRattleTest() {
    initAudio();
    if (!audioCtx || !masterGainNode) return;

    currentTestType = "rattle";
    const osc = audioCtx.createOscillator();
    const testGain = audioCtx.createGain();
    
    osc.type = "sine";
    osc.frequency.setValueAtTime(55, audioCtx.currentTime); // 55Hz sustained clean bass
    
    testGain.gain.setValueAtTime(0, audioCtx.currentTime);
    
    osc.connect(testGain);
    testGain.connect(masterGainNode);
    osc.start();
    currentOscNode = osc;

    const duration = 10; // 10 second sweep up
    const startTime = Date.now();
    
    // Ramp gain linearly up to 0.35 max test amplitude
    testGain.gain.linearRampToValueAtTime(0.35, audioCtx.currentTime + duration);

    const rampBar = document.getElementById('rattle-ramp-bar');
    const readout = document.getElementById('rattle-ramp-readout');
    const warnCard = document.getElementById('distortion-warn-card');

    function updateRampUI() {
      if (currentTestType !== "rattle") return;
      
      const elapsed = (Date.now() - startTime) / 1000;
      const percent = Math.min((elapsed / duration) * 100, 100);
      
      if (rampBar) rampBar.style.width = `${percent}%`;
      if (readout) readout.textContent = `${Math.round(percent)}% Amplitude`;

      // Visual safety pulsing cue at higher level ranges
      if (percent >= 70) {
        warnCard?.classList.add('warning-pulse');
      } else {
        warnCard?.classList.remove('warning-pulse');
      }

      if (elapsed < duration) {
        requestAnimationFrame(updateRampUI);
      } else {
        stopAllAudio();
      }
    }

    requestAnimationFrame(updateRampUI);
  }

  function runCrosstalkTest() {
    initAudio();
    if (!audioCtx || !masterGainNode) return;
    
    currentTestType = "crosstalk";
    
    const osc = audioCtx.createOscillator();
    const testGain = audioCtx.createGain();
    const leftGain = audioCtx.createGain();
    const rightGain = audioCtx.createGain();
    const merger = audioCtx.createChannelMerger(2);
    
    osc.type = "sine";
    osc.frequency.setValueAtTime(1000, audioCtx.currentTime); 
    testGain.gain.setValueAtTime(0, audioCtx.currentTime);
    leftGain.gain.setValueAtTime(0, audioCtx.currentTime);
    rightGain.gain.setValueAtTime(0, audioCtx.currentTime);
    
    osc.connect(testGain);
    testGain.connect(leftGain);
    testGain.connect(rightGain);
    
    leftGain.connect(merger, 0, 0);
    rightGain.connect(merger, 0, 1);
    
    merger.connect(masterGainNode);
    
    osc.start();
    currentOscNode = osc;

    let side = 0; // 0 = Left, 1 = Right
    
    const leftBox = document.getElementById('crosstalk-left-indicator');
    const rightBox = document.getElementById('crosstalk-right-indicator');
    const leftLabel = document.getElementById('crosstalk-left-label');
    const rightLabel = document.getElementById('crosstalk-right-label');

    function executeCrosstalkCycle() {
      if (currentTestType !== "crosstalk") return;
      
      leftBox?.classList.remove('bg-brand-blue/10', 'border-brand-blue');
      rightBox?.classList.remove('bg-brand-teal/10', 'border-brand-teal');
      if (leftLabel) leftLabel.textContent = "Silent";
      if (rightLabel) rightLabel.textContent = "Silent";

      testGain.gain.exponentialRampToValueAtTime(0.001, audioCtx!.currentTime + 0.1);
      leftGain.gain.setValueAtTime(0, audioCtx!.currentTime + 0.1);
      rightGain.gain.setValueAtTime(0, audioCtx!.currentTime + 0.1);

      stepTimer = setTimeout(() => {
        if (currentTestType !== "crosstalk") return;
        
        if (side === 0) {
          leftGain.gain.setValueAtTime(1.0, audioCtx!.currentTime);
          rightGain.gain.setValueAtTime(0.0, audioCtx!.currentTime);
          leftBox?.classList.add('bg-brand-blue/10', 'border-brand-blue');
          if (leftLabel) leftLabel.textContent = "Pulsing...";
        } else {
          leftGain.gain.setValueAtTime(0.0, audioCtx!.currentTime);
          rightGain.gain.setValueAtTime(1.0, audioCtx!.currentTime);
          rightBox?.classList.add('bg-brand-teal/10', 'border-brand-teal');
          if (rightLabel) rightLabel.textContent = "Pulsing...";
        }
        
        testGain.gain.exponentialRampToValueAtTime(0.2, audioCtx!.currentTime + 0.15);
        side = side === 0 ? 1 : 0;
      }, 150);
    }

    executeCrosstalkCycle();
    testInterval = setInterval(executeCrosstalkCycle, 1500);
  }

  let selectedHighFreq = 12000;
  document.querySelectorAll('.hifreq-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      document.querySelectorAll('.hifreq-btn').forEach(b => b.classList.remove('bg-brand-blue', 'text-canvas', 'border-brand-blue'));
      const target = e.currentTarget as HTMLButtonElement;
      target.classList.add('bg-brand-blue', 'text-canvas', 'border-brand-blue');
      selectedHighFreq = parseInt(target.getAttribute('data-freq') || '12000');
      
      if (currentTestType === "highfreq") {
        stopAllAudio();
        runHighFreqTest();
      }
    });
  });

  function runHighFreqTest() {
    initAudio();
    if (!audioCtx || !masterGainNode) return;

    currentTestType = "highfreq";
    const osc = audioCtx.createOscillator();
    const testGain = audioCtx.createGain();
    
    osc.type = "sine";
    osc.frequency.setValueAtTime(selectedHighFreq, audioCtx.currentTime);
    testGain.gain.setValueAtTime(0, audioCtx.currentTime);
    
    osc.connect(testGain);
    testGain.connect(masterGainNode);
    osc.start();
    currentOscNode = osc;

    let isOn = false;
    function executePulse() {
      if (currentTestType !== "highfreq") return;
      if (isOn) {
        testGain.gain.exponentialRampToValueAtTime(0.001, audioCtx!.currentTime + 0.05);
      } else {
        testGain.gain.exponentialRampToValueAtTime(0.15, audioCtx!.currentTime + 0.05);
      }
      isOn = !isOn;
    }

    executePulse();
    testInterval = setInterval(executePulse, 500);
  }

  // Handle generalized Test Actions
  document.querySelectorAll('.test-play-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const test = target.getAttribute('data-test') || '';
      
      const playLabel = target.querySelector('.play-icon');
      const stopLabel = target.querySelector('.stop-icon');
      
      if (currentTestType === test) {
        stopAllAudio();
        return;
      }
      
      // Stop other playing tests
      stopAllAudio();

      // Start requested test
      playLabel?.classList.add('hidden');
      stopLabel?.classList.remove('hidden');
      target.classList.add('bg-brand-coral', 'hover:bg-brand-coral/80');

      if (test === "stereo") runStereoTest();
      else if (test === "sweep") runSweepTest();
      else if (test === "bass") runBassTest();
      else if (test === "dynamic") runDynamicTest();
      else if (test === "rattle") runRattleTest();
      else if (test === "crosstalk") runCrosstalkTest();
      else if (test === "highfreq") runHighFreqTest();
    });
  });

  // Guided Mode Step Engine Navigation
  function updateGuidedStep() {
    // Hide all step panels
    document.querySelectorAll('.guided-step-content').forEach(panel => panel.classList.add('hidden'));
    
    // Show current panel
    const currentPanel = document.getElementById(`guided-step-${currentGuidedStep}`);
    if (currentPanel) currentPanel.classList.remove('hidden');

    // Update Dots
    stepDots.forEach((dot, idx) => {
      dot.classList.remove('active');
      if (idx + 1 === currentGuidedStep) {
        dot.classList.add('active');
      }
      if (idx + 1 < currentGuidedStep) {
        dot.classList.add('completed');
      } else {
        dot.classList.remove('completed');
      }
    });

    // Update Step Metadata
    if (currentGuidedStep === 8) {
      guidedStepBadge!.textContent = "Final Step";
      guidedStepTitle!.textContent = "Diagnostic Results Summary";
      nextStepBtn!.textContent = "Finish Suite";
    } else {
      guidedStepBadge!.textContent = `Test ${currentGuidedStep} of 7`;
      nextStepBtn!.textContent = "Next Step →";
      
      const titles = [
        "Stereo Balance & Channel Test",
        "Frequency Sweep & Range Diagnostic",
        "Low Bass Response Extension",
        "Dynamic Volume Range Check",
        "Driver Rattle & Buzz Analysis",
        "Stereo Crosstalk Isolation",
        "High-Frequency Treble Limit"
      ];
      guidedStepTitle!.textContent = titles[currentGuidedStep - 1] || "";
    }

    if (stepIndexText) stepIndexText.textContent = `Step ${currentGuidedStep} of 8`;
    
    // Disable back if at first step
    prevStepBtn.disabled = currentGuidedStep === 1;
    
    // Stop all playing audio on transition
    stopAllAudio();
  }

  nextStepBtn?.addEventListener('click', () => {
    if (currentGuidedStep < 8) {
      currentGuidedStep++;
      updateGuidedStep();
    } else {
      // Completed, return to step 1
      currentGuidedStep = 1;
      updateGuidedStep();
    }
  });

  prevStepBtn?.addEventListener('click', () => {
    if (currentGuidedStep > 1) {
      currentGuidedStep--;
      updateGuidedStep();
    }
  });

  // Save session to localStorage
  const saveBtn = document.getElementById('save-results-btn');
  saveBtn?.addEventListener('click', () => {
    const rawHistory = localStorage.getItem(HISTORY_KEY);
    const history = rawHistory ? JSON.parse(rawHistory) : [];
    
    const results = {
      stereo: (document.getElementById('check-stereo') as HTMLInputElement).checked,
      sweep: (document.getElementById('check-sweep') as HTMLInputElement).checked,
      bass: (document.getElementById('check-bass') as HTMLInputElement).checked,
      dynamic: (document.getElementById('check-dynamic') as HTMLInputElement).checked,
      rattle: (document.getElementById('check-distortion') as HTMLInputElement).checked,
      crosstalk: (document.getElementById('check-crosstalk') as HTMLInputElement).checked,
      highfreq: (document.getElementById('check-highfreq') as HTMLInputElement).checked
    };

    const device = deviceNameInput.value.trim() || 'Default Headphone';
    
    history.unshift({
      timestamp: Date.now(),
      device,
      results
    });
    
    // Store up to 20 tests
    localStorage.setItem(HISTORY_KEY, JSON.stringify(history.slice(0, 20)));
    loadHistory();
    
    alert(`Diagnostic session details successfully saved for: ${device}`);
  });

  // Export diagnostic report
  const exportBtn = document.getElementById('export-results-btn');
  exportBtn?.addEventListener('click', () => {
    const device = deviceNameInput.value.trim() || 'Default Headphone';
    const stereo = (document.getElementById('check-stereo') as HTMLInputElement).checked ? 'PASS' : 'FAIL';
    const sweep = (document.getElementById('check-sweep') as HTMLInputElement).checked ? 'PASS' : 'FAIL';
    const bass = (document.getElementById('check-bass') as HTMLInputElement).checked ? 'PASS' : 'FAIL';
    const dynamic = (document.getElementById('check-dynamic') as HTMLInputElement).checked ? 'PASS' : 'FAIL';
    const rattle = (document.getElementById('check-distortion') as HTMLInputElement).checked ? 'PASS' : 'FAIL';
    const crosstalk = (document.getElementById('check-crosstalk') as HTMLInputElement).checked ? 'PASS' : 'FAIL';
    const highfreq = (document.getElementById('check-highfreq') as HTMLInputElement).checked ? 'PASS' : 'FAIL';

    const text = `====================================
BOARDTOOLS AUDIO DIAGNOSTIC REPORT
Device: ${device}
Date: ${new Date().toLocaleString()}
====================================
Stereo Assignment Test:     [ ${stereo} ]
Audible Sweep Profile:      [ ${sweep} ]
Sub-bass Extension Level:   [ ${bass} ]
Dynamic Amplitude Steps:   [ ${dynamic} ]
Voice Coil Rattle check:    [ ${rattle} ]
Stereo Crosstalk Isolation: [ ${crosstalk} ]
High-Frequency Treble Limit:[ ${highfreq} ]
====================================
Generated via BoardTools Headphone Test Suite.`;

    const blob = new Blob([text], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `boardtools-audio-report-${device.toLowerCase().replace(/\s+/g, '-')}.txt`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // Share button action
  shareBtn?.addEventListener('click', () => {
    const vol = masterVolumeInput.value;
    const device = deviceNameInput.value.trim();

    const url = new URL(window.location.origin + window.location.pathname);
    url.searchParams.set('vol', vol);
    if (device) url.searchParams.set('device', device);

    const shareData = {
      title: document.title || "Headphone Test",
      url: url.toString()
    };

    if (navigator.share) {
      navigator.share(shareData).catch((err) => {
        if (err.name !== "AbortError") {
          copyToClipboard(url.toString());
        }
      });
    } else {
      copyToClipboard(url.toString());
    }

    function copyToClipboard(text: string) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
      } else {
        fallbackCopy(text);
      }
    }

    function fallbackCopy(text: string) {
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      textArea.style.opacity = "0";
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand("copy");
        showSuccess();
      } catch (err) {
        console.error(err);
      }
      document.body.removeChild(textArea);
    }

    function showSuccess() {
      if (shareBtn) {
        const span = shareBtn.querySelector("span");
        if (span) {
          const originalText = span.textContent || "Share";
          span.textContent = "Link Copied!";
          shareBtn.classList.add("text-success-accent", "border-success-accent");
          setTimeout(() => {
            span.textContent = originalText;
            shareBtn.classList.remove("text-success-accent", "border-success-accent");
          }, 2000);
        }
      }
    }
  });

  // Reset button action (stop, clear progress, clear localStorage)
  resetBtn?.addEventListener('click', () => {
    stopAllAudio();

    if (window.history.pushState) {
      const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
      window.history.pushState({path:newurl}, '', newurl);
    }
    
    // Clear localStorage
    localStorage.removeItem(HISTORY_KEY);
    localStorage.removeItem(DEVICE_KEY);
    localStorage.removeItem(VOLUME_KEY);
    
    if (deviceNameInput) deviceNameInput.value = '';
    if (masterVolumeInput) masterVolumeInput.value = '50';
    if (volumeReadout) volumeReadout.textContent = '50%';
    volumeWarning?.classList.add('hidden');
    
    // Reset guided flow
    currentGuidedStep = 1;
    updateGuidedStep();

    // Reset Checklist inputs
    document.querySelectorAll('.guided-step-content input[type="checkbox"]').forEach(chk => {
      (chk as HTMLInputElement).checked = false;
    });

    loadHistory();
  });

  // Initial Load
  loadHistory();

  // FAQ Accordion Toggle Interaction
  const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
  faqToggleButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      
      // Close other open accordions
      faqToggleButtons.forEach((otherBtn) => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute("aria-expanded", "false");
          const otherContent = otherBtn.nextElementSibling;
          if (otherContent) otherContent.classList.add("hidden");
          otherBtn.querySelector("svg")?.classList.remove("rotate-180");
        }
      });

      // Toggle current accordion
      btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
      const content = btn.nextElementSibling;
      if (content) {
        content.classList.toggle("hidden");
      }
      btn.querySelector("svg")?.classList.toggle("rotate-180");
    });
  });
</script>
