  <!-- Client logic script -->
  <script>
    // System definitions
    interface Preset {
      name: string;
      depth: number;
      volume: number;
      stereo: boolean;
    }

    // Web Audio state variables
    let audioCtx: AudioContext | null = null;
    let noiseNode: ScriptProcessorNode | null = null;
    let biquadFilter: BiquadFilterNode | null = null;
    let gainNode: GainNode | null = null;
    let analyserNode: AnalyserNode | null = null;
    let visualizerAnimationId = 0;
    let isPlaying = false;

    // Timer variables
    let timerInterval: any = null;
    let timerTotalSeconds = 0;
    let timerRemainingSeconds = 0;
    let isFadingOut = false;

    // Local Storage keys
    const KEY_VOLUME = 'toolkify:brown-noise:volume';
    const KEY_DEPTH = 'toolkify:brown-noise:depth';
    const KEY_STEREO = 'toolkify:brown-noise:stereo';
    const KEY_TIMER = 'toolkify:brown-noise:timer';
    const KEY_PRESETS = 'toolkify:brown-noise:custom-presets';

    // DOM Element hooks
    const btnPlayPause = document.getElementById('btn-play-pause') as HTMLButtonElement;
    const playIcon = document.getElementById('play-icon') as HTMLDivElement;
    const pauseIcon = document.getElementById('pause-icon') as HTMLDivElement;
    const playGlow = document.getElementById('play-glow') as HTMLDivElement;

    const volSlider = document.getElementById('vol-slider') as HTMLInputElement;
    const volDisplay = document.getElementById('vol-display') as HTMLSpanElement;

    const depthSlider = document.getElementById('depth-slider') as HTMLInputElement;
    const depthDisplay = document.getElementById('depth-display') as HTMLSpanElement;

    const stereoCheckbox = document.getElementById('stereo-checkbox') as HTMLInputElement;

    const customPresetName = document.getElementById('custom-preset-name') as HTMLInputElement;
    const btnSavePreset = document.getElementById('btn-save-preset') as HTMLButtonElement;
    const customPresetsContainer = document.getElementById('custom-presets-container') as HTMLDivElement;

    const timerCountdown = document.getElementById('timer-countdown') as HTMLSpanElement;
    const customTimerContainer = document.getElementById('custom-timer-container') as HTMLDivElement;
    const customTimerMin = document.getElementById('custom-timer-min') as HTMLInputElement;
    const btnCustomTimerSet = document.getElementById('btn-custom-timer-set') as HTMLButtonElement;
    const timerProgressContainer = document.getElementById('timer-progress-container') as HTMLDivElement;
    const timerProgressBar = document.getElementById('timer-progress-bar') as HTMLDivElement;
    const btnCancelTimer = document.getElementById('btn-cancel-timer') as HTMLButtonElement;

    const visualizerCanvas = document.getElementById('visualizer-canvas') as HTMLCanvasElement;
    const visualizerFallback = document.getElementById('visualizer-fallback') as HTMLDivElement;

    const btnShare = document.getElementById('btn-share') as HTMLButtonElement;
    const shareBtn = document.getElementById('share-btn') as HTMLButtonElement;
    const toastMsg = document.getElementById('toast-msg') as HTMLDivElement;

    const btnReset = document.getElementById('reset-btn') as HTMLButtonElement;
    const howItWorksBtn = document.getElementById('how-it-works-btn');
    const howItWorksModal = document.getElementById('how-it-works-modal');
    const closeModalBtn = document.getElementById('close-modal-btn');
    const modalOkBtn = document.getElementById('modal-ok-btn');

    // Canvas drawing context
    const canvasCtx = visualizerCanvas.getContext('2d')!;

    // Initializer
    function init() {
      // 1. Set up resize observer for high-DPI canvas
      setupCanvas();

      // 2. Load stored settings from localStorage
      const storedVol = localStorage.getItem(KEY_VOLUME);
      const storedDepth = localStorage.getItem(KEY_DEPTH);
      const storedStereo = localStorage.getItem(KEY_STEREO);
      const storedTimer = localStorage.getItem(KEY_TIMER);

      if (storedVol !== null) volSlider.value = storedVol;
      if (storedDepth !== null) depthSlider.value = storedDepth;
      if (storedStereo !== null) stereoCheckbox.checked = storedStereo === 'true';
      if (storedTimer !== null) customTimerMin.value = storedTimer;

      updateVolumeDisplay();
      updateDepthDisplay();

      // 3. Load presets
      renderCustomPresets();

      // 4. Check URL params for shared state
      const params = new URLSearchParams(window.location.search);
      const paramVol = params.get('v');
      const paramDepth = params.get('d');
      const paramStereo = params.get('s');
      const paramTimer = params.get('t');

      if (paramVol !== null) volSlider.value = paramVol;
      if (paramDepth !== null) depthSlider.value = paramDepth;
      if (paramStereo !== null) stereoCheckbox.checked = paramStereo === '1';
      if (paramTimer !== null) {
        startTimer(parseInt(paramTimer, 10));
      }

      updateVolumeDisplay();
      updateDepthDisplay();
    }

    // Setup High DPI Canvas
    function setupCanvas() {
      const dpr = window.devicePixelRatio || 1;
      const rect = visualizerCanvas.getBoundingClientRect();
      visualizerCanvas.width = rect.width * dpr;
      visualizerCanvas.height = rect.height * dpr;
      canvasCtx.scale(dpr, dpr);
    }

    window.addEventListener('resize', setupCanvas);

    // Audio volume to dB helper
    function getDbText(gain: number) {
      if (gain <= 0.001) return '-âˆž dB';
      const db = (20 * Math.log10(gain)).toFixed(1);
      return `${db} dB`;
    }

    function updateVolumeDisplay() {
      const volVal = parseFloat(volSlider.value);
      volDisplay.textContent = `${Math.round(volVal * 100)}% (${getDbText(volVal)})`;
      if (gainNode && !isFadingOut) {
        gainNode.gain.setValueAtTime(volVal, audioCtx!.currentTime);
      }
      localStorage.setItem(KEY_VOLUME, volSlider.value);
    }

    // Tone Control Filter logic: Lowpass filter mapped logarithmically
    function updateDepthDisplay() {
      const depthVal = parseFloat(depthSlider.value);
      let text = 'Balanced';
      if (depthVal < 0.3) text = 'Deep / Rumbling';
      else if (depthVal > 0.7) text = 'Lighter / Soft';
      depthDisplay.textContent = text;

      if (biquadFilter && audioCtx) {
        const minHz = 90;
        const maxHz = 5000;
        const cutoffHz = minHz * Math.pow(maxHz / minHz, depthVal);
        biquadFilter.frequency.setValueAtTime(cutoffHz, audioCtx.currentTime);
      }
      localStorage.setItem(KEY_DEPTH, depthSlider.value);
    }

    // Web Audio Engine Initializer
    function setupAudioContext() {
      if (audioCtx) return;

      const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;
      audioCtx = new AudioCtxClass();

      // ScriptProcessorNode handles custom sample creation
      noiseNode = audioCtx.createScriptProcessor(4096, 0, 2);

      // DSP Random Walk variables (integrated white noise with leak correction)
      let lastOutL = 0.0;
      let lastOutR = 0.0;

      noiseNode.onaudioprocess = (e) => {
        const outputBuffer = e.outputBuffer;
        const channelL = outputBuffer.getChannelData(0);
        const channelR = outputBuffer.getChannelData(1);

        const isStereo = stereoCheckbox.checked;

        for (let i = 0; i < outputBuffer.length; i++) {
          const whiteL = Math.random() * 2 - 1;
          
          if (isStereo) {
            // Uncorrelated random walks for left and right channels to widen stereo field
            const whiteR = Math.random() * 2 - 1;
            lastOutL = (lastOutL + (0.02 * whiteL)) / 1.02;
            lastOutR = (lastOutR + (0.02 * whiteR)) / 1.02;
            channelL[i] = lastOutL * 3.5;
            channelR[i] = lastOutR * 3.5;
          } else {
            // Identical noise in both channels (Mono)
            lastOutL = (lastOutL + (0.02 * whiteL)) / 1.02;
            channelL[i] = lastOutL * 3.5;
            channelR[i] = lastOutL * 3.5;
          }

          // Safe clipping threshold
          if (channelL[i] > 1.0) channelL[i] = 1.0;
          else if (channelL[i] < -1.0) channelL[i] = -1.0;

          if (channelR[i] > 1.0) channelR[i] = 1.0;
          else if (channelR[i] < -1.0) channelR[i] = -1.0;
        }
      };

      // Lowpass filter for tone/depth controls
      biquadFilter = audioCtx.createBiquadFilter();
      biquadFilter.type = 'lowpass';

      // Set up volume gain node
      gainNode = audioCtx.createGain();
      gainNode.gain.value = 0.0; // Start at 0 for fade-in

      // Set up analyzer node for canvas
      analyserNode = audioCtx.createAnalyser();
      analyserNode.fftSize = 256;

      // Pipeline route
      noiseNode.connect(biquadFilter);
      biquadFilter.connect(gainNode);
      gainNode.connect(analyserNode);
      analyserNode.connect(audioCtx.destination);

      updateDepthDisplay();
    }

    // Transport control: Start Noise
    function startNoise() {
      setupAudioContext();

      if (audioCtx!.state === 'suspended') {
        audioCtx!.resume();
      }

      const targetVol = parseFloat(volSlider.value);
      gainNode!.gain.cancelScheduledValues(audioCtx!.currentTime);
      gainNode!.gain.setValueAtTime(0.0, audioCtx!.currentTime);
      // Smooth 0.5s fade-in transition
      gainNode!.gain.linearRampToValueAtTime(targetVol, audioCtx!.currentTime + 0.5);

      isPlaying = true;
      togglePlayUI(true);

      // Start spectrum loop
      visualizerFallback.classList.add('hidden');
      startVisualizer();
    }

    // Transport control: Pause Noise
    function pauseNoise() {
      if (!audioCtx || !isPlaying) return;

      const currentVal = gainNode!.gain.value;
      gainNode!.gain.cancelScheduledValues(audioCtx!.currentTime);
      gainNode!.gain.setValueAtTime(currentVal, audioCtx!.currentTime);
      // Smooth 0.4s fade-out transition
      gainNode!.gain.linearRampToValueAtTime(0.0, audioCtx!.currentTime + 0.4);

      isPlaying = false;
      togglePlayUI(false);

      setTimeout(() => {
        if (!isPlaying && audioCtx) {
          audioCtx.suspend();
        }
      }, 450);
    }

    // Transport control: Fully stop noise (resets visualizer/timer)
    function stopNoise() {
      pauseNoise();
      cancelAnimationFrame(visualizerAnimationId);
      clearCanvas();
      visualizerFallback.classList.remove('hidden');
    }

    // UI State Toggles
    function togglePlayUI(playing: boolean) {
      if (playing) {
        playIcon.classList.add('hidden');
        pauseIcon.classList.remove('hidden');
        playGlow.classList.remove('opacity-0');
        playGlow.classList.add('opacity-100', 'animate-pulse');
      } else {
        playIcon.classList.remove('hidden');
        pauseIcon.classList.add('hidden');
        playGlow.classList.remove('opacity-100', 'animate-pulse');
        playGlow.classList.add('opacity-0');
      }
    }

    // Animated spectrum visualizer for brown noise (warmer, slow-moving waves)
    function startVisualizer() {
      if (!analyserNode) return;

      const bufferLength = analyserNode.frequencyBinCount;
      const dataArray = new Uint8Array(bufferLength);

      function draw() {
        if (!isPlaying) return;
        visualizerAnimationId = requestAnimationFrame(draw);

        analyserNode!.getByteFrequencyData(dataArray);

        const width = visualizerCanvas.width / (window.devicePixelRatio || 1);
        const height = visualizerCanvas.height / (window.devicePixelRatio || 1);

        canvasCtx.clearRect(0, 0, width, height);

        // Warm color gradient matching TOOLKIFY style guidelines
        const gradient = canvasCtx.createLinearGradient(0, height, 0, 0);
        gradient.addColorStop(0, '#fde0f0'); 
        gradient.addColorStop(0.5, '#ff9999'); 
        gradient.addColorStop(1, '#ffc6c6'); 

        canvasCtx.fillStyle = gradient;

        const barWidth = (width / bufferLength) * 1.5;
        let x = 0;

        for (let i = 0; i < bufferLength; i++) {
          const frequencyWeight = (bufferLength - i) / bufferLength;
          const barHeight = (dataArray[i] / 255) * height * 0.9 * frequencyWeight;

          // Render slow rounded wave-form columns
          canvasCtx.beginPath();
          canvasCtx.roundRect(x, height - barHeight, barWidth - 1.5, barHeight, 2);
          canvasCtx.fill();

          x += barWidth;
        }
      }

      draw();
    }

    function clearCanvas() {
      const width = visualizerCanvas.width / (window.devicePixelRatio || 1);
      const height = visualizerCanvas.height / (window.devicePixelRatio || 1);
      canvasCtx.clearRect(0, 0, width, height);
    }

    // Sleep Timer Engine
    function startTimer(minutes: number) {
      clearInterval(timerInterval);
      isFadingOut = false;

      timerTotalSeconds = minutes * 60;
      timerRemainingSeconds = timerTotalSeconds;

      timerCountdown.classList.remove('hidden');
      timerProgressContainer.classList.remove('hidden');
      
      updateTimerUI();

      timerInterval = setInterval(() => {
        timerRemainingSeconds--;
        updateTimerUI();

        // Start fading audio out 10 seconds before completion
        if (timerRemainingSeconds <= 10 && timerRemainingSeconds > 0 && !isFadingOut) {
          isFadingOut = true;
          if (gainNode && audioCtx) {
            gainNode.gain.cancelScheduledValues(audioCtx.currentTime);
            gainNode.gain.setValueAtTime(gainNode.gain.value, audioCtx.currentTime);
            gainNode.gain.linearRampToValueAtTime(0.0, audioCtx.currentTime + 10);
            
            // Pulse timer display to alert the user of the final fade out sequence
            timerCountdown.classList.add('text-brand-coral', 'animate-pulse');
          }
        }

        if (timerRemainingSeconds <= 0) {
          clearInterval(timerInterval);
          stopNoise();
          resetTimerUI();
        }
      }, 1000);

      localStorage.setItem(KEY_TIMER, minutes.toString());
    }

    function cancelTimer() {
      clearInterval(timerInterval);
      resetTimerUI();
      localStorage.removeItem(KEY_TIMER);

      // Restore original volume if cancelled mid-fadeout
      if (isFadingOut && gainNode && audioCtx) {
        isFadingOut = false;
        const targetVol = parseFloat(volSlider.value);
        gainNode.gain.cancelScheduledValues(audioCtx.currentTime);
        gainNode.gain.linearRampToValueAtTime(targetVol, audioCtx.currentTime + 0.5);
      }
    }

    function updateTimerUI() {
      const mins = Math.floor(timerRemainingSeconds / 60);
      const secs = timerRemainingSeconds % 60;
      timerCountdown.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;

      // Progress bar percentage
      const pct = (timerRemainingSeconds / timerTotalSeconds) * 100;
      timerProgressBar.style.width = `${pct}%`;
    }

    function resetTimerUI() {
      timerCountdown.classList.add('hidden');
      timerCountdown.classList.remove('text-brand-coral', 'animate-pulse');
      timerProgressContainer.classList.add('hidden');
      timerProgressBar.style.width = '100%';
    }

    // Saved Preset Actions
    function renderCustomPresets() {
      const raw = localStorage.getItem(KEY_PRESETS);
      let list: Preset[] = [];
      try {
        list = JSON.parse(raw || '[]');
      } catch (e) {}

      customPresetsContainer.innerHTML = '';
      if (list.length === 0) {
        customPresetsContainer.innerHTML = '<span class="text-[11px] text-stone">No custom presets saved. Customize sliders and save above.</span>';
        return;
      }

      list.forEach((preset, index) => {
        const item = document.createElement('div');
        item.className = 'inline-flex items-center gap-1.5 p-1 px-2.5 bg-canvas border border-hairline rounded-full text-xs font-semibold text-charcoal hover:bg-surface-soft shadow-subtle';
        
        const loadBtn = document.createElement('button');
        loadBtn.type = 'button';
        loadBtn.className = 'cursor-pointer hover:text-brand-blue';
        loadBtn.textContent = preset.name;
        loadBtn.addEventListener('click', () => {
          volSlider.value = preset.volume.toString();
          depthSlider.value = preset.depth.toString();
          stereoCheckbox.checked = preset.stereo !== false;
          localStorage.setItem(KEY_STEREO, stereoCheckbox.checked.toString());
          updateVolumeDisplay();
          updateDepthDisplay();
          if (isPlaying) {
            startNoise();
          }
        });

        const deleteBtn = document.createElement('button');
        deleteBtn.type = 'button';
        deleteBtn.className = 'text-stone hover:text-brand-coral font-bold cursor-pointer ml-1';
        deleteBtn.textContent = 'Ã—';
        deleteBtn.title = 'Delete Preset';
        deleteBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          deleteCustomPreset(index);
        });

        item.appendChild(loadBtn);
        item.appendChild(deleteBtn);
        customPresetsContainer.appendChild(item);
      });
    }

    function saveCustomPreset() {
      const name = customPresetName.value.trim();
      if (!name) return;

      const raw = localStorage.getItem(KEY_PRESETS);
      let list: Preset[] = [];
      try {
        list = JSON.parse(raw || '[]');
      } catch (e) {}

      list.push({
        name: name,
        volume: parseFloat(volSlider.value),
        depth: parseFloat(depthSlider.value),
        stereo: stereoCheckbox.checked
      });

      localStorage.setItem(KEY_PRESETS, JSON.stringify(list));
      customPresetName.value = '';
      renderCustomPresets();
    }

    function deleteCustomPreset(index: number) {
      const raw = localStorage.getItem(KEY_PRESETS);
      let list: Preset[] = [];
      try {
        list = JSON.parse(raw || '[]');
      } catch (e) {}

      list.splice(index, 1);
      localStorage.setItem(KEY_PRESETS, JSON.stringify(list));
      renderCustomPresets();
    }

    // Event Bindings
    btnPlayPause.addEventListener('click', () => {
      if (isPlaying) {
        pauseNoise();
      } else {
        startNoise();
      }
    });

    volSlider.addEventListener('input', updateVolumeDisplay);
    depthSlider.addEventListener('input', updateDepthDisplay);
    stereoCheckbox.addEventListener('change', () => {
      localStorage.setItem(KEY_STEREO, stereoCheckbox.checked.toString());
      if (isPlaying) {
        startNoise();
      }
    });

    // Preset button bindings
    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const depth = target.getAttribute('data-depth');
        const vol = target.getAttribute('data-vol');
        if (depth !== null) depthSlider.value = depth;
        if (vol !== null) volSlider.value = vol;

        updateVolumeDisplay();
        updateDepthDisplay();

        if (isPlaying) {
          startNoise();
        }
      });
    });

    // Timer Preset Bindings
    document.querySelectorAll('.timer-preset-btn').forEach(btn => {
      if (btn.id === 'timer-custom-btn') return;
      btn.addEventListener('click', (e) => {
        const min = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-minutes')!, 10);
        startTimer(min);
        customTimerContainer.classList.add('hidden');
      });
    });

    // Custom Timer Toggle
    const customTimerBtn = document.getElementById('timer-custom-btn')!;
    customTimerBtn.addEventListener('click', () => {
      customTimerContainer.classList.toggle('hidden');
    });

    btnCustomTimerSet.addEventListener('click', () => {
      const minutes = parseInt(customTimerMin.value, 10);
      if (minutes > 0) {
        startTimer(minutes);
        customTimerContainer.classList.add('hidden');
        customTimerMin.value = '';
      }
    });

    btnCancelTimer.addEventListener('click', cancelTimer);
    btnSavePreset.addEventListener('click', saveCustomPreset);

    // Share link generation
    function handleShare() {
      const vol = volSlider.value;
      const depth = depthSlider.value;
      const stereo = stereoCheckbox.checked ? '1' : '0';
      const timer = timerCountdown.classList.contains('hidden') ? '' : Math.round(timerRemainingSeconds / 60).toString();

      let url = `${window.location.origin}${window.location.pathname}?v=${vol}&d=${depth}&s=${stereo}`;
      if (timer) url += `&t=${timer}`;

      const shareData = {
        title: document.title || "Brown Noise Generator",
        url: url
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url);
          }
        });
      } else {
        copyToClipboard(url);
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
        if (toastMsg) {
          toastMsg.classList.add('opacity-100');
          setTimeout(() => {
            toastMsg.classList.remove('opacity-100');
          }, 2000);
        }
      }
    }

    btnShare?.addEventListener('click', handleShare);
    shareBtn?.addEventListener('click', handleShare);

    // Keyboard Shortcuts
    window.addEventListener('keydown', (e) => {
      if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') {
        return;
      }

      if (e.code === 'Space') {
        e.preventDefault();
        btnPlayPause.click();
      } else if (e.code === 'ArrowUp') {
        e.preventDefault();
        const nextVol = Math.min(1, parseFloat(volSlider.value) + 0.05);
        volSlider.value = nextVol.toFixed(2);
        updateVolumeDisplay();
      } else if (e.code === 'ArrowDown') {
        e.preventDefault();
        const nextVol = Math.max(0, parseFloat(volSlider.value) - 0.05);
        volSlider.value = nextVol.toFixed(2);
        updateVolumeDisplay();
      }
    });

    // Reset button logic: stops audio, resets controls, clears localstorage keys, resets visualizer
    btnReset.addEventListener('click', () => {
      stopNoise();

      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      volSlider.value = '0.6';
      depthSlider.value = '0.5';
      stereoCheckbox.checked = true;
      cancelTimer();

      updateVolumeDisplay();
      updateDepthDisplay();

      localStorage.removeItem(KEY_VOLUME);
      localStorage.removeItem(KEY_DEPTH);
      localStorage.removeItem(KEY_STEREO);
      localStorage.removeItem(KEY_TIMER);
      localStorage.removeItem(KEY_PRESETS);

      renderCustomPresets();
    });

    // How it works Modal controls
    howItWorksBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Start everything
    init();
  </script>
</Layout>
