  <script>
    // State definitions
    let audioCtx: AudioContext | null = null;
    let masterGain: GainNode | null = null;
    let audioEngineVersion = 0;
    let sourceNode: OscillatorNode | AudioBufferSourceNode | null = null;
    let leftGain: GainNode | null = null;
    let rightGain: GainNode | null = null;
    let splitter: ChannelSplitterNode | null = null;
    let merger: ChannelMergerNode | null = null;
    
    let isPlaying = false;
    let currentSignal = "sine"; // "sine" or "pink-noise"
    let currentFrequency = 60; // range 30-120
    let currentVolume = 50; // range 0-100
    let isOutofPhase = false; // false = In-phase (1), true = Out-of-phase (-1)
    let currentPhaseAngle = 0; // range 0-360
    let currentIsolation = "both"; // "both", "left", "right"
    
    // Waveform Animation State
    let animId: number | null = null;
    let animTime = 0;

    // DOM Elements
    const toggleInPhase = document.getElementById("toggle-in-phase") as HTMLButtonElement;
    const toggleOutPhase = document.getElementById("toggle-out-phase") as HTMLButtonElement;
    const playToggleBtn = document.getElementById("btn-play-toggle") as HTMLButtonElement;
    const playBtnIcon = document.getElementById("play-btn-icon") as HTMLSpanElement;
    const playBtnText = document.getElementById("play-btn-text") as HTMLSpanElement;
    const freqSlider = document.getElementById("frequency-slider") as HTMLInputElement;
    const freqDisplay = document.getElementById("freq-display") as HTMLSpanElement;
    const volumeSlider = document.getElementById("volume-slider") as HTMLInputElement;
    const volumeDisplay = document.getElementById("volume-display") as HTMLSpanElement;
    const signalSelect = document.getElementById("signal-select") as HTMLSelectElement;
    const saveFreqBtn = document.getElementById("btn-save-freq") as HTMLButtonElement;
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const shareBtn = document.getElementById("share-btn") as HTMLButtonElement;
    const freqChips = document.querySelectorAll(".freq-chip");
    const rightPhaseVal = document.getElementById("right-phase-val") as HTMLSpanElement;
    const phaseDiffIndicator = document.getElementById("phase-diff-indicator") as HTMLSpanElement;
    const freqSliderGroup = document.getElementById("freq-slider-group") as HTMLDivElement;
    const frequencyChipsContainer = document.getElementById("frequency-chips-container") as HTMLDivElement;
    const leftWavePath = document.getElementById("left-wave-path") as unknown as SVGPathElement;
    const rightWavePath = document.getElementById("right-wave-path") as unknown as SVGPathElement;

    // Phase Angle & Isolation Selectors
    const phaseAngleSlider = document.getElementById("phase-angle-slider") as HTMLInputElement;
    const phaseAngleDisplay = document.getElementById("phase-angle-display") as HTMLSpanElement;
    const isolateBoth = document.getElementById("isolate-both") as HTMLButtonElement;
    const isolateLeft = document.getElementById("isolate-left") as HTMLButtonElement;
    const isolateRight = document.getElementById("isolate-right") as HTMLButtonElement;

    // How it works modal
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    // Guided diagnostic steps DOM elements
    const step1El = document.getElementById("step-1");
    const step2El = document.getElementById("step-2");
    const step3El = document.getElementById("step-3");

    // Initialize Page Settings
    function init() {
      // 1. Restore from localStorage if present
      const savedFreq = localStorage.getItem("boardtools:speaker-phase:frequency");
      if (savedFreq) {
        currentFrequency = parseInt(savedFreq, 10);
        freqSlider.value = savedFreq;
        freqDisplay.textContent = `${savedFreq} Hz`;
        updateSelectedChip(currentFrequency);
      }

      const savedVol = localStorage.getItem("boardtools:speaker-phase:volume");
      if (savedVol) {
        currentVolume = parseInt(savedVol, 10);
        volumeSlider.value = savedVol;
        volumeDisplay.textContent = `${savedVol}%`;
      }

      const savedSignal = localStorage.getItem("boardtools:speaker-phase:signal-type");
      if (savedSignal) {
        currentSignal = savedSignal;
        signalSelect.value = savedSignal;
        toggleSignalLayout(savedSignal);
      }

      const savedPhase = localStorage.getItem("boardtools:speaker-phase:phase");
      if (savedPhase === "out-of-phase") {
        setPhaseMode(true);
      } else {
        setPhaseMode(false);
      }

      // 2. Parse URL parameters for direct config share
      const params = new URLSearchParams(window.location.search);
      const urlFreq = params.get("freq");
      if (urlFreq) {
        const parsedF = parseInt(urlFreq, 10);
        if (parsedF >= 30 && parsedF <= 120) {
          currentFrequency = parsedF;
          freqSlider.value = urlFreq;
          freqDisplay.textContent = `${urlFreq} Hz`;
          updateSelectedChip(currentFrequency);
        }
      }

      const urlPhase = params.get("phase");
      if (urlPhase === "out") {
        setPhaseMode(true);
      } else if (urlPhase === "in") {
        setPhaseMode(false);
      }

      const urlAngle = params.get("angle");
      if (urlAngle) {
        const parsedA = parseInt(urlAngle, 10);
        if (parsedA >= 0 && parsedA <= 360) {
          setPhaseAngle(parsedA);
        }
      }

      const urlIsolate = params.get("isolate");
      if (urlIsolate === "left" || urlIsolate === "right" || urlIsolate === "both") {
        setIsolation(urlIsolate as "left" | "right" | "both");
      }

      const urlSignal = params.get("signal");
      if (urlSignal === "noise") {
        currentSignal = "pink-noise";
        signalSelect.value = "pink-noise";
        toggleSignalLayout("pink-noise");
      } else if (urlSignal === "sine") {
        currentSignal = "sine";
        signalSelect.value = "sine";
        toggleSignalLayout("sine");
      }

      // Start the SVG Waveform loop
      startWaveformAnimation();
    }

    // Toggle slider panel depending on Sine Wave vs Pink Noise
    function toggleSignalLayout(signal: string) {
      if (signal === "pink-noise") {
        freqSliderGroup.style.opacity = "0.4";
        freqSlider.disabled = true;
        frequencyChipsContainer.style.opacity = "0.4";
        freqChips.forEach(chip => (chip as HTMLButtonElement).disabled = true);
      } else {
        freqSliderGroup.style.opacity = "1";
        freqSlider.disabled = false;
        frequencyChipsContainer.style.opacity = "1";
        freqChips.forEach(chip => (chip as HTMLButtonElement).disabled = false);
      }
    }

    // Generate Pink Noise Buffer (Correlated Mono Copied to Left & Right)
    function createPinkNoiseBuffer(ctx: AudioContext): AudioBuffer {
      const bufferSize = 2 * ctx.sampleRate;
      const noiseBuffer = ctx.createBuffer(2, bufferSize, ctx.sampleRate);
      const leftOut = noiseBuffer.getChannelData(0);
      const rightOut = noiseBuffer.getChannelData(1);

      let b0 = 0, b1 = 0, b2 = 0, b3 = 0, b4 = 0, b5 = 0, b6 = 0;
      
      for (let i = 0; i < bufferSize; i++) {
        const white = Math.random() * 2 - 1;
        b0 = 0.99886 * b0 + white * 0.0555179;
        b1 = 0.99332 * b1 + white * 0.0750759;
        b2 = 0.96900 * b2 + white * 0.1538520;
        b3 = 0.86650 * b3 + white * 0.3104856;
        b4 = 0.55000 * b4 + white * 0.5329522;
        b5 = -0.7616 * b5 - white * 0.0168980;
        const pink = b0 + b1 + b2 + b3 + b4 + b5 + b6 + white * 0.5362;
        b6 = white * 0.115926;
        
        const signalVal = pink * 0.12; // Level adjustment
        // We write the identical signal to both channels so it cancels perfectly in anti-phase
        leftOut[i] = signalVal;
        rightOut[i] = signalVal;
      }

      return noiseBuffer;
    }

    // Start Audio Engine
    let delayNode: DelayNode | null = null;

    function startAudioEngine() {
      audioEngineVersion++;
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      }

      // Resume context if suspended (browser security blocks auto-start)
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }

      // Re-create nodes
      masterGain = audioCtx.createGain();
      leftGain = audioCtx.createGain();
      rightGain = audioCtx.createGain();
      delayNode = audioCtx.createDelay(1.0);
      splitter = audioCtx.createChannelSplitter(2);
      merger = audioCtx.createChannelMerger(2);

      // Volume scaling
      const targetGain = currentVolume / 100;
      masterGain.gain.setValueAtTime(0, audioCtx.currentTime);

      // Configure Left & Right paths
      const leftGainVal = (currentIsolation === "both" || currentIsolation === "left") ? 1.0 : 0.0;
      const rightGainVal = (currentIsolation === "both" || currentIsolation === "right") ? 1.0 : 0.0;

      leftGain.gain.setValueAtTime(leftGainVal, audioCtx.currentTime);
      
      // Basic 180 polarity toggle
      const polarityMultiplier = isOutofPhase ? -1.0 : 1.0;
      rightGain.gain.setValueAtTime(rightGainVal * polarityMultiplier, audioCtx.currentTime);

      // Fine tuning phase shift (in seconds)
      const delaySeconds = currentPhaseAngle / (360.0 * currentFrequency);
      delayNode.delayTime.setValueAtTime(delaySeconds, audioCtx.currentTime);

      // Connect Signal Source
      if (currentSignal === "sine") {
        const osc = audioCtx.createOscillator();
        osc.type = "sine";
        osc.frequency.setValueAtTime(currentFrequency, audioCtx.currentTime);
        sourceNode = osc;
        
        // Connect osc directly to splitter
        sourceNode.connect(splitter!);
      } else {
        const noiseSource = audioCtx.createBufferSource();
        noiseSource.buffer = createPinkNoiseBuffer(audioCtx);
        noiseSource.loop = true;
        sourceNode = noiseSource;
        
        // Connect noiseSource to splitter
        sourceNode.connect(splitter!);
      }

      // Connect Splitter -> Individual channel Gain nodes & Delay -> Merger -> Master
      splitter!.connect(leftGain!, 0);   // Left channel splits to Left Gain
      splitter!.connect(delayNode!, 1);  // Right channel splits to Delay Node
      delayNode!.connect(rightGain!, 0); // Delay splits to Right Gain

      leftGain!.connect(merger!, 0, 0);  // Left Gain to Left Input of Merger
      rightGain!.connect(merger!, 0, 1); // Right Gain to Right Input of Merger

      merger!.connect(masterGain!);
      masterGain!.connect(audioCtx.destination);

      // Start source
      if (sourceNode instanceof OscillatorNode) {
        sourceNode.start();
      } else if (sourceNode instanceof AudioBufferSourceNode) {
        sourceNode.start();
      }

      // Fade-in envelope (pop-free start)
      masterGain.gain.linearRampToValueAtTime(targetGain, audioCtx.currentTime + 0.05);
      isPlaying = true;
    }

    // Stop Audio Engine
    function stopAudioEngine() {
      if (!audioCtx || !masterGain || !sourceNode) return;

      const currentTime = audioCtx.currentTime;
      // Fade-out envelope (pop-free stop)
      masterGain.gain.cancelScheduledValues(currentTime);
      masterGain.gain.setValueAtTime(masterGain.gain.value, currentTime);
      masterGain.gain.linearRampToValueAtTime(0.0001, currentTime + 0.05);

      const oldSource = sourceNode;
      const oldCtx = audioCtx;
      const currentVersion = audioEngineVersion;
      
      setTimeout(() => {
        try {
          if (currentVersion === audioEngineVersion) {
            oldSource.disconnect();
            if (oldSource instanceof OscillatorNode) {
              oldSource.stop();
            } else if (oldSource instanceof AudioBufferSourceNode) {
              oldSource.stop();
            }
          }
        } catch (e) {}
      }, 70);

      isPlaying = false;
    }

    // Toggle Play/Stop
    function togglePlayback() {
      if (isPlaying) {
        stopAudioEngine();
        playBtnIcon.textContent = "▶";
        playBtnText.textContent = "Start Test Signal";
        playToggleBtn.classList.remove("bg-brand-coral", "text-primary");
        playToggleBtn.classList.add("bg-primary", "text-canvas");
      } else {
        startAudioEngine();
        playBtnIcon.textContent = "■";
        playBtnText.textContent = "Stop Test Signal";
        playToggleBtn.classList.remove("bg-primary", "text-canvas");
        // Style feedback depending on phase mode
        playToggleBtn.classList.add("bg-brand-coral", "text-primary");
      }
      triggerMicroAnimation(playToggleBtn);
    }

    // Polarity Phase Toggle Handler
    function setPhaseMode(outPhase: boolean) {
      isOutofPhase = outPhase;
      localStorage.setItem("boardtools:speaker-phase:phase", outPhase ? "out-of-phase" : "in-phase");
      setPhaseAngle(outPhase ? 180 : 0);
    }

    // Fine-Tuning Phase Angle Handler
    function setPhaseAngle(angle: number) {
      currentPhaseAngle = angle;
      phaseAngleSlider.value = String(angle);
      
      let label = `${angle}°`;
      if (angle === 0) {
        label += " (In-Phase)";
        isOutofPhase = false;
        toggleInPhase.className = "relative p-4 rounded-xl border-2 flex flex-col items-center gap-2 cursor-pointer transition-all hover:scale-[1.01] active:scale-[0.99] border-brand-blue bg-surface-pricing-featured text-brand-blue";
        toggleOutPhase.className = "relative p-4 rounded-xl border-2 flex flex-col items-center gap-2 cursor-pointer transition-all hover:scale-[1.01] active:scale-[0.99] border-hairline bg-canvas text-slate";
        phaseDiffIndicator.textContent = "ALIGNED (0° DELTA)";
        phaseDiffIndicator.className = "font-bold text-brand-blue";
        
        // Return step 2 styles
        step2El?.classList.remove("border-brand-blue");
        step2El?.querySelector("span")?.classList.remove("bg-brand-blue", "text-canvas");
        step2El?.querySelector("span")?.classList.add("bg-surface", "text-slate");
      } else if (angle === 180) {
        label += " (Out-of-Phase)";
        isOutofPhase = true;
        toggleOutPhase.className = "relative p-4 rounded-xl border-2 flex flex-col items-center gap-2 cursor-pointer transition-all hover:scale-[1.01] active:scale-[0.99] border-brand-coral bg-brand-red text-coral-dark";
        toggleInPhase.className = "relative p-4 rounded-xl border-2 flex flex-col items-center gap-2 cursor-pointer transition-all hover:scale-[1.01] active:scale-[0.99] border-hairline bg-canvas text-slate";
        phaseDiffIndicator.textContent = "MUTUALLY INVERTED (180° DELTA)";
        phaseDiffIndicator.className = "font-bold text-brand-coral";

        // Highlight Step 2 in diagnostic
        step2El?.classList.add("border-brand-blue");
        step2El?.querySelector("span")?.classList.add("bg-brand-blue", "text-canvas");
        step2El?.querySelector("span")?.classList.remove("bg-surface", "text-slate");
      } else {
        isOutofPhase = false;
        toggleInPhase.className = "relative p-4 rounded-xl border-2 flex flex-col items-center gap-2 cursor-pointer transition-all hover:scale-[1.01] active:scale-[0.99] border-hairline bg-canvas text-slate";
        toggleOutPhase.className = "relative p-4 rounded-xl border-2 flex flex-col items-center gap-2 cursor-pointer transition-all hover:scale-[1.01] active:scale-[0.99] border-hairline bg-canvas text-slate";
        phaseDiffIndicator.textContent = `PHASE SHIFTED (${angle}° DELTA)`;
        phaseDiffIndicator.className = "font-bold text-primary";
        
        step2El?.classList.remove("border-brand-blue");
        step2El?.querySelector("span")?.classList.remove("bg-brand-blue", "text-canvas");
        step2El?.querySelector("span")?.classList.add("bg-surface", "text-slate");
      }
      phaseAngleDisplay.textContent = label;
      rightPhaseVal.textContent = `${angle}°`;

      // Update DSP live if running
      if (audioCtx && rightGain && delayNode) {
        const rightGainVal = (currentIsolation === "both" || currentIsolation === "right") ? 1.0 : 0.0;
        const polarityMultiplier = isOutofPhase ? -1.0 : 1.0;
        rightGain.gain.setValueAtTime(rightGainVal * polarityMultiplier, audioCtx.currentTime);

        const delaySeconds = angle / (360.0 * currentFrequency);
        delayNode.delayTime.setValueAtTime(delaySeconds, audioCtx.currentTime);
      }
    }

    // Channel Isolation Handler
    function setIsolation(mode: "both" | "left" | "right") {
      currentIsolation = mode;
      
      const activeClass = "flex-1 text-center text-xs py-1 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas";
      const inactiveClass = "flex-1 text-center text-xs py-1 rounded-full font-semibold transition-all cursor-pointer text-slate hover:text-primary";
      
      isolateBoth.className = (mode === "both") ? activeClass : inactiveClass;
      isolateLeft.className = (mode === "left") ? activeClass : inactiveClass;
      isolateRight.className = (mode === "right") ? activeClass : inactiveClass;

      // Update DSP live if running
      if (audioCtx && leftGain && rightGain) {
        const leftGainVal = (mode === "both" || mode === "left") ? 1.0 : 0.0;
        const rightGainVal = (mode === "both" || mode === "right") ? 1.0 : 0.0;
        const polarityMultiplier = isOutofPhase ? -1.0 : 1.0;
        
        leftGain.gain.linearRampToValueAtTime(leftGainVal, audioCtx.currentTime + 0.02);
        rightGain.gain.linearRampToValueAtTime(rightGainVal * polarityMultiplier, audioCtx.currentTime + 0.02);
      }
    }

    // Set Frequency Value
    function setFrequency(freq: number) {
      currentFrequency = freq;
      freqSlider.value = String(freq);
      freqDisplay.textContent = `${freq} Hz`;

      // Update oscillator if active
      if (audioCtx && sourceNode && sourceNode instanceof OscillatorNode) {
        sourceNode.frequency.linearRampToValueAtTime(freq, audioCtx.currentTime + 0.05);
      }

      updateSelectedChip(freq);
    }

    // Highlight active chip
    function updateSelectedChip(freq: number) {
      freqChips.forEach(chip => {
        const fVal = parseInt(chip.getAttribute("data-freq") || "0", 10);
        if (fVal === freq) {
          chip.className = "freq-chip px-2.5 py-1 text-[11px] bg-canvas border border-brand-blue text-brand-blue rounded-full transition-colors font-mono font-semibold";
        } else {
          chip.className = "freq-chip px-2.5 py-1 text-[11px] bg-canvas border border-hairline hover:border-brand-blue rounded-full transition-colors font-mono font-semibold";
        }
      });
    }

    // Set Volume Value
    function setVolume(vol: number) {
      currentVolume = vol;
      volumeSlider.value = String(vol);
      volumeDisplay.textContent = `${vol}%`;

      // Update master gain if active
      if (audioCtx && masterGain) {
        masterGain.gain.linearRampToValueAtTime(vol / 100, audioCtx.currentTime + 0.02);
      }
    }

    // Animated SVG Waveform Visualizer
    function startWaveformAnimation() {
      function draw() {
        animTime += (currentFrequency / 60) * 0.08;
        
        let pathL = "";
        let pathR = "";

        const width = 600;
        const height = 112;
        const midY = height / 2;
        const amplitude = isPlaying ? 35 : 10; // Pulsing when audio active

        const showLeft = (currentIsolation === "both" || currentIsolation === "left");
        const showRight = (currentIsolation === "both" || currentIsolation === "right");

        for (let x = 0; x <= width; x += 3) {
          const angle = (x / width) * Math.PI * 8 + animTime;
          const leftY = midY + (showLeft ? Math.sin(angle) * amplitude : 0);
          
          // Right channel wave - shift by actual phase angle
          const phaseRadians = (currentPhaseAngle * Math.PI) / 180;
          const rightY = midY + (showRight ? Math.sin(angle + phaseRadians) * amplitude : 0);

          if (x === 0) {
            pathL += `M ${x} ${leftY}`;
            pathR += `M ${x} ${rightY}`;
          } else {
            pathL += ` L ${x} ${leftY}`;
            pathR += ` L ${x} ${rightY}`;
          }
        }

        leftWavePath.setAttribute("d", pathL);
        rightWavePath.setAttribute("d", pathR);

        animId = requestAnimationFrame(draw);
      }
      draw();
    }

    // Save Favorite Frequency
    saveFreqBtn.addEventListener("click", () => {
      localStorage.setItem("boardtools:speaker-phase:frequency", String(currentFrequency));
      showToastNotification("✓ Saved frequency to local storage");
    });

    // Reset settings to defaults (Verbatim Contract)
    resetBtn.addEventListener("click", () => {
      // 1. Stop Tone
      if (isPlaying) {
        togglePlayback();
      }

      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // 2. Clear localStorage keys
      localStorage.removeItem("boardtools:speaker-phase:frequency");
      localStorage.removeItem("boardtools:speaker-phase:phase");
      localStorage.removeItem("boardtools:speaker-phase:volume");
      localStorage.removeItem("boardtools:speaker-phase:signal-type");

      // 3. Reset defaults
      setPhaseMode(false);
      setIsolation("both");
      setFrequency(60);
      setVolume(50);
      currentSignal = "sine";
      signalSelect.value = "sine";
      toggleSignalLayout("sine");

      showToastNotification("✓ Phase settings reset");
    });

    // Share link generator
    shareBtn.addEventListener("click", () => {
      const isNoise = currentSignal === "pink-noise" ? "noise" : "sine";
      const ph = isOutofPhase ? "out" : "in";
      const shareUrl = `${window.location.origin}${window.location.pathname}?freq=${currentFrequency}&phase=${ph}&signal=${isNoise}&angle=${currentPhaseAngle}&isolate=${currentIsolation}`;

      const shareData = {
        title: document.title || "Speaker Phase Test",
        url: shareUrl
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(shareUrl);
          }
        });
      } else {
        copyToClipboard(shareUrl);
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
        showToastNotification("✓ Shareable configuration URL copied!");
      }
    });

    // Frequency Slider listener
    freqSlider.addEventListener("input", (e) => {
      const val = parseInt((e.target as HTMLInputElement).value, 10);
      setFrequency(val);
    });

    // Phase Angle Slider listener
    phaseAngleSlider.addEventListener("input", (e) => {
      const val = parseInt((e.target as HTMLInputElement).value, 10);
      setPhaseAngle(val);
    });

    // Channel Isolation listeners
    isolateBoth.addEventListener("click", () => setIsolation("both"));
    isolateLeft.addEventListener("click", () => setIsolation("left"));
    isolateRight.addEventListener("click", () => setIsolation("right"));

    // Volume Slider listener
    volumeSlider.addEventListener("input", (e) => {
      const val = parseInt((e.target as HTMLInputElement).value, 10);
      setVolume(val);
      localStorage.setItem("boardtools:speaker-phase:volume", String(val));
    });

    // Signal Select listener
    signalSelect.addEventListener("change", (e) => {
      const val = (e.target as HTMLSelectElement).value;
      currentSignal = val;
      localStorage.setItem("boardtools:speaker-phase:signal-type", val);
      toggleSignalLayout(val);

      // Re-initialize engine if running
      if (isPlaying) {
        stopAudioEngine();
        setTimeout(() => startAudioEngine(), 60);
      }
    });

    // Frequency Chips listener
    freqChips.forEach(chip => {
      chip.addEventListener("click", () => {
        const val = parseInt(chip.getAttribute("data-freq") || "60", 10);
        setFrequency(val);
        triggerMicroAnimation(chip as HTMLButtonElement);
      });
    });

    // Mode toggles
    toggleInPhase.addEventListener("click", () => {
      setPhaseMode(false);
    });
    toggleOutPhase.addEventListener("click", () => {
      setPhaseMode(true);
    });

    playToggleBtn.addEventListener("click", () => {
      togglePlayback();
    });

    // Modal Events (Verbatim Contract)
    howItWorksBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // Keyboard Shortcuts (Space and P)
    document.addEventListener("keydown", (e) => {
      // Toggle play with Spacebar
      if (e.code === "Space") {
        const activeEl = document.activeElement;
        // Avoid interrupting text inputs or selections
        if (activeEl && (activeEl.tagName === "INPUT" || activeEl.tagName === "SELECT" || activeEl.tagName === "TEXTAREA")) {
          return;
        }
        e.preventDefault();
        togglePlayback();
      }
      
      // Toggle phase mode with 'P' or 'p' key
      if (e.key === "P" || e.key === "p") {
        const activeEl = document.activeElement;
        if (activeEl && (activeEl.tagName === "INPUT" || activeEl.tagName === "SELECT" || activeEl.tagName === "TEXTAREA")) {
          return;
        }
        e.preventDefault();
        setPhaseMode(!isOutofPhase);
      }
    });

    // Toast notifications helper
    function showToastNotification(msg: string) {
      const toast = document.createElement("div");
      toast.className = "fixed bottom-5 right-5 bg-success-accent text-canvas text-xs font-bold py-2.5 px-4 rounded-md shadow-lg z-50 transition-opacity duration-300 opacity-0";
      toast.textContent = msg;
      document.body.appendChild(toast);
      
      // trigger reflow then fade-in
      setTimeout(() => toast.classList.remove("opacity-0"), 10);
      
      setTimeout(() => {
        toast.classList.add("opacity-0");
        setTimeout(() => toast.remove(), 300);
      }, 2500);
    }

    function triggerMicroAnimation(btn: HTMLButtonElement) {
      btn.classList.add("scale-95");
      setTimeout(() => {
        btn.classList.remove("scale-95");
      }, 100);
    }

    // Start everything
    init();
  </script>

  <!-- Physics animations stylesheets -->
  <style>
    /* Cone speaker animations */
    .speaker-cone-anim {
      transition: transform 0.1s ease-in-out;
    }

    @keyframes pulse-normal {
      0%, 100% { transform: scaleX(1); }
      50% { transform: scaleX(1.15) translateX(2px); }
    }

    @keyframes pulse-inverted {
      0%, 100% { transform: scaleX(1); }
      50% { transform: scaleX(0.85) translateX(-2px); }
    }

    .speaker-cone-anim.in-phase {
      animation: pulse-normal 1.2s infinite ease-in-out;
    }
    
    .speaker-cone-anim.out-phase {
      animation: pulse-inverted 1.2s infinite ease-in-out;
    }

    /* Support prefers-reduced-motion standard fallback */
    @media (prefers-reduced-motion: reduce) {
      .speaker-cone-anim.in-phase,
      .speaker-cone-anim.out-phase {
        animation: none !important;
        transform: none !important;
      }
      #left-wave-path, #right-wave-path {
        animation: none !important;
      }
    }
  </style>

  <script>
    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });
  </script>
</Layout>
