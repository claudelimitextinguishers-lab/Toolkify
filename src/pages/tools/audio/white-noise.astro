---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "White Noise Generator";
const category = "audio";
const tier = "Audio Utilities";
const description = "Free online white noise generator & customizable sound machine. Block distractions, enhance sleep, soothe babies, and mask tinnitus with high-fidelity, client-side noise.";

const pageTitle = "Best Online White Noise Generator - Free Sound Machine for Sleep & Focus";
const canonicalUrl = "https://toolkify.app/tools/audio/white-noise";
const ogImage = "/og/white-noise.png";
const keywords = "white noise, best online white noise, white noise machine, white noise for sleep, what is white noise, brown noise vs white noise, best white noise machine, white noise app, best white noise for baby, white noise sleep, white noise book, free white noise for sleep";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- FAQ Page JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is white noise?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>White noise is a consistent sound containing all frequencies across the spectrum of audible sound in equal measure. It is named after white light, which contains all visible wavelengths. Because it spans all frequencies, it has a masking effect that can block out sudden, disruptive background noises.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Is white noise bad for babies?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>No, white noise is generally safe and highly effective for babies when used correctly. To ensure safety, always place the sound source at least 6 to 7 feet (2 meters) away from the crib, keep the volume below 50 decibels, and limit continuous use to sleep times.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to play white noise on phone?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>You can play white noise on your phone by visiting an online browser-based tool like our White Noise Generator, downloading a dedicated white noise app, or using built-in phone features (such as Background Sounds in iOS settings). Using our web app is free, private, and doesn't require any downloads.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does white noise help you sleep?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, white noise helps many people sleep by creating a steady sound barrier. This barrier masks sudden changes in environmental sound, such as traffic, barking dogs, or creaking floors, preventing these noises from waking you or interrupting your sleep cycles.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why does white noise help you sleep?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>White noise helps you sleep because of auditory masking. It raises the baseline sound level in your bedroom, making sudden spikes in background noise less noticeable to your auditory cortex. By reducing the sound delta (change in volume), your brain is less likely to register noise as a threat and wake you up.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Is white noise bad for you?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>No, white noise is safe for adults when kept at moderate volumes. However, listening to white noise at high volumes (above 70-85 dB) for prolonged periods can potentially lead to hearing fatigue or damage. Keep the volume at a comfortable, ambient level.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does white noise do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>White noise acts as a sound shield. It delivers a uniform sound across all frequencies, which fills your auditory space and prevents sudden or irritating sounds from distracting your brain. This makes it a popular tool for concentration, study, sleep, and tinnitus masking.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Is white noise good for sleep?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, white noise is a highly effective, non-pharmacological sleep aid. By neutralizing ambient disturbances, it helps you fall asleep faster and maintain a deeper, more continuous sleep state throughout the night.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How loud should white noise be for baby?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>White noise for babies should not exceed 50 decibels (similar to the sound of a soft shower or light rain). It should be kept at a moderate, background volume and never placed directly next to the baby's ears or inside their crib.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Do dogs like white noise?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, many dogs benefit from white noise. It helps mask frightening or stimulating sounds such as thunder, fireworks, construction, or passing delivery trucks, thereby reducing anxiety and helping them relax or sleep.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does white noise help babies sleep?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, white noise is incredibly effective at helping babies fall and stay asleep. It blocks household noises (like siblings, cooking, or TV) and provides a calming, rhythmic environment that facilitates smooth sleep transitions.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is brown noise vs white noise?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>White noise has equal energy across all audible frequencies, resulting in a bright, static-like sound (similar to a waterfall or fan). Brown noise (also called red noise) has deeper bass frequencies with energy that decreases at higher frequencies. This creates a much warmer, deeper, rumbly tone resembling heavy rainfall or a distant ocean roar.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why do babies like white noise?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Babies like white noise because it mimics the constant, loud swooshing sounds of blood flow and heartbeat they heard in the womb (which can reach up to 70-80 decibels). This familiar sound triggers a natural calming reflex, helping them feel safe and secure.</p>"
          }
        }
      ]
    }
  </script>

  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "White Noise Generator",
      "alternateName": "Browser-Based White Noise Sound Machine",
      "url": "https://toolkify.app/tools/audio/white-noise",
      "description": "Generate high-fidelity, loop-safe white noise and environmental soundscapes entirely in your browser. Customizable sleep timer, visualizer, presets, and synthesized audio layers.",
      "applicationCategory": "AudioApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires Web Audio API. Requires HTML5 Canvas.",
      "featureList": [
        "Real-time client-side white noise synthesis",
        "Synthesized sound layers for rain and cooling fan textures",
        "Low-pass and high-pass frequency shaping filters",
        "Customizable sleep timer with automatic smooth volume fade-out",
        "Animated frequency spectrum and waveform visualizer",
        "Curated mood presets: Focus, Sleep, Baby Soothing, Tinnitus, Study",
        "Local save for custom user sound presets",
        "Shareable settings URL generator"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-lg sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[9px] sm:text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <!-- Keyboard shortcuts reference -->
          <button
            type="button"
            id="shortcuts-btn"
            class="hidden sm:inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="View keyboard shortcuts"
          >
            <span>⌨ Keyboard Shortcuts</span>
          </button>

          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How JSON formatter works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Gesture Requirement Overlay -->
    <div id="gesture-overlay" class="hidden p-3 sm:p-4 bg-surface-yellow border border-yellow-light/80 text-yellow-dark rounded-xl flex items-center justify-between text-xs sm:text-sm animate-pulse print:hidden">
      <span class="flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-brand-yellow-deep"></span>
        <span>Browser requires interaction to enable high-fidelity sound. Tap anywhere or play to activate.</span>
      </span>
      <button type="button" id="enable-audio-btn" class="button-yellow text-[10px] sm:text-[11px] py-1 px-3 !rounded-full font-bold shadow-subtle hover:scale-105 active:scale-95 transition-all">
        Enable Audio
      </button>
    </div>

    <!-- IOS Safari background / audio suspension banner -->
    <div id="safari-suspended-banner" class="hidden p-2 sm:p-3 bg-brand-red border border-brand-red-dark text-coral-dark rounded-xl flex items-center justify-between text-xs print:hidden">
      <span>Background audio suspended by browser. Click resume to restore playback.</span>
      <button type="button" id="resume-audio-btn" class="button-primary text-[9px] sm:text-[10px] py-1 px-3 !rounded-full font-bold transition-all">
        Resume Audio
      </button>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 sm:gap-5 items-stretch">
      
      <!-- Left: Synth Controls Panel -->
      <div class="lg:col-span-8 card-base flex flex-col gap-4 sm:gap-6 p-3 sm:p-6">
        
        <!-- Section Title -->
        <div class="flex items-center justify-between border-b border-hairline-soft pb-2 sm:pb-3">
          <h2 class="font-display font-semibold text-base sm:text-lg text-primary flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
            Noise Synthesis Engine
          </h2>
          <span id="audio-state-tag" class="text-[9px] sm:text-[10px] font-bold text-slate px-2 py-0.5 rounded-full bg-surface border border-hairline uppercase tracking-wider">Stopped</span>
        </div>

        <!-- Quick Mood Presets -->
        <div class="flex flex-col gap-1.5">
          <span class="text-[10px] sm:text-[11px] font-semibold text-slate uppercase tracking-wider">Preset Moods</span>
          <div class="flex flex-wrap gap-1.5">
            <button type="button" data-mood="focus" class="mood-chip px-2.5 py-1 sm:px-3 sm:py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary text-xs font-semibold rounded-full transition-all cursor-pointer shadow-subtle hover:scale-105 active:scale-95">
              🎯 Focus
            </button>
            <button type="button" data-mood="sleep" class="mood-chip px-2.5 py-1 sm:px-3 sm:py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary text-xs font-semibold rounded-full transition-all cursor-pointer shadow-subtle hover:scale-105 active:scale-95">
              💤 Sleep
            </button>
            <button type="button" data-mood="baby" class="mood-chip px-2.5 py-1 sm:px-3 sm:py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary text-xs font-semibold rounded-full transition-all cursor-pointer shadow-subtle hover:scale-105 active:scale-95">
              🍼 Baby Soothing
            </button>
            <button type="button" data-mood="tinnitus" class="mood-chip px-2.5 py-1 sm:px-3 sm:py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary text-xs font-semibold rounded-full transition-all cursor-pointer shadow-subtle hover:scale-105 active:scale-95">
              🔔 Tinnitus Relief
            </button>
            <button type="button" data-mood="study" class="mood-chip px-2.5 py-1 sm:px-3 sm:py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary text-xs font-semibold rounded-full transition-all cursor-pointer shadow-subtle hover:scale-105 active:scale-95">
              📚 Deep Study
            </button>
          </div>
        </div>

        <!-- Major Playback / Transport Control -->
        <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 p-3 sm:p-5 bg-surface-soft border border-hairline-soft rounded-2xl">
          
          <!-- Play / Pause / Stop Buttons -->
          <div class="flex items-center gap-3">
            <button
              type="button"
              id="play-btn"
              class="w-12 h-12 sm:w-16 sm:h-16 rounded-full bg-primary text-canvas flex items-center justify-center shadow-lg hover:scale-105 active:scale-95 transition-all cursor-pointer group focus:outline-none focus:ring-4 focus:ring-primary/20 relative"
              aria-label="Play white noise"
            >
              <!-- Ripple Effect -->
              <span id="play-ripple" class="absolute inset-0 rounded-full bg-primary/20 scale-100 opacity-0 transition-all duration-1000 pointer-events-none"></span>
              
              <!-- Play Icon -->
              <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 sm:w-8 sm:h-8 fill-current translate-x-0.5" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
              <!-- Pause Icon -->
              <svg id="pause-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 sm:w-8 sm:h-8 fill-current hidden" viewBox="0 0 24 24">
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
              </svg>
            </button>

            <button
              type="button"
              id="stop-btn"
              class="w-9 h-9 sm:w-11 sm:h-11 rounded-full bg-canvas text-slate hover:text-brand-coral border border-hairline flex items-center justify-center shadow-subtle hover:scale-105 active:scale-95 transition-all cursor-pointer focus:outline-none"
              aria-label="Stop audio"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 fill-current" viewBox="0 0 24 24">
                <path d="M6 6h12v12H6z" />
              </svg>
            </button>
          </div>

          <!-- Transport Info -->
          <div class="flex-grow flex flex-col gap-0.5 text-center sm:text-left">
            <span id="playing-state-title" class="font-display font-semibold text-xs sm:text-sm text-primary">Audio is Idle</span>
            <p id="playing-state-desc" class="text-[11px] sm:text-xs text-slate max-w-xs mx-auto sm:mx-0">Press play to synthesize high-quality white noise directly in your browser.</p>
          </div>

          <!-- Share Link Actions -->
          <div class="flex items-center gap-2 self-stretch sm:self-center justify-center">
            <button
              type="button"
              id="btn-copy-settings"
              class="inline-flex items-center gap-1.5 text-[10px] font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle hover:scale-105 active:scale-95"
              title="Get shareable link of current sound settings"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l-2.884 1.442m0 0l-2.884-1.442m2.884 1.442V17m0 0l3.07-1.535M5.8 17l-3.07-1.535M12 4.5l-3 3m0 0l3 3m-3-3h12a3 3 0 013 3V12" />
              </svg>
              <span>Share Config</span>
            </button>
            
            <div id="toast-message" class="hidden text-success-accent text-[10px] font-bold py-1 px-2 border border-success-accent/20 bg-success-accent/5 rounded-full animate-fade-in">
              Copied!
            </div>
          </div>
        </div>

        <!-- Master Sliders (Volume, Panning) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-5">
          <!-- Volume Control -->
          <div class="flex flex-col gap-2 p-2 sm:p-3 bg-surface rounded-xl border border-hairline-soft">
            <div class="flex items-center justify-between">
              <label for="volume-slider" class="text-[11px] font-semibold text-slate uppercase">Master Volume</label>
              <span id="volume-readout" class="font-mono text-xs font-bold text-primary">70% (-3.1 dB)</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs">🔈</span>
              <input 
                type="range" 
                id="volume-slider" 
                min="0" 
                max="100" 
                value="70" 
                class="slider-input flex-grow h-2 bg-hairline rounded-lg appearance-none cursor-pointer focus:outline-none accent-primary transition-all"
                aria-label="Master volume slider"
              />
              <span class="text-xs">🔊</span>
            </div>
          </div>

          <!-- Stereo Pan Control -->
          <div class="flex flex-col gap-2 p-2 sm:p-3 bg-surface rounded-xl border border-hairline-soft">
            <div class="flex items-center justify-between">
              <label for="pan-slider" class="text-[11px] font-semibold text-slate uppercase">Stereo Balance</label>
              <span id="pan-readout" class="font-mono text-xs font-bold text-primary">Center</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs font-bold text-slate">L</span>
              <input 
                type="range" 
                id="pan-slider" 
                min="-100" 
                max="100" 
                value="0" 
                class="slider-input flex-grow h-2 bg-hairline rounded-lg appearance-none cursor-pointer focus:outline-none accent-primary transition-all"
                aria-label="Stereo panning balance slider"
              />
              <span class="text-xs font-bold text-slate">R</span>
            </div>
          </div>
        </div>

        <!-- Frequency Shaping Filters -->
        <div class="flex flex-col gap-3 sm:gap-4 p-3 sm:p-4 bg-surface rounded-xl border border-hairline-soft">
          <div class="flex items-center justify-between border-b border-hairline-soft pb-2">
            <span class="text-[11px] font-semibold text-slate uppercase tracking-wider">Frequency Shaping (EQ)</span>
            <span id="eq-tilt-desc" class="text-[10px] text-slate font-medium">Pure White Noise</span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Low Pass Filter -->
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center justify-between text-xs">
                <label for="lp-slider" class="font-bold text-slate">Low-Pass Filter (Soften Highs)</label>
                <span id="lp-readout" class="font-mono text-[11px] text-primary">20,000 Hz</span>
              </div>
              <input 
                type="range" 
                id="lp-slider" 
                min="0" 
                max="100" 
                value="100" 
                class="slider-input w-full h-2 bg-hairline rounded-lg appearance-none cursor-pointer accent-primary"
                aria-label="Low-pass filter cutoff frequency slider"
              />
              <span class="text-[10px] text-slate leading-normal">Reduces harsh static hiss. Drag left to create a warmer, deeper rumble (pink/brown noise style).</span>
            </div>

            <!-- High Pass Filter -->
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center justify-between text-xs">
                <label for="hp-slider" class="font-bold text-slate">High-Pass Filter (Soften Lows)</label>
                <span id="hp-readout" class="font-mono text-[11px] text-primary">20 Hz</span>
              </div>
              <input 
                type="range" 
                id="hp-slider" 
                min="0" 
                max="100" 
                value="0" 
                class="slider-input w-full h-2 bg-hairline rounded-lg appearance-none cursor-pointer accent-primary"
                aria-label="High-pass filter cutoff frequency slider"
              />
              <span class="text-[10px] text-slate leading-normal">Removes low-end hum. Drag right to focus only on clean rain-like or static noise.</span>
            </div>
          </div>
        </div>

        <!-- Advanced Synthesis Layer Mixins -->
        <div class="flex flex-col gap-2 sm:gap-3 p-3 sm:p-4 bg-surface rounded-xl border border-hairline-soft">
          <div class="flex items-center justify-between border-b border-hairline-soft pb-2">
            <span class="text-[11px] font-semibold text-slate uppercase tracking-wider">Advanced Layer Mixer</span>
            <span class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-[9px] py-0.5 px-2 rounded-full font-semibold uppercase">100% Synthesized</span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-5 mt-1">
            <!-- Rain Mixin -->
            <div class="flex flex-col gap-2 p-3 bg-canvas rounded-lg border border-hairline">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5">
                  <input type="checkbox" id="rain-toggle" class="w-4 h-4 cursor-pointer accent-primary rounded-md" />
                  <label for="rain-toggle" class="text-xs font-bold text-primary cursor-pointer select-none">🌧 Synthesized Rain</label>
                </div>
                <span id="rain-vol-readout" class="font-mono text-[10px] text-slate">Vol: 0%</span>
              </div>
              <input 
                type="range" 
                id="rain-volume" 
                min="0" 
                max="100" 
                value="30" 
                disabled
                class="slider-input w-full h-1.5 bg-hairline rounded-lg appearance-none cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed accent-primary"
