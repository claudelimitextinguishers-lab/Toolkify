    // Visualizer Canvas loop
    function startVisualizer() {
      if (!analyserNode) return;
      visualizerIdleOverlay.classList.add("opacity-0", "pointer-events-none");
      drawVisualizer();
    }

    function stopVisualizer() {
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }
      visualizerIdleOverlay.classList.remove("opacity-0", "pointer-events-none");
      
      // Clear visualizer to silent state
      const w = canvas.width;
      const h = canvas.height;
      canvasCtx.clearRect(0, 0, w, h);
      
      // Draw a subtle flat centerline
      canvasCtx.strokeStyle = "#8e91a0";
      canvasCtx.lineWidth = 1.5;
      canvasCtx.beginPath();
      canvasCtx.moveTo(0, h / 2);
      canvasCtx.lineTo(w, h / 2);
      canvasCtx.stroke();
    }

    function drawVisualizer() {
      if (!isPlaying || !analyserNode) return;

      animationFrameId = requestAnimationFrame(drawVisualizer);

      const width = canvas.width = canvas.parentElement!.clientWidth;
      const height = canvas.height = canvas.parentElement!.clientHeight;
      const bufferLength = analyserNode.frequencyBinCount;
      const dataArray = new Uint8Array(bufferLength);

      canvasCtx.clearRect(0, 0, width, height);

      if (visualizerStyle === "waveform") {
        analyserNode.getByteTimeDomainData(dataArray);
        
        // Calculate volume/activity level using Root Mean Square (RMS)
        let sum = 0;
        for (let i = 0; i < bufferLength; i++) {
          const val = (dataArray[i] - 128) / 128;
          sum += val * val;
        }
        const rms = Math.sqrt(sum / bufferLength);
        const activity = Math.min(1.0, rms * 4.0); // Scale up for visual presence

        const time = performance.now() * 0.003;

        // Configuration for 3 distinct flowing wave layers
        const waves = [
          { stroke: "rgba(66, 98, 255, 0.8)", glow: "rgba(66, 98, 255, 0.4)", speed: 1.0, frequency: 0.015, amplitude: 0.8, phase: 0 },
          { stroke: "rgba(15, 188, 176, 0.7)", glow: "rgba(15, 188, 176, 0.3)", speed: -1.3, frequency: 0.025, amplitude: 0.5, phase: Math.PI / 3 },
          { stroke: "rgba(255, 153, 153, 0.6)", glow: "rgba(255, 153, 153, 0.2)", speed: 0.7, frequency: 0.01, amplitude: 0.3, phase: Math.PI / 1.5 }
        ];

        waves.forEach(w => {
          canvasCtx.beginPath();
          canvasCtx.lineWidth = w.amplitude === 0.8 ? 2.5 : 1.5;
          canvasCtx.strokeStyle = w.stroke;
          
          // Premium Glow Effects
          canvasCtx.shadowBlur = 10;
          canvasCtx.shadowColor = w.glow;

          for (let x = 0; x < width; x += 2) {
            const angle = x * w.frequency + time * w.speed + w.phase;
            
            // Map x position to index in dataArray to sample real-time noise jitter
            const dataIndex = Math.floor((x / width) * bufferLength);
            const audioMod = (dataArray[dataIndex] - 128) / 128.0;

            // Edge envelope (sine curve) to pinch waves at the boundaries
            const edgeEnvelope = Math.sin((x / width) * Math.PI);

            // Compute vertical displacement (smooth flow + reactive noise micro-jitter)
            const waveY = Math.sin(angle) * (height * 0.35) * w.amplitude * activity * edgeEnvelope;
            const reactiveY = audioMod * (height * 0.12) * edgeEnvelope;
            
            const y = (height / 2) + waveY + reactiveY;

            if (x === 0) {
              canvasCtx.moveTo(x, y);
            } else {
              canvasCtx.lineTo(x, y);
            }
          }
          canvasCtx.stroke();
        });

        // Reset canvas context shadow state
        canvasCtx.shadowBlur = 0;
        canvasCtx.shadowColor = "transparent";
      } else {
        // Spectrum Bars
        analyserNode.getByteFrequencyData(dataArray);
        const barWidth = (width / bufferLength) * 1.5;
        let barHeight;
        let x = 0;

        for (let i = 0; i < bufferLength; i++) {
          barHeight = dataArray[i] / 1.6;
          // Gradient fill
          const grad = canvasCtx.createLinearGradient(0, height, 0, height - barHeight);
          grad.addColorStop(0, "#4262ff"); // Brand blue
          grad.addColorStop(1, "#ff9999"); // Brand coral
          
          canvasCtx.fillStyle = grad;
          canvasCtx.fillRect(x, height - barHeight, barWidth - 1, barHeight);

          x += barWidth;
        }
      }
    }

    // Sleep Timer Mechanics
    function startTimer(minutes: number) {
      stopTimer();
      initAudio();

      timerTotalSeconds = minutes * 60;
      timerRemainingSeconds = timerTotalSeconds;
      isFadingOut = false;

      timerStatus.textContent = "Active";
      timerStatus.classList.add("text-brand-blue");
      timerCountdownArea.classList.remove("hidden");
      cancelTimerBtn.classList.remove("hidden");
      
      updateTimerDisplay();

      timerInterval = window.setInterval(() => {
        timerRemainingSeconds--;
        updateTimerDisplay();

        // 10 Seconds countdown warning
        if (timerRemainingSeconds <= 10 && timerRemainingSeconds > 0) {
          timerCountdownArea.classList.add("animate-pulse-fast");
        }

        // Fade Out Sequence (starts 10 seconds before completion)
        if (timerRemainingSeconds <= 10 && !isFadingOut && audioCtx && mainGainNode) {
          isFadingOut = true;
          mainGainNode.gain.cancelScheduledValues(audioCtx.currentTime);
          mainGainNode.gain.setValueAtTime(mainGainNode.gain.value, audioCtx.currentTime);
          mainGainNode.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + timerRemainingSeconds);
        }

        if (timerRemainingSeconds <= 0) {
          stopAudio();
        }
      }, 1000);

      if (!isPlaying) {
        startAudio();
      }
    }

    function stopTimer() {
      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }
      timerStatus.textContent = "Inactive";
      timerStatus.classList.remove("text-brand-blue");
      timerCountdownArea.classList.add("hidden");
      timerCountdownArea.classList.remove("animate-pulse-fast");
      cancelTimerBtn.classList.add("hidden");
      isFadingOut = false;
    }

    function updateTimerDisplay() {
      const mins = Math.floor(timerRemainingSeconds / 60);
      const secs = timerRemainingSeconds % 60;
      countdownReadout.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
      
      const pct = (timerRemainingSeconds / timerTotalSeconds) * 100;
      timerProgressFill.style.width = `${pct}%`;
    }

    // LocalStorage System (using toolkify:white-noise:{key})
    function saveSettingsToLS() {
      const config = {
        volume: parseInt(volumeSlider.value),
        pan: parseInt(panSlider.value),
        lp: parseInt(lpSlider.value),
        hp: parseInt(hpSlider.value),
        rain: rainToggle.checked,
        rainVol: parseInt(rainVolume.value),
        fan: fanToggle.checked,
        fanVol: parseInt(fanVolume.value)
      };
      localStorage.setItem(`${LS_PREFIX}settings`, JSON.stringify(config));
    }

    function loadSettingsFromLS() {
      const raw = localStorage.getItem(`${LS_PREFIX}settings`);
      if (raw) {
        try {
          const config = JSON.parse(raw);
          applyConfig(config);
        } catch (e) {}
      }
    }

    function applyConfig(config: any) {
      if (config.volume !== undefined) volumeSlider.value = config.volume;
      if (config.pan !== undefined) panSlider.value = config.pan;
      if (config.lp !== undefined) lpSlider.value = config.lp;
      if (config.hp !== undefined) hpSlider.value = config.hp;
      
      if (config.rain !== undefined) {
        rainToggle.checked = config.rain;
        rainVolume.disabled = !config.rain;
      }
      if (config.rainVol !== undefined) rainVolume.value = config.rainVol;

      if (config.fan !== undefined) {
        fanToggle.checked = config.fan;
        fanVolume.disabled = !config.fan;
      }
      if (config.fanVol !== undefined) fanVolume.value = config.fanVol;

      updateNodeValues();
      
      // If audio is already running, apply dynamic components
      if (isPlaying && audioCtx) {
        if (config.rain) {
          startRainSynthesis(audioCtx);
        } else {
          stopRainSynthesis();
        }

        if (config.fan) {
          startFanSynthesis(audioCtx);
        } else {
          stopFanSynthesis();
        }
      }
    }

    // Custom Saved Presets
    interface UserPreset {
      name: string;
      config: any;
    }

    function loadCustomPresets() {
      const raw = localStorage.getItem(`${LS_PREFIX}custom-presets`);
      let list: UserPreset[] = [];
      if (raw) {
        try { list = JSON.parse(raw); } catch (e) {}
      }
      
      // Render
      presetsListContainer.innerHTML = "";
      if (list.length === 0) {
        presetsListContainer.innerHTML = '<span class="text-[11px] text-stone">No saved setups yet.</span>';
        return;
      }

      list.forEach((item, index) => {
        const div = document.createElement("div");
        div.className = "flex items-center justify-between p-2 bg-surface hover:bg-surface-soft border border-hairline rounded-lg text-xs transition-all";
        
        const label = document.createElement("button");
        label.type = "button";
        label.className = "font-semibold text-primary text-left truncate flex-grow mr-2 hover:underline cursor-pointer";
        label.textContent = item.name;
        label.onclick = () => {
          applyConfig(item.config);
          saveSettingsToLS();
        };

        const delBtn = document.createElement("button");
        delBtn.type = "button";
        delBtn.className = "text-stone hover:text-brand-coral font-bold px-1 transition-all cursor-pointer";
        delBtn.innerHTML = "×";
        delBtn.onclick = () => deletePreset(index);

        div.appendChild(label);
        div.appendChild(delBtn);
        presetsListContainer.appendChild(div);
      });
    }

    function saveCurrentAsPreset() {
      const nameVal = newPresetName.value.trim();
      if (!nameVal) return;

      const config = {
        volume: parseInt(volumeSlider.value),
        pan: parseInt(panSlider.value),
        lp: parseInt(lpSlider.value),
        hp: parseInt(hpSlider.value),
        rain: rainToggle.checked,
        rainVol: parseInt(rainVolume.value),
        fan: fanToggle.checked,
        fanVol: parseInt(fanVolume.value)
      };

      const raw = localStorage.getItem(`${LS_PREFIX}custom-presets`);
      let list: UserPreset[] = [];
      if (raw) {
        try { list = JSON.parse(raw); } catch (e) {}
      }

      list.push({ name: nameVal, config });
      localStorage.setItem(`${LS_PREFIX}custom-presets`, JSON.stringify(list));
      
      newPresetName.value = "";
      loadCustomPresets();
    }

    function deletePreset(index: number) {
      const raw = localStorage.getItem(`${LS_PREFIX}custom-presets`);
      let list: UserPreset[] = [];
      if (raw) {
        try { list = JSON.parse(raw); } catch (e) {}
      }
      list.splice(index, 1);
      localStorage.setItem(`${LS_PREFIX}custom-presets`, JSON.stringify(list));
      loadCustomPresets();
    }

    // Share Config link builder
    function getShareableURL(): string {
      const config = {
        v: parseInt(volumeSlider.value),
        p: parseInt(panSlider.value),
        l: parseInt(lpSlider.value),
        h: parseInt(hpSlider.value),
        r: rainToggle.checked ? 1 : 0,
        rv: parseInt(rainVolume.value),
        f: fanToggle.checked ? 1 : 0,
        fv: parseInt(fanVolume.value)
      };
      const query = btoa(JSON.stringify(config));
      return `${window.location.origin}${window.location.pathname}?config=${query}`;
    }

    function parseSharedConfig() {
      const params = new URLSearchParams(window.location.search);
      const query = params.get("config");
      if (query) {
        try {
          const config = JSON.parse(atob(query));
          const fullConfig = {
            volume: config.v,
            pan: config.p,
            lp: config.l,
            hp: config.h,
            rain: config.r === 1,
            rainVol: config.rv,
            fan: config.f === 1,
            fanVol: config.fv
          };
          applyConfig(fullConfig);
        } catch (e) {}
      }
    }

    // Reset Page state contract
    function resetAllState() {
      // 1. Stop all playback
      stopAudio();

      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }
      
      // 2. Clear visualizer
      stopVisualizer();

      // 3. Reset controls to defaults
      volumeSlider.value = "70";
      panSlider.value = "0";
      lpSlider.value = "100";
      hpSlider.value = "0";
      
      rainToggle.checked = false;
      rainVolume.value = "30";
      rainVolume.disabled = true;

      fanToggle.checked = false;
      fanVolume.value = "40";
      fanVolume.disabled = true;

      customTimerMin.value = "";

      // 4. Update Web Audio nodes
      updateNodeValues();

      // 5. Clear LS keys
      localStorage.removeItem(`${LS_PREFIX}settings`);
      localStorage.removeItem(`${LS_PREFIX}custom-presets`);

      // 6. Reload presets visual lists
      loadCustomPresets();
    }

