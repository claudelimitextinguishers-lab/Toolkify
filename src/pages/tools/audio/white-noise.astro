  <!-- Client-side Logic Script -->
  <script>
    // LocalStorage Prefix
    const LS_PREFIX = "toolkify:white-noise:";

    // Audio State
    let audioCtx: AudioContext | null = null;
    let isPlaying = false;
    let mainGainNode: GainNode | null = null;
    let pannerNode: StereoPannerNode | null = null;
    let lpFilterNode: BiquadFilterNode | null = null;
    let hpFilterNode: BiquadFilterNode | null = null;
    let analyserNode: AnalyserNode | null = null;

    // Layer Mixer States
    let whiteNoiseSource: AudioBufferSourceNode | null = null;
    let whiteNoiseGain: GainNode | null = null;

    let rainSource: AudioBufferSourceNode | null = null;
    let rainGain: GainNode | null = null;
    let rainFilter1: BiquadFilterNode | null = null;
    let rainFilter2: BiquadFilterNode | null = null;

    let fanSource: AudioBufferSourceNode | null = null;
    let fanGain: GainNode | null = null;
    let fanFilter: BiquadFilterNode | null = null;
    let fanLfo: OscillatorNode | null = null;
    let fanLfoGain: GainNode | null = null;

    // Timer Variables
    let timerInterval: number | null = null;
    let timerTotalSeconds = 0;
    let timerRemainingSeconds = 0;
    let isFadingOut = false;

    // Visualizer Variables
    let animationFrameId: number | null = null;
    let visualizerStyle: "waveform" | "spectrum" = "spectrum";

    // DOM Elements
    const playBtn = document.getElementById("play-btn") as HTMLButtonElement;
    const playIcon = document.getElementById("play-icon") as HTMLElement;
    const pauseIcon = document.getElementById("pause-icon") as HTMLElement;
    const playRipple = document.getElementById("play-ripple") as HTMLElement;
    const stopBtn = document.getElementById("stop-btn") as HTMLButtonElement;
    
    const audioStateTag = document.getElementById("audio-state-tag") as HTMLElement;
    const playingStateTitle = document.getElementById("playing-state-title") as HTMLElement;
    const playingStateDesc = document.getElementById("playing-state-desc") as HTMLElement;
    
    const volumeSlider = document.getElementById("volume-slider") as HTMLInputElement;
    const volumeReadout = document.getElementById("volume-readout") as HTMLElement;
    
    const panSlider = document.getElementById("pan-slider") as HTMLInputElement;
    const panReadout = document.getElementById("pan-readout") as HTMLElement;
    
    const lpSlider = document.getElementById("lp-slider") as HTMLInputElement;
    const lpReadout = document.getElementById("lp-readout") as HTMLElement;
    const hpSlider = document.getElementById("hp-slider") as HTMLInputElement;
    const hpReadout = document.getElementById("hp-readout") as HTMLElement;
    const eqTiltDesc = document.getElementById("eq-tilt-desc") as HTMLElement;

    // Mixins
    const rainToggle = document.getElementById("rain-toggle") as HTMLInputElement;
    const rainVolume = document.getElementById("rain-volume") as HTMLInputElement;
    const rainVolReadout = document.getElementById("rain-vol-readout") as HTMLElement;
    
    const fanToggle = document.getElementById("fan-toggle") as HTMLInputElement;
    const fanVolume = document.getElementById("fan-volume") as HTMLInputElement;
    const fanVolReadout = document.getElementById("fan-vol-readout") as HTMLElement;

    // Sleep Timer
    const startTimerBtn = document.getElementById("start-timer-btn") as HTMLButtonElement;
    const cancelTimerBtn = document.getElementById("cancel-timer-btn") as HTMLButtonElement;
    const customTimerMin = document.getElementById("custom-timer-min") as HTMLInputElement;
    const timerStatus = document.getElementById("timer-status") as HTMLElement;
    const timerCountdownArea = document.getElementById("timer-countdown-area") as HTMLElement;
    const timerProgressFill = document.getElementById("timer-progress-fill") as HTMLElement;
    const countdownReadout = document.getElementById("countdown-readout") as HTMLElement;

    // Modals
    const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;

    const shortcutsBtn = document.getElementById("shortcuts-btn") as HTMLButtonElement;
    const shortcutsModal = document.getElementById("shortcuts-modal") as HTMLElement;
    const closeShortcutsBtn = document.getElementById("close-shortcuts-btn") as HTMLButtonElement;

    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const shareBtn = document.getElementById("share-btn") as HTMLButtonElement;
    const btnCopySettings = document.getElementById("btn-copy-settings") as HTMLButtonElement;
    const toastMessage = document.getElementById("toast-message") as HTMLElement;

    // Custom Presets
    const savePresetBtn = document.getElementById("save-preset-btn") as HTMLButtonElement;
    const newPresetName = document.getElementById("new-preset-name") as HTMLInputElement;
    const presetsListContainer = document.getElementById("presets-list-container") as HTMLElement;

    // Visualizer Canvas
    const canvas = document.getElementById("visualizer-canvas") as HTMLCanvasElement;
    const canvasCtx = canvas.getContext("2d")!;
    const visualizerIdleOverlay = document.getElementById("visualizer-idle-overlay") as HTMLElement;
    const visualizerToggle = document.getElementById("visualizer-toggle") as HTMLButtonElement;
    const visualizerHzLabel = document.getElementById("visualizer-hz-label") as HTMLElement;

    // Audio Gestures Check
    const gestureOverlay = document.getElementById("gesture-overlay") as HTMLElement;
    const enableAudioBtn = document.getElementById("enable-audio-btn") as HTMLButtonElement;
    const safariSuspendedBanner = document.getElementById("safari-suspended-banner") as HTMLElement;
    const resumeAudioBtn = document.getElementById("resume-audio-btn") as HTMLButtonElement;

    // Curated Presets mapping
    const moodPresets: Record<string, { volume: number, lp: number, hp: number, rain: boolean, rainVol: number, fan: boolean, fanVol: number }> = {
      focus: { volume: 65, lp: 45, hp: 15, rain: false, rainVol: 0, fan: false, fanVol: 0 },
      sleep: { volume: 50, lp: 20, hp: 5, rain: true, rainVol: 40, fan: true, fanVol: 30 },
      baby: { volume: 55, lp: 30, hp: 0, rain: false, rainVol: 0, fan: true, fanVol: 45 },
      tinnitus: { volume: 75, lp: 85, hp: 40, rain: false, rainVol: 0, fan: false, fanVol: 0 },
      study: { volume: 60, lp: 50, hp: 10, rain: true, rainVol: 25, fan: false, fanVol: 0 }
    };

    // Initialize Audio Context on gesture
    function initAudio() {
      if (audioCtx) return;
      
      const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;
      if (!AudioCtxClass) {
        alert("Web Audio API is not supported in this browser.");
        return;
      }
      
      audioCtx = new AudioCtxClass();
      
      // Setup master routing node structure
      mainGainNode = audioCtx.createGain();
      mainGainNode.gain.setValueAtTime(0.001, audioCtx.currentTime); // Prevent pops
      
      pannerNode = audioCtx.createStereoPanner();
      lpFilterNode = audioCtx.createBiquadFilter();
      lpFilterNode.type = 'lowpass';
      
      hpFilterNode = audioCtx.createBiquadFilter();
      hpFilterNode.type = 'highpass';
      
      analyserNode = audioCtx.createAnalyser();
      analyserNode.fftSize = 256;
      
      // Connections: [Synth Layers] -> LP -> HP -> Panner -> Gain -> Analyser -> Destination
      lpFilterNode.connect(hpFilterNode);
      hpFilterNode.connect(pannerNode);
      pannerNode.connect(mainGainNode);
      mainGainNode.connect(analyserNode);
      analyserNode.connect(audioCtx.destination);

      // Listen for safari/iOS background suspension
      audioCtx.onstatechange = () => {
        if (audioCtx && audioCtx.state === 'suspended' && isPlaying) {
          safariSuspendedBanner.classList.remove('hidden');
        } else {
          safariSuspendedBanner.classList.add('hidden');
        }
      };

      updateNodeValues();
      hideGestureOverlay();
    }

    // Dynamic scale-factor for sliders dragging
    document.querySelectorAll('.slider-input').forEach(slider => {
      slider.addEventListener('mousedown', () => slider.classList.add('scale-105'));
      slider.addEventListener('mouseup', () => slider.classList.remove('scale-105'));
      slider.addEventListener('touchstart', () => slider.classList.add('scale-105'), { passive: true });
      slider.addEventListener('touchend', () => slider.classList.remove('scale-105'), { passive: true });
    });

    // Helper: Map slider log-like scales for filters
    function getFilterFreq(value: number, isLowpass: boolean): number {
      // Return frequencies from 20Hz to 20000Hz using an exponential curve
      const minHz = 20;
      const maxHz = 20000;
      if (isLowpass) {
        if (value >= 100) return maxHz;
        return Math.round(minHz + (Math.pow(10, (value / 100) * 3) / 1000) * (maxHz - minHz));
      } else {
        if (value <= 0) return minHz;
        return Math.round(minHz + (Math.pow(10, (value / 100) * 3) / 1000) * (maxHz - minHz));
      }
    }



    // Sound Generation: Loop-Safe White Noise buffer
    function createNoiseBuffer(ctx: AudioContext): AudioBuffer {
      const sampleRate = ctx.sampleRate;
      const bufferSize = sampleRate * 2; // 2 seconds of noise buffer
      const buffer = ctx.createBuffer(2, bufferSize, sampleRate);
      for (let channel = 0; channel < buffer.numberOfChannels; channel++) {
        const data = buffer.getChannelData(channel);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
      }
      return buffer;
    }

    // Sound Generation: Rain texture filter modulation
    // Creates a noise buffer specifically filtered & modulated
    function startRainSynthesis(ctx: AudioContext) {
      if (!rainToggle.checked || !ctx) return;
      
      if (rainSource) {
        try { rainSource.stop(); } catch (e) {}
        rainSource.disconnect();
      }

      rainSource = ctx.createBufferSource();
      rainSource.buffer = createNoiseBuffer(ctx);
      rainSource.loop = true;

      rainGain = ctx.createGain();
      rainFilter1 = ctx.createBiquadFilter();
      rainFilter1.type = 'bandpass';
      rainFilter1.frequency.value = 1600;
      rainFilter1.Q.value = 1.2;

      rainFilter2 = ctx.createBiquadFilter();
      rainFilter2.type = 'highpass';
      rainFilter2.frequency.value = 900;

      // Connect: Rain Source -> BP -> HP -> Rain Gain -> LP Filter
      rainSource.connect(rainFilter1);
      rainFilter1.connect(rainFilter2);
      rainFilter2.connect(rainGain);
      
      if (lpFilterNode) {
        rainGain.connect(lpFilterNode);
      }

      const rainVolumeVal = parseInt(rainVolume.value) / 100;
      rainGain.gain.setValueAtTime(rainVolumeVal * 0.45, ctx.currentTime);

      rainSource.start(0);
    }

    function stopRainSynthesis() {
      if (rainSource) {
        try { rainSource.stop(); } catch (e) {}
        rainSource.disconnect();
        rainSource = null;
      }
      rainGain = null;
      rainFilter1 = null;
      rainFilter2 = null;
    }

    // Sound Generation: Fan LFO Modulation
    function startFanSynthesis(ctx: AudioContext) {
      if (!fanToggle.checked || !ctx) return;

      if (fanSource) {
        try { fanSource.stop(); } catch (e) {}
        fanSource.disconnect();
      }

      fanSource = ctx.createBufferSource();
      fanSource.buffer = createNoiseBuffer(ctx);
      fanSource.loop = true;

      fanGain = ctx.createGain();
      fanFilter = ctx.createBiquadFilter();
      fanFilter.type = 'lowpass';
      fanFilter.frequency.value = 95; // Deep fan rumble base

      // LFO for blade-chopping effect (15Hz rotation speed)
      fanLfo = ctx.createOscillator();
      fanLfo.type = 'sine';
      fanLfo.frequency.value = 16; 

      fanLfoGain = ctx.createGain();
      fanLfoGain.gain.value = 0.22; // blade vibration depth

      // Connect LFO to modulate gain
      fanLfo.connect(fanLfoGain);
      fanLfoGain.connect(fanGain.gain);

      // Connect: Fan Source -> LP -> Fan Gain -> LP Filter
      fanSource.connect(fanFilter);
      fanFilter.connect(fanGain);
      
      if (lpFilterNode) {
        fanGain.connect(lpFilterNode);
      }

      const fanVolumeVal = parseInt(fanVolume.value) / 100;
      // Set base volume of the fan rumble
      fanGain.gain.setValueAtTime(fanVolumeVal * 0.6, ctx.currentTime);

      fanSource.start(0);
      fanLfo.start(0);
    }

    function stopFanSynthesis() {
      if (fanSource) {
        try { fanSource.stop(); } catch (e) {}
        fanSource.disconnect();
        fanSource = null;
      }
      if (fanLfo) {
        try { fanLfo.stop(); } catch (e) {}
        fanLfo.disconnect();
        fanLfo = null;
      }
      fanGain = null;
      fanFilter = null;
      fanLfoGain = null;
    }

    // Primary Playback Engine
    function startAudio(userGesture = false) {
      if (userGesture) {
        initAudio();
      }
      if (!audioCtx) return;

      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }

      if (isPlaying) {
        pauseAudio();
        return;
      }

      // Start White Noise Layer
      whiteNoiseSource = audioCtx.createBufferSource();
      whiteNoiseSource.buffer = createNoiseBuffer(audioCtx);
      whiteNoiseSource.loop = true;

      whiteNoiseGain = audioCtx.createGain();
      whiteNoiseSource.connect(whiteNoiseGain);
      
      if (lpFilterNode) {
        whiteNoiseGain.connect(lpFilterNode);
      }

      // Turn on White Noise Base gain
      whiteNoiseGain.gain.setValueAtTime(0.5, audioCtx.currentTime);

      // Start Mixins
      startRainSynthesis(audioCtx);
      startFanSynthesis(audioCtx);

      // Update control nodes
      updateNodeValues();

      // Trigger smooth fade in transition
      const targetGainVal = parseInt(volumeSlider.value) / 100;
      if (mainGainNode) {
        mainGainNode.gain.cancelScheduledValues(audioCtx.currentTime);
        mainGainNode.gain.setValueAtTime(mainGainNode.gain.value, audioCtx.currentTime);
        mainGainNode.gain.linearRampToValueAtTime(targetGainVal, audioCtx.currentTime + 0.65);
      }

      whiteNoiseSource.start(0);

      isPlaying = true;
      updateUI();
      startVisualizer();
      saveSettingsToLS();
    }

    function pauseAudio() {
      if (!audioCtx || !isPlaying) return;

      const currentGain = mainGainNode ? mainGainNode.gain.value : 0;
      
      // Smooth fade out before pausing
      if (mainGainNode) {
        mainGainNode.gain.cancelScheduledValues(audioCtx.currentTime);
        mainGainNode.gain.setValueAtTime(currentGain, audioCtx.currentTime);
        mainGainNode.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.55);
      }

      // Stop sources after fade duration
      setTimeout(() => {
        if (!isPlaying) {
          // If we haven't resumed in the meantime
          stopAllSources();
        }
      }, 600);

      isPlaying = false;
      updateUI();
      saveSettingsToLS();
    }

    function stopAudio() {
      if (!audioCtx) return;
      
      if (mainGainNode) {
        mainGainNode.gain.cancelScheduledValues(audioCtx.currentTime);
        mainGainNode.gain.setValueAtTime(mainGainNode.gain.value, audioCtx.currentTime);
        mainGainNode.gain.linearRampToValueAtTime(0.001, audioCtx.currentTime + 0.4);
      }

      setTimeout(() => {
        stopAllSources();
        isPlaying = false;
        isFadingOut = false;
        stopTimer();
        updateUI();
      }, 450);
    }

    function stopAllSources() {
      if (whiteNoiseSource) {
        try { whiteNoiseSource.stop(); } catch (e) {}
        whiteNoiseSource.disconnect();
        whiteNoiseSource = null;
      }
      whiteNoiseGain = null;

      stopRainSynthesis();
      stopFanSynthesis();
      stopVisualizer();
    }

    // Refresh actual sound variables from sliders
    function updateNodeValues() {
      if (!audioCtx) return;

      // Master Volume
      const vol = parseInt(volumeSlider.value);
      const gainVal = vol / 100;
      const db = vol > 0 ? (20 * Math.log10(gainVal)).toFixed(1) : "-∞";
      volumeReadout.textContent = `${vol}% (${db} dB)`;
      if (mainGainNode && isPlaying && !isFadingOut) {
        mainGainNode.gain.setValueAtTime(gainVal, audioCtx.currentTime);
      }

      // Stereo Pan
      const pan = parseInt(panSlider.value) / 100;
      if (pan === 0) {
        panReadout.textContent = "Center";
      } else if (pan < 0) {
        panReadout.textContent = `L ${Math.abs(Math.round(pan * 100))}%`;
      } else {
        panReadout.textContent = `R ${Math.round(pan * 100)}%`;
      }
      if (pannerNode) {
        pannerNode.pan.setValueAtTime(pan, audioCtx.currentTime);
      }

      // Low Pass filter frequency mapping
      const lpVal = parseInt(lpSlider.value);
      const lpFreq = getFilterFreq(lpVal, true);
      lpReadout.textContent = lpFreq === 20000 ? "Bypass" : `${lpFreq.toLocaleString()} Hz`;
      if (lpFilterNode) {
        lpFilterNode.frequency.setValueAtTime(lpFreq, audioCtx.currentTime);
      }

      // High Pass filter frequency mapping
      const hpVal = parseInt(hpSlider.value);
      const hpFreq = getFilterFreq(hpVal, false);
      hpReadout.textContent = hpFreq === 20 ? "Bypass" : `${hpFreq.toLocaleString()} Hz`;
      if (hpFilterNode) {
        hpFilterNode.frequency.setValueAtTime(hpFreq, audioCtx.currentTime);
      }

      // Update Filter Description tag
      if (lpVal === 100 && hpVal === 0) {
        eqTiltDesc.textContent = "Pure White Noise";
      } else if (lpVal < 35 && hpVal === 0) {
        eqTiltDesc.textContent = "Deep Brown Noise (Ocean/Rumble)";
      } else if (lpVal < 60 && hpVal === 0) {
        eqTiltDesc.textContent = "Soft Pink Noise (Rainfall)";
      } else if (hpVal > 30) {
        eqTiltDesc.textContent = "High-Static Masking";
      } else {
        eqTiltDesc.textContent = "Custom Sculpted EQ";
      }

      // Rain Gain
      const rainVolVal = parseInt(rainVolume.value) / 100;
      rainVolReadout.textContent = `Vol: ${rainVolume.value}%`;
      if (rainGain && rainToggle.checked) {
        rainGain.gain.setValueAtTime(rainVolVal * 0.45, audioCtx.currentTime);
      }

      // Fan Gain
      const fanVolVal = parseInt(fanVolume.value) / 100;
      fanVolReadout.textContent = `Vol: ${fanVolume.value}%`;
      if (fanGain && fanToggle.checked) {
        fanGain.gain.setValueAtTime(fanVolVal * 0.6, audioCtx.currentTime);
      }
    }

