    });

    // Keyboard navigation
    window.addEventListener("keydown", (e) => {
      // Prevent hijacking native text inputs
      if (document.activeElement?.tagName === "INPUT" || document.activeElement?.tagName === "TEXTAREA") {
        return;
      }

      if (e.code === "Space") {
        e.preventDefault();
        initAudio();
        startAudio(true);
      } else if (e.code === "ArrowUp") {
        e.preventDefault();
        let vol = parseInt(volumeSlider.value);
        vol = Math.min(100, vol + 5);
        volumeSlider.value = vol.toString();
        updateNodeValues();
        saveSettingsToLS();
      } else if (e.code === "ArrowDown") {
        e.preventDefault();
        let vol = parseInt(volumeSlider.value);
        vol = Math.max(0, vol - 5);
        volumeSlider.value = vol.toString();
        updateNodeValues();
        saveSettingsToLS();
      } else if (e.code === "Escape") {
        e.preventDefault();
        stopAudio();
      }
    });

    // Mobile gesture enablement
    enableAudioBtn.addEventListener("click", () => {
      initAudio();
      startAudio(true);
    });
    
    resumeAudioBtn.addEventListener("click", () => {
      if (audioCtx) {
        audioCtx.resume();
      }
    });

    // Tab close node cleanup
    window.addEventListener("beforeunload", () => {
      if (audioCtx) {
        audioCtx.close();
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Page Load Startup sequence
    checkInitialGesture();
    parseSharedConfig();
    loadSettingsFromLS();
    loadCustomPresets();
    stopVisualizer(); // Init silent visualizer line
  </script>

