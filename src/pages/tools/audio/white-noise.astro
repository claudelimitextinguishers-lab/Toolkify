    // Visualizer switch toggle
    visualizerToggle.addEventListener("click", () => {
      visualizerStyle = visualizerStyle === "spectrum" ? "waveform" : "spectrum";
      visualizerHzLabel.textContent = visualizerStyle === "spectrum" ? "Frequency View" : "Time Domain View";
      if (isPlaying) {
        stopVisualizer();
        startVisualizer();
      } else {
        stopVisualizer();
      }
    });

    // Share link trigger
    function handleShare() {
      const url = getShareableURL();
      const shareData = {
        title: document.title || "White Noise Generator",
        url: url
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url);
          }
        });
      } else {
        copyToClipboard(url);
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
        toastMessage.classList.remove("hidden");
        setTimeout(() => {
          toastMessage.classList.add("hidden");
        }, 2000);
      }
    }

    btnCopySettings.addEventListener("click", handleShare);
    shareBtn?.addEventListener("click", handleShare);

