---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Time Zone Converter";
const category = "general";
const tier = "General Everyday Utilities";

// On-page SEO metadata
const pageTitle = "Time Zone Converter - World & Meeting Time Zone Converter";
const description = "Free time zone converter to compare world time zones instantly. Convert Pacific time, plan meetings across multiple time zones, and find the best overlap with a DST-aware, privacy-first world time zone converter.";
const canonicalUrl = "https://toolkify.app/tools/general/time-zone-converter";
const ogImage = "/og/time-zone-converter.png";
const keywords = "time zone converter, pacific time zone converter, time zone converter for meetings, world time zone converter, multiple time zone converter, gmt converter, what time zone am i in, dst aware timezone, world clock, meeting planner";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Time Zone Converter",
      "alternateName": "Client-Side World Clock & Meeting Planner",
      "url": "https://toolkify.app/tools/general/time-zone-converter",
      "description": "Free offline client-side world clock converter. Plan meetings across multiple timezones with a visual 24-hour day/night slider and auto overlap finder.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Dynamic DST-aware conversion using Intl API",
        "Searchable timezone picker with fuzzy matching",
        "Live ticking clock for current moment simulation",
        "Visual 24-hour day/night and business hour bars",
        "Automatic meeting-time overlap finder",
        "Named user presets for team schedules",
        "URL query parameters to share configured times"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "General Tools",
          "item": "https://toolkify.app/tools/general"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Time Zone Converter",
          "item": "https://toolkify.app/tools/general/time-zone-converter"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is my time zone GMT converter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A \"what is my time zone GMT converter\" is a tool that detects your current local time zone and shows how it relates to Greenwich Mean Time (GMT/UTC). This time zone converter automatically reads your device's zone through your browser and displays your offset from GMT &mdash; for example GMT-8 for Pacific Time or GMT+5:30 for India &mdash; so you can instantly convert your local time to and from GMT and any other world time zone.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What time zone am I in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Your time zone is determined by your geographic location and its offset from GMT/UTC. This world time zone converter reads your browser's settings to identify the IANA zone you are in (such as America/Los_Angeles for Pacific Time or Europe/London for GMT) and shows your live local time. Because the tool is DST-aware, it also accounts for daylight saving time, so the zone and offset it reports for \"what time zone am I in\" stay accurate throughout the year.</p>"
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button verbatim from json-formatter.astro -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How time zone converter works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button verbatim from json-formatter.astro -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-3 sm:p-4 flex flex-col gap-3.5 print:border-none print:shadow-none print:bg-transparent print:p-0">
      <!-- Upper Panel: Core Inputs -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-3.5 border-b border-hairline-soft pb-3.5">
        <!-- Left: Source Date, Time, Zone -->
        <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-3 gap-3">
          <div class="flex flex-col gap-1">
            <label for="source-date" class="text-[10px] font-semibold text-slate">Source Date</label>
            <input
              type="date"
              id="source-date"
              class="text-input w-full py-1 px-2.5 text-xs h-9 cursor-pointer border border-hairline-strong bg-canvas rounded-md focus:border-brand-blue outline-none"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="source-time" class="text-[10px] font-semibold text-slate">Source Time</label>
            <div class="flex items-center gap-1.5">
              <input
                type="time"
                id="source-time"
                class="text-input flex-1 py-1 px-2.5 text-xs h-9 cursor-pointer border border-hairline-strong bg-canvas rounded-md focus:border-brand-blue outline-none"
              />
              <button
                type="button"
                id="live-tick-btn"
                class="h-9 px-2 bg-canvas hover:bg-surface border border-hairline text-brand-blue rounded-md text-[10px] font-bold flex items-center gap-1 shrink-0 transition-all shadow-subtle"
                title="Lock to current moment and tick live"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-brand-blue animate-ping" id="live-tick-indicator"></span>
                <span>Live</span>
              </button>
            </div>
          </div>

          <div class="flex flex-col gap-1 relative">
            <label for="source-tz" class="text-[10px] font-semibold text-slate">Source Timezone</label>
            <input
              type="text"
              id="source-tz"
              class="text-input w-full py-1 px-2.5 text-xs h-9 border border-hairline-strong bg-canvas rounded-md focus:border-brand-blue outline-none"
              placeholder="Search e.g. New York..."
              autocomplete="off"
            />
            <div
              id="source-tz-autocomplete"
              class="absolute top-14 left-0 w-full bg-canvas border border-hairline-strong rounded-md shadow-modal max-h-48 overflow-y-auto hidden z-30 text-xs"
            ></div>
          </div>
        </div>

        <!-- Right: Utility Controls & Presets -->
        <div class="lg:col-span-4 flex flex-col justify-end gap-3.5">
          <div class="flex items-center justify-between gap-2">
            <!-- 12h/24h toggle switch -->
            <div class="flex flex-col gap-0.5">
              <span class="text-[10px] font-semibold text-slate">Display Format</span>
              <div class="flex rounded-full bg-surface p-0.5 border border-hairline h-8 items-center w-24">
                <button
                  type="button"
                  id="format-12h-btn"
                  class="flex-1 text-center text-[9px] py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas h-full flex items-center justify-center"
                >
                  12H
                </button>
                <button
                  type="button"
                  id="format-24h-btn"
                  class="flex-1 text-center text-[9px] py-1 rounded-full font-bold transition-all cursor-pointer text-slate h-full flex items-center justify-center"
                >
                  24H
                </button>
              </div>
            </div>

            <!-- Presets control -->
            <div class="flex flex-col gap-0.5 flex-1 max-w-[180px]">
              <label for="preset-select" class="text-[10px] font-semibold text-slate">Presets</label>
              <select
                id="preset-select"
                class="text-input w-full py-0.5 px-2 text-[11px] h-8 cursor-pointer border border-hairline-strong bg-canvas rounded-md"
              >
                <option value="">-- Choose Set --</option>
                <option value="my-team">My Team (Default)</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Workspace: Add Zone Input + Comparison List + Overlap Finder -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-stretch relative">
        <!-- Top Toolbar of comparison area -->
        <div class="lg:col-span-12 flex flex-wrap items-center justify-between gap-2.5">
          <div class="flex items-center gap-2 flex-grow max-w-sm relative">
            <input
              type="text"
              id="add-zone-search"
              class="text-input w-full py-1 px-3 text-xs h-8.5 border border-hairline-strong bg-canvas rounded-md focus:border-brand-blue outline-none"
              placeholder="🔍 Add zone (e.g. London, UTC+1, PST)..."
              autocomplete="off"
            />
            <div
              id="add-zone-autocomplete"
              class="absolute top-9 left-0 w-full bg-canvas border border-hairline-strong rounded-md shadow-modal max-h-48 overflow-y-auto hidden z-30 text-xs"
            ></div>
          </div>

          <!-- Quick Regions list -->
          <div class="flex items-center gap-1.5 flex-wrap">
            <span class="text-[10px] text-stone font-bold uppercase">Quick Add:</span>
            <button type="button" data-region="Americas" class="quick-add-region-btn text-[10px] px-2 py-0.5 bg-surface hover:bg-hairline border border-hairline rounded-full text-slate transition-all font-semibold">Americas</button>
            <button type="button" data-region="Europe" class="quick-add-region-btn text-[10px] px-2 py-0.5 bg-surface hover:bg-hairline border border-hairline rounded-full text-slate transition-all font-semibold">Europe</button>
            <button type="button" data-region="Asia" class="quick-add-region-btn text-[10px] px-2 py-0.5 bg-surface hover:bg-hairline border border-hairline rounded-full text-slate transition-all font-semibold">Asia-Pac</button>
          </div>

          <!-- Utility buttons -->
          <div class="flex items-center gap-1.5">
            <button
              type="button"
              id="btn-copy-summary"
              class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-md transition-all cursor-pointer"
              title="Copy text summary of current times"
            >
              📋 Copy Summary
            </button>
            <button
              type="button"
              id="btn-share-link"
              class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-md transition-all cursor-pointer"
              title="Copy shareable link"
            >
              🔗 Share Link
            </button>
          </div>
        </div>

        <!-- Left Column: Added Timezones list -->
        <div class="lg:col-span-8 flex flex-col gap-2 min-h-[220px] lg:max-h-[380px] overflow-y-auto" id="zone-cards-list">
          <!-- Dynamic cards injected here -->
        </div>

        <!-- Right Column: Meeting Time Overlap Finder & Preset Config -->
        <div class="lg:col-span-4 flex flex-col gap-3">
          <!-- Meeting Time Overlap Finder -->
          <div class="card-base bg-surface-soft border border-hairline p-3 flex flex-col gap-2 rounded-lg flex-1">
            <h3 class="font-display font-semibold text-xs text-primary flex items-center gap-1">
              <span>🤝 Meeting Time Finder</span>
              <span id="overlap-sweep" class="hidden text-[9px] bg-brand-blue/15 text-brand-blue py-0.5 px-1.5 rounded animate-pulse">Analyzing...</span>
            </h3>
            <p class="text-[10px] text-slate leading-relaxed">
              Finds hours when all zones are in waking hours (<strong>8am - 8pm</strong> local time).
            </p>
            <div id="overlap-results" class="flex flex-col gap-1.5 mt-1 overflow-y-auto max-h-[160px] pr-1">
              <!-- Overlap slots injected here -->
            </div>
          </div>

          <!-- Save Preset Box -->
          <div class="card-base border border-hairline-soft p-3 flex flex-col gap-1.5 rounded-lg bg-canvas">
            <h4 class="text-[10px] font-bold text-slate uppercase">Save Current Set</h4>
            <div class="flex items-center gap-1.5">
              <input
                type="text"
                id="new-preset-name"
                class="text-input flex-1 py-1 px-2 text-xs h-7 border border-hairline-strong bg-canvas rounded-md outline-none"
                placeholder="e.g. Sales Team..."
              />
              <button
                type="button"
                id="btn-save-preset"
                class="button-primary text-[10px] h-7 px-3 flex items-center justify-center font-bold"
              >
                Save
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Action feedback toast -->
      <div
        id="toast-message"
        class="fixed bottom-4 right-4 bg-success-accent text-canvas text-xs font-bold py-2 px-4 rounded-md shadow-modal opacity-0 transition-opacity duration-300 pointer-events-none z-50"
      >
        Copied to clipboard!
      </div>
    </div>

    <RelatedTools currentSlug="time-zone-converter" />

    <!-- Security & Privacy Guard Tag -->
    <div class="flex items-center justify-between text-[10px] text-slate px-1 print:hidden">
      <span class="flex items-center gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3 h-3 text-success-accent"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
          ></path>
        </svg>
        100% Offline Client-Side, Built-In Browser Intl API
      </span>
      <span>v1.0.0</span>
    </div>
  </section>

  <!-- Educational Article -->
  <section
    class="max-w-[760px] w-full mx-auto px-4 pb-20 flex flex-col gap-8 text-slate print:hidden"
    aria-labelledby="about-tool-heading"
  >
    <article class="flex flex-col gap-4">
      <h2
        id="about-tool-heading"
        class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight"
      >
        Free World & Meeting Time Zone Converter
      </h2>
      <p class="text-sm leading-relaxed">
        This <strong>time zone converter</strong> is a fast, free, and private
        way to compare the current time across cities and regions all over the
        planet. Whether you are coordinating a call with a client overseas,
        checking when a live stream starts, or simply answering the question
        "what time is it there right now?", this
        <strong>world time zone converter</strong> gives you an accurate,
        DST-aware answer in seconds. Every calculation runs entirely inside your
        browser using the native <code>Intl</code> API, so your dates, times, and
        saved locations never leave your device &mdash; making it a genuinely
        private tool on desktop, tablet, and phone.
      </p>
      <p class="text-sm leading-relaxed">
        Unlike a basic clock that only shows one location, this
        <strong>multiple time zone converter</strong> lets you stack as many
        cities as you need side by side. Add New York, London, Tokyo, and your
        own home zone, then watch every clock update live at once. A visual
        24-hour day/night bar sits beside each location so you can see at a glance
        who is awake, who is at work, and who is asleep &mdash; turning a messy
        mental calculation into a clear, colour-coded picture.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        A Time Zone Converter Built for Meetings
      </h3>
      <p class="text-sm leading-relaxed">
        Scheduling across borders is where a good
        <strong>time zone converter for meetings</strong> earns its keep. Instead
        of guessing whether 9 AM in one city is a reasonable hour for everyone
        else, the built-in Meeting Time Finder scans all 24 hours of the day and
        highlights the slots where every added location falls within comfortable
        waking hours (8 AM to 8 PM local time). One click on a suggested slot sets
        the source time for the whole board, so you can lock in a fair meeting
        time that respects everyone's morning coffee and evening dinner. You can
        also save named presets &mdash; like "Sales Team" or "APAC Standup"
        &mdash; and reload the exact set of zones whenever you need them.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Pacific Time, GMT, and Every Zone In Between
      </h3>
      <p class="text-sm leading-relaxed">
        Need a dedicated <strong>Pacific time zone converter</strong>? Just add
        Los Angeles or search for "PST" or "PDT" and this tool handles the rest,
        automatically switching between Pacific Standard Time and Pacific Daylight
        Time depending on the date you choose. The same applies to GMT/UTC, Eastern
        Time, Central European Time, India Standard Time, and hundreds of other
        regions from the full IANA database. You can type a city name, a common
        abbreviation, or even a UTC offset, and the smart search will surface the
        right match. This makes it equally useful as a
        <strong>world time zone converter</strong> for global teams and as a quick
        GMT converter for anyone who just wants to know their offset from Greenwich
        Mean Time.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Why DST-Aware Conversion Matters
      </h3>
      <p class="text-sm leading-relaxed">
        Many simple calculators just add or subtract a fixed UTC offset, which
        breaks twice a year when clocks change. Because daylight saving rules vary
        by region and shift on different dates, a static offset can leave you an
        hour early or an hour late for an important call. By leaning on the
        browser's <code>Intl.DateTimeFormat</code> API and the full IANA time zone
        database, this converter determines whether each region observes daylight
        saving on your selected date &mdash; past, present, or future &mdash; so
        the times you see are always trustworthy.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        How to Use the World Time Zone Converter
      </h3>
      <p class="text-sm leading-relaxed">
        Getting started takes seconds. Pick a source date, time, and time zone
        (or hit <strong>Live</strong> to lock everything to the current moment and
        watch it tick in real time). Then add the locations you care about using
        the search box or the quick-add region buttons for the Americas, Europe,
        and Asia-Pacific. Toggle between 12-hour and 24-hour display, copy a plain
        text summary of all times for pasting into an email or chat, or grab a
        shareable link that reopens the exact same setup for a colleague. As a
        complete <strong>multiple time zone converter</strong>, it remembers your
        zones locally so the board is ready the next time you visit &mdash; no
        sign-up, no ads in the way, and nothing to install.
      </p>
    </article>

    <!-- Visible FAQ matching FAQ JSON-LD -->
    <div class="flex flex-col gap-6 max-w-4xl mx-auto w-full mt-12">
      <h2 class="font-display font-semibold text-xl sm:text-2xl tracking-tight text-primary text-center mb-1">
        Time Zone Converter FAQs
      </h2>
      <p class="text-xs text-slate text-center mb-4">
        Find answers to the most common questions about time zones, GMT offsets, and detecting your local zone.
      </p>

      <div class="flex flex-col border border-hairline rounded-xl bg-canvas overflow-hidden shadow-subtle divide-y divide-hairline">
        <!-- FAQ 1 -->
        <div class="faq-accordion-item group">
          <button
            type="button"
            class="faq-toggle-btn w-full text-left font-display font-medium text-[15px] sm:text-base text-primary flex items-center justify-between cursor-pointer px-6 py-4.5 hover:bg-surface-soft transition-colors duration-200"
            aria-expanded="false"
          >
            <span>What is my time zone GMT converter?</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 text-stone group-hover:text-primary transition-transform duration-200 shrink-0 ml-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5 pt-1 text-sm text-slate leading-relaxed border-t border-hairline-soft/30 bg-surface-soft/10">
            <p>A "what is my time zone GMT converter" is a tool that detects your current local time zone and shows how it relates to Greenwich Mean Time (GMT/UTC). This time zone converter automatically reads your device's zone through your browser and displays your offset from GMT &mdash; for example GMT-8 for Pacific Time or GMT+5:30 for India &mdash; so you can instantly convert your local time to and from GMT and any other world time zone.</p>
          </div>
        </div>

        <!-- FAQ 2 -->
        <div class="faq-accordion-item group">
          <button
            type="button"
            class="faq-toggle-btn w-full text-left font-display font-medium text-[15px] sm:text-base text-primary flex items-center justify-between cursor-pointer px-6 py-4.5 hover:bg-surface-soft transition-colors duration-200"
            aria-expanded="false"
          >
            <span>What time zone am I in?</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 text-stone group-hover:text-primary transition-transform duration-200 shrink-0 ml-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5 pt-1 text-sm text-slate leading-relaxed border-t border-hairline-soft/30 bg-surface-soft/10">
            <p>Your time zone is determined by your geographic location and its offset from GMT/UTC. This world time zone converter reads your browser's settings to identify the IANA zone you are in (such as America/Los_Angeles for Pacific Time or Europe/London for GMT) and shows your live local time. Because the tool is DST-aware, it also accounts for daylight saving time, so the zone and offset it reports for "what time zone am I in" stay accurate throughout the year.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works Modal (Verbatim Structure from json-formatter.astro) -->
  <div
    id="how-it-works-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div
      class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto"
    >
      <div
        class="flex justify-between items-center pb-2 border-b border-hairline-soft"
      >
        <h3 class="font-display font-semibold text-lg text-primary">
          Time Zone Converter Guide
        </h3>
        <button
          type="button"
          id="close-modal-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >
          ✕
        </button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">
          1. DST-Aware Dynamic Conversion
        </h4>
        <p>
          This tool uses modern browser APIs to match the full IANA Database. The offset adjusts automatically based on the year, month, and day of the selected source date.
        </p>

        <h4 class="font-semibold text-primary">2. Visual Schedule Bars</h4>
        <p>
          Each added location displays a 24-hour horizontal bar. Nighttime hours (10pm to 6am) are shaded dark, standard working hours (9am to 5pm) are highlighted in teal, and sleeping hours are represented by smooth twilight transitions.
        </p>

        <h4 class="font-semibold text-primary">
          3. Meeting Time Finder Helper
        </h4>
        <p>
          Calculates the optimal hours of overlap where all added zones fall within waking hours (8:00 AM to 8:00 PM). Green highlight rings indicate suitable overlap options.
        </p>

        <h4 class="font-semibold text-primary">
          4. Zero Server Footprint
        </h4>
        <p>
          Just like all TOOLKIFY utilities, your configurations, times, and location setups stay locally stored in your browser. Absolutely zero data is logged or sent online.
        </p>
      </div>
      <button
        type="button"
        id="modal-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
      </button>
    </div>
  </div>

  <!-- Client-side script -->
  <script>
    if (typeof window !== 'undefined') {
    // Supported Timezones
    let allTimezones: string[] = [];
    try {
      allTimezones = (Intl as any).supportedValuesOf('timeZone');
    } catch(e) {
      // Fallback
      allTimezones = [
        "UTC", "GMT", "Europe/London", "Europe/Paris", "Europe/Berlin", "Europe/Rome",
        "America/New_York", "America/Chicago", "America/Denver", "America/Los_Angeles",
        "America/Anchorage", "America/Adak", "Pacific/Honolulu", "Asia/Tokyo", "Asia/Shanghai",
        "Asia/Singapore", "Asia/Kolkata", "Asia/Seoul", "Asia/Dubai", "Australia/Sydney",
        "Australia/Melbourne", "Pacific/Auckland", "America/Sao_Paulo", "America/Argentina/Buenos_Aires"
      ];
    }

    // Common abbreviations list to assist search matching
    const tzAbbreviations: Record<string, string[]> = {
      "EST": ["America/New_York", "America/Detroit", "America/Indianapolis", "America/Toronto"],
      "EDT": ["America/New_York", "America/Detroit", "America/Toronto"],
      "CST": ["America/Chicago", "America/Winnipeg", "America/Mexico_City"],
      "CDT": ["America/Chicago", "America/Winnipeg", "America/Mexico_City"],
      "PST": ["America/Los_Angeles", "America/Vancouver", "America/Tijuana"],
      "PDT": ["America/Los_Angeles", "America/Vancouver"],
      "MST": ["America/Denver", "America/Phoenix", "America/Edmonton"],
      "MDT": ["America/Denver", "America/Edmonton"],
      "GMT": ["Europe/London", "Europe/Dublin", "Africa/Casablanca"],
      "BST": ["Europe/London", "Europe/Dublin"],
      "CET": ["Europe/Paris", "Europe/Berlin", "Europe/Rome", "Europe/Madrid", "Europe/Amsterdam"],
      "CEST": ["Europe/Paris", "Europe/Berlin", "Europe/Rome", "Europe/Madrid", "Europe/Amsterdam"],
      "JST": ["Asia/Tokyo"],
      "KST": ["Asia/Seoul"],
      "IST": ["Asia/Kolkata"],
      "AEDT": ["Australia/Sydney", "Australia/Melbourne"],
      "AEST": ["Australia/Sydney", "Australia/Melbourne"],
      "NZDT": ["Pacific/Auckland"],
      "NZST": ["Pacific/Auckland"]
    };

    // State definitions
    interface ToolState {
      sourceDate: string; // YYYY-MM-DD
      sourceTime: string; // HH:MM
      sourceTz: string;
      isLive: boolean;
      format24h: boolean;
      targetZones: string[];
    }

    let state: ToolState = {
      sourceDate: new Date().toISOString().split('T')[0],
      sourceTime: new Date().toTimeString().split(' ')[0].substring(0, 5),
      sourceTz: Intl.DateTimeFormat().resolvedOptions().timeZone || "UTC",
      isLive: true,
      format24h: false,
      targetZones: ["UTC", "America/New_York", "Europe/London", "Asia/Tokyo"]
    };

    // DOM references
    const sourceDateInput = document.getElementById("source-date") as HTMLInputElement;
    const sourceTimeInput = document.getElementById("source-time") as HTMLInputElement;
    const sourceTzInput = document.getElementById("source-tz") as HTMLInputElement;
    const sourceTzAutocomplete = document.getElementById("source-tz-autocomplete") as HTMLDivElement;
    const liveTickBtn = document.getElementById("live-tick-btn") as HTMLButtonElement;
    const liveTickIndicator = document.getElementById("live-tick-indicator") as HTMLSpanElement;
    const format12hBtn = document.getElementById("format-12h-btn") as HTMLButtonElement;
    const format24hBtn = document.getElementById("format-24h-btn") as HTMLButtonElement;
    const presetSelect = document.getElementById("preset-select") as HTMLSelectElement;
    const addZoneSearch = document.getElementById("add-zone-search") as HTMLInputElement;
    const addZoneAutocomplete = document.getElementById("add-zone-autocomplete") as HTMLDivElement;
    const zoneCardsList = document.getElementById("zone-cards-list") as HTMLDivElement;
    const overlapResults = document.getElementById("overlap-results") as HTMLDivElement;
    const overlapSweep = document.getElementById("overlap-sweep") as HTMLSpanElement;
    const newPresetNameInput = document.getElementById("new-preset-name") as HTMLInputElement;
    const btnSavePreset = document.getElementById("btn-save-preset") as HTMLButtonElement;
    const btnCopySummary = document.getElementById("btn-copy-summary") as HTMLButtonElement;
    const btnShareLink = document.getElementById("btn-share-link") as HTMLButtonElement;
    const toastMessage = document.getElementById("toast-message") as HTMLDivElement;

    // Reset and modal buttons verbatim
    const btnShare = document.getElementById("share-btn") as HTMLButtonElement;
    const btnReset = document.getElementById("reset-btn") as HTMLButtonElement;
    const btnHowItWorks = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;

    // Shared ticking interval
    let tickInterval: number | null = null;
    let draggedZoneIndex: number | null = null;

    // Initialize State
    function init() {
      // 1. Restore state from URL or LocalStorage
      const urlParams = new URLSearchParams(window.location.search);
      const timeParam = urlParams.get("time");
      const dateParam = urlParams.get("date");
      const stzParam = urlParams.get("stz");
      const zonesParam = urlParams.get("zones");

      if (timeParam && dateParam) {
        state.sourceTime = timeParam;
        state.sourceDate = dateParam;
        state.isLive = false;
      }
      if (stzParam) {
        state.sourceTz = decodeURIComponent(stzParam);
      }
      if (zonesParam) {
        state.targetZones = decodeURIComponent(zonesParam).split(",");
      } else {
        // Fallback to local storage
        const savedZones = localStorage.getItem("toolkify:time-zone-converter:targetZones");
        if (savedZones) {
          state.targetZones = JSON.parse(savedZones);
        }
      }

      const savedFormat = localStorage.getItem("toolkify:time-zone-converter:format24h");
      if (savedFormat !== null) {
        state.format24h = savedFormat === "true";
      }

      // Sync form displays
      sourceDateInput.value = state.sourceDate;
      sourceTimeInput.value = state.sourceTime;
      sourceTzInput.value = state.sourceTz;

      updateFormatButtons();
      loadPresetsList();

      if (state.isLive) {
        startLiveTicking();
      } else {
        stopLiveTicking();
      }

      renderComparisonList();
      calculateOverlap();
    }

    function showToast(msg: string) {
      toastMessage.textContent = msg;
      toastMessage.classList.remove("opacity-0");
      toastMessage.classList.add("opacity-100");
      setTimeout(() => {
        toastMessage.classList.remove("opacity-100");
        toastMessage.classList.add("opacity-0");
      }, 2000);
    }

    // DST aware timezone offset finder
    function getTzOffsetMinutes(timeZone: string, date: Date): number {
      try {
        const parts = new Intl.DateTimeFormat('en-US', {
          timeZone,
          timeZoneName: 'longOffset'
        }).formatToParts(date);
        let tzPart = parts.find(p => p.type === 'timeZoneName')?.value || '';
        if (!tzPart || tzPart === 'GMT' || tzPart === 'UTC') return 0;

        // Normalize minus signs
        tzPart = tzPart.replace(/[\u2212−]/g, '-');

        // Match GMT+05:30 or GMT-05:30
        const matchColon = tzPart.match(/GMT([+-])(\d+):(\d+)/);
        if (matchColon) {
          const sign = matchColon[1] === '+' ? 1 : -1;
          return sign * (parseInt(matchColon[2], 10) * 60 + parseInt(matchColon[3], 10));
        }

        // Match GMT+0530 or GMT-0530
        const matchNoColon = tzPart.match(/GMT([+-])(\d{2})(\d{2})/);
        if (matchNoColon) {
          const sign = matchNoColon[1] === '+' ? 1 : -1;
          return sign * (parseInt(matchNoColon[2], 10) * 60 + parseInt(matchNoColon[3], 10));
        }

        // Match GMT+5.5 or GMT-5.5
        const matchDecimal = tzPart.match(/GMT([+-])(\d+(?:\.\d+)?)/);
        if (matchDecimal) {
          const sign = matchDecimal[1] === '+' ? 1 : -1;
          return sign * Math.round(parseFloat(matchDecimal[2]) * 60);
        }
      } catch (e) {}
      return 0;
    }

    function getTzAbbreviation(timeZone: string, date: Date): string {
      try {
        const parts = new Intl.DateTimeFormat('en-US', {
          timeZone,
          timeZoneName: 'short'
        }).formatToParts(date);
        const part = parts.find(p => p.type === 'timeZoneName');
        return part ? part.value : '';
      } catch(e) {
        return 'UTC';
      }
    }

    // Live Ticking control
    function startLiveTicking() {
      state.isLive = true;
      liveTickBtn.classList.remove("bg-canvas", "text-brand-blue");
      liveTickBtn.classList.add("bg-brand-blue", "text-canvas");
      liveTickIndicator.classList.add("animate-ping");

      if (tickInterval) clearInterval(tickInterval);
      tickInterval = window.setInterval(() => {
        const now = new Date();
        state.sourceDate = now.toISOString().split('T')[0];
        state.sourceTime = now.toTimeString().split(' ')[0].substring(0, 5);
        sourceDateInput.value = state.sourceDate;
        sourceTimeInput.value = state.sourceTime;
        renderComparisonList();
        calculateOverlap();
      }, 1000);
    }

    function stopLiveTicking() {
      state.isLive = false;
      liveTickBtn.classList.remove("bg-brand-blue", "text-canvas");
      liveTickBtn.classList.add("bg-canvas", "text-brand-blue");
      liveTickIndicator.classList.remove("animate-ping");
      if (tickInterval) {
        clearInterval(tickInterval);
        tickInterval = null;
      }
    }

    // Formatting utilities
    function formatTime(date: Date, tz: string, use24h: boolean): string {
      return new Intl.DateTimeFormat('en-US', {
        timeZone: tz,
        hour: 'numeric',
        minute: '2-digit',
        second: '2-digit',
        hour12: !use24h
      }).format(date);
    }

    function getSourceDateTime(): Date {
      return new Date(`${state.sourceDate}T${state.sourceTime}:00`);
    }

    // Render Target Zone List
    function renderComparisonList() {
      zoneCardsList.innerHTML = "";
      const sourceDateTime = getSourceDateTime();
      const sourceOffset = getTzOffsetMinutes(state.sourceTz, sourceDateTime);

      state.targetZones.forEach((tz, index) => {
        // Compute targets
        const targetOffset = getTzOffsetMinutes(tz, sourceDateTime);
        const relativeOffset = targetOffset - sourceOffset;
        const relativeOffsetStr = relativeOffset === 0 ? "Same time" : 
          `${relativeOffset > 0 ? "+" : ""}${(relativeOffset / 60).toFixed(relativeOffset % 60 === 0 ? 0 : 1)}h`;

        // Calculate time
        const targetDateTime = new Date(sourceDateTime.getTime() + (relativeOffset * 60 * 1000));
        const timeStr = formatTime(targetDateTime, tz, state.format24h);
        const abbr = getTzAbbreviation(tz, targetDateTime);
        const city = tz.split('/').pop()?.replace(/_/g, ' ') || tz;

        // Visual day/night bar setup
        // The bar represents 24 hours. We place current hour marker.
        const currentHour = targetDateTime.getHours() + (targetDateTime.getMinutes() / 60);
        const markerPercent = (currentHour / 24) * 100;

        // Render card
        const card = document.createElement("div");
        card.className = "flex flex-col gap-2 p-2.5 bg-canvas border border-hairline hover:border-hairline-strong rounded-lg shadow-subtle relative cursor-grab select-none transition-all duration-200 animate-slide-in";
        card.setAttribute("draggable", "true");
        card.setAttribute("data-index", String(index));

        // Drag events
        card.addEventListener("dragstart", (e) => {
          draggedZoneIndex = index;
          card.classList.add("opacity-50");
          if (e.dataTransfer) {
            e.dataTransfer.effectAllowed = "move";
          }
        });
        card.addEventListener("dragend", () => {
          card.classList.remove("opacity-50");
          draggedZoneIndex = null;
        });

        // HTML builder
        card.innerHTML = `
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-1.5 min-w-0">
              <span class="text-stone text-[10px] cursor-move select-none">☰</span>
              <div class="flex flex-col">
                <span class="font-display font-semibold text-xs text-primary truncate">${city}</span>
                <span class="text-[9px] text-slate font-medium truncate">${tz} • ${abbr}</span>
              </div>
            </div>

            <div class="flex items-center gap-2">
              <div class="flex flex-col items-end">
                <span class="font-mono font-bold text-xs text-brand-blue">${timeStr}</span>
                <span class="text-[9px] text-stone font-semibold">${relativeOffsetStr}</span>
              </div>
              <button
                type="button"
                class="remove-zone-btn text-stone hover:text-brand-coral font-bold text-sm h-6 w-6 flex items-center justify-center rounded-full hover:bg-surface transition-colors"
                data-index="${index}"
                title="Remove location"
              >
                ×
              </button>
            </div>
          </div>

          <!-- Day/Night 24h Bar -->
          <div class="relative w-full h-4 rounded bg-gradient-to-r from-indigo-950 via-sky-300 to-indigo-950 border border-hairline overflow-hidden">
            <!-- Custom dusk/dawn gradients overlaying standard colors -->
            <div class="absolute inset-0 bg-gradient-to-r from-slate-900/40 via-transparent to-slate-900/40 pointer-events-none"></div>
            <!-- Waking hours bounds (8am - 8pm) -->
            <div class="absolute top-0 bottom-0 left-[33.33%] right-[16.66%] bg-white/20 border-l border-r border-white/30 pointer-events-none"></div>
            
            <!-- Hourly intervals tick marks -->
            <div class="absolute inset-0 flex justify-between pointer-events-none opacity-20 px-0.5">
              ${Array.from({length: 24}).map((_) => `<span class="w-[1px] h-full bg-slate-900"></span>`).join('')}
            </div>

            <!-- Current time marker -->
            <div 
              class="absolute top-0 bottom-0 w-1 bg-brand-coral shadow-lg transition-all duration-300"
              style="left: ${markerPercent}%"
            >
              <div class="absolute -top-1 -left-1 w-3 h-3 rounded-full bg-brand-coral border border-canvas"></div>
            </div>
          </div>

          <div class="flex justify-between items-center text-[9px] text-stone font-mono px-0.5">
            <span>12 AM</span>
            <span>6 AM</span>
            <span>12 PM</span>
            <span>6 PM</span>
            <span>12 AM</span>
          </div>
        `;

        zoneCardsList.appendChild(card);
      });

      // Attach remove button listeners
      document.querySelectorAll(".remove-zone-btn").forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const target = e.currentTarget as HTMLButtonElement;
          const idx = parseInt(target.getAttribute("data-index") || "0", 10);
          state.targetZones.splice(idx, 1);
          localStorage.setItem("toolkify:time-zone-converter:targetZones", JSON.stringify(state.targetZones));
          renderComparisonList();
          calculateOverlap();
        });
      });
    }

    // Meeting finder calculations
    function calculateOverlap() {
      // Gentle animated highlight sweep
      overlapSweep.classList.remove("hidden");
      setTimeout(() => {
        overlapSweep.classList.add("hidden");
      }, 600);

      overlapResults.innerHTML = "";

      if (state.targetZones.length === 0) {
        overlapResults.innerHTML = `<span class="text-[10px] text-stone">Add at least one zone to compare overlap.</span>`;
        return;
      }

      // Check all 24 hours of the current selected day (UTC boundaries)
      const matches: { hour: number; label: string }[] = [];
      const baseMidnight = new Date(`${state.sourceDate}T00:00:00`);

      for (let h = 0; h < 24; h++) {
        const testDate = new Date(baseMidnight.getTime() + (h * 60 * 60 * 1000));
        let allWaking = true;

        state.targetZones.forEach(tz => {
          // Use Intl.DateTimeFormat to get local hour in the timezone directly
          const hourString = new Intl.DateTimeFormat('en-US', {
            timeZone: tz,
            hour: 'numeric',
            hourCycle: 'h23'
          }).format(testDate);
          const hour = parseInt(hourString, 10);
          // Waking hours: 8am (8) to 8pm (20)
          if (hour < 8 || hour > 20) {
            allWaking = false;
          }
        });

        if (allWaking) {
          const labelHour = h % 12 === 0 ? 12 : h % 12;
          const ampm = h >= 12 ? "PM" : "AM";
          matches.push({ hour: h, label: `${labelHour}:00 ${ampm}` });
        }
      }

      if (matches.length === 0) {
        overlapResults.innerHTML = `<span class="text-[10px] text-brand-coral font-medium">⚠️ No comfortable overlap slots found for these timezones.</span>`;
        return;
      }

      matches.forEach(slot => {
        const item = document.createElement("button");
        item.type = "button";
        item.className = "w-full text-left p-1.5 border border-hairline rounded bg-canvas hover:bg-surface-yellow hover:border-brand-yellow-deep transition-all text-[11px] font-medium flex items-center justify-between cursor-pointer";
        item.innerHTML = `
          <span>🕒 ${slot.label}</span>
          <span class="text-[9px] bg-success-accent/10 text-success-accent py-0.5 px-2 rounded-full font-bold">Good Match</span>
        `;
        item.addEventListener("click", () => {
          // Set source time to this slot hour
          state.sourceTime = `${String(slot.hour).padStart(2, '0')}:00`;
          sourceTimeInput.value = state.sourceTime;
          stopLiveTicking();
          renderComparisonList();
        });
        overlapResults.appendChild(item);
      });
    }

    // Autocomplete / timezone search
    function setupTimezoneSearch(
      input: HTMLInputElement,
      container: HTMLDivElement,
      onSelect: (tz: string) => void
    ) {
      input.addEventListener("input", () => {
        const val = input.value.trim().toLowerCase();
        if (!val) {
          container.classList.add("hidden");
          return;
        }

        // Fuzzy match timezones
        const matches = allTimezones.filter(tz => {
          const tzLower = tz.toLowerCase();
          const city = tz.split('/').pop()?.replace(/_/g, ' ').toLowerCase() || '';
          const abbrMatch = Object.entries(tzAbbreviations).some(([abbr, zones]) => {
            return abbr.toLowerCase() === val && zones.includes(tz);
          });
          return tzLower.includes(val) || city.includes(val) || abbrMatch;
        }).slice(0, 8);

        container.innerHTML = "";
        if (matches.length === 0) {
          container.innerHTML = `<div class="p-2 text-stone text-[10px]">No zones found</div>`;
          container.classList.remove("hidden");
          return;
        }

        matches.forEach(tz => {
          const div = document.createElement("div");
          div.className = "p-2 hover:bg-surface cursor-pointer border-b border-hairline-soft last:border-none";
          div.textContent = tz;
          div.addEventListener("click", () => {
            onSelect(tz);
            container.classList.add("hidden");
            input.value = "";
          });
          container.appendChild(div);
        });
        container.classList.remove("hidden");
      });

      // Close on click outside
      document.addEventListener("click", (e) => {
        if (e.target !== input && e.target !== container) {
          container.classList.add("hidden");
        }
      });
    }

    // Setup autocomplete for source zone
    setupTimezoneSearch(sourceTzInput, sourceTzAutocomplete, (tz) => {
      state.sourceTz = tz;
      sourceTzInput.value = tz;
      renderComparisonList();
      calculateOverlap();
    });

    // Setup autocomplete for added zone
    setupTimezoneSearch(addZoneSearch, addZoneAutocomplete, (tz) => {
      if (!state.targetZones.includes(tz)) {
        state.targetZones.push(tz);
        localStorage.setItem("toolkify:time-zone-converter:targetZones", JSON.stringify(state.targetZones));
        renderComparisonList();
        calculateOverlap();
      }
    });

    // Region quick add buttons
    document.querySelectorAll(".quick-add-region-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const region = btn.getAttribute("data-region");
        let zonesToAdd: string[] = [];
        if (region === "Americas") {
          zonesToAdd = ["America/New_York", "America/Chicago", "America/Denver", "America/Los_Angeles"];
        } else if (region === "Europe") {
          zonesToAdd = ["Europe/London", "Europe/Paris", "Europe/Berlin", "Europe/Athens"];
        } else if (region === "Asia") {
          zonesToAdd = ["Asia/Tokyo", "Asia/Shanghai", "Asia/Singapore", "Australia/Sydney"];
        }

        zonesToAdd.forEach(z => {
          if (!state.targetZones.includes(z)) {
            state.targetZones.push(z);
          }
        });
        localStorage.setItem("toolkify:time-zone-converter:targetZones", JSON.stringify(state.targetZones));
        renderComparisonList();
        calculateOverlap();
      });
    });

    // Format toggle buttons
    function updateFormatButtons() {
      if (state.format24h) {
        format24hBtn.className = "flex-1 text-center text-[9px] py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas h-full flex items-center justify-center";
        format12hBtn.className = "flex-1 text-center text-[9px] py-1 rounded-full font-bold transition-all cursor-pointer text-slate h-full flex items-center justify-center";
      } else {
        format12hBtn.className = "flex-1 text-center text-[9px] py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas h-full flex items-center justify-center";
        format24hBtn.className = "flex-1 text-center text-[9px] py-1 rounded-full font-bold transition-all cursor-pointer text-slate h-full flex items-center justify-center";
      }
    }

    format12hBtn.addEventListener("click", () => {
      state.format24h = false;
      localStorage.setItem("toolkify:time-zone-converter:format24h", "false");
      updateFormatButtons();
      renderComparisonList();
    });

    format24hBtn.addEventListener("click", () => {
      state.format24h = true;
      localStorage.setItem("toolkify:time-zone-converter:format24h", "true");
      updateFormatButtons();
      renderComparisonList();
    });

    // Input change handlers
    sourceDateInput.addEventListener("input", () => {
      state.sourceDate = sourceDateInput.value;
      stopLiveTicking();
      renderComparisonList();
      calculateOverlap();
    });

    sourceTimeInput.addEventListener("input", () => {
      state.sourceTime = sourceTimeInput.value;
      stopLiveTicking();
      renderComparisonList();
      calculateOverlap();
    });

    liveTickBtn.addEventListener("click", () => {
      if (state.isLive) {
        stopLiveTicking();
      } else {
        startLiveTicking();
      }
    });

    // Local presets management
    function loadPresetsList() {
      presetSelect.innerHTML = `<option value="">-- Choose Set --</option>`;
      const rawPresets = localStorage.getItem("toolkify:time-zone-converter:presets");
      const presets = rawPresets ? JSON.parse(rawPresets) : {};
      
      // Add default Sales Team preset if empty
      if (!presets["My Team"]) {
        presets["My Team"] = ["UTC", "America/New_York", "Europe/London", "Asia/Tokyo"];
      }

      Object.keys(presets).forEach(name => {
        const opt = document.createElement("option");
        opt.value = name;
        opt.textContent = name;
        presetSelect.appendChild(opt);
      });
    }

    presetSelect.addEventListener("change", () => {
      const presetName = presetSelect.value;
      if (!presetName) return;

      const rawPresets = localStorage.getItem("toolkify:time-zone-converter:presets");
      const presets = rawPresets ? JSON.parse(rawPresets) : {};
      
      // Default fallback
      if (presetName === "My Team" && !presets["My Team"]) {
        state.targetZones = ["UTC", "America/New_York", "Europe/London", "Asia/Tokyo"];
      } else if (presets[presetName]) {
        state.targetZones = presets[presetName];
      }

      localStorage.setItem("toolkify:time-zone-converter:targetZones", JSON.stringify(state.targetZones));
      renderComparisonList();
      calculateOverlap();
    });

    btnSavePreset.addEventListener("click", () => {
      const nameVal = newPresetNameInput.value.trim();
      if (!nameVal) {
        showToast("Please enter a name for the preset.");
        return;
      }

      const rawPresets = localStorage.getItem("toolkify:time-zone-converter:presets");
      const presets = rawPresets ? JSON.parse(rawPresets) : {};
      presets[nameVal] = [...state.targetZones];

      localStorage.setItem("toolkify:time-zone-converter:presets", JSON.stringify(presets));
      newPresetNameInput.value = "";
      loadPresetsList();
      presetSelect.value = nameVal;
      showToast("✓ Preset saved locally!");
    });

    // Share action
    btnShare?.addEventListener("click", () => {
      const zonesEncoded = encodeURIComponent(state.targetZones.join(","));
      const stzEncoded = encodeURIComponent(state.sourceTz);
      const shareUrl = `${window.location.origin}${window.location.pathname}?date=${state.sourceDate}&time=${state.sourceTime}&stz=${stzEncoded}&zones=${zonesEncoded}`;

      const shareData = {
        title: document.title || "Time Zone Converter",
        url: shareUrl
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(shareUrl);
          }
        });
      } else {
        copyToClipboard(shareUrl);
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (btnShare) {
          const span = btnShare.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            btnShare.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              btnShare.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Verbatim Reset button structure and action handler
    btnReset.addEventListener("click", () => {
      // Clear localStorage
      localStorage.removeItem("toolkify:time-zone-converter:targetZones");
      localStorage.removeItem("toolkify:time-zone-converter:format24h");
      localStorage.removeItem("toolkify:time-zone-converter:presets");

      // Clear URL query parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // Reset to original states
      state.sourceDate = new Date().toISOString().split('T')[0];
      state.sourceTime = new Date().toTimeString().split(' ')[0].substring(0, 5);
      state.sourceTz = Intl.DateTimeFormat().resolvedOptions().timeZone || "UTC";
      state.format24h = false;
      state.targetZones = ["UTC", "America/New_York", "Europe/London", "Asia/Tokyo"];

      sourceDateInput.value = state.sourceDate;
      sourceTimeInput.value = state.sourceTime;
      sourceTzInput.value = state.sourceTz;

      updateFormatButtons();
      loadPresetsList();
      startLiveTicking();
      renderComparisonList();
      calculateOverlap();
      showToast("🔄 State reset successfully");
    });

    // Copy Summary Text
    btnCopySummary.addEventListener("click", () => {
      const sourceDateTime = getSourceDateTime();
      let summary = `Time Zone Converter Summary - ${state.sourceDate} at ${state.sourceTime} (${state.sourceTz})\n`;
      summary += `===================================================\n`;
      state.targetZones.forEach(tz => {
        const offset = getTzOffsetMinutes(tz, sourceDateTime);
        const relativeOffset = offset - getTzOffsetMinutes(state.sourceTz, sourceDateTime);
        const targetDateTime = new Date(sourceDateTime.getTime() + (relativeOffset * 60 * 1000));
        const timeStr = formatTime(targetDateTime, tz, state.format24h);
        const city = tz.split('/').pop()?.replace(/_/g, ' ') || tz;
        summary += `• ${city} (${tz}): ${timeStr} (Offset: ${relativeOffset >= 0 ? "+" : ""}${(relativeOffset / 60).toFixed(relativeOffset % 60 === 0 ? 0 : 1)}h)\n`;
      });

      navigator.clipboard.writeText(summary).then(() => {
        showToast("📋 Summary copied to clipboard");
      });
    });

    // Share link as URL query param
    btnShareLink.addEventListener("click", () => {
      const zonesEncoded = encodeURIComponent(state.targetZones.join(","));
      const stzEncoded = encodeURIComponent(state.sourceTz);
      const shareUrl = `${window.location.origin}${window.location.pathname}?date=${state.sourceDate}&time=${state.sourceTime}&stz=${stzEncoded}&zones=${zonesEncoded}`;

      navigator.clipboard.writeText(shareUrl).then(() => {
        showToast("🔗 Shareable link copied!");
      });
    });

    // Verbatim Modal interactions pulled from json-formatter.astro
    btnHowItWorks?.addEventListener("click", () => {
      howItWorksModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // Container-level drag events
    zoneCardsList.addEventListener("dragover", (e) => {
      e.preventDefault();
    });
    zoneCardsList.addEventListener("drop", (e) => {
      e.preventDefault();
      if (draggedZoneIndex === null) return;

      const children = Array.from(zoneCardsList.children);
      let targetIndex = children.length;

      for (let i = 0; i < children.length; i++) {
        const rect = children[i].getBoundingClientRect();
        const middleY = rect.top + rect.height / 2;
        if (e.clientY < middleY) {
          targetIndex = i;
          break;
        }
      }

      if (draggedZoneIndex !== targetIndex && draggedZoneIndex !== targetIndex - 1) {
        const zones = [...state.targetZones];
        const [moved] = zones.splice(draggedZoneIndex, 1);
        let insertIndex = targetIndex;
        if (draggedZoneIndex < targetIndex) {
          insertIndex = targetIndex - 1;
        }
        zones.splice(insertIndex, 0, moved);
        state.targetZones = zones;
        localStorage.setItem("toolkify:time-zone-converter:targetZones", JSON.stringify(zones));
        renderComparisonList();
        calculateOverlap();
      }
    });

    // Cleanup listeners on navigate
    document.addEventListener("astro:before-swap", () => {
      stopLiveTicking();
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";

        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Start everything
    init();
    }
  </script>
</Layout>
