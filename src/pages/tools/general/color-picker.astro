---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Color Picker & Eyedropper";
const category = "general";
const tier = "General Everyday Utilities";

// On-page SEO metadata
const pageTitle =
  "Color Picker & Eyedropper - Free Online Color Picker from Image";
const description =
  "Free online color picker & eyedropper tool. Pick a color picker from image, use the RGB, RGBA, and random color picker, and copy HEX codes instantly with this private online color picker tool.";
const canonicalUrl = "https://toolkify.app/tools/general/color-picker";
const ogImage = "/og/color-picker.png";
const keywords =
  "color picker & eyedropper, color picker, color picker from image, rgb color picker, random color picker, rgba color picker, online color picker, color picker tool, color picker online, eyedropper tool, hex color picker, html color picker, css color picker";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Color Picker & Eyedropper",
      "alternateName": "Client-Side Color Selector & Image Palette Extractor",
      "url": "https://toolkify.app/tools/general/color-picker",
      "description": "Free online client-side color picker with manual HSL/RGB adjustment, canvas image pixel sampling, WCAG contrast accessibility analysis, and CSS/JSON palette exports.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Interactive Saturation-Lightness square with Hue & Alpha range sliders",
        "Drag & drop image eyedropper with canvas mapping precision",
        "Magnified pixel preview cursor on canvas hover",
        "Native EyeDropper API integration where supported",
        "Simultaneous live HEX, RGB, RGBA, HSL, and HSLA readouts",
        "Color harmony generation (complementary, analogous, triadic, monochromatic)",
        "WCAG contrast validation against black & white",
        "Saved and recent palettes stored securely in localStorage"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a color picker tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A color picker tool is an online utility that lets you select, sample, and copy colors in formats like HEX, RGB, RGBA, and HSL. This color picker & eyedropper works as a manual color picker with a saturation-lightness square and hue slider, a color picker from image that samples any pixel from an uploaded photo, and a screen eyedropper that grabs colors from anywhere on your display. It runs entirely in your browser, so it is a fast, private online color picker you can use for web design, graphics, and CSS.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to use a color picker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To use this color picker, first choose a mode. In the Manual Picker, drag inside the color square to set saturation and lightness, move the hue slider to change the tone, and adjust opacity for RGBA values. To use it as a color picker from image, switch to the Image Eyedropper tab, upload or drag in a photo, and click any pixel to capture its exact color. On supported browsers you can also click 'Sample from Screen' to pick a color from anywhere on your screen. The tool instantly shows the HEX, RGB, RGBA, HSL, and HSLA codes, which you can copy with one click.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How Color Picker works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 print:border-none print:shadow-none print:bg-transparent print:p-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 items-stretch relative">
        
        <!-- Left Pane: Input Selectors -->
        <div class="lg:col-span-7 flex flex-col gap-3 min-h-[300px] lg:min-h-[420px]">
          <!-- Switchable Tabs -->
          <div class="flex rounded-full bg-surface p-0.5 border border-hairline w-full">
            <button
              type="button"
              id="tab-manual-btn"
              class="flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
            >
              Manual Picker
            </button>
            <button
              type="button"
              id="tab-image-btn"
              class="flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate"
            >
              Image Eyedropper
            </button>
          </div>

          <!-- Tab Content 1: Manual Picker -->
          <div id="panel-manual" class="flex flex-col gap-3 flex-grow">
            <!-- Saturation & Lightness Picker Canvas Box -->
            <div
              id="picker-sl-box"
              class="relative w-full h-[180px] rounded-lg cursor-crosshair overflow-hidden border border-hairline-strong select-none"
              style="background-color: hsl(0, 100%, 50%);"
            >
              <!-- Gradients layering for S & L -->
              <div class="absolute inset-0 bg-gradient-to-r from-white to-transparent"></div>
              <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent"></div>
              <!-- Drag marker thumb -->
              <div
                id="picker-sl-thumb"
                class="absolute w-4.5 h-4.5 -ml-2.25 -mt-2.25 rounded-full border-2 border-white shadow-md cursor-pointer pointer-events-none"
                style="left: 100%; top: 0%;"
              ></div>
            </div>

            <!-- Hue & Alpha Sliders -->
            <div class="flex flex-col gap-2.5">
              <!-- Hue Slider -->
              <div class="flex flex-col gap-1">
                <div class="flex justify-between items-center text-[10px] font-semibold text-slate">
                  <label for="slider-hue">Hue</label>
                  <span id="label-hue">0°</span>
                </div>
                <div class="relative h-6 flex items-center">
                  <input
                    type="range"
                    id="slider-hue"
                    min="0"
                    max="360"
                    value="0"
                    class="w-full h-3 rounded-full cursor-pointer appearance-none outline-none border border-hairline"
                    style="background: linear-gradient(to right, #f00 0%, #ff0 17%, #0f0 33%, #0ff 50%, #00f 67%, #f0f 83%, #f00 100%);"
                  />
                </div>
              </div>

              <!-- Alpha (Opacity) Slider -->
              <div class="flex flex-col gap-1">
                <div class="flex justify-between items-center text-[10px] font-semibold text-slate">
                  <label for="slider-alpha">Opacity</label>
                  <span id="label-alpha">100%</span>
                </div>
                <div class="relative h-6 flex items-center rounded-full overflow-hidden bg-checkerboard border border-hairline">
                  <input
                    type="range"
                    id="slider-alpha"
                    min="0"
                    max="100"
                    value="100"
                    class="w-full h-3 rounded-full cursor-pointer appearance-none outline-none"
                    style="background: linear-gradient(to right, transparent, hsl(0, 100%, 50%));"
                  />
                </div>
              </div>
            </div>

            <!-- Native Eyedropper API Button -->
            <div id="native-eyedropper-container" class="mt-1 flex items-center justify-between">
              <button
                type="button"
                id="btn-native-eyedropper"
                class="inline-flex items-center gap-1.5 text-xs font-semibold px-4 py-2 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle w-full justify-center"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" />
                </svg>
                <span>Sample from Screen (EyeDropper)</span>
              </button>
              <p id="eyedropper-unsupported-note" class="hidden text-[10px] text-stone text-center w-full py-1">
                ⚠️ Screen eyedropper is not supported on this browser (use Chrome/Edge).
              </p>
            </div>
          </div>

          <!-- Tab Content 2: Image Eyedropper -->
          <div id="panel-image" class="hidden flex-col gap-3 flex-grow">
            <div
              id="image-drop-zone"
              class="relative flex-grow flex flex-col items-center justify-center border-2 border-dashed border-hairline-strong rounded-xl bg-surface-soft p-4 text-center cursor-pointer hover:border-brand-blue transition-colors min-h-[160px]"
            >
              <input type="file" id="image-uploader" class="hidden" accept="image/*" />
              
              <div id="drop-zone-prompt" class="flex flex-col items-center gap-1.5">
                <span class="text-2xl">🖼️</span>
                <span class="text-xs font-bold text-brand-blue">Upload or drag-drop an image</span>
                <span class="text-[10px] text-stone">PNG, JPG, SVG, WebP up to 10MB</span>
              </div>

              <!-- Canvas and Loupe Wrapper -->
              <div id="image-canvas-wrapper" class="hidden relative w-full max-h-[220px] overflow-hidden flex justify-center items-center">
                <canvas id="image-canvas" class="max-w-full max-h-[220px] rounded-lg cursor-crosshair border border-hairline shadow-sm"></canvas>
                <!-- Loupe Zoom Preview -->
                <div id="zoom-loupe" class="absolute w-20 h-20 rounded-full border-2 border-white shadow-lg pointer-events-none hidden overflow-hidden z-30 bg-canvas">
                  <canvas id="loupe-canvas" width="80" height="80" class="w-full h-full image-render-pixelated"></canvas>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <!-- Crosshair center point -->
                    <div class="w-1.5 h-1.5 border border-white bg-transparent pointer-events-none shadow-sm rounded-full"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Canvas controls -->
            <div id="image-canvas-actions" class="hidden flex justify-between items-center text-[10px] font-semibold text-slate">
              <span id="image-info-label" class="font-mono text-[9px] text-stone"></span>
              <button type="button" id="btn-clear-image" class="text-brand-coral hover:underline cursor-pointer">Remove Image</button>
            </div>
          </div>
        </div>

        <!-- Right Pane: Active Color Preview & Formats -->
        <div class="lg:col-span-5 flex flex-col gap-3 min-h-[300px] lg:min-h-[420px]">
          <span class="text-[11px] font-semibold text-charcoal flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-brand-blue animate-pulse"></span>
            Color Output Details
          </span>

          <!-- Main Swatch Box -->
          <div class="card-base p-3 flex flex-col gap-2 bg-surface-soft border border-hairline relative">
            <div id="preview-swatch" class="w-full h-16 rounded-lg border border-hairline-strong shadow-inner relative flex items-end p-2 bg-checkerboard">
              <div class="absolute inset-0 rounded-lg" style="background-color: hsl(0, 100%, 50%);"></div>
              <!-- Named label overlay -->
              <span id="preview-name-badge" class="relative z-10 bg-canvas/80 text-[10px] px-2 py-0.5 rounded font-bold text-primary shadow-subtle truncate max-w-full">
                Red
              </span>
            </div>
          </div>

          <!-- Color Output Readouts -->
          <div class="flex flex-col gap-2 bg-surface p-2.5 rounded-xl border border-hairline-soft">
            <!-- Output template helper -->
            <div class="flex flex-col gap-2" id="outputs-list">
              <!-- HEX -->
              <div class="flex items-center justify-between gap-1.5 py-1 border-b border-hairline-soft/60">
                <span class="text-[10px] font-bold text-slate w-10">HEX</span>
                <input
                  type="text"
                  id="output-hex"
                  readonly
                  class="font-mono text-[11px] bg-transparent text-primary outline-none flex-grow"
                  value="#ff0000"
                />
                <button
                  type="button"
                  data-copy-target="output-hex"
                  class="copy-btn text-[10px] font-bold text-brand-blue hover:underline cursor-pointer transition-transform"
                >
                  Copy
                </button>
              </div>

              <!-- RGB -->
              <div class="flex items-center justify-between gap-1.5 py-1 border-b border-hairline-soft/60">
                <span class="text-[10px] font-bold text-slate w-10">RGB</span>
                <input
                  type="text"
                  id="output-rgb"
                  readonly
                  class="font-mono text-[11px] bg-transparent text-primary outline-none flex-grow"
                  value="rgb(255, 0, 0)"
                />
                <button
                  type="button"
                  data-copy-target="output-rgb"
                  class="copy-btn text-[10px] font-bold text-brand-blue hover:underline cursor-pointer transition-transform"
                >
                  Copy
                </button>
              </div>

              <!-- RGBA -->
              <div class="flex items-center justify-between gap-1.5 py-1 border-b border-hairline-soft/60">
                <span class="text-[10px] font-bold text-slate w-10">RGBA</span>
                <input
                  type="text"
                  id="output-rgba"
                  readonly
                  class="font-mono text-[11px] bg-transparent text-primary outline-none flex-grow"
                  value="rgba(255, 0, 0, 1.00)"
                />
                <button
                  type="button"
                  data-copy-target="output-rgba"
                  class="copy-btn text-[10px] font-bold text-brand-blue hover:underline cursor-pointer transition-transform"
                >
                  Copy
                </button>
              </div>

              <!-- HSL -->
              <div class="flex items-center justify-between gap-1.5 py-1 border-b border-hairline-soft/60">
                <span class="text-[10px] font-bold text-slate w-10">HSL</span>
                <input
                  type="text"
                  id="output-hsl"
                  readonly
                  class="font-mono text-[11px] bg-transparent text-primary outline-none flex-grow"
                  value="hsl(0, 100%, 50%)"
                />
                <button
                  type="button"
                  data-copy-target="output-hsl"
                  class="copy-btn text-[10px] font-bold text-brand-blue hover:underline cursor-pointer transition-transform"
                >
                  Copy
                </button>
              </div>

              <!-- HSLA -->
              <div class="flex items-center justify-between gap-1.5 py-1">
                <span class="text-[10px] font-bold text-slate w-10">HSLA</span>
                <input
                  type="text"
                  id="output-hsla"
                  readonly
                  class="font-mono text-[11px] bg-transparent text-primary outline-none flex-grow"
                  value="hsla(0, 100%, 50%, 1.00)"
                />
                <button
                  type="button"
                  data-copy-target="output-hsla"
                  class="copy-btn text-[10px] font-bold text-brand-blue hover:underline cursor-pointer transition-transform"
                >
                  Copy
                </button>
              </div>
            </div>
          </div>

          <!-- Add to Saved Palette -->
          <button
            type="button"
            id="btn-add-palette"
            class="button-primary text-xs py-2 px-5 w-full flex items-center justify-center gap-1.5 !rounded-full shadow-subtle hover:scale-105 active:scale-95 transition-all cursor-pointer font-bold mt-1"
          >
            <span>➕ Save Color to Palette</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Collapsible Accordion: Accessibility, Harmonies, and Palettes -->
    <div class="flex flex-col gap-3 print:hidden">
      <!-- Section 1: Color Harmonies -->
      <details class="card-base p-4 bg-canvas border border-hairline-soft group" open>
        <summary class="font-display font-semibold text-xs sm:text-sm text-primary flex items-center justify-between cursor-pointer list-none select-none">
          <span class="flex items-center gap-2">
            🎨 Color Harmony Generator
          </span>
          <span class="text-stone transition-transform group-open:rotate-180">▼</span>
        </summary>

        <div class="mt-4 flex flex-col gap-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
            <!-- Complementary -->
            <div class="flex flex-col gap-1.5">
              <span class="text-[10px] font-bold text-slate uppercase">Complementary</span>
              <div id="harmony-complementary" class="flex gap-1.5 h-10"></div>
            </div>
            <!-- Analogous -->
            <div class="flex flex-col gap-1.5">
              <span class="text-[10px] font-bold text-slate uppercase">Analogous</span>
              <div id="harmony-analogous" class="flex gap-1.5 h-10"></div>
            </div>
            <!-- Triadic -->
            <div class="flex flex-col gap-1.5">
              <span class="text-[10px] font-bold text-slate uppercase">Triadic</span>
              <div id="harmony-triadic" class="flex gap-1.5 h-10"></div>
            </div>
            <!-- Shades & Tints -->
            <div class="flex flex-col gap-1.5">
              <span class="text-[10px] font-bold text-slate uppercase">Monochromatic (Shades/Tints)</span>
              <div id="harmony-monochromatic" class="flex gap-1.5 h-10"></div>
            </div>
          </div>
        </div>
      </details>

      <!-- Section 2: Contrast & Accessibility Checker -->
      <details class="card-base p-4 bg-canvas border border-hairline-soft group">
        <summary class="font-display font-semibold text-xs sm:text-sm text-primary flex items-center justify-between cursor-pointer list-none select-none">
          <span class="flex items-center gap-2">
            ♿ WCAG Accessibility & Contrast Checker
          </span>
          <span class="text-stone transition-transform group-open:rotate-180">▼</span>
        </summary>

        <div class="mt-4 flex flex-col gap-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Contrast against White -->
            <div class="p-3 bg-surface rounded-xl border border-hairline flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <span class="text-[11px] font-semibold text-primary">Contrast Against White (#FFFFFF)</span>
                <span id="contrast-white-ratio" class="font-mono text-xs font-bold text-primary">1.00:1</span>
              </div>
              <div id="contrast-white-preview" class="h-10 rounded border border-hairline flex items-center justify-center text-xs font-medium" style="background-color: #fff; color: #f00;">
                Example Text Sample
              </div>
              <div class="flex gap-2 justify-between text-[10px]">
                <div class="flex items-center gap-1">
                  <span>Normal Text:</span>
                  <span id="white-normal-badge" class="px-1.5 py-0.5 rounded font-bold">FAIL</span>
                </div>
                <div class="flex items-center gap-1">
                  <span>Large Text:</span>
                  <span id="white-large-badge" class="px-1.5 py-0.5 rounded font-bold">FAIL</span>
                </div>
              </div>
            </div>

            <!-- Contrast against Black -->
            <div class="p-3 bg-surface rounded-xl border border-hairline flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <span class="text-[11px] font-semibold text-primary">Contrast Against Black (#000000)</span>
                <span id="contrast-black-ratio" class="font-mono text-xs font-bold text-primary">21.00:1</span>
              </div>
              <div id="contrast-black-preview" class="h-10 rounded border border-hairline flex items-center justify-center text-xs font-medium" style="background-color: #000; color: #f00;">
                Example Text Sample
              </div>
              <div class="flex gap-2 justify-between text-[10px]">
                <div class="flex items-center gap-1">
                  <span>Normal Text:</span>
                  <span id="black-normal-badge" class="px-1.5 py-0.5 rounded font-bold bg-success-accent/10 text-success-accent border border-success-accent/35">AAA PASS</span>
                </div>
                <div class="flex items-center gap-1">
                  <span>Large Text:</span>
                  <span id="black-large-badge" class="px-1.5 py-0.5 rounded font-bold bg-success-accent/10 text-success-accent border border-success-accent/35">AAA PASS</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </details>

      <!-- Section 3: Saved Palette & Recents -->
      <details class="card-base p-4 bg-canvas border border-hairline-soft group">
