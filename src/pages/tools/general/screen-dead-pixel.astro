</Layout>

<script>
  if (typeof window !== 'undefined') {
  // LocalStorage Namespace helper
  const STORAGE_KEY = 'toolkify:screen-dead-pixel:settings';

  interface ToolSettings {
    customColors: string[];
    autoAdvance: boolean;
    interval: number;
  }

  // State
  let settings: ToolSettings = {
    customColors: [],
    autoAdvance: false,
    interval: 3
  };

  // Base list of pure colors
  const DEFAULT_COLORS = [
    '#FFFFFF', // Pure White
    '#000000', // Pure Black
    '#FF0000', // Pure Red
    '#00FF00', // Pure Green
    '#0000FF', // Pure Blue
    '#808080'  // Mid-Gray
  ];

  let testColors: string[] = [...DEFAULT_COLORS];
  let activeIndex = 0;
  let testActive = false;
  let autoTimer: any = null;
  let zoomMode = false;
  let mouseX = 0;
  let mouseY = 0;
  let hudTimeout: any = null;

  // DOM Elements
  const shareBtn = document.getElementById("share-btn") as HTMLButtonElement;
  const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
  const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
  const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
  const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
  const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;

  const modeManualBtn = document.getElementById("mode-manual-btn") as HTMLButtonElement;
  const modeAutoBtn = document.getElementById("mode-auto-btn") as HTMLButtonElement;
  const durationConfigWrapper = document.getElementById("duration-config-wrapper") as HTMLDivElement;
  const autoDurationInput = document.getElementById("auto-duration") as HTMLInputElement;
  const durationValSpan = document.getElementById("duration-val") as HTMLSpanElement;

  const customHexInput = document.getElementById("custom-hex-input") as HTMLInputElement;
  const customColorPreview = document.getElementById("custom-color-preview") as HTMLSpanElement;
  const addCustomColorBtn = document.getElementById("add-custom-color-btn") as HTMLButtonElement;
  const customColorError = document.getElementById("custom-color-error") as HTMLSpanElement;
  const colorSequenceList = document.getElementById("color-sequence-list") as HTMLDivElement;

  const startTestBtn = document.getElementById("start-test-btn") as HTMLButtonElement;
  const fullscreenTestArea = document.getElementById("fullscreen-test-area") as HTMLDivElement;
  const hudToolbar = document.getElementById("hud-toolbar") as HTMLDivElement;
  const hudStatus = document.getElementById("hud-status") as HTMLSpanElement;
  const hudZoomToggle = document.getElementById("hud-zoom-toggle") as HTMLButtonElement;
  const hudExitBtn = document.getElementById("hud-exit-btn") as HTMLButtonElement;
  const floatingExitX = document.getElementById("floating-exit-x") as HTMLButtonElement;
  const magnifierLens = document.getElementById("magnifier-lens") as HTMLDivElement;
  const magnifierCanvas = document.getElementById("magnifier-canvas") as HTMLCanvasElement;

  const postTestGuidance = document.getElementById("post-test-guidance") as HTMLDivElement;
  const closeGuidanceBtn = document.getElementById("close-guidance-btn") as HTMLButtonElement;

  // Load from localStorage or URL query parameters
  function loadSettings() {
    // 1. Load from localStorage
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) {
        settings = JSON.parse(stored);
      }
    } catch (e) {
      console.error("Failed to load settings", e);
    }

    // 2. Override with URL parameters if present
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has("auto")) {
      settings.autoAdvance = urlParams.get("auto") === "true";
    }
    if (urlParams.has("interval")) {
      const parsedInterval = parseInt(urlParams.get("interval") || "3", 10);
      if (!isNaN(parsedInterval)) {
        settings.interval = Math.max(1, Math.min(15, parsedInterval));
      }
    }
    if (urlParams.has("colors")) {
      const colorsParam = urlParams.get("colors");
      if (colorsParam) {
        const customHexes = colorsParam.split(",").map(c => c.startsWith("#") ? c : `#${c}`).filter(c => /^#[0-9A-F]{6}$/i.test(c));
        settings.customColors = customHexes;
      }
    }

    applySettingsToUI();
  }

  // Save to localStorage
  function saveSettings() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));
    } catch (e) {
      console.error("Failed to save settings", e);
    }
  }

  // Reset to original settings
  function performReset() {
    // 1. Exit fullscreen mode if active
    if (document.fullscreenElement || (document as any).webkitFullscreenElement) {
      exitFullscreen();
    }
    stopTest();

    // 2. Clear this tool's localStorage keys
    localStorage.removeItem(STORAGE_KEY);

    // 3. Clear URL query parameters
    if (window.history.pushState) {
      const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
      window.history.pushState({path:newurl}, '', newurl);
    }

    // 4. Reset color sequence to start & default inputs
    settings = {
      customColors: [],
      autoAdvance: false,
      interval: 3
    };

    applySettingsToUI();
    postTestGuidance.classList.add("hidden");
  }

  // Update layout and options based on current settings state
  function applySettingsToUI() {
    // Auto-advance values
    if (settings.autoAdvance) {
      modeAutoBtn.classList.add("bg-canvas", "text-primary", "shadow-sm");
      modeAutoBtn.classList.remove("text-slate", "hover:text-primary");
      modeManualBtn.classList.remove("bg-canvas", "text-primary", "shadow-sm");
      modeManualBtn.classList.add("text-slate", "hover:text-primary");
      durationConfigWrapper.classList.remove("hidden");
      durationConfigWrapper.classList.add("flex");
    } else {
      modeManualBtn.classList.add("bg-canvas", "text-primary", "shadow-sm");
      modeManualBtn.classList.remove("text-slate", "hover:text-primary");
      modeAutoBtn.classList.remove("bg-canvas", "text-primary", "shadow-sm");
      modeAutoBtn.classList.add("text-slate", "hover:text-primary");
      durationConfigWrapper.classList.remove("flex");
      durationConfigWrapper.classList.add("hidden");
    }

    autoDurationInput.value = String(settings.interval);
    durationValSpan.textContent = `${settings.interval} second${settings.interval > 1 ? 's' : ''}`;

    // Colors sequence setup
    testColors = [...DEFAULT_COLORS, ...settings.customColors];
    renderColorSwatches();
  }

  // Render swatches preview list
  function renderColorSwatches() {
    colorSequenceList.innerHTML = '';
    testColors.forEach((color, index) => {
      const isDefault = index < DEFAULT_COLORS.length;

      const swatch = document.createElement('div');
      swatch.className = "group relative flex items-center justify-center w-8 h-8 rounded-lg border border-hairline shadow-sm shrink-0 select-none transition-transform hover:scale-105";
      swatch.style.backgroundColor = color;
      swatch.title = color;

      if (!isDefault) {
        // Delete button for custom color
        const delBtn = document.createElement('button');
        delBtn.type = 'button';
        delBtn.className = "absolute -top-1 -right-1 w-3.5 h-3.5 bg-brand-coral hover:bg-rose-600 text-white rounded-full flex items-center justify-center text-[8px] font-bold shadow transition-opacity opacity-0 group-hover:opacity-100 cursor-pointer";
        delBtn.textContent = '✕';
        delBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const customIndex = index - DEFAULT_COLORS.length;
          settings.customColors.splice(customIndex, 1);
          saveSettings();
          applySettingsToUI();
        });
        swatch.appendChild(delBtn);
      }

      colorSequenceList.appendChild(swatch);
    });
  }

  // Validate custom hex colors
  function validateHex(hex: string): boolean {
    return /^#([A-Fa-f0-9]{3}){1,2}$/.test(hex);
  }

  // Update custom color input preview
  function updateHexInputPreview() {
    const val = customHexInput.value.trim();
    if (validateHex(val)) {
      customColorPreview.style.backgroundColor = val;
      customColorError.classList.add("hidden");
    } else {
      customColorError.classList.remove("hidden");
    }
  }

  // Fullscreen helper functions
  function enterFullscreen(elem: HTMLElement) {
    if (elem.requestFullscreen) {
      elem.requestFullscreen();
    } else if ((elem as any).webkitRequestFullscreen) { /* Safari */
      (elem as any).webkitRequestFullscreen();
    } else if ((elem as any).msRequestFullscreen) { /* IE11 */
      (elem as any).msRequestFullscreen();
    }
  }

  function exitFullscreen() {
    if (document.exitFullscreen) {
      document.exitFullscreen();
    } else if ((document as any).webkitExitFullscreen) {
      (document as any).webkitExitFullscreen();
    } else if ((document as any).msExitFullscreen) {
      (document as any).msExitFullscreen();
    }
  }

  // Active full screen color sequence test loop
  function startTest() {
    if (testColors.length === 0) return;
    activeIndex = 0;
    testActive = true;
    zoomMode = false;
    hudZoomToggle.classList.remove("text-brand-yellow");

    fullscreenTestArea.classList.remove("hidden");
    fullscreenTestArea.classList.add("flex");
    
    // Apply initial test color
    updateTestColor();

    // Trigger Fullscreen
    enterFullscreen(fullscreenTestArea);

    // Fade active controls initially
    resetHudTimeout();

    // Bind event handlers specific to active test
    fullscreenTestArea.addEventListener("click", handleTestAreaClick);
    fullscreenTestArea.addEventListener("mousemove", handleMouseMove);
    fullscreenTestArea.addEventListener("touchmove", handleTouchMove, { passive: true });
    fullscreenTestArea.addEventListener("touchstart", handleTouchStart, { passive: true });
    document.addEventListener("keydown", handleKeyNavigation);

    if (settings.autoAdvance) {
      startAutoTimer();
    }
  }

  function stopTest() {
    if (!testActive) return;
    testActive = false;
    fullscreenTestArea.classList.add("hidden");
    fullscreenTestArea.classList.remove("flex");

    // Clean timers
    clearAutoTimer();
    if (hudTimeout) clearTimeout(hudTimeout);

    // Remove active event listeners
    fullscreenTestArea.removeEventListener("click", handleTestAreaClick);
    fullscreenTestArea.removeEventListener("mousemove", handleMouseMove);
    fullscreenTestArea.removeEventListener("touchmove", handleTouchMove);
    fullscreenTestArea.removeEventListener("touchstart", handleTouchStart);
    document.removeEventListener("keydown", handleKeyNavigation);

    // Hide magnifier
    magnifierLens.classList.add("hidden");

    // Show recommendations panel
    postTestGuidance.classList.remove("hidden");
    postTestGuidance.classList.add("flex");
  }

  function updateTestColor() {
    const color = testColors[activeIndex];
    fullscreenTestArea.style.backgroundColor = color;
    hudStatus.textContent = `Color ${activeIndex + 1} of ${testColors.length} (${color})`;

    // Re-draw magnifier if active
    if (zoomMode) {
      drawMagnifier();
    }
  }

  function nextColor() {
    activeIndex = (activeIndex + 1) % testColors.length;
    updateTestColor();
    if (settings.autoAdvance) {
      // Refresh interval cycle on manual clicks
      startAutoTimer();
    }
  }

  function prevColor() {
    activeIndex = (activeIndex - 1 + testColors.length) % testColors.length;
    updateTestColor();
    if (settings.autoAdvance) {
      startAutoTimer();
    }
  }

  function startAutoTimer() {
    clearAutoTimer();
    autoTimer = setInterval(() => {
      nextColor();
    }, settings.interval * 1000);
  }

  function clearAutoTimer() {
    if (autoTimer) {
      clearInterval(autoTimer);
      autoTimer = null;
    }
  }

  // Key navigation handler during full screen test
  function handleKeyNavigation(e: KeyboardEvent) {
    if (!testActive) return;

    if (e.key === "Escape") {
      e.preventDefault();
      exitFullscreen();
      stopTest();
    } else if (e.key === "ArrowRight" || e.key === "ArrowDown" || e.key === " ") {
      e.preventDefault();
      nextColor();
    } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
      e.preventDefault();
      prevColor();
    } else if (e.key === "z" || e.key === "Z") {
      e.preventDefault();
      toggleZoomMode();
    }
  }

  // Click handler on full screen test
  function handleTestAreaClick(e: MouseEvent) {
    // If target is inside HUD or Exit button, let normal listener handle it
    if ((e.target as HTMLElement).closest('#hud-toolbar') || (e.target as HTMLElement).closest('#floating-exit-x')) {
      return;
    }

    if (zoomMode) {
      // If clicking in zoom mode, reposition magnifier lens to mouse position
      mouseX = e.clientX;
      mouseY = e.clientY;
      positionMagnifier();
    } else {
      nextColor();
    }
  }

  function toggleZoomMode() {
    zoomMode = !zoomMode;
    if (zoomMode) {
      hudZoomToggle.classList.add("text-brand-yellow");
      magnifierLens.classList.remove("hidden");
      // Put magnifier lens in center initial position
      mouseX = window.innerWidth / 2;
      mouseY = window.innerHeight / 2;
      positionMagnifier();
    } else {
      hudZoomToggle.classList.remove("text-brand-yellow");
      magnifierLens.classList.add("hidden");
    }
  }

  function handleMouseMove(e: MouseEvent) {
    resetHudTimeout();
    if (zoomMode) {
      mouseX = e.clientX;
      mouseY = e.clientY;
      positionMagnifier();
    }
  }

  function handleTouchStart(e: TouchEvent) {
    resetHudTimeout();
    if (zoomMode && e.touches.length > 0) {
      mouseX = e.touches[0].clientX;
      mouseY = e.touches[0].clientY;
      positionMagnifier();
    }
  }

  function handleTouchMove(e: TouchEvent) {
    resetHudTimeout();
    if (zoomMode && e.touches.length > 0) {
      mouseX = e.touches[0].clientX;
      mouseY = e.touches[0].clientY;
      positionMagnifier();
    }
  }

  function positionMagnifier() {
    magnifierLens.style.left = `${mouseX - 72}px`;
    magnifierLens.style.top = `${mouseY - 72}px`;
    drawMagnifier();
  }

  // Render a simulated RGB subpixel matrix on canvas magnification
  function drawMagnifier() {
    const ctx = magnifierCanvas.getContext("2d");
    if (!ctx) return;

    const width = magnifierCanvas.width;
    const height = magnifierCanvas.height;
    ctx.clearRect(0, 0, width, height);

    const activeColor = testColors[activeIndex];
    
    // Parse color to components
    let r = 0, g = 0, b = 0;
    if (activeColor.startsWith('#')) {
      const hex = activeColor.slice(1);
      if (hex.length === 3) {
        r = parseInt(hex[0] + hex[0], 16);
        g = parseInt(hex[1] + hex[1], 16);
        b = parseInt(hex[2] + hex[2], 16);
      } else if (hex.length === 6) {
        r = parseInt(hex.slice(0, 2), 16);
        g = parseInt(hex.slice(2, 4), 16);
        b = parseInt(hex.slice(4, 6), 16);
      }
    }

    // Grid properties
    const pixelBlockSize = 12; // size of simulated screen pixel
    const subpixelWidth = pixelBlockSize / 3;

    // Draw simulated subpixels grid (Red, Green, Blue columns)
    for (let x = 0; x < width; x += pixelBlockSize) {
      for (let y = 0; y < height; y += pixelBlockSize) {
        // Red subpixel
        ctx.fillStyle = `rgb(${r}, 0, 0)`;
        ctx.fillRect(x, y, subpixelWidth - 0.5, pixelBlockSize - 0.5);

        // Green subpixel
        ctx.fillStyle = `rgb(0, ${g}, 0)`;
        ctx.fillRect(x + subpixelWidth, y, subpixelWidth - 0.5, pixelBlockSize - 0.5);

        // Blue subpixel
        ctx.fillStyle = `rgb(0, 0, ${b})`;
        ctx.fillRect(x + 2 * subpixelWidth, y, subpixelWidth - 0.5, pixelBlockSize - 0.5);
      }
    }
  }

  // Temporary minimal HUD fading logic
  function resetHudTimeout() {
    hudToolbar.style.opacity = '1';
    floatingExitX.style.opacity = '1';
    if (hudTimeout) clearTimeout(hudTimeout);
    hudTimeout = setTimeout(() => {
      if (testActive) {
        hudToolbar.style.opacity = '0.05';
        floatingExitX.style.opacity = '0.05';
      }
    }, 2500);
  }

  // Handle Fullscreen Event Listener triggers (Backwards-compatibility sync)
  function handleFullscreenChange() {
    const isFullscreen = document.fullscreenElement || (document as any).webkitFullscreenElement;
    if (!isFullscreen && testActive) {
      stopTest();
    }
  }

  // Initial event bindings
  function init() {
    loadSettings();

    // Mode toggles
    modeManualBtn.addEventListener("click", () => {
      settings.autoAdvance = false;
      saveSettings();
      applySettingsToUI();
    });

    modeAutoBtn.addEventListener("click", () => {
      settings.autoAdvance = true;
      saveSettings();
      applySettingsToUI();
    });

    autoDurationInput.addEventListener("input", () => {
      settings.interval = parseInt(autoDurationInput.value, 10);
      durationValSpan.textContent = `${settings.interval} second${settings.interval > 1 ? 's' : ''}`;
    });

    autoDurationInput.addEventListener("change", () => {
      saveSettings();
    });

    // Custom Hex validation & adding
    customHexInput.addEventListener("input", () => {
      let val = customHexInput.value.trim();
      if (val && !val.startsWith('#')) {
        val = '#' + val;
        customHexInput.value = val;
      }
      updateHexInputPreview();
    });

    addCustomColorBtn.addEventListener("click", () => {
      const val = customHexInput.value.trim();
      if (validateHex(val)) {
        if (!settings.customColors.includes(val)) {
          settings.customColors.push(val);
          saveSettings();
          applySettingsToUI();
        }
      } else {
        customColorError.classList.remove("hidden");
      }
    });

    // Start action
    startTestBtn.addEventListener("click", startTest);

    // Floating toolbar events
    hudZoomToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleZoomMode();
    });
    
    hudExitBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      exitFullscreen();
      stopTest();
    });

    floatingExitX.addEventListener("click", (e) => {
      e.stopPropagation();
      exitFullscreen();
      stopTest();
    });

    // Share action
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("auto", settings.autoAdvance ? "true" : "false");
      url.searchParams.set("interval", settings.interval.toString());
      if (settings.customColors.length > 0) {
        const hexes = settings.customColors.map(c => c.replace("#", ""));
        url.searchParams.set("colors", hexes.join(","));
      }

      const shareData = {
        title: document.title || "Screen Dead Pixel Checker",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Reset action
    resetBtn.addEventListener("click", performReset);

    // Modal action handlers
    howItWorksBtn.addEventListener("click", () => {
      howItWorksModal.classList.remove("hidden");
    });

    closeModalBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });

    modalOkBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });

    howItWorksModal.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    closeGuidanceBtn.addEventListener("click", () => {
      postTestGuidance.classList.add("hidden");
    });

    // Listeners for standard fullscreen changes
    document.addEventListener("fullscreenchange", handleFullscreenChange);
    document.addEventListener("webkitfullscreenchange", handleFullscreenChange);

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";

        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    document.addEventListener("astro:before-swap", () => {
      document.removeEventListener("keydown", handleKeyNavigation);
      document.removeEventListener("fullscreenchange", handleFullscreenChange);
      document.removeEventListener("webkitfullscreenchange", handleFullscreenChange);
    });
  }

  init();
  }
</script>

<style>
  /* Ensure cursor is hidden in fullscreen test area */
  #fullscreen-test-area {
    user-select: none;
    -webkit-user-select: none;
  }
</style>
