  // Unicode safe Base64 Encoder / Decoder helpers
  function unicodeBtoa(str: string): string {
    const encoder = new TextEncoder();
    const data = encoder.encode(str);
    let binString = "";
    for (let i = 0; i < data.length; i++) {
      binString += String.fromCharCode(data[i]);
    }
    return btoa(binString);
  }

  // Safe decoding of base64
  function unicodeAtob(b64: string): string {
    const binString = atob(b64);
    const len = binString.length;
    const bytes = new Uint8Array(len);
    for (let i = 0; i < len; i++) {
      bytes[i] = binString.charCodeAt(i);
    }
    const decoder = new TextDecoder();
    return decoder.decode(bytes);
  }

  // Variant adjustments for Base64 (Standard vs URL-Safe)
  function toUrlSafeB64(str: string): string {
    return str.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  }

  function fromUrlSafeB64(str: string): string {
    let standard = str.replace(/-/g, '+').replace(/_/g, '/');
    while (standard.length % 4) {
      standard += '=';
    }
    return standard;
  }

  // Image Detection & Decoded Preview Handling
  function checkAndRenderImagePreview(text: string) {
    if (!imagePreviewContainer || !imgPreview) return;

    const trimmed = text.trim();
    // Case 1: Decoded value is a data url representing an image
    if (trimmed.startsWith('data:image/')) {
      imgPreview.src = trimmed;
      imagePreviewContainer.classList.remove('hidden');
      return;
    }

    // Case 2: Decoded value is raw SVG markup
    if (trimmed.startsWith('<svg') && trimmed.endsWith('</svg>')) {
      try {
        const svgBase64 = btoa(unescape(encodeURIComponent(trimmed)));
        imgPreview.src = `data:image/svg+xml;base64,${svgBase64}`;
        imagePreviewContainer.classList.remove('hidden');
        return;
      } catch (e) {}
    }

    // Case 3: Decoded output is not a direct image data URL, let's look at the source (input) string if we are in decode mode
    if (direction === 'decode' && mode === 'b64') {
      const sourceVal = editorA.value.trim();
      if (/^(iVBOR|R0lG|\/9j\/|UklGR)/.test(sourceVal)) {
        let mime = 'image/png';
        if (sourceVal.startsWith('/9j/')) mime = 'image/jpeg';
        else if (sourceVal.startsWith('R0lG')) mime = 'image/gif';
        else if (sourceVal.startsWith('UklGR')) mime = 'image/webp';
        
        imgPreview.src = `data:${mime};base64,${sourceVal.replace(/[\s\r\n]+/g, '')}`;
        imagePreviewContainer.classList.remove('hidden');
        return;
      }
    }

    // Hide preview if no matching image layout found
    imagePreviewContainer.classList.add('hidden');
    imgPreview.src = "";
  }

  // Main Conversion Dispatcher
  function runConversion(targetPanel: string = 'b') {
    if (blockSync) return;
    blockSync = true;

    const inputArea = targetPanel === 'b' ? editorA : editorB;
    const val = inputArea.value;

    // Reset banners/previews
    errorBanner?.classList.add('hidden');
    
    if (targetPanel === 'b') {
      imagePreviewContainer?.classList.add('hidden');
    }

    // Dynamic Live Symmetrical Highlights
    if (targetPanel === 'b') {
      syncIndicatorA?.classList.remove('opacity-50');
      syncIndicatorB?.classList.add('opacity-50');
    } else {
      syncIndicatorA?.classList.add('opacity-50');
      syncIndicatorB?.classList.remove('opacity-50');
    }

    if (!val && !loadedFile) {
      if (targetPanel === 'b') editorB.value = '';
      else editorA.value = '';
      updateStats();
      blockSync = false;
      return;
    }

    try {
      let finalResult = '';

      // Set up transformation values
      const isEncode = targetPanel === 'b' ? (direction === 'encode') : (direction === 'decode');
      const isBatch = chkBatchMode?.checked;

      // Processing line by line (Batch Mode) or single block
      const processString = (str: string): string => {
        if (isEncode) {
          // ================== ENCODING ==================
          if (mode === 'b64') {
            const b64Var = selB64Variant?.value || 'standard';
            let res = unicodeBtoa(str);
            if (b64Var === 'urlsafe') {
              res = toUrlSafeB64(res);
            }
            return res;
          } else if (mode === 'url') {
            const urlScope = selUrlScope?.value || 'component';
            return urlScope === 'component' ? encodeURIComponent(str) : encodeURI(str);
          } else {
            // Chained: Base64 -> URL or URL -> Base64
            const order = selChainedOrder?.value || 'b64-url';
            if (order === 'b64-url') {
              // B64 then URL
              let b64 = unicodeBtoa(str);
              const b64Var = selB64Variant?.value || 'standard';
              if (b64Var === 'urlsafe') b64 = toUrlSafeB64(b64);
              return encodeURIComponent(b64);
            } else {
              // URL then B64
              const urlScope = selUrlScope?.value || 'component';
              const urled = urlScope === 'component' ? encodeURIComponent(str) : encodeURI(str);
              let b64 = unicodeBtoa(urled);
              const b64Var = selB64Variant?.value || 'standard';
              if (b64Var === 'urlsafe') b64 = toUrlSafeB64(b64);
              return b64;
            }
          }
        } else {
          // ================== DECODING ==================
          if (mode === 'b64') {
            const b64Var = selB64Variant?.value || 'standard';
            let cleaned = str.trim();
            if (b64Var === 'urlsafe' || /[-_]/.test(cleaned)) {
              cleaned = fromUrlSafeB64(cleaned);
            }
            // Strict check
            if (!/^[A-Za-z0-9+/]*={0,2}$/.test(cleaned)) {
              throw new Error("Invalid character detected. Ensure string contains only letters, numbers, and valid Base64 symbols.");
            }
            if (cleaned.length % 4 !== 0) {
              throw new Error(`Invalid padding: String length of ${cleaned.length} is not a multiple of 4.`);
            }
            return unicodeAtob(cleaned);
          } else if (mode === 'url') {
            if (/%[^0-9a-fA-F]/g.test(str) || /%[0-9a-fA-F](?![0-9a-fA-F])/g.test(str)) {
              throw new Error("Malformed URI sequence: Percent (%) sign must be followed by exactly two hexadecimal digits.");
            }
            return decodeURIComponent(str);
          } else {
            // Chained Decode
            const order = selChainedOrder?.value || 'b64-url';
            if (order === 'b64-url') {
              // URL Decode then B64 Decode
              if (/%[^0-9a-fA-F]/g.test(str) || /%[0-9a-fA-F](?![0-9a-fA-F])/g.test(str)) {
                throw new Error("Malformed URL-encoded sequence in chained decode.");
              }
              const urlDecoded = decodeURIComponent(str);
              let b64 = urlDecoded.trim();
              const b64Var = selB64Variant?.value || 'standard';
              if (b64Var === 'urlsafe' || /[-_]/.test(b64)) b64 = fromUrlSafeB64(b64);
              return unicodeAtob(b64);
            } else {
              // B64 Decode then URL Decode
              let b64 = str.trim();
              const b64Var = selB64Variant?.value || 'standard';
              if (b64Var === 'urlsafe' || /[-_]/.test(b64)) b64 = fromUrlSafeB64(b64);
              const b64Decoded = unicodeAtob(b64);
              if (/%[^0-9a-fA-F]/g.test(b64Decoded) || /%[0-9a-fA-F](?![0-9a-fA-F])/g.test(b64Decoded)) {
                throw new Error("Malformed URI sequence parsed from decoded Base64.");
              }
              return decodeURIComponent(b64Decoded);
            }
          }
        }
      };

      // File encoding priority
      if (targetPanel === 'b' && loadedFile && mode === 'b64' && direction === 'encode') {
        const b64Var = selB64Variant?.value || 'standard';
        let res = loadedFile.base64;
        if (b64Var === 'urlsafe') {
          res = toUrlSafeB64(res);
        }
        finalResult = res;
      } else {
        if (isBatch) {
          const lines = val.split('\n');
          const processed = lines.map(line => {
            if (!line) return '';
            try {
              return processString(line);
            } catch (e: any) {
              return `[Error: ${e.message}]`;
            }
          });
          finalResult = processed.join('\n');
        } else {
          finalResult = processString(val);
        }
      }

      // Populate results
      if (targetPanel === 'b') {
        editorB.value = finalResult;
        
        // Add subtle pulse on complete
        editorB.classList.add('ring-2', 'ring-success-accent/40');
        setTimeout(() => editorB.classList.remove('ring-2', 'ring-success-accent/40'), 400);

        // Check image preview if we decoded
        if (direction === 'decode') {
          checkAndRenderImagePreview(finalResult);
        } else if (mode === 'b64' && direction === 'encode' && loadedFile && loadedFile.type.startsWith('image/')) {
          if (imagePreviewContainer && imgPreview) {
            imgPreview.src = `data:${loadedFile.type};base64,${loadedFile.base64}`;
            imagePreviewContainer.classList.remove('hidden');
          }
        }
        
        // Save to History (Debounced or on complete conversion)
        saveToHistory(val || (loadedFile ? `[File: ${loadedFile.name}]` : ''), finalResult);
      } else {
        editorA.value = finalResult;
        
        editorA.classList.add('ring-2', 'ring-success-accent/40');
        setTimeout(() => editorA.classList.remove('ring-2', 'ring-success-accent/40'), 400);
      }

    } catch (e: any) {
      if (errorBanner && errorMsg) {
        errorMsg.textContent = e.message || 'Operation failed. Verify format structure and attributes.';
        errorBanner.classList.remove('hidden');
      }
    }

    updateStats();
    blockSync = false;
  }

  // Update Character / Word counts
  function updateStats() {
    if (statLengthA) {
      const len = editorA.value.length;
      statLengthA.textContent = `${len.toLocaleString()} character${len !== 1 ? 's' : ''}`;
    }
    if (statLengthB) {
      const len = editorB.value.length;
      statLengthB.textContent = `${len.toLocaleString()} character${len !== 1 ? 's' : ''}`;
    }
  }

  // History Management
  interface HistoryItem {
    id: string;
    mode: string;
    direction: string;
    input: string;
    output: string;
    timestamp: number;
  }

  function saveToHistory(input: string, output: string) {
    if (!input || !output || input.length > 5000 || output.length > 5000) return;
    try {
      const raw = localStorage.getItem('bt_converter_history');
      let items: HistoryItem[] = raw ? JSON.parse(raw) : [];

      // Avoid duplicates
      items = items.filter(item => item.input !== input || item.mode !== mode || item.direction !== direction);

      const newItem: HistoryItem = {
        id: Math.random().toString(36).substring(2, 9),
        mode,
        direction,
        input,
        output,
        timestamp: Date.now()
      };

      items.unshift(newItem);
      if (items.length > 10) items.pop();

      localStorage.setItem('bt_converter_history', JSON.stringify(items));
      renderHistory();
    } catch (e) {
      console.error(e);
    }
  }

  function renderHistory() {
    if (!historyList) return;
    try {
      const raw = localStorage.getItem('bt_converter_history');
      const items: HistoryItem[] = raw ? JSON.parse(raw) : [];

      if (items.length === 0) {
        historyEmptyMsg?.classList.remove('hidden');
        const childs = historyList.querySelectorAll('.history-card-item');
        childs.forEach(c => c.remove());
        return;
      }

      historyEmptyMsg?.classList.add('hidden');

      const childs = historyList.querySelectorAll('.history-card-item');
      childs.forEach(c => c.remove());

      items.forEach(item => {
        const row = document.createElement('div');
        row.className = 'history-card-item flex flex-col sm:flex-row items-start sm:items-center justify-between p-3 bg-surface hover:bg-hairline-soft border border-hairline rounded-lg text-xs gap-2 cursor-pointer transition-colors';
        row.setAttribute('data-id', item.id);

        const modeLabels: Record<string, string> = {
          'b64': 'Base64',
          'url': 'URL',
          'chained': 'Chained'
        };

        const dateStr = new Date(item.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const summaryText = item.input.length > 60 ? item.input.substring(0, 60) + '...' : item.input;

        row.innerHTML = `
          <div class="flex items-center gap-2 overflow-hidden w-full sm:w-auto">
            <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase ${item.direction === 'encode' ? 'bg-brand-coral/20 text-coral-dark' : 'bg-brand-teal/20 text-moss-dark'}">
              ${modeLabels[item.mode] || item.mode} ${item.direction}
            </span>
            <span class="truncate font-mono text-slate max-w-[280px] sm:max-w-[400px]">${escapeHTML(summaryText)}</span>
          </div>
          <div class="flex items-center gap-2 text-stone ml-auto sm:ml-0">
            <span>${dateStr}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        `;

        row.addEventListener('click', () => {
          editorA.value = item.input;
          mode = item.mode;
          direction = item.direction;

          mainTabs.forEach(btn => {
            const isMatch = btn.getAttribute('data-tab') === mode;
            btn.className = isMatch
              ? "px-4 py-1.5 rounded-lg text-xs font-bold transition-all cursor-pointer bg-primary text-canvas shadow-sm"
              : "px-4 py-1.5 rounded-lg text-xs font-semibold transition-all cursor-pointer text-slate hover:text-primary";
          });

          dirButtons.forEach(btn => {
            const isMatch = btn.getAttribute('data-dir') === direction;
            btn.className = isMatch
              ? "px-3 py-1 rounded-md text-[11px] font-bold transition-all cursor-pointer bg-brand-blue text-canvas"
              : "px-3 py-1 rounded-md text-[11px] font-semibold transition-all cursor-pointer text-slate hover:text-primary";
          });

          updateConfigVisibility();
          updatePanelLabels();
          runConversion('b');
        });

        historyList.appendChild(row);
      });

    } catch (e) {
      console.error(e);
    }
  }

  function escapeHTML(str: string): string {
    return str.replace(/[&<>'"]/g, 
      tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
    );
  }

