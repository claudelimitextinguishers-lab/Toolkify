  const btnCloseModal = document.getElementById('btn-close-modal');
  const btnModalDownload = document.getElementById('btn-modal-download');
  const btnModalClose = document.getElementById('btn-modal-close');

  // Application States
  let mode = 'b64'; // 'b64' | 'url' | 'chained'
  let direction = 'encode'; // 'encode' | 'decode'
  let blockSync = false; // Prevent circular triggers
  let activeSyncTarget = 'b';
  let loadedFile: { name: string; size: number; type: string; base64: string } | null = null;
  let detectedSuggestion: { targetMode: string; targetDir: string; message: string } | null = null;

  // Initial State Setup from URL parameters
  function initFromUrl() {
    try {
      const urlParams = new URLSearchParams(window.location.search);
      const urlInput = urlParams.get('input');
      const urlMode = urlParams.get('mode');
      const urlDir = urlParams.get('dir');
      const urlBatch = urlParams.get('batch');
      const urlVariant = urlParams.get('variant');
      const urlScope = urlParams.get('scope');

      if (urlMode) {
        mode = urlMode;
        mainTabs.forEach(btn => {
          const isMatch = btn.getAttribute('data-tab') === mode;
          btn.className = isMatch
            ? "px-2.5 sm:px-4 py-1.5 rounded-lg text-[11px] sm:text-xs font-bold transition-all cursor-pointer bg-primary text-canvas shadow-sm"
            : "px-2.5 sm:px-4 py-1.5 rounded-lg text-[11px] sm:text-xs font-semibold transition-all cursor-pointer text-slate hover:text-primary";
        });
      }

      if (urlDir) {
        direction = urlDir;
        dirButtons.forEach(btn => {
          const isMatch = btn.getAttribute('data-dir') === direction;
          btn.className = isMatch
            ? "px-3 py-1 rounded-md text-[11px] font-bold transition-all cursor-pointer bg-brand-blue text-canvas"
            : "px-3 py-1 rounded-md text-[11px] font-semibold transition-all cursor-pointer text-slate hover:text-primary";
        });
      }

      if (urlBatch === 'true' && chkBatchMode) {
        chkBatchMode.checked = true;
      }
      if (urlVariant && selB64Variant) {
        selB64Variant.value = urlVariant;
      }
      if (urlScope && selUrlScope) {
        selUrlScope.value = urlScope;
      }

      updateConfigVisibility();
      updatePanelLabels();

      if (urlInput && editorA) {
        editorA.value = decodeURIComponent(urlInput);
        runConversion('b'); // Convert inputs to outputs
      }
    } catch (e) {
      console.error('Failed to parse URL config', e);
    }
  }

  // Update visual configuration section visibility
  function updateConfigVisibility() {
    cfgB64Variant?.classList.toggle('hidden', mode !== 'b64');
    cfgUrlScope?.classList.toggle('hidden', mode !== 'url');
    cfgChainedOrder?.classList.toggle('hidden', mode !== 'chained');

    // File dropzone is only relevant for Base64 Encoding
    const isBase64Encode = (mode === 'b64' && direction === 'encode');
    fileDropzone?.classList.toggle('hidden', !isBase64Encode);
    if (!isBase64Encode && loadedFile) {
      removeFileState();
    }
  }

  // Update Symmetrical Panel Labels
  function updatePanelLabels() {
    if (!lblPanelA || !lblPanelB) return;

    if (direction === 'encode') {
      lblPanelA.innerHTML = `<span class="w-2.5 h-2.5 rounded-full bg-brand-coral"></span>Raw Unconverted Source`;
      lblPanelB.innerHTML = `<span class="w-2.5 h-2.5 rounded-full bg-brand-rose"></span>Encoded Result Output`;
    } else {
      lblPanelA.innerHTML = `<span class="w-2.5 h-2.5 rounded-full bg-brand-rose"></span>Encoded Hash or Parameter`;
      lblPanelB.innerHTML = `<span class="w-2.5 h-2.5 rounded-full bg-brand-coral"></span>Decoded Raw Representation`;
    }
  }

  // Auto-Detect Text Types
  function autoDetectPastedText(text: string) {
    if (!text || text.trim().length < 8) return;

    // Check if URL encoded
    const percentCount = (text.match(/%/g) || []).length;
    if (percentCount > 2 && /%[0-9a-fA-F]{2}/.test(text)) {
      if (mode !== 'url' || direction !== 'decode') {
        detectedSuggestion = {
          targetMode: 'url',
          targetDir: 'decode',
          message: 'Pasted text looks like URL Encoded content. Switch to URL Decode mode?'
        };
        showDetectionToast();
        return;
      }
    }

    // Check if Base64 (Standard or URL Safe)
    const cleaned = text.trim();
    const isBase64Regex = /^[A-Za-z0-9+/=]+$/;
    const isUrlSafeB64Regex = /^[A-Za-z0-9_-]+$/;

    // Detect data URI
    if (cleaned.startsWith('data:')) {
      if (mode !== 'b64' || direction !== 'decode') {
        detectedSuggestion = {
          targetMode: 'b64',
          targetDir: 'decode',
          message: 'Pasted text is a Data URL. Switch to Base64 Decode mode?'
        };
        showDetectionToast();
        return;
      }
    }

    // If it looks like base64
    if ((isBase64Regex.test(cleaned) && (cleaned.length % 4 === 0 || cleaned.includes('='))) || 
        (isUrlSafeB64Regex.test(cleaned) && cleaned.length > 20 && (cleaned.includes('-') || cleaned.includes('_')))) {
      if (mode !== 'b64' || direction !== 'decode') {
        detectedSuggestion = {
          targetMode: 'b64',
          targetDir: 'decode',
          message: 'Pasted text looks like Base64 encoded code. Switch to Base64 Decode mode?'
        };
        showDetectionToast();
        return;
      }
    }

    hideDetectionToast();
  }

  function showDetectionToast() {
    if (!detectionToast || !detectionText || !detectedSuggestion) return;
    detectionText.textContent = detectedSuggestion.message;
    detectionToast.classList.remove('hidden');
  }

  function hideDetectionToast() {
    detectionToast?.classList.add('hidden');
    detectedSuggestion = null;
  }

