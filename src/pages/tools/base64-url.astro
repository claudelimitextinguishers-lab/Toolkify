  const shareLinkInput = document.getElementById('share-link-input') as HTMLInputElement;
  const btnGenerateShare = document.getElementById('btn-generate-share');
  const btnSwapPanels = document.getElementById('btn-swap-panels');

  const btnLoadSample = document.getElementById('btn-load-sample');
  const btnClearA = document.getElementById('btn-clear-a');
  const btnClearB = document.getElementById('btn-clear-b');
  const btnCopyA = document.getElementById('btn-copy-a');
  const btnCopyB = document.getElementById('btn-copy-b');

  const statLengthA = document.getElementById('stat-length-a');
  const statLengthB = document.getElementById('stat-length-b');

  const detectionToast = document.getElementById('detection-toast');
  const detectionText = document.getElementById('detection-text');
  const btnApplyDetection = document.getElementById('btn-apply-detection');
  const btnDismissDetection = document.getElementById('btn-dismiss-detection');

  const historyList = document.getElementById('history-list');
  const btnClearHistory = document.getElementById('btn-clear-history');
