---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Chronological Age Calculator";
const category = "fun";
const tier = "Fun Tools";

// On-page SEO metadata
const pageTitle =
  "Chronological Age Calculator – Find Out Your Exact Age";
const description =
  "Free chronological age calculator to find out your exact age in years, months, weeks, days, hours, minutes, and seconds. Online age calculator for testing, Pearson & Super Duper scoring.";
const canonicalUrl =
  "https://boardtools.app/tools/fun/chronological-age";
const ogImage = "/og/chronological-age-calculator.png";
const keywords =
  "chronological age calculator, chronological age calculator pearson, super duper chronological age calculator, chronological age calculator find out your age, chronological age calculator for testing, free chronological age calculator, chronological age calculator super duper, biological age vs chronological age calculator, chronological age calculator in months, chronological age calculator year and month, online chronological age calculator, chronological age calculator in years, chronological age calculator in weeks, chronological age calculator in days, chronological age calculator in hours, chronological age calculator in minutes, chronological age calculator in seconds";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Chronological Age Calculator",
      "alternateName": "Chronological Age Calculator (Find Out Your Age)",
      "url": "https://boardtools.app/tools/fun/chronological-age",
      "description": "Free online chronological age calculator that finds your exact age in years, months, weeks, days, hours, minutes, and seconds. Includes clinical 15-day rounding for testing (Pearson and Super Duper style scoring) and corrected age for prematurity.",
      "applicationCategory": "EducationalApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Chronological age calculator in years, months, and weeks",
        "Chronological age calculator in days, hours, minutes, and seconds",
        "Chronological age calculator for testing with 15-day clinical rounding (Pearson / Super Duper style)",
        "Corrected age for prematurity (gestational adjustment)",
        "Calculate age as of any test date",
        "100% private, client-side calculations"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a chronological age calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A chronological age calculator works out the exact amount of time that has passed between a person's date of birth and a chosen reference date. This free online chronological age calculator finds out your age in years, months, weeks, days, hours, minutes, and seconds instantly."
          }
        },
        {
          "@type": "Question",
          "name": "How does the chronological age calculator for testing work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For testing, the chronological age is calculated as of the test date and expressed in years, months, and days. This tool follows the same conventions used by Pearson and Super Duper style assessments, including the optional 15-day rounding rule that rounds 15 or more remaining days up to the next month."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between biological age and chronological age?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Chronological age is simply how much time has passed since birth, which is what this calculator measures. Biological age estimates how old your body seems based on health markers. A biological age vs chronological age calculator compares the two, but chronological age is the precise, date-based figure used for testing and records."
          }
        },
        {
          "@type": "Question",
          "name": "Can I calculate chronological age in months, weeks, days, hours, minutes, and seconds?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. This chronological age calculator shows your age broken down into years and months as well as total weeks, days, hours, minutes, and seconds lived, so you can read your chronological age in months, in days, in hours, in minutes, or in seconds at a glance."
          }
        },
        {
          "@type": "Question",
          "name": "Is this chronological age calculator free and private?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. It is a 100% free chronological age calculator that runs entirely in your browser. No sign-up is required, it works on iPhone, Android, and desktop, and your birth date never leaves your device."
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-3"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-rose-light text-coral-dark text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap"
            >{tier}</span
          >
        </div>
        <div class="flex items-center gap-2 self-end sm:self-auto flex-wrap">
          <!-- Audio Toggle -->
          <button
            type="button"
            id="audio-toggle"
            class="inline-flex items-center justify-center w-8 h-8 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Toggle sound effects"
            title="Toggle sound effects"
          >
            <svg
              id="sound-on-icon"
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
              ></path>
            </svg>
            <svg
              id="sound-off-icon"
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zm10.914-4.5l3 3m0-3l-3 3"
              ></path>
            </svg>
          </button>

          <!-- Share Tool Link Button -->
          <button
            type="button"
            id="share-tool-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How It Works Button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How chronological age calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset Button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset fields"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div
      class="card-base p-4 sm:p-5 flex flex-col gap-4 dark-plum-theme relative overflow-hidden"
    >
      <!-- Background glow overlay for plum flavor -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-plum-bg/40 to-plum-bg/10 pointer-events-none"
      >
      </div>

      <!-- Mode Selector / Options Row -->
      <div
        class="flex items-center justify-between z-10 border-b border-plum-border/40 pb-3 flex-wrap gap-2"
      >
        <div class="flex items-center gap-2">
          <span
            class="text-[11px] uppercase font-bold text-plum-accent tracking-wider"
            >Mode:</span
          >
          <div class="flex items-center gap-1" id="mode-select-container">
            <button class="mode-btn active" id="btn-mode-standard">Standard</button>
            <button class="mode-btn" id="btn-mode-clinical">Clinical</button>
          </div>
        </div>
        <div
          class="text-[10px] text-plum-text-muted font-mono select-none"
          id="mode-hint"
        >
          Detailed chronological breakdown (Y/M/W/D/H)
        </div>
      </div>

      <!-- Main Layout Grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5 items-stretch z-10"
      >
        <!-- Left Pane: Input Forms -->
        <div class="flex flex-col gap-3 justify-between">
          <div class="flex flex-col gap-3">
            <h2 class="text-[11px] uppercase font-bold text-plum-text-bright tracking-wider">
              1. Date Inputs
            </h2>

            <!-- Birth Date -->
            <div class="flex flex-col gap-1">
              <label for="input-dob" class="text-[10px] font-semibold text-plum-text-muted">
                Date of Birth <span class="text-plum-accent">*</span>
              </label>
              <input
                type="text"
                id="input-dob"
                required
                placeholder="DD/MM/YYYY"
                inputmode="numeric"
                aria-invalid="false"
                aria-describedby="error-banner"
                class="w-full bg-plum-surface/50 border border-plum-border/40 text-plum-text-bright rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-plum-accent transition-colors font-mono"
              />
            </div>

            <!-- Optional Birth Time -->
            <div class="flex flex-col gap-1">
              <label for="input-tob" class="text-[10px] font-semibold text-plum-text-muted flex justify-between">
                <span>Time of Birth <span class="text-[9px] text-stone">(Optional)</span></span>
              </label>
              <input
                type="time"
                id="input-tob"
                value="00:00"
                class="w-full bg-plum-surface/50 border border-plum-border/40 text-plum-text-bright rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-plum-accent transition-colors font-mono"
              />
            </div>

            <!-- As Of Date -->
            <div class="flex flex-col gap-1">
              <label for="input-asof" class="text-[10px] font-semibold text-plum-text-muted">
                Calculate Age As Of
              </label>
              <input
                type="text"
                id="input-asof"
                placeholder="DD/MM/YYYY"
                inputmode="numeric"
                aria-invalid="false"
                aria-describedby="error-banner"
                class="w-full bg-plum-surface/50 border border-plum-border/40 text-plum-text-bright rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-plum-accent transition-colors font-mono"
              />
            </div>

            <!-- Optional As Of Time -->
            <div class="flex flex-col gap-1">
              <label for="input-asof-time" class="text-[10px] font-semibold text-plum-text-muted flex justify-between">
                <span>Time As Of <span class="text-[9px] text-stone">(Optional)</span></span>
              </label>
              <input
                type="time"
                id="input-asof-time"
                class="w-full bg-plum-surface/50 border border-plum-border/40 text-plum-text-bright rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-plum-accent transition-colors font-mono"
              />
            </div>

            <!-- Advanced / Clinician Toggles -->
            <div class="flex flex-col gap-2.5 pt-2 border-t border-plum-border/20">
              <!-- Gestational Adjustment -->
              <div class="flex items-center justify-between">
                <label for="toggle-gestational" class="text-[10px] font-semibold text-plum-text-muted cursor-pointer flex flex-col">
                  <span>Gestational Correction</span>
                  <span class="text-[8px] text-stone font-normal">For infants born prematurely (&lt; 37 weeks)</span>
                </label>
                <input
                  type="checkbox"
                  id="toggle-gestational"
                  class="w-4 h-4 rounded border-plum-border text-plum-accent focus:ring-plum-accent cursor-pointer"
                />
              </div>

              <!-- Gestational Weeks Input (Conditional) -->
              <div id="gestational-input-wrapper" class="hidden flex-col gap-1 pl-4 border-l-2 border-plum-accent/30 animate-fade-in-up">
                <label for="input-prematurity" class="text-[9px] uppercase font-bold text-plum-text-muted">
                  Weeks Premature (1 - 16 weeks)
                </label>
                <input
                  type="number"
                  id="input-prematurity"
                  min="1"
                  max="16"
                  placeholder="e.g. 4"
                  class="w-24 bg-plum-surface/50 border border-plum-border/40 text-plum-text-bright rounded-lg px-2 py-1 text-xs focus:outline-none focus:border-plum-accent transition-colors font-mono"
                />
              </div>

              <!-- 15-Day Rounding Toggle (Visible in Clinical mode) -->
              <div id="clinical-rounding-wrapper" class="hidden items-center justify-between animate-fade-in-up">
                <label for="toggle-rounding" class="text-[10px] font-semibold text-plum-text-muted cursor-pointer flex flex-col">
                  <span>15-Day Rounding Rule</span>
                  <span class="text-[8px] text-stone font-normal">Round $\ge$ 15 days up to next month</span>
                </label>
                <input
                  type="checkbox"
                  id="toggle-rounding"
                  class="w-4 h-4 rounded border-plum-border text-plum-accent focus:ring-plum-accent cursor-pointer"
                />
              </div>
            </div>
          </div>

          <!-- Action buttons -->
          <div class="flex gap-2.5 pt-2">
            <button
              type="button"
              id="calculate-btn"
              class="flex-1 inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2.5 bg-plum-accent text-canvas rounded-full transition-all cursor-pointer shadow-subtle hover:bg-plum-accent/90"
            >
              📊 Calculate Age
            </button>
          </div>
        </div>

        <!-- Right Pane: Results Dashboard -->
        <div
          class="flex flex-col justify-between p-3 sm:p-5 relative overflow-hidden rounded-xl border border-plum-border bg-plum-surface shadow-inner min-h-[300px] sm:min-h-[380px]"
        >
          <!-- Dynamic Glow -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-plum-accent/10 rounded-full blur-2xl pointer-events-none"></div>

          <div class="flex flex-col gap-3 sm:gap-4 z-10 w-full h-full justify-between">
            <!-- Results Header -->
            <div class="flex items-center justify-between border-b border-plum-border/40 pb-1.5 sm:pb-2">
              <span class="text-[10px] uppercase font-extrabold text-plum-accent tracking-widest">Age Output</span>
              <div class="flex items-center gap-1.5">
                <span class="text-[10px] font-mono text-plum-text-muted" id="status-label">Awaiting Input</span>
                <span class="flex h-2 w-2 relative">
                  <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75"></span>
                  <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-stone"></span>
                </span>
              </div>
            </div>

            <!-- Error Banner -->
            <div id="error-banner" class="hidden bg-brand-red/10 border border-brand-red-dark/30 rounded-lg p-2.5 text-[11px] text-brand-red-dark leading-relaxed animate-fade-in-up">
              ⚠️ Birthdate cannot be in the future relative to the "as of" date.
            </div>

            <!-- Results Reveal Container -->
            <div
              id="themed-reveal-container"
              class="flex flex-col items-center justify-center py-3 relative min-h-[160px] bg-black/20 rounded-xl border border-plum-border/20 backdrop-blur-sm shadow-inner transition-all duration-300"
            >
              <!-- Initial Idle State -->
              <div id="idle-readout" class="flex flex-col items-center gap-1.5 px-4 text-center">
                <span class="text-3xl animate-bounce">📅</span>
                <span class="text-xs font-semibold text-plum-text-bright">Enter a birth date to calculate</span>
                <span class="text-[10px] text-plum-text-muted max-w-[200px]">Calculates precise years, months, weeks, days, and hours instantly.</span>
              </div>

              <!-- Standard Mode Result Grid -->
              <div id="result-standard-grid" class="hidden w-full grid-cols-3 gap-2 px-3 animate-fade-in-up">
                <div class="flex flex-col items-center bg-plum-bg/40 p-2 rounded-lg border border-plum-border/10">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Years</span>
                  <span class="text-2xl sm:text-3xl font-mono font-black text-plum-text-bright mt-0.5" id="val-years">0</span>
                </div>
                <div class="flex flex-col items-center bg-plum-bg/40 p-2 rounded-lg border border-plum-border/10">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Months</span>
                  <span class="text-2xl sm:text-3xl font-mono font-black text-plum-text-bright mt-0.5" id="val-months">0</span>
                </div>
                <div class="flex flex-col items-center bg-plum-bg/40 p-2 rounded-lg border border-plum-border/10">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Weeks</span>
                  <span class="text-2xl sm:text-3xl font-mono font-black text-plum-text-bright mt-0.5" id="val-weeks">0</span>
                </div>
                <div class="flex flex-col items-center bg-plum-bg/40 p-2 rounded-lg border border-plum-border/10 col-span-1">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Days</span>
                  <span class="text-2xl sm:text-3xl font-mono font-black text-plum-text-bright mt-0.5" id="val-days">0</span>
                </div>
                <div class="flex flex-col items-center bg-plum-bg/40 p-2 rounded-lg border border-plum-border/10 col-span-2">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Hours</span>
                  <span class="text-2xl sm:text-3xl font-mono font-black text-plum-text-bright mt-0.5" id="val-hours">0</span>
                </div>
                <!-- Chronological Age Row (if gestational correction is active) -->
                <div id="standard-uncorrected-row" class="hidden text-[10px] text-plum-text-muted mt-2 border-t border-plum-border/20 pt-1.5 w-full text-center">
                  Chronological Age: <span id="val-uncorrected-standard" class="text-plum-text-bright font-mono">--</span>
                </div>
              </div>

              <!-- Clinical Mode Result -->
              <div id="result-clinical-box" class="hidden flex-col items-center gap-1 px-4 w-full text-center animate-fade-in-up">
                <span class="text-[9px] uppercase font-bold text-plum-text-muted">Clinical scoring format</span>
                <div class="font-display font-bold text-base sm:text-lg text-plum-text-bright leading-tight" id="clinical-readout-text">
                  0 years, 0 months, 0 days
                </div>
                <div class="font-mono font-black text-2xl sm:text-3xl text-plum-accent tracking-tight mt-1" id="clinical-readout">
                  0;0;0
                </div>
                <span class="text-[9px] text-stone mt-1" id="clinical-rounding-status">Standard exact calculation</span>
                <!-- Chronological Clinical Row (if gestational correction is active) -->
                <div id="clinical-uncorrected-row" class="hidden text-[10px] text-plum-text-muted mt-2 border-t border-plum-border/20 pt-1.5 w-full text-center">
                  Chronological Age: <span id="val-uncorrected-clinical" class="text-plum-text-bright font-mono">--</span>
                </div>
              </div>
            </div>

            <!-- Milestones / Secondary statistics -->
            <div id="milestones-box" class="hidden flex-col gap-1 border-t border-plum-border/40 pt-2 animate-fade-in-up">
              <span class="text-[9px] uppercase font-extrabold text-plum-accent">Total Lifespan Stats (Approx. Years/Months)</span>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-center">
                <div class="flex flex-col bg-plum-bg/25 p-1 rounded border border-plum-border/5">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Total Years</span>
                  <span id="stat-total-years" class="text-[11px] font-mono font-bold text-plum-text-bright">--</span>
                </div>
                <div class="flex flex-col bg-plum-bg/25 p-1 rounded border border-plum-border/5">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Total Months</span>
                  <span id="stat-total-months" class="text-[11px] font-mono font-bold text-plum-text-bright">--</span>
                </div>
                <div class="flex flex-col bg-plum-bg/25 p-1 rounded border border-plum-border/5">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Total Weeks</span>
                  <span id="stat-total-weeks" class="text-[11px] font-mono font-bold text-plum-text-bright">--</span>
                </div>
                <div class="flex flex-col bg-plum-bg/25 p-1 rounded border border-plum-border/5">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Total Days</span>
                  <span id="stat-total-days" class="text-[11px] font-mono font-bold text-plum-text-bright">--</span>
                </div>
                <div class="flex flex-col bg-plum-bg/25 p-1 rounded border border-plum-border/5">
                  <span class="text-[8px] uppercase font-bold text-plum-text-muted">Total Hours</span>
