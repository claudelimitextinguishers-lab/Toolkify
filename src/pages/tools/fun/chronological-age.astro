        gestationalInputWrapper?.classList.remove("flex");
        if (inputPrematurity) inputPrematurity.value = "";
      }
      triggerCalculation(false);
    });

    [inputDob, inputTob, inputAsof, inputAsofTime, inputPrematurity, toggleRounding].forEach(el => {
      el?.addEventListener("change", () => triggerCalculation(false));
      el?.addEventListener("input", () => triggerCalculation(false));
    });

    // Helper to parse typed/standard dates flexibly (strictly DD/MM/YYYY)
    function parseDateInput(value: string): Date | null {
      value = value.trim();
      if (!value) return null;

      // Match DD/MM/YYYY exactly
      const ddmm = /^(\d{2})\/(\d{2})\/(\d{4})$/.exec(value);
      if (ddmm) {
        const d = parseInt(ddmm[1], 10);
        const m = parseInt(ddmm[2], 10) - 1;
        const y = parseInt(ddmm[3], 10);
        const date = new Date(y, m, d);
        if (date.getFullYear() === y && date.getMonth() === m && date.getDate() === d) {
          return date;
        }
      }

      return null;
    }

    function parseDateTime(dateStr: string, timeStr: string): Date | null {
      const parsedDate = parseDateInput(dateStr);
      if (!parsedDate) return null;
      
      const [hours, minutes] = (timeStr || "00:00").split(":").map(x => parseInt(x, 10) || 0);
      return new Date(parsedDate.getFullYear(), parsedDate.getMonth(), parsedDate.getDate(), hours, minutes);
    }

    // Audit-compliant helper to calculate date subtraction difference
    // Accounts for both exact calendar month lengths and exact hour-minute day boundaries.
    function calculateAgeDifference(dob: Date, asOf: Date) {
      let years = asOf.getFullYear() - dob.getFullYear();
      let months = asOf.getMonth() - dob.getMonth();
      let days = asOf.getDate() - dob.getDate();

      // Fix hour/minute borrow: Convert standard clock hours/minutes to minutes of day,
      // and borrow a whole day if asOf time-of-day is before dob time-of-day.
      let timeDiffMinutes = (asOf.getHours() * 60 + asOf.getMinutes()) - (dob.getHours() * 60 + dob.getMinutes());
      if (timeDiffMinutes < 0) {
        timeDiffMinutes += 24 * 60;
        days--;
      }
      let hours = Math.floor(timeDiffMinutes / 60);

      // Fix date-borrow logic: If days < 0, borrow from months.
      if (days < 0) {
        months--;
        // Determine the actual number of days in the month immediately preceding the asOfDate's month.
        // We do this by creating a Date at day 0 of the asOf month (which naturally points to the last day of the preceding month).
        const prevMonth = new Date(asOf.getFullYear(), asOf.getMonth(), 0);
        const prevMonthDays = prevMonth.getDate();

        // Edge case: If the DOB day exceeds the number of days in the borrowed month (e.g. Feb in leap/non-leap years, EOM DOBs),
        // we cap the effective start day to the maximum capacity of that borrowed month to prevent negative/underflow days.
        const effectiveDobDate = Math.min(dob.getDate(), prevMonthDays);
        days = asOf.getDate() + (prevMonthDays - effectiveDobDate);
      }

      if (months < 0) {
        months += 12;
        years--;
      }

      const remainingWeeks = Math.floor(days / 7);
      const remainingDays = days % 7;

      return { years, months, days, hours, remainingWeeks, remainingDays };
    }

    // Calculate core age math
    function triggerCalculation(withSound: boolean = true) {
      if (!inputDob.value) {
        return; // DOB is required
      }

      // Parse DOB
      const dobDate = parseDateTime(inputDob.value, inputTob?.value);
      if (!dobDate) {
        showError(true, "⚠️ Please enter a valid Date of Birth (DD/MM/YYYY).");
        return;
      }

      // Parse As Of
      const currentDefaultStr = String(new Date().getDate()).padStart(2, "0") + "/" + 
        String(new Date().getMonth() + 1).padStart(2, "0") + "/" + 
        new Date().getFullYear();
      const asOfDate = parseDateTime(inputAsof.value || currentDefaultStr, inputAsofTime?.value);
      if (!asOfDate) {
        showError(true, "⚠️ Please enter a valid As Of Date (DD/MM/YYYY).");
        return;
      }

      // Gestational Adjustment (1-16 weeks clamping)
      let adjustedDob = new Date(dobDate.getTime());
      const applyCorrection = toggleGestational?.checked && inputPrematurity?.value;
      let weeksPremature = applyCorrection ? parseInt(inputPrematurity.value, 10) || 0 : 0;

      if (applyCorrection) {
        // Clamp to stated HTML range (1-16 weeks)
        if (weeksPremature < 1) weeksPremature = 1;
        if (weeksPremature > 16) weeksPremature = 16;
        inputPrematurity.value = weeksPremature.toString();

        // Adjust DOB later (add days)
        adjustedDob.setDate(adjustedDob.getDate() + (weeksPremature * 7));
      }

      // Validation
      if (adjustedDob.getTime() > asOfDate.getTime()) {
        showError(true, '⚠️ Birthdate cannot be in the future relative to the "as of" date.');
        return;
      }
      showError(false);

      // Total Milestones Calculations (uses corrected DOB if prematurity is applied)
      const diffMs = asOfDate.getTime() - adjustedDob.getTime();
      const totalYears = parseFloat((diffMs / (1000 * 60 * 60 * 24 * 365.2425)).toFixed(2));
      const totalMonths = parseFloat((diffMs / (1000 * 60 * 60 * 24 * 30.4375)).toFixed(1));
      const totalWeeks = parseFloat((diffMs / (1000 * 60 * 60 * 24 * 7)).toFixed(1));
      const totalDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
      const totalHours = Math.floor(diffMs / (1000 * 60 * 60));
      const totalMinutes = Math.floor(diffMs / (1000 * 60));
      const totalSeconds = Math.floor(diffMs / 1000);

      // Calculate both corrected (adjusted) and chronological age
      const correctedAge = calculateAgeDifference(adjustedDob, asOfDate);
      const chronologicalAge = calculateAgeDifference(dobDate, asOfDate);

      // Extract results for display
      const { years, months, days, hours, remainingWeeks, remainingDays } = correctedAge;

      // Update UI Status indicators
      if (statusLabel) statusLabel.textContent = "Calculated";
      if (statusDot) {
        statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-emerald-500";
      }
      if (statusPulse) {
        statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75";
      }

      if (withSound) {
        playCalculatedSound();
      }

      // Render Display Mode
      if (activeMode === "standard") {
        resultStandardGrid?.classList.remove("hidden");
        resultStandardGrid?.classList.add("grid");
        resultClinicalBox?.classList.add("hidden");

        // Animate count-up for corrected/adjusted values
        animateNumber(valYears, years);
        animateNumber(valMonths, months);
        animateNumber(valWeeks, remainingWeeks);
        animateNumber(valDays, remainingDays);
        animateNumber(valHours, hours);

        // Show/hide chronological age row if gestational correction is active
        if (applyCorrection && weeksPremature > 0) {
          standardUncorrectedRow?.classList.remove("hidden");
          if (valUncorrectedStandard) {
            valUncorrectedStandard.textContent = `${chronologicalAge.years}y ${chronologicalAge.months}m ${chronologicalAge.remainingWeeks}w ${chronologicalAge.remainingDays}d ${chronologicalAge.hours}h`;
          }
        } else {
          standardUncorrectedRow?.classList.add("hidden");
        }
      } else {
        // Clinical mode Y;M;D scoring
        resultStandardGrid?.classList.add("hidden");
        resultStandardGrid?.classList.remove("grid");
        resultClinicalBox?.classList.remove("hidden");
        resultClinicalBox?.classList.add("flex");

        // Apply Clinical Rounding Rule (15-Day Rule) on the corrected age
        let finalYears = years;
        let finalMonths = months;
        let finalDays = days;
        let roundedUp = false;

        const isRoundingEnabled = toggleRounding?.checked;

        if (isRoundingEnabled && days >= 15) {
          finalMonths++;
          finalDays = 0; // days rounded off
          roundedUp = true;
          if (finalMonths >= 12) {
            finalMonths = 0;
            finalYears++;
          }
        }

        const clinicalResultStr = roundedUp ? `${finalYears};${finalMonths}` : `${finalYears};${finalMonths};${finalDays}`;
        if (clinicalReadout) {
          clinicalReadout.textContent = clinicalResultStr;
        }

        // Formatted friendly representation
        let clinicalTextStr = "";
        if (roundedUp) {
          clinicalTextStr = `${finalYears} year${finalYears !== 1 ? 's' : ''} ${finalMonths} month${finalMonths !== 1 ? 's' : ''}`;
        } else {
          clinicalTextStr = `${finalYears} year${finalYears !== 1 ? 's' : ''} ${finalMonths} month${finalMonths !== 1 ? 's' : ''} ${finalDays} day${finalDays !== 1 ? 's' : ''}`;
        }
        if (clinicalReadoutText) {
          clinicalReadoutText.textContent = clinicalTextStr;
        }

        if (clinicalRoundingStatus) {
          if (isRoundingEnabled) {
            clinicalRoundingStatus.textContent = roundedUp 
              ? `Rounded UP (days was ${days} >= 15)`
              : `Rounded DOWN (days was ${days} < 15)`;
          } else {
            clinicalRoundingStatus.textContent = "Clinical exact calculation (Rounding off)";
          }
        }

        // Show/hide chronological age row in clinical box
        if (applyCorrection && weeksPremature > 0) {
          clinicalUncorrectedRow?.classList.remove("hidden");
          if (valUncorrectedClinical) {
            let chronoYears = chronologicalAge.years;
            let chronoMonths = chronologicalAge.months;
            let chronoDays = chronologicalAge.days;
            let chronoRoundedUp = false;

            if (isRoundingEnabled && chronoDays >= 15) {
              chronoMonths++;
              chronoDays = 0;
              chronoRoundedUp = true;
              if (chronoMonths >= 12) {
                chronoMonths = 0;
                chronoYears++;
              }
            }
            valUncorrectedClinical.textContent = chronoRoundedUp ? `${chronoYears};${chronoMonths}` : `${chronoYears};${chronoMonths};${chronoDays}`;
          }
        } else {
          clinicalUncorrectedRow?.classList.add("hidden");
        }
      }

      // Show Milestones and copy/share buttons
      milestonesBox?.classList.remove("hidden");
      milestonesBox?.classList.add("flex");
      actionBtnRow?.classList.remove("hidden");
      actionBtnRow?.classList.add("flex");
      idleReadout?.classList.add("hidden");

      // Update secondary stats
      if (statTotalYears) statTotalYears.textContent = totalYears.toLocaleString();
      if (statTotalMonths) statTotalMonths.textContent = totalMonths.toLocaleString();
      if (statTotalWeeks) statTotalWeeks.textContent = totalWeeks.toLocaleString();
      if (statTotalDays) statTotalDays.textContent = totalDays.toLocaleString();
      if (statTotalHours) statTotalHours.textContent = totalHours.toLocaleString();
      if (statTotalMinutes) statTotalMinutes.textContent = totalMinutes.toLocaleString();
      if (statTotalSeconds) statTotalSeconds.textContent = totalSeconds.toLocaleString();

      // Prematurity Badge Display
      if (applyCorrection && weeksPremature > 0) {
        gestationalBadge?.classList.remove("hidden");
        if (prematurityWeeksDisplay) prematurityWeeksDisplay.textContent = weeksPremature.toString();
      } else {
        gestationalBadge?.classList.add("hidden");
      }

      // Auto scroll to results container on mobile viewports
      if (window.innerWidth < 768 && withSound) {
        const revealContainer = document.getElementById("themed-reveal-container");
        if (revealContainer) {
          const navbarHeight = 64;
          const targetY = revealContainer.getBoundingClientRect().top + window.pageYOffset - navbarHeight - 16;
          window.scrollTo({ top: targetY, behavior: "smooth" });
        }
      }
    }

    // Numbers animation runner
    function animateNumber(element: HTMLElement | null, endValue: number) {
      if (!element) return;
      let startValue = 0;
      const duration = 400; // ms
      const startTime = performance.now();

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const easeOutQuad = progress * (2 - progress); // basic easing
        const currentValue = Math.floor(easeOutQuad * endValue);
        
        element!.textContent = currentValue.toString();

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          element!.textContent = endValue.toString();
        }
      }

      requestAnimationFrame(update);
    }

    function showError(visible: boolean, message: string = '⚠️ Birthdate cannot be in the future relative to the "as of" date.') {
      if (errorBanner) {
        errorBanner.textContent = message;
      }
      if (visible) {
        errorBanner?.classList.remove("hidden");
        resultStandardGrid?.classList.add("hidden");
        resultClinicalBox?.classList.add("hidden");
        milestonesBox?.classList.add("hidden");
        actionBtnRow?.classList.add("hidden");
        idleReadout?.classList.remove("hidden");
        inputDob?.setAttribute("aria-invalid", "true");
        inputAsof?.setAttribute("aria-invalid", "true");
      } else {
        errorBanner?.classList.add("hidden");
        inputDob?.setAttribute("aria-invalid", "false");
        inputAsof?.setAttribute("aria-invalid", "false");
      }
    }

    // Reset Calculator Fields
    function resetCalculator() {
      inputDob.value = "";
      inputTob.value = "00:00";
      setDefaultDates();
      
      toggleGestational.checked = false;
      gestationalInputWrapper?.classList.add("hidden");
      gestationalInputWrapper?.classList.remove("flex");
      if (inputPrematurity) inputPrematurity.value = "";

      toggleRounding.checked = false;

      // Reset Output State
      if (statusLabel) statusLabel.textContent = "Awaiting Input";
      if (statusDot) {
        statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-stone";
      }
      if (statusPulse) {
        statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75";
      }

      errorBanner?.classList.add("hidden");
      resultStandardGrid?.classList.add("hidden");
      resultStandardGrid?.classList.remove("grid");
      resultClinicalBox?.classList.add("hidden");
      milestonesBox?.classList.add("hidden");
      actionBtnRow?.classList.add("hidden");
      idleReadout?.classList.remove("hidden");
      
      standardUncorrectedRow?.classList.add("hidden");
      clinicalUncorrectedRow?.classList.add("hidden");

      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // Reset mode to standard
      setMode("standard");

      playResetSound();
    }

    // Attach listeners
    calculateBtn?.addEventListener("click", () => triggerCalculation(true));
    resetBtn?.addEventListener("click", resetCalculator);

    // Export formatted report copy logic
    shareBtn?.addEventListener("click", () => {
      const dobStr = inputDob.value;
      const tobStr = inputTob.value || "00:00";
      const asOfStr = inputAsof.value;
      const asOfTimeStr = inputAsofTime.value || "00:00";

      const applyCorrection = toggleGestational?.checked && inputPrematurity?.value;
      const weeksPremature = applyCorrection ? parseInt(inputPrematurity.value, 10) || 0 : 0;

      let reportText = `--- BOARDTOOLS CHRONOLOGICAL AGE REPORT ---\n`;
      reportText += `Date of Birth: ${dobStr} at ${tobStr}\n`;
      reportText += `Age calculated as of: ${asOfStr} at ${asOfTimeStr}\n`;

      if (applyCorrection && weeksPremature > 0) {
        reportText += `Prematurity Correction Applied: ${weeksPremature} week(s)\n`;
      }

      if (activeMode === "standard") {
        reportText += `Precise Age Breakdown:\n`;
        reportText += `- Years: ${valYears?.textContent || 0}\n`;
        reportText += `- Months: ${valMonths?.textContent || 0}\n`;
        reportText += `- Weeks: ${valWeeks?.textContent || 0}\n`;
        reportText += `- Days: ${valDays?.textContent || 0}\n`;
        reportText += `- Hours: ${valHours?.textContent || 0}\n`;
      } else {
        reportText += `Clinical Scoring Age (Y;M;D): ${clinicalReadout?.textContent || "0;0;0"}\n`;
        reportText += `Rounding Rule (15-Day Rule): ${toggleRounding.checked ? "Yes" : "No"} (${clinicalRoundingStatus?.textContent || ""})\n`;
      }

      reportText += `Total Milestones:\n`;
      reportText += `- Total Days Lived: ${statTotalDays?.textContent || "--"}\n`;
      reportText += `- Total Weeks Lived: ${statTotalWeeks?.textContent || "--"}\n`;
      reportText += `- Total Hours Lived: ${statTotalHours?.textContent || "--"}\n`;
      reportText += `------------------------------------------`;

      navigator.clipboard.writeText(reportText).then(() => {
        const span = shareBtn.querySelector("span");
        if (span) {
          const originalText = span.textContent || "Copy formatted report";
          span.textContent = "Report Copied to Clipboard!";
          setTimeout(() => {
            span.textContent = originalText;
          }, 2000);
        }
      }).catch(err => {
        console.error("Report copy failed: ", err);
      });
    });

    // Share tool URL logic
    const shareToolBtn = document.getElementById("share-tool-btn");
    shareToolBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("dob", inputDob.value);
      url.searchParams.set("tob", inputTob.value);
      url.searchParams.set("asof", inputAsof.value);
      url.searchParams.set("asofTime", inputAsofTime.value);
      url.searchParams.set("mode", activeMode);
      if (toggleGestational.checked && inputPrematurity.value) {
        url.searchParams.set("premature", inputPrematurity.value);
      }
      if (toggleRounding.checked) {
        url.searchParams.set("rounding", "1");
      }

      const shareData = {
        title: document.title || "Chronological Age Calculator",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareToolBtn) {
          const span = shareToolBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareToolBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareToolBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // How it works modal events
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    // Parse URL params on load
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.has("dob")) {
        inputDob.value = urlParams.get("dob") || "";
      } else {
        inputDob.value = "";
      }
      if (urlParams.has("tob")) {
        inputTob.value = urlParams.get("tob") || "00:00";
      } else {
        inputTob.value = "00:00";
      }
      if (urlParams.has("asof")) {
        inputAsof.value = urlParams.get("asof") || "";
      } else {
        setDefaultDates();
      }
      if (urlParams.has("asofTime")) {
        inputAsofTime.value = urlParams.get("asofTime") || "";
      }
      if (urlParams.has("mode")) {
        const mode = urlParams.get("mode") as CalculatorMode;
        if (mode === "standard" || mode === "clinical") {
          setMode(mode);
        }
      } else {
        setMode("standard");
      }
      if (urlParams.has("premature")) {
        toggleGestational.checked = true;
        gestationalInputWrapper?.classList.remove("hidden");
        gestationalInputWrapper?.classList.add("flex");
        inputPrematurity.value = urlParams.get("premature") || "";
      } else {
        toggleGestational.checked = false;
        gestationalInputWrapper?.classList.add("hidden");
        gestationalInputWrapper?.classList.remove("flex");
        inputPrematurity.value = "";
      }
      if (urlParams.has("rounding")) {
        toggleRounding.checked = urlParams.get("rounding") === "1";
      } else {
        toggleRounding.checked = false;
      }
      if (urlParams.has("dob")) {
        triggerCalculation(false);
      } else {
        // Reset Output State
        if (statusLabel) statusLabel.textContent = "Awaiting Input";
        if (statusDot) {
          statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-stone";
        }
        if (statusPulse) {
          statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75";
        }
        errorBanner?.classList.add("hidden");
        resultStandardGrid?.classList.add("hidden");
        resultStandardGrid?.classList.remove("grid");
        resultClinicalBox?.classList.add("hidden");
        milestonesBox?.classList.add("hidden");
        actionBtnRow?.classList.add("hidden");
        idleReadout?.classList.remove("hidden");
        standardUncorrectedRow?.classList.add("hidden");
        clinicalUncorrectedRow?.classList.add("hidden");
      }
    }

    window.addEventListener("popstate", loadState);

    loadState();
  </script>

  <!-- Help / How it works Guide Overlay Modal -->
  <div
    id="how-it-works-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto z-50">
      <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
        <h3 class="font-display font-semibold text-lg text-primary font-medium">How the Chronological Age Calculator Works</h3>
        <button
          type="button"
          id="close-modal-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >
          ✕
        </button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">1. Standard Date Calculations</h4>
        <p>
          Calculates the exact time elapsed between your date of birth and the chosen reference date (defaulting to today). It handles variations in month lengths (28, 29, 30, or 31 days) and leap years.
        </p>

        <h4 class="font-semibold text-primary">2. Clinical Mode (Assessment scoring)</h4>
        <p>
          Commonly used by clinicians and psychologists for tests like Pearson or Super Duper. It presents age as <code>Years;Months;Days</code>.
        </p>

        <h4 class="font-semibold text-primary">3. 15-Day Rounding Rule</h4>
        <p>
          Under the 15-day rule (used in clinical testing), if the remaining days are 15 or more, the age rounds up to the next full month. If they are 14 or less, they are rounded down.
        </p>

        <h4 class="font-semibold text-primary">4. Gestational Adjustment</h4>
        <p>
          For infants born prematurely (before 37 weeks gestation), the corrected age is calculated by subtracting the weeks of prematurity from the chronological age.
        </p>
      </div>
      <button
        type="button"
        id="modal-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
      </button>
    </div>
  </div>

  <!-- Animation & Effect Styles -->
  <style>
    /* Dark Plum Theme variables */
    .dark-plum-theme {
      --plum-bg: #2d1226;
      --plum-accent: #e040a9;
      --plum-accent-deep: #b82a84;
      --plum-border: rgba(224, 64, 169, 0.25);
      --plum-surface: rgba(30, 9, 23, 0.85);
      --plum-text-muted: #d6cbd3;
      --plum-text-bright: #ffffff;
    }

    .mode-btn {
      background-color: transparent;
      border: none;
      color: var(--plum-text-muted);
      font-size: 10px;
      font-weight: 600;
      padding: 5px 12px;
      border-radius: 9999px;
      cursor: pointer;
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .mode-btn.active,
    .mode-btn:hover {
      background-color: var(--plum-accent);
      color: #ffffff;
      box-shadow: 0 0 8px rgba(224, 64, 169, 0.4);
    }

    /* Calculate button scoped styles */
    .dark-plum-theme #calculate-btn {
      background-color: var(--plum-accent) !important;
      color: #ffffff !important;
      border: 1px solid transparent !important;
    }
    .dark-plum-theme #calculate-btn:hover {
      background-color: var(--plum-accent-deep) !important;
    }

    /* Share button scoped styles */
    .dark-plum-theme #share-btn {
      background-color: var(--plum-accent) !important;
      color: #ffffff !important;
      border: 1px solid transparent !important;
    }
    .dark-plum-theme #share-btn:hover {
      background-color: var(--plum-accent-deep) !important;
    }

    /* Input focus styling scope */
    .dark-plum-theme input:focus {
      border-color: var(--plum-accent) !important;
      box-shadow: 0 0 0 2px rgba(224, 64, 169, 0.15);
    }
  </style>
</Layout>
