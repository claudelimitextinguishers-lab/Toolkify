    // Synthesizer Helper
    function getAudioContext() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      }
      if (audioCtx.state === "suspended") {
        audioCtx.resume();
      }
      return audioCtx;
    }

    function playTone(freq: number, type: OscillatorType, duration: number, volume: number = 0.05) {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioContext();
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();

        osc.type = type;
        osc.frequency.setValueAtTime(freq, ctx.currentTime);
        gainNode.gain.setValueAtTime(volume, ctx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);

        osc.connect(gainNode);
        gainNode.connect(ctx.destination);
        osc.start();
        osc.stop(ctx.currentTime + duration);
      } catch (err) {
        console.warn("AudioContext playback error:", err);
      }
    }

    function playCalculatedSound() {
      playTone(587.33, "triangle", 0.1, 0.08); // D5
      setTimeout(() => playTone(880.00, "triangle", 0.25, 0.08), 80); // A5
    }

    function playResetSound() {
      playTone(440, "sine", 0.15, 0.05);
    }

    // Set Default Dates on Load
    function setDefaultDates() {
      const now = new Date();
      const localDateStr = String(now.getDate()).padStart(2, "0") + "/" + 
        String(now.getMonth() + 1).padStart(2, "0") + "/" + 
        now.getFullYear();
      
      const localTimeStr = String(now.getHours()).padStart(2, "0") + ":" + 
        String(now.getMinutes()).padStart(2, "0");

      if (inputAsof) {
        inputAsof.value = localDateStr;
      }
      if (inputAsofTime) {
        inputAsofTime.value = localTimeStr;
      }
    }

    function setupDateFormatter(input: HTMLInputElement | null) {
      if (!input) return;
      input.addEventListener("input", (e) => {
        const target = e.target as HTMLInputElement;
        let value = target.value.replace(/\D/g, "");
        if (value.length > 8) value = value.slice(0, 8);
        
        let formatted = "";
        if (value.length > 4) {
          formatted = `${value.slice(0, 2)}/${value.slice(2, 4)}/${value.slice(4)}`;
        } else if (value.length > 2) {
          formatted = `${value.slice(0, 2)}/${value.slice(2)}`;
        } else {
          formatted = value;
        }
        
        const selectionStart = target.selectionStart;
        const oldLength = target.value.length;
        
        target.value = formatted;
        
        if (selectionStart !== null && target.value.length !== oldLength) {
          const addedChars = target.value.length - oldLength;
          target.setSelectionRange(selectionStart + addedChars, selectionStart + addedChars);
        }
      });
    }

    setupDateFormatter(inputDob);
    setupDateFormatter(inputAsof);

    setDefaultDates();

    // Mode toggling
    function setMode(mode: CalculatorMode) {
      activeMode = mode;
