    });

    // Gestational Correction show/hide input
    toggleGestational?.addEventListener("change", () => {
      if (toggleGestational.checked) {
        gestationalInputWrapper?.classList.remove("hidden");
        gestationalInputWrapper?.classList.add("flex");
