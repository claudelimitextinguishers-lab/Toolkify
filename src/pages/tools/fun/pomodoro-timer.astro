              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 text-stone group-hover:text-primary transition-transform duration-200 shrink-0 ml-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-5 pt-1 text-sm text-slate leading-relaxed border-t border-hairline-soft/30 bg-surface-soft/10">
            <p>To improve kids' focus, encourage regular physical activity, ensure they get sufficient sleep, limit passive screen time, play concentration-building games (like puzzles or memory matches), and provide positive reinforcement for their attention efforts.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Client-side Logic Module -->
  <script>
    type TimerStage = "focus" | "short" | "long";

    // Configuration / Timer parameters
    let focusMinutes = 25;
    let shortMinutes = 5;
    let longMinutes = 15;
    let longInterval = 4;

    // Timer State
    let currentStage: TimerStage = "focus";
    let isRunning = false;
    let timeLeft = focusMinutes * 60; // in seconds
    let lastTime = 0; // high precision delta checker
    let currentCycle = 1;

    // Statistics
    let totalFocusMins = 0;
    let completedSessions = 0;
    let currentStreak = 0;
    let earlyAbandons = 0;

    let soundEnabled = true;
    let notificationsEnabled = false;
    let audioCtx: AudioContext | null = null;

    // DOM Elements
    const toggleSettingsBtn = document.getElementById("toggle-settings-btn");
    const settingsPanel = document.getElementById("settings-panel");
    const inputFocus = document.getElementById(
      "input-focus-duration",
    ) as HTMLInputElement;
    const inputShort = document.getElementById(
      "input-short-duration",
    ) as HTMLInputElement;
    const inputLong = document.getElementById(
      "input-long-duration",
    ) as HTMLInputElement;
    const inputInterval = document.getElementById(
      "input-long-interval",
    ) as HTMLInputElement;

    const tabFocus = document.getElementById("tab-focus");
    const tabShort = document.getElementById("tab-short");
    const tabLong = document.getElementById("tab-long");

    const timerClickArea = document.getElementById("timer-click-area");
    const timerProgressRing = document.querySelector(
      "#timer-progress-ring",
    ) as SVGCircleElement;
    const timerStageLabel = document.getElementById("timer-stage-label");
    const timerTimeLeft = document.getElementById("timer-time-left");
    const timerCyclePip = document.getElementById("timer-cycle-pip");
    const startPauseBtn = document.getElementById("start-pause-btn");
    const skipBtn = document.getElementById("skip-btn");
    const focusTargetNote = document.getElementById(
      "focus-target-note",
    ) as HTMLInputElement;

    const stateIndicator = document.getElementById("state-indicator");
    const statusDot = document.getElementById("status-dot");
    const statusPulse = document.getElementById("status-pulse");

    const outputMinutes = document.getElementById("output-total-minutes");
    const outputSessions = document.getElementById("output-total-sessions");
    const outputStreak = document.getElementById("output-current-streak");

    const classificationBadge = document.getElementById("classification-badge");
    const mainContextText = document.getElementById("main-context-text");
    const actionBtnRow = document.getElementById("action-btn-row");
    const shareBtn = document.getElementById("share-btn");
    const audioToggle = document.getElementById("audio-toggle");
    const soundOnIcon = document.getElementById("sound-on-icon");
    const soundOffIcon = document.getElementById("sound-off-icon");
    const notificationToggle = document.getElementById("notification-toggle");
    const resetBtn = document.getElementById("reset-btn");

    // Dynamic anim elements
    const pilotRadar = document.getElementById("pilot-radar");
    const racerSpeedlines = document.getElementById("racer-speedlines");
    const gamerNeon = document.getElementById("gamer-neon");
    const slothAnim = document.getElementById("sloth-anim");
    const dashboardReadout = document.getElementById("dashboard-readout");

    // Get Web Audio synthesizer helper
    function getAudioContext() {
      if (!audioCtx) {
        audioCtx = new (
          window.AudioContext || (window as any).webkitAudioContext
        )();
      }
      if (audioCtx.state === "suspended") {
        audioCtx.resume();
      }
      return audioCtx;
    }

    function playTone(
      freq: number,
      type: OscillatorType,
      duration: number,
      volume: number = 0.1,
    ) {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioContext();
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();

        osc.type = type;
        osc.frequency.setValueAtTime(freq, ctx.currentTime);

        gainNode.gain.setValueAtTime(volume, ctx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(
          0.0001,
          ctx.currentTime + duration,
        );

        osc.connect(gainNode);
        gainNode.connect(ctx.destination);

        osc.start();
        osc.stop(ctx.currentTime + duration);
      } catch (err) {
        console.warn("AudioContext playback error:", err);
      }
    }

    function playChimeStart() {
      playTone(523.25, "sine", 0.15, 0.1); // C5
      setTimeout(() => playTone(659.25, "sine", 0.25, 0.1), 120); // E5
    }

    function playChimeComplete() {
      playTone(523.25, "triangle", 0.15, 0.15); // C5
      setTimeout(() => playTone(659.25, "triangle", 0.15, 0.15), 100); // E5
      setTimeout(() => playTone(783.99, "triangle", 0.15, 0.15), 200); // G5
      setTimeout(() => playTone(1046.5, "triangle", 0.3, 0.25), 300); // C6
    }

    function playToneSkip() {
      playTone(220, "sawtooth", 0.15, 0.1); // low tone
    }

    // Toggle Settings panel
    toggleSettingsBtn?.addEventListener("click", () => {
      if (settingsPanel) {
        if (settingsPanel.classList.contains("hidden")) {
          settingsPanel.classList.remove("hidden");
          settingsPanel.classList.add("grid");
        } else {
          settingsPanel.classList.remove("grid");
          settingsPanel.classList.add("hidden");
        }
      }
    });

    // Handle updates in Settings
    function readSettings() {
      if (inputFocus) focusMinutes = parseInt(inputFocus.value, 10) || 25;
      if (inputShort) shortMinutes = parseInt(inputShort.value, 10) || 5;
      if (inputLong) longMinutes = parseInt(inputLong.value, 10) || 15;
      if (inputInterval) longInterval = parseInt(inputInterval.value, 10) || 4;

      focusMinutes = Math.max(1, Math.min(180, focusMinutes));
      shortMinutes = Math.max(1, Math.min(60, shortMinutes));
      longMinutes = Math.max(1, Math.min(120, longMinutes));
      longInterval = Math.max(1, Math.min(20, longInterval));

      if (inputFocus) inputFocus.value = focusMinutes.toString();
      if (inputShort) inputShort.value = shortMinutes.toString();
      if (inputLong) inputLong.value = longMinutes.toString();
      if (inputInterval) inputInterval.value = longInterval.toString();

      if (!isRunning) {
        resetTimerToStageDefault();
      }
    }

    [inputFocus, inputShort, inputLong, inputInterval].forEach((input) => {
      input?.addEventListener("change", readSettings);
      input?.addEventListener("input", readSettings);
    });

    // Setup Notification capability
    notificationToggle?.addEventListener("click", () => {
      if (!("Notification" in window)) {
        alert("This browser does not support desktop notification");
        return;
      }

      if (Notification.permission === "granted") {
        notificationsEnabled = !notificationsEnabled;
        updateNotificationIcon();
      } else if (Notification.permission !== "denied") {
        Notification.requestPermission().then((permission) => {
          if (permission === "granted") {
            notificationsEnabled = true;
          }
          updateNotificationIcon();
        });
      } else {
        alert(
          "Notifications are disabled in browser settings. Please enable them to receive alert notification.",
        );
      }
    });

    function updateNotificationIcon() {
      if (notificationToggle) {
        notificationToggle.textContent = notificationsEnabled
          ? "🔔 On"
          : "🔕 Off";
        notificationToggle.className = notificationsEnabled
          ? "inline-flex items-center justify-center px-2 h-8 bg-plum-accent text-canvas border border-plum-accent rounded-full font-semibold transition-all cursor-pointer text-[10px]"
          : "inline-flex items-center justify-center w-8 h-8 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle text-[11px]";
      }
    }

    function sendNotification(title: string, body: string) {
      if (notificationsEnabled && Notification.permission === "granted") {
        new Notification(title, {
          body,
          icon: "/favicon.ico",
        });
      }
    }

    // Timer stages definition
    function resetTimerToStageDefault() {
      if (currentStage === "focus") {
        timeLeft = focusMinutes * 60;
      } else if (currentStage === "short") {
        timeLeft = shortMinutes * 60;
      } else if (currentStage === "long") {
        timeLeft = longMinutes * 60;
      }
      updateTimerDisplay();
    }

    function switchStage(stage: TimerStage) {
      currentStage = stage;

      // Update active tabs
      [tabFocus, tabShort, tabLong].forEach((tab) =>
        tab?.classList.remove("active"),
      );
      if (stage === "focus") tabFocus?.classList.add("active");
      else if (stage === "short") tabShort?.classList.add("active");
      else if (stage === "long") tabLong?.classList.add("active");

      // Update timer texts
      if (timerStageLabel) {
        timerStageLabel.textContent =
          stage === "focus"
            ? "FOCUS"
            : stage === "short"
              ? "SHORT BREAK"
              : "LONG BREAK";
        timerStageLabel.className =
          stage === "focus"
            ? "text-[10px] sm:text-xs uppercase font-extrabold tracking-widest text-plum-accent mb-0.5"
            : "text-[10px] sm:text-xs uppercase font-extrabold tracking-widest text-success-accent mb-0.5";
      }

      if (timerCyclePip) {
        timerCyclePip.textContent = `Cycle ${currentCycle} of ${longInterval}`;
      }

      resetTimerToStageDefault();
    }

    [tabFocus, tabShort, tabLong].forEach((tab) => {
      tab?.addEventListener("click", (e) => {
        if (isRunning) {
          const confirmSwitch = confirm("Abandon current running session?");
          if (!confirmSwitch) return;
          earlyAbandons++;
          currentStreak = 0;
          updateDashboard();
          evaluatePersona();
        }
        pauseTimer();
        const targetId = (e.currentTarget as HTMLElement).id;
        if (targetId === "tab-focus") switchStage("focus");
        else if (targetId === "tab-short") switchStage("short");
        else if (targetId === "tab-long") switchStage("long");
      });
    });

    // Update Progress Ring & Texts
    function updateTimerDisplay() {
      // Formatted minute & second readout
      const mins = Math.floor(timeLeft / 60);
      const secs = timeLeft % 60;
      const formattedTime = `${mins.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;
      if (timerTimeLeft) {
        timerTimeLeft.textContent = formattedTime;
      }
      document.title = `${formattedTime} - ${currentStage === "focus" ? "Focus" : "Break"} | TOOLKIFY`;

      // Circular Ring logic
      let maxSeconds = focusMinutes * 60;
      if (currentStage === "short") maxSeconds = shortMinutes * 60;
      else if (currentStage === "long") maxSeconds = longMinutes * 60;

      const circumference = 565.48;
      const offsetPercent = (timeLeft / maxSeconds) * circumference;
      if (timerProgressRing) {
        timerProgressRing.style.strokeDashoffset = (
          circumference - offsetPercent
        ).toFixed(1);
      }
    }

    // Heartbeat Status updates
    function updateStateUI() {
      if (stateIndicator) {
        stateIndicator.textContent = isRunning
          ? `Status: ${currentStage === "focus" ? "Focusing" : "Resting"}`
          : "Status: Paused";
      }

      if (statusDot) {
        statusDot.className = isRunning
          ? `relative inline-flex rounded-full h-2 w-2 ${currentStage === "focus" ? "bg-rose-500" : "bg-emerald-500"}`
          : "relative inline-flex rounded-full h-2 w-2 bg-stone";
      }

      if (statusPulse) {
        statusPulse.className = isRunning
          ? `animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${currentStage === "focus" ? "bg-rose-500" : "bg-emerald-500"}`
          : "animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75";
      }

      if (startPauseBtn) {
        startPauseBtn.textContent = isRunning
          ? "⏸ Pause Timer"
          : "▶ Start Timer";
        startPauseBtn.className = isRunning
          ? "flex-1 inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2.5 bg-plum-border/50 text-plum-text-bright border border-plum-border rounded-full transition-all cursor-pointer"
          : "flex-1 inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2.5 bg-plum-accent text-canvas rounded-full transition-all cursor-pointer shadow-subtle hover:bg-plum-accent/90";
      }
    }

    // High Precision Timer loop
    let requestFrameId: number | null = null;
    function timerTick(now: number) {
      if (!isRunning) return;
      if (!lastTime) lastTime = now;
      const delta = (now - lastTime) / 1000;

      if (delta >= 1) {
        const secondsDrained = Math.floor(delta);
        timeLeft -= secondsDrained;
        lastTime = now - (delta % 1) * 1000; // preserve sub-second fractions

        if (timeLeft <= 0) {
          timeLeft = 0;
          updateTimerDisplay();
          handleSessionComplete();
          return;
        }
        updateTimerDisplay();
      }

      requestFrameId = requestAnimationFrame(timerTick);
    }

    function startTimer() {
      getAudioContext();
      isRunning = true;
      lastTime = 0;
      updateStateUI();
      playChimeStart();
      requestFrameId = requestAnimationFrame(timerTick);
    }

    function pauseTimer() {
      isRunning = false;
      if (requestFrameId) {
        cancelAnimationFrame(requestFrameId);
        requestFrameId = null;
      }
      updateStateUI();
      document.title = "Pomodoro / Focus Timer | TOOLKIFY";
    }

    startPauseBtn?.addEventListener("click", () => {
      if (isRunning) {
        pauseTimer();
      } else {
        startTimer();
      }
    });

    timerClickArea?.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("#start-pause-btn, #skip-btn")) return;
      if (isRunning) {
        pauseTimer();
      } else {
        startTimer();
      }
    });

    // Skip handler
    skipBtn?.addEventListener("click", () => {
      playToneSkip();
      if (isRunning) {
        earlyAbandons++;
        currentStreak = 0;
        updateDashboard();
        evaluatePersona();
      }
      advanceStage(true);
    });

    // Advance to next session stage
    function advanceStage(skipped: boolean = false) {
      pauseTimer();

      if (currentStage === "focus") {
        if (!skipped) {
          completedSessions++;
          currentStreak++;
          totalFocusMins += focusMinutes;
          updateDashboard();
          evaluatePersona();
        }

        // Move to break
        if (currentCycle >= longInterval) {
          currentCycle = 1; // reset cycle
          switchStage("long");
          sendNotification(
            "Focus Complete!",
            "Time for a well-deserved long break!",
          );
        } else {
          currentCycle++;
          switchStage("short");
          sendNotification("Focus Complete!", "Time for a quick short break!");
        }
      } else {
        // Break completed, move to focus
        switchStage("focus");
        sendNotification("Break Over!", "Let's start your next focus session!");
      }
      document.title = "Pomodoro / Focus Timer | TOOLKIFY";
      saveStats();
    }

    function handleSessionComplete() {
      playChimeComplete();
      advanceStage(false);
    }

    function saveStats() {
      localStorage.setItem("pomodoro-sessions", completedSessions.toString());
      localStorage.setItem("pomodoro-mins", totalFocusMins.toString());
      localStorage.setItem("pomodoro-streak", currentStreak.toString());
      localStorage.setItem("pomodoro-abandons", earlyAbandons.toString());
      localStorage.setItem("pomodoro-cycle", currentCycle.toString());
    }

    // Stats updates
    function updateDashboard() {
      if (outputMinutes) outputMinutes.textContent = totalFocusMins.toString();
      if (outputSessions)
        outputSessions.textContent = completedSessions.toString();
      if (outputStreak) outputStreak.textContent = currentStreak.toString();
      saveStats();
    }

    // Evaluate user focus persona
    function evaluatePersona() {
      let classification = "";
      let badgeStyle = "";
      let adviceMsg = "";

      // Hide all overlay anims
      pilotRadar?.classList.add("hidden");
      racerSpeedlines?.classList.add("hidden");
      gamerNeon?.classList.add("hidden");
      slothAnim?.classList.add("hidden");
      slothAnim?.classList.remove("flex");
      dashboardReadout?.classList.remove("hidden");
      actionBtnRow?.classList.add("hidden");
      actionBtnRow?.classList.remove("flex");

      if (completedSessions >= 4 && earlyAbandons === 0 && currentStreak >= 4) {
        classification = "Fighter Pilot Focus";
        badgeStyle =
          "bg-brand-yellow text-primary border border-brand-yellow-deep shadow-[0_0_12px_rgba(252,185,0,0.4)]";
        adviceMsg =
          "Absolute elite! Zero distractions and uninterrupted streaks. Your cognitive stamina is equivalent to a tactical pilot.";
        pilotRadar?.classList.remove("hidden");
        dashboardReadout?.classList.add("hidden");
        actionBtnRow?.classList.remove("hidden");
        actionBtnRow?.classList.add("flex");
      } else if (completedSessions >= 3 && earlyAbandons === 0) {
        classification = "F1 Pit-Crew Precision";
        badgeStyle =
          "bg-brand-blue text-canvas border border-blue-pressed shadow-[0_0_12px_rgba(66,98,255,0.4)]";
        adviceMsg =
          "Extremely clean and precise cycles. You transitioned efficiently without breaking attention lanes.";
        racerSpeedlines?.classList.remove("hidden");
        dashboardReadout?.classList.add("hidden");
        actionBtnRow?.classList.remove("hidden");
        actionBtnRow?.classList.add("flex");
      } else if (completedSessions >= 2) {
        classification = "Pro Gamer Grind";
        badgeStyle =
          "bg-success-accent text-canvas border border-moss-dark shadow-[0_0_12px_rgba(0,180,115,0.4)]";
        adviceMsg =
          "High volume of completions! You are grinding out deep work chunks back-to-back.";
        gamerNeon?.classList.remove("hidden");
        dashboardReadout?.classList.add("hidden");
        actionBtnRow?.classList.remove("hidden");
        actionBtnRow?.classList.add("flex");
      } else if (completedSessions >= 1) {
        classification = "Casual Cruiser";
        badgeStyle =
          "bg-plum-border/40 border border-plum-accent text-plum-text-bright";
        adviceMsg =
          "A great start! You completed a structured focus session. Keep the momentum going.";
      } else if (earlyAbandons >= 2) {
        classification = "Sleepy Sloth";
        badgeStyle = "bg-brand-coral text-canvas border border-coral-dark";
        adviceMsg =
          "Multiple resets or skipped focus blocks. Wake up, minimize chat windows, and try for a 5-minute custom block!";
        slothAnim?.classList.remove("hidden");
        slothAnim?.classList.add("flex");
        dashboardReadout?.classList.add("hidden");
      } else {
        classification = "Not Classified";
        badgeStyle =
          "bg-plum-border/30 text-plum-text-muted border border-plum-border/10";
        adviceMsg =
          "Complete focus sessions to unlock elite focus personas. Maintain your streak without skipping!";
      }

      if (classificationBadge) {
        classificationBadge.textContent = classification;
        classificationBadge.className = `text-[9px] py-0.5 px-2 rounded-full font-bold uppercase tracking-wider ${badgeStyle}`;
      }

      if (mainContextText) {
        mainContextText.textContent = adviceMsg;
      }
    }

    // Reset settings & stats
    function resetAllStats() {
      const confirmReset = confirm(
        "Are you sure you want to reset all focus stats?",
      );
      if (!confirmReset) return;

      pauseTimer();
      totalFocusMins = 0;
      completedSessions = 0;
      currentStreak = 0;
      earlyAbandons = 0;
      currentCycle = 1;

      saveStats();
      switchStage("focus");
      updateDashboard();
      evaluatePersona();

      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }
    }

    resetBtn?.addEventListener("click", resetAllStats);

    // Audio Toggle Setting
    audioToggle?.addEventListener("click", () => {
      soundEnabled = !soundEnabled;
      if (soundEnabled) {
        soundOnIcon?.classList.remove("hidden");
        soundOffIcon?.classList.add("hidden");
      } else {
        soundOnIcon?.classList.add("hidden");
        soundOffIcon?.classList.remove("hidden");
      }
    });

    // Share results copy to clipboard
    shareBtn?.addEventListener("click", () => {
      const targetNoteText = focusTargetNote?.value
        ? ` on "${focusTargetNote.value}"`
        : "";
      const textToCopy = `I unlocked the "${classificationBadge?.textContent || "Casual Cruiser"}" Focus Persona by completing ${completedSessions} session(s) (${totalFocusMins} focus minutes)${targetNoteText} on TOOLKIFY Pomodoro Timer! Try it out!`;
      navigator.clipboard
        .writeText(textToCopy)
        .then(() => {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share focus achievement";
            span.textContent = "Copied to Clipboard!";
            setTimeout(() => {
              span.textContent = originalText;
            }, 2000);
          }
        })
        .catch((err) => {
          console.error("Failed to copy text: ", err);
        });
    });

    // Share tool URL logic
    const shareToolBtn = document.getElementById("share-tool-btn");
    shareToolBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("focus", focusMinutes.toString());
      url.searchParams.set("short", shortMinutes.toString());
      url.searchParams.set("long", longMinutes.toString());
      url.searchParams.set("interval", longInterval.toString());

      const shareData = {
        title: document.title || "Pomodoro / Focus Timer",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareToolBtn) {
          const span = shareToolBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareToolBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareToolBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // How it works modal events
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    // Parse URL params on load
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      focusMinutes = urlParams.has("focus") ? parseInt(urlParams.get("focus") || "25", 10) : 25;
      if (inputFocus) inputFocus.value = focusMinutes.toString();

      shortMinutes = urlParams.has("short") ? parseInt(urlParams.get("short") || "5", 10) : 5;
      if (inputShort) inputShort.value = shortMinutes.toString();

      longMinutes = urlParams.has("long") ? parseInt(urlParams.get("long") || "15", 10) : 15;
      if (inputLong) inputLong.value = longMinutes.toString();

      longInterval = urlParams.has("interval") ? parseInt(urlParams.get("interval") || "4", 10) : 4;
      if (inputInterval) inputInterval.value = longInterval.toString();

      pauseTimer();
      switchStage("focus");
    }

    window.addEventListener("popstate", loadState);

    // Init Page setup
    loadState();
    completedSessions = parseInt(
      localStorage.getItem("pomodoro-sessions") || "0",
      10,
    );
    totalFocusMins = parseInt(localStorage.getItem("pomodoro-mins") || "0", 10);
    currentStreak = parseInt(
      localStorage.getItem("pomodoro-streak") || "0",
      10,
    );
    earlyAbandons = parseInt(
      localStorage.getItem("pomodoro-abandons") || "0",
      10,
    );
    currentCycle = parseInt(localStorage.getItem("pomodoro-cycle") || "1", 10);

    switchStage("focus");
    updateDashboard();
    evaluatePersona();

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });
  </script>

  <!-- Help / How it works Guide Overlay Modal -->
  <div
    id="how-it-works-modal"
