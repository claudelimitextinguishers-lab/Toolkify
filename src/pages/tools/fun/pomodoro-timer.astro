---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Pomodoro / Focus Timer";
const category = "fun";
const tier = "Fun Tools";

// On-page SEO metadata
// Primary keyword: "pomodoro timer"
const heading = "Pomodoro Timer";
const seoTitle = "Pomodoro Timer – Aesthetic Online Focus Timer App";
const description =
  "A free, aesthetic online Pomodoro timer for deep focus. Customize focus & break intervals, track streaks, and master the Pomodoro technique to study better.";
const keywords =
  "pomodoro timer, pomodoro timer app, pomodoro timer aesthetic, aesthetic pomodoro timer, pomodoro timer online, best pomodoro timer, online pomodoro timer, pomodoro, pomodoro method, pomodoro technique, pomodoro study method, focus, focus timer, pomodoro focus timer, focus timer app, focus timer online, deep focus timer, study focus timer, focus timer pomodoro";
const canonical =
  "https://toolkify.app/tools/fun/pomodoro-timer";
const ogImage = "https://toolkify.app/og-pomodoro-timer.png";
---

<Layout
  title={seoTitle}
  description={description}
  keywords={keywords}
  canonical={canonical}
  ogImage={ogImage}
  ogType="website"
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Pomodoro Timer - Aesthetic Online Focus Timer",
      "alternateName": "TOOLKIFY Pomodoro / Focus Timer",
      "url": "https://toolkify.app/tools/fun/pomodoro-timer",
      "description": "A free, aesthetic online Pomodoro timer and focus timer app. Customize focus and break intervals, track focus streaks, get background alerts, and unlock focus classification achievements using the Pomodoro technique.",
      "applicationCategory": "ProductivityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "inLanguage": "en",
      "isAccessibleForFree": true,
      "keywords": "pomodoro timer, pomodoro timer app, aesthetic pomodoro timer, online pomodoro timer, focus timer, pomodoro technique, study focus timer",
      "featureList": [
        "Customizable focus and break intervals",
        "Aesthetic dark plum design",
        "Focus streak and session tracking",
        "Background sound and browser notifications",
        "Focus persona achievements",
        "100% client-side and private"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Fun Tools",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Pomodoro Timer",
          "item": "https://toolkify.app/tools/fun/pomodoro-timer"
        }
      ]
    }
  </script>

  <!-- FAQ Schema for rich results -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Pomodoro?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Pomodoro is the Italian word for tomato. In a productivity context, it refers to a single 25-minute interval of focused work or study, named after the tomato-shaped kitchen timer originally used to track these sessions.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is the Pomodoro Technique?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The Pomodoro Technique is a time management method developed by Francesco Cirillo in the late 1980s. It involves breaking your workday into 25-minute focus intervals (called Pomodoros) separated by 5-minute short breaks. After completing four cycles, you take a longer break of 15 to 30 minutes to rest and recharge.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a Pomodoro timer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A Pomodoro timer is a tool—either physical, digital, or browser-based—used to track the structured work and break intervals of the Pomodoro Technique. It counts down the active focus periods and alerts you when it is time to take a break or resume working.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why is it called the Pomodoro Technique?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>It is called the Pomodoro Technique because its creator, Francesco Cirillo, used a tomato-shaped kitchen timer (which is \"pomodoro\" in Italian) to track his study sessions during his university years.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to focus?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To focus effectively, you should define a single, clear task, eliminate all physical and digital distractions (like phone notifications and extra browser tabs), work in dedicated time blocks, and take regular short breaks to maintain your mental stamina.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to improve focus?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>You can improve your focus by practicing mindfulness, ensuring you get adequate sleep, decluttering your workspace, taking regular breaks, and training your brain using structured time management methods like the Pomodoro Technique to build attention stamina.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is the best focus technique?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>While the best focus technique depends on individual preference, the Pomodoro Technique is widely considered one of the most effective due to its simple structure, built-in breaks that prevent mental fatigue, and how it combats procrastination.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to focus on yourself?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To focus on yourself, dedicate time to self-care, set clear personal boundaries, practice mindfulness or journaling, and establish quiet periods in your daily routine where you unplug from external demands to reflect on your goals and well-being.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to improve focus and concentration?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To improve focus and concentration, minimize multitasking, set specific daily goals, structure your work with a focus timer, keep your workspace organized, stay hydrated, and practice active listening or meditation to strengthen your attention span.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to help kids focus on studies?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>You can help kids focus on their studies by establishing a consistent daily routine, creating a quiet and dedicated study space free of screens, breaking tasks into smaller, manageable steps, and using shorter study intervals with fun, active breaks.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to improve kids focus?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To improve kids' focus, encourage regular physical activity, ensure they get sufficient sleep, limit passive screen time, play concentration-building games (like puzzles or memory matches), and provide positive reinforcement for their attention efforts.</p>"
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-3"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {heading}
          </h1>
          <span
            class="bg-rose-light text-coral-dark text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap"
            >{tier}</span
          >
        </div>
        <div class="flex items-center gap-2 self-end sm:self-auto">
          <!-- Audio Toggle -->
          <button
            type="button"
            id="audio-toggle"
            class="inline-flex items-center justify-center w-8 h-8 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Toggle sound effects"
            title="Toggle sound effects"
          >
            <svg
              id="sound-on-icon"
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
              ></path>
            </svg>
            <svg
              id="sound-off-icon"
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zm10.914-4.5l3 3m0-3l-3 3"
              ></path>
            </svg>
          </button>

          <!-- Notification Toggle -->
          <button
            type="button"
            id="notification-toggle"
            class="inline-flex items-center justify-center w-8 h-8 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle text-[11px]"
            aria-label="Toggle browser notifications"
            title="Toggle browser notifications"
          >
            🔔
          </button>

          <!-- Share Tool Link Button -->
          <button
            type="button"
            id="share-tool-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How It Works Button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How Pomodoro timer works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset Button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset timer stats"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset Stats</span>
          </button>
        </div>
      </div>
      <p class="text-[11px] sm:text-xs text-slate leading-relaxed mt-1 max-w-2xl">
        A free, aesthetic <strong>Pomodoro timer</strong> and focus timer that
        runs entirely in your browser. Use this online Pomodoro timer to study,
        work, and beat procrastination with the proven Pomodoro technique -
        customize your intervals, track your focus streak, and stay in deep
        focus.
      </p>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div
      class="card-base p-4 sm:p-5 flex flex-col gap-4 dark-plum-theme relative overflow-hidden"
    >
      <!-- Background glow overlay for plum flavor -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-plum-bg/40 to-plum-bg/10 pointer-events-none"
      >
      </div>

      <!-- Customizable Settings Panel (Compact & Inline) -->
      <div class="flex flex-col gap-3 z-10 border-b border-plum-border/40 pb-3">
        <div class="flex items-center justify-between">
          <span
            class="text-[11px] uppercase font-bold text-plum-accent tracking-wider flex items-center gap-1.5"
          >
            ⚙️ Timer Settings
          </span>
          <button
            id="toggle-settings-btn"
            class="inline-flex items-center gap-1 text-[10.5px] font-semibold px-3 py-1 bg-plum-surface hover:bg-plum-accent/20 border border-plum-border/60 text-plum-text-bright rounded-md transition-all cursor-pointer shadow-subtle hover:border-plum-accent"
          >
            Configure
          </button>
        </div>

        <div
          id="settings-panel"
          class="hidden grid-cols-2 sm:grid-cols-4 gap-3 bg-black/20 p-3 rounded-lg border border-plum-border/20 transition-all duration-300"
        >
          <div class="flex flex-col gap-1">
            <label class="text-[9px] uppercase font-bold text-plum-text-muted"
              >Focus (min)</label
            >
            <input
              type="number"
              id="input-focus-duration"
              min="1"
              max="180"
              value="25"
              class="bg-plum-bg text-plum-text-bright border border-plum-border rounded px-2 py-1 text-xs focus:outline-none focus:border-plum-accent font-mono"
            />
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-[9px] uppercase font-bold text-plum-text-muted"
              >Short Break (min)</label
            >
            <input
              type="number"
              id="input-short-duration"
              min="1"
              max="60"
              value="5"
              class="bg-plum-bg text-plum-text-bright border border-plum-border rounded px-2 py-1 text-xs focus:outline-none focus:border-plum-accent font-mono"
            />
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-[9px] uppercase font-bold text-plum-text-muted"
              >Long Break (min)</label
            >
            <input
              type="number"
              id="input-long-duration"
              min="1"
              max="120"
              value="15"
              class="bg-plum-bg text-plum-text-bright border border-plum-border rounded px-2 py-1 text-xs focus:outline-none focus:border-plum-accent font-mono"
            />
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-[9px] uppercase font-bold text-plum-text-muted"
              >Long Break After</label
            >
            <input
              type="number"
              id="input-long-interval"
              min="1"
              max="20"
              value="4"
              class="bg-plum-bg text-plum-text-bright border border-plum-border rounded px-2 py-1 text-xs focus:outline-none focus:border-plum-accent font-mono"
            />
          </div>
        </div>
      </div>

      <!-- Main Layout Grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5 items-stretch z-10"
      >
        <!-- Left Pane: Interactive Timer & Focus Note -->
        <div class="flex flex-col items-center justify-between gap-4 relative">
          <!-- Session Type Tabs -->
          <div
            class="flex items-center gap-1.5 bg-black/30 p-1 rounded-full border border-plum-border/30 w-full max-w-sm justify-around"
          >
            <button id="tab-focus" class="session-tab active">Focus</button>
            <button id="tab-short" class="session-tab">Short Break</button>
            <button id="tab-long" class="session-tab">Long Break</button>
          </div>

          <!-- Circular Timer Ring -->
          <div
            id="timer-click-area"
            class="relative w-52 h-52 sm:w-60 sm:h-60 flex items-center justify-center cursor-pointer transition-all duration-300 hover:scale-[1.03] active:scale-[0.98] group"
            title="Click to start/pause timer"
            role="button"
            aria-label="Click to start or pause timer"
          >
            <svg
              class="w-full h-full transform -rotate-90"
              viewBox="0 0 200 200"
            >
              <circle
                cx="100"
                cy="100"
                r="90"
                stroke="rgba(224, 64, 169, 0.1)"
                stroke-width="8"
                fill="transparent"
                class="transition-colors group-hover:stroke-plum-accent/20"
              ></circle>
              <circle
                id="timer-progress-ring"
                cx="100"
                cy="100"
                r="90"
                stroke="var(--plum-accent)"
                stroke-width="8"
                fill="transparent"
                stroke-dasharray="565.48"
                stroke-dashoffset="0"
                stroke-linecap="round"
                class="transition-all duration-300 group-hover:stroke-plum-accent-deep"
              ></circle>
            </svg>

            <!-- Center Text display -->
            <div
              class="absolute flex flex-col items-center justify-center text-center"
            >
              <span
                id="timer-stage-label"
                class="text-[10px] sm:text-xs uppercase font-extrabold tracking-widest text-plum-accent mb-0.5 group-hover:text-plum-text-bright transition-colors"
                >FOCUS</span
              >
              <span
                id="timer-time-left"
                class="font-display font-black text-4xl sm:text-5xl text-plum-text-bright font-mono leading-none tracking-tight group-hover:text-plum-accent transition-colors"
                >25:00</span
              >
              <span
                id="timer-cycle-pip"
                class="text-[8.5px] font-mono text-plum-text-muted mt-1.5 uppercase font-bold"
                >Cycle 1 of 4</span
              >
              <!-- Click prompt indicator -->
              <span
                class="text-[7.5px] uppercase font-bold text-plum-accent/60 opacity-0 group-hover:opacity-100 transition-opacity mt-1 tracking-wider"
              >
                Click to Start/Pause
              </span>
            </div>
          </div>

          <!-- Timer Actions Row -->
          <div class="flex items-center gap-2.5 w-full max-w-sm justify-center">
            <button
              type="button"
              id="start-pause-btn"
              class="flex-1 inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2.5 bg-plum-accent text-canvas rounded-full transition-all cursor-pointer shadow-subtle hover:bg-plum-accent/90"
            >
              ▶ Start Timer
            </button>
            <button
              type="button"
              id="skip-btn"
              class="inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2.5 bg-plum-surface border border-plum-border text-plum-text-bright rounded-full transition-all cursor-pointer hover:bg-plum-accent/20"
              title="Skip current session"
            >
              ⏭ Skip
            </button>
          </div>

          <!-- Focus Target Input -->
          <div class="w-full max-w-sm flex flex-col gap-1">
            <label
              for="focus-target-note"
              class="text-[9px] uppercase font-bold text-plum-text-muted"
              >Focus Target:</label
            >
            <input
              type="text"
              id="focus-target-note"
              placeholder="What are you focusing on right now?"
              class="w-full bg-plum-surface/50 border border-plum-border/40 text-plum-text-bright rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-plum-accent placeholder-plum-text-muted/40 transition-colors"
            />
          </div>
        </div>

        <!-- Right Pane: Focus Dashboard & Persona Reveal -->
        <div
          class="flex flex-col justify-between p-3 sm:p-5 relative overflow-hidden rounded-xl border border-plum-border bg-plum-surface shadow-inner min-h-[220px] sm:min-h-[320px]"
        >
          <!-- Dynamic glow -->
          <div
            class="absolute top-0 right-0 w-32 h-32 bg-plum-accent/10 rounded-full blur-2xl pointer-events-none"
          >
          </div>

          <div
            class="flex flex-col gap-2 sm:gap-4 z-10 w-full h-full justify-between"
          >
            <!-- Dashboard Header -->
            <div
              class="flex items-center justify-between border-b border-plum-border/40 pb-1.5 sm:pb-2"
            >
              <span
                class="text-[10px] uppercase font-extrabold text-plum-accent tracking-widest"
                >Focus Dashboard</span
              >
              <div class="flex items-center gap-1.5">
                <span
                  class="text-[10px] font-mono text-plum-text-muted"
                  id="state-indicator">Status: Paused</span
                >
                <span class="flex h-2 w-2 relative">
                  <span
                    id="status-pulse"
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75"
                  ></span>
                  <span
                    id="status-dot"
                    class="relative inline-flex rounded-full h-2 w-2 bg-stone"
                  ></span>
                </span>
              </div>
            </div>

            <!-- Focus Reveal Container / Animations Slot -->
            <div
              id="themed-reveal-container"
              class="flex flex-col items-center justify-center py-2 sm:py-4 relative min-h-[110px] sm:min-h-[160px] bg-black/20 rounded-xl border border-plum-border/20 backdrop-blur-sm shadow-inner transition-all duration-300"
            >
              <!-- Default state / live dashboard stats -->
              <div
                id="dashboard-readout"
                class="flex flex-col items-center gap-0.5 sm:gap-1 w-full px-4"
              >
                <span
                  class="text-[9px] sm:text-[10px] uppercase font-bold text-plum-text-muted"
                  >Total Focus Time</span
                >
                <div class="flex items-baseline gap-1 mt-0.5">
                  <span
                    id="output-total-minutes"
                    class="font-display font-black text-4xl sm:text-6xl text-plum-text-bright font-mono tracking-tight leading-none"
                    >0</span
                  >
                  <span
                    class="text-[10px] sm:text-xs font-semibold text-plum-accent"
                    >MINS</span
                  >
                </div>

                <!-- Secondary statistics grid -->
                <div
                  class="grid grid-cols-2 gap-4 w-full mt-2 sm:mt-3 pt-2 sm:pt-3 border-t border-plum-border/30 text-center"
                >
                  <div class="flex flex-col">
                    <span
                      class="text-[8px] uppercase font-bold text-plum-text-muted"
                      >Completed Sessions</span
                    >
                    <span
                      id="output-total-sessions"
                      class="text-xs sm:text-sm font-mono font-bold text-plum-text-bright"
                      >0</span
                    >
                  </div>
