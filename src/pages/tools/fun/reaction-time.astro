    </div>
  </section>

  <!-- Client-side logic module -->
  <script>
    // State machine definition
    type State = 'idle' | 'waiting' | 'stimulus' | 'falsestart' | 'result' | 'complete';
    let currentState: State = 'idle';

    // Core state variables
    let roundTimes: number[] = [];
    const maxRounds = 5;
    let timerId: number | null = null;
    let stimulusStartTime = 0;

    // Sound configuration
    let soundEnabled = true;
    let audioCtx: AudioContext | null = null;

    // DOM References
    const testBox = document.getElementById('test-box');
    const testIcon = document.getElementById('test-icon');
    const testTitle = document.getElementById('test-title');
    const testInstructions = document.getElementById('test-instructions');
    const waitingPulse = document.getElementById('waiting-pulse');
    const particleGrid = document.getElementById('particle-grid');
    const keyboardHint = document.getElementById('keyboard-hint');


    const roundIndicator = document.getElementById('round-indicator');
    const statusPulse = document.getElementById('status-pulse');
    const statusDot = document.getElementById('status-dot');

    const outputAverage = document.getElementById('output-average');
    const outputBestMetric = document.getElementById('output-best-metric');
    const outputSdMetric = document.getElementById('output-sd-metric');
    const outputWorst = document.getElementById('output-worst');
    const classificationBadge = document.getElementById('classification-badge');
    const mainContextText = document.getElementById('main-context-text');
    
    const audioToggle = document.getElementById('audio-toggle');
    const soundOnIcon = document.getElementById('sound-on-icon');
    const soundOffIcon = document.getElementById('sound-off-icon');
    const resetBtn = document.getElementById('reset-btn');

    // Chart Elements
    const chartContainer = document.getElementById('chart-container');
    const dashboardReadout = document.getElementById('dashboard-readout');
    const graphPath = document.querySelector('#graph-path') as SVGPathElement;
    const graphDots = document.getElementById('graph-dots');

    // Animations DOM
    const cockpitHUD = document.getElementById('cockpit-hud');
    const speedlines = document.getElementById('speedlines');
    const proGamerNeon = document.getElementById('pro-gamer-neon');
    const sleepySlothAnim = document.getElementById('sleepy-sloth-anim');

    // Audio synthesizer helper
    function getAudioContext() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      }
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      return audioCtx;
    }

    function playTone(freq: number, type: OscillatorType, duration: number, volume: number = 0.1) {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioContext();
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();

        osc.type = type;
        osc.frequency.setValueAtTime(freq, ctx.currentTime);

        gainNode.gain.setValueAtTime(volume, ctx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);

        osc.connect(gainNode);
        gainNode.connect(ctx.destination);

        osc.start();
        osc.stop(ctx.currentTime + duration);
      } catch (err) {
        console.warn('AudioContext playback error:', err);
      }
    }

    function playStartBeep() {
      playTone(1000, 'sine', 0.2, 0.2); // high pitched start go beep
    }

    function playFailBuzzer() {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioContext();
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();

        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(130, ctx.currentTime);
        osc.frequency.linearRampToValueAtTime(90, ctx.currentTime + 0.3);

        gainNode.gain.setValueAtTime(0.15, ctx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.3);

        osc.connect(gainNode);
        gainNode.connect(ctx.destination);

        osc.start();
        osc.stop(ctx.currentTime + 0.3);
      } catch (err) {}
    }

    function playVictoryBeep() {
      playTone(523.25, 'triangle', 0.15, 0.15); // C5
      setTimeout(() => playTone(659.25, 'triangle', 0.15, 0.15), 100); // E5
      setTimeout(() => playTone(783.99, 'triangle', 0.15, 0.15), 200); // G5
      setTimeout(() => playTone(1046.50, 'triangle', 0.3, 0.2), 300); // C6
    }

    // Toggle Audio Setting
    audioToggle?.addEventListener('click', () => {
      soundEnabled = !soundEnabled;
      if (soundEnabled) {
        soundOnIcon?.classList.remove('hidden');
        soundOffIcon?.classList.add('hidden');
      } else {
        soundOnIcon?.classList.add('hidden');
        soundOffIcon?.classList.remove('hidden');
      }
    });

    // Initialize/Load state from localStorage
    function init() {
      try {
        const savedHistory = localStorage.getItem('reaction-time-history-v3');
        if (savedHistory) {
          const parsed = JSON.parse(savedHistory);
          if (Array.isArray(parsed) && parsed.length === maxRounds) {
            roundTimes = parsed;
            currentState = 'complete';
            updateUI();
            renderCompletedStats();
            return;
          }
        }
      } catch (e) {
        console.warn('Failed to parse localStorage history:', e);
      }
      resetTest();
    }

    function resetTest() {
      if (timerId !== null) {
        clearTimeout(timerId);
        timerId = null;
      }
      roundTimes = [];
      currentState = 'idle';
      try {
        localStorage.removeItem('reaction-time-history-v3');
      } catch (e) {}
      updateUI();
    }

    // Handles the transition updates
    function transitionTo(state: State) {
      currentState = state;
      updateUI();

      if (state === 'waiting') {
        // Trigger randomized delay between 2000ms and 5000ms
        const delay = 2000 + Math.random() * 3000;
        timerId = window.setTimeout(() => {
          if (currentState === 'waiting') {
            transitionTo('stimulus');
          }
        }, delay);
      } else if (state === 'stimulus') {
        stimulusStartTime = performance.now();
        playStartBeep();
      }
    }

    // Trigger action (tap or space)
    function triggerAction(event?: PointerEvent | KeyboardEvent) {
      if (event) {
        event.preventDefault();
      }

      // Initialize Web Audio context on first user click gesture
      getAudioContext();

      switch (currentState) {
        case 'idle':
          roundTimes = [];
          transitionTo('waiting');
          break;

        case 'waiting':
          // Clicked too early (False Start)
          if (timerId !== null) {
            clearTimeout(timerId);
            timerId = null;
          }
          playFailBuzzer();
          transitionTo('falsestart');
          break;

        case 'falsestart':
          // Retry the round
          transitionTo('waiting');
          break;

        case 'stimulus':
          // Correct click
          const endTime = performance.now();
          const latency = Math.round(endTime - stimulusStartTime);
          roundTimes.push(latency);
          
          if (roundTimes.length >= maxRounds) {
            playVictoryBeep();
            transitionTo('complete');
            try {
              localStorage.setItem('reaction-time-history-v3', JSON.stringify(roundTimes));
            } catch (e) {}
          } else {
            // play normal round completion click sound
            playTone(660, 'sine', 0.15, 0.12);
            transitionTo('result');
          }
          break;

        case 'result':
          // Start next round
          transitionTo('waiting');
          break;

        case 'complete':
          // Reset
          resetTest();
          break;
      }
    }

    // Dynamic UI styling based on state
    function updateUI() {
      // Clean up styles
      testBox?.classList.remove(
        'bg-surface',
        'bg-success-accent',
        'bg-brand-coral',
        'animate-shake',
        'text-white',
        'shadow-[inset_0_0_80px_rgba(0,0,0,0.4)]'
      );
      testBox?.setAttribute('style', ''); // Clear inline backgrounds
      waitingPulse?.classList.add('hidden');
      particleGrid?.classList.add('opacity-[0.03]');
      particleGrid?.classList.remove('opacity-0');
      keyboardHint?.classList.remove('hidden');

      if (testTitle) testTitle.className = 'font-display font-bold text-lg sm:text-2xl text-primary leading-tight max-w-xs transition-colors duration-200';
      if (testInstructions) testInstructions.className = 'text-xs text-slate max-w-xs leading-relaxed transition-colors duration-200';

      // Update Round Indicator Text
      if (roundIndicator) {
        const roundCount = Math.min(roundTimes.length + (currentState === 'waiting' || currentState === 'stimulus' || currentState === 'falsestart' ? 1 : 0), maxRounds);
        roundIndicator.textContent = `Round ${roundCount} of 5`;
      }

      // Hide animation modes
      cockpitHUD?.classList.add('hidden');
      speedlines?.classList.add('hidden');
      proGamerNeon?.classList.add('hidden');
      sleepySlothAnim?.classList.add('hidden');
      dashboardReadout?.classList.remove('hidden');
      chartContainer?.classList.add('hidden');
      chartContainer?.classList.add('opacity-0');

      switch (currentState) {
        case 'idle':
          testBox?.classList.add('bg-surface');
          if (testIcon) testIcon.textContent = '🎯';
          if (testTitle) testTitle.textContent = 'Click to Start Test';
          if (testInstructions) {
            testInstructions.textContent = 'Once you click, the box will turn red. Wait for it to turn green, then click instantly!';
          }
          
          if (statusDot) statusDot.className = 'relative inline-flex rounded-full h-2 w-2 bg-stone';
          if (statusPulse) statusPulse.className = 'animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75';

          resetPips();
          break;

        case 'waiting':
          // Pulsing warning crimson waiting background
          if (testBox) {
            testBox.style.background = 'radial-gradient(circle, #e11d48 0%, #9f1239 100%)';
            testBox.classList.add('text-white', 'shadow-[inset_0_0_80px_rgba(0,0,0,0.4)]');
          }
          if (testTitle) {
            testTitle.textContent = 'Wait for Green...';
            testTitle.classList.add('text-white');
          }
          if (testInstructions) {
            testInstructions.textContent = 'Hold on! Focus and prepare to tap.';
            testInstructions.classList.add('text-rose-200');
          }
          waitingPulse?.classList.remove('hidden');
          particleGrid?.classList.add('opacity-0');
          particleGrid?.classList.remove('opacity-[0.03]');
          if (testIcon) testIcon.textContent = '🔴';

          if (statusDot) statusDot.className = 'relative inline-flex rounded-full h-2 w-2 bg-rose-500';
          if (statusPulse) statusPulse.className = 'animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-500 opacity-75';

          updatePips();
          break;

        case 'stimulus':
          testBox?.classList.add('bg-success-accent', 'text-white');
          particleGrid?.classList.add('opacity-0');
          particleGrid?.classList.remove('opacity-[0.03]');
          if (testIcon) testIcon.textContent = '🟢';
          if (testTitle) {
            testTitle.textContent = 'CLICK NOW!';
            testTitle.classList.add('text-white');
          }
          if (testInstructions) {
            testInstructions.textContent = 'GO GO GO!';
            testInstructions.classList.add('text-green-100');
          }

          if (statusDot) statusDot.className = 'relative inline-flex rounded-full h-2 w-2 bg-emerald-500';
          if (statusPulse) statusPulse.className = 'animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75';
          break;

        case 'falsestart':
          testBox?.classList.add('bg-brand-coral', 'animate-shake', 'text-white');
          if (testIcon) testIcon.textContent = '⚠️';
          if (testTitle) {
            testTitle.textContent = 'Too Early!';
            testTitle.classList.add('text-white');
          }
          if (testInstructions) {
            testInstructions.textContent = 'You clicked before the stimulus appeared. Tap to try again.';
            testInstructions.classList.add('text-red-100');
          }

          if (statusDot) statusDot.className = 'relative inline-flex rounded-full h-2 w-2 bg-brand-coral';
          if (statusPulse) statusPulse.className = 'animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-coral opacity-75';

          updatePipFalseStart();
          break;

        case 'result':
          testBox?.classList.add('bg-surface');
          const latestTime = roundTimes[roundTimes.length - 1];
          if (testIcon) testIcon.textContent = '⏱️';
          if (testTitle) testTitle.textContent = `${latestTime} ms`;
          if (testInstructions) testInstructions.textContent = 'Good reaction! Click to start the next round.';

          if (statusDot) statusDot.className = 'relative inline-flex rounded-full h-2 w-2 bg-stone';
          if (statusPulse) statusPulse.className = 'animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75';

          updatePips();
          updateDashboardSummary();
          break;

        case 'complete':
          testBox?.classList.add('bg-surface');
          if (testIcon) testIcon.textContent = '🏆';
          if (testTitle) testTitle.textContent = 'Test Complete!';
          if (testInstructions) testInstructions.textContent = 'Review your reflex profile. Click the box to restart.';
          keyboardHint?.classList.add('hidden');

          if (statusDot) statusDot.className = 'relative inline-flex rounded-full h-2 w-2 bg-emerald-500';
          if (statusPulse) statusPulse.className = 'animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75';

          updatePips();
          renderCompletedStats();
          break;
      }
    }

    function resetPips() {
      for (let i = 0; i < maxRounds; i++) {
        const pip = document.querySelector(`[data-pip-index="${i}"]`);
        const timeLbl = document.querySelector(`[data-time-index="${i}"]`);
        if (pip) {
          pip.className = 'w-full h-2 rounded-full bg-hairline-strong/30 border border-hairline-strong/10 transition-all duration-300';
        }
        if (timeLbl) {
          timeLbl.textContent = '--';
          timeLbl.className = 'text-[8px] font-mono text-stone';
        }
      }
      if (outputAverage) outputAverage.textContent = '--';
      if (outputBestMetric) outputBestMetric.textContent = '--';
      if (outputSdMetric) outputSdMetric.textContent = '--';
      if (outputWorst) outputWorst.textContent = '--';
      if (classificationBadge) {
        classificationBadge.textContent = 'Not Classified';
        classificationBadge.className = 'bg-hairline text-slate text-[9px] py-0.5 px-2 rounded-full font-bold uppercase tracking-wider';
      }
      if (mainContextText) {
        mainContextText.innerHTML = 'Complete all 5 rounds to evaluate your reaction speed profile. Click the arena to begin.';
      }
    }

    function updatePips() {
      // Color completed rounds green
      roundTimes.forEach((time, index) => {
        const pip = document.querySelector(`[data-pip-index="${index}"]`);
        const timeLbl = document.querySelector(`[data-time-index="${index}"]`);
        if (pip) {
          pip.className = 'w-full h-2 rounded-full bg-success-accent border border-success-accent/20 transition-all duration-300 scale-y-110';
        }
        if (timeLbl) {
          timeLbl.textContent = `${time}ms`;
          timeLbl.className = 'text-[8px] font-mono font-bold text-success-accent';
        }
      });

      // Highlight current round in blue if waiting/stimulus
      if (currentState === 'waiting' || currentState === 'stimulus') {
        const currentIndex = roundTimes.length;
        const currentPip = document.querySelector(`[data-pip-index="${currentIndex}"]`);
        if (currentPip) {
          currentPip.className = 'w-full h-2 rounded-full bg-brand-blue border border-brand-blue/20 animate-pulse transition-all duration-300 scale-y-110';
        }
      }
    }

    function updatePipFalseStart() {
      const currentIndex = roundTimes.length;
      const currentPip = document.querySelector(`[data-pip-index="${currentIndex}"]`);
      const timeLbl = document.querySelector(`[data-time-index="${currentIndex}"]`);
      if (currentPip) {
        currentPip.className = 'w-full h-2 rounded-full bg-brand-coral border border-brand-coral/20 transition-all duration-300 scale-y-110';
      }
      if (timeLbl) {
        timeLbl.textContent = 'Early';
        timeLbl.className = 'text-[8px] font-mono font-bold text-brand-coral';
      }
    }

    function calculateStats() {
      if (roundTimes.length === 0) return { avg: 0, best: 0, worst: 0, sd: 0 };
      const best = Math.min(...roundTimes);
      const worst = Math.max(...roundTimes);
      const sum = roundTimes.reduce((a, b) => a + b, 0);
      const avg = Math.round(sum / roundTimes.length);
      
      // Calculate standard deviation
      const mean = sum / roundTimes.length;
      const variance = roundTimes.reduce((acc, val) => acc + Math.pow(val - mean, 2), 0) / roundTimes.length;
      const sd = Math.round(Math.sqrt(variance));

      return { avg, best, worst, sd };
    }

    function updateDashboardSummary() {
      const { avg, best, sd } = calculateStats();
      if (outputAverage) outputAverage.textContent = avg.toString();
      if (outputBestMetric) outputBestMetric.textContent = `${best} ms`;
      if (outputSdMetric) outputSdMetric.textContent = `±${sd} ms`;
    }

    // Graph drawing helper
    function renderHistoryGraph() {
      if (roundTimes.length < 2 || !graphPath || !graphDots) return;

      const minVal = Math.min(...roundTimes) * 0.85; // buffer
      const maxVal = Math.max(...roundTimes) * 1.15; // buffer
      const spread = maxVal - minVal || 1;

      // 5 steps across X axis (0 to 100)
      const points = roundTimes.map((time, idx) => {
        const x = (idx / (maxRounds - 1)) * 100;
        // Y goes from 90 (bottom/slow) to 10 (top/fast)
        const y = 90 - ((time - minVal) / spread) * 80;
        return { x, y, val: time };
      });

      // Build path string
      const pathStr = points.map((p, idx) => `${idx === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');
      graphPath.setAttribute('d', pathStr);

      // Render dots
      graphDots.innerHTML = '';
      points.forEach((p, idx) => {
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', p.x.toString());
        circle.setAttribute('cy', p.y.toString());
        circle.setAttribute('r', '3.5');
        circle.setAttribute('fill', '#00b473');
        circle.setAttribute('stroke', '#ffffff');
        circle.setAttribute('stroke-width', '1.5');
        circle.innerHTML = `<title>Round ${idx + 1}: ${p.val}ms</title>`;
        
        // Ripple effect on hover
        circle.style.cursor = 'pointer';
        circle.style.transition = 'r 0.15s ease';
        circle.addEventListener('mouseenter', () => circle.setAttribute('r', '5.5'));
        circle.addEventListener('mouseleave', () => circle.setAttribute('r', '3.5'));

        graphDots.appendChild(circle);
      });
    }

    function renderCompletedStats() {
      const { avg, best, worst, sd } = calculateStats();

      if (outputAverage) outputAverage.textContent = avg.toString();
      if (outputBestMetric) outputBestMetric.textContent = `${best} ms`;
      if (outputSdMetric) outputSdMetric.textContent = `±${sd} ms`;
      if (outputWorst) outputWorst.textContent = `${worst} ms`;

      // Draw performance chart
      renderHistoryGraph();
      dashboardReadout?.classList.add('hidden');
      chartContainer?.classList.remove('hidden');
      setTimeout(() => {
        chartContainer?.classList.remove('opacity-0');
      }, 50);

      // Evaluate Reflex benchmarks
      let classification = '';
      let badgeStyle = '';
      let adviceMsg = '';

      if (avg < 180) {
        classification = 'Fighter Jet Pilot';
        badgeStyle = 'bg-brand-yellow text-primary border border-brand-yellow-deep shadow-[0_0_12px_rgba(252,185,0,0.4)]';
        adviceMsg = `Astonishing reflexes! Your average reaction speed of <strong>${avg}ms</strong> places you in the elite rank of Fighter Jet Pilots. This level of rapid cognitive-motor response is exceptionally rare in the general public.`;
        
        // Show Cockpit Radar effect
        cockpitHUD?.classList.remove('hidden');
      } else if (avg >= 180 && avg < 210) {
        classification = 'F1 Racer';
        badgeStyle = 'bg-brand-blue text-canvas border border-blue-pressed shadow-[0_0_12px_rgba(66,98,255,0.4)]';
        adviceMsg = `Incredible response! With an average of <strong>${avg}ms</strong>, you possess the reflexes of an F1 Driver. You are perfectly suited to high-speed decision environments and rapid visual changes.`;
        
        // Show Speedlines effect
        speedlines?.classList.remove('hidden');
      } else if (avg >= 210 && avg < 240) {
        classification = 'Pro Gamer';
        badgeStyle = 'bg-success-accent text-canvas border border-moss-dark shadow-[0_0_12px_rgba(0,180,115,0.4)]';
        adviceMsg = `Excellent twitch reflexes. Your average of <strong>${avg}ms</strong> ranks you alongside competitive esports athletes. You process visual stimuli faster than over 80% of adults.`;
        
        // Show Neon gaming effect
        proGamerNeon?.classList.remove('hidden');
      } else if (avg >= 240 && avg < 300) {
        classification = 'Average Adult';
        badgeStyle = 'bg-surface border border-hairline-strong text-primary';
        adviceMsg = `Solid average reflexes. Your reaction speed of <strong>${avg}ms</strong> is right in the center of the normal curve for human visual reaction speeds. Highly functional for everyday tasks.`;
      } else if (avg >= 300 && avg < 450) {
        classification = 'Slower than Average';
        badgeStyle = 'bg-brand-coral/20 text-coral-dark border border-brand-coral/40';
        adviceMsg = `Your average score of <strong>${avg}ms</strong> is slightly slower than typical standards. This could be due to late-night fatigue, distractions, display panel lag, or normal metabolic variations.`;
      } else {
        classification = 'Sleepy Sloth';
        badgeStyle = 'bg-brand-coral text-canvas border border-coral-dark';
        adviceMsg = `Reflex speed is <strong>${avg}ms</strong>. Are you a bit sleep-deprived or distracted? Get some rest, close secondary tabs, and try again when fully charged!`;
        
        // Show Sloth Sleep animation
        sleepySlothAnim?.classList.remove('hidden');
      }

      if (classificationBadge) {
        classificationBadge.textContent = classification;
        classificationBadge.className = `text-[9px] py-0.5 px-2 rounded-full font-bold uppercase tracking-wider ${badgeStyle}`;
      }

      if (mainContextText) {
        mainContextText.innerHTML = adviceMsg;
      }
    }

    // Attach event listeners
    testBox?.addEventListener('pointerdown', (e) => {
      triggerAction(e);
    });

    // Spacebar trigger handler
    testBox?.addEventListener('keydown', (e) => {
      if (e.code === 'Space') {
        triggerAction(e);
      }
    });

    // Reset button
    resetBtn?.addEventListener('click', () => {
      resetTest();
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }
    });

    // Share tool URL logic
    const shareToolBtn = document.getElementById("share-tool-btn");
    shareToolBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);

      const shareData = {
        title: document.title || "Reaction Time Test",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareToolBtn) {
          const span = shareToolBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareToolBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareToolBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // How it works modal events
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    // Cursor reactive grid glow
    testBox?.addEventListener('pointermove', (e: PointerEvent) => {
      if (currentState === 'idle' || currentState === 'result' || currentState === 'complete') {
        const rect = testBox.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        testBox.style.setProperty('--cursor-x', `${x}px`);
        testBox.style.setProperty('--cursor-y', `${y}px`);
      }
    });

    // Parse URL params on load
    function loadState() {
      resetTest();
    }

    window.addEventListener("popstate", loadState);

    // Initial page load
    loadState();
    init();
  </script>

  <!-- Help / How it works Guide Overlay Modal -->
  <div
    id="how-it-works-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto z-50">
      <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
        <h3 class="font-display font-semibold text-lg text-primary font-medium">How the Reaction Time Test Works</h3>
        <button
          type="button"
          id="close-modal-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >
          ✕
        </button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">1. Test Mechanics</h4>
        <p>
          The test measures how quickly you respond to a visual stimulus. When you click the arena, it prepares the test. The box will turn red, warning you to wait. After a random delay (between 1.5 to 5 seconds), the box turns green.
        </p>

        <h4 class="font-semibold text-primary">2. Registering Your Response</h4>
        <p>
          The moment the box turns green, click or press spacebar as fast as you can. The tool records the difference in milliseconds between the green signal and your press.
        </p>

        <h4 class="font-semibold text-primary">3. False Starts</h4>
        <p>
          If you click while the box is red, it registers a false start. You will have to restart that round.
        </p>

        <h4 class="font-semibold text-primary">4. Final Scoring Tiers</h4>
        <p>
          Your average over 5 completed rounds is calculated and compared to professional reflex tiers:
        </p>
        <ul class="list-disc pl-4 flex flex-col gap-1">
          <li><strong>Fighter Jet Pilot:</strong> Under 180 ms</li>
          <li><strong>F1 Racer:</strong> 180–210 ms</li>
          <li><strong>Pro Gamer:</strong> 210–240 ms</li>
          <li><strong>Average Adult:</strong> 240–300 ms</li>
          <li><strong>Sleepy Sloth:</strong> 450+ ms</li>
        </ul>
      </div>
      <button
        type="button"
        id="modal-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
      </button>
    </div>
  </div>

  <!-- Animation & Effect Styles -->
  <style>
    /* cursor reactive grid glow styling */
    #test-box {
      --cursor-x: 50%;
      --cursor-y: 50%;
      position: relative;
    }
    #test-box::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(180px circle at var(--cursor-x) var(--cursor-y), rgba(66,98,255,0.06), transparent 80%);
      opacity: 0.8;
      pointer-events: none;
      transition: opacity 0.5s ease;
      z-index: 1;
    }

    /* Slow pulse animation for waiting screen heartbeat */
    @keyframes ping-slow {
      0% { transform: scale(0.9); opacity: 0.6; }
      50% { transform: scale(1.1); opacity: 0.2; }
      100% { transform: scale(1.3); opacity: 0; }
    }
    .animate-ping-slow {
      animation: ping-slow 1.8s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;
    }

    /* Ripple Click Indicator */
    @keyframes ripple {
      to {
        transform: scale(3) translate(-17%, -17%);
        opacity: 0;
      }
    }
    .animate-ripple {
      animation: ripple 0.55s cubic-bezier(0.1, 0.8, 0.3, 1) forwards;
    }

    /* Shake animation for false starts */
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      15%, 45%, 75% { transform: translateX(-6px); }
      30%, 60%, 90% { transform: translateX(6px); }
    }
    .animate-shake {
      animation: shake 0.4s ease-in-out;
    }

    /* Radar / Cockpit HUD effect styles */
    .hud-effect {
      background: radial-gradient(circle, rgba(24,117,116,0.15) 0%, rgba(28,28,30,0.96) 100%);
      border: 2px solid #00b473;
    }
    .radar-line {
      position: absolute;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, transparent, #00b473, transparent);
      top: 0;
      animation: radar-sweep 2.5s infinite linear;
    }
    @keyframes radar-sweep {
      0% { top: 0%; opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { top: 100%; opacity: 0; }
    }
    .crosshair-target {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 40px;
      height: 40px;
      border: 1px solid #00b473;
      border-radius: 50%;
      transform: translate(-50%, -50%);
      animation: target-pulse 1.2s infinite ease-in-out;
    }
    .crosshair-target::before, .crosshair-target::after {
      content: '';
      position: absolute;
      background: #00b473;
    }
    .crosshair-target::before {
      top: 50%;
      left: -10px;
      width: 60px;
      height: 1px;
    }
    .crosshair-target::after {
      left: 50%;
      top: -10px;
      width: 1px;
      height: 60px;
    }
    @keyframes target-pulse {
      0%, 100% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.7; }
      50% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
    }

    /* Speedlines (F1 style) */
    .speedline-effect {
      background: #1c1c1e;
    }
    .speedline-effect .line {
      position: absolute;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.7), transparent);
      height: 2px;
      width: 100px;
      animation: move-line 0.4s infinite linear;
    }
    .speedline-effect .line:nth-child(1) { top: 25%; left: -100px; animation-delay: 0s; }
    .speedline-effect .line:nth-child(2) { top: 45%; left: -100px; animation-delay: 0.1s; }
    .speedline-effect .line:nth-child(3) { top: 65%; left: -100px; animation-delay: 0.2s; }
    .speedline-effect .line:nth-child(4) { top: 85%; left: -100px; animation-delay: 0.3s; }
    @keyframes move-line {
      0% { left: -100px; width: 50px; }
      100% { left: 100%; width: 150px; }
    }

    /* Pro Gamer neon crosshair effect */
    .neon-effect {
      background: #0d0e12;
      box-shadow: inset 0 0 20px rgba(0, 180, 115, 0.4);
    }
    .gaming-crosshair {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 24px;
      height: 24px;
      border: 2px solid #00b473;
      transform: translate(-50%, -50%) rotate(45deg);
      animation: neon-spin 3s infinite linear;
      box-shadow: 0 0 10px #00b473;
    }
    @keyframes neon-spin {
      0% { transform: translate(-50%, -50%) rotate(0deg); }
      100% { transform: translate(-50%, -50%) rotate(360deg); }
    }

    /* Sloth effect */
    .sloth-effect {
      background: #2a2c35;
    }
  </style>
</Layout>
