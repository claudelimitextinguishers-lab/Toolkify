---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Spacebar Counter";
const category = "fun";
const tier = "Fun Tools";

// SEO metadata
const seoTitle = "Spacebar Counter - Free Spacebar Speed Test Online";
const description = "Spacebar Counter is a free online spacebar test to measure your space bar speed over 5, 10, 30 and 60 seconds. Try this spacebar counter game and beat your high score!";
const keywords = "spacebar counter, space bar counter, spacebar test, space bar speed test, spacebar counter 60 seconds, spacebar counter 10 seconds, space bar counter 1 minute, space bar counter online, space bar counter test, space bar counter 30 seconds, space bar counter 60, spacebar speed test, spacebar counter 30, space bar test, spacebar counter 60 second test, spacebar counter 60 sec, spacebar counter unblocked, spacebar counter game, spacebar counter 5 seconds, spacebar counter timer, spacebar counter 1 seconds, spacebar counter 30 seconds unblocked, space spacebar counter";
const canonical = "https://toolkify.com/tools/fun/spacebar-counter";
const ogImage = "https://toolkify.com/og-spacebar-counter.png";
---

<Layout 
  title={seoTitle}
  description={description}
  keywords={keywords}
  canonical={canonical}
  ogImage={ogImage}
  ogType="website"
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Spacebar Counter",
      "alternateName": ["Space Bar Counter", "Spacebar Speed Test", "Space Bar Speed Test"],
      "url": "https://toolkify.com/tools/fun/spacebar-counter",
      "description": "Free online spacebar counter and spacebar speed test. Measure your space bar speed (presses per second) over 5, 10, 30, or 60 second windows with precise key-event handling and rich audio-visual feedback.",
      "applicationCategory": "GameApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Spacebar counter 5 seconds, 10 seconds, 30 seconds and 60 seconds modes",
        "Real-time presses-per-second (PPS) tracking",
        "Speed tier classification and shareable results",
        "Works unblocked in any modern browser"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How fast can you click the spacebar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Most people can click the spacebar at 4 to 6 presses per second (PPS) during a standard 10-second test. Practiced gamers and typists typically reach 6 to 8 PPS, and elite tappers using jitter or alternating-finger techniques have been recorded exceeding 10 PPS. Your hardware matters too — a mechanical keyboard with a short-travel switch will register presses faster than a membrane keyboard.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why is my spacebar not working?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>If your spacebar is not registering in the spacebar counter, the most common causes are: (1) the arena does not have keyboard focus — click inside the test area first; (2) browser key-repeat or accessibility settings are blocking rapid inputs; (3) dust or debris under the keycap is preventing a clean keystroke; (4) your keyboard's USB polling rate or debounce setting is filtering rapid successive presses. Try clicking the arena directly, refreshing the page, or testing with a different keyboard to isolate the issue.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How many times can you click the spacebar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The number of times you can click the spacebar depends on the test duration and your tapping speed. At an average of 5 PPS, you would register 50 presses in 10 seconds, 150 presses in 30 seconds, and around 300 presses in the full 60-second test. Top-speed players pushing 10 PPS can exceed 600 spacebar clicks in one minute. Use the 60-second mode on this spacebar counter to find your personal maximum.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a good spacebar CPS?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A good spacebar CPS (clicks per second) is generally considered to be 5 to 7 for a casual user. Reaching 7 to 9 CPS puts you in pro-gamer territory, and anything above 9 CPS is elite. Beginners typically average 3 to 5 CPS. Unlike mouse clicking, spacebar speed is heavily influenced by finger technique — jitter tapping or alternating two fingers across the wide key can significantly boost your spacebar CPS score.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a good spacebar speed?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A good spacebar speed is 5 to 7 presses per second (PPS) for most users. Scores below 4 PPS are considered below average, 4 to 6 PPS is the standard casual range, 6 to 8 PPS is competitive gamer level, and above 8 to 10 PPS is exceptional. For the 60-second endurance test, sustaining 5 PPS or more throughout the full minute is a strong result, since fatigue typically drops speed after the first 20 seconds.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-3">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-rose-light text-coral-dark text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap">{tier}</span>
        </div>
        <div class="flex items-center gap-2 self-end sm:self-auto flex-wrap">
          <!-- Audio Toggle -->
          <button
            type="button"
            id="audio-toggle"
            class="inline-flex items-center justify-center w-8 h-8 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Toggle sound effects"
            title="Toggle sound effects"
          >
            <svg id="sound-on-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
            </svg>
            <svg id="sound-off-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zm10.914-4.5l3 3m0-3l-3 3" />
            </svg>
          </button>

          <!-- Share Tool Link Button -->
          <button
            type="button"
            id="share-tool-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How It Works Button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How spacebar counter works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset Button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset test data"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 dark-plum-theme relative overflow-hidden">
      <!-- Background glow overlay for plum flavor -->
      <div class="absolute inset-0 plum-gradient-overlay pointer-events-none"></div>

      <!-- Duration Selector / Options row -->
      <div class="flex items-center justify-between z-10 border-b border-plum-border/40 pb-3 flex-wrap gap-2">
        <div class="flex items-center gap-2">
          <span class="text-[11px] uppercase font-bold text-plum-accent tracking-wider">Duration:</span>
          <div class="flex items-center gap-1" id="duration-select-container">
            <button class="duration-btn active" data-seconds="10">10s</button>
            <button class="duration-btn" data-seconds="5">5s</button>
            <button class="duration-btn" data-seconds="30">30s</button>
            <button class="duration-btn" data-seconds="60">60s</button>
          </div>
        </div>
        <div class="text-[10px] text-plum-text-muted font-mono select-none" id="keyboard-hint">
          Click arena or press Spacebar to start
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5 items-stretch z-10">
        <!-- Left Pane: Interactive Spacebar Arena -->
        <div class="flex flex-col gap-2 relative">
          <div class="flex items-center justify-between">
            <span class="text-[11px] font-semibold text-plum-text-bright">Spacebar Arena</span>
            <span class="text-[10px] font-mono text-plum-text-muted" id="pps-tracker">0.00 PPS</span>
          </div>

          <!-- Click/Keyboard Focus Arena Box -->
          <div
            id="spacebar-arena"
            tabindex="0"
            class="flex-1 min-h-[180px] sm:min-h-[320px] rounded-xl border border-plum-border bg-plum-surface flex flex-col items-center justify-center text-center p-4 sm:p-6 cursor-pointer select-none relative overflow-hidden transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-plum-accent/50 touch-action-none"
            aria-label="Spacebar speed test arena. Press Spacebar repeatedly inside this area."
          >
            <!-- Focus Lost Helper Overlay -->
            <div id="focus-warning" class="absolute inset-0 bg-black/85 flex flex-col items-center justify-center p-4 text-center z-30 transition-opacity duration-300 pointer-events-none opacity-0">
              <span class="text-2xl mb-1.5">⚠️</span>
              <h3 class="text-xs sm:text-sm font-bold text-plum-text-bright">Click to Focus Arena</h3>
              <p class="text-[10px] text-plum-text-muted max-w-[200px] mt-1 leading-relaxed">
                The spacebar test needs page focus to record keyboard presses.
              </p>
            </div>

            <!-- Particle Grid (Decorative background) -->
            <div class="absolute inset-0 grid grid-cols-8 grid-rows-8 opacity-[0.04] pointer-events-none transition-opacity duration-500" id="arena-grid">
              {Array.from({ length: 64 }).map(() => <div class="border-[0.5px] border-plum-accent" />)}
            </div>

            <!-- Linear Depleting Progress Indicator -->
            <div class="absolute top-0 left-0 h-1.5 bg-gradient-to-r from-plum-accent to-brand-coral transition-all duration-75 w-full pointer-events-none" id="timer-bar"></div>

            <!-- Canvas for particle explosions -->
            <canvas id="particles-canvas" class="absolute inset-0 pointer-events-none z-0"></canvas>

            <!-- Main Content: Keycap Graphic -->
            <div class="z-10 flex flex-col items-center gap-4 sm:gap-6 w-full pointer-events-none select-none">
              <!-- Animated 3D Spacebar Keycap -->
              <div class="keycap-container">
                <div id="spacebar-keycap" class="keycap-stem shadow-md">
                  <div class="keycap-face">
                    <span class="keycap-text font-mono uppercase tracking-widest text-[9px] sm:text-[10px] opacity-70">SPACEBAR</span>
                  </div>
                </div>
              </div>

              <div class="flex flex-col items-center gap-1 sm:gap-1.5">
                <h2 id="arena-title" class="font-display font-bold text-base sm:text-xl text-plum-text-bright leading-tight max-w-xs transition-colors duration-200">
                  Press Spacebar to Start
                </h2>
                <p id="arena-instructions" class="text-[10px] sm:text-xs text-plum-text-muted max-w-xs leading-relaxed transition-colors duration-200">
                  First press registers immediately and starts the timer. Keep hitting it as fast as you can!
                </p>
                <p class="text-[9px] text-plum-text-muted/60 max-w-xs font-medium">
                  Note: Holding down spacebar does not count as multiple presses.
                </p>
              </div>
            </div>

            <!-- Mobile Tapping Helper Key (Visible on touch devices) -->
            <div id="mobile-tap-pad" class="absolute bottom-4 left-4 right-4 h-12 bg-plum-accent/20 border border-plum-accent/30 rounded-lg flex items-center justify-center text-xs font-bold text-plum-text-bright pointer-events-auto sm:hidden active:bg-plum-accent/40 active:scale-95 transition-all cursor-pointer">
              📱 Tap Here (Mobile Spacebar Sim)
            </div>
          </div>

          <!-- Dedicated Restart Button -->
          <button
            type="button"
            id="restart-test-btn"
            class="hidden w-full inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2 bg-plum-accent text-canvas rounded-full transition-all cursor-pointer shadow-subtle hover:bg-plum-accent/90 animate-fade-in-up mt-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
            </svg>
            <span>Restart Test</span>
          </button>
        </div>

        <!-- Right Pane: Performance Dashboard & Tiers -->
        <div class="flex flex-col justify-between p-3 sm:p-5 relative overflow-hidden rounded-xl border border-plum-border bg-plum-surface shadow-inner min-h-[180px] sm:min-h-[320px]">
          <div class="absolute top-0 right-0 w-32 h-32 bg-plum-accent/10 rounded-full blur-2xl pointer-events-none"></div>

          <div class="flex flex-col gap-2 sm:gap-4 z-10 w-full h-full justify-between">
            <!-- Results Header -->
            <div class="flex items-center justify-between border-b border-plum-border/40 pb-1.5 sm:pb-2">
              <span class="text-[10px] uppercase font-extrabold text-plum-accent tracking-widest">Dashboard Readout</span>
              <div class="flex items-center gap-1.5">
                <span class="text-[10px] font-mono text-plum-text-muted" id="state-indicator">Status: Idle</span>
                <span class="flex h-2 w-2 relative">
                  <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75"></span>
                  <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-stone"></span>
                </span>
              </div>
            </div>

            <!-- Themed Visual Container / Results Reveal -->
            <div id="themed-reveal-container" class="flex flex-col items-center justify-center py-2 sm:py-4 relative min-h-[90px] sm:min-h-[160px] bg-black/20 rounded-xl border border-plum-border/20 backdrop-blur-sm shadow-inner transition-all duration-300">
              <!-- Default state / live dashboard readout -->
              <div id="dashboard-readout" class="flex flex-col items-center gap-0.5 sm:gap-1 w-full px-4">
                <span class="text-[9px] sm:text-[10px] uppercase font-bold text-plum-text-muted">Press Speed</span>
                <div class="flex items-baseline gap-1 mt-0.5">
                  <span id="output-pps" class="font-display font-black text-4xl sm:text-6xl text-plum-text-bright font-mono tracking-tight leading-none">0.00</span>
                  <span class="text-[10px] sm:text-xs font-semibold text-plum-accent">PPS</span>
                </div>

                <!-- Secondary metrics -->
                <div class="grid grid-cols-2 gap-4 w-full mt-2 sm:mt-3 pt-2 sm:pt-3 border-t border-plum-border/30 text-center">
                  <div class="flex flex-col">
                    <span class="text-[8px] uppercase font-bold text-plum-text-muted">Total Presses</span>
                    <span id="output-total-presses" class="text-xs sm:text-sm font-mono font-bold text-plum-text-bright">0</span>
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[8px] uppercase font-bold text-plum-text-muted">Remaining Time</span>
                    <span id="output-time-left" class="text-xs sm:text-sm font-mono font-bold text-plum-text-bright">--</span>
                  </div>
                </div>
              </div>

              <!-- Animated Cockpit / Speedlines / Neon Targets for Tier Payoffs -->
              <div id="pilot-radar" class="radar-hud-effect absolute inset-0 rounded-xl overflow-hidden pointer-events-none hidden">
                <div class="radar-line"></div>
                <div class="radar-crosshair"></div>
                <div class="hud-text absolute bottom-2 left-2 text-[8px] font-mono text-brand-yellow font-bold">MACH_SPEED: PILOT_LOCKED</div>
              </div>

              <div id="racer-speedlines" class="speedline-effect absolute inset-0 rounded-xl overflow-hidden pointer-events-none hidden">
                <div class="checkered-flag-bg"></div>
                <div class="line"></div>
                <div class="line"></div>
                <div class="line"></div>
                <div class="line"></div>
              </div>

              <div id="gamer-neon" class="neon-effect absolute inset-0 rounded-xl overflow-hidden pointer-events-none hidden">
                <div class="neon-ring"></div>
                <div class="gaming-crosshair"></div>
              </div>

              <div id="sloth-anim" class="sloth-effect absolute inset-0 rounded-xl overflow-hidden pointer-events-none hidden flex items-center justify-center">
                <span class="text-4xl animate-bounce">💤</span>
              </div>
            </div>

            <!-- Dynamic Advice / Classification -->
            <div id="classification-box" class="text-xs text-plum-text-muted leading-relaxed pt-2 sm:pt-3 border-t border-plum-border/40">
              <div class="flex flex-wrap gap-1.5 items-center">
                <span class="text-[9px] uppercase font-extrabold text-plum-text-muted">Tier Classification:</span>
                <span id="classification-badge" class="bg-plum-border/30 text-plum-text-muted text-[9px] py-0.5 px-2 rounded-full font-bold uppercase tracking-wider">Not Classified</span>
              </div>
              <p id="main-context-text" class="font-medium text-[10px] sm:text-[11px] mt-1 sm:mt-1.5 text-plum-text-muted">
                Complete a test to evaluate your spacebar reflex speed tier. Focus the arena and start pressing.
              </p>
            </div>

            <!-- Action buttons / Share -->
            <div id="action-btn-row" class="hidden items-center gap-2 pt-1">
              <button
                type="button"
                id="share-btn"
                class="flex-1 inline-flex items-center justify-center gap-1.5 text-xs font-semibold px-4 py-2 bg-plum-accent text-canvas rounded-full transition-all cursor-pointer shadow-subtle hover:bg-plum-accent/90"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.622-2.311m0 0a3 3 0 10-3.664-3.664L8.684 10.742m0 0a3 3 0 100 4.516l4.622 2.311m0 0a3 3 0 103.664-3.664l-4.622-2.311" />
                </svg>
                <span>Share Results</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <RelatedTools currentSlug="spacebar-counter" />

    <!-- Educational details panel -->
    <div class="card-base flex flex-col gap-4 p-4 sm:p-5 mt-2">
      <h3 class="font-display font-semibold text-sm sm:text-base text-primary flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Understanding Spacebar Clicking Speed
      </h3>
      <div class="text-[11px] sm:text-xs text-slate leading-relaxed flex flex-col gap-2">
        <p>
          The spacebar counter measures how fast you can tap the spacebar key on your keyboard. While mouse-clicking speed is essential for shooters and MOBAs, keyboard tapping frequencies measure visual-motor reflexes and physical finger stamina.
        </p>
        <p class="font-semibold text-charcoal">Advanced Keyboard Tapping Methods:</p>
        <ul class="list-disc pl-4 flex flex-col gap-1.5 text-slate font-medium">
          <li>
            <strong>Single Finger Jitter:</strong> Vibrate your index finger using tension in your wrist and forearm.
          </li>
          <li>
            <strong>Double Finger Alternating:</strong> Alternate between index and middle fingers on the same spacebar key (works best on low-profile mechanical keyboard setups).
          </li>
          <li>
            <strong>Two-Handed Hovering:</strong> Use the index finger of both hands to alternate tapping, keeping the keyboard stabilized.
          </li>
        </ul>
        <p class="text-[10px] text-stone mt-1">
          Hardware parameters like switch travel distance, keycap weight, debouncing algorithms, and USB keyboard polling rates have a massive impact on peak recorded speed.
        </p>
      </div>
    </div>

    <!-- Security & Privacy Guard Footer Tag -->
    <div class="flex items-center justify-between text-[10px] text-slate px-1">
      <span class="flex items-center gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3 h-3 text-success-accent"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
          ></path>
        </svg>
        100% Client-Side Speed Evaluation
      </span>
