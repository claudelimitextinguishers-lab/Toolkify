  <!-- Client-side Logic Module -->
  <script>
    type TestState = "idle" | "playing" | "finished";
    let currentState: TestState = "idle";

    // State parameters
    let totalPresses = 0;
    let selectedDuration = 10; // Default 10s
    let startTime = 0;
    let timerFrameId: number | null = null;
    let soundEnabled = true;
    let audioCtx: AudioContext | null = null;
    let finishJingleTimeouts: number[] = [];

    // DOM Elements
    const spacebarArena = document.getElementById("spacebar-arena");
    const spacebarKeycap = document.getElementById("spacebar-keycap");
    const focusWarning = document.getElementById("focus-warning");
    const arenaTitle = document.getElementById("arena-title");
    const arenaInstructions = document.getElementById("arena-instructions");
    const timerBar = document.getElementById("timer-bar");
    const ppsTracker = document.getElementById("pps-tracker");
    const stateIndicator = document.getElementById("state-indicator");
    const statusDot = document.getElementById("status-dot");
    const statusPulse = document.getElementById("status-pulse");

    const outputPPS = document.getElementById("output-pps");
    const outputTotalPresses = document.getElementById("output-total-presses");
    const outputTimeLeft = document.getElementById("output-time-left");

    const durationBtns = document.querySelectorAll(".duration-btn");
    const audioToggle = document.getElementById("audio-toggle");
    const soundOnIcon = document.getElementById("sound-on-icon");
    const soundOffIcon = document.getElementById("sound-off-icon");
    const resetBtn = document.getElementById("reset-btn");
    const shareBtn = document.getElementById("share-btn");
    const actionBtnRow = document.getElementById("action-btn-row");
    const restartTestBtn = document.getElementById("restart-test-btn");
    const mobileTapPad = document.getElementById("mobile-tap-pad");

    // Classification elements
    const classificationBadge = document.getElementById("classification-badge");
    const mainContextText = document.getElementById("main-context-text");

    // Tier Anim Panels
    const pilotRadar = document.getElementById("pilot-radar");
    const racerSpeedlines = document.getElementById("racer-speedlines");
    const gamerNeon = document.getElementById("gamer-neon");
    const slothAnim = document.getElementById("sloth-anim");
    const dashboardReadout = document.getElementById("dashboard-readout");

    // Particles setup
    const canvas = document.getElementById("particles-canvas") as HTMLCanvasElement;
    const ctx = canvas ? canvas.getContext("2d") : null;
    let particles: Array<{
      x: number;
      y: number;
      vx: number;
      vy: number;
      radius: number;
      color: string;
      alpha: number;
    }> = [];
    let animating = false;

    function resizeCanvas() {
      if (canvas && spacebarArena && ctx) {
        const dpr = window.devicePixelRatio || 1;
        const width = spacebarArena.clientWidth;
        const height = spacebarArena.clientHeight;
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        ctx.resetTransform();
        ctx.scale(dpr, dpr);
      }
    }
    resizeCanvas();
    window.addEventListener("resize", resizeCanvas);

    // Audio synthesizer helper
    function getAudioContext() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      }
      if (audioCtx.state === "suspended") {
        audioCtx.resume();
      }
      return audioCtx;
    }

    function playTone(freq: number, type: OscillatorType, duration: number, volume: number = 0.1) {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioContext();
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();

        osc.type = type;
        osc.frequency.setValueAtTime(freq, ctx.currentTime);

        gainNode.gain.setValueAtTime(volume, ctx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);

        osc.connect(gainNode);
        gainNode.connect(ctx.destination);

        osc.start();
        osc.stop(ctx.currentTime + duration);
      } catch (err) {
        console.warn("AudioContext playback error:", err);
      }
    }

    function spawnParticles(x: number, y: number) {
      if (!ctx) return;
      const count = 15;
      const colors = ["#e040a9", "#ff9999", "#ffffff", "#ffd02f"];
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 1 + Math.random() * 5;
        particles.push({
          x,
          y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          radius: 2 + Math.random() * 3,
          color: colors[Math.floor(Math.random() * colors.length)],
          alpha: 1,
        });
      }
      if (!animating) {
        animateParticles();
      }
    }

    function animateParticles() {
      if (!ctx || !canvas) return;
      if (particles.length === 0 && currentState !== "playing") {
        animating = false;
        return;
      }
      animating = true;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles = particles.filter(p => {
        p.x += p.vx;
        p.y += p.vy;
        p.alpha -= 0.04;
        if (p.alpha <= 0) return false;
        ctx!.save();
        ctx!.globalAlpha = p.alpha;
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = p.color;
        ctx!.fill();
        ctx!.restore();
        return true;
      });
      requestAnimationFrame(animateParticles);
    }
    animateParticles();

    function resetTest() {
      currentState = "idle";
      totalPresses = 0;
      if (timerFrameId) {
        cancelAnimationFrame(timerFrameId);
        timerFrameId = null;
      }

      // Clear any pending audio timeouts
      finishJingleTimeouts.forEach(clearTimeout);
      finishJingleTimeouts = [];

      // Reset UI elements
      if (timerBar) timerBar.style.width = "100%";
      if (ppsTracker) ppsTracker.textContent = "0.00 PPS";
      if (stateIndicator) stateIndicator.textContent = "Status: Idle";
      if (arenaTitle) arenaTitle.textContent = "Press Spacebar to Start";
      if (arenaInstructions)
        arenaInstructions.textContent = "First press registers immediately and starts the timer. Keep hitting it as fast as you can!";

      if (statusDot)
        statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-stone";
      if (statusPulse)
        statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-stone opacity-75";

      if (outputPPS) outputPPS.textContent = "0.00";
      if (outputTotalPresses) outputTotalPresses.textContent = "0";
      if (outputTimeLeft)
        outputTimeLeft.textContent = selectedDuration.toFixed(1) + "s";

      if (classificationBadge) {
        classificationBadge.textContent = "Not Classified";
        classificationBadge.className =
          "bg-plum-border/30 text-plum-text-muted text-[9px] py-0.5 px-2 rounded-full font-bold uppercase tracking-wider";
      }
      if (mainContextText) {
        mainContextText.textContent =
          "Complete a test to evaluate your spacebar reflex speed tier. Focus the arena and start pressing.";
      }

      // Hide all overlay anim components
      pilotRadar?.classList.add("hidden");
      racerSpeedlines?.classList.add("hidden");
      gamerNeon?.classList.add("hidden");
      slothAnim?.classList.add("hidden");
      dashboardReadout?.classList.remove("hidden");
      actionBtnRow?.classList.add("hidden");
      actionBtnRow?.classList.remove("flex");
      restartTestBtn?.classList.add("hidden");
    }

    function updateTimer() {
      if (currentState !== "playing") return;
      const now = performance.now();
      const elapsed = (now - startTime) / 1000;
      const remaining = Math.max(0, selectedDuration - elapsed);

      // Update progress bar
      if (timerBar) {
        const percent = (remaining / selectedDuration) * 100;
        timerBar.style.width = `${percent}%`;
      }

      // Update stats
      const currentPPS = elapsed > 0 ? totalPresses / elapsed : 0;
      if (ppsTracker) ppsTracker.textContent = `${currentPPS.toFixed(2)} PPS`;
      if (outputPPS) outputPPS.textContent = currentPPS.toFixed(2);
      if (outputTimeLeft)
        outputTimeLeft.textContent = `${remaining.toFixed(1)}s`;

      if (remaining <= 0) {
        finishTest();
      } else {
        timerFrameId = requestAnimationFrame(updateTimer);
      }
    }

    function startTest() {
      currentState = "playing";
      startTime = performance.now();
      totalPresses = 1; // Count first press immediately
      if (outputTotalPresses) outputTotalPresses.textContent = "1";
      if (stateIndicator) stateIndicator.textContent = "Status: Testing";

      if (statusDot)
        statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-rose-500";
      if (statusPulse)
        statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-500 opacity-75";

      if (arenaTitle) arenaTitle.textContent = "TAPPING ACTIVE!";
      if (arenaInstructions)
        arenaInstructions.textContent = "Keep pounding the spacebar key!";

      playTone(440, "sine", 0.1, 0.1);
      timerFrameId = requestAnimationFrame(updateTimer);
    }

    function registerPress() {
      if (currentState === "finished") {
        return;
      }

      // Visual feedback: depress the 3D keycap
      if (spacebarKeycap) {
        spacebarKeycap.classList.add("depressed");
        setTimeout(() => spacebarKeycap.classList.remove("depressed"), 80);
      }

      // Spawn particles near the keycap center
      if (spacebarArena) {
        const rect = spacebarArena.getBoundingClientRect();
        spawnParticles(rect.width / 2, rect.height / 2);
      }

      if (currentState === "idle") {
        startTest();
      } else if (currentState === "playing") {
        totalPresses++;
        if (outputTotalPresses)
          outputTotalPresses.textContent = totalPresses.toString();
        playTone(600 + Math.min(totalPresses * 5, 400), "sine", 0.08, 0.15);
      }
    }

    function finishTest() {
      currentState = "finished";
      if (timerFrameId) cancelAnimationFrame(timerFrameId);
      if (timerBar) timerBar.style.width = "0%";
      if (stateIndicator) stateIndicator.textContent = "Status: Finished";

      if (statusDot)
        statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-emerald-500";
      if (statusPulse)
        statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75";

      if (arenaTitle) arenaTitle.textContent = "Time Up!";
      if (arenaInstructions)
        arenaInstructions.textContent = "Review your spacebar speed statistics below.";

      const finalPPS = totalPresses / selectedDuration;
      if (outputPPS) outputPPS.textContent = finalPPS.toFixed(2);
      if (outputTimeLeft) outputTimeLeft.textContent = "0.0s";

      playTone(523.25, "triangle", 0.15, 0.15); // C5
      finishJingleTimeouts.push(window.setTimeout(() => playTone(659.25, "triangle", 0.15, 0.15), 100)); // E5
      finishJingleTimeouts.push(window.setTimeout(() => playTone(783.99, "triangle", 0.15, 0.15), 200)); // G5
      finishJingleTimeouts.push(window.setTimeout(() => playTone(1046.5, "triangle", 0.3, 0.2), 300)); // C6

      evaluatePPS(finalPPS);

      actionBtnRow?.classList.remove("hidden");
      actionBtnRow?.classList.add("flex");
      restartTestBtn?.classList.remove("hidden");
    }

    const TIERS = [
      {
        min: 10,
        max: Infinity,
        classification: "Fighter Jet Pilot",
        badgeStyle: "bg-brand-yellow text-primary border border-brand-yellow-deep shadow-[0_0_12px_rgba(252,185,0,0.4)]",
        advice: (pps: number) => `Incredible speed! Your average of ${pps.toFixed(2)} presses per second matches the split-second response of tactical jet pilots.`,
        effect: () => {
          pilotRadar?.classList.remove("hidden");
          dashboardReadout?.classList.add("hidden");
        }
      },
      {
        min: 8,
        max: 10,
        classification: "F1 Racer",
        badgeStyle: "bg-brand-blue text-canvas border border-blue-pressed shadow-[0_0_12px_rgba(66,98,255,0.4)]",
        advice: (pps: number) => `High gear speed! Tapping at ${pps.toFixed(2)} PPS displays the high-frequency physical motor speed of formula racing professionals.`,
        effect: () => {
          racerSpeedlines?.classList.remove("hidden");
          dashboardReadout?.classList.add("hidden");
        }
      },
      {
        min: 6,
        max: 8,
        classification: "Pro Gamer",
        badgeStyle: "bg-success-accent text-canvas border border-moss-dark shadow-[0_0_12px_rgba(0,180,115,0.4)]",
        advice: (pps: number) => `Esports caliber reflexes! At ${pps.toFixed(2)} spacebar presses per second, your finger coordination is perfect for competitive keys.`,
        effect: () => {
          gamerNeon?.classList.remove("hidden");
          dashboardReadout?.classList.add("hidden");
        }
      },
      {
        min: 4,
        max: 6,
        classification: "Casual Typist",
        badgeStyle: "bg-plum-border/40 border border-plum-accent text-plum-text-bright",
        advice: (pps: number) => `Reliable speed! Tapping at ${pps.toFixed(2)} PPS is within the standard healthy average for regular keyboard users.`,
        effect: () => {}
      },
      {
        min: 0,
        max: 4,
        classification: "Sleepy Sloth",
        badgeStyle: "bg-brand-coral text-canvas border border-coral-dark",
        advice: (pps: number) => `Tapping speed registered at ${pps.toFixed(2)} PPS. Time to stretch your hands, focus your setup, and restart!`,
        effect: () => {
          slothAnim?.classList.remove("hidden");
          dashboardReadout?.classList.add("hidden");
        }
      }
    ];

    function evaluatePPS(pps: number) {
      // Hide all overlay anim components first
      pilotRadar?.classList.add("hidden");
      racerSpeedlines?.classList.add("hidden");
      gamerNeon?.classList.add("hidden");
      slothAnim?.classList.add("hidden");
      dashboardReadout?.classList.remove("hidden");

      const tier = TIERS.find(t => pps >= t.min && pps < t.max) || TIERS[TIERS.length - 1];

      if (classificationBadge) {
        classificationBadge.textContent = tier.classification;
        classificationBadge.className = `text-[9px] py-0.5 px-2 rounded-full font-bold uppercase tracking-wider ${tier.badgeStyle}`;
      }

      if (mainContextText) {
        mainContextText.textContent = tier.advice(pps);
      }

      tier.effect();
    }

    // Attach Focus Helpers
    spacebarArena?.addEventListener("focus", () => {
      focusWarning?.classList.add("opacity-0");
      focusWarning?.classList.add("pointer-events-none");
    });

    spacebarArena?.addEventListener("blur", () => {
      if (currentState === "playing") return; // Don't warn mid-game
      focusWarning?.classList.remove("opacity-0");
      focusWarning?.classList.remove("pointer-events-none");
    });

    spacebarArena?.addEventListener("pointerdown", (e) => {
      // Focus the container if not focused
      spacebarArena.focus();
      getAudioContext();
    });

    // Spacebar Keydown Trigger
    window.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.code === "Space") {
        const active = document.activeElement;
        if (active !== spacebarArena) {
          if (active && active !== document.body && active !== document.documentElement) {
            e.preventDefault();
            spacebarArena?.focus();
          }
          return;
        }

        e.preventDefault();
        if (e.repeat) return;

        getAudioContext();
        registerPress();
      }
    });

    // Mobile simulator touch support
    let lastTapTime = 0;
    const MIN_TAP_INTERVAL = 40; // minimum ms between mobile taps to guard against duplicate events
    mobileTapPad?.addEventListener("pointerdown", (e) => {
      e.preventDefault();
      e.stopPropagation();
      const now = performance.now();
      if (now - lastTapTime < MIN_TAP_INTERVAL) {
        return;
      }
      lastTapTime = now;
      spacebarArena?.focus();
      getAudioContext();
      registerPress();
    });

    // Duration buttons
    durationBtns.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        if (currentState === "playing") {
          target.classList.add("opacity-50", "cursor-not-allowed");
          setTimeout(() => {
            target.classList.remove("opacity-50", "cursor-not-allowed");
          }, 400);
          return;
        }
        if (currentState === "finished") {
          if (!confirm("Are you sure you want to change the test duration? This will reset your current results.")) {
            return;
          }
          resetTest();
        }
        selectedDuration = parseInt(target.getAttribute("data-seconds") || "10", 10);
        durationBtns.forEach((b) => b.classList.remove("active"));
        target.classList.add("active");
        if (outputTimeLeft)
          outputTimeLeft.textContent = selectedDuration.toFixed(1) + "s";
      });
    });

    // Audio Toggle Setting
    audioToggle?.addEventListener("click", () => {
      soundEnabled = !soundEnabled;
      if (soundEnabled) {
        soundOnIcon?.classList.remove("hidden");
        soundOffIcon?.classList.add("hidden");
      } else {
        soundOnIcon?.classList.add("hidden");
        soundOffIcon?.classList.remove("hidden");
      }
    });

    // Reset buttons
    resetBtn?.addEventListener("click", () => {
      resetTest();
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }
    });

    restartTestBtn?.addEventListener("click", () => {
      resetTest();
    });

    // Share results copy to clipboard
    shareBtn?.addEventListener("click", () => {
      const displayedPPS = outputPPS?.textContent || "0.00";
      const textToCopy = `I hit the spacebar at ${displayedPPS} PPS (Presses Per Second) on TOOLKIFY Spacebar Counter! Duration: ${selectedDuration}s. Beat my score!`;
      navigator.clipboard
        .writeText(textToCopy)
        .then(() => {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share Results";
            span.textContent = "Copied!";
            setTimeout(() => {
              span.textContent = originalText;
            }, 2000);
          }
        })
        .catch((err) => {
          console.error("Failed to copy text: ", err);
        });
    });

    // Share tool URL logic
    const shareToolBtn = document.getElementById("share-tool-btn");
    shareToolBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("duration", selectedDuration.toString());

      const shareData = {
        title: document.title || "Spacebar Counter",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareToolBtn) {
          const span = shareToolBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareToolBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareToolBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // How it works modal events
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    // Parse URL params on load
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const dur = urlParams.has("duration") ? parseInt(urlParams.get("duration") || "10", 10) : 10;
      if ([5, 10, 30, 60].includes(dur)) {
        selectedDuration = dur;
        durationBtns.forEach((btn) => {
          const btnSec = parseInt(btn.getAttribute("data-seconds") || "10", 10);
          if (btnSec === dur) {
            btn.classList.add("active");
          } else {
            btn.classList.remove("active");
          }
        });
        if (outputTimeLeft) {
          outputTimeLeft.textContent = selectedDuration.toFixed(1) + "s";
        }
      }
      resetTest();
    }

    window.addEventListener("popstate", loadState);

    // Auto-focus on mount
    setTimeout(() => {
      spacebarArena?.focus();
    }, 100);

    loadState();
    resetTest();
  </script>

  <!-- Help / How it works Guide Overlay Modal -->
  <div
    id="how-it-works-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto z-50">
      <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
        <h3 class="font-display font-semibold text-lg text-primary font-medium">How the Spacebar Counter Works</h3>
        <button
          type="button"
          id="close-modal-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >
          ✕
        </button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">1. Spacebar Test Metrics</h4>
        <p>
          Measures your tapping speed by calculating presses per second (PPS) over standard durations. The calculation is: <code>PPS = Total Spacebar Hits / Duration</code>.
        </p>

        <h4 class="font-semibold text-primary">2. Taking the Test</h4>
        <p>
          Select a test duration (5s, 10s, 30s, or 60s) from the header panel. Start tapping the spacebar repeatedly. The timer starts automatically on your first press.
        </p>

        <h4 class="font-semibold text-primary">3. Safeguards</h4>
        <p>
          The system ensures you physically press and release the spacebar. Holding down the keycap will not count as multiple presses. Focus must be maintained on the arena to register keys.
        </p>

        <h4 class="font-semibold text-primary">4. Speed Classification Tiers</h4>
        <p>
          At the end of the timer, your average presses per second is compared to human speed tiers:
        </p>
        <ul class="list-disc pl-4 flex flex-col gap-1">
          <li><strong>Elite Gamer:</strong> 8+ PPS</li>
          <li><strong>Pro Tapper:</strong> 6–8 PPS</li>
          <li><strong>Fast:</strong> 5–6 PPS</li>
          <li><strong>Average:</strong> 4–5 PPS</li>
          <li><strong>Slower:</strong> Under 4 PPS</li>
        </ul>
      </div>
      <button
        type="button"
        id="modal-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
      </button>
    </div>
  </div>

  <!-- Animation & Effect Styles -->
  <style>
    /* Dark Plum variables override classes */
    .dark-plum-theme {
      --plum-bg: #2d1226;
      --plum-accent: #e040a9;
      --plum-accent-deep: #b82a84;
      --plum-border: rgba(224, 64, 169, 0.25);
      --plum-surface: rgba(30, 9, 23, 0.85);
      --plum-text-muted: #d6cbd3;
      --plum-text-bright: #ffffff;
      background-color: #1e0917 !important;
      color: var(--plum-text-muted) !important;
      border-color: var(--plum-border) !important;
    }

    /* Custom utility classes to support tailwind styles */
    .text-plum-accent { color: var(--plum-accent) !important; }
    .text-plum-text-bright { color: var(--plum-text-bright) !important; }
    .text-plum-text-muted { color: var(--plum-text-muted) !important; }
    .bg-plum-surface { background-color: var(--plum-surface) !important; }
    .border-plum-border { border-color: var(--plum-border) !important; }
    .border-plum-border\/40 { border-color: rgba(224, 64, 169, 0.4) !important; }
    .bg-plum-border\/30 { background-color: rgba(224, 64, 169, 0.3) !important; }
    .bg-plum-border\/40 { background-color: rgba(224, 64, 169, 0.4) !important; }
    .bg-plum-accent\/20 { background-color: rgba(224, 64, 169, 0.2) !important; }
    .border-plum-accent\/30 { border-color: rgba(224, 64, 169, 0.3) !important; }
    .active\:bg-plum-accent\/40:active { background-color: rgba(224, 64, 169, 0.4) !important; }
    .plum-gradient-overlay {
      background: linear-gradient(135deg, rgba(45, 18, 38, 0.4) 0%, rgba(45, 18, 38, 0.1) 100%) !important;
    }

    #restart-test-btn,
    #share-btn {
      background-color: var(--plum-accent) !important;
      color: #ffffff !important;
    }
    #restart-test-btn:hover,
    #share-btn:hover {
      background-color: var(--plum-accent-deep) !important;
    }

    .duration-btn {
      background-color: transparent;
      border: 1px solid var(--plum-border);
      color: var(--plum-text-muted);
      font-size: 11px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 9999px;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .duration-btn.active,
    .duration-btn:hover {
      background-color: var(--plum-accent);
      color: #ffffff;
      border-color: var(--plum-accent);
      box-shadow: 0 0 8px rgba(224, 64, 169, 0.4);
    }

    /* 3D Keyboard Keycap design */
    .keycap-container {
      perspective: 300px;
      width: 140px;
      height: 48px;
      margin: 0 auto;
    }
    .keycap-stem {
      width: 100%;
      height: 100%;
      position: relative;
      background: #4a213a;
      border-radius: 8px;
      box-shadow: 
        0 4px 0 #280d1e,
        0 8px 10px rgba(0,0,0,0.5);
      transition: transform 0.08s ease, box-shadow 0.08s ease;
      cursor: pointer;
    }
    .keycap-face {
      position: absolute;
      top: 1px;
      left: 1px;
      right: 1px;
      bottom: 4px;
      background: linear-gradient(180deg, #6c2f54 0%, #52203e 100%);
      border-radius: 6px;
      border-top: 1px solid rgba(255,255,255,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .keycap-text {
      color: #ffffff;
      text-shadow: 0 -1px 0 rgba(0,0,0,0.4);
    }

    /* Depressed Key state */
    .keycap-stem.depressed {
      transform: translateY(3px);
      box-shadow: 
        0 1px 0 #280d1e,
        0 2px 4px rgba(0,0,0,0.4);
    }

    /* Radar / Cockpit HUD effect styles */
    .radar-hud-effect {
      background: radial-gradient(circle, rgba(240, 64, 169, 0.12) 0%, rgba(28, 28, 30, 0.97) 100%);
      border: 2px solid var(--plum-accent);
    }
    .radar-line {
      position: absolute;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--plum-accent), transparent);
      top: 0;
      animation: radar-sweep-anim 2.5s infinite linear;
    }
    @keyframes radar-sweep-anim {
      0% { top: 0%; opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { top: 100%; opacity: 0; }
    }
    .radar-crosshair {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 40px;
      height: 40px;
      border: 1px solid var(--plum-accent);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      animation: crosshair-pulse 1.2s infinite ease-in-out;
    }
    .radar-crosshair::before,
    .radar-crosshair::after {
      content: "";
      position: absolute;
      background: var(--plum-accent);
    }
    .radar-crosshair::before {
      top: 50%;
      left: -10px;
      width: 60px;
      height: 1px;
    }
    .radar-crosshair::after {
      left: 50%;
      top: -10px;
      width: 1px;
      height: 60px;
    }
    @keyframes crosshair-pulse {
      0%, 100% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.7; }
      50% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
    }

    /* Speedlines (F1 style) */
    .speedline-effect {
      background: #1c1c1e;
    }
    .checkered-flag-bg {
      position: absolute;
      inset: 0;
      opacity: 0.15;
      background-image: 
        linear-gradient(45deg, #ffffff 25%, transparent 25%), 
        linear-gradient(-45deg, #ffffff 25%, transparent 25%), 
        linear-gradient(45deg, transparent 75%, #ffffff 75%), 
        linear-gradient(-45deg, transparent 75%, #ffffff 75%);
      background-size: 20px 20px;
      background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
    }
    .speedline-effect .line {
      position: absolute;
      background: linear-gradient(90deg, transparent, rgba(224, 64, 169, 0.7), transparent);
      height: 2px;
      width: 100px;
      animation: f1-line-move 0.4s infinite linear;
    }
    .speedline-effect .line:nth-child(2) { top: 25%; left: -100px; animation-delay: 0s; }
    .speedline-effect .line:nth-child(3) { top: 45%; left: -100px; animation-delay: 0.1s; }
    .speedline-effect .line:nth-child(4) { top: 65%; left: -100px; animation-delay: 0.2s; }
    .speedline-effect .line:nth-child(5) { top: 85%; left: -100px; animation-delay: 0.3s; }
    @keyframes f1-line-move {
      0% { left: -100px; width: 50px; }
      100% { left: 100%; width: 150px; }
    }

    /* Pro Gamer neon crosshair effect */
    .neon-effect {
      background: #0d0e12;
      box-shadow: inset 0 0 20px rgba(224, 64, 169, 0.4);
    }
    .neon-ring {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100px;
      height: 100px;
      border: 2px dashed var(--plum-accent);
      border-radius: 50%;
      transform: translate(-50%, -50%) rotate(0deg);
      animation: rotating-ring 6s infinite linear;
      opacity: 0.6;
    }
    @keyframes rotating-ring {
      from { transform: translate(-50%, -50%) rotate(0deg); }
      to { transform: translate(-50%, -50%) rotate(360deg); }
    }
    .gaming-crosshair {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 24px;
      height: 24px;
      border: 2px solid var(--plum-accent);
      transform: translate(-50%, -50%) rotate(45deg);
      animation: neon-spin-anim 3s infinite linear;
      box-shadow: 0 0 10px var(--plum-accent);
    }
    @keyframes neon-spin-anim {
      0% { transform: translate(-50%, -50%) rotate(0deg); }
      100% { transform: translate(-50%, -50%) rotate(360deg); }
    }

    /* Sloth effect */
    .sloth-effect {
      background: #2a2c35;
    }
  </style>
</Layout>
