              <div class="flex justify-between items-center text-[10px]">
                <div class="flex items-center gap-1.5">
                  <span class="font-bold text-primary">SHA-1</span>
                  <span class="inline-flex px-1.5 py-0.5 bg-brand-coral/15 text-coral-dark rounded text-[8px] font-bold uppercase">Legacy / Weak</span>
                </div>
                <button data-hash-copy="sha1-output" class="text-brand-blue hover:underline font-bold cursor-pointer">Copy</button>
              </div>
              <input 
                type="text" 
                id="sha1-output" 
                readonly 
                placeholder="SHA-1 checksum (Not secure for collisions)..."
                class="w-full bg-transparent border-none p-0 outline-none font-mono text-xs text-primary select-all"
              />
            </div>

            <!-- MD5 (Deprecated) -->
            <div class="flex flex-col gap-1.5 bg-surface p-3 rounded-lg border border-hairline relative group">
              <div class="flex justify-between items-center text-[10px]">
                <div class="flex items-center gap-1.5">
                  <span class="font-bold text-primary">MD5</span>
                  <span class="inline-flex px-1.5 py-0.5 bg-brand-coral/15 text-coral-dark rounded text-[8px] font-bold uppercase">Legacy / Weak</span>
                </div>
                <button data-hash-copy="md5-output" class="text-brand-blue hover:underline font-bold cursor-pointer">Copy</button>
              </div>
              <input 
                type="text" 
                id="md5-output" 
                readonly 
                placeholder="MD5 checksum (Not secure for collisions)..."
                class="w-full bg-transparent border-none p-0 outline-none font-mono text-xs text-primary select-all"
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Security & Privacy Guard Tag -->
    <div class="flex items-center justify-between text-[10px] text-slate px-1">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        100% Client-Side Processing, 0KB Sent to Servers
