              id="hash-drop-zone" 
              class="relative min-h-[110px] sm:min-h-[140px] border-2 border-dashed border-hairline-strong rounded-xl bg-surface-soft/60 hover:bg-surface flex flex-col items-center justify-center gap-2 p-5 text-center cursor-pointer transition-all focus-within:border-brand-blue"
            >
              <input type="file" id="hash-file-input" class="hidden" />
              <span class="text-xl">📁</span>
              <div class="flex flex-col gap-0.5">
                <span class="text-xs font-bold text-primary">Drag & drop file here or click to browse</span>
                <span class="text-[10px] text-slate">Calculation is 100% offline and client-side (no uploads).</span>
              </div>
            </div>

            <!-- File Progress Bar / Info -->
            <div id="file-info-container" class="hidden flex flex-col gap-2 p-3 bg-surface border border-hairline rounded-lg">
              <div class="flex items-center justify-between text-xs">
                <span id="hash-filename" class="font-semibold text-primary truncate max-w-[200px]">document.zip</span>
                <span id="hash-filesize" class="font-mono text-stone">4.2 MB</span>
              </div>
              <div class="w-full bg-hairline rounded-full h-1.5 overflow-hidden">
                <div id="hash-progress" class="bg-brand-blue h-1.5 rounded-full" style="width: 0%"></div>
              </div>
              <div class="flex items-center justify-between text-[9px] text-stone uppercase">
                <span id="hash-progress-text">Reading file chunks...</span>
                <button type="button" id="btn-cancel-file-hash" class="text-brand-coral hover:underline font-bold">Cancel</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Hash Outputs -->
        <div id="hash-outputs-container" class="lg:col-span-6 flex flex-col gap-3.5">
          <div class="flex items-center justify-between">
            <span class="text-[11px] font-semibold text-charcoal flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-brand-rose animate-pulse"></span>
              Calculated Digest Outputs
            </span>
          </div>

          <div class="flex flex-col gap-3">
            <!-- SHA-256 (Recommended) -->
            <div class="flex flex-col gap-1.5 bg-surface p-3 rounded-lg border border-hairline relative group">
              <div class="flex justify-between items-center text-[10px]">
                <div class="flex items-center gap-1.5">
                  <span class="font-bold text-primary">SHA-256</span>
                  <span class="inline-flex px-1.5 py-0.5 bg-success-accent/15 text-success-accent rounded text-[8px] font-bold uppercase">Secure</span>
                </div>
                <button data-hash-copy="sha256-output" class="text-brand-blue hover:underline font-bold cursor-pointer">Copy</button>
              </div>
              <input 
                type="text" 
                id="sha256-output" 
                readonly 
                placeholder="SHA-256 checksum..."
                class="w-full bg-transparent border-none p-0 outline-none font-mono text-xs text-primary select-all"
              />
            </div>

            <!-- SHA-512 -->
