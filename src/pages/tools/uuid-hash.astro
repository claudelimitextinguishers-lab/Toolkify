                  <span class="inline-flex px-1.5 py-0.5 bg-success-accent/15 text-success-accent rounded text-[8px] font-bold uppercase">Secure</span>
                </div>
                <button data-hash-copy="sha512-output" class="text-brand-blue hover:underline font-bold cursor-pointer">Copy</button>
              </div>
