                Plain Text Hashing
              </label>
              <button id="btn-clear-hash" class="text-[10px] text-stone hover:text-primary font-bold cursor-pointer">Clear</button>
            </div>
            <textarea 
              id="hash-text-input" 
              placeholder="Type or paste plain text here for dynamic live hashing..." 
              rows="4"
              class="w-full p-3 font-mono text-xs bg-surface-soft border border-hairline-strong rounded-lg outline-none focus:border-brand-blue transition-all"
            ></textarea>
          </div>

          <!-- File Checksum Mode -->
          <div class="flex flex-col gap-3">
            <label class="text-[11px] font-semibold text-charcoal flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-teal"></span>
