      <span>v2.1.0</span>
    </div>
  </section>

  <!-- Educational Article -->
  <section class="max-w-[760px] w-full mx-auto px-4 pb-20 flex flex-col gap-8 text-slate" aria-labelledby="about-tool-heading">
    <article class="flex flex-col gap-4">
      <h2 id="about-tool-heading" class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight">
        Private Client-Side UUID & Cryptographic Hash Suite
      </h2>
      <p class="text-sm leading-relaxed">
        Our <strong>UUID & Hash Generator</strong> is a specialized utility designed for developers, systems administrators, and privacy-conscious users. Typical online UUID generators and hash verifiers send your input strings and values back to their databases for processing or ad-tracking. This utility performs all generation (v1, v4, v7) and cryptographic digest math (MD5, SHA-1, SHA-256, SHA-512) 100% inside your web browser. 
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Understanding UUID Versions: v1, v4, and v7
      </h3>
      <p class="text-sm leading-relaxed">
        <strong>UUID v4</strong> is completely random and is ideal for most basic identifiers where timestamp ordering is not needed. 
        <strong>UUID v7</strong> is a modern variant ordered by Unix epoch timestamp, meaning identifiers sort chronologically—significantly improving database index insert performance.
        <strong>UUID v1</strong> uses a sub-millisecond timestamp and host hardware node address (mac address) to guarantee absolute uniqueness across local machines.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Cryptographic Security Warnings: MD5/SHA-1 vs SHA-2
      </h3>
      <p class="text-sm leading-relaxed">
        Security standards deprecate both <strong>MD5</strong> and <strong>SHA-1</strong> for collision resistance. Practical exploits can generate identical MD5 or SHA-1 hashes for two differing contents. They remain useful strictly as legacy checksums to verify downloaded file integrity. For security-sensitive processes (such as password hashing, digital signatures, or system integrity checks), always select <strong>SHA-256</strong> or <strong>SHA-512</strong> digests.
      </p>
    </article>
  </section>
</Layout>

<script>
  // --- MD5 Hash Algorithm Implementation (Client-side) ---
  function md5(str: string): string {
    const k = [
      0xd76aa478, 0xe8c7b756, 0x242070db, 0xc1bdceee, 0xf57c0faf, 0x4787c62a, 0xa8304613, 0xfd469501,
      0x698098d8, 0x8b44f7af, 0xffff5bb1, 0x895cd7be, 0x6b901122, 0xfd987193, 0xa679438e, 0x49b40821,
      0xf61e2562, 0xc040b340, 0x265e5a51, 0xe9b6c7aa, 0xd62f105d, 0x02441453, 0xd8a1e681, 0xe7d3fbc8,
      0x21e1cde6, 0xc33707d6, 0xf4d50d87, 0x455a14ed, 0xa9e3e905, 0xfcefa3f8, 0x676f02d9, 0x8d2a4c8a,
      0xfffa3942, 0x8771f681, 0x6d9d6122, 0xfde5380c, 0xa4beea44, 0x4bdecfa9, 0xf6bb4b60, 0xbebfbc70,
      0x289b7ec6, 0xeaa127fa, 0xd4ef3085, 0x04881d05, 0xd9d4d039, 0xe6db99e5, 0x1fa27cf8, 0xc4ac5665,
      0xf4292244, 0x432aff97, 0xab9423a7, 0xfc93a039, 0x655b59c3, 0x8f0ccc92, 0xffeff47d, 0x85845dd1,
      0x6fa87e4f, 0xfe2ce6e0, 0xa3014314, 0x4e0811a1, 0xf7537e82, 0xbd3af235, 0x2ad7d2bb, 0xeb86d391
    ];
    const r = [
      7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22,
      5,  9, 14, 20, 5,  9, 14, 20, 5,  9, 14, 20, 5,  9, 14, 20,
      4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23,
      6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21
    ];

    const utf8 = unescape(encodeURIComponent(str));
    const words: number[] = [];
    for (let i = 0; i < utf8.length; i++) {
      words[i >> 2] |= utf8.charCodeAt(i) << ((i % 4) * 8);
    }
    const len = utf8.length * 8;
    words[len >> 5] |= 0x80 << (len % 32);
    words[(((len + 64) >>> 9) << 4) + 14] = len;

    let h0 = 0x67452301;
    let h1 = 0xefcdab89;
    let h2 = 0x98badcfe;
    let h3 = 0x10325476;

    for (let i = 0; i < words.length; i += 16) {
      let a = h0, b = h1, c = h2, d = h3;
      for (let j = 0; j < 64; j++) {
        let f, g;
        if (j < 16) {
          f = (b & c) | (~b & d);
          g = j;
        } else if (j < 32) {
          f = (d & b) | (~d & c);
          g = (5 * j + 1) % 16;
        } else if (j < 48) {
          f = b ^ c ^ d;
          g = (3 * j + 5) % 16;
        } else {
          f = c ^ (b | ~d);
          g = (7 * j) % 16;
        }
        const temp = d;
        d = c;
        c = b;
        b = b + rotateLeft((a + f + k[j] + (words[i + g] || 0)), r[j]);
        a = temp;
      }
      h0 = (h0 + a) | 0;
      h1 = (h1 + b) | 0;
      h2 = (h2 + c) | 0;
      h3 = (h3 + d) | 0;
    }

    function rotateLeft(x: number, n: number) {
      return (x << n) | (x >>> (32 - n));
    }

    const hex = (val: number) => {
      let str = "";
      for (let i = 0; i < 4; i++) {
        str += ((val >> (i * 8)) & 0xff).toString(16).padStart(2, "0");
      }
      return str;
    };
    return hex(h0) + hex(h1) + hex(h2) + hex(h3);
  }

  // Fallback Incremental MD5 for large files
  class IncrementalMD5 {
    private h0 = 0x67452301;
    private h1 = 0xefcdab89;
    private h2 = 0x98badcfe;
    private h3 = 0x10325476;
    private buffer: Uint8Array = new Uint8Array(64);
    private bufferLen = 0;
    private totalLen = 0;

    private static K = [
      0xd76aa478, 0xe8c7b756, 0x242070db, 0xc1bdceee, 0xf57c0faf, 0x4787c62a, 0xa8304613, 0xfd469501,
      0x698098d8, 0x8b44f7af, 0xffff5bb1, 0x895cd7be, 0x6b901122, 0xfd987193, 0xa679438e, 0x49b40821,
      0xf61e2562, 0xc040b340, 0x265e5a51, 0xe9b6c7aa, 0xd62f105d, 0x02441453, 0xd8a1e681, 0xe7d3fbc8,
      0x21e1cde6, 0xc33707d6, 0xf4d50d87, 0x455a14ed, 0xa9e3e905, 0xfcefa3f8, 0x676f02d9, 0x8d2a4c8a,
      0xfffa3942, 0x8771f681, 0x6d9d6122, 0xfde5380c, 0xa4beea44, 0x4bdecfa9, 0xf6bb4b60, 0xbebfbc70,
      0x289b7ec6, 0xeaa127fa, 0xd4ef3085, 0x04881d05, 0xd9d4d039, 0xe6db99e5, 0x1fa27cf8, 0xc4ac5665,
      0xf4292244, 0x432aff97, 0xab9423a7, 0xfc93a039, 0x655b59c3, 0x8f0ccc92, 0xffeff47d, 0x85845dd1,
      0x6fa87e4f, 0xfe2ce6e0, 0xa3014314, 0x4e0811a1, 0xf7537e82, 0xbd3af235, 0x2ad7d2bb, 0xeb86d391
    ];

    private static R = [
      7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22,
      5,  9, 14, 20, 5,  9, 14, 20, 5,  9, 14, 20, 5,  9, 14, 20,
      4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23,
      6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21
    ];

    public update(chunk: Uint8Array) {
      this.totalLen += chunk.length;
      let pos = 0;
      while (pos < chunk.length) {
        const copyLen = Math.min(64 - this.bufferLen, chunk.length - pos);
        this.buffer.set(chunk.subarray(pos, pos + copyLen), this.bufferLen);
        this.bufferLen += copyLen;
        pos += copyLen;

        if (this.bufferLen === 64) {
          this.processBlock(this.buffer);
          this.bufferLen = 0;
        }
      }
    }

    private processBlock(block: Uint8Array) {
      const words: number[] = [];
      for (let i = 0; i < 16; i++) {
        words[i] = block[i * 4] | (block[i * 4 + 1] << 8) | (block[i * 4 + 2] << 16) | (block[i * 4 + 3] << 24);
      }

      let a = this.h0, b = this.h1, c = this.h2, d = this.h3;
      const K = IncrementalMD5.K;
      const r = IncrementalMD5.R;

      for (let j = 0; j < 64; j++) {
        let f, g;
        if (j < 16) {
          f = (b & c) | (~b & d);
          g = j;
        } else if (j < 32) {
          f = (d & b) | (~d & c);
          g = (5 * j + 1) % 16;
        } else if (j < 48) {
          f = b ^ c ^ d;
          g = (3 * j + 5) % 16;
        } else {
          f = c ^ (b | ~d);
          g = (7 * j) % 16;
        }
        const temp = d;
        d = c;
        c = b;
        b = b + rotateLeft((a + f + K[j] + words[g]), r[j]);
        a = temp;
      }

      this.h0 = (this.h0 + a) | 0;
      this.h1 = (this.h1 + b) | 0;
      this.h2 = (this.h2 + c) | 0;
      this.h3 = (this.h3 + d) | 0;

      function rotateLeft(x: number, n: number) {
        return (x << n) | (x >>> (32 - n));
      }
    }

    public finalize(): string {
      // Pad input
      const padding = new Uint8Array(64);
      padding[0] = 0x80;
      
      const lenBytes = new Uint8Array(8);
      const totalBits = this.totalLen * 8;
      for (let i = 0; i < 8; i++) {
        lenBytes[i] = (totalBits >>> (i * 8)) & 0xff;
      }

      const padLen = (this.bufferLen < 56) ? (56 - this.bufferLen) : (120 - this.bufferLen);
      this.update(padding.subarray(0, padLen));
      this.update(lenBytes);

      const hex = (val: number) => {
        let str = "";
        for (let i = 0; i < 4; i++) {
          str += ((val >> (i * 8)) & 0xff).toString(16).padStart(2, "0");
        }
        return str;
      };
      return hex(this.h0) + hex(this.h1) + hex(this.h2) + hex(this.h3);
    }
  }

  // --- UUID Algorithms (v1, v4, v7) ---
  function generateUUIDv4(): string {
    const randomVals = new Uint8Array(16);
    crypto.getRandomValues(randomVals);
    randomVals[6] = (randomVals[6] & 0x0f) | 0x40; // set version 4
    randomVals[8] = (randomVals[8] & 0x3f) | 0x80; // set variant 10
    
    return formatHexBytes(randomVals);
  }

  function generateUUIDv7(): string {
    const bytes = new Uint8Array(16);
    crypto.getRandomValues(bytes);
    
    // Timestamp in ms (unix epoch)
    const timestamp = Date.now();
    
    // Top 48 bits of timestamp (must use Math.floor to get integer byte values)
    bytes[0] = Math.floor(timestamp / 0x10000000000) & 0xff;
    bytes[1] = Math.floor(timestamp / 0x100000000) & 0xff;
    bytes[2] = Math.floor(timestamp / 0x1000000) & 0xff;
    bytes[3] = Math.floor(timestamp / 0x10000) & 0xff;
    bytes[4] = Math.floor(timestamp / 0x100) & 0xff;
    bytes[5] = timestamp & 0xff;

    // UUID version 7
    bytes[6] = (bytes[6] & 0x0f) | 0x70;
    // UUID variant
    bytes[8] = (bytes[8] & 0x3f) | 0x80;

    return formatHexBytes(bytes);
  }

  let clockSequence = Math.floor(Math.random() * 0x3fff);
  let lastUUIDv1Time = 0;
  const staticMacNode = new Uint8Array(6);
  crypto.getRandomValues(staticMacNode);
  staticMacNode[0] |= 0x01; // Multicast bit set to identify random nodes

  function generateUUIDv1(): string {
    // Use safe integer arithmetic: split Gregorian epoch offset to avoid exceeding Number.MAX_SAFE_INTEGER
    const gregorianOffsetHigh = 12219292800; // seconds from 1582 to 1970
    let now = Date.now() * 10000 + gregorianOffsetHigh * 10000000; // 100ns intervals since Gregorian Reform (1582)
    if (now <= lastUUIDv1Time) {
      now = lastUUIDv1Time + 1;
    }
    lastUUIDv1Time = now;

    const timeLow = now % 0x100000000;
    const timeMid = Math.floor(now / 0x100000000) % 0x10000;
    const timeHi = Math.floor(now / 0x1000000000000) & 0x0fff;

    const bytes = new Uint8Array(16);
    bytes[0] = (timeLow >>> 24) & 0xff;
    bytes[1] = (timeLow >>> 16) & 0xff;
    bytes[2] = (timeLow >>> 8) & 0xff;
    bytes[3] = timeLow & 0xff;

    bytes[4] = (timeMid >>> 8) & 0xff;
    bytes[5] = timeMid & 0xff;

    bytes[6] = ((timeHi >>> 8) & 0x0f) | 0x10; // set version 1
    bytes[7] = timeHi & 0xff;

    bytes[8] = ((clockSequence >>> 8) & 0x3f) | 0x80; // variant
    bytes[9] = clockSequence & 0xff;

    bytes.set(staticMacNode, 10);

    return formatHexBytes(bytes);
  }

  function formatHexBytes(bytes: Uint8Array): string {
    const hex: string[] = [];
    for (let i = 0; i < 16; i++) {
      hex.push(bytes[i].toString(16).padStart(2, "0"));
    }
    return `${hex[0]}${hex[1]}${hex[2]}${hex[3]}-${hex[4]}${hex[5]}-${hex[6]}${hex[7]}-${hex[8]}${hex[9]}-${hex[10]}${hex[11]}${hex[12]}${hex[13]}${hex[14]}${hex[15]}`;
  }

  // --- State Setup & Persistence ---
  interface PresetConfig {
    id: string;
    version: string;
    uppercase: boolean;
    noHyphens: boolean;
    wrapper: string;
  }

  // activeTab tracked via DOM state
  let activeTab: 'uuid' | 'hash' = 'uuid';
  let pinList: PresetConfig[] = [];

  // DOM Elements
  const tabUuidBtn = document.getElementById('tab-uuid-btn') as HTMLButtonElement;
  const tabHashBtn = document.getElementById('tab-hash-btn') as HTMLButtonElement;
  const sectionUuid = document.getElementById('section-uuid') as HTMLDivElement;
  const sectionHash = document.getElementById('section-hash') as HTMLDivElement;

  const uuidVersion = document.getElementById('uuid-version') as HTMLSelectElement;
  const versionDescription = document.getElementById('version-description') as HTMLSpanElement;
  const uuidQuantity = document.getElementById('uuid-quantity') as HTMLInputElement;
  const uuidUppercase = document.getElementById('uuid-uppercase') as HTMLInputElement;
  const uuidNoHyphens = document.getElementById('uuid-no-hyphens') as HTMLInputElement;
  const uuidWrapper = document.getElementById('uuid-wrapper') as HTMLSelectElement;
  const btnGenerate = document.getElementById('btn-generate-uuids') as HTMLButtonElement;
  const uuidOutputText = document.getElementById('uuid-output-text') as HTMLTextAreaElement;
  const favoritesContainer = document.getElementById('favorites-container') as HTMLDivElement;
  const btnPinPreset = document.getElementById('btn-pin-preset') as HTMLButtonElement;
  
  const btnReset = document.getElementById('reset-btn') as HTMLButtonElement;
  const btnCopyUuids = document.getElementById('btn-copy-uuids') as HTMLButtonElement;
  const btnDownloadTxt = document.getElementById('btn-download-txt') as HTMLButtonElement;
  const btnDownloadCsv = document.getElementById('btn-download-csv') as HTMLButtonElement;
  const uuidToast = document.getElementById('uuid-toast') as HTMLDivElement;

  // Hashing DOM Elements
  const hashTextInput = document.getElementById('hash-text-input') as HTMLTextAreaElement;
  const hashDropZone = document.getElementById('hash-drop-zone') as HTMLDivElement;
  const hashFileInput = document.getElementById('hash-file-input') as HTMLInputElement;
  const fileInfoContainer = document.getElementById('file-info-container') as HTMLDivElement;
  const hashFilename = document.getElementById('hash-filename') as HTMLSpanElement;
  const hashFilesize = document.getElementById('hash-filesize') as HTMLSpanElement;
  const hashProgress = document.getElementById('hash-progress') as HTMLDivElement;
  const hashProgressText = document.getElementById('hash-progress-text') as HTMLSpanElement;
  const btnCancelFileHash = document.getElementById('btn-cancel-file-hash') as HTMLButtonElement;
  const btnClearHash = document.getElementById('btn-clear-hash') as HTMLButtonElement;

  const sha256Val = document.getElementById('sha256-output') as HTMLInputElement;
  const sha512Val = document.getElementById('sha512-output') as HTMLInputElement;
  const sha1Val = document.getElementById('sha1-output') as HTMLInputElement;
  const md5Val = document.getElementById('md5-output') as HTMLInputElement;

  // --- Initializer ---
  function init() {
    // Load options
    uuidVersion.value = localStorage.getItem('bt-uuid-ver') || 'v4';
    uuidQuantity.value = localStorage.getItem('bt-uuid-qty') || '10';
    uuidUppercase.checked = localStorage.getItem('bt-uuid-upper') === 'true';
    uuidNoHyphens.checked = localStorage.getItem('bt-uuid-nohyphens') === 'true';
    uuidWrapper.value = localStorage.getItem('bt-uuid-wrap') || 'plain';
    
    try {
      pinList = JSON.parse(localStorage.getItem('bt-uuid-pins') || '[]');
    } catch (e) {
      pinList = [];
    }

    updateVersionDescription();
    updatePinnedListHTML();
    triggerUUIDGeneration();
  }

  // --- Navigation & Tab Toggles ---
  tabUuidBtn.addEventListener('click', () => toggleTab('uuid'));
  tabHashBtn.addEventListener('click', () => toggleTab('hash'));

  function toggleTab(tab: 'uuid' | 'hash') {
    activeTab = tab;
    if (tab === 'uuid') {
      tabUuidBtn.className = "flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabHashBtn.className = "flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate";
      sectionUuid.classList.remove('hidden');
      sectionHash.classList.add('hidden');
    } else {
      tabHashBtn.className = "flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabUuidBtn.className = "flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate";
      sectionHash.classList.remove('hidden');
      sectionUuid.classList.add('hidden');
      scrollToElementWithOffset('hash-outputs-container', 80);
    }
  }

  function scrollToElementWithOffset(elementId: string, offset = 80) {
    if (window.innerWidth < 1024) { // Only scroll on mobile/tablet viewports
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }
  }

  // --- UUID Generation Action ---
  function triggerUUIDGeneration() {
    let qty = parseInt(uuidQuantity.value) || 1;
    if (qty < 1) qty = 1;
    if (qty > 1000) qty = 1000;
    uuidQuantity.value = qty.toString();

    const ver = uuidVersion.value;
    const isUpper = uuidUppercase.checked;
    const isNoHyphens = uuidNoHyphens.checked;
    const wrap = uuidWrapper.value;

    // Save defaults to LocalStorage
    localStorage.setItem('bt-uuid-ver', ver);
    localStorage.setItem('bt-uuid-qty', qty.toString());
    localStorage.setItem('bt-uuid-upper', isUpper.toString());
    localStorage.setItem('bt-uuid-nohyphens', isNoHyphens.toString());
    localStorage.setItem('bt-uuid-wrap', wrap);

    const generated: string[] = [];
    for (let i = 0; i < qty; i++) {
      let id = "";
      if (ver === 'v1') id = generateUUIDv1();
      else if (ver === 'v7') id = generateUUIDv7();
      else id = generateUUIDv4();

      if (isNoHyphens) id = id.replace(/-/g, '');
      if (isUpper) id = id.toUpperCase();
      generated.push(id);
    }

    // Format output based on wrapper selection
    let output = "";
    if (wrap === 'single') {
      output = generated.map(id => `'${id}'`).join('\n');
    } else if (wrap === 'double') {
      output = generated.map(id => `"${id}"`).join('\n');
    } else if (wrap === 'braces') {
      output = generated.map(id => `{${id}}`).join('\n');
    } else if (wrap === 'array') {
      output = JSON.stringify(generated, null, 2);
    } else {
      output = generated.join('\n');
    }

    uuidOutputText.value = output;
  }

  btnGenerate.addEventListener('click', () => {
    triggerUUIDGeneration();
    triggerAnimate(uuidOutputText);
    scrollToElementWithOffset('uuid-output-container', 80);
  });

  uuidVersion.addEventListener('change', () => {
    updateVersionDescription();
    triggerUUIDGeneration();
  });
  uuidQuantity.addEventListener('input', triggerUUIDGeneration);
  uuidUppercase.addEventListener('change', triggerUUIDGeneration);
  uuidNoHyphens.addEventListener('change', triggerUUIDGeneration);
  uuidWrapper.addEventListener('change', triggerUUIDGeneration);

  function updateVersionDescription() {
    const val = uuidVersion.value;
    if (val === 'v1') {
      versionDescription.textContent = "Includes host machine mac nodes & high-resolution timestamps. Useful in clustered clusters.";
    } else if (val === 'v7') {
      versionDescription.textContent = "Time-ordered layout. Excellent for index insert performance in SQL databases.";
    } else {
      versionDescription.textContent = "Most common. Generates completely random identifiers.";
    }
  }

  // Presets presets
  const quantityPresets = document.querySelectorAll('.btn-qty-preset');
  quantityPresets.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const val = (e.currentTarget as HTMLButtonElement).dataset.value || "10";
      uuidQuantity.value = val;
      triggerUUIDGeneration();
    });
  });

  // --- Copy, Download, & Reset Actions ---
  btnCopyUuids.addEventListener('click', () => {
    if (uuidOutputText.value) {
      navigator.clipboard.writeText(uuidOutputText.value).then(() => {
        showToast(uuidToast, "Copied list!");
      });
    }
  });

  btnDownloadTxt.addEventListener('click', () => downloadFile(uuidOutputText.value, "uuid-list.txt", "text/plain"));
  btnDownloadCsv.addEventListener('click', () => {
    const wrap = uuidWrapper.value;
    let content = uuidOutputText.value;
    if (wrap !== 'array') {
      content = "uuid\n" + content;
    }
    downloadFile(content, "uuid-list.csv", "text/csv");
  });

  btnReset.addEventListener('click', () => {
    localStorage.removeItem('bt-uuid-ver');
    localStorage.removeItem('bt-uuid-qty');
    localStorage.removeItem('bt-uuid-upper');
    localStorage.removeItem('bt-uuid-nohyphens');
    localStorage.removeItem('bt-uuid-wrap');
    init();
  });

  function downloadFile(content: string, filename: string, mime: string) {
    if (!content) return;
    const blob = new Blob([content], { type: mime });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    link.click();
    URL.revokeObjectURL(url);
  }

  function showToast(elem: HTMLDivElement, text: string) {
    elem.textContent = text;
    elem.style.opacity = "1";
    setTimeout(() => {
      elem.style.opacity = "0";
    }, 1500);
  }

  // --- Pin / Favorites Management ---
  btnPinPreset.addEventListener('click', () => {
    const item: PresetConfig = {
      id: "Preset-" + Math.floor(Math.random() * 100000),
      version: uuidVersion.value,
      uppercase: uuidUppercase.checked,
      noHyphens: uuidNoHyphens.checked,
      wrapper: uuidWrapper.value
    };

    // Prevent identical duplicates
    const duplicate = pinList.some(p => 
      p.version === item.version && 
      p.uppercase === item.uppercase && 
      p.noHyphens === item.noHyphens && 
      p.wrapper === item.wrapper
    );

    if (!duplicate) {
      pinList.push(item);
      localStorage.setItem('bt-uuid-pins', JSON.stringify(pinList));
      updatePinnedListHTML();
    }
  });

  function updatePinnedListHTML() {
    if (pinList.length === 0) {
      favoritesContainer.innerHTML = `<span class="text-[11px] text-stone">No items pinned yet. Pin your favorite configuration below!</span>`;
      return;
    }

    favoritesContainer.innerHTML = pinList.map(p => {
      const parts = [
        p.version.toUpperCase(),
        p.uppercase ? 'UPPER' : 'lower',
        p.noHyphens ? 'NOHYPHEN' : 'HYPHEN',
        p.wrapper !== 'plain' ? `WRAP:${p.wrapper.toUpperCase()}` : 'PLAIN'
      ];
      return `
        <div class="flex items-center justify-between bg-surface p-1.5 px-2.5 rounded border border-hairline text-[11px] font-mono group">
          <button type="button" class="text-left hover:text-brand-blue font-bold flex-grow btn-apply-preset" data-id="${p.id}">
            ⭐ ${parts.join(' | ')}
          </button>
          <button type="button" class="text-stone hover:text-brand-coral ml-2 btn-remove-preset" data-id="${p.id}">×</button>
        </div>
      `;
    }).join('');

    // Attach listeners
    document.querySelectorAll('.btn-apply-preset').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        const config = pinList.find(p => p.id === id);
        if (config) {
          uuidVersion.value = config.version;
          uuidUppercase.checked = config.uppercase;
          uuidNoHyphens.checked = config.noHyphens;
          uuidWrapper.value = config.wrapper;
          updateVersionDescription();
          triggerUUIDGeneration();
        }
      });
    });

    document.querySelectorAll('.btn-remove-preset').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).dataset.id;
        pinList = pinList.filter(p => p.id !== id);
        localStorage.setItem('bt-uuid-pins', JSON.stringify(pinList));
        updatePinnedListHTML();
      });
    });
  }

  // --- CRYPTOGRAPHIC HASHER (Text Mode) ---
  hashTextInput.addEventListener('input', runTextHasher);

  async function runTextHasher() {
    const val = hashTextInput.value;
    if (!val) {
      clearHashInputs();
      return;
    }

    // Local MD5
    md5Val.value = md5(val);

    const encoder = new TextEncoder();
    const data = encoder.encode(val);

    try {
      const sha1 = await crypto.subtle.digest('SHA-1', data);
      sha1Val.value = bufferToHex(sha1);

      const sha256 = await crypto.subtle.digest('SHA-256', data);
      sha256Val.value = bufferToHex(sha256);

      const sha512 = await crypto.subtle.digest('SHA-512', data);
      sha512Val.value = bufferToHex(sha512);

      scrollToElementWithOffset('hash-outputs-container', 80);
    } catch (e) {
      console.error("Cryptographic hash failure: ", e);
    }
  }

  function clearHashInputs() {
    md5Val.value = '';
    sha1Val.value = '';
    sha256Val.value = '';
    sha512Val.value = '';
  }

  btnClearHash.addEventListener('click', () => {
    hashTextInput.value = '';
    clearHashInputs();
  });

  // --- FILE HASHER (Drag & Drop Mode) ---
  let fileReaderAbortController: AbortController | null = null;

  hashDropZone.addEventListener('click', () => hashFileInput.click());
  hashFileInput.addEventListener('change', handleFileSelected);
  
  hashDropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    hashDropZone.classList.add('border-brand-blue', 'bg-surface');
  });

  hashDropZone.addEventListener('dragleave', () => {
    hashDropZone.classList.remove('border-brand-blue', 'bg-surface');
  });

  hashDropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    hashDropZone.classList.remove('border-brand-blue', 'bg-surface');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      processFile(files[0]);
    }
  });

  function handleFileSelected() {
    const files = hashFileInput.files;
    if (files && files.length > 0) {
      processFile(files[0]);
    }
  }

  async function processFile(file: File) {
    if (!file) return;

    // Reset progress
    fileInfoContainer.classList.remove('hidden');
    hashFilename.textContent = file.name;
    hashFilesize.textContent = formatBytes(file.size);
    hashProgress.style.width = "0%";
    hashProgressText.textContent = "Reading file chunks...";

    if (fileReaderAbortController) {
      fileReaderAbortController.abort();
    }
    fileReaderAbortController = new AbortController();
    const signal = fileReaderAbortController.signal;

    const chunkSize = 1024 * 1024 * 2; // 2MB chunk sizes
    let offset = 0;
    const size = file.size;

    const md5Hasher = new IncrementalMD5();
    
    // In-browser Web Crypto API digests require complete arrays. We compute SHA-256/512 iteratively using a custom SHA library,
    // or by loading the complete file for WebCrypto if it is reasonably small. 
    // For simplicity, robustness, and performance (without third party bloat), if the file is < 100MB we calculate SHA on complete buffers.
    let fullBuffer: Uint8Array | null = null;
    if (size < 100 * 1024 * 1024) {
      fullBuffer = new Uint8Array(size);
    }

    try {
      while (offset < size) {
        if (signal.aborted) throw new Error("Aborted");

        const slice = file.slice(offset, offset + chunkSize);
        const chunk = await readBlobAsArrayBuffer(slice);
        const uintArray = new Uint8Array(chunk);

        // Update MD5
        md5Hasher.update(uintArray);

        // Update full buffer for WebCrypto
        if (fullBuffer) {
          fullBuffer.set(uintArray, offset);
        }

        offset += chunkSize;
        const progressPercentage = Math.min(100, Math.floor((offset / size) * 100));
        hashProgress.style.width = `${progressPercentage}%`;
        hashProgressText.textContent = `Processing chunk... ${progressPercentage}%`;
      }

      // Finish MD5
      md5Val.value = md5Hasher.finalize();

      // SHA computation
      if (fullBuffer) {
        hashProgressText.textContent = "Calculating secure SHA-256/512 hashes...";
        const sha1 = await crypto.subtle.digest('SHA-1', fullBuffer.buffer as ArrayBuffer);
        sha1Val.value = bufferToHex(sha1);

        const sha256 = await crypto.subtle.digest('SHA-256', fullBuffer.buffer as ArrayBuffer);
        sha256Val.value = bufferToHex(sha256);

        const sha512 = await crypto.subtle.digest('SHA-512', fullBuffer.buffer as ArrayBuffer);
        sha512Val.value = bufferToHex(sha512);
      } else {
        sha1Val.value = "File too large (Only MD5 computed)";
        sha256Val.value = "File too large (> 100MB)";
        sha512Val.value = "File too large (> 100MB)";
      }

      hashProgressText.textContent = "Calculation Complete!";
      scrollToElementWithOffset('hash-outputs-container', 80);
    } catch (e: any) {
      if (e.message === "Aborted") {
        hashProgressText.textContent = "Checksum Cancelled.";
      } else {
        hashProgressText.textContent = "Hash Error.";
        console.error(e);
      }
    }
  }

  btnCancelFileHash.addEventListener('click', () => {
    if (fileReaderAbortController) {
      fileReaderAbortController.abort();
    }
    fileInfoContainer.classList.add('hidden');
    clearHashInputs();
  });

  function readBlobAsArrayBuffer(blob: Blob): Promise<ArrayBuffer> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result as ArrayBuffer);
      reader.onerror = () => reject(reader.error);
      reader.readAsArrayBuffer(blob);
    });
  }

  // --- Utility Functions ---
  function bufferToHex(buffer: ArrayBuffer): string {
    const bytes = new Uint8Array(buffer);
    return Array.from(bytes)
      .map(b => b.toString(16).padStart(2, '0'))
      .join('');
  }

  // formatBytes function
  function formatBytes(bytes: number): string {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  function triggerAnimate(elem: HTMLElement) {
    elem.classList.remove('animate-pulse');
    void elem.offsetWidth; // trigger reflow
    elem.classList.add('animate-pulse');
  }

  // Attach generic copy listeners to digest output blocks
  const hashCopyButtons = document.querySelectorAll('[data-hash-copy]');
  hashCopyButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const targetId = (e.currentTarget as HTMLButtonElement).dataset.hashCopy || '';
      const input = document.getElementById(targetId) as HTMLInputElement | null;
      if (input && input.value) {
        navigator.clipboard.writeText(input.value).then(() => {
          const origText = btn.innerHTML;
          btn.innerHTML = "✓ Copied";
          setTimeout(() => {
            btn.innerHTML = origText;
          }, 1500);
        });
      }
    });
  });

  // Run init on startup
  init();
</script>
