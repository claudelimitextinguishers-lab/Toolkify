            <div class="flex items-center gap-2">
              <button id="btn-copy-uuids" class="text-[11px] text-brand-blue hover:underline font-bold cursor-pointer">Copy All</button>
              <span class="text-stone">|</span>
              <button id="btn-download-txt" class="text-[11px] text-brand-blue hover:underline font-bold cursor-pointer">Download TXT</button>
              <span class="text-stone">|</span>
              <button id="btn-download-csv" class="text-[11px] text-brand-blue hover:underline font-bold cursor-pointer">Download CSV</button>
            </div>
          </div>

          <div id="uuid-output-container" class="relative flex-grow flex flex-col min-h-[160px] h-[160px] sm:min-h-[220px] lg:min-h-[420px] border border-hairline rounded-xl bg-surface p-3 overflow-hidden">
            <!-- Toast notification inside output -->
            <div id="uuid-toast" class="absolute top-3 right-3 bg-success-accent text-canvas text-[10px] font-bold py-1 px-2.5 rounded-md shadow-subtle opacity-0 transition-opacity duration-300 pointer-events-none z-20">
