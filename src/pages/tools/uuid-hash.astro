                  <button type="button" class="btn-qty-preset px-1.5 py-0.5 sm:px-2 sm:py-1 bg-canvas hover:bg-surface border border-hairline text-[9px] sm:text-[10px] font-semibold rounded" data-value="10">10</button>
                  <button type="button" class="btn-qty-preset px-1.5 py-0.5 sm:px-2 sm:py-1 bg-canvas hover:bg-surface border border-hairline text-[9px] sm:text-[10px] font-semibold rounded" data-value="100">100</button>
                  <button type="button" class="btn-qty-preset px-1.5 py-0.5 sm:px-2 sm:py-1 bg-canvas hover:bg-surface border border-hairline text-[9px] sm:text-[10px] font-semibold rounded" data-value="500">500</button>
