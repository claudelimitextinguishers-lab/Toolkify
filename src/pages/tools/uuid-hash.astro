---
import Layout from '../../layouts/Layout.astro';

// Tool metadata
const name = "UUID & Hash Generator";
const category = "developer";
const tier = "Developer Tools";

// SEO metadata
const pageTitle = "UUID (v1, v4, v7) & Cryptographic Hash Generator - BoardTools";
const description = "Free online bulk UUID generator (v1, v4, v7) and client-side hash calculator (MD5, SHA-1, SHA-256, SHA-512). Format UUIDs with quotes/braces and calculate file checksums locally.";
const keywords = "uuid generator, guid generator, uuid v4, uuid v7, uuid v1, sha256 generator, md5 hash, sha1, file hash checker, checksum verifier, client-side hash, developer tools";
const canonicalUrl = "https://boardtools.app/tools/uuid-hash";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage="/og/uuid-hash.png"
  ogType="website"
  hideBanner={true}
>
  <!-- SEO Schemas -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "UUID & Hash Generator",
      "url": "https://boardtools.app/tools/uuid-hash",
      "description": "Generate bulk UUIDs (v1, v4, v7) with custom formatting or hash text and files locally using secure MD5, SHA-1, SHA-256, and SHA-512 algorithms.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Bulk generate UUID versions 1, 4, and 7",
        "UUID formatting: hyphens, casing, arrays, braces, single/double quotes",
        "Real-time text hashing (MD5, SHA-1, SHA-256, SHA-512)",
        "Secure local client-side file hashing/checksum validation",
        "Security status badges warning against collision-prone legacy hashes",
        "Favorites list & custom options auto-save locally",
        "100% private execution inside your browser"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1200px] w-full mx-auto px-4 py-4 sm:py-6 flex flex-col gap-4 animate-fade-in-up pb-16">
