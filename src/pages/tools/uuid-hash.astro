      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>
        
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset options and output"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main Navigation Tabs -->
    <div class="flex rounded-full bg-surface p-0.5 border border-hairline w-full max-w-md">
      <button
        type="button"
        id="tab-uuid-btn"
        class="flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
        role="tab"
        aria-selected="true"
      >
        ID / UUID Generator
      </button>
      <button
        type="button"
        id="tab-hash-btn"
        class="flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate"
        role="tab"
        aria-selected="false"
      >
        Hasher (Text & File)
      </button>
    </div>

    <div class="card-base p-3 sm:p-5 flex flex-col gap-3.5 sm:gap-5 relative">
      <!-- Dot grid visual backdrop -->
      <div class="absolute inset-0 dot-grid opacity-[0.04] pointer-events-none rounded-xl"></div>

      <!-- ==================== TAB 1: UUID GENERATOR ==================== -->
      <div id="section-uuid" class="grid grid-cols-1 lg:grid-cols-12 gap-4 sm:gap-6 relative z-10">
