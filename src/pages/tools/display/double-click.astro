          </div>
        </div>
      </div>

      <!-- Practice rhythm selection (hidden by default) -->
      <div id="practice-settings-panel" class="hidden flex flex-wrap items-center gap-3 bg-surface-soft p-3 rounded-xl border border-hairline transition-all">
        <span class="text-[10px] font-semibold text-slate">Practice Target BPM:</span>
        <div class="flex gap-2">
          <button type="button" data-bpm="120" class="bpm-btn px-3 py-1 text-[10px] font-bold rounded-full border border-hairline bg-canvas text-slate hover:text-primary transition-all">120 BPM</button>
          <button type="button" data-bpm="180" class="bpm-btn px-3 py-1 text-[10px] font-bold rounded-full border border-hairline bg-canvas text-slate hover:text-primary transition-all">180 BPM</button>
          <button type="button" data-bpm="240" class="bpm-btn px-3 py-1 text-[10px] font-bold rounded-full border border-hairline bg-primary text-canvas transition-all">240 BPM (Fast)</button>
        </div>
        <div class="flex items-center gap-2 ml-auto text-[10px] text-slate">
          <span>Practice visual rhythm:</span>
          <div id="practice-metronome" class="w-3.5 h-3.5 rounded-full bg-slate-400 transition-all duration-100"></div>
        </div>
      </div>

      <!-- Main Workspace Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 items-stretch min-h-[360px]">
        <!-- Primary Click Test Zone & Counters -->
        <div class="lg:col-span-8 flex flex-col gap-4">
          <!-- Counters -->
          <div class="grid grid-cols-3 gap-3">
            <div class="card-base p-3 bg-surface-soft border border-hairline-soft flex flex-col items-center justify-center text-center">
              <span class="text-[10px] font-semibold text-slate uppercase">Total Clicks</span>
              <span id="counter-total" class="font-display font-medium text-2xl sm:text-3xl text-primary mt-1">0</span>
            </div>
            <div id="chatter-card" class="card-base p-3 bg-surface-soft border border-hairline-soft flex flex-col items-center justify-center text-center transition-all duration-300">
              <span class="text-[10px] font-semibold text-slate uppercase">Chatter Events</span>
              <span id="counter-chatter" class="font-display font-medium text-2xl sm:text-3xl text-primary mt-1">0</span>
            </div>
            <div class="card-base p-3 bg-surface-soft border border-hairline-soft flex flex-col items-center justify-center text-center">
              <span class="text-[10px] font-semibold text-slate uppercase">Chatter Rate</span>
              <span id="counter-rate" class="font-display font-medium text-2xl sm:text-3xl text-primary mt-1">0.0%</span>
            </div>
          </div>

          <!-- Click zone -->
          <div
            id="click-zone"
            class="flex-1 min-h-[220px] bg-canvas border-2 border-dashed border-hairline-strong/80 hover:border-brand-blue/60 rounded-xl relative flex flex-col items-center justify-center text-center cursor-pointer select-none overflow-hidden transition-all duration-300 shadow-sm"
