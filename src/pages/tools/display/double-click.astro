  <!-- Client-side Logic Script -->
  <script>
    if (typeof window !== 'undefined') {
      interface ClickEventLog {
      button: string; // "Left", "Middle", "Right"
      timestamp: number;
      interval: number;
      isChatter: boolean;
    }

    // State Variables
    let totalClicks = 0;
    let chatterClicks = 0;
    let chatterThreshold = 80; // ms
    let clickHistory: ClickEventLog[] = [];
    let practiceModeActive = false;
    let practiceBpm = 240;
    let metronomeIntervalId: number | null = null;
    let currentFilter: "all" | "left" | "middle" | "right" = "all";

    // Track last click timestamps per button to isolate buttons
    const lastClickTime: Record<string, number> = {
      Left: 0,
      Middle: 0,
      Right: 0,
    };

    const minInterval: Record<string, number> = {
      Left: Infinity,
      Middle: Infinity,
      Right: Infinity,
    };

    const buttonClicks: Record<string, number> = {
      Left: 0,
      Middle: 0,
      Right: 0,
    };

    const buttonChatter: Record<string, number> = {
      Left: 0,
      Middle: 0,
      Right: 0,
    };

    // DOM Elements
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const headerShareBtn = document.getElementById("share-btn") as HTMLButtonElement;
    const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;
    const touchWarning = document.getElementById("touch-warning") as HTMLDivElement;

    const chatterThresholdRange = document.getElementById("chatter-threshold-range") as HTMLInputElement;
    const chatterThresholdVal = document.getElementById("chatter-threshold-val") as HTMLSpanElement;

    const practiceToggleBtn = document.getElementById("practice-toggle-btn") as HTMLButtonElement;
    const practiceSettingsPanel = document.getElementById("practice-settings-panel") as HTMLDivElement;
    const practiceMetronome = document.getElementById("practice-metronome") as HTMLDivElement;
    const practiceGuideBox = document.getElementById("practice-guide-box") as HTMLDivElement;
    const practiceTargetRing = document.getElementById("practice-target-ring") as HTMLDivElement;

    const clickZone = document.getElementById("click-zone") as HTMLDivElement;
    const rippleOverlay = document.getElementById("ripple-overlay") as HTMLDivElement;

    const counterTotal = document.getElementById("counter-total") as HTMLSpanElement;
    const counterChatter = document.getElementById("counter-chatter") as HTMLSpanElement;
    const counterRate = document.getElementById("counter-rate") as HTMLSpanElement;
    const chatterCard = document.getElementById("chatter-card") as HTMLDivElement;

    const logList = document.getElementById("log-list") as HTMLDivElement;
    const btnExportCsv = document.getElementById("btn-export-csv") as HTMLButtonElement;

    const summarySection = document.getElementById("summary-section") as HTMLDivElement;
    const diagnosticStatus = document.getElementById("diagnostic-status") as HTMLSpanElement;
    const diagnosticText = document.getElementById("diagnostic-text") as HTMLParagraphElement;
    const summaryBreakdownBody = document.getElementById("summary-breakdown-body") as HTMLTableSectionElement;

    // Filter elements
    const filterAll = document.getElementById("filter-all") as HTMLButtonElement;
    const filterLeft = document.getElementById("filter-left") as HTMLButtonElement;
    const filterMiddle = document.getElementById("filter-middle") as HTMLButtonElement;
    const filterRight = document.getElementById("filter-right") as HTMLButtonElement;

    // Initialize LocalStorage state
    function init() {
      // Load settings
      const urlParams = new URLSearchParams(window.location.search);
      const urlThreshold = urlParams.get("threshold");
      if (urlThreshold) {
        chatterThreshold = parseInt(urlThreshold, 10);
        chatterThresholdRange.value = String(chatterThreshold);
        chatterThresholdVal.textContent = `${chatterThreshold}ms`;
      } else {
        const savedThreshold = localStorage.getItem("boardtools:double-click:threshold");
        if (savedThreshold) {
          chatterThreshold = parseInt(savedThreshold, 10);
          chatterThresholdRange.value = String(chatterThreshold);
          chatterThresholdVal.textContent = `${chatterThreshold}ms`;
        }
      }

      // Load click history from localStorage if exists
      const savedHistory = localStorage.getItem("boardtools:double-click:history");
      if (savedHistory) {
        try {
          const parsed = JSON.parse(savedHistory);
          if (Array.isArray(parsed)) {
            clickHistory = parsed;
            recalculateStatsFromHistory();
            updateDashboard();
          }
        } catch (e) {
          console.warn("Failed to load click history from local storage.", e);
        }
      }

      // Touch warning verification
      if ("ontouchstart" in window || navigator.maxTouchPoints > 0) {
        touchWarning.classList.remove("hidden");
      }
    }

    // Share button event
    headerShareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("threshold", String(chatterThreshold));

      const shareData = {
        title: document.title || "Double Click Test",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (headerShareBtn) {
          const span = headerShareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            headerShareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              headerShareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    function saveState() {
      localStorage.setItem("boardtools:double-click:threshold", String(chatterThreshold));
      localStorage.setItem("boardtools:double-click:history", JSON.stringify(clickHistory));
    }

    function recalculateStatsFromHistory() {
      totalClicks = clickHistory.length;
      chatterClicks = clickHistory.filter(c => c.isChatter).length;

      // Reset aggregates
      Object.keys(buttonClicks).forEach(k => {
        buttonClicks[k] = 0;
        buttonChatter[k] = 0;
        minInterval[k] = Infinity;
        lastClickTime[k] = 0;
      });

      clickHistory.forEach(log => {
        buttonClicks[log.button]++;
        if (log.isChatter) {
          buttonChatter[log.button]++;
        }
        if (log.interval > 0 && log.interval < minInterval[log.button]) {
          minInterval[log.button] = log.interval;
        }
      });
    }

    // Reset logic
    function handleReset() {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      clickHistory = [];
      recalculateStatsFromHistory();

      // Clear local storage
      try {
        localStorage.removeItem("boardtools:double-click:threshold");
        localStorage.removeItem("boardtools:double-click:history");
      } catch (e) {}

      // Reset UI elements
      chatterThreshold = 80;
      chatterThresholdRange.value = "80";
      chatterThresholdVal.textContent = "80ms";

      updateDashboard();
      triggerMicroAnimation(resetBtn);
    }

    // Animate counter values
    function animateCounter(element: HTMLSpanElement, start: number, end: number, duration = 300, isPercentage = false) {
      const startTime = performance.now();
      
      // Respect prefers-reduced-motion
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        element.textContent = isPercentage ? `${end.toFixed(1)}%` : String(Math.round(end));
        return;
      }

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const easeOutQuad = (t: number) => t * (2 - t);
        const currentVal = start + (end - start) * easeOutQuad(progress);

        element.textContent = isPercentage ? `${currentVal.toFixed(1)}%` : String(Math.round(currentVal));

        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }
      requestAnimationFrame(update);
    }

    function updateDashboard() {
      const prevTotal = parseInt(counterTotal.textContent || "0", 10);
      const prevChatter = parseInt(counterChatter.textContent || "0", 10);
      const prevRate = parseFloat(counterRate.textContent || "0.0%");

      const rate = totalClicks > 0 ? (chatterClicks / totalClicks) * 100 : 0.0;

      animateCounter(counterTotal, prevTotal, totalClicks);
      animateCounter(counterChatter, prevChatter, chatterClicks);
      animateCounter(counterRate, prevRate, rate, 300, true);

      // Warning styling on Chatter card if chatter rate > 0
      if (chatterClicks > 0) {
        chatterCard.className = "card-base p-3 bg-brand-red border border-brand-red-dark/30 text-coral-dark flex flex-col items-center justify-center text-center transition-all duration-300";
      } else {
        chatterCard.className = "card-base p-3 bg-surface-soft border border-hairline-soft flex flex-col items-center justify-center text-center transition-all duration-300";
      }

      // Render Logs
      renderLogs();

      // Render Summary Report
      renderSummaryReport();

      // Enable/Disable CSV export button
      btnExportCsv.disabled = clickHistory.length === 0;
    }

    function renderLogs() {
      logList.innerHTML = "";

      const filtered = clickHistory.filter(c => {
        if (currentFilter === "all") return true;
        return c.button.toLowerCase() === currentFilter;
      });

      if (filtered.length === 0) {
        logList.innerHTML = `<div class="text-stone italic text-center py-8">No matching clicks.</div>`;
        return;
      }

      // Scroll/Slide animations
      filtered.slice().reverse().forEach((log) => {
        const item = document.createElement("div");
        const isChatter = log.isChatter;
        
        item.className = `flex items-center justify-between p-2 rounded-lg border transition-all duration-200 ${
          isChatter
            ? "bg-brand-red/60 border-brand-red-dark/30 text-coral-dark font-bold animate-shake"
            : "bg-canvas border-hairline-soft hover:bg-surface-soft"
        }`;

        const buttonBadge = `<span class="px-1.5 py-0.5 rounded text-[9px] uppercase font-bold ${
          log.button === "Left" ? "bg-brand-blue/10 text-brand-blue" :
          log.button === "Right" ? "bg-brand-coral/10 text-coral-dark" :
          "bg-yellow-light text-yellow-dark"
        }">${log.button}</span>`;

        const intervalText = log.interval === 0 ? "First Click" : `${log.interval.toFixed(1)}ms`;
        const timeStr = new Date(log.timestamp).toLocaleTimeString([], { hour12: false, fractionSecondDigits: 3 } as any).split(" ")[0];

        item.innerHTML = `
          <div class="flex items-center gap-2">
            ${buttonBadge}
            <span>${timeStr}</span>
          </div>
          <div class="flex items-center gap-2">
            <span>${intervalText}</span>
            ${isChatter ? `<span class="text-[9px] bg-coral-dark text-canvas px-1 rounded font-bold uppercase animate-pulse">CHATTER</span>` : ""}
          </div>
        `;

        logList.appendChild(item);
      });
    }

    function renderSummaryReport() {
      if (clickHistory.length === 0) {
        summarySection.classList.add("hidden");
        return;
      }

      summarySection.classList.remove("hidden");
      summaryBreakdownBody.innerHTML = "";

      const overallChatterRate = (chatterClicks / totalClicks) * 100;
      const hasSevereIssues = overallChatterRate > 5.0;

      if (hasSevereIssues) {
        diagnosticStatus.textContent = "ATTENTION REQUIRED";
        diagnosticStatus.className = "badge-tag-coral bg-coral-light text-coral-dark text-[10px] py-1 px-3 rounded-full font-semibold uppercase animate-pulse";
        diagnosticText.innerHTML = `Your mouse has a chatter rate of <strong>${overallChatterRate.toFixed(1)}%</strong>. This highly indicates a hardware contact bounce issue. You may experience accidental double-clicks.`;
      } else {
        diagnosticStatus.textContent = "HEALTHY";
        diagnosticStatus.className = "badge-success bg-success-accent text-canvas text-[10px] py-1 px-3 rounded-full font-semibold uppercase";
        diagnosticText.innerHTML = `No significant hardware double-clicking issue detected (Chatter rate is <strong>${overallChatterRate.toFixed(1)}%</strong>).`;
      }

      // Fill table rows
      ["Left", "Middle", "Right"].forEach(btn => {
        const count = buttonClicks[btn];
        if (count === 0) return;

        const chatter = buttonChatter[btn];
        const rate = (chatter / count) * 100;
        const minInt = minInterval[btn] === Infinity ? "-" : `${minInterval[btn].toFixed(1)}ms`;
        const status = rate > 5.0 ? `<span class="text-coral-dark font-bold">Chattering</span>` : `<span class="text-success-accent">Healthy</span>`;

        const row = document.createElement("tr");
        row.className = "border-b border-hairline-soft text-slate";
        row.innerHTML = `
          <td class="py-2">${btn}</td>
          <td class="py-2">${count}</td>
          <td class="py-2">${chatter} (${rate.toFixed(1)}%)</td>
          <td class="py-2">${minInt}</td>
          <td class="py-2">${status}</td>
        `;
        summaryBreakdownBody.appendChild(row);
      });
    }

    // Metronome/Rhythm Helper for Practice Mode
    function startMetronome() {
      if (metronomeIntervalId) clearInterval(metronomeIntervalId);

      const msPerBeat = 60000 / practiceBpm;
      metronomeIntervalId = window.setInterval(() => {
        // Pulse Metronome Icon
        practiceMetronome.classList.add("bg-brand-blue", "scale-125");
        practiceTargetRing.classList.remove("scale-95");
        practiceTargetRing.classList.add("scale-105", "border-brand-blue/80");

        setTimeout(() => {
          practiceMetronome.classList.remove("bg-brand-blue", "scale-125");
          practiceTargetRing.classList.remove("scale-105", "border-brand-blue/80");
          practiceTargetRing.classList.add("scale-95");
        }, 100);
      }, msPerBeat);
    }

    // metronome stop
    function stopMetronome() {
      if (metronomeIntervalId) {
        clearInterval(metronomeIntervalId);
        metronomeIntervalId = null;
      }
    }

    // Click registration logic
    function handleMouseClick(e: MouseEvent) {
      // Stop execution if touched & touchwarning active
      if ((e as any).pointerType && (e as any).pointerType !== "mouse") {
        touchWarning.classList.remove("hidden");
      }

      e.preventDefault();

      let buttonName = "Left";
      if (e.button === 1) buttonName = "Middle";
      if (e.button === 2) buttonName = "Right";

      const now = performance.now();
      const lastTime = lastClickTime[buttonName];
      let interval = 0;

      if (lastTime > 0) {
        interval = now - lastTime;
      }

      // Check chatter
      const isChatter = interval > 0 && interval < chatterThreshold;

      // Update local state
      lastClickTime[buttonName] = now;
      totalClicks++;
      buttonClicks[buttonName]++;

      if (isChatter) {
        chatterClicks++;
        buttonChatter[buttonName]++;
        triggerChatterFeedback();
      } else {
        triggerNormalFeedback(e);
      }

      if (interval > 0 && interval < minInterval[buttonName]) {
        minInterval[buttonName] = interval;
      }

      clickHistory.push({
        button: buttonName,
        timestamp: Date.now(),
        interval: interval,
        isChatter: isChatter,
      });

      saveState();
      updateDashboard();
    }

    // Ripple feedback
    function triggerNormalFeedback(e: MouseEvent) {
      // Ripple Animation inside Click zone
      const rect = clickZone.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      const ripple = document.createElement("div");
      ripple.className = "absolute rounded-full bg-brand-blue/20 pointer-events-none transform -translate-x-1/2 -translate-y-1/2 scale-0 animate-ping duration-300";
      ripple.style.width = "60px";
      ripple.style.height = "60px";
      ripple.style.left = `${x}px`;
      ripple.style.top = `${y}px`;

      rippleOverlay.appendChild(ripple);
      setTimeout(() => ripple.remove(), 400);

      // Light flash on click zone
      clickZone.classList.add("bg-surface");
      setTimeout(() => clickZone.classList.remove("bg-surface"), 100);
    }

    function triggerChatterFeedback() {
      // Shake and Flash Click Zone Alarmingly
      clickZone.classList.add("bg-brand-red", "border-brand-red-dark/80", "animate-shake");
      
      // Respect prefers-reduced-motion
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        clickZone.classList.remove("animate-shake");
      }

      setTimeout(() => {
        clickZone.classList.remove("bg-brand-red", "border-brand-red-dark/80", "animate-shake");
      }, 350);
    }

    // CSV Exporter
    function exportToCsv() {
      if (clickHistory.length === 0) return;

      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Button,Timestamp,Interval (ms),Is Chatter\n";

      clickHistory.forEach(log => {
        const timeStr = new Date(log.timestamp).toISOString();
        csvContent += `${log.button},${timeStr},${log.interval.toFixed(2)},${log.isChatter}\n`;
      });

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", `double_click_test_${Date.now()}.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    // Micro interactions helper
    function triggerMicroAnimation(btn: HTMLButtonElement) {
      btn.classList.add("scale-95");
      setTimeout(() => {
        btn.classList.remove("scale-95");
      }, 100);
    }

    // Event Listeners
    clickZone.addEventListener("mousedown", handleMouseClick);
    clickZone.addEventListener("contextmenu", (e) => e.preventDefault());

    chatterThresholdRange.addEventListener("input", () => {
      chatterThreshold = parseInt(chatterThresholdRange.value, 10);
      chatterThresholdVal.textContent = `${chatterThreshold}ms`;
      saveState();
    });

    practiceToggleBtn.addEventListener("click", () => {
      practiceModeActive = !practiceModeActive;
      if (practiceModeActive) {
        practiceToggleBtn.textContent = "On";
        practiceToggleBtn.className = "inline-flex items-center gap-1 text-[10px] font-bold px-3 py-1 bg-primary text-canvas rounded-full transition-all cursor-pointer";
        practiceSettingsPanel.classList.remove("hidden");
        practiceGuideBox.classList.remove("opacity-0");
        practiceGuideBox.classList.add("opacity-100");
        startMetronome();
      } else {
        practiceToggleBtn.textContent = "Off";
        practiceToggleBtn.className = "inline-flex items-center gap-1 text-[10px] font-bold px-3 py-1 bg-surface hover:bg-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer";
        practiceSettingsPanel.classList.add("hidden");
        practiceGuideBox.classList.add("opacity-0");
        practiceGuideBox.classList.remove("opacity-100");
        stopMetronome();
      }
    });

    // BPM change listeners
    document.querySelectorAll(".bpm-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const bpm = parseInt(target.getAttribute("data-bpm") || "240", 10);
        practiceBpm = bpm;

        // Visual selection update
        document.querySelectorAll(".bpm-btn").forEach(b => {
          b.className = "bpm-btn px-3 py-1 text-[10px] font-bold rounded-full border border-hairline bg-canvas text-slate hover:text-primary transition-all";
        });
        target.className = "bpm-btn px-3 py-1 text-[10px] font-bold rounded-full border border-hairline bg-primary text-canvas transition-all";

        if (practiceModeActive) startMetronome();
      });
    });

    // Filter Listeners
    function applyFilter(filterName: typeof currentFilter, activeBtn: HTMLButtonElement) {
      currentFilter = filterName;

      [filterAll, filterLeft, filterMiddle, filterRight].forEach(b => {
        b.className = "px-2.5 py-0.5 rounded-full transition-all";
      });
      activeBtn.className = "px-2.5 py-0.5 rounded-full bg-primary text-canvas transition-all";

      renderLogs();
    }

    filterAll.addEventListener("click", () => applyFilter("all", filterAll));
    filterLeft.addEventListener("click", () => applyFilter("left", filterLeft));
    filterMiddle.addEventListener("click", () => applyFilter("middle", filterMiddle));
    filterRight.addEventListener("click", () => applyFilter("right", filterRight));

    // Reset button triggers
    resetBtn.addEventListener("click", handleReset);
    btnExportCsv.addEventListener("click", exportToCsv);

    // Modal Events
    howItWorksBtn.addEventListener("click", () => howItWorksModal.classList.remove("hidden"));
    closeModalBtn.addEventListener("click", () => howItWorksModal.classList.add("hidden"));
    modalOkBtn.addEventListener("click", () => howItWorksModal.classList.add("hidden"));
    howItWorksModal.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    // Cleanup listeners on navigate
    document.addEventListener("astro:before-swap", () => {
      stopMetronome();
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";

        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Run init
    init();
    }
  </script>

  <!-- Global styles overrides -->
  <style is:global>
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-4px); }
      40%, 80% { transform: translateX(4px); }
    }
    .animate-shake {
      animation: shake 0.3s ease-in-out;
    }
  </style>
</Layout>
