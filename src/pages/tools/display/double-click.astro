              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div
      class="card-base p-4 sm:p-5 flex flex-col gap-4 print:border-none print:shadow-none print:bg-transparent print:p-0"
    >
      <!-- Touch Warning Banner (Hidden by default) -->
      <div
        id="touch-warning"
        class="hidden bg-brand-red border border-brand-red-dark/30 text-coral-dark p-3 rounded-lg text-xs flex items-center gap-2 animate-fade-in"
      >
        <span class="text-base">⚠️</span>
        <div>
          <strong>Touch input detected.</strong> A physical mouse is highly recommended to accurately measure hardware switch chatter. Touch screen tap data might mask or skew results.
        </div>
      </div>

      <!-- Settings & Dashboard Controls -->
      <div
        class="border-b border-hairline-soft pb-3 flex flex-col md:flex-row justify-between items-start md:items-center gap-3"
      >
        <!-- Threshold control -->
        <div class="w-full md:w-auto flex flex-col sm:flex-row sm:items-center gap-3">
          <div class="flex flex-col gap-1 w-full sm:w-48">
            <div class="flex justify-between items-center text-[10px] font-semibold text-slate">
              <label for="chatter-threshold-range">Chatter Threshold</label>
              <span id="chatter-threshold-val" class="text-brand-blue font-bold">80ms</span>
            </div>
            <input
              type="range"
              id="chatter-threshold-range"
              min="5"
              max="150"
              value="80"
              step="5"
              class="w-full h-1 bg-hairline rounded-lg appearance-none cursor-pointer accent-brand-blue"
              aria-label="Adjust chatter detection threshold in milliseconds"
            />
          </div>

          <div class="flex items-center gap-2 mt-2 sm:mt-0">
            <span class="text-[10px] font-semibold text-slate">Practice Mode</span>
            <button
              type="button"
              id="practice-toggle-btn"
              class="inline-flex items-center gap-1 text-[10px] font-bold px-3 py-1 bg-surface hover:bg-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer"
            >
              Off
            </button>
          </div>
        </div>

        <!-- Filter tabs for logs -->
        <div class="flex items-center gap-1.5 self-end md:self-auto">
          <span class="text-[10px] font-semibold text-slate hidden sm:inline">Show Button:</span>
