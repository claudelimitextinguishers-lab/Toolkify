            <!-- Ripple container -->
            <div id="ripple-overlay" class="absolute inset-0 pointer-events-none z-0"></div>

            <div class="flex flex-col items-center gap-2 pointer-events-none z-10 p-4">
              <div class="text-3xl sm:text-4xl animate-bounce">🖱️</div>
              <h3 class="font-display font-semibold text-sm sm:text-base text-primary">
                Click inside this area to test mouse switches
              </h3>
              <p class="text-[10px] sm:text-xs text-stone max-w-sm leading-relaxed">
                Supports Left click, Right click, and Middle scroll wheel click. Context menu is prevented.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar logs & summaries -->
        <div class="lg:col-span-4 flex flex-col gap-4">
          <!-- Interval Log Panel -->
