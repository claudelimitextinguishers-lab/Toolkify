            </button>
            <button
              type="button"
              id="filter-left"
              class="px-2.5 py-0.5 rounded-full transition-all"
            >
              Left
            </button>
            <button
              type="button"
              id="filter-middle"
              class="px-2.5 py-0.5 rounded-full transition-all"
            >
              Mid
            </button>
            <button
              type="button"
              id="filter-right"
              class="px-2.5 py-0.5 rounded-full transition-all"
            >
              Right
