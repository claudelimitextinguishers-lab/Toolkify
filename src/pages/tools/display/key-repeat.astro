  <!-- Client-Side Page Script -->
  <script>
    if (typeof window !== 'undefined') {
    // State management
    interface KeySession {
      keyDownCount: number;
      repeatsCount: number;
      bounceCount: number;
      ghostCount: number;
      firstKeyDownTime: number;
      lastRepeatTime: number;
      lastKeyupTime: number;
      repeatDelay: number | null;
      repeatIntervals: number[];
      isHeld: boolean;
    }

    const localStoragePrefix = "toolkify:key-repeat:";
    
    let bounceThreshold = 30; // ms
    let ghostThreshold = 5; // seconds

    let totalBounces = 0;
    let totalGhosts = 0;
    
    // Per key logs in active session
    let perKeyStats: Record<string, KeySession> = {};
    let activeHeldKeys = new Set<string>();
    let keystrokeHistory: Array<{
      key: string;
      code: string;
      type: "down" | "repeat" | "up" | "bounce" | "ghost";
      timestamp: number;
      interval: number | null;
    }> = [];

    // UI elements
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const headerShareBtn = document.getElementById("share-btn") as HTMLButtonElement;
    const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;
    const touchWarning = document.getElementById("touch-warning") as HTMLDivElement;
    
    const statDelay = document.getElementById("stat-delay") as HTMLSpanElement;
    const statRate = document.getElementById("stat-rate") as HTMLSpanElement;
    const statBounce = document.getElementById("stat-bounce") as HTMLSpanElement;
    const statGhost = document.getElementById("stat-ghost") as HTMLSpanElement;

    const testZone = document.getElementById("test-zone") as HTMLDivElement;
    const testZonePlaceholder = document.getElementById("test-zone-placeholder") as HTMLDivElement;
    const testZoneActive = document.getElementById("test-zone-active") as HTMLDivElement;
    const activeKeyDisplay = document.getElementById("active-key-display") as HTMLSpanElement;
    const activeKeyType = document.getElementById("active-key-type") as HTMLSpanElement;
    const testZoneRippleLayer = document.getElementById("test-zone-ripple-layer") as HTMLDivElement;
    const heldKeysContainer = document.getElementById("held-keys-container") as HTMLDivElement;
    
    const bounceThresholdRange = document.getElementById("bounce-threshold-range") as HTMLInputElement;
    const bounceThresholdVal = document.getElementById("bounce-threshold-val") as HTMLSpanElement;
    
    const ghostThresholdRange = document.getElementById("ghost-threshold-range") as HTMLInputElement;
    const ghostThresholdVal = document.getElementById("ghost-threshold-val") as HTMLSpanElement;
    
    const typingSandbox = document.getElementById("typing-sandbox") as HTMLTextAreaElement;
    const perKeyTbody = document.getElementById("per-key-tbody") as HTMLTableSectionElement;
    const logConsole = document.getElementById("log-console") as HTMLDivElement;

    const exportCsvBtn = document.getElementById("export-csv-btn") as HTMLButtonElement;
    const exportJsonBtn = document.getElementById("export-json-btn") as HTMLButtonElement;

    // Detect touch keyboard users
    function checkTouchCapability() {
      if ("ontouchstart" in window || navigator.maxTouchPoints > 0) {
        touchWarning.classList.remove("hidden");
      }
    }

    let resizeTimeout: number | null = null;
    function handleResize() {
      if (resizeTimeout) {
        clearTimeout(resizeTimeout);
      }
      resizeTimeout = window.setTimeout(() => {
        checkTouchCapability();
      }, 150);
    }
    window.addEventListener("resize", handleResize);

    // Set interactive sliders
    function loadSavedSettings() {
      try {
        const urlParams = new URLSearchParams(window.location.search);
        const urlBounce = urlParams.get("bounce");
        const urlGhost = urlParams.get("ghost");

        if (urlBounce) {
          bounceThreshold = parseInt(urlBounce, 10);
          bounceThresholdRange.value = urlBounce;
          bounceThresholdVal.textContent = `${bounceThreshold}ms`;
        } else {
          const savedBounce = localStorage.getItem(`${localStoragePrefix}setting:bounce`);
          if (savedBounce) {
            bounceThreshold = parseInt(savedBounce, 10);
            bounceThresholdRange.value = savedBounce;
            bounceThresholdVal.textContent = `${bounceThreshold}ms`;
          }
        }

        if (urlGhost) {
          ghostThreshold = parseInt(urlGhost, 10);
          ghostThresholdRange.value = urlGhost;
          ghostThresholdVal.textContent = `${ghostThreshold}s`;
        } else {
          const savedGhost = localStorage.getItem(`${localStoragePrefix}setting:ghost`);
          if (savedGhost) {
            ghostThreshold = parseInt(savedGhost, 10);
            ghostThresholdRange.value = savedGhost;
            ghostThresholdVal.textContent = `${ghostThreshold}s`;
          }
        }
      } catch (err) {
        console.error("Failed to read localStorage settings:", err);
      }
    }

    function saveSettings() {
      try {
        localStorage.setItem(`${localStoragePrefix}setting:bounce`, bounceThreshold.toString());
        localStorage.setItem(`${localStoragePrefix}setting:ghost`, ghostThreshold.toString());
      } catch (err) {
        console.error("Failed to write localStorage settings:", err);
      }
    }

    // Helper to log console output
    function addLogEntry(text: string, styleClass = "text-slate") {
      const line = document.createElement("span");
      line.className = styleClass;
      line.textContent = `[${new Date().toLocaleTimeString()}] ${text}`;
      logConsole.appendChild(line);
      logConsole.scrollTop = logConsole.scrollHeight;
    }

    // Pulse feedback on keydown
    function triggerPulseAnimation(isRepeat: boolean) {
      // Create ripple element
      const pulse = document.createElement("div");
      if (isRepeat) {
        pulse.className = "absolute rounded-full bg-brand-blue/10 pointer-events-none transform -translate-x-1/2 -translate-y-1/2 scale-0 animate-ping duration-500";
        pulse.style.width = "100px";
        pulse.style.height = "100px";
      } else {
        pulse.className = "absolute rounded-full bg-brand-yellow/30 pointer-events-none transform -translate-x-1/2 -translate-y-1/2 scale-0 animate-ping duration-300";
        pulse.style.width = "120px";
        pulse.style.height = "120px";
      }
      pulse.style.left = `${Math.random() * 80 + 10}%`;
      pulse.style.top = `${Math.random() * 80 + 10}%`;

      testZoneRippleLayer.appendChild(pulse);
      setTimeout(() => pulse.remove(), 600);
    }

    // Bounce error animation
    function triggerBounceAnimation() {
      testZone.classList.add("bg-brand-red", "border-brand-red-dark", "animate-shake");
      
      // Respect prefers-reduced-motion
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        testZone.classList.remove("animate-shake");
      }

      setTimeout(() => {
        testZone.classList.remove("bg-brand-red", "border-brand-red-dark", "animate-shake");
      }, 300);
    }

    // Update stats indicators
    function animateNumericValue(element: HTMLSpanElement, targetValue: number, isFloat = false) {
      const startValue = parseFloat(element.textContent || "0");
      if (startValue === targetValue) return;

      const duration = 250; // ms
      const startTime = performance.now();

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        const currentValue = startValue + progress * (targetValue - startValue);
        element.textContent = isFloat ? currentValue.toFixed(1) : Math.round(currentValue).toString();

        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }
      requestAnimationFrame(update);
    }

    // Update Held Keys Display list
    function updateHeldKeysUI() {
      if (activeHeldKeys.size === 0) {
        heldKeysContainer.innerHTML = `<span class="text-[11px] text-stone italic px-1">None active. Hold keys to view.</span>`;
        return;
      }

      heldKeysContainer.innerHTML = "";
      activeHeldKeys.forEach(k => {
        const badge = document.createElement("span");
        badge.className = "px-2.5 py-0.5 rounded-full bg-primary text-canvas text-[11px] font-semibold";
        badge.textContent = k;
        heldKeysContainer.appendChild(badge);
      });
    }

    // Render per-key stats table
    function updateStatsTable() {
      if (Object.keys(perKeyStats).length === 0) {
        perKeyTbody.innerHTML = `<tr><td colspan="6" class="p-4 text-center text-stone italic">No keystroke records in session. Start holding down keys to collect diagnostics.</td></tr>`;
        return;
      }

      perKeyTbody.innerHTML = "";
      Object.entries(perKeyStats).forEach(([code, session]) => {
        const tr = document.createElement("tr");
        tr.className = "hover:bg-surface transition-colors";

        const delayStr = session.repeatDelay !== null ? `${Math.round(session.repeatDelay)} ms` : "-";
        
        let avgRateStr = "-";
        if (session.repeatIntervals.length > 0) {
          const sumIntervals = session.repeatIntervals.reduce((a, b) => a + b, 0);
          const avgInterval = sumIntervals / session.repeatIntervals.length;
          const avgRate = 1000 / avgInterval;
          avgRateStr = `${avgRate.toFixed(1)} Hz`;
        }

        // Consistency evaluation
        let consistency = "Excellent";
        if (session.repeatIntervals.length > 1) {
          const sumIntervals = session.repeatIntervals.reduce((a, b) => a + b, 0);
          const avgInterval = sumIntervals / session.repeatIntervals.length;
          const variance = session.repeatIntervals.map(x => Math.pow(x - avgInterval, 2)).reduce((a, b) => a + b, 0) / session.repeatIntervals.length;
          const stdDev = Math.sqrt(variance);
          
          if (stdDev > 45) {
            consistency = "Poor (Unstable)";
          } else if (stdDev > 20) {
            consistency = "Moderate";
          }
        }

        tr.innerHTML = `
          <td class="p-3 font-semibold text-primary">${code}</td>
          <td class="p-3">${delayStr}</td>
          <td class="p-3">${avgRateStr}</td>
          <td class="p-3 text-brand-coral font-semibold">${session.bounceCount}</td>
          <td class="p-3 text-brand-coral font-semibold">${session.ghostCount}</td>
          <td class="p-3">
            <span class="px-2 py-0.5 rounded-full text-[10px] font-bold ${consistency === "Excellent" ? "bg-teal-light text-moss-dark" : consistency.startsWith("Poor") ? "bg-brand-red text-brand-red-dark" : "bg-yellow-light text-yellow-dark"}">
              ${consistency}
            </span>
          </td>
        `;
        perKeyTbody.appendChild(tr);
      });
    }

    // Helper to clear held keys on focus loss or blur
    function clearHeldKeys() {
      activeHeldKeys.clear();
      Object.values(perKeyStats).forEach(session => {
        session.isHeld = false;
        session.firstKeyDownTime = 0;
        session.lastRepeatTime = 0;
      });
      updateHeldKeysUI();
      if (activeHeldKeys.size === 0) {
        testZoneActive.classList.add("hidden");
        testZonePlaceholder.classList.remove("hidden");
      }
    }

    // Core keystroke handler
    function processKeyDown(e: KeyboardEvent) {
      const keyName = e.key === " " ? "Space" : e.key;
      const code = e.code || keyName;

      // Prevent browser default scroll actions, page refresh, and other shortcut overrides when focused
      if (document.activeElement === testZone) {
        const isFunctionKey = /^F[1-9]$|^F1[0-2]$/.test(e.key);
        const preventKeys = ["Space", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight", "Tab", "Backspace"];
        if (preventKeys.includes(e.code) || e.key === " " || isFunctionKey) {
          e.preventDefault();
        }
      }

      const now = performance.now();

      // Show focused capture zone layout
      testZonePlaceholder.classList.add("hidden");
      testZoneActive.classList.remove("hidden");
      activeKeyDisplay.textContent = keyName;

      // Handle Key Session
      if (!perKeyStats[code]) {
        perKeyStats[code] = {
          keyDownCount: 0,
          repeatsCount: 0,
          bounceCount: 0,
          ghostCount: 0,
          firstKeyDownTime: 0,
          lastRepeatTime: 0,
          lastKeyupTime: 0,
          repeatDelay: null,
          repeatIntervals: [],
          isHeld: false
        };
      }

      const session = perKeyStats[code];

      if (!e.repeat) {
        // Genuine new press
        activeHeldKeys.add(keyName);
        session.isHeld = true;
        session.keyDownCount++;
        session.firstKeyDownTime = now;
        session.lastRepeatTime = now;
        
        activeKeyType.textContent = "New Press";
        activeKeyType.className = "text-[10px] text-brand-blue mt-1 uppercase font-bold";

        // Check Bounce chatter
        if (session.lastKeyupTime > 0) {
          const releaseToPress = now - session.lastKeyupTime;
          if (releaseToPress < bounceThreshold) {
            session.bounceCount++;
            totalBounces++;
            animateNumericValue(statBounce, totalBounces);
            addLogEntry(`âš ï¸ BOUNCE detected on [${keyName}] interval: ${releaseToPress.toFixed(1)}ms`, "text-brand-coral font-bold");
            keystrokeHistory.push({ key: keyName, code, type: "bounce", timestamp: Date.now(), interval: releaseToPress });
            triggerBounceAnimation();
          }
        }

        keystrokeHistory.push({ key: keyName, code, type: "down", timestamp: Date.now(), interval: null });
        triggerPulseAnimation(false);
      } else {
        // Auto-repeat event
        session.repeatsCount++;
        activeKeyType.textContent = "Auto Repeat";
        activeKeyType.className = "text-[10px] text-yellow-dark mt-1 uppercase font-bold";

        if (session.firstKeyDownTime === 0) {
          session.firstKeyDownTime = now;
        }
        if (session.lastRepeatTime === 0) {
          session.lastRepeatTime = now;
        }

        const elapsedSinceFirst = now - session.firstKeyDownTime;

        // Measure Repeat Delay (Time from first keydown to first repeat)
        if (session.repeatDelay === null) {
          session.repeatDelay = elapsedSinceFirst;
          animateNumericValue(statDelay, session.repeatDelay);
          addLogEntry(`[${keyName}] repeat delay measured: ${Math.round(session.repeatDelay)}ms`, "text-primary");
        }

        // Measure Repeat Rate Interval
        const interval = now - session.lastRepeatTime;
        if (interval > 0) {
          session.repeatIntervals.push(interval);
          const currentHz = 1000 / interval;
          animateNumericValue(statRate, currentHz, true);
        }

        // Ghost Key Check based on continuous held duration
        if (elapsedSinceFirst > (ghostThreshold * 1000) && session.ghostCount === 0) {
          session.ghostCount++;
          totalGhosts++;
          animateNumericValue(statGhost, totalGhosts);
          addLogEntry(`âš ï¸ GHOST/STUCK detection: [${keyName}] held > ${ghostThreshold}s`, "text-brand-coral font-bold");
          keystrokeHistory.push({ key: keyName, code, type: "ghost", timestamp: Date.now(), interval: elapsedSinceFirst });
        }

        session.lastRepeatTime = now;
        keystrokeHistory.push({ key: keyName, code, type: "repeat", timestamp: Date.now(), interval: interval });
        triggerPulseAnimation(true);
      }

      updateHeldKeysUI();
      updateStatsTable();
    }

    function processKeyUp(e: KeyboardEvent) {
      const keyName = e.key === " " ? "Space" : e.key;
      const code = e.code || keyName;
      const now = performance.now();

      activeHeldKeys.delete(keyName);
      updateHeldKeysUI();

      if (perKeyStats[code]) {
        const session = perKeyStats[code];
        session.isHeld = false;
        session.lastKeyupTime = now;
        
        keystrokeHistory.push({ key: keyName, code, type: "up", timestamp: Date.now(), interval: null });
      }

      // Restore normal zone layout if no keys active
      if (activeHeldKeys.size === 0) {
        testZoneActive.classList.add("hidden");
        testZonePlaceholder.classList.remove("hidden");
      }
    }

    // Reset handlers
    function handleReset() {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // Clear states
      perKeyStats = {};
      activeHeldKeys.clear();
      keystrokeHistory = [];
      totalBounces = 0;
      totalGhosts = 0;

      // Animate resets
      statDelay.textContent = "0";
      statRate.textContent = "0";
      statBounce.textContent = "0";
      statGhost.textContent = "0";

      testZoneActive.classList.add("hidden");
      testZonePlaceholder.classList.remove("hidden");
      
      typingSandbox.value = "";
      logConsole.innerHTML = `<span class="text-stone italic">[System] Session reset. Listening for keyboard input events...</span>`;

      // Clear localStorage keys prefix
      try {
        const keysToRemove = [];
        for (let i = 0; i < localStorage.length; i++) {
          const key = localStorage.key(i);
          if (key && key.startsWith(localStoragePrefix)) {
            keysToRemove.push(key);
          }
        }
        keysToRemove.forEach(k => localStorage.removeItem(k));
      } catch (err) {
        console.error("Failed to clear localStorage keys:", err);
      }

      updateHeldKeysUI();
      updateStatsTable();
      addLogEntry("Session and diagnostic history cleared.");
    }

    // Exporters
    function exportToCSV() {
      if (keystrokeHistory.length === 0) {
        alert("No logs to export. Record some keystrokes first.");
        return;
      }

      let csv = "Timestamp,Key,Event Type,Interval (ms)\n";
      keystrokeHistory.forEach(item => {
        const timeStr = new Date(item.timestamp).toISOString();
        const intervalStr = item.interval !== null ? item.interval.toFixed(1) : "-";
        csv += `${timeStr},"${item.key}",${item.type},${intervalStr}\n`;
      });

      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.setAttribute("href", url);
      link.setAttribute("download", `key_repeat_test_${Date.now()}.csv`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    function exportToJSON() {
      if (keystrokeHistory.length === 0) {
        alert("No logs to export. Record some keystrokes first.");
        return;
      }

      const exportData = {
        meta: {
          exporter: "TOOLKIFY Key Repeat Test",
          timestamp: new Date().toISOString(),
          totals: {
            bounces: totalBounces,
            ghosts: totalGhosts
          }
        },
        keystrokes: keystrokeHistory,
        perKeyAverages: Object.entries(perKeyStats).map(([keyName, item]) => {
          const sumIntervals = item.repeatIntervals.reduce((a, b) => a + b, 0);
          const avgInterval = item.repeatIntervals.length > 0 ? sumIntervals / item.repeatIntervals.length : null;
          return {
            key: keyName,
            repeatDelay: item.repeatDelay,
            avgRepeatInterval: avgInterval,
            avgRateHz: avgInterval ? 1000 / avgInterval : null,
            bounceCount: item.bounceCount,
            ghostCount: item.ghostCount
          };
        })
      };

      const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.setAttribute("href", url);
      link.setAttribute("download", `key_repeat_test_${Date.now()}.json`);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    // Attach listeners
    testZone.addEventListener("keydown", processKeyDown);
    testZone.addEventListener("keyup", processKeyUp);
    
    typingSandbox.addEventListener("keydown", processKeyDown);
    typingSandbox.addEventListener("keyup", processKeyUp);

    bounceThresholdRange.addEventListener("input", () => {
      bounceThreshold = parseInt(bounceThresholdRange.value, 10);
      bounceThresholdVal.textContent = `${bounceThreshold}ms`;
      saveSettings();
    });

    ghostThresholdRange.addEventListener("input", () => {
      ghostThreshold = parseInt(ghostThresholdRange.value, 10);
      ghostThresholdVal.textContent = `${ghostThreshold}s`;
      saveSettings();
    });

    // Reset and exporter events
    resetBtn.addEventListener("click", handleReset);
    headerShareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("bounce", String(bounceThreshold));
      url.searchParams.set("ghost", String(ghostThreshold));

      const shareData = {
        title: document.title || "Key Repeat Test",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      // Success animation matching bmi-calculator.astro
      function showSuccess() {
        if (headerShareBtn) {
          const span = headerShareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            headerShareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              headerShareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });
    exportCsvBtn.addEventListener("click", exportToCSV);
    exportJsonBtn.addEventListener("click", exportToJSON);

    // Modal logic
    howItWorksBtn.addEventListener("click", () => {
      howItWorksModal.classList.remove("hidden");
    });
    closeModalBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });
    modalOkBtn.addEventListener("click", () => {
      howItWorksModal.classList.add("hidden");
    });
    howItWorksModal.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });
    // Focus handling for test zone styling and cleanup
    testZone.addEventListener("focus", () => {
      testZone.classList.add("border-brand-blue", "bg-canvas");
      testZone.classList.remove("bg-surface");
    });
    testZone.addEventListener("blur", () => {
      testZone.classList.remove("border-brand-blue");
      clearHeldKeys();
    });
    window.addEventListener("blur", clearHeldKeys);

    // Cleanup listeners on navigate (for single page applications/Astro transitions)
    document.addEventListener("astro:before-swap", () => {
      testZone.removeEventListener("keydown", processKeyDown);
      testZone.removeEventListener("keyup", processKeyUp);
      typingSandbox.removeEventListener("keydown", processKeyDown);
      typingSandbox.removeEventListener("keyup", processKeyUp);
      window.removeEventListener("blur", clearHeldKeys);
      window.removeEventListener("resize", handleResize);
    });
    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";

        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    checkTouchCapability();
    loadSavedSettings();
    }
  </script>

  <style is:global>
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-4px); }
      40%, 80% { transform: translateX(4px); }
    }
    .animate-shake {
      animation: shake 0.3s ease-in-out;
    }
  </style>
</Layout>
