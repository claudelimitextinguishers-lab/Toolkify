      // Delta Mode Normalizer
      function normalizeDeltas(delta, mode) {
        if (mode === 1) return delta * 40;
        if (mode === 2) return delta * 800;
        return delta;
      }

      // Statistical Notch Classifier
      function classifyNotchVariance(deltas) {
        if (deltas.length < 5) return "Analyzing...";
        const absDeltas = deltas.map(Math.abs);
        const mean = absDeltas.reduce((a, b) => a + b, 0) / absDeltas.length;
        const variance = absDeltas.reduce((a, b) => a + Math.pow(b - mean, 2), 0) / absDeltas.length;
        const stdDev = Math.sqrt(variance);
        const integerCount = absDeltas.filter(d => Number.isInteger(d)).length;
        const pctInteger = integerCount / absDeltas.length;
        const uniqueValues = new Set(absDeltas.map(v => Math.round(v * 10) / 10));

        if (pctInteger >= 0.85 && uniqueValues.size <= 4) return "Notched Wheel";
        if (stdDev > 5 && uniqueValues.size > 8) return "Smooth/Trackpad Input";
        return "Mixed Input";
      }

      // Velocity tracker logic (rolling buffer)
      function updateVelocity(normalizedDelta) {
        const now = Date.now();
        scrollVelocityBuffer.push({ timestamp: now, delta: Math.abs(normalizedDelta) });
        scrollVelocityBuffer = scrollVelocityBuffer.filter(e => now - e.timestamp <= 500);

        const totalDelta = scrollVelocityBuffer.reduce((sum, e) => sum + e.delta, 0);
        const velocity = Math.round(totalDelta / 0.5);

        if (velocity > maxVelocityObserved) {
          maxVelocityObserved = velocity;
          maxVelocityEl.textContent = `Peak: ${maxVelocityObserved} px/s`;
        }

        scrollVelocityEl.textContent = `${velocity} px/s`;
        drawGauge(velocity);

        // Momentum score (decaying EMA)
        momentumHistory.push(velocity);
        if (momentumHistory.length > 20) momentumHistory.shift();
        const ema = momentumHistory.reduce((acc, v, i) => {
          const weight = (i + 1) / momentumHistory.length;
          return acc + v * weight;
        }, 0) / (momentumHistory.length * (momentumHistory.length + 1) / 2 / momentumHistory.length);
        if (statMomentumEl) statMomentumEl.textContent = Math.round(ema) + " px/s";

        if (wheelLogs.length > 0) {
          const totalVal = wheelLogs.reduce((acc, log) => acc + Math.abs(log.normalizedY) + Math.abs(log.normalizedX), 0);
          const durationSeconds = Math.max(1, (Date.now() - (wheelLogs[0]?.rawTime || Date.now())) / 1000);
          statAvgVelocityEl.textContent = `${Math.round(totalVal / durationSeconds)} px/s`;
        }
      }

      // Stress test progress calculator
      function updateStressProgress() {
        if (!stressTestToggle.checked) return;
        const target = parseInt(stressTargetSelect.value, 10);
        const pct = Math.min(100, Math.round((ticksCaptured / target) * 100));
        stressProgress.style.width = `${pct}%`;
        stressPct.textContent = `${pct}% Complete`;

        if (pct >= 100) {
          stressStatus.textContent = "ðŸŽ‰ Target Reached!";
          stressStatus.className = "text-success-accent font-bold animate-bounce";
        } else {
          stressStatus.textContent = `${ticksCaptured} / ${target} ticks`;
          stressStatus.className = "text-slate";
        }
      }

      stressTestToggle.addEventListener("change", () => {
        if (stressTestToggle.checked) {
          stressTestControls.classList.remove("hidden");
          updateStressProgress();
        } else {
          stressTestControls.classList.add("hidden");
        }
        saveSessionState();
      });

      stressTargetSelect.addEventListener("change", () => {
        updateStressProgress();
        saveSessionState();
      });

      // Direction indicators with glow class
      function updateDirectionIndicators(dir) {
        [dirLeft, dirRight, dirUp, dirDown].forEach(el => {
          el.classList.add("opacity-30");
          el.classList.remove("sw-dir-active");
        });

        const map = { up: dirUp, down: dirDown, left: dirLeft, right: dirRight };
        if (map[dir]) {
          map[dir].classList.remove("opacity-30");
          map[dir].classList.add("sw-dir-active");
        }
      }

      // ---- Zone readout pop helper ----
      function popZoneNum(el, value) {
        if (!el) return;
        el.textContent = value;
        el.classList.remove("sw-zone-delta-pop");
        void el.offsetWidth;
        el.classList.add("sw-zone-delta-pop");
      }

      // Main event capture logic
      testZone.addEventListener("wheel", function (e) {
        e.preventDefault();

        const rawDeltaX = e.deltaX;
        const rawDeltaY = e.deltaY;
        const rawDeltaZ = e.deltaZ;
        const mode = e.deltaMode;

        if (rawDeltaX === 0 && rawDeltaY === 0) return;

        const normX = normalizeDeltas(rawDeltaX, mode);
        const normY = normalizeDeltas(rawDeltaY, mode);

        // Zone active state
        setZoneActive(true);
        lastScrollTime = Date.now();
        if (zoneIdleTimer) clearTimeout(zoneIdleTimer);
        zoneIdleTimer = setTimeout(() => setZoneActive(false), 800);

        // Delta mode label
        let modeLabel = "Pixels (Mode 0)";
        if (mode === 1) modeLabel = "Lines (Mode 1)";
        if (mode === 2) modeLabel = "Pages (Mode 2)";
        scrollModeEl.textContent = modeLabel;
        rawModeTextEl.textContent = `Mode Raw: ${mode}`;

        // Direction
        let direction = null;
        if (Math.abs(normY) >= Math.abs(normX)) {
          direction = normY > 0 ? "down" : "up";
        } else {
          direction = normX > 0 ? "right" : "left";
        }

        if (previousScrollDirection && previousScrollDirection !== direction) {
          directionChangesCount++;
          statDirChangesEl.textContent = directionChangesCount;
        }
        previousScrollDirection = direction;
        updateDirectionIndicators(direction);

        // Tick counter
        ticksCaptured++;
        tickCounterEl.textContent = ticksCaptured;
        if (zoneTicksEl) popZoneNum(zoneTicksEl, ticksCaptured);

        // Flash
        flashTick();

        // Tick number scale pop
        tickCounterEl.classList.remove("scale-105");
        void tickCounterEl.offsetWidth;
        tickCounterEl.classList.add("scale-105");
        setTimeout(() => tickCounterEl.classList.remove("scale-105"), 100);

        // Zone mini readout
        if (zoneDyEl) popZoneNum(zoneDyEl, Math.round(normY));
        if (zoneDxEl) popZoneNum(zoneDxEl, Math.round(normX));

        // Wheel visual animate
        const rotationY = (normY > 0 ? 1 : -1) * 8;
        wheelVisualIndicator.style.transform = `translateY(${rotationY}px)`;
        setTimeout(() => {
          wheelVisualIndicator.style.transform = "translateY(0px)";
        }, 150);

        // Ripple at cursor or center
        const zoneRect = testZone.getBoundingClientRect();
        const rx = cursorX !== null ? cursorX : zoneRect.width / 2;
        const ry = cursorY !== null ? cursorY : zoneRect.height / 2;
        const rippleColor = Math.abs(normY) >= Math.abs(normX)
          ? "rgba(66,98,255,0.5)"
          : "rgba(255,153,153,0.55)";
        spawnRipple(rx, ry, rippleColor);

        // Particle burst every 10 ticks
        if (ticksCaptured % 10 === 0) {
          const pColor = Math.abs(normY) >= Math.abs(normX) ? "#4262ff" : "#ff9999";
          spawnParticleBurst(rx, ry, 10, pColor);
        }

        // Milestone celebration
        MILESTONES.forEach(m => {
          if (ticksCaptured === m && !passedMilestones.has(m)) {
            passedMilestones.add(m);
            showMilestoneToast(`ðŸŽ¯ ${m} ticks reached!`);
            spawnParticleBurst(rx, ry, 18, "#7c3aed");
          }
        });

        // Stats
        const currentMaxDelta = Math.max(Math.abs(normX), Math.abs(normY));
        if (currentMaxDelta > maxDeltaObserved) {
          maxDeltaObserved = currentMaxDelta;
          statMaxDeltaEl.textContent = Math.round(maxDeltaObserved);
        }

        if (normY !== 0) nonZeroDeltasHistory.push(rawDeltaY);
        else if (normX !== 0) nonZeroDeltasHistory.push(rawDeltaX);
        if (nonZeroDeltasHistory.length > 30) nonZeroDeltasHistory.shift();

        const currentClassification = classifyNotchVariance(nonZeroDeltasHistory);
        deviceClassificationEl.textContent = currentClassification;

        // Bounded tracks
        boundedY = Math.max(0, Math.min(100, boundedY + (normY * 0.1)));
        boundedX = Math.max(0, Math.min(100, boundedX + (normX * 0.1)));
        
        const verticalTrack = verticalBoundedIndicator.parentElement;
        const horizontalTrack = horizontalBoundedIndicator.parentElement;

        let trackH = 100;
        let trackW = 100;

        if (verticalTrack && verticalBoundedIndicator) {
          const trackRect = verticalTrack.getBoundingClientRect();
          const indicatorRect = verticalBoundedIndicator.getBoundingClientRect();
          trackH = trackRect.height - indicatorRect.height;
        }

        if (horizontalTrack && horizontalBoundedIndicator) {
          const trackRect = horizontalTrack.getBoundingClientRect();
          const indicatorRect = horizontalBoundedIndicator.getBoundingClientRect();
          trackW = trackRect.width - indicatorRect.width;
        }

        verticalBoundedIndicator.style.transform = `translateY(${(boundedY / 100) * Math.max(trackH, 0)}px)`;
        horizontalBoundedIndicator.style.transform = `translateX(${(boundedX / 100) * Math.max(trackW, 0)}px)`;

        updateVelocity(normY || normX);

        const now = Date.now();
        timelinePoints.push({ time: now, y: normY, x: normX });
        if (timelinePoints.length > maxTimelinePoints) timelinePoints.shift();

        const timeString = new Date().toLocaleTimeString() + "." + String(now % 1000).padStart(3, "0");
        const logObj = {
          time: timeString,
          rawTime: now,
          dx: rawDeltaX,
          dy: rawDeltaY,
          dz: rawDeltaZ,
          mode: mode,
          normalizedX: normX,
          normalizedY: normY,
          classification: currentClassification
        };

        wheelLogs.unshift(logObj);
        if (wheelLogs.length > 100) wheelLogs.pop();

        renderLogsUI();
        updateStressProgress();
        saveSessionState();
      }, { passive: false });

      // Render Logs table
      function renderLogsUI() {
        if (wheelLogs.length === 0) return;
        const slice = wheelLogs.slice(0, 30);
        rawLogTbody.innerHTML = slice.map(log => `
          <tr class="border-b border-hairline-soft hover:bg-surface transition-colors">
            <td class="py-1.5 px-3 font-mono">${log.time}</td>
            <td class="py-1.5 px-3 text-right font-mono">${log.dx.toFixed(1)}</td>
            <td class="py-1.5 px-3 text-right font-mono">${log.dy.toFixed(1)}</td>
            <td class="py-1.5 px-3 text-right font-mono">${log.dz.toFixed(1)}</td>
            <td class="py-1.5 px-3 text-stone">${log.mode}</td>
            <td class="py-1.5 px-3 text-right font-mono">${Math.round(log.normalizedX)}, ${Math.round(log.normalizedY)}</td>
            <td class="py-1.5 px-3 font-semibold text-brand-blue">${log.classification}</td>
          </tr>
        `).join("");
      }

      // ---- Enhanced Timeline Canvas with gradients, bezier, grid ----
      function initGraphCanvas() {
        const ctx = timelineCanvas.getContext("2d");

        function draw() {
          if (!timelineCanvas) return;

          const rect = timelineCanvas.getBoundingClientRect();
          if (timelineCanvas.width !== Math.floor(rect.width) || timelineCanvas.height !== Math.floor(rect.height)) {
            timelineCanvas.width = Math.floor(rect.width) || 400;
            timelineCanvas.height = Math.floor(rect.height) || 160;
          }

          const width = timelineCanvas.width;
          const height = timelineCanvas.height;
          const centerY = height / 2;

          ctx.clearRect(0, 0, width, height);

          // Background
          ctx.fillStyle = "rgba(0,0,0,0)";
          ctx.fillRect(0, 0, width, height);

          // Grid lines
          ctx.strokeStyle = "rgba(107,111,126,0.10)";
          ctx.lineWidth = 1;
          const gridCols = 8;
          for (let i = 1; i < gridCols; i++) {
            ctx.beginPath();
            ctx.moveTo((width / gridCols) * i, 0);
            ctx.lineTo((width / gridCols) * i, height);
            ctx.stroke();
          }
          const gridRows = 4;
          for (let i = 1; i < gridRows; i++) {
            ctx.beginPath();
            ctx.moveTo(0, (height / gridRows) * i);
            ctx.lineTo(width, (height / gridRows) * i);
            ctx.stroke();
          }

          // Zero line
          ctx.strokeStyle = "rgba(107,111,126,0.22)";
          ctx.lineWidth = 1;
          ctx.setLineDash([4, 4]);
          ctx.beginPath();
          ctx.moveTo(0, centerY);
          ctx.lineTo(width, centerY);
          ctx.stroke();
          ctx.setLineDash([]);

          if (timelinePoints.length > 1) {
            const step = width / maxTimelinePoints;

            // Helper: compute point positions
            function getPoints(axis) {
              return timelinePoints.map((pt, i) => ({
                x: width - (timelinePoints.length - 1 - i) * step,
                y: centerY - ((axis === 'y' ? pt.y : pt.x) * (centerY / 200))
              }));
            }

            // Draw gradient fill + bezier line for Y (blue)
            {
              const pts = getPoints('y');
              // Gradient fill
              const fillGrad = ctx.createLinearGradient(0, 0, 0, height);
              fillGrad.addColorStop(0, "rgba(66,98,255,0.25)");
              fillGrad.addColorStop(0.5, "rgba(66,98,255,0.08)");
              fillGrad.addColorStop(1, "rgba(66,98,255,0.01)");

              ctx.beginPath();
              ctx.moveTo(pts[0].x, centerY);
              ctx.lineTo(pts[0].x, pts[0].y);
              for (let i = 1; i < pts.length; i++) {
                const cp1x = (pts[i - 1].x + pts[i].x) / 2;
                ctx.bezierCurveTo(cp1x, pts[i - 1].y, cp1x, pts[i].y, pts[i].x, pts[i].y);
              }
              ctx.lineTo(pts[pts.length - 1].x, centerY);
              ctx.closePath();
              ctx.fillStyle = fillGrad;
              ctx.fill();

              // Line
              ctx.beginPath();
              ctx.moveTo(pts[0].x, pts[0].y);
              for (let i = 1; i < pts.length; i++) {
                const cp1x = (pts[i - 1].x + pts[i].x) / 2;
                ctx.bezierCurveTo(cp1x, pts[i - 1].y, cp1x, pts[i].y, pts[i].x, pts[i].y);
              }
              ctx.strokeStyle = "#4262ff";
              ctx.lineWidth = 2.5;
              ctx.lineJoin = "round";
              ctx.stroke();

              // Head dot
              const last = pts[pts.length - 1];
              ctx.beginPath();
              ctx.arc(last.x, last.y, 4, 0, Math.PI * 2);
              ctx.fillStyle = "#4262ff";
              ctx.fill();
              ctx.beginPath();
              ctx.arc(last.x, last.y, 7, 0, Math.PI * 2);
              ctx.strokeStyle = "rgba(66,98,255,0.3)";
              ctx.lineWidth = 2;
              ctx.stroke();
            }

            // Draw gradient fill + bezier line for X (coral)
            {
              const pts = getPoints('x');
              const hasX = timelinePoints.some(p => p.x !== 0);
              if (hasX) {
                const fillGrad = ctx.createLinearGradient(0, 0, 0, height);
                fillGrad.addColorStop(0, "rgba(255,153,153,0.18)");
                fillGrad.addColorStop(1, "rgba(255,153,153,0.01)");

                ctx.beginPath();
                ctx.moveTo(pts[0].x, centerY);
                ctx.lineTo(pts[0].x, pts[0].y);
                for (let i = 1; i < pts.length; i++) {
                  const cp1x = (pts[i - 1].x + pts[i].x) / 2;
                  ctx.bezierCurveTo(cp1x, pts[i - 1].y, cp1x, pts[i].y, pts[i].x, pts[i].y);
                }
                ctx.lineTo(pts[pts.length - 1].x, centerY);
                ctx.closePath();
                ctx.fillStyle = fillGrad;
                ctx.fill();

                ctx.beginPath();
                ctx.moveTo(pts[0].x, pts[0].y);
                for (let i = 1; i < pts.length; i++) {
                  const cp1x = (pts[i - 1].x + pts[i].x) / 2;
                  ctx.bezierCurveTo(cp1x, pts[i - 1].y, cp1x, pts[i].y, pts[i].x, pts[i].y);
                }
                ctx.strokeStyle = "#ff9999";
                ctx.lineWidth = 2;
                ctx.lineJoin = "round";
                ctx.stroke();

                const last = pts[pts.length - 1];
                ctx.beginPath();
                ctx.arc(last.x, last.y, 3, 0, Math.PI * 2);
                ctx.fillStyle = "#ff9999";
                ctx.fill();
              }
            }
          }

          animationFrameId = requestAnimationFrame(draw);
        }

        draw();
      }

      // Export tools
      exportCsvBtn.addEventListener("click", () => {
        if (wheelLogs.length === 0) return alert("No captured logs to export yet.");
        let csvContent = "data:text/csv;charset=utf-8,";
        csvContent += "Timestamp,deltaX,deltaY,deltaZ,deltaMode,NormalizedX,NormalizedY,Classification\n";
        wheelLogs.forEach(log => {
          csvContent += `${log.time},${log.dx},${log.dy},${log.dz},${log.mode},${log.normalizedX},${log.normalizedY},"${log.classification}"\n`;
        });
        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", `scroll_wheel_diagnostics_${Date.now()}.csv`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      });

      exportJsonBtn.addEventListener("click", () => {
        if (wheelLogs.length === 0) return alert("No captured logs to export yet.");
        const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(wheelLogs, null, 2));
        const link = document.createElement("a");
        link.setAttribute("href", dataStr);
        link.setAttribute("download", `scroll_wheel_diagnostics_${Date.now()}.json`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      });

      // Cleanup listeners on navigate
      document.addEventListener("astro:before-swap", () => {
        isDrawActive = false;
      });

      // Boot up
      restoreSettings();
      initGraphCanvas();
      initZoneBgCanvas();
      drawGauge(0);
    })();
    }
  </script>

  <style is:global>
    /* ---- Scroll Wheel Tool Animations ---- */
    .scale-105 {
      transform: scale(1.08);
      color: #4262ff;
    }

    /* Stat card hover lift */
    .sw-stat-card {
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .sw-stat-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(66,98,255,0.10);
    }

    /* Direction arrow glow */
    .sw-dir-arrow.sw-dir-active {
      opacity: 1 !important;
      filter: drop-shadow(0 0 6px currentColor);
    }
    .sw-dir-arrow.sw-dir-active .sw-arrow-glyph {
      animation: sw-arrow-pop 0.22s cubic-bezier(.22,1.5,.36,1) forwards;
    }
    @keyframes sw-arrow-pop {
      0%   { transform: scale(1); }
      50%  { transform: scale(1.45); }
      100% { transform: scale(1.15); }
    }

    /* Wheel indicator bounce */
    .sw-wheel-indicator {
      transition: transform 0.12s cubic-bezier(.22,1.5,.36,1);
    }

    /* Mouse icon subtle float */
    .sw-mouse-icon {
      animation: sw-mouse-float 3s ease-in-out infinite;
    }
    @keyframes sw-mouse-float {
      0%, 100% { transform: translateY(0px); }
      50%       { transform: translateY(-4px); }
    }

    /* Zone active dot pulsing */
    .sw-zone-active .sw-active-dot {
      background: #22c55e !important;
      animation: sw-dot-ping 0.8s ease-out infinite;
    }
    @keyframes sw-dot-ping {
      0%    { box-shadow: 0 0 0 0 rgba(34,197,94,0.6); }
      70%   { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
      100%  { box-shadow: 0 0 0 0 rgba(34,197,94,0); }
    }

    /* Glow cursor */
    .sw-cursor-glow-el {
      background: radial-gradient(circle, rgba(66,98,255,0.35) 0%, rgba(66,98,255,0.08) 55%, transparent 75%);
      transition: opacity 0.3s ease, transform 0.08s ease;
    }

    /* Ripple ring animation */
    .sw-ripple {
      position: absolute;
      border-radius: 50%;
      border: 2px solid;
      pointer-events: none;
      animation: sw-ripple-expand 0.7s cubic-bezier(.22,1,.36,1) forwards;
    }
    @keyframes sw-ripple-expand {
      from { opacity: 0.7; transform: translate(-50%, -50%) scale(0); }
      to   { opacity: 0;   transform: translate(-50%, -50%) scale(1); }
    }

    /* Particle burst */
    .sw-particle {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      animation: sw-particle-fly var(--dur, 0.6s) ease-out forwards;
    }
    @keyframes sw-particle-fly {
      from { opacity: 1; transform: translate(0, 0) scale(1); }
      to   { opacity: 0; transform: translate(var(--tx, 0px), var(--ty, 0px)) scale(0.2); }
    }

    /* Milestone toast */
    .sw-milestone-toast {
      animation: none;
    }
    .sw-milestone-toast.sw-toast-show {
      animation: sw-toast-in-out 2.2s ease forwards;
    }
    @keyframes sw-toast-in-out {
      0%   { opacity: 0; transform: translateX(-50%) translateY(-8px); }
      15%  { opacity: 1; transform: translateX(-50%) translateY(0); }
      75%  { opacity: 1; transform: translateX(-50%) translateY(0); }
      100% { opacity: 0; transform: translateX(-50%) translateY(-8px); }
    }

    /* Tick counter flash */
    #tick-flash.sw-flash {
      animation: sw-tick-flash 0.25s ease-out forwards;
    }
    @keyframes sw-tick-flash {
      0%   { opacity: 0.6; }
      100% { opacity: 0; }
    }

    /* Progress bar gradient */
    .sw-progress-bar {
      background: linear-gradient(90deg, #4262ff, #7c3aed);
    }

    /* Track dot glow */
    .sw-track-dot {
      transition: transform 0.12s cubic-bezier(.22,1,.36,1);
      box-shadow: 0 0 6px 1px rgba(66,98,255,0.5);
    }

    /* Test zone border glow */
    .sw-test-zone {
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .sw-test-zone:hover {
      border-color: rgba(66,98,255,0.5);
      box-shadow: inset 0 0 40px rgba(66,98,255,0.04);
    }
    .sw-test-zone.sw-zone-active {
      border-color: rgba(66,98,255,0.65) !important;
      box-shadow: inset 0 0 60px rgba(66,98,255,0.07);
    }

    /* Zone mini readout number pop */
    .sw-zone-delta-pop {
      animation: sw-num-pop 0.18s cubic-bezier(.22,1.5,.36,1);
    }
    @keyframes sw-num-pop {
      0%   { transform: scale(1); }
      50%  { transform: scale(1.3); }
      100% { transform: scale(1); }
    }
  </style>

</Layout>
