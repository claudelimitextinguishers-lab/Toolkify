      }

      // ---- Milestone toast ----
      function showMilestoneToast(text) {
        milestoneToast.textContent = text;
        milestoneToast.classList.remove("sw-toast-show");
        void milestoneToast.offsetWidth; // reflow
        milestoneToast.classList.add("sw-toast-show");
        setTimeout(() => milestoneToast.classList.remove("sw-toast-show"), 2400);
      }

      // ---- Zone active/idle ----
      function setZoneActive(active) {
        if (active) {
          testZone.classList.add("sw-zone-active");
          zoneActiveLabel.textContent = "Active";
          zoneActiveLabel.classList.remove("text-slate/60");
          zoneActiveLabel.classList.add("text-green-500");
        } else {
          testZone.classList.remove("sw-zone-active");
          zoneActiveLabel.textContent = "Idle";
          zoneActiveLabel.classList.add("text-slate/60");
          zoneActiveLabel.classList.remove("text-green-500");
        }
      }

      // ---- Tick flash ----
      function flashTick() {
        tickFlash.classList.remove("sw-flash");
        void tickFlash.offsetWidth;
        tickFlash.classList.add("sw-flash");
      }

      // ---- Radial Gauge ----
      function drawGauge(velocity) {
        if (!gaugeCanvas) return;
        const ctx = gaugeCanvas.getContext("2d");
        const w = gaugeCanvas.width;
        const h = gaugeCanvas.height;
        ctx.clearRect(0, 0, w, h);

        const cx = w / 2;
        const cy = h - 4;
        const r = h - 8;
        const startAngle = Math.PI;
        const endAngle = 2 * Math.PI;

        // Track arc
        ctx.beginPath();
        ctx.arc(cx, cy, r, startAngle, endAngle);
        ctx.strokeStyle = "rgba(107,111,126,0.18)";
        ctx.lineWidth = 5;
        ctx.lineCap = "round";
        ctx.stroke();

        // Value arc
        const maxV = Math.max(maxVelocityObserved, 500);
        const fraction = Math.min(1, velocity / maxV);
        const valueAngle = startAngle + fraction * Math.PI;

        const grad = ctx.createLinearGradient(0, 0, w, 0);
        grad.addColorStop(0, "#4262ff");
        grad.addColorStop(0.6, "#7c3aed");
        grad.addColorStop(1, "#ff4466");

        ctx.beginPath();
        ctx.arc(cx, cy, r, startAngle, valueAngle);
        ctx.strokeStyle = grad;
        ctx.lineWidth = 5;
        ctx.lineCap = "round";
        ctx.stroke();

        // Needle dot
        const nx = cx + Math.cos(valueAngle) * r;
        const ny = cy + Math.sin(valueAngle) * r;
        ctx.beginPath();
        ctx.arc(nx, ny, 3.5, 0, Math.PI * 2);
        ctx.fillStyle = "#fff";
        ctx.fill();
        ctx.strokeStyle = "#4262ff";
        ctx.lineWidth = 1.5;
        ctx.stroke();

        if (gaugeLabel) gaugeLabel.textContent = velocity + " px/s";
      }

      // ---- Zone background animated grid ----
      function initZoneBgCanvas() {
        if (!zoneBgCanvas) return;
        const ctx = zoneBgCanvas.getContext("2d");
        let phase = 0;

        function draw() {
          const w = zoneBgCanvas.offsetWidth;
          const h = zoneBgCanvas.offsetHeight;
          if (zoneBgCanvas.width !== w || zoneBgCanvas.height !== h) {
            zoneBgCanvas.width = w;
            zoneBgCanvas.height = h;
          }
          ctx.clearRect(0, 0, w, h);

          // Animated soft grid
          const spacing = 36;
          ctx.strokeStyle = "rgba(66,98,255,0.12)";
          ctx.lineWidth = 0.8;

          for (let x = (phase % spacing); x < w; x += spacing) {
            ctx.beginPath();
            ctx.moveTo(x, 0);
            ctx.lineTo(x, h);
            ctx.stroke();
          }
          for (let y = (phase % spacing); y < h; y += spacing) {
            ctx.beginPath();
            ctx.moveTo(0, y);
            ctx.lineTo(w, y);
            ctx.stroke();
          }

          // Subtle concentric circles at center
          const cx = w / 2, cy = h / 2;
          for (let r = 40; r < Math.max(w, h); r += 60) {
            const pulse = Math.sin(phase * 0.04 + r * 0.02) * 0.04 + 0.08;
            ctx.beginPath();
            ctx.arc(cx, cy, r, 0, Math.PI * 2);
            ctx.strokeStyle = `rgba(66,98,255,${pulse})`;
            ctx.lineWidth = 0.7;
            ctx.stroke();
          }

          phase += 0.4;
          if (isDrawActive) {
            requestAnimationFrame(draw);
          }
        }
        draw();
      }

      // Local storage restore
      function restoreSettings() {
