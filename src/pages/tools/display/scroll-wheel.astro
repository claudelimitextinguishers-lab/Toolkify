            stressTestToggle.checked = urlStress === "true";
            stressTargetSelect.value = urlTarget || "100";
          } else if (settings) {
            stressTestToggle.checked = settings.stressTestEnabled || false;
            stressTargetSelect.value = settings.stressTarget || "100";
