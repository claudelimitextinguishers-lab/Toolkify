      "description": "Free online scroll wheel test to diagnose your mouse scroll wheel in real time. Check scroll speed, CPS, tick accuracy, infinite scroll behavior, direction, and detect a broken or jumpy scroll wheel â€” 100% client-side, no download needed.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires Mouse or Trackpad input.",
      "featureList": [
        "Scroll wheel test â€” real-time tick counter and CPS measurement",
        "Mouse scroll wheel test online â€” works in any browser, no install",
        "Scroll wheel test speed â€” instantaneous and peak velocity in px/s",
        "Infinite scroll wheel test â€” unlimited duration stress test mode",
        "Broken scroll wheel test â€” detects erratic, skipping, or reversing ticks",
        "Mouse scroll wheel jumps detector â€” flags abnormal delta spikes",
        "Statistical notched vs smooth wheel classification",
        "Live canvas delta waveform timeline visualization",
        "Raw event log export in CSV and JSON formats",
        "100% private, client-side execution â€” zero data sent to servers"
      ],
      "keywords": "scroll wheel test, mouse scroll wheel test, scroll wheel test online, scroll wheel test speed, cps scroll wheel test, infinite scroll wheel test, broken scroll wheel test, mouse scroll wheel jumps, why is my scroll wheel not working",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "1240"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
