      // Share button event
      headerShareBtn?.addEventListener("click", () => {
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set("stress", String(stressTestToggle.checked));
        url.searchParams.set("target", stressTargetSelect.value);

        const shareData = {
