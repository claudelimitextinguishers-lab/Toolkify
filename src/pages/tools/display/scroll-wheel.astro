---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Scroll Wheel Test";
const category = "display";
const tier = "Display & Input Diagnostics";
const description = "Verify scroll wheel ticks, direction velocities, and scroll track sensitivity.";

// On-page SEO metadata
const pageTitle = "Scroll Wheel Test - Check Mouse Scroll Ticks & Velocity";
const pageDescription = "Free client-side tool to test mouse scroll wheel behavior, tick accuracy, horizontal scrolling, and velocity. Analyze notched vs smooth inputs with a live graph.";
const canonicalUrl = "https://boardtools.app/tools/display/scroll-wheel";
const ogImage = "/og/scroll-wheel.png";
const keywords = "scroll wheel test, mouse test, scroll speed test, scroll ticks counter, trackpad test, horizontal scroll test, notched wheel test, smooth scroll test, mouse wheel diagnostics";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Scroll Wheel Test",
      "alternateName": "Mouse Scroll Wheel Diagnostics",
      "url": "https://boardtools.app/tools/display/scroll-wheel",
      "description": "Diagnose mouse scroll wheel performance, ticks, directions, and velocity. Visualizes delta values on a live canvas timeline and flags notched vs smooth inputs.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires Mouse/Trackpad input.",
      "featureList": [
        "Real-time vertical and horizontal scroll wheel capture",
        "Statistical classification of notched vs smooth inputs",
        "Live scrolling canvas graph representing scroll delta magnitudes",
        "Instantaneous and peak velocity tracker",
        "Stress test mode with interactive targets and progress feedback",
        "Raw event log visualization with CSV and JSON exports",
        "100% private client-side execution"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://boardtools.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Tools",
          "item": "https://boardtools.app/tools"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Display",
          "item": "https://boardtools.app/tools/display"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Scroll Wheel Test",
          "item": "https://boardtools.app/tools/display/scroll-wheel"
        }
      ]
    }
  </script>

  <section
    class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2">
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How scroll wheel test works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Friendly warning for Touch-Only devices -->
    <div
      id="touch-warning-banner"
      class="hidden p-3 rounded-lg border border-brand-yellow-deep/50 bg-surface-yellow text-xs text-yellow-dark leading-relaxed flex items-center justify-between animate-fade-in print:hidden"
    >
      <div class="flex items-center gap-2">
        <span>⚠️</span>
        <span>
          <strong>Touch-Only Device Detected:</strong> This tool is designed to diagnose scroll wheels, trackpads, and mouse scroll inputs. Connect a mouse/trackpad or tilt-wheel device to begin.
        </span>
      </div>
      <button
        type="button"
        id="dismiss-warning-btn"
        class="text-xs font-bold px-2 py-0.5 rounded-full hover:bg-yellow-light/50 border border-transparent hover:border-yellow-dark/30 transition-all cursor-pointer"
      >
        Dismiss
      </button>
    </div>

    <!-- Workspace Container -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-stretch relative">
      <!-- Controls & Live Statistics (4 cols on lg) -->
      <div class="lg:col-span-4 flex flex-col gap-4">
        <div class="card-base p-4 sm:p-5 flex flex-col gap-4 h-full justify-between">
          <div class="flex flex-col gap-4">
            <h2 class="font-display font-semibold text-sm text-primary flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-brand-blue animate-pulse"></span>
              Live Diagnostics
            </h2>

            <!-- Stats grid -->
            <div class="grid grid-cols-2 gap-3">
              <!-- Counter Card -->
              <div class="sw-stat-card p-3 bg-surface border border-hairline rounded-xl flex flex-col gap-1 items-center text-center relative overflow-hidden">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Ticks Captured</span>
                <span id="tick-counter" class="text-3xl font-display font-medium text-primary sw-tick-num">0</span>
                <span id="tick-trend" class="text-[9px] text-stone">Total ticks</span>
                <div id="tick-flash" class="absolute inset-0 bg-brand-blue/10 opacity-0 rounded-xl pointer-events-none"></div>
              </div>

              <!-- Input Type Card -->
              <div class="sw-stat-card p-3 bg-surface border border-hairline rounded-xl flex flex-col gap-1 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Classification</span>
                <span id="device-classification" class="text-xs font-bold text-brand-blue truncate max-w-full">Waiting...</span>
                <span class="text-[9px] text-stone">Best-effort estimation</span>
              </div>

              <!-- Velocity Card -->
              <div class="sw-stat-card p-3 bg-surface border border-hairline rounded-xl flex flex-col gap-1 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Scroll Velocity</span>
                <span id="scroll-velocity" class="text-base font-bold text-primary">0 px/s</span>
                <span id="max-velocity" class="text-[9px] text-stone">Peak: 0 px/s</span>
              </div>

              <!-- Direction/Mode Card -->
              <div class="sw-stat-card p-3 bg-surface border border-hairline rounded-xl flex flex-col gap-1 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Active Mode</span>
                <span id="scroll-mode" class="text-xs font-bold text-primary">Waiting...</span>
                <span id="raw-mode-text" class="text-[9px] text-stone">deltaMode</span>
              </div>
            </div>

            <!-- Direction Indicator Block -->
            <div class="p-3 bg-surface border border-hairline rounded-xl flex flex-col gap-2">
              <span class="text-[9px] font-semibold text-slate uppercase tracking-wider text-center block">Direction Vector</span>
              <div class="flex items-center justify-around gap-1">
                <div id="dir-left" class="sw-dir-arrow flex flex-col items-center opacity-30 transition-all duration-200">
                  <span class="text-2xl sw-arrow-glyph">←</span>
                  <span class="text-[8px] font-bold tracking-widest">LEFT</span>
                </div>
                <div class="flex flex-col gap-2 items-center">
                  <div id="dir-up" class="sw-dir-arrow flex flex-col items-center opacity-30 transition-all duration-200">
                    <span class="text-2xl sw-arrow-glyph">↑</span>
                    <span class="text-[8px] font-bold tracking-widest">UP</span>
                  </div>
                  <div id="dir-down" class="sw-dir-arrow flex flex-col items-center opacity-30 transition-all duration-200">
                    <span class="text-2xl sw-arrow-glyph">↓</span>
                    <span class="text-[8px] font-bold tracking-widest">DOWN</span>
                  </div>
                </div>
                <div id="dir-right" class="sw-dir-arrow flex flex-col items-center opacity-30 transition-all duration-200">
                  <span class="text-2xl sw-arrow-glyph">→</span>
                  <span class="text-[8px] font-bold tracking-widest">RIGHT</span>
                </div>
              </div>
            </div>

            <!-- Radial Velocity Gauge -->
            <div class="p-3 bg-surface border border-hairline rounded-xl flex flex-col gap-2 items-center">
              <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Velocity Gauge</span>
              <div class="relative w-28 h-14 flex items-end justify-center">
                <canvas id="gauge-canvas" width="112" height="56" class="absolute inset-0"></canvas>
                <span id="gauge-label" class="relative z-10 text-[10px] font-bold text-primary pb-0.5">0 px/s</span>
              </div>
            </div>

            <!-- Gamified Stress Test Mode -->
            <div class="p-3 bg-surface border border-hairline rounded-xl flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <span class="text-[10px] font-semibold text-slate uppercase tracking-wider">Stress Test Mode</span>
                <div class="flex items-center gap-1">
                  <input type="checkbox" id="stress-test-toggle" class="cursor-pointer h-3 w-3 rounded text-brand-blue" />
                  <label for="stress-test-toggle" class="text-[9px] font-semibold text-slate cursor-pointer">Enable</label>
                </div>
              </div>
              <div id="stress-test-controls" class="hidden flex flex-col gap-2 mt-1">
                <div class="flex justify-between items-center text-[10px]">
                  <label for="stress-target" class="text-slate">Target Ticks:</label>
                  <select id="stress-target" class="text-[10px] py-0.5 px-2 bg-canvas border border-hairline rounded">
                    <option value="50">50 Ticks</option>
                    <option value="100" selected>100 Ticks</option>
                    <option value="250">250 Ticks</option>
                    <option value="500">500 Ticks</option>
                  </select>
                </div>
                <div class="relative w-full h-2 bg-hairline rounded-full overflow-hidden mt-1">
                  <div id="stress-progress" class="absolute top-0 left-0 h-full sw-progress-bar rounded-full transition-all duration-200" style="width: 0%"></div>
                </div>
                <div class="flex justify-between items-center text-[9px] font-semibold">
                  <span id="stress-pct">0% Complete</span>
                  <span id="stress-status" class="text-stone">Ready</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Session Statistics Summary -->
          <div class="border-t border-hairline-soft pt-3 mt-1 flex flex-col gap-2">
            <h3 class="text-[10px] font-bold text-slate uppercase tracking-wider">Session Stats</h3>
            <div class="flex flex-col gap-1.5 text-xs">
              <div class="flex justify-between">
                <span class="text-slate">Direction Changes:</span>
                <span id="stat-dir-changes" class="font-bold text-primary">0</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate">Max Event Delta:</span>
                <span id="stat-max-delta" class="font-bold text-primary">0</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate">Avg. Tick Velocity:</span>
                <span id="stat-avg-velocity" class="font-bold text-primary">0 px/s</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate">Momentum Score:</span>
                <span id="stat-momentum" class="font-bold text-primary">—</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Test Area & Canvas Timeline (8 cols on lg) -->
      <div class="lg:col-span-8 flex flex-col gap-4">
        <!-- Interactive Test Zone Card (tall & immersive) -->
        <div
          id="test-zone"
          class="card-base sw-test-zone flex-1 min-h-[420px] sm:min-h-[520px] lg:min-h-[300px] p-5 flex flex-col items-center justify-center border-2 border-dashed border-hairline-strong bg-canvas select-none relative overflow-hidden cursor-crosshair"
        >
          <!-- Animated radial grid background -->
          <canvas id="zone-bg-canvas" class="absolute inset-0 w-full h-full pointer-events-none opacity-30"></canvas>

          <!-- Glow cursor follower -->
          <div id="sw-cursor-glow" class="absolute pointer-events-none w-24 h-24 rounded-full sw-cursor-glow-el opacity-0 transition-opacity duration-300" style="transform: translate(-50%, -50%) scale(1); left: 50%; top: 50%;"></div>

          <!-- Ripple container -->
          <div id="sw-ripple-container" class="absolute inset-0 pointer-events-none overflow-hidden"></div>

          <!-- Particle container -->
          <div id="sw-particle-container" class="absolute inset-0 pointer-events-none overflow-hidden"></div>

          <!-- Milestone toast -->
          <div id="sw-milestone-toast" class="absolute top-4 left-1/2 -translate-x-1/2 px-4 py-2 bg-brand-blue text-white text-xs font-bold rounded-full shadow-lg opacity-0 pointer-events-none sw-milestone-toast z-10"></div>

          <!-- Center content -->
          <div class="pointer-events-none flex flex-col items-center text-center gap-4 relative z-5">
            <!-- Animated mouse icon -->
            <div class="relative w-14 h-20 border-2 border-slate/50 rounded-2xl flex items-start justify-center pt-2 bg-surface/80 backdrop-blur-sm shadow-lg sw-mouse-icon">
              <div id="wheel-visual-indicator" class="w-2 h-5 bg-brand-blue rounded-full sw-wheel-indicator" style="transform: translateY(0px)"></div>
              <!-- Side buttons -->
              <div class="absolute left-0 top-3 bottom-5 w-px bg-slate/20"></div>
              <div class="absolute right-0 top-3 bottom-5 w-px bg-slate/20"></div>
            </div>

            <div class="flex flex-col gap-2">
              <h3 class="font-display font-semibold text-base sm:text-lg text-primary">Scroll Wheel Test Zone</h3>
              <p class="text-xs text-slate max-w-xs leading-relaxed">
                Position your pointer here and scroll up, down, or horizontally using your mouse wheel or trackpad.
              </p>
              <!-- Live mini readout inside zone -->
              <div class="flex items-center justify-center gap-4 mt-1">
                <div class="flex flex-col items-center">
                  <span class="text-[9px] text-slate uppercase tracking-widest">ΔY</span>
                  <span id="zone-dy" class="text-sm font-mono font-bold text-brand-blue">0</span>
                </div>
                <div class="w-px h-6 bg-hairline"></div>
                <div class="flex flex-col items-center">
                  <span class="text-[9px] text-slate uppercase tracking-widest">ΔX</span>
                  <span id="zone-dx" class="text-sm font-mono font-bold text-brand-coral">0</span>
                </div>
                <div class="w-px h-6 bg-hairline"></div>
                <div class="flex flex-col items-center">
                  <span class="text-[9px] text-slate uppercase tracking-widest">ticks</span>
                  <span id="zone-ticks" class="text-sm font-mono font-bold text-primary">0</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Vertical scroll track (right) -->
          <div class="absolute right-4 top-4 bottom-16 w-2.5 border border-hairline rounded-full overflow-hidden bg-surface/60 backdrop-blur-sm">
            <div id="vertical-bounded-indicator" class="w-full h-3 bg-brand-blue rounded-full sw-track-dot" style="transform: translateY(0px)"></div>
          </div>

          <!-- Horizontal scroll track (bottom) -->
          <div class="absolute bottom-4 left-4 right-16 h-2.5 border border-hairline rounded-full overflow-hidden bg-surface/60 backdrop-blur-sm">
            <div id="horizontal-bounded-indicator" class="h-full w-3 bg-brand-coral rounded-full sw-track-dot" style="transform: translateX(0px)"></div>
          </div>

          <!-- Corner badge: active indicator -->
          <div class="absolute top-3 left-3 flex items-center gap-1.5">
            <span id="zone-active-dot" class="w-2 h-2 rounded-full bg-slate/40 sw-active-dot"></span>
            <span id="zone-active-label" class="text-[9px] font-semibold text-slate/60 uppercase tracking-wider">Idle</span>
          </div>
        </div>

        <!-- Scrolling canvas graph container -->
        <div class="card-base p-4 sm:p-5 flex flex-col gap-2" style="min-height: 220px;">
          <div class="flex justify-between items-center">
            <h3 class="font-display font-semibold text-xs text-primary flex items-center gap-1.5">
              <span>Timeline: Delta Waveform</span>
              <span class="flex items-center gap-1.5 text-[9px] font-medium text-stone ml-2">
                <span class="w-2 h-2 bg-brand-blue rounded-full inline-block"></span> Vertical (Y)
                <span class="w-2 h-2 bg-brand-coral rounded-full inline-block"></span> Horizontal (X)
              </span>
            </h3>
            <button
              type="button"
              id="clear-timeline-btn"
              class="text-[10px] font-semibold px-2 py-0.5 bg-surface hover:bg-canvas border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer"
            >
              Clear
            </button>
          </div>
          <div class="flex-1 bg-surface border border-hairline rounded-lg overflow-hidden relative" style="min-height: 160px;">
            <canvas id="timeline-canvas" class="w-full h-full block" style="min-height: 160px;"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Raw log panel & export functions -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 print:hidden">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-hairline-soft pb-3">
        <h3 class="font-display font-semibold text-xs sm:text-sm text-primary flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-slate"></span>
          Raw Event Log (Last 30 events)
        </h3>
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="export-csv-btn"
            class="inline-flex items-center gap-1 text-[10px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
          >
            Export CSV
          </button>
          <button
            type="button"
            id="export-json-btn"
            class="inline-flex items-center gap-1 text-[10px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
          >
            Export JSON
          </button>
          <button
            type="button"
            id="clear-log-btn"
            class="inline-flex items-center gap-1 text-[10px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
          >
            Clear Log
          </button>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-xs">
          <thead>
            <tr class="border-b border-hairline text-slate font-semibold">
              <th class="py-2 px-3">Timestamp</th>
              <th class="py-2 px-3 text-right">deltaX</th>
              <th class="py-2 px-3 text-right">deltaY</th>
              <th class="py-2 px-3 text-right">deltaZ</th>
              <th class="py-2 px-3">deltaMode</th>
              <th class="py-2 px-3 text-right">Normalized (X, Y)</th>
              <th class="py-2 px-3">Classification</th>
            </tr>
          </thead>
          <tbody id="raw-log-tbody">
            <tr>
              <td colspan="7" class="py-4 px-3 text-center text-stone italic">No scroll events captured yet. Scroll in the test zone to trigger logs.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Security & Privacy Guard Tag -->
    <div class="flex items-center justify-between text-[10px] text-slate px-1 print:hidden">
      <span class="flex items-center gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3 h-3 text-success-accent"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
          ></path>
        </svg>
        100% Client-Side Processing, 0KB Sent to Servers
      </span>
      <span>v2.0.0</span>
    </div>
  </section>

  <!-- Educational Article -->
  <section
    class="max-w-[760px] w-full mx-auto px-4 pb-20 flex flex-col gap-8 text-slate print:hidden"
    aria-labelledby="about-tool-heading"
  >
    <article class="flex flex-col gap-4">
      <h2
        id="about-tool-heading"
        class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight"
      >
        Mouse Scroll Wheel Diagnostics & Calibration
      </h2>
      <p class="text-sm leading-relaxed">
        Our <strong>Scroll Wheel Test</strong> provides a comprehensive diagnostics toolbox for analyzing mouse scroll wheels, touchpad scrolls, and tilt-wheels. Like all tools on BoardTools, this analyzer runs entirely client-side, ensuring complete data security and instant responsiveness.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Understanding deltaMode and Normalized Output
      </h3>
      <p class="text-sm leading-relaxed">
        Web browsers report scroll wheel inputs through <code>wheel</code> events. Crucially, browsers report scroll magnitudes in different units specified by <code>deltaMode</code>. Pixel mode (mode 0) gives raw physical coordinates; Line mode (mode 1) is typical of Firefox and Windows default system configurations; Page mode (mode 2) is used when a single wheel notch scrolls an entire document screen. This test normalizes these inputs into consistent pixel equivalents, allowing users to accurately compare performance across diverse systems.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Diagnosing Notched Wheels vs. Smooth Wheels/Trackpads
      </h3>
      <p class="text-sm leading-relaxed">
        Traditional computer mice use a physical rotary encoder that registers discrete steps (or notches), resulting in a sudden jump of delta values (e.g., ±120 pixels or ±3 lines). In contrast, modern trackpads and free-spin scroll wheels (such as Logitech's MagSpeed) send continuous, highly granular, and varying delta inputs. Our heuristic engine analyzes the mathematical distribution of your scroll steps in real-time, detecting erratic ticks that might point to a hardware defect or a dusty rotary sensor.
      </p>
    </article>
  </section>

