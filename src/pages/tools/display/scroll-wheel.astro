          const angle = (Math.PI * 2 * i) / count + Math.random() * 0.5;
          const dist = 30 + Math.random() * 40;
          const tx = Math.cos(angle) * dist;
          const ty = Math.sin(angle) * dist;
          const size = 3 + Math.random() * 4;
          const dur = 0.45 + Math.random() * 0.3;
          p.style.cssText = `
            left: ${x}px; top: ${y}px;
