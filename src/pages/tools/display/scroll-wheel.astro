      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Scroll Wheel Test",
      "alternateName": ["Mouse Scroll Wheel Test Online", "Scroll Wheel Test Speed Tool", "CPS Scroll Wheel Test", "Broken Scroll Wheel Test"],
