---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Scroll Wheel Test";
const category = "display";
const tier = "Display & Input Diagnostics";
const description = "Verify scroll wheel ticks, direction velocities, and scroll track sensitivity.";

// On-page SEO metadata
const pageTitle = "Scroll Wheel Test - Free Online Mouse Scroll Wheel Test";
const pageDescription = "Free online scroll wheel test to check your mouse scroll wheel in seconds. Test scroll speed, CPS, infinite scroll, direction, tick accuracy, and diagnose broken or jumpy scroll wheels instantly â€” no download needed.";
const canonicalUrl = "https://toolkify.com/tools/display/scroll-wheel";
const ogImage = "/og/scroll-wheel.png";
const keywords = "scroll wheel test, mouse scroll wheel test, scroll wheel test online, mouse scroll wheel test online, scroll wheel test speed, cps scroll wheel test, infinite scroll wheel test, scroll wheel test world record, broken scroll wheel test, mouse scroll wheel jumps, why is my scroll wheel not working, mouse scroll wheel, scroll wheel diagnostics, scroll speed test, mouse wheel test, mouse scroll test";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
