---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Aspect Ratio Checker";
const category = "display";
const tier = "Display & Input Diagnostics";
const description =
  "Calculate and verify screen aspect ratios, viewport pixel geometries, physical scales, and CSS properties.";

// On-page SEO metadata
const pageTitle =
  "Aspect Ratio Checker - Viewport, Screen & Resolution Calculator";
const seoKeywords =
  "aspect ratio checker, screen ratio calculator, check aspect ratio, viewport dimensions, resolution scaling calculator, screen size ratio, css aspect-ratio, display diagnostic, ppi calculator, pixels per inch, monitor resolution";
const canonicalUrl = "https://boardtools.app/tools/display/aspect-ratio";
const ogImage = "/og/aspect-ratio.png";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={seoKeywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Aspect Ratio Checker",
      "alternateName": "Resolution Ratio Tool",
      "url": "https://boardtools.app/tools/display/aspect-ratio",
      "description": "Compute screen aspect ratios, live browser viewport measurements, device pixel scaling, PPI calculations, and ratio comparisons in real-time.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript.",
      "featureList": [
        "Live viewport and screen pixel aspect ratio tracking",
        "Exact GCD ratio reduction algorithm",
        "Nearest common video display ratio matching",
        "Live scaling aspect ratio visual shape previewer",
        "Three-way interactive dimension constraint solver",
        "Pixel-perfect image and video scaling grid",
        "Custom user-named resolution preset saving",
        "Side-by-side ratio comparison mode",
        "PPI (pixels per inch) density calculator",
        "Use-case reference panel with popular platforms",
        "One-click orientation flip (portrait/landscape)",
        "Ratio history with last 10 calculations"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://boardtools.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Tools",
          "item": "https://boardtools.app/tools"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Display",
          "item": "https://boardtools.app/tools/display"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Aspect Ratio Checker",
          "item": "https://boardtools.app/tools/display/aspect-ratio"
        }
      ]
    }
  </script>

  <section
    class="max-w-[1280px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-4 animate-fade-in-up pb-16 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0"
          >
            {tier}
          </span>
        </div>

        <div
          class="flex items-center gap-1.5 sm:gap-2 flex-wrap justify-start sm:justify-end"
        >
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How aspect ratio checker works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>

          <!-- Keyboard shortcuts button -->
          <button
            type="button"
            id="shortcuts-btn"
            class="hidden sm:inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="View keyboard shortcuts"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <rect
                x="2"
                y="4"
                width="20"
                height="16"
                rx="2"
                stroke="currentColor"
                stroke-width="2"
                fill="none"></rect>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M6 12h.01M10 12h.01M14 12h.01M18 12h.01M8 16h8"
              ></path>
            </svg>
            <span>Shortcuts</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Top-level Mode Tabs -->
    <div
      class="flex rounded-full bg-surface p-1 border border-hairline w-full max-w-lg"
    >
      <button
        type="button"
        id="tab-live-btn"
        class="flex-1 text-center text-xs py-2 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas shadow-subtle"
      >
        <span class="hidden sm:inline">Live Viewport</span>
        <span class="sm:hidden">Live</span>
      </button>
      <button
        type="button"
        id="tab-custom-btn"
        class="flex-1 text-center text-xs py-2 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-primary"
      >
        <span class="hidden sm:inline">Custom Calculator</span>
        <span class="sm:hidden">Custom</span>
      </button>
      <button
        type="button"
        id="tab-compare-btn"
        class="flex-1 text-center text-xs py-2 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-primary"
      >
        <span class="hidden sm:inline">Compare Ratios</span>
        <span class="sm:hidden">Compare</span>
      </button>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 sm:gap-6 items-start">
      <!-- Left Column: Visual previewer + diagnostics -->
      <div class="lg:col-span-7 flex flex-col gap-4 sm:gap-6">
        <!-- ============================================================ -->
        <!-- SINGLE RATIO PREVIEW PANEL (Live / Custom modes)             -->
        <!-- ============================================================ -->
        <div id="single-preview-panel" class="flex flex-col gap-4">
          <!-- Interactive Visual Shape Previewer -->
          <div
            class="card-base flex flex-col gap-0 items-center justify-between min-h-[300px] sm:min-h-[380px] relative overflow-hidden bg-surface-soft/60 p-0"
          >
            <div
              class="w-full flex items-center justify-between px-3 pt-3 pb-2 z-10"
            >
              <div class="flex items-center gap-1.5">
                <span
                  class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"
                  id="live-indicator"></span>
                <span
                  class="text-[10px] font-bold text-slate uppercase tracking-wider"
                  id="preview-mode-label">Live Viewport Preview</span
                >
              </div>
              <div
                class="flex items-center gap-1 sm:gap-2 flex-wrap justify-end"
              >
                <!-- Grid lines toggle -->
                <button
                  id="toggle-grid-btn"
                  type="button"
                  title="Toggle grid lines"
                  class="px-2 py-0.5 text-[9px] font-bold rounded-full text-slate hover:text-primary border border-hairline hover:border-primary transition-all flex items-center gap-1"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3 h-3"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                      d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"
                    ></path></svg
                  >
                  Grid
                </button>
                <!-- Orientation flip -->
                <button
                  id="flip-orientation-btn"
                  type="button"
                  title="Flip portrait / landscape (F)"
                  class="px-2 py-0.5 text-[9px] font-bold rounded-full text-slate hover:text-primary border border-hairline hover:border-primary transition-all flex items-center gap-1"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3 h-3"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"
                    ></path></svg
                  >
                  Flip
                </button>
                <!-- Simplified vs Decimal Toggle -->
                <div
                  class="bg-canvas border border-hairline rounded-full p-0.5 flex gap-1 shadow-subtle shrink-0"
                >
                  <button
                    id="toggle-ratio-simp"
                    class="px-2 py-0.5 text-[9px] font-bold rounded-full bg-primary text-canvas transition-all"
                    type="button"
                  >
                    <span class="hidden sm:inline">Simplified</span>
                    <span class="sm:hidden">Ratio</span>
                  </button>
                  <button
                    id="toggle-ratio-dec"
                    class="px-2 py-0.5 text-[9px] font-bold rounded-full text-slate hover:text-primary transition-all"
                    type="button"
                  >
                    <span class="hidden sm:inline">Decimal</span>
                    <span class="sm:hidden">Dec</span>
                  </button>
                </div>
              </div>
            </div>

            <!-- Scaled Box -->
            <div
              class="w-full flex items-center justify-center px-6 pb-4 pt-2 relative"
              id="preview-area"
              style="min-height: 180px; height: 220px;"
            >
              <div
                id="visual-ratio-box"
                class="border-2 border-primary bg-brand-yellow/15 rounded-xl shadow-lg flex flex-col items-center justify-center gap-2 p-4 transition-all duration-300 relative overflow-hidden"
                style="width: 200px; height: 120px;"
              >
                <!-- Grid overlay (hidden by default) -->
                <div
                  id="grid-overlay"
                  class="absolute inset-0 opacity-20 pointer-events-none hidden"
                  style="background-image: repeating-linear-gradient(0deg,#1c1c1e 0,#1c1c1e 1px,transparent 1px,transparent 33.33%),repeating-linear-gradient(90deg,#1c1c1e 0,#1c1c1e 1px,transparent 1px,transparent 33.33%);"
                >
                </div>
                <!-- Rule of thirds overlay (3x3 grid) -->

                <span
                  id="box-ratio-label"
                  class="font-display font-medium text-xl sm:text-2xl text-primary drop-shadow-sm select-none z-10"
                  >16:9</span
                >
                <span
                  id="box-pixels-label"
                  class="text-[11px] text-slate font-mono select-none z-10"
                  >1920 × 1080</span
                >

                <!-- CSS aspect-ratio previewer watermark -->
                <span
                  id="box-css-label"
                  class="text-[9px] text-stone font-mono bg-canvas px-1.5 py-0.5 rounded border border-hairline select-none z-10"
                  >aspect-ratio: 16 / 9</span
                >
              </div>
            </div>

            <!-- Proportion bar — visual width:height ratio strip -->
            <div class="w-full px-3 pb-3">
              <div class="flex items-center gap-1.5 mb-1">
                <span
                  class="text-[9px] font-bold text-stone uppercase tracking-wider"
                  >Proportion</span
                >
              </div>
              <div
                class="w-full h-4 rounded-full bg-surface border border-hairline overflow-hidden flex"
              >
                <div
                  id="prop-bar-w"
                  class="h-full bg-primary transition-all duration-300 flex items-center justify-center"
                  style="width:64%"
                >
                  <span
                    id="prop-bar-w-label"
                    class="text-[8px] text-canvas font-bold select-none truncate px-1"
                    >W</span
                  >
                </div>
                <div
                  id="prop-bar-h"
                  class="h-full bg-brand-yellow/80 transition-all duration-300 flex items-center justify-center"
                  style="width:36%"
                >
                  <span
                    id="prop-bar-h-label"
                    class="text-[8px] text-primary font-bold select-none truncate px-1"
                    >H</span
                  >
                </div>
              </div>
            </div>

            <!-- CSS copy overlay snippet -->
            <div
              class="w-full border-t border-hairline-soft bg-canvas/70 px-3 py-2 flex flex-row items-center justify-between gap-3 text-xs"
            >
              <code
                class="font-mono text-slate truncate select-all"
                id="css-snippet-text">aspect-ratio: 16 / 9;</code
              >
              <div class="flex items-center gap-2 shrink-0">
                <button
                  type="button"
                  id="export-btn"
                  class="px-2.5 py-1 text-[11px] font-semibold bg-surface hover:bg-hairline text-slate rounded-full transition-all cursor-pointer shadow-subtle flex items-center gap-1 active:scale-95"
                  title="Export ratio info as JSON"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3.5 h-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                    ></path></svg
                  >
                  <span>Export</span>
                </button>
                <button
                  type="button"
                  id="copy-css-btn"
                  class="px-2.5 py-1 text-[11px] font-semibold bg-primary hover:bg-charcoal text-canvas rounded-full transition-all cursor-pointer shadow-subtle flex items-center gap-1 shrink-0 active:scale-95"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3.5 h-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"
                    ></path>
                  </svg>
                  <span>Copy CSS</span>
                </button>
              </div>
            </div>
          </div>

          <!-- Primary Live Diagnostics Grid -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <div class="card-base p-3 flex flex-col gap-1 justify-center">
              <span
                class="text-[10px] font-bold text-slate uppercase tracking-wider"
                >CSS Viewport</span
              >
              <span
                id="stat-css-viewport"
                class="text-sm font-semibold font-mono text-primary">---</span
              >
              <span class="text-[9px] text-stone">Logical size</span>
            </div>
            <div class="card-base p-3 flex flex-col gap-1 justify-center">
              <span
                class="text-[10px] font-bold text-slate uppercase tracking-wider"
                >Physical Screen</span
              >
              <span
                id="stat-phys-screen"
                class="text-sm font-semibold font-mono text-primary">---</span
              >
              <span class="text-[9px] text-stone">Hardware resolution</span>
            </div>
            <div class="card-base p-3 flex flex-col gap-1 justify-center">
              <span
                class="text-[10px] font-bold text-slate uppercase tracking-wider"
                >Device Pixel Ratio</span
              >
              <span
                id="stat-dpr"
                class="text-sm font-semibold font-mono text-primary">---</span
              >
              <span class="text-[9px] text-stone">Pixel scaling factor</span>
            </div>
            <div class="card-base p-3 flex flex-col gap-1 justify-center">
              <span
                class="text-[10px] font-bold text-slate uppercase tracking-wider"
                >Nearest Standard</span
              >
              <span
                id="stat-nearest-ratio"
                class="text-sm font-semibold text-brand-blue">---</span
              >
              <span class="text-[9px] text-stone">Closest display ratio</span>
            </div>
          </div>

          <!-- Ratio History Strip -->
          <div class="card-base flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <h3
                class="font-display font-semibold text-xs text-primary uppercase tracking-wider flex items-center gap-1.5"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-brand-coral"></span>
                Recent Calculations
              </h3>
              <button
                type="button"
                id="clear-history-btn"
                class="text-[9px] text-stone hover:text-brand-coral transition-colors cursor-pointer font-semibold"
                >Clear</button
              >
            </div>
            <div id="history-list" class="flex flex-wrap gap-1.5 min-h-[28px]">
              <span class="text-[10px] text-stone italic" id="history-empty"
                >No history yet.</span
              >
            </div>
          </div>
        </div>

        <!-- ============================================================ -->
        <!-- COMPARE PANEL (side-by-side visual comparison)               -->
        <!-- ============================================================ -->
        <div id="compare-panel" class="hidden flex-col gap-4">
          <div class="card-base flex flex-col gap-3 p-4">
            <h3
              class="font-display font-semibold text-xs text-primary uppercase tracking-wider flex items-center gap-1.5"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-brand-blue"></span>
              Side-by-Side Comparison
            </h3>
            <p class="text-[10px] text-slate leading-relaxed">
              Enter two ratios to see them visually scaled at the same height
              for an instant size comparison.
            </p>

            <div class="grid grid-cols-2 gap-4">
              <!-- Ratio A -->
              <div class="flex flex-col gap-2">
                <label class="text-[10px] font-bold text-slate uppercase"
                  >Ratio A</label
                >
                <div class="flex gap-2">
                  <input
                    type="number"
                    id="compare-a-w"
                    value="16"
                    min="1"
                    class="w-full bg-canvas text-ink text-xs rounded-md border border-hairline-strong px-2 py-2 h-9 focus:border-brand-blue outline-none transition-all"
                    placeholder="W"
                  />
                  <span class="flex items-center text-stone font-bold text-sm"
                    >:</span
                  >
                  <input
                    type="number"
                    id="compare-a-h"
                    value="9"
                    min="1"
                    class="w-full bg-canvas text-ink text-xs rounded-md border border-hairline-strong px-2 py-2 h-9 focus:border-brand-blue outline-none transition-all"
                    placeholder="H"
                  />
                </div>
              </div>
              <!-- Ratio B -->
              <div class="flex flex-col gap-2">
                <label class="text-[10px] font-bold text-slate uppercase"
                  >Ratio B</label
                >
                <div class="flex gap-2">
                  <input
                    type="number"
                    id="compare-b-w"
                    value="4"
                    min="1"
                    class="w-full bg-canvas text-ink text-xs rounded-md border border-hairline-strong px-2 py-2 h-9 focus:border-brand-blue outline-none transition-all"
                    placeholder="W"
                  />
                  <span class="flex items-center text-stone font-bold text-sm"
                    >:</span
                  >
                  <input
                    type="number"
                    id="compare-b-h"
                    value="3"
                    min="1"
                    class="w-full bg-canvas text-ink text-xs rounded-md border border-hairline-strong px-2 py-2 h-9 focus:border-brand-blue outline-none transition-all"
                    placeholder="H"
                  />
                </div>
              </div>
            </div>

            <!-- Visual comparison boxes -->
            <div
              class="relative bg-surface-soft rounded-xl border border-hairline-soft p-4 flex items-end gap-4 min-h-[200px] overflow-hidden"
            >
              <div class="flex flex-col items-center gap-2 flex-1">
                <div
                  id="compare-box-a"
                  class="border-2 border-primary bg-primary/10 rounded-lg flex items-center justify-center transition-all duration-300"
                  style="width:100%;height:120px;"
                >
                  <span
                    id="compare-label-a"
                    class="font-display font-semibold text-primary text-sm select-none"
                    >16:9</span
                  >
                </div>
                <div class="text-center">
                  <div
                    id="compare-a-info"
                    class="text-[10px] font-bold text-primary"
                  >
                    16:9
                  </div>
                  <div
                    id="compare-a-decimal"
                    class="text-[9px] text-stone font-mono"
                  >
                    ≈ 1.778
                  </div>
                </div>
              </div>
              <div class="flex flex-col items-center gap-2 flex-1">
                <div
                  id="compare-box-b"
                  class="border-2 border-brand-blue bg-brand-blue/10 rounded-lg flex items-center justify-center transition-all duration-300"
                  style="width:100%;height:90px;"
                >
                  <span
