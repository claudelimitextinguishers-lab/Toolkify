          w: 21,
          h: 9,
          color: "#1c1c1e",
          emoji: "🎬",
        },
        {
          label: "DSLR Photo",
          ratio: "3:2",
          w: 3,
          h: 2,
          color: "#4262ff",
          emoji: "📸",
        },
        {
          label: "iPad / Tablet",
          ratio: "4:3",
          w: 4,
          h: 3,
          color: "#0fbcb0",
          emoji: "💻",
        },
        {
          label: "TikTok / Reels",
          ratio: "9:16",
          w: 9,
          h: 16,
          color: "#69C9D0",
          emoji: "🎵",
        },
        {
          label: "LinkedIn Banner",
          ratio: "4:1",
          w: 4,
          h: 1,
          color: "#0077B5",
          emoji: "💼",
        },
        {
          label: "Facebook Landscape",
          ratio: "1.91:1",
          w: 191,
          h: 100,
          color: "#1877F2",
          emoji: "f",
        },
      ];

      // State Management
      let currentMode = "live"; // "live" | "custom" | "compare"
      let displayDecimal = false;
      let gridVisible = false;
      let cachedLiveWidth = window.innerWidth;
      let cachedLiveHeight = window.innerHeight;
      let customWidth = 1920;
      let customHeight = 1080;
      let historyItems = [];

      // -----------------------------------------------------------------------
      // DOM Elements
      // -----------------------------------------------------------------------
      const resetBtn = document.getElementById("reset-btn");
      const headerShareBtn = document.getElementById("share-btn");
      const howItWorksBtn = document.getElementById("how-it-works-btn");
      const howItWorksModal = document.getElementById("how-it-works-modal");
      const closeModalBtn = document.getElementById("close-modal-btn");
      const modalOkBtn = document.getElementById("modal-ok-btn");
      const shortcutsBtn = document.getElementById("shortcuts-btn");
      const shortcutsModal = document.getElementById("shortcuts-modal");
      const closeShortcutsBtn = document.getElementById("close-shortcuts-btn");

      // Tabs
      const tabLiveBtn = document.getElementById("tab-live-btn");
      const tabCustomBtn = document.getElementById("tab-custom-btn");
      const tabCompareBtn = document.getElementById("tab-compare-btn");
      const liveIndicator = document.getElementById("live-indicator");
      const previewModeLabel = document.getElementById("preview-mode-label");

      // Visual box elements
      const visualRatioBox = document.getElementById("visual-ratio-box");
      const boxRatioLabel = document.getElementById("box-ratio-label");
      const boxPixelsLabel = document.getElementById("box-pixels-label");
      const boxCssLabel = document.getElementById("box-css-label");
      const cssSnippetText = document.getElementById("css-snippet-text");
      const copyCssBtn = document.getElementById("copy-css-btn");
      const exportBtn = document.getElementById("export-btn");
      const gridOverlay = document.getElementById("grid-overlay");
      const toggleGridBtn = document.getElementById("toggle-grid-btn");
      const propBarW = document.getElementById("prop-bar-w");
      const propBarH = document.getElementById("prop-bar-h");
      const propBarWLabel = document.getElementById("prop-bar-w-label");
      const propBarHLabel = document.getElementById("prop-bar-h-label");

      // Diagnostics Output
      const statCssViewport = document.getElementById("stat-css-viewport");
      const statPhysScreen = document.getElementById("stat-phys-screen");
      const statDpr = document.getElementById("stat-dpr");
      const statNearestRatio = document.getElementById("stat-nearest-ratio");

      // Ratio simplification toggles
      const toggleRatioSimp = document.getElementById("toggle-ratio-simp");
      const toggleRatioDec = document.getElementById("toggle-ratio-dec");

      // Solver
      const solverPanel = document.getElementById("solver-panel");
      const solverStatus = document.getElementById("solver-status");
      const solveSelect = document.getElementById("solve-select");
      const inputWidth = document.getElementById("input-width");
      const inputHeight = document.getElementById("input-height");
      const ratioInputWrapper = document.getElementById("ratio-input-wrapper");
      const inputRatio = document.getElementById("input-ratio");
      const standardRatiosDropdown = document.getElementById(
        "standard-ratios-dropdown",
      );
      const solverInputsGrid = document.getElementById("solver-inputs-grid");

      // Preset Chips
      const presetsContainer = document.getElementById("presets-container");

      // Scaler
      const scaleWidthInput = document.getElementById("scale-width");
      const scaleHeightInput = document.getElementById("scale-height");
      const scaleGeometryResult = document.getElementById(
        "scale-geometry-result",
      );

      // Saved Presets
      const savePresetForm = document.getElementById("save-preset-form");
      const newPresetName = document.getElementById("new-preset-name");
      const savedPresetsList = document.getElementById("saved-presets-list");
      const noSavedPresets = document.getElementById("no-saved-presets");

      // Share Link
      const shareLinkInput = document.getElementById("share-link-input");
      const copyShareBtn = document.getElementById("copy-share-btn");

      // Orientation flip buttons
      const flipOrientationBtn = document.getElementById(
        "flip-orientation-btn",
      );
      const flipOrientationBtn2 = document.getElementById(
        "flip-orientation-btn2",
      );

      // Panels
      const singlePreviewPanel = document.getElementById(
        "single-preview-panel",
      );
      const comparePanel = document.getElementById("compare-panel");

      // Compare inputs
      const compareAW = document.getElementById("compare-a-w");
      const compareAH = document.getElementById("compare-a-h");
      const compareBW = document.getElementById("compare-b-w");
      const compareBH = document.getElementById("compare-b-h");
      const compareBoxA = document.getElementById("compare-box-a");
      const compareBoxB = document.getElementById("compare-box-b");
      const compareLabelA = document.getElementById("compare-label-a");
      const compareLabelB = document.getElementById("compare-label-b");
      const compareAInfo = document.getElementById("compare-a-info");
      const compareADecimal = document.getElementById("compare-a-decimal");
      const compareBInfo = document.getElementById("compare-b-info");
      const compareBDecimal = document.getElementById("compare-b-decimal");
      const compareStatWidth = document.getElementById("compare-stat-width");
      const compareStatRatio = document.getElementById("compare-stat-ratio");
      const compareStatArea = document.getElementById("compare-stat-area");

      // PPI Calculator
      const ppiWidthInput = document.getElementById("ppi-width");
      const ppiHeightInput = document.getElementById("ppi-height");
      const ppiDiagonalInput = document.getElementById("ppi-diagonal");
      const ppiResult = document.getElementById("ppi-result");
      const ppiTier = document.getElementById("ppi-tier");
      const ppiTierDesc = document.getElementById("ppi-tier-desc");

      // History
      const historyList = document.getElementById("history-list");
      const historyEmpty = document.getElementById("history-empty");
      const clearHistBtn = document.getElementById("clear-history-btn");

      // Use-case list
      const useCaseList = document.getElementById("use-case-list");

      // -----------------------------------------------------------------------
      // Math Helpers
      // -----------------------------------------------------------------------
      function getGcd(a, b) {
        a = Math.abs(Math.round(a));
        b = Math.abs(Math.round(b));
        while (b) {
          let t = b;
          b = a % b;
          a = t;
        }
        return a;
      }

      function getSimplifiedRatio(w, h) {
        if (!w || !h) return "0:0";
        const gcd = getGcd(w, h);
        return `${w / gcd}:${h / gcd}`;
      }

      function getNearestStandardRatio(w, h) {
        if (!w || !h) return "Unknown";
        const targetRatio = w / h;
        let closest = STANDARD_RATIOS[0];
        let minDiff = Math.abs(targetRatio - closest.ratio);
        for (let i = 1; i < STANDARD_RATIOS.length; i++) {
          const diff = Math.abs(targetRatio - STANDARD_RATIOS[i].ratio);
          if (diff < minDiff) {
            minDiff = diff;
            closest = STANDARD_RATIOS[i];
          }
        }
        return minDiff < 0.08 ? closest.label : "Custom";
      }

      function parseRatio(str) {
        if (!str) return 1;
        if (str.includes(":")) {
          const [w, h] = str.split(":").map(parseFloat);
          if (w && h) return w / h;
        }
        if (str.includes("/")) {
          const [w, h] = str.split("/").map(parseFloat);
          if (w && h) return w / h;
        }
        const val = parseFloat(str);
        return isNaN(val) ? 1 : val;
      }

      function escapeHtml(str) {
        return str
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      // -----------------------------------------------------------------------
      // Tab / Mode Management
      // -----------------------------------------------------------------------
      function setMode(mode) {
        currentMode = mode;

        // Reset all tabs
        [tabLiveBtn, tabCustomBtn, tabCompareBtn].forEach((btn) => {
          btn.classList.remove("bg-primary", "text-canvas", "shadow-subtle");
          btn.classList.add("text-slate", "hover:text-primary");
        });

        if (mode === "live") {
          tabLiveBtn.classList.add(
            "bg-primary",
            "text-canvas",
            "shadow-subtle",
          );
          tabLiveBtn.classList.remove("text-slate", "hover:text-primary");

          liveIndicator.classList.remove("hidden");
          liveIndicator.classList.add("bg-emerald-500");
          previewModeLabel.textContent = "Live Viewport Preview";
          solverStatus.textContent = "Live Monitoring Active";
          solverStatus.className =
            "text-[10px] text-emerald-500 font-bold uppercase";

          inputWidth.disabled = true;
          inputHeight.disabled = true;
          inputRatio.disabled = true;
          standardRatiosDropdown.disabled = true;
          solveSelect.disabled = true;
          solverPanel.classList.add("opacity-60");

          singlePreviewPanel.classList.remove("hidden");
          singlePreviewPanel.classList.add("flex");
          comparePanel.classList.add("hidden");
          comparePanel.classList.remove("flex");
        } else if (mode === "custom") {
          tabCustomBtn.classList.add(
            "bg-primary",
            "text-canvas",
            "shadow-subtle",
          );
          tabCustomBtn.classList.remove("text-slate", "hover:text-primary");

          liveIndicator.classList.add("hidden");
          previewModeLabel.textContent = "Custom Dimension Preview";
          solverStatus.textContent = "Custom Mode Override";
          solverStatus.className =
            "text-[10px] text-brand-blue font-bold uppercase";

          inputWidth.disabled = false;
          inputHeight.disabled = false;
          inputRatio.disabled = false;
          standardRatiosDropdown.disabled = false;
          solveSelect.disabled = false;
          solverPanel.classList.remove("opacity-60");

          singlePreviewPanel.classList.remove("hidden");
          singlePreviewPanel.classList.add("flex");
          comparePanel.classList.add("hidden");
          comparePanel.classList.remove("flex");
        } else if (mode === "compare") {
          tabCompareBtn.classList.add(
            "bg-primary",
            "text-canvas",
            "shadow-subtle",
          );
          tabCompareBtn.classList.remove("text-slate", "hover:text-primary");

          liveIndicator.classList.add("hidden");
          previewModeLabel.textContent = "Compare Mode";

          singlePreviewPanel.classList.add("hidden");
          singlePreviewPanel.classList.remove("flex");
          comparePanel.classList.remove("hidden");
          comparePanel.classList.add("flex");

          updateCompare();
          return;
        }

        recalculate();
      }

      tabLiveBtn.addEventListener("click", () => setMode("live"));
      tabCustomBtn.addEventListener("click", () => setMode("custom"));
      tabCompareBtn.addEventListener("click", () => setMode("compare"));

      // -----------------------------------------------------------------------
      // Core Recalculation
      // -----------------------------------------------------------------------
      function recalculate() {
        let activeWidth = 0;
        let activeHeight = 0;

        if (currentMode === "live") {
          activeWidth = window.innerWidth;
          activeHeight = window.innerHeight;
        } else {
          const mode = solveSelect.value;
          if (mode === "ratio") {
            activeWidth = Math.max(1, parseInt(inputWidth.value) || 1);
            activeHeight = Math.max(1, parseInt(inputHeight.value) || 1);
          } else if (mode === "height") {
            activeWidth = Math.max(1, parseInt(inputWidth.value) || 1);
            const ratioVal = parseRatio(inputRatio.value);
            activeHeight = Math.round(activeWidth / ratioVal) || 1;
            inputHeight.value = activeHeight;
          } else if (mode === "width") {
            activeHeight = Math.max(1, parseInt(inputHeight.value) || 1);
            const ratioVal = parseRatio(inputRatio.value);
            activeWidth = Math.round(activeHeight * ratioVal) || 1;
            inputWidth.value = activeWidth;
          }
          customWidth = activeWidth;
          customHeight = activeHeight;
        }

        // 1. Live diagnostics panel
        const dpr = window.devicePixelRatio || 1;
        statCssViewport.textContent = `${window.innerWidth} × ${window.innerHeight}`;
        statPhysScreen.textContent = `${Math.round(window.screen.width * dpr)} × ${Math.round(window.screen.height * dpr)}`;
        statDpr.textContent = `${dpr.toFixed(1)}x`;
        statNearestRatio.textContent = getNearestStandardRatio(
          activeWidth,
          activeHeight,
        );

        // 2. Visual display computations
        const rawRatio = activeWidth / activeHeight;
        const simplifiedRatio = getSimplifiedRatio(activeWidth, activeHeight);
        const decimalRatio = rawRatio.toFixed(3);

        const displayRatioString = displayDecimal
          ? decimalRatio
          : simplifiedRatio;
        boxRatioLabel.textContent = displayRatioString;
        boxPixelsLabel.textContent = `${activeWidth} × ${activeHeight} px`;

        const exactGcd = getGcd(activeWidth, activeHeight);
        const cssAspect = `aspect-ratio: ${activeWidth / exactGcd} / ${activeHeight / exactGcd}`;
        boxCssLabel.textContent = cssAspect;
        cssSnippetText.textContent = `${cssAspect};`;

        // 3. Resize visual ratio preview box
        const previewArea = document.getElementById("preview-area");
        // clientWidth/clientHeight can be 0 on first render in a flex column on mobile
        // Use getBoundingClientRect for reliability, with sensible fallbacks
        const areaBounds = previewArea.getBoundingClientRect();
        const pWidth = Math.max(80, (areaBounds.width || previewArea.clientWidth || 300) - 48);
        const pHeight = Math.max(80, (areaBounds.height || previewArea.clientHeight || 220) - 24);
        const containerRatio = pWidth / pHeight;
        let newW, newH;

        if (rawRatio > containerRatio) {
          newW = pWidth;
          newH = pWidth / rawRatio;
        } else {
          newH = pHeight;
          newW = pHeight * rawRatio;
        }

        // Clamp: never exceed container, never shrink below readable minimum
        newW = Math.min(pWidth, Math.max(60, newW));
        newH = Math.min(pHeight, Math.max(40, newH));

        visualRatioBox.style.width = `${newW}px`;
        visualRatioBox.style.height = `${newH}px`;

        // Adjust font sizes & visibility based on box dimensions to prevent overflow on mobile/small boxes
        if (newW < 120 || newH < 85) {
          boxRatioLabel.className =
            "font-display font-medium text-xs text-primary drop-shadow-sm select-none z-10 truncate max-w-full text-center px-1";
          boxPixelsLabel.classList.add("hidden");
          boxCssLabel.classList.add("hidden");
        } else if (newW < 185 || newH < 125) {
          boxRatioLabel.className =
            "font-display font-medium text-sm sm:text-base text-primary drop-shadow-sm select-none z-10 truncate max-w-full text-center px-1";
          boxPixelsLabel.className =
            "text-[9px] text-slate font-mono select-none z-10 truncate max-w-full text-center px-1";
          boxPixelsLabel.classList.remove("hidden");
          boxCssLabel.classList.add("hidden");
        } else {
          boxRatioLabel.className =
            "font-display font-medium text-xl sm:text-2xl text-primary drop-shadow-sm select-none z-10 truncate max-w-full text-center px-1";
          boxPixelsLabel.className =
            "text-[11px] text-slate font-mono select-none z-10 truncate max-w-full text-center px-1";
          boxPixelsLabel.classList.remove("hidden");
          boxCssLabel.className =
            "text-[9px] text-stone font-mono bg-canvas px-1.5 py-0.5 rounded border border-hairline select-none z-10 truncate max-w-full text-center";
          boxCssLabel.classList.remove("hidden");
        }

        // 4. Proportion bar
        const totalParts = activeWidth + activeHeight;
        const wPct = ((activeWidth / totalParts) * 100).toFixed(1);
        const hPct = ((activeHeight / totalParts) * 100).toFixed(1);
        propBarW.style.width = `${wPct}%`;
        propBarH.style.width = `${hPct}%`;
        propBarWLabel.textContent = `W ${wPct}%`;
        propBarHLabel.textContent = `H ${hPct}%`;

        // 5. Proportional scaler
        updateScaler(activeWidth, activeHeight);

        // 6. Share link
        updateShareLink(activeWidth, activeHeight);

        // 7. PPI calculator sync (from current dimensions)
        ppiWidthInput.value = activeWidth;
        ppiHeightInput.value = activeHeight;
        updatePpi();

        // 8. Push to history
        pushHistory(activeWidth, activeHeight, displayRatioString);
      }

      // -----------------------------------------------------------------------
      // Proportional Scaler
      // -----------------------------------------------------------------------
      function updateScaler(activeW, activeH) {
        const ratio = activeW / activeH;
        const targetW = parseFloat(scaleWidthInput.value);
        const targetH = parseFloat(scaleHeightInput.value);
        const focusedEl = document.activeElement;

        if (focusedEl === scaleWidthInput && !isNaN(targetW) && targetW > 0) {
          const solvedH = Math.round(targetW / ratio);
          scaleGeometryResult.innerHTML = `<span>${Math.round(targetW)} px</span> <span class="text-stone">×</span> <span>${solvedH} px</span>`;
          scaleHeightInput.value = solvedH;
        } else if (
          focusedEl === scaleHeightInput &&
          !isNaN(targetH) &&
          targetH > 0
        ) {
          const solvedW = Math.round(targetH * ratio);
          scaleGeometryResult.innerHTML = `<span>${solvedW} px</span> <span class="text-stone">×</span> <span>${Math.round(targetH)} px</span>`;
          scaleWidthInput.value = solvedW;
        } else {
          scaleGeometryResult.innerHTML = `<span>${activeW} px</span> <span class="text-stone">×</span> <span>${activeH} px</span>`;
        }
      }

      scaleWidthInput.addEventListener("input", () => {
        if (
          scaleHeightInput.value &&
          document.activeElement === scaleWidthInput
        )
          scaleHeightInput.value = "";
        recalculate();
      });
      scaleHeightInput.addEventListener("input", () => {
        if (
          scaleWidthInput.value &&
          document.activeElement === scaleHeightInput
        )
          scaleWidthInput.value = "";
        recalculate();
      });

      // -----------------------------------------------------------------------
      // Share Link
      // -----------------------------------------------------------------------
      function updateShareLink(w, h) {
        const url = new URL(window.location.href);
        url.searchParams.set("w", w);
        url.searchParams.set("h", h);
        shareLinkInput.value = url.toString();
      }

      // -----------------------------------------------------------------------
      // Copy / Export helpers
      // -----------------------------------------------------------------------
      function animateCopySuccess(btn, originalText) {
        btn.classList.add("bg-success-accent", "hover:bg-success-accent");
        btn.classList.remove("bg-primary", "hover:bg-charcoal");
        const span = btn.querySelector("span");
        if (span) span.textContent = "Copied!";
        setTimeout(() => {
          btn.classList.remove("bg-success-accent", "hover:bg-success-accent");
          btn.classList.add("bg-primary", "hover:bg-charcoal");
          if (span) span.textContent = originalText;
        }, 1200);
      }

      copyCssBtn.addEventListener("click", () => {
        navigator.clipboard.writeText(cssSnippetText.textContent).then(() => {
          animateCopySuccess(copyCssBtn, "Copy CSS");
        });
      });

      copyShareBtn.addEventListener("click", () => {
        navigator.clipboard.writeText(shareLinkInput.value).then(() => {
          animateCopySuccess(copyShareBtn, "Copy");
        });
      });

      exportBtn.addEventListener("click", () => {
        const activeW =
          currentMode === "live" ? window.innerWidth : customWidth;
        const activeH =
          currentMode === "live" ? window.innerHeight : customHeight;
        const dpr = window.devicePixelRatio || 1;
        const data = {
          width: activeW,
          height: activeH,
          simplifiedRatio: getSimplifiedRatio(activeW, activeH),
          decimalRatio: (activeW / activeH).toFixed(6),
          nearestStandard: getNearestStandardRatio(activeW, activeH),
          cssProperty: `aspect-ratio: ${activeW / getGcd(activeW, activeH)} / ${activeH / getGcd(activeW, activeH)}`,
          devicePixelRatio: dpr,
          physicalWidth: Math.round(window.screen.width * dpr),
          physicalHeight: Math.round(window.screen.height * dpr),
          generatedAt: new Date().toISOString(),
        };
        const blob = new Blob([JSON.stringify(data, null, 2)], {
          type: "application/json",
        });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `aspect-ratio-${activeW}x${activeH}.json`;
        a.click();
        URL.revokeObjectURL(url);
      });

      // -----------------------------------------------------------------------
      // Orientation Flip
      // -----------------------------------------------------------------------
      function flipOrientation() {
        if (currentMode !== "custom") {
          setMode("custom");
          solveSelect.value = "ratio";
          adjustInputsLayout();
        }
        const w = parseInt(inputWidth.value) || customWidth;
        const h = parseInt(inputHeight.value) || customHeight;
        inputWidth.value = h;
        inputHeight.value = w;
        visualRatioBox.classList.add("scale-[0.97]", "opacity-80");
        setTimeout(
          () => visualRatioBox.classList.remove("scale-[0.97]", "opacity-80"),
          200,
        );
        recalculate();
      }

      flipOrientationBtn.addEventListener("click", flipOrientation);
      flipOrientationBtn2.addEventListener("click", flipOrientation);

      // -----------------------------------------------------------------------
      // Grid Toggle
      // -----------------------------------------------------------------------
      toggleGridBtn.addEventListener("click", () => {
        gridVisible = !gridVisible;
        gridOverlay.classList.toggle("hidden", !gridVisible);
        toggleGridBtn.classList.toggle("bg-primary", gridVisible);
        toggleGridBtn.classList.toggle("text-canvas", gridVisible);
        toggleGridBtn.classList.toggle("text-slate", !gridVisible);
      });

      // -----------------------------------------------------------------------
      // Preset Chip clicks
      // -----------------------------------------------------------------------
      presetsContainer.addEventListener("click", (e) => {
        const chip = e.target.closest("button.chip");
        if (!chip) return;

        const w = parseInt(chip.getAttribute("data-w"));
        const h = parseInt(chip.getAttribute("data-h"));

        setMode("custom");
        solveSelect.value = "ratio";
        adjustInputsLayout();

        inputWidth.value = w;
        inputHeight.value = h;

        visualRatioBox.classList.add("scale-[1.03]", "bg-brand-yellow/30");
        setTimeout(
          () =>
            visualRatioBox.classList.remove(
              "scale-[1.03]",
              "bg-brand-yellow/30",
            ),
          250,
        );

        recalculate();
      });

      // -----------------------------------------------------------------------
      // Simplified / Decimal Toggle
      // -----------------------------------------------------------------------
      toggleRatioSimp.addEventListener("click", () => {
        displayDecimal = false;
        toggleRatioSimp.classList.add("bg-primary", "text-canvas");
        toggleRatioSimp.classList.remove("text-slate", "hover:text-primary");
        toggleRatioDec.classList.remove("bg-primary", "text-canvas");
        toggleRatioDec.classList.add("text-slate", "hover:text-primary");
        recalculate();
      });

      toggleRatioDec.addEventListener("click", () => {
        displayDecimal = true;
        toggleRatioDec.classList.add("bg-primary", "text-canvas");
        toggleRatioDec.classList.remove("text-slate", "hover:text-primary");
        toggleRatioSimp.classList.remove("bg-primary", "text-canvas");
        toggleRatioSimp.classList.add("text-slate", "hover:text-primary");
        recalculate();
      });

      // -----------------------------------------------------------------------
      // Solver input layout adjustments
      // -----------------------------------------------------------------------
      function adjustInputsLayout() {
        const mode = solveSelect.value;
        if (mode === "ratio") {
          solverInputsGrid.classList.remove("hidden");
          ratioInputWrapper.classList.add("hidden");
          inputWidth.parentElement.classList.remove("hidden");
          inputHeight.parentElement.classList.remove("hidden");
        } else if (mode === "height") {
          solverInputsGrid.classList.remove("hidden");
          ratioInputWrapper.classList.remove("hidden");
          inputWidth.parentElement.classList.remove("hidden");
          inputHeight.parentElement.classList.add("hidden");
        } else if (mode === "width") {
          solverInputsGrid.classList.remove("hidden");
          ratioInputWrapper.classList.remove("hidden");
          inputWidth.parentElement.classList.add("hidden");
          inputHeight.parentElement.classList.remove("hidden");
        }
      }

      solveSelect.addEventListener("change", () => {
        adjustInputsLayout();
        recalculate();
      });
      inputWidth.addEventListener("input", recalculate);
      inputHeight.addEventListener("input", recalculate);
      inputRatio.addEventListener("input", recalculate);

      standardRatiosDropdown.addEventListener("change", () => {
        if (standardRatiosDropdown.value) {
          inputRatio.value = standardRatiosDropdown.value;
          recalculate();
        }
      });

      // -----------------------------------------------------------------------
      // PPI Calculator
      // -----------------------------------------------------------------------
      function updatePpi() {
        const w = parseFloat(ppiWidthInput.value);
        const h = parseFloat(ppiHeightInput.value);
        const d = parseFloat(ppiDiagonalInput.value);

        if (!w || !h || !d || w <= 0 || h <= 0 || d <= 0) {
          ppiResult.textContent = "---";
          ppiTier.textContent = "---";
          ppiTierDesc.textContent = "—";
          return;
        }

        const ppi = Math.round(Math.sqrt(w * w + h * h) / d);
        ppiResult.textContent = `${ppi} PPI`;

        let tier, desc;
        if (ppi >= 400) {
          tier = "Ultra HD";
          desc = "Microscopic pixels — premium mobile";
        } else if (ppi >= 220) {
          tier = "Retina";
          desc = "Pixel-perfect at normal viewing dist";
        } else if (ppi >= 160) {
          tier = "HiDPI";
          desc = "High-density, sharp text & graphics";
        } else if (ppi >= 100) {
          tier = "Standard";
          desc = "Good for desktop at arm's length";
        } else if (ppi >= 70) {
          tier = "Low";
          desc = "Visible pixels, okay for large displays";
        } else {
          tier = "Very Low";
          desc = "Jagged edges visible at close range";
        }

        ppiTier.textContent = tier;
        ppiTierDesc.textContent = desc;
      }

      ppiWidthInput.addEventListener("input", updatePpi);
      ppiHeightInput.addEventListener("input", updatePpi);
      ppiDiagonalInput.addEventListener("input", updatePpi);

      // -----------------------------------------------------------------------
      // Compare Mode
      // -----------------------------------------------------------------------
      function updateCompare() {
        const aw = parseFloat(compareAW.value) || 16;
        const ah = parseFloat(compareAH.value) || 9;
        const bw = parseFloat(compareBW.value) || 4;
        const bh = parseFloat(compareBH.value) || 3;

        const ratioA = aw / ah;
        const ratioB = bw / bh;

        // Determine max box width from the compare container (each side is ~50% minus gap)
        const compareContainer = document.querySelector("#compare-panel .relative.bg-surface-soft");
        const containerW = compareContainer ? compareContainer.clientWidth : 300;
        // Each column gets ~half the container minus padding/gap
        const maxBoxW = Math.max(60, Math.floor((containerW / 2) - 32));

        const BASE_H = Math.max(60, Math.min(140, maxBoxW / Math.max(ratioA, ratioB)));
        const heightA = BASE_H;
        const widthA = Math.min(maxBoxW, Math.round(BASE_H * ratioA));
        const heightB = BASE_H;
        const widthB = Math.min(maxBoxW, Math.round(BASE_H * ratioB));

        compareBoxA.style.width = `${widthA}px`;
        compareBoxA.style.height = `${heightA}px`;
        compareBoxB.style.width = `${widthB}px`;
        compareBoxB.style.height = `${heightB}px`;

        const simpA = getSimplifiedRatio(aw, ah);
        const simpB = getSimplifiedRatio(bw, bh);
        compareLabelA.textContent = simpA;
        compareLabelB.textContent = simpB;
        compareAInfo.textContent = simpA;
        compareBInfo.textContent = simpB;
        compareADecimal.textContent = `≈ ${ratioA.toFixed(3)}`;
        compareBDecimal.textContent = `≈ ${ratioB.toFixed(3)}`;

        // Stats: compare at a reference 1000px height
        const refH = 1000;
        const wA = Math.round(refH * ratioA);
        const wB = Math.round(refH * ratioB);
        const widthDiff = Math.abs(wA - wB);
        const ratioDiff = Math.abs(ratioA - ratioB).toFixed(4);
        const areaA = wA * refH;
        const areaB = wB * refH;
        const areaDiff = (
          ((Math.max(areaA, areaB) - Math.min(areaA, areaB)) /
            Math.min(areaA, areaB)) *
          100
        ).toFixed(1);

        compareStatWidth.textContent = `${widthDiff} px wider`;
        compareStatRatio.textContent = `Δ ${ratioDiff}`;
        compareStatArea.textContent = `${areaDiff}% more area`;
      }

      [compareAW, compareAH, compareBW, compareBH].forEach((el) => {
        el.addEventListener("input", updateCompare);
      });

      // -----------------------------------------------------------------------
      // Ratio History
      // -----------------------------------------------------------------------
      function loadHistory() {
        try {
          const raw = localStorage.getItem(STORAGE_HISTORY_KEY);
          historyItems = raw ? JSON.parse(raw) : [];
        } catch {
          historyItems = [];
        }
        renderHistory();
      }

      function pushHistory(w, h, label) {
        const key = `${w}x${h}`;
        historyItems = historyItems.filter((i) => i.key !== key);
        historyItems.unshift({ key, w, h, label, time: Date.now() });
        historyItems = historyItems.slice(0, 10);
        try {
          localStorage.setItem(
            STORAGE_HISTORY_KEY,
            JSON.stringify(historyItems),
          );
        } catch {}
        renderHistory();
      }

      function renderHistory() {
        historyList.innerHTML = "";
        if (historyItems.length === 0) {
          historyList.appendChild(historyEmpty);
          return;
        }
        historyItems.forEach((item) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.title = `Load ${item.w} × ${item.h}`;
          btn.className =
            "text-[10px] font-semibold px-2.5 py-1 rounded-full bg-surface hover:bg-hairline border border-hairline text-slate hover:text-primary transition-all cursor-pointer flex items-center gap-1";
          btn.innerHTML = `<span class="font-mono">${item.w}×${item.h}</span><span class="opacity-50">(${item.label})</span>`;
          btn.addEventListener("click", () => {
            setMode("custom");
            solveSelect.value = "ratio";
            adjustInputsLayout();
            inputWidth.value = item.w;
            inputHeight.value = item.h;
            recalculate();
          });
          historyList.appendChild(btn);
        });
      }

      clearHistBtn.addEventListener("click", () => {
        historyItems = [];
        try {
          localStorage.removeItem(STORAGE_HISTORY_KEY);
        } catch {}
        renderHistory();
      });

      // -----------------------------------------------------------------------
      // Use-Case Reference Panel
      // -----------------------------------------------------------------------
      function renderUseCases() {
        USE_CASES.forEach((uc) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className =
            "flex items-center justify-between gap-3 px-3 py-2 rounded-lg bg-surface hover:bg-hairline border border-hairline text-left transition-all cursor-pointer group w-full";
          btn.innerHTML = `
            <div class="flex items-center gap-2">
              <span class="text-sm">${uc.emoji}</span>
              <div>
                <div class="text-[11px] font-semibold text-primary">${escapeHtml(uc.label)}</div>
                <div class="text-[9px] text-stone font-mono">${uc.ratio}</div>
              </div>
            </div>
            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded border border-hairline bg-canvas text-slate group-hover:text-brand-blue transition-colors">Load</span>
          `;
          btn.addEventListener("click", () => {
            setMode("custom");
            solveSelect.value = "ratio";
            adjustInputsLayout();
            inputWidth.value = uc.w;
            inputHeight.value = uc.h;
            visualRatioBox.classList.add("scale-[1.02]", "bg-brand-yellow/25");
            setTimeout(
              () =>
                visualRatioBox.classList.remove(
                  "scale-[1.02]",
                  "bg-brand-yellow/25",
                ),
              250,
            );
            recalculate();
          });
          useCaseList.appendChild(btn);
        });
      }

      // -----------------------------------------------------------------------
      // Custom Saved Presets
      // -----------------------------------------------------------------------
      let savedPresets = [];

      function loadSavedPresets() {
        try {
          const raw = localStorage.getItem(STORAGE_PRESETS_KEY);
          savedPresets = raw ? JSON.parse(raw) : [];
        } catch {
          savedPresets = [];
        }
        renderSavedPresets();
      }

      function savePresetsToStorage() {
        localStorage.setItem(STORAGE_PRESETS_KEY, JSON.stringify(savedPresets));
        renderSavedPresets();
      }

      function renderSavedPresets() {
        savedPresetsList.innerHTML = "";
        if (savedPresets.length === 0) {
          savedPresetsList.appendChild(noSavedPresets);
          return;
        }
        savedPresets.forEach((item, index) => {
          const div = document.createElement("div");
          div.className =
            "flex items-center justify-between gap-2 bg-surface hover:bg-hairline p-2 rounded-lg border border-hairline transition-all text-xs";
          div.innerHTML = `
            <div class="flex flex-col select-none">
              <span class="font-semibold text-primary">${escapeHtml(item.name)}</span>
              <span class="text-[10px] text-stone font-mono">${item.width} × ${item.height} (${getSimplifiedRatio(item.width, item.height)})</span>
            </div>
            <div class="flex items-center gap-1.5">
              <button type="button" class="apply-preset-btn text-[10px] bg-canvas hover:bg-surface border border-hairline font-bold px-2 py-0.5 rounded transition-all cursor-pointer" data-index="${index}">Load</button>
              <button type="button" class="delete-preset-btn text-brand-coral hover:text-coral-dark text-[11px] font-bold px-1.5 cursor-pointer" data-index="${index}" aria-label="Delete preset">✕</button>
            </div>
          `;
          savedPresetsList.appendChild(div);
        });
      }

      savePresetForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const name = newPresetName.value.trim();
        if (!name) return;
        const activeW =
          currentMode === "live"
            ? window.innerWidth
            : parseInt(inputWidth.value) || 1;
        const activeH =
          currentMode === "live"
            ? window.innerHeight
            : parseInt(inputHeight.value) || 1;
        savedPresets.push({ name, width: activeW, height: activeH });
        newPresetName.value = "";
        savePresetsToStorage();
      });

      savedPresetsList.addEventListener("click", (e) => {
        const loadBtn = e.target.closest(".apply-preset-btn");
        const deleteBtn = e.target.closest(".delete-preset-btn");
        if (loadBtn) {
          const item =
            savedPresets[parseInt(loadBtn.getAttribute("data-index"))];
          if (item) {
            setMode("custom");
            solveSelect.value = "ratio";
            adjustInputsLayout();
            inputWidth.value = item.width;
            inputHeight.value = item.height;
            recalculate();
          }
        } else if (deleteBtn) {
          savedPresets.splice(
            parseInt(deleteBtn.getAttribute("data-index")),
            1,
          );
          savePresetsToStorage();
        }
      });

      // -----------------------------------------------------------------------
      // Modal management
      // -----------------------------------------------------------------------
      howItWorksBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.remove("hidden"),
      );
      closeModalBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.add("hidden"),
      );
      modalOkBtn?.addEventListener("click", () =>
        howItWorksModal?.classList.add("hidden"),
      );
      howItWorksModal?.addEventListener("click", (e) => {
        if (e.target === howItWorksModal)
          howItWorksModal.classList.add("hidden");
      });

      shortcutsBtn?.addEventListener("click", () =>
        shortcutsModal?.classList.remove("hidden"),
      );
      closeShortcutsBtn?.addEventListener("click", () =>
        shortcutsModal?.classList.add("hidden"),
      );
      shortcutsModal?.addEventListener("click", (e) => {
        if (e.target === shortcutsModal) shortcutsModal.classList.add("hidden");
      });

      // -----------------------------------------------------------------------
      // Share Button
      // -----------------------------------------------------------------------
      headerShareBtn?.addEventListener("click", () => {
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set("mode", currentMode);
        url.searchParams.set("w", (currentMode === "live" ? window.innerWidth : parseInt(inputWidth.value) || 1920).toString());
        url.searchParams.set("h", (currentMode === "live" ? window.innerHeight : parseInt(inputHeight.value) || 1080).toString());

        const shareData = {
          title: document.title || "Aspect Ratio Checker",
          url: url.toString()
        };

        if (navigator.share) {
          navigator.share(shareData).catch((err) => {
            if (err.name !== "AbortError") {
              copyToClipboard(url.toString());
            }
          });
        } else {
          copyToClipboard(url.toString());
        }

        function copyToClipboard(text) {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
          } else {
            fallbackCopy(text);
          }
        }

        function fallbackCopy(text) {
          const textArea = document.createElement("textarea");
          textArea.value = text;
          textArea.style.position = "fixed";
          textArea.style.opacity = "0";
          document.body.appendChild(textArea);
          textArea.select();
          try {
            document.execCommand("copy");
            showSuccess();
          } catch (err) {
            console.error(err);
          }
          document.body.removeChild(textArea);
        }

        function showSuccess() {
          if (headerShareBtn) {
            const span = headerShareBtn.querySelector("span");
            if (span) {
              const originalText = span.textContent || "Share";
              span.textContent = "Link Copied!";
              headerShareBtn.classList.add("text-success-accent", "border-success-accent");
              setTimeout(() => {
                span.textContent = originalText;
                headerShareBtn.classList.remove("text-success-accent", "border-success-accent");
              }, 2000);
            }
          }
        }
      });

      // -----------------------------------------------------------------------
      // Reset Button
      // -----------------------------------------------------------------------
      resetBtn.addEventListener("click", () => {
        // Clear URL parameters
        if (window.history.pushState) {
          const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
          window.history.pushState({path:newurl}, '', newurl);
        }

        currentMode = "live";
        displayDecimal = false;
        gridVisible = false;

        inputWidth.value = 1920;
        inputHeight.value = 1080;
        inputRatio.value = "16:9";
        scaleWidthInput.value = "";
        scaleHeightInput.value = "";
        solveSelect.value = "ratio";
        standardRatiosDropdown.value = "";
        ppiDiagonalInput.value = "24";

        gridOverlay.classList.add("hidden");
        toggleGridBtn.classList.remove("bg-primary", "text-canvas");
        toggleGridBtn.classList.add("text-slate");

        toggleRatioSimp.classList.add("bg-primary", "text-canvas");
        toggleRatioSimp.classList.remove("text-slate", "hover:text-primary");
        toggleRatioDec.classList.remove("bg-primary", "text-canvas");
        toggleRatioDec.classList.add("text-slate", "hover:text-primary");

        localStorage.removeItem(STORAGE_PRESETS_KEY);
        localStorage.removeItem(STORAGE_HISTORY_KEY);
        historyItems = [];
        savedPresets = [];
        loadSavedPresets();
        loadHistory();

        setMode("live");
        adjustInputsLayout();
        recalculate();

        document.body.classList.add("opacity-50");
        setTimeout(() => document.body.classList.remove("opacity-50"), 150);
      });

      // -----------------------------------------------------------------------
      // Keyboard Shortcuts
      // -----------------------------------------------------------------------
      function handleKeyDown(e) {
        const tag = document.activeElement.tagName.toLowerCase();
        if (tag === "input" || tag === "textarea" || tag === "select") return;

        switch (e.key.toUpperCase()) {
          case "L":
            setMode("live");
            break;
          case "C":
            setMode("custom");
            break;
          case "V":
            setMode("compare");
            break;
          case "F":
            flipOrientation();
            break;
          case "D":
            if (!displayDecimal) {
              toggleRatioDec.click();
            } else {
              toggleRatioSimp.click();
            }
            break;
          case "G":
            toggleGridBtn.click();
            break;
          case "ESCAPE":
            if (!howItWorksModal.classList.contains("hidden")) {
              howItWorksModal.classList.add("hidden");
            } else if (!shortcutsModal.classList.contains("hidden")) {
              shortcutsModal.classList.add("hidden");
            }
            break;
        }
        // Ctrl+Shift+C → copy CSS
        if (e.ctrlKey && e.shiftKey && e.key.toUpperCase() === "C") {
          e.preventDefault();
          copyCssBtn.click();
        }
      }
      document.addEventListener("keydown", handleKeyDown);

      // -----------------------------------------------------------------------
      // Debounced resize listener
      // -----------------------------------------------------------------------
      let resizeTimeout;
      function handleResize() {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          if (
            window.innerWidth !== cachedLiveWidth ||
            window.innerHeight !== cachedLiveHeight
          ) {
            cachedLiveWidth = window.innerWidth;
            cachedLiveHeight = window.innerHeight;
            recalculate();
          }
          // Always re-render compare boxes on resize (orientation change etc.)
          if (currentMode === "compare") updateCompare();
        }, 60);
      }
      window.addEventListener("resize", handleResize);

      // -----------------------------------------------------------------------
      // Init
      // -----------------------------------------------------------------------
      function init() {
        renderUseCases();

        const urlParams = new URLSearchParams(window.location.search);
        const urlW = parseInt(urlParams.get("w"));
        const urlH = parseInt(urlParams.get("h"));
        const urlMode = urlParams.get("mode");

        if (urlMode === "compare") {
          setMode("compare");
        } else if (urlMode === "live") {
          setMode("live");
        } else if (!isNaN(urlW) && !isNaN(urlH) && urlW > 0 && urlH > 0) {
          setMode("custom");
          solveSelect.value = "ratio";
          inputWidth.value = urlW;
          inputHeight.value = urlH;
        } else if (urlMode === "custom") {
          setMode("custom");
        } else {
          setMode("live");
        }

        loadSavedPresets();
        loadHistory();
        adjustInputsLayout();
        recalculate();
        updatePpi();
        updateCompare();

        // Re-run after one frame so getBoundingClientRect has real layout dimensions
        requestAnimationFrame(() => {
          recalculate();
          updateCompare();
        });
      }

      document.addEventListener("astro:before-swap", () => {
        document.removeEventListener("keydown", handleKeyDown);
        window.removeEventListener("resize", handleResize);
        document.removeEventListener("DOMContentLoaded", init);
      });

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    })();
    }
  </script>
</Layout>
