  <!-- Interactive JavaScript logic -->
  <script is:inline>
    if (typeof window !== 'undefined') {
    (function () {
      // -----------------------------------------------------------------------
      // Configuration & Namespacing
      // -----------------------------------------------------------------------
      const STORAGE_PRESETS_KEY = "boardtools:aspect-ratio:named-presets";
      const STORAGE_HISTORY_KEY = "boardtools:aspect-ratio:history";

      // Common Standard Ratios for closest matching
      const STANDARD_RATIOS = [
        { label: "16:9", ratio: 16 / 9, w: 16, h: 9 },
        { label: "16:10", ratio: 16 / 10, w: 16, h: 10 },
        { label: "21:9", ratio: 21 / 9, w: 21, h: 9 },
        { label: "32:9", ratio: 32 / 9, w: 32, h: 9 },
        { label: "4:3", ratio: 4 / 3, w: 4, h: 3 },
        { label: "3:2", ratio: 3 / 2, w: 3, h: 2 },
        { label: "1:1", ratio: 1 / 1, w: 1, h: 1 },
        { label: "9:16", ratio: 9 / 16, w: 9, h: 16 },
        { label: "3:4", ratio: 3 / 4, w: 3, h: 4 },
        { label: "2:3", ratio: 2 / 3, w: 2, h: 3 },
      ];

      // Use-case reference data
      const USE_CASES = [
        {
          label: "YouTube Video",
