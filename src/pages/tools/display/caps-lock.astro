  <script>
    if (typeof window !== 'undefined') {
    interface EventLog {
      time: string;
      timestamp: number;
      type: 'toggle' | 'keypress';
      details: string;
      rawKey?: string;
      stateBefore?: boolean;
      stateAfter?: boolean;
    }

    // Modal elements matching json-formatter.astro verbatim
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");
    const headerShareBtn = document.getElementById("share-btn");
    const btnReset = document.getElementById("reset-btn");

    // Local storage key schema matching toolkify:{tool-slug}:{key}
    const STORAGE_KEY_HISTORY = "toolkify:caps-lock:history";

    // Diagnostic elements
    const interactiveZone = document.getElementById("interactive-zone") as HTMLDivElement;
    const statusCard = document.getElementById("status-card") as HTMLDivElement;
    const statusIconWrapper = document.getElementById("status-icon-wrapper") as HTMLDivElement;
    const statusIcon = document.getElementById("status-icon") as SVGElement | null;
    const statusLabel = document.getElementById("status-label") as HTMLDivElement;
    const statusHint = document.getElementById("status-hint") as HTMLParagraphElement;
    const statusEyebrow = document.getElementById("status-eyebrow") as HTMLSpanElement;
    const mockPassword = document.getElementById("mock-password") as HTMLInputElement;
    const capsWarningPill = document.getElementById("caps-warning-pill") as HTMLDivElement;
    const practiceTextarea = document.getElementById("practice-textarea") as HTMLTextAreaElement;
    const typingCounter = document.getElementById("typing-counter") as HTMLSpanElement;
    const statTotalToggles = document.getElementById("stat-total-toggles") as HTMLSpanElement;
    const statAnomalies = document.getElementById("stat-anomalies") as HTMLSpanElement;
    const anomalyAlertBox = document.getElementById("anomaly-alert-box") as HTMLDivElement;
    const exportCsvBtn = document.getElementById("export-csv-btn") as HTMLButtonElement;

    // Mobile simulator components
    const mobileWarningBanner = document.getElementById("mobile-warning-banner") as HTMLDivElement;
    const simToggleBtn = document.getElementById("sim-toggle-btn") as HTMLButtonElement;

    // Log Tab Elements
    const tabKeystrokes = document.getElementById("tab-keystrokes") as HTMLButtonElement;
    const tabToggles = document.getElementById("tab-toggles") as HTMLButtonElement;
    const logList = document.getElementById("log-list") as HTMLDivElement;

    let capsLockState: boolean | null = null;
    let eventLogs: EventLog[] = [];
    let activeLogTab: 'keystroke' | 'toggle' = 'keystroke';
    let anomalyCount = 0;
    let toggleCount = 0;
    let lastToggleTime = 0;

    // How it works modal interactions (verbatim copy from json-formatter.astro)
    howItWorksBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.remove("hidden");
    });
    closeModalBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    modalOkBtn?.addEventListener("click", () => {
      howItWorksModal?.classList.add("hidden");
    });
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal.classList.add("hidden");
      }
    });

    headerShareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      const shareData = {
        title: document.title || "Caps Lock Test",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (headerShareBtn) {
          const span = headerShareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            headerShareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              headerShareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Device / Touch Screen check
    function checkDeviceType() {
      const hasTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      const isSmallScreen = window.innerWidth < 768;
      if (hasTouch && isSmallScreen) {
        mobileWarningBanner?.classList.remove("hidden");
      } else {
        mobileWarningBanner?.classList.add("hidden");
      }
    }

    let resizeTimeout: number | null = null;
    function handleResize() {
      if (resizeTimeout) {
        clearTimeout(resizeTimeout);
      }
      resizeTimeout = window.setTimeout(() => {
        checkDeviceType();
      }, 150);
    }
    window.addEventListener("resize", handleResize);

    // Initialize Page & Load state from local storage
    function init() {
      checkDeviceType();
      
      try {
        const storedLogs = localStorage.getItem(STORAGE_KEY_HISTORY);
        if (storedLogs) {
          eventLogs = JSON.parse(storedLogs);
          // Recalculate stats based on loaded log
          toggleCount = eventLogs.filter(l => l.type === 'toggle').length;
          statTotalToggles.textContent = String(toggleCount);
          
          // Check loaded anomalies
          anomalyCount = eventLogs.filter(l => l.type === 'toggle' && l.details.includes('bounce')).length;
          statAnomalies.textContent = String(anomalyCount);
          if (anomalyCount > 0) {
            anomalyAlertBox.classList.remove("hidden");
          }
        }
      } catch (e) {
        console.warn("Could not read localstorage history", e);
      }

      renderLogs();
    }

    // Check Caps Lock State via Key Event
    function evaluateEventState(e: KeyboardEvent) {
      // getModifierState is the accurate modifier API
      const state = e.getModifierState("CapsLock");
      setCapsLockUIState(state);

      // Log printable/normal keypresses
      if (e.type === 'keydown' && e.key.length === 1) {
        logKeyPress(e.key);
      }
    }

    function setCapsLockUIState(state: boolean) {
      if (capsLockState === state) return;

      const prev = capsLockState;
      capsLockState = state;

      // Update Large ON/OFF Indicator UI with animations
      if (state) {
        statusCard.className = "w-full max-w-sm rounded-2xl p-6 flex flex-col items-center justify-center gap-3 transition-all duration-500 shadow-lg transform scale-102 bg-brand-coral/10 border-2 border-brand-coral text-coral-dark";
        statusIconWrapper.className = "w-16 h-16 rounded-full flex items-center justify-center transition-all duration-500 bg-brand-coral text-canvas animate-pulse shadow-md";
        statusLabel.className = "text-4xl font-display font-extrabold transition-all duration-500 tracking-tight text-coral-dark";
        statusLabel.textContent = "ON";
        statusHint.textContent = "Software registers Caps Lock modifier as ACTIVE.";
        statusHint.className = "text-[10px] text-coral-dark/80 text-center max-w-[200px]";
        statusEyebrow.className = "text-[10px] font-bold tracking-widest uppercase text-brand-coral";
        
        // Update SVG icon representation to locked
        if (statusIconWrapper) {
          statusIconWrapper.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
          `;
        }

        // Mock Password Warning pill show
        capsWarningPill?.classList.remove("hidden");
        capsWarningPill?.classList.add("flex");
      } else {
        statusCard.className = "w-full max-w-sm rounded-2xl p-6 flex flex-col items-center justify-center gap-3 transition-all duration-500 shadow-md transform scale-100 bg-brand-teal/5 border-2 border-brand-teal text-moss-dark";
        statusIconWrapper.className = "w-16 h-16 rounded-full flex items-center justify-center transition-all duration-500 bg-brand-teal text-canvas shadow-subtle";
        statusLabel.className = "text-4xl font-display font-extrabold transition-all duration-500 tracking-tight text-moss-dark";
        statusLabel.textContent = "OFF";
        statusHint.textContent = "Software registers Caps Lock modifier as INACTIVE.";
        statusHint.className = "text-[10px] text-moss-dark/80 text-center max-w-[200px]";
        statusEyebrow.className = "text-[10px] font-bold tracking-widest uppercase text-brand-teal";

        // Update SVG icon representation to unlocked
        if (statusIconWrapper) {
          statusIconWrapper.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 119 0v3.75M3.75 21.75h16.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25zM13.5 15.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
            </svg>
          `;
        }

        // Mock Password Warning pill hide
        capsWarningPill?.classList.remove("flex");
        capsWarningPill?.classList.add("hidden");
      }

      // Log toggle events
      if (prev !== null) {
        logToggleEvent(prev, state);
      }
    }

    // Focus Regain Handler
    // Re-check and correctly update state upon tab focal activation
    function setupFocusCheckers() {
      const verifyStateOnInput = (e: Event) => {
        // Evaluate state from keydown/mousedown/pointerdown modifiers
        if (e instanceof KeyboardEvent) {
          evaluateEventState(e);
        } else if (e instanceof MouseEvent || e instanceof PointerEvent) {
          const capOn = e.getModifierState("CapsLock");
          setCapsLockUIState(capOn);
        }
        
        // Remove temporary trigger checkers
        window.removeEventListener("keydown", verifyStateOnInput);
        window.removeEventListener("mousedown", verifyStateOnInput);
        window.removeEventListener("pointerdown", verifyStateOnInput);
      };

      window.addEventListener("focus", () => {
        // Soften visual style indicating we are waiting to confirm sync status
        statusHint.textContent = "Focus returned. Press any key or click to confirm sync.";
        
        // Bind single use validation listeners
        window.addEventListener("keydown", verifyStateOnInput);
        window.addEventListener("mousedown", verifyStateOnInput);
        window.addEventListener("pointerdown", verifyStateOnInput);
      });
      
      window.addEventListener("blur", () => {
        // Change text slightly showing we are not listening
        statusHint.textContent = "Lost focus. Click here to reactivate tester.";
      });
    }

    // Toggle event logs tracker
    function logToggleEvent(from: boolean, to: boolean) {
      const now = Date.now();
      const diff = lastToggleTime ? now - lastToggleTime : 0;
      lastToggleTime = now;

      toggleCount++;
      statTotalToggles.textContent = String(toggleCount);

      let anomalyStr = "";
      if (diff > 0 && diff < 150) {
        anomalyCount++;
        statAnomalies.textContent = String(anomalyCount);
        statAnomalies.className = "text-xl font-display font-bold text-brand-coral";
        anomalyAlertBox.classList.remove("hidden");
        anomalyStr = " [⚠️ Switch Bounce Anomaly]";
      }

      const timestampStr = new Date().toLocaleTimeString();
      const logEntry: EventLog = {
        time: timestampStr,
        timestamp: now,
        type: 'toggle',
        details: `CapsLock toggled: ${from ? "ON" : "OFF"} ➔ ${to ? "ON" : "OFF"}${anomalyStr}`,
        stateBefore: from,
        stateAfter: to
      };

      eventLogs.unshift(logEntry);
      saveLogs();
      renderLogs();
    }

    // Keystroke Casing Log Tracker
    function logKeyPress(key: string) {
      const timestampStr = new Date().toLocaleTimeString();
      const isSpace = key === " ";
      const displayKey = isSpace ? "Space" : key;
      const charCode = isSpace ? 32 : key.charCodeAt(0);

      const logEntry: EventLog = {
        time: timestampStr,
        timestamp: Date.now(),
        type: 'keypress',
        details: `Key: '${displayKey}' (Casing: ${isSpace ? "N/A" : (key === key.toUpperCase() ? "UPPER" : "lower")}, ASCII: ${charCode})`,
        rawKey: displayKey
      };

      eventLogs.unshift(logEntry);
      saveLogs();
      renderLogs();
    }

    function saveLogs() {
      try {
        localStorage.setItem(STORAGE_KEY_HISTORY, JSON.stringify(eventLogs.slice(0, 100)));
      } catch (e) {
        console.warn("Storage quota exceeded", e);
      }
    }

    // Render Event logs view list
    function renderLogs() {
      if (!logList) return;

      const filtered = eventLogs.filter(log => {
        if (activeLogTab === 'keystroke') return log.type === 'keypress';
        return log.type === 'toggle';
      });

      if (filtered.length === 0) {
        logList.innerHTML = `<div class="text-stone italic text-center py-8">No ${activeLogTab === 'keystroke' ? 'keys logged' : 'toggles registered'} yet...</div>`;
        return;
      }

      logList.innerHTML = filtered.map(log => {
        const itemClass = log.details.includes("⚠️") 
          ? "p-1.5 rounded bg-brand-coral/10 border border-brand-coral/20 text-coral-dark" 
          : "p-1 rounded bg-surface hover:bg-hairline-soft transition-all text-slate border border-transparent";
        return `
          <div class="${itemClass} flex flex-col sm:flex-row sm:justify-between items-start gap-1 text-[10px]">
            <span class="font-semibold break-all">${escapeHtml(log.details)}</span>
            <span class="text-stone text-[9px] shrink-0">${log.time}</span>
          </div>
        `;
      }).join("");
    }

    function escapeHtml(str: string): string {
      return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    // Event log CSV export logic
    function exportToCSV() {
      if (eventLogs.length === 0) {
        alert("No event logs recorded to export yet.");
        return;
      }

      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Timestamp,Time,Event Type,Details\n";

      eventLogs.forEach(log => {
        const row = [
          log.timestamp,
          `"${log.time}"`,
          `"${log.type}"`,
          `"${log.details.replace(/"/g, '""')}"`
        ].join(",");
        csvContent += row + "\n";
      });

      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", "caps_lock_diagnostic_log.csv");
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    // Log type Tab switches
    tabKeystrokes?.addEventListener("click", () => {
      activeLogTab = 'keystroke';
      tabKeystrokes.className = "flex-1 text-center py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabToggles.className = "flex-1 text-center py-1 rounded-full font-bold transition-all cursor-pointer text-slate";
      renderLogs();
    });

    tabToggles?.addEventListener("click", () => {
      activeLogTab = 'toggle';
      tabToggles.className = "flex-1 text-center py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabKeystrokes.className = "flex-1 text-center py-1 rounded-full font-bold transition-all cursor-pointer text-slate";
      renderLogs();
    });

    btnReset?.addEventListener("click", () => {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      // Clear logs
      eventLogs = [];
      localStorage.removeItem(STORAGE_KEY_HISTORY);

      // Clear practice textarea
      if (practiceTextarea) {
        practiceTextarea.value = "";
        typingCounter.textContent = "0 characters";
      }

      // Reset mock password
      if (mockPassword) {
        mockPassword.value = "";
      }

      // Reset stats indicators
      capsLockState = null;
      anomalyCount = 0;
      toggleCount = 0;
      lastToggleTime = 0;

      statTotalToggles.textContent = "0";
      statAnomalies.textContent = "0";
      statAnomalies.className = "text-xl font-display font-bold text-primary";
      anomalyAlertBox.classList.add("hidden");
      capsWarningPill?.classList.add("hidden");
      capsWarningPill?.classList.remove("flex");

      // Reset main card visually
      statusCard.className = "w-full max-w-sm rounded-2xl p-6 flex flex-col items-center justify-center gap-3 transition-all duration-500 shadow-md transform scale-100 bg-surface text-slate";
      statusIconWrapper.className = "w-16 h-16 rounded-full flex items-center justify-center transition-all duration-500 bg-hairline text-slate";
      statusLabel.className = "text-3xl font-display font-bold transition-all duration-500 tracking-tight";
      statusLabel.textContent = "PENDING INPUT";
      statusHint.textContent = "Press any key on your keyboard to detect status.";
      statusHint.className = "text-[10px] text-stone text-center max-w-[200px]";
      statusEyebrow.className = "text-[10px] font-bold tracking-widest uppercase text-stone";
      if (statusIconWrapper) {
        statusIconWrapper.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        `;
      }

      renderLogs();
    });

    // Keyboard Listeners
    window.addEventListener("keydown", evaluateEventState);
    window.addEventListener("keyup", evaluateEventState);

    // Practice typing character counts
    practiceTextarea?.addEventListener("input", () => {
      typingCounter.textContent = `${practiceTextarea.value.length} character${practiceTextarea.value.length === 1 ? "" : "s"}`;
    });

    // Simulated toggle trigger for mobile devices
    simToggleBtn?.addEventListener("click", () => {
      setCapsLockUIState(!capsLockState);
    });

    // CSV exporter trigger
    exportCsvBtn?.addEventListener("click", exportToCSV);

    // Astro SPA navigation cleanup
    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("keydown", evaluateEventState);
      window.removeEventListener("keyup", evaluateEventState);
      window.removeEventListener("resize", handleResize);
    });

    // Initial load
    init();
    }
  </script>

  <!-- FAQ Accordion Toggle Script -->
  <script>
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";

        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });
  </script>
</Layout>
