          <!-- Log Content Scrollbox -->
          <div class="flex-1 overflow-y-auto max-h-[220px] text-[11px] font-mono flex flex-col gap-1.5 pr-1 mt-1" id="log-list">
            <div class="text-stone italic text-center py-8">Waiting for keyboard activity...</div>
