          <h3 class="font-display font-semibold text-xs text-primary uppercase tracking-wider">Session Statistics</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-surface p-2.5 rounded-xl border border-hairline flex flex-col gap-1">
              <span class="text-[9px] text-stone font-bold uppercase">Total Toggles</span>
              <span class="text-xl font-display font-bold text-primary" id="stat-total-toggles">0</span>
            </div>
            <div class="bg-surface p-2.5 rounded-xl border border-hairline flex flex-col gap-1">
              <span class="text-[9px] text-stone font-bold uppercase">Anomalies Detected</span>
              <span class="text-xl font-display font-bold text-primary transition-colors" id="stat-anomalies">0</span>
            </div>
          </div>
          <div id="anomaly-alert-box" class="hidden p-2 bg-brand-coral/10 border border-brand-coral/30 rounded-lg text-[10px] text-coral-dark leading-relaxed">
