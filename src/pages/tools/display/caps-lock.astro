---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Caps Lock Test";
const category = "display";
const tier = "Display & Input Diagnostics";
const pageTitle = "Caps Lock Test - Check If Caps Lock Is On or Off Online";
const description = "Free online caps lock test to check if caps lock is on or off in real-time. Detect caps lock state, log keystrokes, and learn how to turn off caps lock on Chromebook, Windows, and Mac.";
const canonicalUrl = "https://toolkify.com/tools/display/caps-lock";
const ogImage = "/og/caps-lock.png";
const keywords = "caps lock test, what is a caps lock test, what is a caps lock test in typing class, caps lock test 90s, how to turn off caps lock on chromebook, caps lock on chromebook, caps lock, how to turn off caps lock, how to caps lock on chromebook, how to turn caps lock off on chromebook, key above caps lock, caps lock reversed, how to turn caps lock off, how to disable caps lock, caps lock converter";
---

