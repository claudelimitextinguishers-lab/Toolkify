---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Polling Rate Test";
const category = "display";
const tier = "Display & Input Diagnostics";

// On-page SEO metadata
const pageTitle = "Polling Rate Test - Free Online Mouse & Keyboard Polling Rate Checker";
const description = "Free online polling rate test for mouse, keyboard, and controller. Check your mouse polling rate in Hz instantly — no download required. Test 125Hz, 500Hz, 1000Hz, 4000Hz, and 8000Hz polling rate mice online.";
const canonicalUrl = "https://toolkify.app/tools/display/polling-rate";
const ogImage = "/og/polling-rate.png";
const keywords = "polling rate test, mouse polling rate test, polling rate test online, mouse polling rate test online, polling rate test speed, polling rate test controller, keyboard polling rate test online, online mouse polling rate test, what is polling rate on a mouse, polling rate, how to change mouse polling rate, 8k polling rate mouse, what does polling rate do on a mouse, how to change polling rate on mouse, polling rate checker, polling rate meaning";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Polling Rate Test",
      "alternateName": ["Mouse Polling Rate Test", "Polling Rate Checker", "Online Mouse Polling Rate Test", "Keyboard Polling Rate Test Online"],
      "url": "https://toolkify.app/tools/display/polling-rate",
      "description": "Free online polling rate test for mouse, keyboard, and controller. Instantly check your mouse polling rate in Hz, verify report rate consistency, and measure input latency. Supports 125Hz, 500Hz, 1000Hz, 4000Hz, and 8000Hz polling rate mice.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires PointerEvent support.",
      "featureList": [
        "Free online mouse polling rate test — no download required",
        "Polling rate test online for mouse, keyboard, and controller",
        "Real-time Hz measurement using coalesced pointer events for 8K polling rate mice",
        "Polling rate checker with median interval analysis for accurate results",
        "Support for 125Hz, 500Hz, 1000Hz, 4000Hz, and 8000Hz polling rate mice",
        "Detailed statistics: median delay, consistency %, min/max range",
        "Session history log saved locally — 100% client-side and private"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Polling rate is the frequency at which an input device — such as a mouse, keyboard, or controller — reports its current state to the computer. It is measured in Hertz (Hz). A polling rate of 1000Hz means the device sends updates 1000 times per second, resulting in a 1ms report interval. Higher polling rates reduce input latency and provide smoother, more responsive control.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is mouse polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Mouse polling rate is the number of times per second your mouse reports its position to the computer, measured in Hz. A 500Hz mouse sends its coordinates 500 times per second (every 2ms), while a 1000Hz mouse does so 1000 times per second (every 1ms). High-end gaming mice now offer 4000Hz and 8000Hz polling rates for ultra-low input latency.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test mouse polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To test your mouse polling rate online, use this free polling rate test tool. Click \"Start Capture\", then move your mouse in fast, steady circles inside the test box. The tool measures the time intervals between pointer events and calculates your mouse's report rate in Hz. For the most accurate results, move at a consistent speed for the full test duration.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test keyboard polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Testing keyboard polling rate in a browser is limited because browsers throttle keyboard events. Most keyboards report at 125Hz (8ms) or 1000Hz (1ms). To accurately test keyboard polling rate, use dedicated software such as HID latency analyzers or manufacturer utilities. For gaming keyboards, check the product specifications or use the manufacturer's software to verify and adjust the polling rate.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test controller polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Controller polling rate testing can be done through the Gamepad API in modern browsers, though results may be limited by browser and OS scheduling. Most wired controllers (e.g., Xbox, PlayStation) report at 125Hz over USB. Wireless controllers often have higher latency. For accurate controller polling rate measurement, use dedicated tools like the Gamepad Tester or platform-specific diagnostic tools.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to change mouse polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To change your mouse polling rate, use the mouse's companion software (e.g., Logitech G HUB, Razer Synapse, SteelSeries GG, or Corsair iCUE). Open the software, find the performance or polling rate settings, and select your desired Hz value (125Hz, 250Hz, 500Hz, or 1000Hz). Some high-end gaming mice also have a physical button or DPI switch to cycle through polling rates without software.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What polling rate should I use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>For most users, 500Hz or 1000Hz is the optimal polling rate. 1000Hz (1ms) is the standard for competitive gaming as it provides responsive, low-latency input. 500Hz is a good balance for everyday use. Very high polling rates like 4000Hz or 8000Hz may improve feel for professional esports players but can increase CPU usage. If you experience stuttering or high CPU load, try lowering from 8000Hz to 1000Hz.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is polling rate on a keyboard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Polling rate on a keyboard refers to how many times per second the keyboard sends keystroke data to the computer. Most standard keyboards have a polling rate of 125Hz (8ms latency), while gaming keyboards typically offer 1000Hz (1ms latency). Some high-end gaming keyboards now support 2000Hz or 8000Hz polling rates to minimize input lag during fast-paced gameplay.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does polling rate do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Polling rate determines how frequently your input device communicates its state to the computer. A higher polling rate means more frequent updates, which results in lower input latency and smoother cursor or keystroke tracking. In gaming, a higher polling rate helps your actions register faster and more accurately on screen. It does not affect sensor DPI or click response time, only the report frequency.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to lower mouse polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To lower your mouse polling rate, open your mouse's software (Logitech G HUB, Razer Synapse, SteelSeries GG, etc.) and navigate to the performance settings. Select a lower polling rate such as 500Hz, 250Hz, or 125Hz. Lowering the polling rate can reduce CPU usage on older systems and may help with driver compatibility issues. After changing the setting, use this polling rate test tool to verify the new rate.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Is higher polling rate better?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A higher polling rate generally means lower input latency, which can be beneficial for competitive gaming. However, the benefit diminishes above 1000Hz for most users, and ultra-high polling rates (4000Hz, 8000Hz) require more CPU processing power. For casual use, 500Hz is more than sufficient. For competitive gaming, 1000Hz is the sweet spot. 8000Hz is mainly for professional esports players who demand the absolute minimum input delay.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does polling rate matter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, polling rate matters for gaming precision and input responsiveness. Going from 125Hz (8ms) to 1000Hz (1ms) makes a noticeable difference in cursor smoothness and latency. However, the difference between 1000Hz and 8000Hz is much smaller and may not be perceptible in most games. For office work and general browsing, polling rate has minimal practical impact. For competitive gaming, using at least 500Hz or 1000Hz is recommended.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What polling rate do pros use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Most professional esports players use a polling rate of 1000Hz (1ms), which has been the industry standard for competitive gaming for over a decade. Some pros playing titles like Valorant or CS2 have started using 2000Hz or 4000Hz mice from brands like Razer (HyperPolling), Logitech (HERO sensors), and Pulsar. The exact polling rate choice depends on the game engine, system specs, and personal preference.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Is 1000Hz polling rate good?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, 1000Hz polling rate is excellent and is the gold standard for gaming mice. At 1000Hz, the mouse reports its position every 1 millisecond, providing very low input latency and smooth cursor tracking. It is more than sufficient for all types of gaming, including competitive FPS, MOBA, and RTS titles. Most gaming mice support 1000Hz natively, and it is the most widely recommended polling rate for serious gamers.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to change polling rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To change polling rate on your mouse or keyboard, follow these steps: 1) Install the manufacturer's software (e.g., Logitech G HUB, Razer Synapse, SteelSeries GG, Corsair iCUE, or ASUS Armoury Crate). 2) Connect your device and open the software. 3) Find the \"Polling Rate\" or \"Report Rate\" setting under Performance or Advanced settings. 4) Select your desired polling rate (125Hz, 250Hz, 500Hz, 1000Hz, 2000Hz, 4000Hz, or 8000Hz). 5) Apply and save. Then use this free polling rate test to confirm the change.</p>"
          }
        }
      ]
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Tools",
          "item": "https://toolkify.app/tools"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Display",
          "item": "https://toolkify.app/tools/display"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Polling Rate Test",
          "item": "https://toolkify.app/tools/display/polling-rate"
        }
      ]
    }
  </script>

  <section
    class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2">
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How polling rate test works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Friendly warning for Touch-Only devices -->
    <div
      id="touch-warning-banner"
      class="hidden p-3 rounded-lg border border-brand-yellow-deep/50 bg-surface-yellow text-xs text-yellow-dark leading-relaxed flex items-center justify-between animate-fade-in print:hidden"
    >
      <div class="flex items-center gap-2">
        <span>⚠️</span>
        <span>
          <strong>Touch-Only Device Detected:</strong> This test is designed to measure physical mouse report intervals. Touch interfaces coalesce/filter inputs differently and won't show accurate hardware polling rates. Connect a physical mouse to begin.
        </span>
      </div>
      <button
        type="button"
        id="dismiss-warning-btn"
        class="text-xs font-bold px-2 py-0.5 rounded-full hover:bg-yellow-light/50 border border-transparent hover:border-yellow-dark/30 transition-all cursor-pointer"
      >
        Dismiss
      </button>
    </div>

    <!-- Accuracy mode status badge banner -->
    <div
      id="accuracy-banner"
      class="p-2.5 rounded-lg border flex items-center justify-between text-[11px] transition-all duration-300 bg-surface border-hairline text-slate print:hidden"
    >
      <span id="accuracy-msg" class="font-semibold flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-slate"></span>
        Detecting support...
      </span>
      <span class="font-mono text-[9px] text-stone">Method: Feature-detecting getCoalescedEvents</span>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 items-stretch relative">
      <!-- Controls & Live Statistics (Column 1: 4 cols on lg, 3 cols on xl) -->
      <div class="lg:col-span-4 xl:col-span-3 flex flex-col gap-3">
        <div class="card-base p-3 flex flex-col gap-3 h-full justify-between">
          <div class="flex flex-col gap-3">
            <h2 class="font-display font-semibold text-xs text-primary flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-blue animate-pulse"></span>
              Live Diagnostics
            </h2>

            <!-- Stats grid -->
            <div class="grid grid-cols-2 gap-2">
              <!-- Live Hz display -->
              <div class="p-2.5 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center col-span-2 relative overflow-hidden group">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Live Polling Rate</span>
                <span id="live-hz" class="text-3xl font-display font-medium text-brand-blue tracking-tight">0 <span class="text-xs text-slate">Hz</span></span>
                <span id="live-hz-subtext" class="text-[9px] text-stone">Move mouse to start</span>
              </div>

              <!-- Median Interval -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Median Delay</span>
                <span id="median-delay" class="text-xs font-bold text-primary">0.00 ms</span>
                <span class="text-[8px] text-stone">Target report</span>
              </div>

              <!-- Consistency % -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Consistency</span>
                <span id="stability-pct" class="text-xs font-bold text-primary">0.0%</span>
                <span class="text-[8px] text-stone">Interval stability</span>
              </div>

              <!-- Minimum observed delay -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Min / Max Delay</span>
                <span id="delay-min-max" class="text-[10px] font-bold text-primary">0.0 / 0.0 ms</span>
                <span class="text-[8px] text-stone">Range limits</span>
              </div>

              <!-- Total Events -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Samples</span>
                <span id="event-counter" class="text-[10px] font-bold text-primary">0</span>
                <span class="text-[8px] text-stone">Pointer reports</span>
              </div>
            </div>

            <!-- Movement Speed indicator -->
            <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-1.5">
              <div class="flex items-center justify-between">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Speed Threshold</span>
                <span id="speed-status" class="text-[8px] font-bold text-coral-dark bg-brand-coral/40 px-1.5 py-0.5 rounded-full">TOO SLOW</span>
              </div>
              <div class="relative w-full h-1.5 bg-hairline rounded-full overflow-hidden">
                <div id="speed-bar" class="absolute top-0 left-0 h-full bg-brand-teal transition-all duration-100" style="width: 0%"></div>
              </div>
            </div>
          </div>

          <!-- Test Duration Selector -->
          <div class="flex flex-col gap-1.5">
            <div class="flex items-center justify-between">
              <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Duration</span>
              <span id="duration-countdown" class="text-[9px] font-mono font-bold text-brand-blue hidden">--</span>
            </div>
            <div class="grid grid-cols-3 gap-1" id="duration-btns" role="radiogroup" aria-label="Test duration">
              <button type="button" data-duration="5" class="duration-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer">5s</button>
              <button type="button" data-duration="10" class="duration-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer duration-active">10s</button>
              <button type="button" data-duration="15" class="duration-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer">15s</button>
              <button type="button" data-duration="30" class="duration-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer">30s</button>
              <button type="button" data-duration="60" class="duration-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer">60s</button>
              <button type="button" data-duration="0" class="duration-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer">∞ Free</button>
            </div>
          </div>

          <!-- Quick Test Capture Triggers -->
          <div class="flex flex-col gap-1.5">
            <button
              type="button"
              id="start-stop-btn"
              class="w-full button-primary text-xs py-2 px-4 !rounded-full shadow-subtle hover:scale-[1.02] active:scale-95 transition-all cursor-pointer font-bold text-center flex items-center justify-center gap-1.5"
            >
              <span id="start-stop-icon">▶</span>
              <span id="start-stop-text">Start Capture</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Test Area & Canvas Visualizer (Column 2: 5 cols on lg, 6 cols on xl) -->
      <div class="lg:col-span-5 xl:col-span-6 flex flex-col gap-3">
        <!-- Interactive Test Zone Card -->
        <div id="test-zone" class="card-base flex-1 min-h-[300px] h-[340px] lg:h-[380px] p-4 flex flex-col items-center justify-center border-2 border-dashed border-hairline-strong bg-canvas hover:border-brand-blue/50 transition-colors select-none relative group cursor-crosshair overflow-hidden">
          <canvas id="trail-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>

          <!-- Countdown overlay inside test zone -->
          <div id="zone-countdown-overlay" class="absolute top-4 right-4 z-20 pointer-events-none hidden">
            <div class="flex flex-col items-center bg-canvas/80 backdrop-blur-sm border border-brand-blue/40 rounded-2xl px-3 py-1.5 shadow-lg">
              <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Time Left</span>
              <span id="zone-countdown-value" class="text-2xl font-display font-bold text-brand-blue tabular-nums">10</span>
              <span class="text-[9px] text-stone">seconds</span>
            </div>
          </div>

          <!-- Progress arc overlay -->
          <div id="zone-progress-bar" class="absolute bottom-0 left-0 right-0 h-1 pointer-events-none hidden">
            <div id="zone-progress-fill" class="h-full bg-brand-blue/70 transition-all duration-1000 ease-linear" style="width: 100%"></div>
          </div>

          <div id="test-zone-instructions" class="pointer-events-none flex flex-col items-center text-center gap-2 z-10 transition-opacity duration-300">
            <div class="text-3xl animate-bounce">🖱️</div>
            <div class="flex flex-col gap-1">
              <h3 class="font-display font-medium text-sm sm:text-base text-primary">Mouse Polling Rate Test Box</h3>
              <p class="text-xs text-slate max-w-sm leading-relaxed">
                Click <strong class="text-brand-blue">Start Capture</strong>, then move your mouse in fast, steady circles inside this box.
              </p>
            </div>
          </div>
        </div>

        <!-- Reference values / chips (more compact) -->
        <div class="card-base p-3 flex flex-col gap-2">
