        <div class="card-base p-3 flex flex-col gap-3 h-full justify-between">
          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between border-b border-hairline-soft pb-2">
              <h3 class="font-display font-semibold text-xs text-primary flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-slate"></span>
                History
              </h3>
              <div class="flex items-center gap-1.5">
