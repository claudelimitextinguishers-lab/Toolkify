              <span class="text-[8px] text-stone">1.0 ms</span>
            </div>
            <div class="p-1 border border-hairline rounded bg-surface flex flex-col items-center">
              <span class="text-[10px] font-bold text-primary">4000 Hz</span>
              <span class="text-[8px] text-stone">0.25 ms</span>
            </div>
            <div class="p-1 border border-hairline rounded bg-surface flex flex-col items-center">
              <span class="text-[10px] font-bold text-primary">8000 Hz</span>
