---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Polling Rate Test";
const category = "display";
const tier = "Display & Input Diagnostics";

// On-page SEO metadata
const pageTitle = "Mouse Polling Rate Test - Measure Mouse Hz & Stability";
const description = "Free online browser mouse polling rate test. Measure mouse event frequency in Hz, capture coalesced pointer events, and verify report rate consistency.";
const canonicalUrl = "https://boardtools.app/tools/display/polling-rate";
const ogImage = "/og/polling-rate.png";
const keywords = "polling rate test, mouse hz test, mouse rate tester, mouse response time, check mouse polling rate, browser mouse rate, coalesced pointer events, gaming mouse check, response rate test";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Mouse Polling Rate Test",
      "alternateName": "Mouse Hz Analyzer",
      "url": "https://boardtools.app/tools/display/polling-rate",
      "description": "Measure and analyze mouse reporting rate and event intervals in real-time. Features coalesced pointer event capture for high-frequency gaming mice.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires PointerEvent support.",
      "featureList": [
        "Real-time mouse pointer event frequency calculation (Hz)",
        "Support for PointerEvent.getCoalescedEvents() for high-rate gaming mice",
        "Visual feedback trail using high-performance HTML5 Canvas",
        "Consistent/Stabilized Hz calculation using median interval analysis",
        "Detailed statistical readout (Median, Standard Deviation, Consistency %)",
        "Session-based history log saved locally",
        "100% secure client-side execution"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://boardtools.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Tools",
          "item": "https://boardtools.app/tools"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Display",
          "item": "https://boardtools.app/tools/display"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Polling Rate Test",
          "item": "https://boardtools.app/tools/display/polling-rate"
        }
      ]
    }
  </script>

  <section
    class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0"
