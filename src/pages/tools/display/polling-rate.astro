    </div>
  </section>

  <!-- Educational Article -->
  <section
    class="max-w-[760px] w-full mx-auto px-4 pb-20 flex flex-col gap-8 text-slate print:hidden"
    aria-labelledby="about-tool-heading"
  >
    <article class="flex flex-col gap-4">
      <h2
        id="about-tool-heading"
        class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight"
      >
        Understanding Mouse Polling Rates & Browser Throttling
      </h2>
      <p class="text-sm leading-relaxed">
        A mouse's polling rate (or report rate) determines how frequently it sends its current position coordinates to the computer. Measured in Hertz (Hz), higher polling rates like 1000Hz, 4000Hz, or 8000Hz represent lower input lag (1ms down to 0.125ms), which is crucial for competitive gaming.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Why Standard Browser mousemove is Throttled
      </h3>
      <p class="text-sm leading-relaxed">
        Standard web browsers batch coordinates changes to match the screen's refresh cycle. In engines like Safari or Firefox, the standard <code>mousemove</code> event will fire only as fast as the monitor refreshes (e.g. 60Hz or 144Hz), even if you have a 1000Hz gaming mouse. To bypass this, Chromium-based browsers support <code>PointerEvent.getCoalescedEvents()</code>, which retrieves the fine-grained events generated by the OS between animation frames.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        How the Calculations Work
      </h3>
      <p class="text-sm leading-relaxed">
        This tool monitors coordinates updates and calculates the duration (delta time) between successive events. Pauses and low velocities are excluded. The tool then calculates the median interval from all captured events. The final estimated polling rate is calculated as: <code>1000 / median interval</code>. Median is utilized over mean averages to eliminate occasional system-level micro-stuts and scheduling hiccups from skewing the final result.
      </p>
    </article>
  </section>

  <!-- How it works Modal copied verbatim pattern from json-formatter.astro -->
  <div
    id="how-it-works-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div
      class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto"
    >
      <div
        class="flex justify-between items-center pb-2 border-b border-hairline-soft"
      >
        <h3 class="font-display font-semibold text-lg text-primary">
          Polling Rate Test Guide
        </h3>
        <button
          type="button"
          id="close-modal-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >
          ✕
        </button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">
          1. What is Mouse Polling Rate?
        </h4>
        <p>
          Polling rate is the frequency at which the mouse reports its position data to the computer, measured in Hz. A 1000Hz polling rate means the mouse sends updates 1000 times per second (once every 1ms).
        </p>

        <h4 class="font-semibold text-primary">2. The Browser Coalescing Limitation</h4>
        <p>
          Web browsers typically throttle mouse events to match the screen's refresh cycle to save processing power. To solve this, this tool utilizes <code>PointerEvent.getCoalescedEvents()</code> to fetch true OS-level pointer messages, allowing precision measurement on supported browsers.
        </p>

        <h4 class="font-semibold text-primary">3. How to get an Accurate Test</h4>
        <p>
          To get a high-quality readout, you must move your mouse rapidly and consistently in circular patterns inside the test box. Slow movements do not saturate the report rate and will result in lower, inaccurate readings.
        </p>
      </div>
      <button
        type="button"
        id="modal-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
      </button>
    </div>
  </div>

  <script>
    // Interfaces
    interface TestRun {
      timestamp: number;
      rate: number;
      medianDelay: number;
      consistency: number;
      mode: string;
      status: string;
    }

    // State Variables
    let isCapturing = false;
    let eventTimestamps: number[] = [];
    let intervals: number[] = [];
    let trailPoints: Array<{ x: number; y: number; time: number }> = [];
    let lastX = 0;
    let lastY = 0;
    let lastTime = 0;
    let methodSupported = "Standard mode: mousemove throttled by browser";
    let coalescedCount = 0;

    // Duration state
    let selectedDurationSec = 10; // default 10 sec
    let captureStartTime = 0;
    let countdownTimer: ReturnType<typeof setInterval> | null = null;

    // DOM Elements
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;
    
    const touchWarningBanner = document.getElementById("touch-warning-banner") as HTMLDivElement;
    const dismissWarningBtn = document.getElementById("dismiss-warning-btn") as HTMLButtonElement;
    
    const accuracyBanner = document.getElementById("accuracy-banner") as HTMLDivElement;
    const accuracyMsg = document.getElementById("accuracy-msg") as HTMLSpanElement;
    
    const testZone = document.getElementById("test-zone") as HTMLDivElement;
    const instructions = document.getElementById("test-zone-instructions") as HTMLDivElement;
    const trailCanvas = document.getElementById("trail-canvas") as HTMLCanvasElement;
    
    const startStopBtn = document.getElementById("start-stop-btn") as HTMLButtonElement;
    const startStopIcon = document.getElementById("start-stop-icon") as HTMLSpanElement;
    const startStopText = document.getElementById("start-stop-text") as HTMLSpanElement;
    
    // Stats Readouts
    const liveHz = document.getElementById("live-hz") as HTMLSpanElement;
    const liveHzSubtext = document.getElementById("live-hz-subtext") as HTMLSpanElement;
    const medianDelay = document.getElementById("median-delay") as HTMLSpanElement;
    const stabilityPct = document.getElementById("stability-pct") as HTMLSpanElement;
    const delayMinMax = document.getElementById("delay-min-max") as HTMLSpanElement;
    const eventCounter = document.getElementById("event-counter") as HTMLSpanElement;
    const speedStatus = document.getElementById("speed-status") as HTMLSpanElement;
    const speedBar = document.getElementById("speed-bar") as HTMLDivElement;
    
    const historyTbody = document.getElementById("history-tbody") as HTMLTableSectionElement;
    const exportBtn = document.getElementById("export-btn") as HTMLButtonElement;
    const clearHistoryBtn = document.getElementById("clear-history-btn") as HTMLButtonElement;

    // Duration UI
    const durationCountdown = document.getElementById("duration-countdown") as HTMLSpanElement;
    const zoneCountdownOverlay = document.getElementById("zone-countdown-overlay") as HTMLDivElement;
    const zoneCountdownValue = document.getElementById("zone-countdown-value") as HTMLSpanElement;
    const zoneProgressBar = document.getElementById("zone-progress-bar") as HTMLDivElement;
    const zoneProgressFill = document.getElementById("zone-progress-fill") as HTMLDivElement;
    const durationBtns = document.querySelectorAll<HTMLButtonElement>(".duration-btn");

    // Wire up duration buttons
    durationBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        if (isCapturing) return; // lock while running
        durationBtns.forEach(b => b.classList.remove("duration-active"));
        btn.classList.add("duration-active");
        selectedDurationSec = Number(btn.dataset.duration);
        if (selectedDurationSec === 0) {
          startStopText.textContent = "Start Capture (Free)";
        } else {
          startStopText.textContent = `Start ${selectedDurationSec}s Capture`;
        }
      });
    });

    // Apply initial active style to the default button (10 sec)
    (document.querySelector(".duration-btn[data-duration='10']") as HTMLButtonElement)?.classList.add("duration-active");
    startStopText.textContent = "Start 10s Capture";

    // LocalStorage Keys
    const LS_KEY_HISTORY = "boardtools:polling-rate:history";

    // Setup Canvas context
    const ctx = trailCanvas.getContext("2d");
    
    function resizeCanvas() {
      if (!trailCanvas) return;
      const rect = trailCanvas.getBoundingClientRect();
      trailCanvas.width = rect.width * window.devicePixelRatio;
      trailCanvas.height = rect.height * window.devicePixelRatio;
      if (ctx) {
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
      }
    }
    
    window.addEventListener("resize", resizeCanvas);
    resizeCanvas();

    // Check features
    function detectFeatures() {
      if (typeof PointerEvent.prototype.getCoalescedEvents === "function") {
        methodSupported = "High-accuracy mode: coalesced events";
        accuracyBanner.classList.add("bg-success-accent/10", "border-success-accent/40", "text-success-accent");
        accuracyMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-success-accent animate-pulse"></span>High-accuracy mode: coalesced events active`;
      } else {
        methodSupported = "Standard mode: mousemove throttled by browser";
        accuracyBanner.classList.add("bg-surface-yellow", "border-yellow-light/80", "text-yellow-dark");
        accuracyMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-yellow-dark animate-pulse"></span>Standard mode: mousemove throttled by browser`;
      }
      
      // Detect touch screen
      if (window.matchMedia("(pointer: coarse)").matches) {
        touchWarningBanner.classList.remove("hidden");
      }
    }
    detectFeatures();

    // Event handlers for How it works modal
    howItWorksBtn.addEventListener("click", () => {
      howItWorksModal.classList.remove("hidden");
    });
    
    const closeModal = () => {
      howItWorksModal.classList.add("hidden");
    };
    
    closeModalBtn.addEventListener("click", closeModal);
    modalOkBtn.addEventListener("click", closeModal);
    howItWorksModal.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) closeModal();
    });
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });

    dismissWarningBtn.addEventListener("click", () => {
      touchWarningBanner.classList.add("hidden");
    });

    // Start/Stop Control
    startStopBtn.addEventListener("click", toggleCapture);

    function toggleCapture() {
      if (!isCapturing) {
        startCapture();
      } else {
        stopCapture();
      }
    }

    function startCapture() {
      isCapturing = true;
      eventTimestamps = [];
      intervals = [];
      trailPoints = [];
      coalescedCount = 0;
      lastTime = performance.now();
      captureStartTime = Date.now();
      
      startStopIcon.textContent = "⏹";
      startStopText.textContent = "Stop Capture";
      startStopBtn.classList.remove("button-primary");
      startStopBtn.classList.add("bg-brand-coral", "text-coral-dark", "hover:bg-coral-light");
      
      // Lock duration buttons during capture
      durationBtns.forEach(b => b.setAttribute("disabled", "true"));
      
      instructions.classList.add("opacity-25");
      testZone.classList.remove("border-dashed");
      testZone.classList.add("border-solid", "border-brand-blue", "shadow-lg", "shadow-brand-blue/10");
      
      resizeCanvas();

      // Show/hide countdown widgets
      if (selectedDurationSec > 0) {
        durationCountdown.textContent = `${selectedDurationSec}s`;
        durationCountdown.classList.remove("hidden");
        zoneCountdownOverlay.classList.remove("hidden");
        zoneProgressBar.classList.remove("hidden");
        zoneCountdownValue.textContent = String(selectedDurationSec);
        zoneProgressFill.style.transition = "none";
        zoneProgressFill.style.width = "100%";

        // Kick off the shrink animation after a tick
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            zoneProgressFill.style.transition = `width ${selectedDurationSec}s linear`;
            zoneProgressFill.style.width = "0%";
          });
        });

        let remaining = selectedDurationSec;
        countdownTimer = setInterval(() => {
          remaining--;
          zoneCountdownValue.textContent = String(remaining);
          durationCountdown.textContent = `${remaining}s`;
          if (remaining <= 0) {
            if (countdownTimer !== null) clearInterval(countdownTimer);
            stopCapture();
          }
        }, 1000);
      } else {
        // Free mode — hide countdown
        durationCountdown.classList.add("hidden");
        zoneCountdownOverlay.classList.add("hidden");
        zoneProgressBar.classList.add("hidden");
      }
    }

    function stopCapture() {
      if (!isCapturing) return;
      isCapturing = false;

      if (countdownTimer !== null) {
        clearInterval(countdownTimer);
        countdownTimer = null;
      }
      
      startStopIcon.textContent = "▶";
      const label = selectedDurationSec > 0 ? `Start ${selectedDurationSec}s Capture` : "Start Capture (Free)";
      startStopText.textContent = label;
      startStopBtn.classList.add("button-primary");
      startStopBtn.classList.remove("bg-brand-coral", "text-coral-dark", "hover:bg-coral-light");

      // Unlock duration buttons
      durationBtns.forEach(b => b.removeAttribute("disabled"));
      
      // Hide countdown widgets
      durationCountdown.classList.add("hidden");
      zoneCountdownOverlay.classList.add("hidden");
      zoneProgressBar.classList.add("hidden");
      
      instructions.classList.remove("opacity-25");
      testZone.classList.add("border-dashed");
      testZone.classList.remove("border-solid", "border-brand-blue", "shadow-lg", "shadow-brand-blue/10");
      
      saveRunToHistory();
    }

    // Reset button contract (verbatim callback trigger)
    resetBtn.addEventListener("click", () => {
      stopCapture();
      // Clear variables
      eventTimestamps = [];
      intervals = [];
      trailPoints = [];
      coalescedCount = 0;
      smoothHz = 0;
      
      // Reset UI
      liveHz.innerHTML = `0 <span class="text-xs text-slate">Hz</span>`;
      liveHzSubtext.textContent = "Move mouse to start measuring";
      medianDelay.textContent = "0.00 ms";
      stabilityPct.textContent = "0.0%";
      delayMinMax.textContent = "0.0 / 0.0 ms";
      eventCounter.textContent = "0";
      speedStatus.textContent = "TOO SLOW";
      speedStatus.className = "text-[9px] font-bold text-coral-dark bg-brand-coral/40 px-1.5 py-0.5 rounded-full";
      speedBar.style.width = "0%";
      
      if (ctx && trailCanvas) {
        ctx.clearRect(0, 0, trailCanvas.width, trailCanvas.height);
      }
      
      // Clear localStorage
      localStorage.removeItem(LS_KEY_HISTORY);
      renderHistory();
    });

    // Core Hz and pointer handler
    testZone.addEventListener("pointermove", (e: PointerEvent) => {
      if (!isCapturing) return;
      
      const now = performance.now();
      const rect = testZone.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      // Add visual points for trail
      trailPoints.push({ x, y, time: now });
      
      // Filter out points older than 300ms
      trailPoints = trailPoints.filter(p => now - p.time < 300);

      // Handle coalesced events for precision
      let events: PointerEvent[] = [];
      if (typeof e.getCoalescedEvents === "function") {
        events = e.getCoalescedEvents();
      } else {
        events = [e];
      }
      
      coalescedCount += events.length;

      // Extract intervals
      events.forEach((ev) => {
        const t = ev.timeStamp; // high precision browser timestamp
        
        if (eventTimestamps.length > 0) {
          const dt = t - eventTimestamps[eventTimestamps.length - 1];
          // Filter out pauses / idle frames (any interval > 100ms)
          if (dt > 0.01 && dt < 100) {
            intervals.push(dt);
          }
        }
        eventTimestamps.push(t);
      });

      // Calculate speed
      const dt = now - lastTime;
      if (dt > 0) {
        const dx = x - lastX;
        const dy = y - lastY;
        const speed = Math.sqrt(dx * dx + dy * dy) / dt; // pixels per ms
        
        // Speed bar display (relative to a target speed of 3 pixels/ms)
        const pct = Math.min(100, (speed / 3) * 100);
        speedBar.style.width = `${pct}%`;
        
        if (speed > 1.2) {
          speedStatus.textContent = "OPTIMAL";
          speedStatus.className = "text-[9px] font-bold text-success-accent bg-success-accent/10 px-1.5 py-0.5 rounded-full";
        } else {
          speedStatus.textContent = "TOO SLOW";
          speedStatus.className = "text-[9px] font-bold text-coral-dark bg-brand-coral/40 px-1.5 py-0.5 rounded-full";
        }
        
        lastX = x;
        lastY = y;
      }
      lastTime = now;
    });

    // RAF loop for smooth UI updates
    let lastRenderTime = 0;
    let smoothHz = 0;
    
    function animate(timestamp: number) {
      requestAnimationFrame(animate);
      
      const now = performance.now();
      
      // 1. Draw cursor trail
      if (ctx && trailCanvas) {
        ctx.clearRect(0, 0, trailCanvas.width / window.devicePixelRatio, trailCanvas.height / window.devicePixelRatio);
        
        const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        
        if (prefersReduced) {
          // Draw only a single point
          if (trailPoints.length > 0) {
            const last = trailPoints[trailPoints.length - 1];
            ctx.beginPath();
            ctx.arc(last.x, last.y, 6, 0, Math.PI * 2);
            ctx.fillStyle = "#4262ff";
            ctx.fill();
          }
        } else if (trailPoints.length > 1) {
          ctx.beginPath();
          ctx.moveTo(trailPoints[0].x, trailPoints[0].y);
          
          for (let i = 1; i < trailPoints.length; i++) {
            const p = trailPoints[i];
            const age = now - p.time;
            const alpha = Math.max(0, 1 - age / 300);
            
            ctx.lineTo(p.x, p.y);
            ctx.strokeStyle = `rgba(66, 98, 255, ${alpha * 0.7})`;
            ctx.lineWidth = 3 * alpha;
            ctx.stroke();
            
            // Start path for next segment to allow fading opacity
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
          }
        }
      }

      // 2. Throttle text/DOM stats recalculation to ~60ms intervals for performance
      if (now - lastRenderTime < 60) return;
      lastRenderTime = now;
      
      if (!isCapturing || intervals.length < 5) return;

      // Make a copy and sort to get statistics
      const sorted = [...intervals].sort((a, b) => a - b);
      const medianIdx = Math.floor(sorted.length / 2);
      const medianVal = sorted.length % 2 !== 0 
        ? sorted[medianIdx] 
        : (sorted[medianIdx - 1] + sorted[medianIdx]) / 2;
      
      if (medianVal <= 0) return;

      const rawHz = 1000 / medianVal;
      
      // Rolling average smoothing for live display
      smoothHz = smoothHz === 0 ? rawHz : smoothHz * 0.85 + rawHz * 0.15;
      
      // Calculate stability consistency (% of intervals within 15% of median)
      const margin = medianVal * 0.15;
      const consistentCount = intervals.filter(val => Math.abs(val - medianVal) <= margin).length;
      const consistency = (consistentCount / intervals.length) * 100;
      
      // Delay min/max
      const minVal = sorted[0];
      const maxVal = sorted[sorted.length - 1];

      // Update UI
      liveHz.innerHTML = `${Math.round(smoothHz)} <span class="text-xs text-slate">Hz</span>`;
      liveHzSubtext.textContent = `Smoothing active (${Math.round(rawHz)} Hz raw)`;
      medianDelay.textContent = `${medianVal.toFixed(2)} ms`;
      stabilityPct.textContent = `${consistency.toFixed(1)}%`;
      delayMinMax.textContent = `${minVal.toFixed(1)} / ${maxVal.toFixed(1)} ms`;
      eventCounter.textContent = coalescedCount.toString();
    }
    requestAnimationFrame(animate);

    // Save and history
    function saveRunToHistory() {
      if (intervals.length < 15) return;
      
      const sorted = [...intervals].sort((a, b) => a - b);
      const medianIdx = Math.floor(sorted.length / 2);
      const medianVal = sorted.length % 2 !== 0 
        ? sorted[medianIdx] 
        : (sorted[medianIdx - 1] + sorted[medianIdx]) / 2;
        
      const rawHz = Math.round(1000 / medianVal);
      const margin = medianVal * 0.15;
      const consistentCount = intervals.filter(val => Math.abs(val - medianVal) <= margin).length;
      const consistency = Math.round((consistentCount / intervals.length) * 100);

      const run: TestRun = {
        timestamp: Date.now(),
        rate: rawHz,
        medianDelay: Number(medianVal.toFixed(2)),
        consistency,
        mode: methodSupported.includes("coalesced") ? "Coalesced" : "Standard",
        status: consistency > 85 ? "Excellent" : consistency > 60 ? "Good" : "Unstable"
      };

      const history = getHistory();
      history.unshift(run);
      localStorage.setItem(LS_KEY_HISTORY, JSON.stringify(history.slice(0, 10)));
      renderHistory();
    }

    function getHistory(): TestRun[] {
      const stored = localStorage.getItem(LS_KEY_HISTORY);
      if (!stored) return [];
      try {
        return JSON.parse(stored);
      } catch (e) {
        return [];
      }
    }

    function renderHistory() {
      const history = getHistory();
      if (history.length === 0) {
        historyTbody.innerHTML = `
          <tr>
            <td colspan="4" class="py-4 px-1 text-center text-stone italic">No tests saved.</td>
          </tr>
        `;
        return;
      }

      historyTbody.innerHTML = history.map(item => `
        <tr class="border-b border-hairline-soft hover:bg-surface/40">
          <td class="py-1.5 px-1 font-bold text-primary">${item.rate} Hz</td>
          <td class="py-1.5 px-1 text-right font-mono">${item.medianDelay} ms</td>
          <td class="py-1.5 px-1 text-right font-mono">${item.consistency}%</td>
          <td class="py-1.5 px-1 text-right">
            <span class="px-1.5 py-0.5 rounded text-[9px] font-semibold ${
              item.status === "Excellent" ? "bg-success-accent/10 text-success-accent" : 
              item.status === "Good" ? "bg-brand-blue/10 text-brand-blue" : "bg-brand-coral/10 text-coral-dark"
            }">${item.status}</span>
          </td>
        </tr>
      `).join("");
    }
    
    // Export summary to clipboard
    exportBtn.addEventListener("click", () => {
      const history = getHistory();
      if (history.length === 0) {
        alert("No history to copy.");
        return;
      }
      
      let text = "BoardTools Polling Rate Test Results Summary:\n";
      text += "=========================================\n";
      history.forEach((run, i) => {
        text += `Run #${i + 1}: ${run.rate}Hz | Median: ${run.medianDelay}ms | Consistency: ${run.consistency}% | Mode: ${run.mode} | Status: ${run.status}\n`;
      });
      
      navigator.clipboard.writeText(text).then(() => {
        alert("Summary copied to clipboard!");
      }).catch(err => {
        console.error("Failed to copy", err);
      });
    });

    clearHistoryBtn.addEventListener("click", () => {
      localStorage.removeItem(LS_KEY_HISTORY);
      renderHistory();
    });

    // Initial render
    renderHistory();
  </script>

  <style>
    /* Duration selector active state */
    .duration-btn.duration-active {
      background-color: var(--color-surface-pricing-featured, oklch(0.92 0.03 250));
      border-color: var(--color-brand-blue, oklch(0.55 0.22 265));
      color: var(--color-brand-blue, oklch(0.55 0.22 265));
      font-weight: 700;
    }
    .duration-btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      pointer-events: none;
    }
  </style>
</Layout>
