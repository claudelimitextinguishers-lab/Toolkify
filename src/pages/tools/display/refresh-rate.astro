  <script>
    if (typeof window !== 'undefined') {
    // Interfaces
    interface RefreshRun {
      timestamp: number;
      rate: number;
      medianDelay: number;
      jitter: number;
      dropped: number;
    }

    // State Variables
    let isTesting = false;
    let isContinuous = false;
    let frameTimestamps: number[] = [];
    let frameIntervals: number[] = [];
    let lastFrameTime = 0;
    
    let activeDriver: 'bar' | 'block' | 'none' = 'bar';
    let isFullscreenMode = false;
    let testStartTime = 0;
    let quickTestDuration = 3000; // 3 seconds
    let rafId = 0;
    
    // Animation driver state variables
    let barX = 0;
    let barDirection = 1;
    let blockX = 10;
    let blockY = 10;
    let blockDx = 2.5;
    let blockDy = 2.5;
    
    // LocalStorage Keys
    const LS_KEY_HISTORY = "toolkify:refresh-rate:history";

    // DOM Elements
    const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
    const headerShareBtn = document.getElementById("share-btn");
    const howItWorksBtn = document.getElementById("how-it-works-btn") as HTMLButtonElement;
    const howItWorksModal = document.getElementById("how-it-works-modal") as HTMLDivElement;
    const closeModalBtn = document.getElementById("close-modal-btn") as HTMLButtonElement;
    const modalOkBtn = document.getElementById("modal-ok-btn") as HTMLButtonElement;
    
    const startStopBtn = document.getElementById("start-stop-btn") as HTMLButtonElement;
    const startStopIcon = document.getElementById("start-stop-icon") as HTMLSpanElement;
    const startStopText = document.getElementById("start-stop-text") as HTMLSpanElement;
    
    const fullscreenBtn = document.getElementById("fullscreen-btn") as HTMLButtonElement;
    const fullscreenOverlay = document.getElementById("fullscreen-overlay") as HTMLDivElement;
    
    const modeQuickBtn = document.getElementById("mode-quick-btn") as HTMLButtonElement;
    const modeContBtn = document.getElementById("mode-cont-btn") as HTMLButtonElement;
    const driverBtns = document.querySelectorAll<HTMLButtonElement>(".driver-btn");
    
    // Stats elements
    const liveHz = document.getElementById("live-hz") as HTMLSpanElement;
    const liveHzSubtext = document.getElementById("live-hz-subtext") as HTMLSpanElement;
    const medianInterval = document.getElementById("median-interval") as HTMLSpanElement;
    const sdVal = document.getElementById("sd-val") as HTMLSpanElement;
    const droppedCounter = document.getElementById("dropped-counter") as HTMLSpanElement;
    const sampleCounter = document.getElementById("sample-counter") as HTMLSpanElement;
    
    const zoneCountdownOverlay = document.getElementById("zone-countdown-overlay") as HTMLDivElement;
    const zoneCountdownValue = document.getElementById("zone-countdown-value") as HTMLSpanElement;
    const zoneProgressBar = document.getElementById("zone-progress-bar") as HTMLDivElement;
    const zoneProgressFill = document.getElementById("zone-progress-fill") as HTMLDivElement;
    
    const testZone = document.getElementById("test-zone") as HTMLDivElement;
    const instructions = document.getElementById("test-zone-instructions") as HTMLDivElement;
    const pacingCanvas = document.getElementById("pacing-canvas") as HTMLCanvasElement;
    const troubleshootPanel = document.getElementById("troubleshoot-panel") as HTMLDivElement;
    
    const historyTbody = document.getElementById("history-tbody") as HTMLTableSectionElement;
    const exportBtn = document.getElementById("export-btn") as HTMLButtonElement;
    const clearHistoryBtn = document.getElementById("clear-history-btn") as HTMLButtonElement;
    
    // Interactive driver components
    const driverBar = document.getElementById("driver-bar") as HTMLDivElement;
    const driverBlock = document.getElementById("driver-block") as HTMLDivElement;
    const fsDriverBar = document.getElementById("fs-driver-bar") as HTMLDivElement;
    const fsDriverBlock = document.getElementById("fs-driver-block") as HTMLDivElement;
    
    const fsHz = document.getElementById("fs-hz") as HTMLSpanElement;
    const fsDropped = document.getElementById("fs-dropped") as HTMLSpanElement;
    const fsProgress = document.getElementById("fs-progress") as HTMLParagraphElement;

    // Canvas rendering context
    const ctx = pacingCanvas.getContext("2d");

    function resizeCanvas() {
      if (!pacingCanvas) return;
      const rect = pacingCanvas.getBoundingClientRect();
      pacingCanvas.width = rect.width * window.devicePixelRatio;
      pacingCanvas.height = rect.height * window.devicePixelRatio;
      if (ctx) {
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
      }
    }
    
    window.addEventListener("resize", resizeCanvas);
    resizeCanvas();

    // Setup how it works modal events
    howItWorksBtn.addEventListener("click", () => {
      howItWorksModal.classList.remove("hidden");
    });
    
    const closeModal = () => {
      howItWorksModal.classList.add("hidden");
    };
    
    closeModalBtn.addEventListener("click", closeModal);
    modalOkBtn.addEventListener("click", closeModal);
    howItWorksModal.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) closeModal();
    });
    function handleEscapeKey(e: KeyboardEvent) {
      if (e.key === "Escape") closeModal();
    }
    window.addEventListener("keydown", handleEscapeKey);

    // Test mode controls
    modeQuickBtn.addEventListener("click", () => {
      if (isTesting) return;
      isContinuous = false;
      modeQuickBtn.classList.add("active-mode");
      modeContBtn.classList.remove("active-mode");
    });
    
    modeContBtn.addEventListener("click", () => {
      if (isTesting) return;
      isContinuous = true;
      modeContBtn.classList.add("active-mode");
      modeQuickBtn.classList.remove("active-mode");
    });

    // Driver buttons
    driverBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        driverBtns.forEach(b => b.classList.remove("driver-active"));
        btn.classList.add("driver-active");
        activeDriver = btn.dataset.driver as 'bar' | 'block' | 'none';
        updateDriverVisibility();
      });
    });

    function updateDriverVisibility() {
      // Hide all initially
      driverBar.classList.add("hidden");
      driverBlock.classList.add("hidden");
      fsDriverBar.classList.add("hidden");
      fsDriverBlock.classList.add("hidden");

      if (!isTesting) return;

      const container = isFullscreenMode ? fsDriverBar.parentElement : driverBar.parentElement;
      if (!container) return;
      
      const width = container.clientWidth;
      const height = container.clientHeight;

      if (isFullscreenMode) {
        if (activeDriver === 'bar') {
          fsDriverBar.classList.remove("hidden");
        } else if (activeDriver === 'block') {
          fsDriverBlock.classList.remove("hidden");
          blockX = width / 2;
          blockY = height / 2;
        }
      } else {
        if (activeDriver === 'bar') {
          driverBar.classList.remove("hidden");
        } else if (activeDriver === 'block') {
          driverBlock.classList.remove("hidden");
          blockX = width / 2;
          blockY = height / 2;
        }
      }
    }

    // Toggle testing
    startStopBtn.addEventListener("click", () => {
      if (!isTesting) {
        startTest();
      } else {
        stopTest();
      }
    });

    // Fullscreen Overlay Toggle
    fullscreenBtn.addEventListener("click", () => {
      enterFullscreen();
    });

    fullscreenOverlay.addEventListener("click", () => {
      exitFullscreen();
    });

    function handleFullscreenChange() {
      if (!document.fullscreenElement) {
        exitFullscreenState();
      }
    }
    document.addEventListener("fullscreenchange", handleFullscreenChange);

    function enterFullscreen() {
      isFullscreenMode = true;
      fullscreenOverlay.classList.remove("hidden");
      
      // Request standard fullscreen
      if (document.documentElement.requestFullscreen) {
        document.documentElement.requestFullscreen().catch((err) => {
          console.error("Fullscreen request failed", err);
        });
      }
      
      startTest();
    }

    function exitFullscreen() {
      if (document.exitFullscreen) {
        document.exitFullscreen().catch((e) => {
          // ignore
        });
      }
      exitFullscreenState();
    }

    function exitFullscreenState() {
      isFullscreenMode = false;
      fullscreenOverlay.classList.add("hidden");
      stopTest();
    }

    function startTest() {
      isTesting = true;
      frameTimestamps = [];
      frameIntervals = [];
      lastFrameTime = performance.now();
      testStartTime = lastFrameTime;
      
      troubleshootPanel.classList.add("hidden");

      if (!isFullscreenMode) {
        startStopIcon.textContent = "â¹";
        startStopText.textContent = "Stop Test";
        startStopBtn.classList.remove("button-primary");
        startStopBtn.classList.add("bg-brand-coral", "text-coral-dark", "hover:bg-coral-light");
        
        modeQuickBtn.setAttribute("disabled", "true");
        modeContBtn.setAttribute("disabled", "true");
        
        instructions.classList.add("opacity-20");
        testZone.classList.remove("border-dashed");
        testZone.classList.add("border-solid", "border-brand-blue", "shadow-lg", "shadow-brand-blue/10");
        
        if (!isContinuous) {
          zoneCountdownOverlay.classList.remove("hidden");
          zoneProgressBar.classList.remove("hidden");
          zoneCountdownValue.textContent = "3";
          zoneProgressFill.style.transition = "none";
          zoneProgressFill.style.width = "100%";
        }
      } else {
        fsHz.textContent = "0.0 Hz";
        fsDropped.textContent = "0 dropped frames";
        fsProgress.textContent = !isContinuous ? "Duration: 3s" : "Continuous";
      }

      updateDriverVisibility();
      resizeCanvas();

      rafId = requestAnimationFrame(loop);
    }

    function stopTest() {
      if (!isTesting) return;
      isTesting = false;
      cancelAnimationFrame(rafId);
      
      if (!isFullscreenMode) {
        startStopIcon.textContent = "â–¶";
        startStopText.textContent = "Start Test";
        startStopBtn.classList.add("button-primary");
        startStopBtn.classList.remove("bg-brand-coral", "text-coral-dark", "hover:bg-coral-light");
        
        modeQuickBtn.removeAttribute("disabled");
        modeContBtn.removeAttribute("disabled");
        
        instructions.classList.remove("opacity-20");
        testZone.classList.add("border-dashed");
        testZone.classList.remove("border-solid", "border-brand-blue", "shadow-lg", "shadow-brand-blue/10");
        
        zoneCountdownOverlay.classList.add("hidden");
        zoneProgressBar.classList.add("hidden");
      }

      // Hide animation drivers
      driverBar.classList.add("hidden");
      driverBlock.classList.add("hidden");
      fsDriverBar.classList.add("hidden");
      fsDriverBlock.classList.add("hidden");

      // Save summary to history and trigger check
      saveRunToHistory();
      checkDisplayDiagnostics();
    }

    // Core Frame loop
    function loop(timestamp: number) {
      if (!isTesting) return;
      
      const elapsed = timestamp - lastFrameTime;
      lastFrameTime = timestamp;

      // Skip initial frames to wait for stabilizer
      if (frameTimestamps.length > 0) {
        // Exclude pauses like background tab swaps (> 150ms)
        if (elapsed > 1 && elapsed < 150) {
          frameIntervals.push(elapsed);
        }
      }
      frameTimestamps.push(timestamp);

      // Render Visual Driver animation
      animateDriver(elapsed);

      // Handle Quick test countdown
      if (!isContinuous) {
        const testElapsed = timestamp - testStartTime;
        const remaining = Math.max(0, Math.ceil((quickTestDuration - testElapsed) / 1000));
        
        if (!isFullscreenMode) {
          zoneCountdownValue.textContent = remaining.toString();
          const pct = Math.max(0, 100 - (testElapsed / quickTestDuration) * 100);
          zoneProgressFill.style.width = `${pct}%`;
        } else {
          fsProgress.textContent = `${(testElapsed / 1000).toFixed(1)}s / 3.0s`;
        }

        if (testElapsed >= quickTestDuration) {
          stopTest();
          return;
        }
      }

      // Live Stats computation
      updateStats();

      // Render scrolling Canvas Graph
      renderGraph();

      rafId = requestAnimationFrame(loop);
    }

    // Move the bar or block elements
    function animateDriver(elapsed: number) {
      if (activeDriver === 'none') return;

      const container = isFullscreenMode ? fsDriverBar.parentElement : driverBar.parentElement;
      if (!container) return;

      const containerWidth = container.clientWidth;
      const containerHeight = container.clientHeight;

      const targetBar = isFullscreenMode ? fsDriverBar : driverBar;
      const targetBlock = isFullscreenMode ? fsDriverBlock : driverBlock;

      // Animate sliding bar
      if (activeDriver === 'bar') {
        const speed = containerWidth / 1500; // cross screen in 1.5s
        barX += speed * elapsed * barDirection;
        if (barX >= containerWidth - 10) {
          barX = containerWidth - 10;
          barDirection = -1;
        } else if (barX <= 0) {
          barX = 0;
          barDirection = 1;
        }
        targetBar.style.transform = `translateX(${barX}px)`;
      }

      // Animate bouncing block
      if (activeDriver === 'block') {
        const speedMultiplier = containerWidth / 400; // normalize bounce speed
        blockX += blockDx * speedMultiplier * (elapsed / 16.6);
        blockY += blockDy * speedMultiplier * (elapsed / 16.6);

        const size = isFullscreenMode ? 80 : 48;

        if (blockX + size >= containerWidth) {
          blockX = containerWidth - size;
          blockDx *= -1;
        } else if (blockX <= 0) {
          blockX = 0;
          blockDx *= -1;
        }

        if (blockY + size >= containerHeight) {
          blockY = containerHeight - size;
          blockDy *= -1;
        } else if (blockY <= 0) {
          blockY = 0;
          blockDy *= -1;
        }

        targetBlock.style.transform = `translate(${blockX}px, ${blockY}px)`;
      }
    }

    // Render Realtime scrolling frame pacing graph
    function renderGraph() {
      if (!ctx || !pacingCanvas || frameIntervals.length < 2) return;

      const dpr = window.devicePixelRatio;
      const w = pacingCanvas.width / dpr;
      const h = pacingCanvas.height / dpr;

      ctx.clearRect(0, 0, w, h);

      // Max items to fit on canvas
      const maxSamples = Math.min(frameIntervals.length, 120);
      const startIdx = frameIntervals.length - maxSamples;
      const samples = frameIntervals.slice(startIdx);

      // Compute standard height scale targeting typical display values (around 16.6ms for 60Hz)
      const maxVal = 35; // Cap height scaling to max 35ms to ignore high spikes
      const minVal = 2;

      ctx.beginPath();
      ctx.lineWidth = 1.5;
      ctx.strokeStyle = "rgba(66, 98, 255, 0.7)";

      const step = w / 110;

      for (let i = 0; i < samples.length; i++) {
        const val = samples[i];
        const x = i * step;
        // Clamp height
        const clampedVal = Math.max(minVal, Math.min(maxVal, val));
        const y = h - ((clampedVal - minVal) / (maxVal - minVal)) * (h - 20) - 10;

        if (i === 0) {
          ctx.moveTo(x, y);
        } else {
          ctx.lineTo(x, y);
        }
      }
      ctx.stroke();

      // Draw standard guideline (e.g. median line)
      if (samples.length > 5) {
        const sorted = [...samples].sort((a, b) => a - b);
        const median = sorted[Math.floor(sorted.length / 2)];
        const medianY = h - ((median - minVal) / (maxVal - minVal)) * (h - 20) - 10;
        
        ctx.beginPath();
        ctx.setLineDash([4, 4]);
        ctx.strokeStyle = "rgba(0, 180, 115, 0.4)";
        ctx.moveTo(0, medianY);
        ctx.lineTo(w, medianY);
        ctx.stroke();
        ctx.setLineDash([]);
      }
    }

    function calculateStatistics(intervals: number[]) {
      if (intervals.length === 0) {
        return { median: 0, mean: 0, estHz: 0, sd: 0, dropped: 0 };
      }
      const sorted = [...intervals].sort((a, b) => a - b);
      const medianIdx = Math.floor(sorted.length / 2);
      const median = sorted.length % 2 !== 0
        ? sorted[medianIdx]
        : (sorted[medianIdx - 1] + sorted[medianIdx]) / 2;

      // Trimmed Mean (ignoring top and bottom 10% outliers to filter stutters)
      const trimCount = Math.floor(sorted.length * 0.1);
      const trimmed = sorted.slice(trimCount, sorted.length - trimCount);
      const sum = trimmed.length > 0 ? trimmed.reduce((acc, v) => acc + v, 0) : 0;
      const mean = trimmed.length > 0 ? sum / trimmed.length : median;

      const estHz = mean > 0 ? 1000 / mean : 0;

      // Standard Deviation (Jitter)
      const variance = trimmed.length > 0
        ? trimmed.reduce((acc, v) => acc + Math.pow(v - mean, 2), 0) / trimmed.length
        : 0;
      const sd = Math.sqrt(variance);

      // Dropped Frames (any frame > 1.5 * expected interval)
      const expected = median;
      const dropped = intervals.filter(v => v > 1.5 * expected).length;

      return { median, mean, estHz, sd, dropped };
    }

    // Compute stats
    function updateStats() {
      if (frameIntervals.length < 5) return;

      const stats = calculateStatistics(frameIntervals);

      // Map to standard Hz
      const standardHzs = [60, 75, 90, 120, 144, 165, 240, 280, 360, 500];
      let closestHz = 60;
      let minDiff = Infinity;
      standardHzs.forEach(hz => {
        const diff = Math.abs(stats.estHz - hz);
        if (diff < minDiff) {
          minDiff = diff;
          closestHz = hz;
        }
      });

      // Update UI readouts
      liveHz.innerHTML = `${stats.estHz.toFixed(1)} <span class="text-xs text-slate">Hz</span>`;
      liveHzSubtext.textContent = `Likely ${closestHz}Hz Display`;
      medianInterval.textContent = `${stats.median.toFixed(2)} ms`;
      sdVal.textContent = `Â±${stats.sd.toFixed(2)} ms`;
      droppedCounter.textContent = stats.dropped.toString();
      sampleCounter.textContent = frameIntervals.length.toString();

      if (isFullscreenMode) {
        fsHz.textContent = `${stats.estHz.toFixed(1)} Hz`;
        fsDropped.textContent = `${stats.dropped} dropped frames`;
      }
    }

    // Diagnostics Troubleshooting display
    function checkDisplayDiagnostics() {
      if (frameIntervals.length < 10) return;
      const stats = calculateStatistics(frameIntervals);
      // If estimated refresh rate is below 45Hz or frame jitter is high (> 3.5ms)
      if (stats.estHz < 45 || stats.sd > 3.5) {
        troubleshootPanel.classList.remove("hidden");
      }
    }

    // Reset layout
    resetBtn.addEventListener("click", () => {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      stopTest();
      
      // Clear variables
      frameTimestamps = [];
      frameIntervals = [];
      
      // Reset UI
      liveHz.innerHTML = `0.0 <span class="text-xs text-slate">Hz</span>`;
      liveHzSubtext.textContent = "Likely -- Hz Display";
      medianInterval.textContent = "0.00 ms";
      sdVal.textContent = "Â±0.00 ms";
      droppedCounter.textContent = "0";
      sampleCounter.textContent = "0";
      
      troubleshootPanel.classList.add("hidden");
      
      // Reset active mode button visuals to default (Quick)
      isContinuous = false;
      modeQuickBtn.classList.add("active-mode");
      modeContBtn.classList.remove("active-mode");

      if (ctx && pacingCanvas) {
        ctx.clearRect(0, 0, pacingCanvas.width, pacingCanvas.height);
      }
      
      // Clear localStorage history
      try {
        localStorage.removeItem(LS_KEY_HISTORY);
      } catch (e) {}
      renderHistory();
    });

    // History and Persistence functions
    function saveRunToHistory() {
      if (frameIntervals.length < 30) return;

      const stats = calculateStatistics(frameIntervals);

      const run: RefreshRun = {
        timestamp: Date.now(),
        rate: Number(stats.estHz.toFixed(1)),
        medianDelay: Number(stats.median.toFixed(2)),
        jitter: Number(stats.sd.toFixed(2)),
        dropped: stats.dropped
      };

      const history = getHistory();
      history.unshift(run);
      localStorage.setItem(LS_KEY_HISTORY, JSON.stringify(history.slice(0, 10)));
      renderHistory();
    }

    function getHistory(): RefreshRun[] {
      const stored = localStorage.getItem(LS_KEY_HISTORY);
      if (!stored) return [];
      try {
        return JSON.parse(stored);
      } catch (e) {
        return [];
      }
    }

    function renderHistory() {
      const history = getHistory();
      if (history.length === 0) {
        historyTbody.innerHTML = `
          <tr>
            <td colspan="4" class="py-4 px-1 text-center text-stone italic">No tests saved.</td>
          </tr>
        `;
        return;
      }

      historyTbody.innerHTML = history.map(item => `
        <tr class="border-b border-hairline-soft hover:bg-surface/40">
          <td class="py-1.5 px-1 font-bold text-primary">${item.rate} Hz</td>
          <td class="py-1.5 px-1 text-right font-mono">${item.medianDelay} ms</td>
          <td class="py-1.5 px-1 text-right font-mono">Â±${item.jitter} ms</td>
          <td class="py-1.5 px-1 text-right font-mono text-coral-dark">${item.dropped}</td>
        </tr>
      `).join("");
    }

    // Export Results Summary
    exportBtn.addEventListener("click", () => {
      const history = getHistory();
      if (history.length === 0) {
        alert("No history to copy.");
        return;
      }
      
      let text = "TOOLKIFY Refresh Rate Test Results Summary:\n";
      text += "=========================================\n";
      history.forEach((run, i) => {
        text += `Run #${i + 1}: ${run.rate}Hz | Median: ${run.medianDelay}ms | Jitter: Â±${run.jitter}ms | Dropped Frames: ${run.dropped}\n`;
      });
      
      navigator.clipboard.writeText(text).then(() => {
        alert("Summary copied to clipboard!");
      }).catch(err => {
        console.error("Failed to copy history", err);
      });
    });

    clearHistoryBtn.addEventListener("click", () => {
      try {
        localStorage.removeItem(LS_KEY_HISTORY);
      } catch (e) {}
      renderHistory();
    });

    headerShareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("continuous", String(isContinuous));

      const shareData = {
        title: document.title || "Refresh Rate Test",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (headerShareBtn) {
          const span = headerShareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            headerShareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              headerShareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Suspend loop if browser tab is backgrounded
    function handleVisibilityChange() {
      if (document.hidden && isTesting) {
        stopTest();
      }
    }
    document.addEventListener("visibilitychange", handleVisibilityChange);

    // Cleanup listeners on navigate
    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("resize", resizeCanvas);
      window.removeEventListener("keydown", handleEscapeKey);
      document.removeEventListener("fullscreenchange", handleFullscreenChange);
      document.removeEventListener("visibilitychange", handleVisibilityChange);
      stopTest();
    });

    // Initial render
    function init() {
      const urlParams = new URLSearchParams(window.location.search);
      const urlCont = urlParams.get("continuous");
      if (urlCont === "true") {
        isContinuous = true;
        modeContBtn.classList.add("active-mode");
        modeQuickBtn.classList.remove("active-mode");
      } else {
        isContinuous = false;
        modeQuickBtn.classList.add("active-mode");
        modeContBtn.classList.remove("active-mode");
      }
      renderHistory();
    }
    init();
    }
  </script>

  <style>
    /* Styling states */
    .active-mode {
      background-color: var(--color-surface-pricing-featured, oklch(0.92 0.03 250));
      border-color: var(--color-brand-blue, oklch(0.55 0.22 265));
      color: var(--color-brand-blue, oklch(0.55 0.22 265));
      font-weight: 700;
    }
    
    .driver-active {
      background-color: var(--color-primary, oklch(0.20 0.01 200));
      border-color: var(--color-primary, oklch(0.20 0.01 200));
      color: var(--color-on-primary, oklch(1.0 0.0 0.0));
      font-weight: 600;
    }

    button:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      pointer-events: none;
    }
  </style>
</Layout>
