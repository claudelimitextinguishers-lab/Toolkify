---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Refresh Rate Test";
const category = "display";
const tier = "Display & Input Diagnostics";

// On-page SEO metadata
const pageTitle = "Refresh Rate Test - Check Monitor Hz Online";
const description = "Use our free online refresh rate test to check your monitor refresh rate. Measure screen refresh rate on TV, PC, and mobile (Android & iPhone) in real-time.";
const canonicalUrl = "https://toolkify.app/tools/display/refresh-rate";
const ogImage = "/og/refresh-rate.png";
const keywords = "Refresh Rate Test, monitor refresh rate test, screen refresh rate test, refresh rate test mobile, display refresh rate test, refresh rate test online, 120hz refresh rate test, refresh rate test monitor, online refresh rate test, phone refresh rate test, refresh rate test android, refresh rate test iphone, monitor hz test, hz tester, screen refresh rate, measure hz, fps test, check refresh rate, display hz check, frame pacing test, dropped frames";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Refresh Rate Test",
      "alternateName": "Monitor Hz Analyzer",
      "url": "https://toolkify.app/tools/display/refresh-rate",
      "description": "Measure and analyze your monitor display refresh rate and frame pacing consistency in real-time using high-precision requestAnimationFrame loops.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires requestAnimationFrame support.",
      "featureList": [
        "Real-time display refresh rate estimation (Hz)",
        "Trimmed mean and median calculations to filter out OS/compositor hiccups",
        "Visual scrolling frame-interval pacing graph using HTML5 Canvas",
        "Dropped frames counter detection",
        "Fullscreen test driver overlay to optimize GPU prioritizing",
        "Toggles for Quick Test vs. Continuous Monitoring",
        "Troubleshooting suggestions for display capping issues"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Tools",
          "item": "https://toolkify.app/tools"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Display",
          "item": "https://toolkify.app/tools/display"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Refresh Rate Test",
          "item": "https://toolkify.app/tools/display/refresh-rate"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How to test refresh rate",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To test your refresh rate, use an online refresh rate test like this tool. Simply open the page on any browser, click 'Start Test', and the tool will use high-precision requestAnimationFrame loops to measure the exact frequency (in Hz) at which your display renders frames.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test monitor refresh rate",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To test monitor refresh rate, open this free tool in your desktop browser. Close any background applications to avoid CPU/GPU stutter, and click 'Start Test'. For the most accurate hardware diagnostic, enter Fullscreen mode to bypass window compositor limitations.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test tv refresh rate",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To test a TV refresh rate, connect your computer, phone, or streaming device to the TV. Open this online test on the TV's browser, select the display context, and start the test. Ensure your system's display settings are configured to output the TV's native Hz rate.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test my refresh rate",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>You can test your display's refresh rate instantly using our free web-based tool. It automatically analyzes frame pacing, stability, and dropped frames to tell you exactly whether your screen is running at its intended speed.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test refresh rate on iphone",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To test the refresh rate on an iPhone, open Safari or Chrome, navigate to this online refresh rate test mobile version, and click 'Start Test'. For ProMotion models (iPhone 13 Pro and newer), the test can verify dynamic rates up to 120Hz depending on active scrolling.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test screen refresh rate",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Testing your screen refresh rate is simple: run our online test on any display, monitor, or phone. The tool counts the time intervals between frame rendering ticks to calculate the screen's actual performance in Hz.</p>"
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1200px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2">
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How refresh rate test works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Status Banner / Accuracy Mode -->
    <div
      id="status-banner"
      class="p-2.5 rounded-lg border flex items-center justify-between text-[11px] transition-all duration-300 bg-surface border-hairline text-slate print:hidden"
    >
      <span id="status-msg" class="font-semibold flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-success-accent animate-pulse"></span>
        Ready to test. High-precision hardware clock active.
      </span>
      <span class="font-mono text-[9px] text-stone">Method: requestAnimationFrame Sampling</span>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 items-stretch relative">
      <!-- Left Controls & Diagnostics (Column 1: 4 cols on lg, 3 cols on xl) -->
      <div class="lg:col-span-4 xl:col-span-3 flex flex-col gap-3">
        <div class="card-base p-3 flex flex-col gap-3 h-full justify-between">
          <div class="flex flex-col gap-3">
            <h2 class="font-display font-semibold text-xs text-primary flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-blue animate-pulse"></span>
              Live Diagnostics
            </h2>

            <!-- Stats grid -->
            <div class="grid grid-cols-2 gap-2">
              <!-- Live Hz display -->
              <div class="p-2.5 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center col-span-2 relative overflow-hidden group">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Estimated Rate</span>
                <span id="live-hz" class="text-3xl font-display font-medium text-brand-blue tracking-tight">0.0 <span class="text-xs text-slate">Hz</span></span>
                <span id="live-hz-subtext" class="text-[9px] text-stone">Likely -- Hz Display</span>
              </div>

              <!-- Median Interval -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Median Interval</span>
                <span id="median-interval" class="text-xs font-bold text-primary">0.00 ms</span>
                <span class="text-[8px] text-stone">Frame delay</span>
              </div>

              <!-- Jitter / Confidence -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Stability (SD)</span>
                <span id="sd-val" class="text-xs font-bold text-primary">Â±0.00 ms</span>
                <span class="text-[8px] text-stone">Frame variance</span>
              </div>

              <!-- Dropped Frames -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Dropped Frames</span>
                <span id="dropped-counter" class="text-[10px] font-bold text-primary">0</span>
                <span class="text-[8px] text-stone">Intervals > 1.5x</span>
              </div>

              <!-- Total Frames Sampled -->
              <div class="p-2 bg-surface border border-hairline rounded-xl flex flex-col gap-0.5 items-center text-center">
                <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Total Samples</span>
                <span id="sample-counter" class="text-[10px] font-bold text-primary">0</span>
                <span class="text-[8px] text-stone">rAF ticks</span>
              </div>
            </div>
          </div>

          <!-- Controls Section -->
          <div class="flex flex-col gap-2.5">
            <!-- Mode Toggle -->
            <div class="flex flex-col gap-1">
              <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Test Mode</span>
              <div class="grid grid-cols-2 gap-1" role="radiogroup" aria-label="Test mode">
                <button type="button" id="mode-quick-btn" class="text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer active-mode">Quick (3s)</button>
                <button type="button" id="mode-cont-btn" class="text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface hover:bg-surface-pricing-featured hover:border-brand-blue hover:text-brand-blue text-slate transition-all cursor-pointer">Continuous</button>
              </div>
            </div>

            <!-- Test Driver Speed/Style -->
            <div class="flex flex-col gap-1">
              <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Visual Test Driver</span>
              <div class="grid grid-cols-3 gap-1" role="radiogroup" aria-label="Test driver type">
                <button type="button" data-driver="bar" class="driver-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface text-slate transition-all cursor-pointer driver-active">Bar</button>
                <button type="button" data-driver="block" class="driver-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface text-slate transition-all cursor-pointer">Block</button>
                <button type="button" data-driver="none" class="driver-btn text-[9px] font-semibold py-1 px-1 rounded border border-hairline bg-surface text-slate transition-all cursor-pointer">None</button>
              </div>
            </div>

            <!-- Action buttons -->
            <div class="flex flex-col gap-1.5">
              <button
                type="button"
                id="start-stop-btn"
                class="w-full button-primary text-xs py-2 px-4 !rounded-full shadow-subtle hover:scale-[1.02] active:scale-95 transition-all cursor-pointer font-bold text-center flex items-center justify-center gap-1.5"
              >
                <span id="start-stop-icon">â–¶</span>
                <span id="start-stop-text">Start Test</span>
              </button>
              
              <button
                type="button"
                id="fullscreen-btn"
                class="w-full inline-flex items-center justify-center gap-1.5 text-[11px] font-semibold py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
              >
                <span>ðŸŽŽ</span>
                <span>Fullscreen Overlay</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Center Test Area & Canvas Graph (Column 2: 5 cols on lg, 6 cols on xl) -->
      <div class="lg:col-span-5 xl:col-span-6 flex flex-col gap-3">
        <!-- Interactive Visualizer -->
        <div id="test-zone" class="card-base flex-1 min-h-[300px] h-[340px] lg:h-[380px] p-4 flex flex-col items-center justify-center border-2 border-dashed border-hairline-strong bg-canvas hover:border-brand-blue/50 transition-colors select-none relative group overflow-hidden">
          <!-- Live Pacing Scrolling Canvas -->
          <canvas id="pacing-canvas" class="absolute inset-0 w-full h-full pointer-events-none opacity-40"></canvas>

          <!-- Countdown / Progress Overlay -->
          <div id="zone-countdown-overlay" class="absolute top-4 right-4 z-20 pointer-events-none hidden">
            <div class="flex flex-col items-center bg-canvas/80 backdrop-blur-sm border border-brand-blue/40 rounded-2xl px-3 py-1.5 shadow-lg">
              <span class="text-[9px] font-semibold text-slate uppercase tracking-wider">Time Left</span>
              <span id="zone-countdown-value" class="text-2xl font-display font-bold text-brand-blue tabular-nums">3</span>
              <span class="text-[9px] text-stone">seconds</span>
            </div>
          </div>

          <div id="zone-progress-bar" class="absolute bottom-0 left-0 right-0 h-1 pointer-events-none hidden">
            <div id="zone-progress-fill" class="h-full bg-brand-blue/70 transition-all text-brand-blue" style="width: 100%"></div>
          </div>

          <!-- Dynamic Visual Drivers Container -->
          <div id="visual-driver-container" class="absolute inset-0 w-full h-full pointer-events-none overflow-hidden">
            <!-- Sliding Bar -->
            <div id="driver-bar" class="absolute top-0 bottom-0 w-2.5 bg-brand-blue shadow-[0_0_10px_rgba(66,98,255,0.6)] hidden"></div>
            <!-- Bouncing Block -->
            <div id="driver-block" class="absolute w-12 h-12 bg-brand-teal rounded-lg shadow-lg hidden"></div>
          </div>

          <div id="test-zone-instructions" class="pointer-events-none flex flex-col items-center text-center gap-2 z-10 transition-opacity duration-300">
            <div class="text-3xl animate-bounce">âš¡</div>
            <div class="flex flex-col gap-1">
              <h3 class="font-display font-medium text-sm sm:text-base text-primary">Refresh Rate Diagnostics Box</h3>
              <p class="text-xs text-slate max-w-sm leading-relaxed">
                Click <strong class="text-brand-blue">Start Test</strong> to sample frame rendering performance. Running in Fullscreen improves browser scheduler prioritization.
              </p>
            </div>
          </div>
        </div>

        <!-- Troubleshooting Panel (Shown under test zone if issues detected) -->
        <div id="troubleshoot-panel" class="hidden card-base p-3 bg-surface-yellow border border-brand-yellow-deep/40 flex flex-col gap-2 animate-fade-in">
          <h3 class="font-display font-semibold text-xs text-yellow-dark flex items-center gap-1.5">
            <span>âš ï¸</span> Low Refresh Rate or High Jitter Detected
          </h3>
          <div class="text-[10px] text-yellow-dark leading-relaxed flex flex-col gap-1">
            <p>Your browser reports high variance or capped frame rates. Common solutions:</p>
            <ul class="list-disc pl-4 flex flex-col gap-0.5">
              <li>Enable **Hardware Acceleration** in browser settings.</li>
              <li>Check Windows/macOS advanced display settings to confirm monitor Hz is set correctly (e.g. 144Hz, not 60Hz).</li>
              <li>Close background apps or other browser tabs that consume GPU resources.</li>
              <li>Run the test in **Fullscreen Overlay** mode to bypass compositor limitations.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- History Panel (Column 3: 3 cols on lg/xl) -->
      <div class="lg:col-span-3 xl:col-span-3 flex flex-col gap-3">
        <div class="card-base p-3 flex flex-col gap-3 h-full justify-between">
          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between border-b border-hairline-soft pb-2">
              <h3 class="font-display font-semibold text-xs text-primary flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-slate"></span>
                History
              </h3>
              <div class="flex items-center gap-1.5">
                <button
                  type="button"
                  id="export-btn"
                  class="inline-flex items-center gap-1 text-[9px] font-semibold px-2 py-0.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded transition-all cursor-pointer shadow-subtle"
                >
                  Copy
                </button>
                <button
                  type="button"
                  id="clear-history-btn"
                  class="inline-flex items-center gap-1 text-[9px] font-semibold px-2 py-0.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded transition-all cursor-pointer shadow-subtle"
                >
                  Clear
                </button>
              </div>
            </div>

            <div class="max-h-[220px] lg:max-h-[250px] xl:max-h-[280px] overflow-y-auto pr-1">
              <table class="w-full text-left border-collapse text-[10px]">
                <thead>
                  <tr class="border-b border-hairline text-slate font-semibold sticky top-0 bg-canvas z-10">
                    <th class="py-1 px-1">Hz</th>
                    <th class="py-1 px-1 text-right">Interval</th>
                    <th class="py-1 px-1 text-right">Jitter</th>
                    <th class="py-1 px-1 text-right">Drops</th>
                  </tr>
                </thead>
                <tbody id="history-tbody">
                  <tr>
                    <td colspan="4" class="py-4 px-1 text-center text-stone italic">No tests saved.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
          
          <!-- Security & Privacy Guard Tag -->
          <div class="flex items-center justify-between text-[9px] text-slate border-t border-hairline-soft pt-2">
            <span class="flex items-center gap-0.5">
              <span class="text-success-accent font-semibold">âœ“</span> Client-Side
            </span>
            <span>v2.0.0</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fullscreen Floating Visualizer Overlay -->
  <div id="fullscreen-overlay" class="fixed inset-0 bg-primary z-50 flex flex-col items-center justify-center hidden select-none cursor-none">
    <!-- Active Driver for Fullscreen -->
    <div id="fs-driver-container" class="absolute inset-0 w-full h-full">
      <div id="fs-driver-bar" class="absolute top-0 bottom-0 w-3 bg-brand-blue shadow-[0_0_15px_rgba(66,98,255,0.8)] hidden"></div>
      <div id="fs-driver-block" class="absolute w-20 h-20 bg-brand-teal rounded-xl shadow-2xl hidden"></div>
    </div>

    <!-- Stats display overlay (semi-trans) -->
    <div class="absolute bottom-8 left-8 right-8 flex justify-between items-end pointer-events-none z-10">
      <div class="bg-primary/80 border border-hairline-soft/20 backdrop-blur-md p-4 rounded-xl flex flex-col gap-1 text-white shadow-2xl">
        <span class="text-[10px] font-semibold text-stone uppercase tracking-wider">Measuring Rate</span>
        <span id="fs-hz" class="text-4xl font-display font-medium text-brand-blue tabular-nums">0.0 Hz</span>
        <span id="fs-dropped" class="text-[10px] text-brand-coral font-mono">0 dropped frames</span>
      </div>
      <div class="text-right text-stone text-[10px] flex flex-col gap-1">
        <p>Press <kbd class="px-1.5 py-0.5 bg-charcoal rounded text-white font-mono">ESC</kbd> or click anywhere to exit Fullscreen</p>
        <p id="fs-progress" class="font-bold text-brand-blue tabular-nums"></p>
      </div>
    </div>
  </div>

  <!-- Educational Article -->
  <section
    class="max-w-[760px] w-full mx-auto px-4 pb-20 flex flex-col gap-8 text-slate print:hidden"
    aria-labelledby="about-tool-heading"
  >
    <article class="flex flex-col gap-4">
      <h2
        id="about-tool-heading"
        class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight"
      >
        Complete Guide to the Refresh Rate Test & Monitor Hz Diagnostics
      </h2>
      <p class="text-sm leading-relaxed">
        Every screen you interact with relies on rapid visual updates to create smooth motion. Whether you are aiming for high-fps competitive gaming or simply scrolling through social feeds, understanding your display's actual performance is essential. Our free <strong>refresh rate test</strong> provides a real-time diagnostic to evaluate display frame pacing, detect jitter, and check for dropped frames directly inside your web browser. By measuring the precise interval between successive frames, this utility functions as an <strong>online refresh rate test</strong> that calculates exactly how many times per second your monitor refreshes its image buffer. Understanding these hardware variables helps you optimize your system for gaming, creative work, or daily tasks, ensuring that what you see matches what your system is actually rendering.
      </p>

      <h3 class="font-display font-semibold text-lg text-primary mt-2">
        Why Run a Monitor Refresh Rate Test?
      </h3>
