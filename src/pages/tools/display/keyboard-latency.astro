---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Keyboard Latency Test";
const category = "display";
const tier = "Display & Input Diagnostics";

// On-page SEO metadata
const pageTitle =
  "Keyboard Latency Test - Measure Keyboard Latency Online Free";
const description =
  "Free online keyboard latency test to measure keyboard latency in your browser. Test wired vs wireless keyboard latency, check Bluetooth keyboard lag, and see if your keyboard latency is good for gaming.";
const canonicalUrl = "https://boardtools.app/tools/display/keyboard-latency";
const ogImage = "/og/keyboard-latency.png";
const keywords =
  "keyboard latency test, keyboard latency, keyboard latency tester, test keyboard latency, how to test keyboard latency, wireless keyboard latency, wired vs wireless keyboard latency, how to check keyboard latency, keyboard latency test online, keyboard latency for gaming, what is a good keyboard latency, bluetooth keyboard latency, measure keyboard latency, wired vs wireless keyboard latency gaming, how to measure keyboard latency, wireless keyboard latency gaming";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Keyboard Latency Test",
      "alternateName": "Online Keyboard Latency Tester & Input Lag Measure Tool",
      "url": "https://boardtools.app/tools/display/keyboard-latency",
      "description": "Free online keyboard latency test to measure keyboard latency in your browser. Compare wired vs wireless keyboard latency, check Bluetooth keyboard lag, collect multi-press distributions, export session CSV, and A/B compare setups for gaming.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5 requestAnimationFrame.",
      "featureList": [
        "High-resolution monotonic timer performance.now() tracking",
        "Visual feedback target with instant color change mapped to frame painting",
        "Session statistical summary containing median, mean, min, and max values",
        "Local distribution histogram displaying keypress frequency by latency bins",
        "A/B comparison mode to evaluate two separate browser test configurations",
        "Browser environment info parsing (browser, version, OS) to contextualize data",
        "Raw session log viewer with CSV/JSON export functionality",
        "Mobile-touch warning if no physical keyboard is present"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://boardtools.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Tools",
          "item": "https://boardtools.app/tools"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Display",
          "item": "https://boardtools.app/tools/display"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Keyboard Latency Test",
          "item": "https://boardtools.app/tools/display/keyboard-latency"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is keyboard latency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Keyboard latency is the delay between the moment you physically press a key and the moment that keystroke is registered and shown by your computer. It is usually measured in milliseconds (ms) and is made up of several stages: the switch actuation and debounce, the keyboard's internal scanning, the polling interval over USB or wireless, and the operating system and application processing time. Lower keyboard latency means your inputs feel more instant and responsive.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to test keyboard latency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To test keyboard latency with this online tool, click the test target to focus it, then press the Spacebar or any key repeatedly at a natural pace. The tool captures a batch of presses and measures the time from each keydown event to the next rendered frame, then reports the median, average, minimum, and maximum latency. Running 20 to 30 presses filters out timing noise and gives you a reliable keyboard latency reading you can compare across setups.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a good keyboard latency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A good keyboard latency is generally under 15 ms, with high-end gaming keyboards achieving 1 to 5 ms of hardware latency. In everyday typing anything under 30 ms feels responsive, while readings above 40 ms can start to feel sluggish. Because this browser-based test also includes display and rendering delay, expect slightly higher numbers here than a pure hardware probe would show, but the relative comparison between keyboards remains meaningful.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What keyboard has the lowest latency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Wired mechanical and optical gaming keyboards with a 1000 Hz (or higher 4000/8000 Hz) polling rate typically have the lowest latency, often in the 1 to 5 ms range. Optical-switch keyboards from gaming-focused brands and analog boards tend to lead because they skip mechanical debounce delay. In general, a wired connection with a high polling rate will beat wireless and Bluetooth keyboards on raw latency.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What to look for in wireless gaming keyboard latency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>For a wireless gaming keyboard, look for a dedicated 2.4 GHz USB dongle rather than Bluetooth, a 1000 Hz polling rate, and low, consistent latency (ideally under 5 to 8 ms). Consistency matters as much as the average: stable, low jitter latency feels better than a low average with occasional spikes. Also check battery-saving modes, since some keyboards increase latency to preserve power when idle.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is input latency on a keyboard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Input latency on a keyboard is the total time it takes for a key press to travel from the physical switch to a visible result on screen. It combines switch actuation, keyboard firmware scanning and debounce, the polling rate of the connection, and operating-system input handling. This end-to-end input latency is what actually determines how responsive a keyboard feels during typing and gaming.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is good keyboard latency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Good keyboard latency is low and consistent. As a rule of thumb, under 5 ms is excellent (competitive gaming grade), 5 to 15 ms is very good, 16 to 30 ms is normal and perfectly fine for everyday use, and anything consistently above 40 ms is worth investigating. Alongside the raw number, a low jitter (small gap between minimum and maximum) is a strong sign of good keyboard latency.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a good keyboard latency for gaming?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>For gaming, a good keyboard latency is under 10 ms, and competitive players often aim for 1 to 5 ms using a wired keyboard with a 1000 Hz or higher polling rate. At these levels the keyboard is no longer the bottleneck, and your reaction time and display refresh rate become the limiting factors. If your keyboard latency test shows consistently low, stable results, your keyboard is well suited to fast-paced gaming.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Why is my keyboard latency so high?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>High keyboard latency is often caused by a low polling rate, a weak or interfered wireless connection, a nearly empty battery on a wireless keyboard, or Bluetooth instead of a 2.4 GHz dongle. Software factors also matter: heavy CPU load, too many background apps or browser tabs, power-saving USB settings, and outdated drivers can all raise latency. In a browser test, a low display refresh rate and demanding pages can add extra delay too.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to decrease keyboard latency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To decrease keyboard latency, use a wired connection or a 2.4 GHz dongle instead of Bluetooth, set the polling rate to 1000 Hz, and keep firmware and drivers up to date. Disable USB power-saving in your OS, close unnecessary background apps and browser tabs, and use a higher refresh-rate monitor. Charging wireless keyboards fully and reducing 2.4 GHz interference (from Wi-Fi routers or USB 3.0 devices) also helps keep latency low and stable.</p>"
          }
        }
      ]
    }
  </script>

  <section
    class="max-w-[1280px] w-full mx-auto px-4 py-1.5 sm:py-3 flex flex-col gap-2 animate-fade-in-up pb-8 print:p-0"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2"
      >
        <div class="flex items-center gap-2 flex-wrap">
          <h1
            class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0"
          >
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2">
          <!-- Share button -->
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <!-- How it works button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How keyboard latency works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <!-- Reset button -->
          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Honesty Caveat Callout Banner -->
    <div
      class="p-2 bg-surface-yellow border border-yellow-light/80 rounded-lg text-[11px] text-yellow-dark leading-normal flex flex-col sm:flex-row sm:items-center justify-between gap-2 shadow-subtle print:hidden"
    >
      <div class="flex items-start gap-1.5">
        <span class="text-xs select-none shrink-0">💡</span>
        <div>
          <span class="font-bold">Honesty Disclaimer:</span> Measures <span
            class="font-bold underline text-primary"
            >Browser Input-to-Paint Latency</span
          > (event to next paint frame). True hardware latency requires physical probes.
        </div>
      </div>
    </div>

    <!-- Virtual Keyboard / Touch Detection Warning -->
    <div
      id="touch-device-warning"
      class="hidden p-3.5 bg-brand-red border border-brand-red-dark/50 text-coral-dark rounded-xl text-xs flex items-center gap-2.5 shadow-subtle"
    >
      <span class="text-base">⚠️</span>
      <div>
        <span class="font-bold">Physical Keyboard Recommended:</span> We detected
        a touch-only or virtual keyboard environment. For meaningful diagnostics,
        please connect a physical wired or Bluetooth keyboard.
      </div>
    </div>

    <!-- main workspace: compact zero-scroll style grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 items-stretch relative">
      <!-- Left: Interactive Test & Live Target Panel (8 columns on lg) -->
      <div class="lg:col-span-7 flex flex-col gap-3">
        <div class="card-base p-3 sm:p-4 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <h2
              class="font-display font-semibold text-xs text-primary flex items-center gap-1.5"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-brand-blue"></span>
              Live Test Target
            </h2>
            <div class="flex items-center gap-1.5">
              <!-- Target sample size setting -->
              <label
                for="sample-target-count"
                class="text-[9px] font-semibold text-slate uppercase"
                >Batch Size</label
              >
              <select
                id="sample-target-count"
                class="text-input py-0.5 px-1.5 text-[10px] h-6 cursor-pointer border border-hairline-strong bg-canvas rounded"
              >
                <option value="1">Single Press</option>
                <option value="10">10 Presses</option>
                <option value="20">20 Presses</option>
                <option value="30" selected>30 Presses</option>
                <option value="50">50 Presses</option>
              </select>
            </div>
          </div>

<!-- The Instant Paint Visual Target Flash -->
            <div
              id="visual-test-target"
              class="relative flex flex-col items-center justify-center min-h-[140px] bg-canvas border-2 border-hairline-strong rounded-xl text-center p-3 transition-all duration-75 select-none cursor-pointer focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
              tabindex="0"
              role="button"
              aria-label="Keyboard latency test target. Click to focus, then press Spacebar or any key."
            >
              <!-- Sync indicator light on paint -->
              <div
                id="target-paint-indicator"
                class="absolute top-2 right-2 w-2.5 h-2.5 rounded-full bg-stone-400 border border-canvas/20 dark:bg-stone-500"
              >
              </div>

              <div id="target-instruction" class="flex flex-col gap-1 pointer-events-none">
                <span
                  class="text-sm font-bold text-ink animate-pulse"
                >
                  Click here to focus, then press <span
                    class="bg-surface px-1.5 py-0.5 rounded border border-hairline text-brand-blue"
                    >Spacebar</span
                  > or any key
                </span>
                <p class="text-[10px] text-slate max-w-sm mx-auto">
                  Press repeatedly at a natural pace. Hold-down repeats are filtered.
                </p>
              </div>

              <!-- Absolute readout in middle of target -->
              <div
                id="target-readout-container"
                class="hidden absolute inset-0 flex flex-col items-center justify-center bg-transparent pointer-events-none"
              >
                <span
                  id="target-number"
                  class="text-4xl font-mono font-bold tracking-tight text-brand-blue"
                  >0.0</span
                >
                <span
                  id="target-readout-label"
                  class="text-[9px] text-slate font-bold tracking-wider uppercase mt-0.5"
                  >Milliseconds Paint Delay</span
                >
              </div>
            </div>

          <!-- Progress Indicator bar -->
          <div class="flex flex-col gap-1.5">
            <div
              class="flex items-center justify-between text-[10px] font-semibold text-slate"
            >
              <span>BATCH PROGRESS</span>
              <span id="progress-text">0 / 30 Presses</span>
            </div>
            <div
              class="w-full h-1.5 bg-surface border border-hairline rounded-full overflow-hidden"
            >
              <div
                id="progress-bar"
                class="w-0 h-full bg-brand-blue transition-all duration-150"
              >
              </div>
            </div>
          </div>
        </div>

        <!-- A/B Comparison workspace -->
        <div class="card-base p-3 sm:p-4 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <h2
              class="font-display font-semibold text-xs text-primary flex items-center gap-1.5"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-brand-coral"></span>
              A/B Comparison Mode
            </h2>
            <button
              type="button"
              id="toggle-ab-mode"
              class="text-[9px] font-bold px-2 py-0.5 bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer"
            >
              Enable A/B Mode
            </button>
          </div>

          <div
            id="ab-comparison-grid"
            class="hidden grid-cols-2 gap-2 items-stretch"
          >
            <!-- Setup A Panel -->
            <div
              class="p-2 bg-surface rounded-lg border border-hairline flex flex-col gap-1 relative"
            >
              <span
                class="text-[9px] font-bold uppercase tracking-wider text-brand-blue"
                >Setup A</span
              >
              <div class="text-[9px] text-slate flex flex-col gap-0.5">
                <div class="flex justify-between">
                  <span>Name:</span>
                  <span id="ab-a-name" class="font-semibold text-primary truncate max-w-[60px]"
                    >Unrecorded</span
                  >
                </div>
                <div class="flex justify-between">
                  <span>Samples:</span>
                  <span id="ab-a-samples" class="font-mono">0</span>
                </div>
                <div class="flex justify-between">
                  <span>Median:</span>
                  <span id="ab-a-median" class="font-mono font-bold">-</span>
                </div>
                <div class="flex justify-between">
                  <span>Avg:</span>
                  <span id="ab-a-avg" class="font-mono">-</span>
                </div>
              </div>
              <button
                type="button"
                id="save-to-a"
                class="mt-1 text-[9px] font-bold py-0.5 px-2 bg-primary text-canvas rounded hover:opacity-90 active:scale-95 transition-all text-center cursor-pointer"
              >
                Copy current
              </button>
            </div>

            <!-- Setup B Panel -->
            <div
              class="p-2 bg-surface rounded-lg border border-hairline flex flex-col gap-1 relative"
            >
              <span
                class="text-[9px] font-bold uppercase tracking-wider text-brand-coral"
                >Setup B</span
              >
              <div class="text-[9px] text-slate flex flex-col gap-0.5">
                <div class="flex justify-between">
                  <span>Name:</span>
                  <span id="ab-b-name" class="font-semibold text-primary truncate max-w-[60px]"
                    >Unrecorded</span
                  >
                </div>
                <div class="flex justify-between">
                  <span>Samples:</span>
                  <span id="ab-b-samples" class="font-mono">0</span>
                </div>
                <div class="flex justify-between">
                  <span>Median:</span>
                  <span id="ab-b-median" class="font-mono font-bold">-</span>
                </div>
                <div class="flex justify-between">
                  <span>Avg:</span>
                  <span id="ab-b-avg" class="font-mono">-</span>
                </div>
              </div>
              <button
                type="button"
                id="save-to-b"
                class="mt-1 text-[9px] font-bold py-0.5 px-2 bg-primary text-canvas rounded hover:opacity-90 active:scale-95 transition-all text-center cursor-pointer"
              >
                Copy current
              </button>
            </div>
          </div>

          <!-- Comparison result text -->
          <div
            id="ab-result-banner"
            class="hidden p-2 rounded border border-hairline bg-surface-yellow text-yellow-dark text-[10px] font-semibold text-center"
          >
            A/B setups are not populated yet. Record runs into slots to run a
            comparative analysis.
          </div>
        </div>
      </div>

      <!-- Right: Stats Panel, Histogram & Logs (5 columns on lg) -->
      <div class="lg:col-span-5 flex flex-col gap-3">
        <!-- Live Run Stats Card -->
        <div class="card-base p-3 sm:p-4 flex flex-col gap-3">
          <h2
            class="font-display font-semibold text-xs text-primary flex items-center justify-between"
          >
            <span>Statistics Summary</span>
            <span
              id="stats-banner"
              class="text-[9px] text-stone font-semibold tracking-wider font-mono"
              >NO SAMPLES</span
            >
          </h2>

          <div class="grid grid-cols-2 gap-1.5 text-center">
            <!-- Median -->
            <div
              class="p-1.5 bg-surface-soft border border-hairline rounded-lg flex flex-col justify-center"
            >
              <span class="text-[8px] font-bold text-slate uppercase"
                >Median</span
              >
              <span
                id="stat-median"
                class="text-xl font-mono font-bold text-primary">-</span
              >
            </div>
            <!-- Average -->
            <div
              class="p-1.5 bg-surface-soft border border-hairline rounded-lg flex flex-col justify-center"
            >
              <span class="text-[8px] font-bold text-slate uppercase"
                >Average</span
              >
              <span
                id="stat-avg"
                class="text-xl font-mono font-bold text-primary">-</span
              >
            </div>
            <!-- Min -->
            <div
              class="p-1.5 bg-surface-soft border border-hairline rounded-lg flex flex-col justify-center"
            >
              <span class="text-[8px] font-bold text-slate uppercase"
                >Min Latency</span
              >
              <span
                id="stat-min"
                class="text-sm font-mono font-semibold text-success-accent"
                >-</span
              >
            </div>
            <!-- Max -->
            <div
              class="p-1.5 bg-surface-soft border border-hairline rounded-lg flex flex-col justify-center"
            >
              <span class="text-[8px] font-bold text-slate uppercase"
                >Max Latency</span
              >
              <span
                id="stat-max"
                class="text-sm font-mono font-semibold text-coral-dark"
                >-</span
              >
            </div>
          </div>

          <!-- Histogram representation -->
          <div class="flex flex-col gap-1 mt-1">
            <span
              class="text-[9px] font-bold text-slate uppercase tracking-wider"
              >Latency Distribution</span
            >
            <div
              id="histogram-container"
              class="flex flex-col gap-1 min-h-[70px] justify-center text-[9px] text-stone"
            >
              <div class="text-center py-4">
                No distribution data available. Press keys to plot.
              </div>
            </div>
          </div>
        </div>

        <!-- System Context -->
        <div class="card-base p-3 sm:p-4 flex flex-col gap-2">
          <span
            class="text-[9px] font-bold text-slate uppercase tracking-wider"
            >Browser Environment context</span
          >
          <div class="text-[11px] text-slate space-y-1">
            <div
              class="flex justify-between border-b border-hairline-soft pb-0.5"
            >
              <span>Browser:</span>
              <span id="env-browser" class="font-bold text-primary"
                >Detecting...</span
              >
            </div>
            <div
              class="flex justify-between border-b border-hairline-soft pb-0.5"
            >
              <span>Operating System:</span>
              <span id="env-os" class="font-semibold text-primary"
                >Detecting...</span
              >
            </div>
            <div class="flex justify-between">
              <span>Pacing Stability:</span>
              <span id="env-stability" class="font-mono text-stone"
                >Evaluating...</span
              >
            </div>
