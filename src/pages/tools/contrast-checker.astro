  // Color Conversions & Helper Math
  function hexToRgb(hex: string) {
    const shorthandRegex = /^#?([a-f\d])([a-f\d])([a-f\d])$/i;
    const cleanHex = hex.replace(shorthandRegex, (_, r, g, b) => r + r + g + g + b + b);
    const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(cleanHex);
    return result ? {
      r: parseInt(result[1], 16),
      g: parseInt(result[2], 16),
      b: parseInt(result[3], 16)
    } : { r: 0, g: 0, b: 0 };
  }

  function rgbToHex(r: number, g: number, b: number): string {
    const toHex = (c: number) => {
      const hex = Math.max(0, Math.min(255, c)).toString(16);
      return hex.length === 1 ? '0' + hex : hex;
    };
    return `#${toHex(r)}${toHex(g)}${toHex(b)}`.toUpperCase();
  }

  function rgbToHsl(r: number, g: number, b: number) {
    r /= 255; g /= 255; b /= 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h = 0, s = 0, l = (max + min) / 2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch (max) {
        case r: h = (g - b) / d + (g < b ? 6 : 0); break;
        case g: h = (b - r) / d + 2; break;
        case b: h = (r - g) / d + 4; break;
      }
      h /= 6;
    }
    return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
  }

  function hslToRgb(h: number, s: number, l: number) {
    s /= 100; l /= 100;
    const k = (n: number) => (n + h / 30) % 12;
    const a = s * Math.min(l, 1 - l);
    const f = (n: number) => l - a * Math.max(-1, Math.min(k(n) - 3, 9 - k(n), 1));
    return {
      r: Math.round(255 * f(0)),
      g: Math.round(255 * f(8)),
      b: Math.round(255 * f(4))
    };
  }

  function parseToHex(str: string): string {
    const s = str.trim().toLowerCase();
    if (s.startsWith('#')) return str.toUpperCase();
    
    // Parse rgb(r, g, b)
    if (s.startsWith('rgb')) {
      const parts = s.match(/\d+/g);
      if (parts && parts.length >= 3) {
        return rgbToHex(parseInt(parts[0]), parseInt(parts[1]), parseInt(parts[2]));
      }
    }
    
    // Parse hsl(h, s%, l%)
    if (s.startsWith('hsl')) {
      const parts = s.match(/\d+/g);
      if (parts && parts.length >= 3) {
        const { r, g, b } = hslToRgb(parseInt(parts[0]), parseInt(parts[1]), parseInt(parts[2]));
        return rgbToHex(r, g, b);
      }
    }
    return str.toUpperCase();
  }

  function getLuminance(r: number, g: number, b: number): number {
    const a = [r, g, b].map(v => {
      v /= 255;
      return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
    });
    return a[0] * 0.2126 + a[1] * 0.7152 + a[2] * 0.0722;
  }

  function calculateContrastRatio(hex1: string, hex2: string): number {
    const rgb1 = hexToRgb(hex1);
    const rgb2 = hexToRgb(hex2);
    const lum1 = getLuminance(rgb1.r, rgb1.g, rgb1.b);
    const lum2 = getLuminance(rgb2.r, rgb2.g, rgb2.b);
    return lum1 > lum2 ? (lum1 + 0.05) / (lum2 + 0.05) : (lum2 + 0.05) / (lum1 + 0.05);
  }

  // Active pair memory
  let activeFg = '#1C1C1E';
  let activeBg = '#FFFFFF';

  function updateActiveColors(fg: string, bg: string, updateSliders = true, updateFields = true) {
    activeFg = parseToHex(fg);
    activeBg = parseToHex(bg);

    if (updateFields) {
      if (fgText) fgText.value = activeFg;
      if (bgText) bgText.value = activeBg;
    }

    if (fgLabelHex) fgLabelHex.textContent = activeFg;
    if (bgLabelHex) bgLabelHex.textContent = activeBg;

    if (fgPicker) fgPicker.value = activeFg.toLowerCase();
    if (bgPicker) bgPicker.value = activeBg.toLowerCase();

    // Decode to HSL for sliders
    const rgbFg = hexToRgb(activeFg);
    const hslFg = rgbToHsl(rgbFg.r, rgbFg.g, rgbFg.b);
    const rgbBg = hexToRgb(activeBg);
    const hslBg = rgbToHsl(rgbBg.r, rgbBg.g, rgbBg.b);

    if (updateSliders) {
      if (fgH) fgH.value = hslFg.h.toString();
      if (fgS) fgS.value = hslFg.s.toString();
      if (fgL) fgL.value = hslFg.l.toString();

      if (bgH) bgH.value = hslBg.h.toString();
      if (bgS) bgS.value = hslBg.s.toString();
      if (bgL) bgL.value = hslBg.l.toString();
    }

    if (fgValH) fgValH.textContent = `${hslFg.h}°`;
    if (fgValS) fgValS.textContent = `${hslFg.s}%`;
    if (fgValL) fgValL.textContent = `${hslFg.l}%`;

    if (bgValH) bgValH.textContent = `${hslBg.h}°`;
    if (bgValS) bgValS.textContent = `${hslBg.s}%`;
    if (bgValL) bgValL.textContent = `${hslBg.l}%`;

    // Apply styles to sandbox preview
    if (previewFrame) {
      previewFrame.style.backgroundColor = activeBg;
      previewFrame.style.color = activeFg;
    }

    // Recalculate
    auditContrast();
    syncUrl();
  }

  function auditContrast() {
    const ratio = calculateContrastRatio(activeFg, activeBg);

    if (ratioDisplay) {
      ratioDisplay.textContent = `${ratio.toFixed(1)}:1`;
    }

    // Evaluate badges
    const normAA = ratio >= 4.5;
    const normAAA = ratio >= 7.0;
    const largeAA = ratio >= 3.0;
    const largeAAA = ratio >= 4.5;

    renderBadge(badgeNormAA, normAA);
    renderBadge(badgeNormAAA, normAAA);
    renderBadge(badgeLargeAA, largeAA);
    renderBadge(badgeLargeAAA, largeAAA);

    // Compute fixes if any fail
    if (!normAAA) {
      generateFixSuggestions(activeFg, activeBg);
      if (fixSuggestionsPanel) fixSuggestionsPanel.classList.remove('hidden');
    } else {
      if (fixSuggestionsPanel) fixSuggestionsPanel.classList.add('hidden');
    }

    // Update the multi-palette grid too
    renderPaletteGrid();
  }

  function renderBadge(el: HTMLElement | null, pass: boolean) {
    if (!el) return;
    const prevClass = el.className;
    if (pass) {
      el.className = 'text-xs font-black uppercase tracking-wider px-2 py-0.5 rounded bg-success-accent/15 text-success-accent';
      el.textContent = 'PASS';
      if (!prevClass.includes('bg-success-accent')) {
        el.classList.add('badge-pass-anim');
        setTimeout(() => el.classList.remove('badge-pass-anim'), 400);
      }
    } else {
      el.className = 'text-xs font-black uppercase tracking-wider px-2 py-0.5 rounded bg-brand-red/15 text-brand-red-dark';
      el.textContent = 'FAIL';
      if (!prevClass.includes('bg-brand-red')) {
        el.classList.add('badge-fail-anim');
        setTimeout(() => el.classList.remove('badge-fail-anim'), 400);
      }
    }
  }

  // Suggest a fix generator
  function generateFixSuggestions(fg: string, bg: string) {
    if (!fixSwatchesGrid) return;
    fixSwatchesGrid.innerHTML = '';

    const rgbFg = hexToRgb(fg);
    const hslFg = rgbToHsl(rgbFg.r, rgbFg.g, rgbFg.b);
    
    const rgbBg = hexToRgb(bg);

    // Search lightness space [0..100] for nearest compliant colors
    const options: Array<{ label: string; hex: string; ratio: number; diff: number }> = [];

    // Targets to seek
    const targets = [
      { ratio: 4.5, label: 'AA Pass (4.5:1)' },
      { ratio: 7.0, label: 'AAA Pass (7.0:1)' }
    ];

    targets.forEach(target => {
      let bestLightnessLighter = -1;
      let minDiffLighter = Infinity;
      let bestLightnessDarker = -1;
      let minDiffDarker = Infinity;

      for (let l = 0; l <= 100; l++) {
        const testHex = hslToHex(hslFg.h, hslFg.s, l);
        const currentRatio = calculateContrastRatio(testHex, bg);

        if (currentRatio >= target.ratio) {
          const diff = Math.abs(l - hslFg.l);
          if (l > hslFg.l) {
            if (diff < minDiffLighter) {
              minDiffLighter = diff;
              bestLightnessLighter = l;
            }
          } else {
            if (diff < minDiffDarker) {
              minDiffDarker = diff;
              bestLightnessDarker = l;
            }
          }
        }
      }

      if (bestLightnessLighter !== -1) {
        const hex = hslToHex(hslFg.h, hslFg.s, bestLightnessLighter);
        options.push({
          label: `${target.label} Lighter`,
          hex,
          ratio: calculateContrastRatio(hex, bg),
          diff: minDiffLighter
        });
      }
      if (bestLightnessDarker !== -1) {
        const hex = hslToHex(hslFg.h, hslFg.s, bestLightnessDarker);
        options.push({
          label: `${target.label} Darker`,
          hex,
          ratio: calculateContrastRatio(hex, bg),
          diff: minDiffDarker
        });
      }
    });

    // Sort by smallest distance/diff and limit to 3 swatches
    options.sort((a, b) => a.diff - b.diff);
    const selectedOptions = options.slice(0, 3);

    if (selectedOptions.length === 0) {
      fixSwatchesGrid.innerHTML = `<span class="text-xs text-stone italic">No clean HSL adjustments found. Try swapping layers.</span>`;
      return;
    }

    selectedOptions.forEach(opt => {
      const btn = document.createElement('button');
      btn.className = 'flex items-center gap-2 px-3 py-2 rounded-lg border border-hairline bg-canvas hover:scale-[1.03] transition-all duration-150 text-left shadow-sm cursor-pointer';
      btn.innerHTML = `
        <span class="w-5 h-5 rounded border border-hairline-strong inline-block" style="background-color: ${opt.hex}"></span>
        <div class="flex flex-col">
          <span class="text-[10px] font-black text-slate uppercase">${opt.label}</span>
          <span class="font-mono text-xs font-semibold text-charcoal">${opt.hex} (${opt.ratio.toFixed(1)}:1)</span>
        </div>
      `;
      btn.addEventListener('click', () => {
        // Shake preview and load new foreground
        if (sandboxCard) {
          sandboxCard.classList.add('shake-anim');
          setTimeout(() => sandboxCard.classList.remove('shake-anim'), 300);
        }
        updateActiveColors(opt.hex, bg);
        // Add to history
        pushHistory(opt.hex, bg);
      });
      fixSwatchesGrid.appendChild(btn);
    });
  }

  function hslToHex(h: number, s: number, l: number) {
    const { r, g, b } = hslToRgb(h, s, l);
    return rgbToHex(r, g, b);
  }

  // Multi-Palette Auditing Grid
  function renderPaletteGrid() {
    if (!paletteGrid || !multiInput) return;
    
    // Parse input colors
    const colors = multiInput.value
      .split(/[\s,]+/)
      .map(c => c.trim())
      .filter(c => c.length > 0)
      .map(c => {
        try {
          return parseToHex(c);
        } catch {
          return null;
        }
      })
      .filter(c => c && (c.startsWith('#') || c.length === 7));

    paletteGrid.innerHTML = '';

    colors.forEach(col => {
      if (!col) return;
      const ratio = calculateContrastRatio(col, activeBg);
      const aaPass = ratio >= 4.5;

      const card = document.createElement('div');
      card.className = 'flex flex-col items-stretch p-2 bg-canvas rounded-lg border border-hairline gap-2 hover:scale-[1.01] transition-transform text-center';
      
      const badgeHTML = aaPass 
        ? `<span class="text-[9px] font-bold text-success-accent bg-success-accent/10 px-1 rounded">AA PASS</span>`
        : `<span class="text-[9px] font-bold text-brand-red-dark bg-brand-red/10 px-1 rounded">AA FAIL</span>`;

      card.innerHTML = `
        <div class="h-6 rounded border border-hairline-soft" style="background-color: ${col}"></div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] font-bold text-charcoal">${col}</span>
          <span class="text-[11px] font-semibold text-slate">${ratio.toFixed(1)}:1</span>
        </div>
        <div class="flex justify-center gap-1">${badgeHTML}</div>
        <button class="text-[10px] text-brand-blue font-bold hover:underline cursor-pointer">Set FG</button>
      `;

      card.querySelector('button')?.addEventListener('click', () => {
        updateActiveColors(col, activeBg);
        pushHistory(col, activeBg);
      });

      paletteGrid.appendChild(card);
    });
  }

  // Save pairs & Library (localStorage)
  const LIBRARY_KEY = 'toolkify-contrast-library';
  interface SavedPair {
    id: string;
    name: string;
    fg: string;
    bg: string;
  }

  function getLibrary(): SavedPair[] {
    try {
      const raw = localStorage.getItem(LIBRARY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function saveLibrary(lib: SavedPair[]) {
    localStorage.setItem(LIBRARY_KEY, JSON.stringify(lib));
  }

  function renderLibrary() {
    if (!libraryContainer) return;
    const lib = getLibrary();
    libraryContainer.innerHTML = '';

    if (lib.length === 0) {
      libraryContainer.innerHTML = `<p class="text-xs text-stone italic py-1">No saved pairings yet. Click 'Save Active' to build your collection.</p>`;
      return;
    }

    lib.forEach(item => {
      const row = document.createElement('div');
      row.className = 'flex items-center justify-between p-2 rounded-lg bg-surface border border-hairline-soft gap-2 text-xs';
      row.innerHTML = `
        <div class="flex items-center gap-2 flex-grow truncate">
          <div class="flex -space-x-1">
            <span class="w-4 h-4 rounded-full border border-white" style="background-color: ${item.fg}"></span>
            <span class="w-4 h-4 rounded-full border border-white" style="background-color: ${item.bg}"></span>
          </div>
          <span class="font-semibold text-charcoal truncate" title="${item.name}">${item.name}</span>
        </div>
        <div class="flex items-center gap-2">
          <button class="text-brand-blue font-bold hover:underline btn-load-pair cursor-pointer">Load</button>
          <button class="text-brand-red-dark font-bold hover:underline btn-del-pair cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </button>
        </div>
      `;

      row.querySelector('.btn-load-pair')?.addEventListener('click', () => {
        updateActiveColors(item.fg, item.bg);
        pushHistory(item.fg, item.bg);
      });

      row.querySelector('.btn-del-pair')?.addEventListener('click', () => {
        const clean = getLibrary().filter(x => x.id !== item.id);
        saveLibrary(clean);
        renderLibrary();
      });

      libraryContainer.appendChild(row);
    });
  }

  // History strip
  const HISTORY_KEY = 'toolkify-contrast-history';
  interface HistoryPair {
    fg: string;
    bg: string;
  }

  function getHistory(): HistoryPair[] {
    try {
      const raw = localStorage.getItem(HISTORY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function pushHistory(fg: string, bg: string) {
    let hist = getHistory().filter(h => !(h.fg.toLowerCase() === fg.toLowerCase() && h.bg.toLowerCase() === bg.toLowerCase()));
    hist.unshift({ fg, bg });
    hist = hist.slice(0, 5); // cap at 5
    localStorage.setItem(HISTORY_KEY, JSON.stringify(hist));
    renderHistory();
  }

  function renderHistory() {
    if (!recentStrip) return;
    const hist = getHistory();
    recentStrip.innerHTML = '';

    if (hist.length === 0) {
      recentStrip.innerHTML = `<span class="text-xs text-stone italic">No recent history</span>`;
      return;
    }

    hist.forEach(item => {
      const bubble = document.createElement('button');
      bubble.className = 'flex items-center gap-1.5 p-1 rounded-full border border-hairline bg-canvas hover:scale-105 active:scale-95 transition-all text-xs cursor-pointer';
      bubble.innerHTML = `
        <div class="flex -space-x-1">
          <span class="w-3.5 h-3.5 rounded-full border border-white" style="background-color: ${item.fg}"></span>
          <span class="w-3.5 h-3.5 rounded-full border border-white" style="background-color: ${item.bg}"></span>
        </div>
        <span class="font-mono text-[9px] font-bold text-slate pr-1">${item.fg} / ${item.bg}</span>
      `;
      bubble.addEventListener('click', () => {
        updateActiveColors(item.fg, item.bg);
      });
      recentStrip.appendChild(bubble);
    });
  }

  // EyeDropper API Integrations
  // @ts-ignore
  if (window.EyeDropper) {
    if (btnEyedropperFg) btnEyedropperFg.classList.remove('hidden');
    if (btnEyedropperBg) btnEyedropperBg.classList.remove('hidden');

    btnEyedropperFg?.addEventListener('click', async () => {
      try {
        // @ts-ignore
        const eyeDropper = new window.EyeDropper();
        const result = await eyeDropper.open();
        updateActiveColors(result.sRGBHex, activeBg);
        pushHistory(result.sRGBHex, activeBg);
      } catch (err) {
        console.warn('EyeDropper closed or failed', err);
      }
    });

    btnEyedropperBg?.addEventListener('click', async () => {
      try {
        // @ts-ignore
        const eyeDropper = new window.EyeDropper();
        const result = await eyeDropper.open();
        updateActiveColors(activeFg, result.sRGBHex);
        pushHistory(activeFg, result.sRGBHex);
      } catch (err) {
        console.warn('EyeDropper closed or failed', err);
      }
    });
  }

  // URL State Synchronizations
  function syncUrl() {
    const url = new URL(window.location.href);
    url.searchParams.set('fg', activeFg.replace('#', ''));
    url.searchParams.set('bg', activeBg.replace('#', ''));
    window.history.replaceState({}, '', url.toString());
  }

  function loadFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const fgParam = params.get('fg');
    const bgParam = params.get('bg');
    
    let fgVal = '#1C1C1E';
    let bgVal = '#FFFFFF';

    if (fgParam) fgVal = fgParam.startsWith('#') ? fgParam : '#' + fgParam;
    if (bgParam) bgVal = bgParam.startsWith('#') ? bgParam : '#' + bgParam;

    updateActiveColors(fgVal, bgVal);
  }

  // UI Event Listeners Hookups
  if (fgPicker && fgText) {
    fgPicker.addEventListener('input', () => {
      updateActiveColors(fgPicker.value, activeBg, true, false);
      if (fgText) fgText.value = fgPicker.value.toUpperCase();
    });
    fgPicker.addEventListener('change', () => {
      pushHistory(activeFg, activeBg);
    });
    fgText.addEventListener('input', () => {
      if (fgText.value.length >= 4) {
        updateActiveColors(fgText.value, activeBg, true, false);
      }
    });
    fgText.addEventListener('change', () => {
      pushHistory(activeFg, activeBg);
    });
  }

  if (bgPicker && bgText) {
    bgPicker.addEventListener('input', () => {
      updateActiveColors(activeFg, bgPicker.value, true, false);
      if (bgText) bgText.value = bgPicker.value.toUpperCase();
    });
    bgPicker.addEventListener('change', () => {
      pushHistory(activeFg, activeBg);
    });
    bgText.addEventListener('input', () => {
      if (bgText.value.length >= 4) {
        updateActiveColors(activeFg, bgText.value, true, false);
      }
    });
    bgText.addEventListener('change', () => {
      pushHistory(activeFg, activeBg);
    });
  }

  // Sliders input hooks
  const syncFromSliders = (source: 'fg' | 'bg') => {
    if (source === 'fg') {
      if (fgH && fgS && fgL) {
        const hex = hslToHex(parseInt(fgH.value), parseInt(fgS.value), parseInt(fgL.value));
        updateActiveColors(hex, activeBg, false, true);
      }
    } else {
      if (bgH && bgS && bgL) {
        const hex = hslToHex(parseInt(bgH.value), parseInt(bgS.value), parseInt(bgL.value));
        updateActiveColors(activeFg, hex, false, true);
      }
    }
  };

  [fgH, fgS, fgL].forEach(slider => {
    slider?.addEventListener('input', () => syncFromSliders('fg'));
    slider?.addEventListener('change', () => pushHistory(activeFg, activeBg));
  });

  [bgH, bgS, bgL].forEach(slider => {
    slider?.addEventListener('input', () => syncFromSliders('bg'));
    slider?.addEventListener('change', () => pushHistory(activeFg, activeBg));
  });

  // Swap Hook
  if (btnSwap) {
    btnSwap.addEventListener('click', () => {
      const oldFg = activeFg;
      const oldBg = activeBg;
      updateActiveColors(oldBg, oldFg);
      pushHistory(oldBg, oldFg);
    });
  }

  // Preset hooks
  presets.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const current = e.currentTarget as HTMLButtonElement;
      const fg = current.dataset.fg || '#1c1c1e';
      const bg = current.dataset.bg || '#ffffff';
      updateActiveColors(fg, bg);
      pushHistory(fg, bg);
    });
  });

  // Slider for preview font size
  if (fontSlider && fontLabel) {
    fontSlider.addEventListener('input', (e) => {
      const size = (e.target as HTMLInputElement).value;
      fontLabel.textContent = `${size}px`;
      if (previewHeading) previewHeading.style.fontSize = `${size}px`;
    });
  }

  // Weight selector
  weightSelector?.addEventListener('change', () => {
    if (previewHeading && previewBody && weightSelector) {
      previewHeading.style.fontWeight = weightSelector.value;
      previewBody.style.fontWeight = weightSelector.value;
    }
  });

  // Multi color grid auditor trigger
  btnAuditPalette?.addEventListener('click', () => {
    renderPaletteGrid();
  });
  multiInput?.addEventListener('keyup', (e) => {
    if (e.key === 'Enter') renderPaletteGrid();
  });

  // Save pair to library trigger
  btnSavePair?.addEventListener('click', () => {
    const pairName = prompt('Enter a name for this color pairing:', `${activeFg} & ${activeBg}`);
    if (!pairName) return;

    const lib = getLibrary();
    lib.push({
      id: Date.now().toString(),
      name: pairName.trim(),
      fg: activeFg,
      bg: activeBg
    });
    saveLibrary(lib);
    renderLibrary();
  });

  // Guide Toggle Hook
  btnToggleGuide?.addEventListener('click', () => {
    if (guideContent && guideArrow) {
      const isHidden = guideContent.classList.toggle('hidden');
      guideArrow.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
    }
  });

  // Share button action
  shareBtn?.addEventListener('click', () => {
    try {
      const url = new URL(window.location.href);
      url.searchParams.set('fg', activeFg.replace('#', ''));
      url.searchParams.set('bg', activeBg.replace('#', ''));
      const finalUrl = url.toString();

      const shareData = {
        title: document.title || "Color Contrast Checker",
        url: finalUrl
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(finalUrl);
          }
        });
      } else {
        copyToClipboard(finalUrl);
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    } catch (e) {
      console.error(e);
    }
  });

  // Reset button action
  resetBtn?.addEventListener('click', () => {
    // Clear URL parameters
    if (window.history.pushState) {
      const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
      window.history.pushState({path:newurl}, '', newurl);
    }
    updateActiveColors('#1C1C1E', '#FFFFFF');
    pushHistory('#1C1C1E', '#FFFFFF');
  });

  // Modal interactions
  howItWorksBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.remove('hidden');
  });
  closeModalBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  modalOkBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  howItWorksModal?.addEventListener('click', (e) => {
    if (e.target === howItWorksModal) {
      howItWorksModal.classList.add('hidden');
    }
  });

  // Mobile navigation tabs
  function setMobileTab(tab: 'config' | 'preview') {
    if (!tabConfigBtn || !tabPreviewBtn || !colInputs || !colPreview) return;
    if (tab === 'config') {
      tabConfigBtn.className = 'flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas';
      tabPreviewBtn.className = 'flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer text-slate hover:text-primary';
      colInputs.classList.remove('hidden');
      colPreview.classList.add('hidden');
    } else {
      tabConfigBtn.className = 'flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer text-slate hover:text-primary';
      tabPreviewBtn.className = 'flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas';
      colInputs.classList.add('hidden');
      colPreview.classList.remove('hidden');
    }
  }
  tabConfigBtn?.addEventListener('click', () => setMobileTab('config'));
  tabPreviewBtn?.addEventListener('click', () => setMobileTab('preview'));

  // FAQ Accordion Toggle Interaction
  const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
  faqToggleButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      
      // Close other open accordions
      faqToggleButtons.forEach((otherBtn) => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute("aria-expanded", "false");
          const otherContent = otherBtn.nextElementSibling;
          if (otherContent) otherContent.classList.add("hidden");
          otherBtn.querySelector("svg")?.classList.remove("rotate-180");
        }
      });

      // Toggle current accordion
      btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
      const content = btn.nextElementSibling;
      if (content) {
        content.classList.toggle("hidden");
      }
      btn.querySelector("svg")?.classList.toggle("rotate-180");
    });
  });

  // Initializations
  loadFromUrl();
  renderLibrary();
  renderHistory();
</script>
