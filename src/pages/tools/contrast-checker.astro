---
import Layout from '../../layouts/Layout.astro';
import RelatedTools from '../../components/RelatedTools.astro';

// Tool metadata
const name = "Color Contrast Checker";
const category = "design";
const tier = "Design & Accessibility";

// On-page SEO metadata
const pageTitle = "Color Contrast Checker - Free WCAG Accessibility Color Contrast Tool";
const description = "Use our free web color contrast checker to test background and foreground text compliance for WCAG 2.1 AA & AAA ratings. Inspect and audit colors in real-time.";
const canonicalUrl = "https://toolkify.app/tools/contrast-checker";
const ogImage = "/og/color-contrast-checker.png";
const keywords = "Color Contrast Checker, color contrast checker, color contrast checker accessibility, web color contrast checker, website color contrast checker, free color contrast checker, color checker, contrast color checker, color checker passport, contrast checker, web contrast checker, website contrast checker, colour contrast checker, we color contrast checker";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Color Contrast Checker",
      "alternateName": "WCAG Accessibility Color Contrast Checker",
      "url": "https://toolkify.app/tools/contrast-checker",
      "description": "Use our free web color contrast checker to test background and foreground text compliance for WCAG 2.1 AA & AAA ratings. Inspect and audit colors in real-time.",
      "applicationCategory": "DesignApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Real-time contrast ratio score and WCAG 2.1 AA/AAA validation",
        "Interactive HSL and RGB color sliders",
        "Automatic lightness adjustment suggestions for failing colors",
        "Multi-color palette auditing grid",
        "Live text preview sandbox with custom weights and sizes"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Design & Accessibility Tools",
          "item": "https://toolkify.app/#design"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Color Contrast Checker",
          "item": "https://toolkify.app/tools/contrast-checker"
        }
      ]
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best color contrast checker tool",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The best color contrast checker tool is one that allows real-time interactive adjustments (using HSL and RGB sliders) and automatically generates lightness fixes for failing color pairs. TOOLKIFY' Color Contrast Checker is a free, 100% private, client-side tool that supports single pairing validation, live text rendering previews, and multi-color palette auditing.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to use a color checker",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To use a color checker, enter your hex codes, RGB, or HSL values for both the foreground text and the background canvas. The tool immediately outputs the exact contrast ratio and indicates whether it passes WCAG 2.1 AA and AAA standards. You can adjust the sliders or test different font weights to ensure optimal legibility.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to use contrast checker",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Using a contrast checker involves selecting a background and foreground color pair and comparing their relative luminance ratio. If the ratio is below 4.5:1 for normal text or 3.0:1 for large text, you should use the tool's suggested adjustments to select a compliant lightness value that preserves your design's hue and saturation.</p>"
          }
        }
      ]
    }
  </script>
  <style>
    /* Custom shake and pulse animations */
    @keyframes pulse-success {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    @keyframes pulse-fail {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(0.95); }
    }
    @keyframes shake-apply {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      75% { transform: translateX(4px); }
    }
    .badge-pass-anim {
      animation: pulse-success 0.4s ease-in-out;
    }
    .badge-fail-anim {
      animation: pulse-fail 0.4s ease-in-out;
    }
    .shake-anim {
      animation: shake-apply 0.3s ease-in-out;
    }
  </style>

  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-10 flex flex-col gap-6 animate-fade-in-up">
    <!-- Header -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue">Contrast Checker</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-primary">Color Contrast Checker</h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">Design & Accessibility</span>
          <div class="flex items-center gap-2">
            <button
              type="button"
              id="share-btn"
              class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
              aria-label="Share tool link"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>Share</span>
            </button>
            <button
              type="button"
              id="how-it-works-btn"
              class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
              aria-label="How contrast checker works"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>How it works</span>
            </button>
            <button
              type="button"
              id="reset-btn"
              class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
              aria-label="Reset calculator inputs"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
              </svg>
              <span>Reset</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Tabs (Visible only on mobile/tablet) -->
    <div class="flex lg:hidden rounded-full bg-surface p-1 border border-hairline w-full self-start max-w-[280px]">
      <button
        type="button"
        id="tab-config-btn"
        class="flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-primary text-canvas"
      >
        Configure
      </button>
      <button
        type="button"
        id="tab-preview-btn"
        class="flex-1 text-center text-xs py-1.5 rounded-full font-semibold transition-all cursor-pointer text-slate hover:text-primary"
      >
        Results
      </button>
    </div>

    <!-- Main Grid layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      <!-- Controls Column (Left, 5 cols) -->
      <div id="col-inputs" class="lg:col-span-5 flex flex-col gap-6">
        
        <!-- Main Dual Picker Card -->
        <div class="card-base flex flex-col gap-6" id="panel-inputs">
          <h2 class="font-display font-semibold text-lg text-primary pb-2 border-b border-hairline flex items-center justify-between">
            <span>Color Configuration</span>
            <button id="btn-swap-colors" class="text-xs text-brand-blue hover:text-blue-pressed flex items-center gap-1 cursor-pointer transition-colors duration-200" title="Swap Foreground & Background">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
              Swap Colors
            </button>
          </h2>

          <!-- Pickers Group -->
          <div class="flex flex-col gap-5">
            <!-- Text (Foreground) Color -->
            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-center">
                <label class="text-xs font-bold text-charcoal uppercase tracking-wider flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full bg-brand-blue"></span> Text Color (Foreground)
                </label>
                <div class="flex items-center gap-2">
                  <span id="fg-val-hex" class="font-mono text-xs text-stone font-semibold bg-surface px-1.5 py-0.5 rounded border border-hairline-soft">#1C1C1E</span>
                  <button id="btn-eyedropper-fg" class="hidden text-xs text-slate hover:text-primary flex items-center gap-1" title="Pick color from screen">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                  </button>
                </div>
              </div>
              <div class="flex gap-2">
                <input type="color" id="fg-picker" value="#1c1c1e" class="w-12 h-10 border border-hairline-strong rounded cursor-pointer p-0.5" />
                <input type="text" id="fg-text" value="#1C1C1E" class="text-input flex-grow font-mono uppercase text-sm" placeholder="#HEX, rgb(), or hsl()" />
              </div>
              <!-- HSL & RGB Sliders (Interactive controls) -->
              <div class="bg-surface-soft p-3 rounded-lg border border-hairline flex flex-col gap-2.5">
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between text-[11px] font-semibold text-slate">
                    <span>Hue (H)</span>
                    <span id="fg-val-h">0°</span>
                  </div>
                  <input type="range" id="slider-fg-h" min="0" max="360" value="0" class="w-full h-1 bg-gradient-to-r from-red-500 via-yellow-500 via-green-500 via-blue-500 to-red-500 rounded-lg appearance-none cursor-pointer" />
                </div>
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between text-[11px] font-semibold text-slate">
                    <span>Saturation (S)</span>
                    <span id="fg-val-s">0%</span>
                  </div>
                  <input type="range" id="slider-fg-s" min="0" max="100" value="0" class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer" />
                </div>
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between text-[11px] font-semibold text-slate">
                    <span>Lightness (L)</span>
                    <span id="fg-val-l">11%</span>
                  </div>
                  <input type="range" id="slider-fg-l" min="0" max="100" value="11" class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer" />
                </div>
              </div>
            </div>

            <!-- Background Color -->
            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-center">
                <label class="text-xs font-bold text-charcoal uppercase tracking-wider flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full bg-brand-yellow"></span> Background Color
                </label>
                <div class="flex items-center gap-2">
                  <span id="bg-val-hex" class="font-mono text-xs text-stone font-semibold bg-surface px-1.5 py-0.5 rounded border border-hairline-soft">#FFFFFF</span>
                  <button id="btn-eyedropper-bg" class="hidden text-xs text-slate hover:text-primary flex items-center gap-1" title="Pick color from screen">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                  </button>
                </div>
              </div>
              <div class="flex gap-2">
                <input type="color" id="bg-picker" value="#ffffff" class="w-12 h-10 border border-hairline-strong rounded cursor-pointer p-0.5" />
                <input type="text" id="bg-text" value="#FFFFFF" class="text-input flex-grow font-mono uppercase text-sm" placeholder="#HEX, rgb(), or hsl()" />
              </div>
              <!-- HSL & RGB Sliders for Background -->
              <div class="bg-surface-soft p-3 rounded-lg border border-hairline flex flex-col gap-2.5">
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between text-[11px] font-semibold text-slate">
                    <span>Hue (H)</span>
                    <span id="bg-val-h">0°</span>
                  </div>
                  <input type="range" id="slider-bg-h" min="0" max="360" value="0" class="w-full h-1 bg-gradient-to-r from-red-500 via-yellow-500 via-green-500 via-blue-500 to-red-500 rounded-lg appearance-none cursor-pointer" />
                </div>
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between text-[11px] font-semibold text-slate">
                    <span>Saturation (S)</span>
                    <span id="bg-val-s">0%</span>
                  </div>
                  <input type="range" id="slider-bg-s" min="0" max="100" value="0" class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer" />
                </div>
                <div class="flex flex-col gap-1">
                  <div class="flex justify-between text-[11px] font-semibold text-slate">
                    <span>Lightness (L)</span>
                    <span id="bg-val-l">100%</span>
                  </div>
                  <input type="range" id="slider-bg-l" min="0" max="100" value="100" class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer" />
                </div>
              </div>
            </div>
          </div>

          <!-- Presets -->
          <div class="flex flex-col gap-2.5">
            <span class="text-xs font-bold text-slate uppercase tracking-wider">Miro Design System Audits</span>
            <div class="grid grid-cols-2 gap-2">
              <button class="btn-preset text-xs p-2.5 rounded-lg border border-hairline bg-brand-yellow text-primary font-medium hover:scale-[1.02] active:scale-95 transition-all duration-150 cursor-pointer" data-fg="#1c1c1e" data-bg="#ffd02f">
                Yellow Canvas
              </button>
              <button class="btn-preset text-xs p-2.5 rounded-lg border border-hairline bg-teal-light text-moss-dark font-medium hover:scale-[1.02] active:scale-95 transition-all duration-150 cursor-pointer" data-fg="#187574" data-bg="#c3faf5">
                Teal Canvas
              </button>
              <button class="btn-preset text-xs p-2.5 rounded-lg border border-hairline bg-coral-light text-coral-dark font-medium hover:scale-[1.02] active:scale-95 transition-all duration-150 cursor-pointer" data-fg="#600000" data-bg="#ffc6c6">
                Coral Canvas
              </button>
              <button class="btn-preset text-xs p-2.5 rounded-lg border border-hairline bg-rose-light text-primary font-medium hover:scale-[1.02] active:scale-95 transition-all duration-150 cursor-pointer" data-fg="#1c1c1e" data-bg="#fde0f0">
                Rose Canvas
              </button>
            </div>
          </div>
        </div>

        <!-- Library & Saved Pairs Card -->
        <div class="card-base flex flex-col gap-4">
          <div class="flex justify-between items-center">
            <h3 class="font-display font-semibold text-sm text-primary uppercase tracking-wider">Saved Pairs</h3>
            <button id="btn-save-pair" class="text-xs bg-brand-blue text-white font-medium py-1.5 px-3 rounded-full hover:bg-blue-pressed transition-colors cursor-pointer">
              Save Active
            </button>
          </div>
          <div id="library-container" class="flex flex-col gap-2 max-h-[160px] overflow-y-auto pr-1">
            <p class="text-xs text-stone italic py-1">No saved pairings yet. Click 'Save Active' to build your collection.</p>
          </div>
        </div>

      </div>

      <!-- Live Previews & Results Column (Right, 7 cols) -->
      <div id="col-preview" class="lg:col-span-7 flex flex-col gap-6 hidden lg:flex">

        <!-- Giant Score Card -->
        <div class="card-base flex flex-col sm:flex-row items-center justify-between gap-6 bg-surface">
          <div class="flex flex-col gap-1 text-center sm:text-left">
            <span class="text-xs font-semibold text-slate uppercase tracking-wider">Contrast Ratio Score</span>
            <div id="ratio-display" class="font-display font-medium text-4xl sm:text-6xl tracking-tight text-primary transition-all duration-150">21.0:1</div>
          </div>

          <!-- Compliance badges grid -->
          <div class="grid grid-cols-2 gap-3 w-full sm:w-auto">
            <div class="flex flex-col items-center p-3 bg-canvas rounded-xl border border-hairline text-center gap-1 transition-all">
              <span class="text-[9px] font-bold text-slate uppercase tracking-wide">Normal AA (4.5)</span>
              <span id="badge-norm-aa" class="text-xs font-black uppercase tracking-wider px-2 py-0.5 rounded">PASS</span>
            </div>
            <div class="flex flex-col items-center p-3 bg-canvas rounded-xl border border-hairline text-center gap-1 transition-all">
              <span class="text-[9px] font-bold text-slate uppercase tracking-wide">Normal AAA (7.0)</span>
              <span id="badge-norm-aaa" class="text-xs font-black uppercase tracking-wider px-2 py-0.5 rounded">PASS</span>
            </div>
            <div class="flex flex-col items-center p-3 bg-canvas rounded-xl border border-hairline text-center gap-1 transition-all">
              <span class="text-[9px] font-bold text-slate uppercase tracking-wide">Large AA (3.0)</span>
              <span id="badge-large-aa" class="text-xs font-black uppercase tracking-wider px-2 py-0.5 rounded">PASS</span>
            </div>
            <div class="flex flex-col items-center p-3 bg-canvas rounded-xl border border-hairline text-center gap-1 transition-all">
              <span class="text-[9px] font-bold text-slate uppercase tracking-wide">Large AAA (4.5)</span>
              <span id="badge-large-aaa" class="text-xs font-black uppercase tracking-wider px-2 py-0.5 rounded">PASS</span>
            </div>
          </div>
        </div>

        <!-- Suggest a Fix (Crucial UI addition) -->
        <div id="fix-suggestions-panel" class="card-base flex flex-col gap-3.5 bg-yellow-light/10 border-brand-yellow/30 hidden">
          <div class="flex items-center gap-2 text-yellow-dark">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-yellow-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <h3 class="font-display font-bold text-sm uppercase tracking-wide">Suggested Contrast Fixes</h3>
          </div>
          <p class="text-xs text-slate -mt-1.5">Here are compliant lightness adjustments that preserve your current hue & saturation:</p>
          <div id="fix-swatches-grid" class="flex flex-wrap gap-3">
            <!-- Dynamically populated suggestions -->
          </div>
        </div>

        <!-- Live Preview Sandbox Panel -->
        <div class="card-base flex-grow flex flex-col gap-4" id="sandbox-card">
          <div class="flex flex-wrap items-center justify-between gap-3 pb-2 border-b border-hairline-soft">
            <span class="font-display font-semibold text-sm text-primary flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-rose"></span>
              Aesthetic Rendering Sandbox
            </span>
            
            <!-- Controls slider / buttons -->
            <div class="flex items-center gap-4">
              <!-- Text weight selector -->
              <div class="flex items-center gap-1.5">
                <label for="weight-selector" class="text-xs font-semibold text-slate">Weight</label>
                <select id="weight-selector" class="text-xs bg-surface border border-hairline rounded px-1.5 py-1 font-semibold text-charcoal outline-none">
                  <option value="300">Light</option>
                  <option value="400" selected>Regular</option>
                  <option value="500">Medium</option>
                  <option value="700">Bold</option>
                </select>
              </div>

              <!-- Size slider -->
              <div class="flex items-center gap-2">
                <label for="font-slider" class="text-xs font-semibold text-slate">Size</label>
                <input type="range" id="font-slider" min="14" max="56" value="20" class="w-20 cursor-pointer" />
                <span id="lbl-font-size" class="text-xs font-mono font-semibold text-stone w-8">20px</span>
              </div>
            </div>
          </div>

          <!-- Preview Frame -->
          <div 
            id="preview-frame" 
            class="flex-grow min-h-[220px] border border-hairline rounded-xl flex flex-col justify-center p-8 transition-colors duration-300 shadow-sm overflow-auto"
          >
            <h3 id="preview-heading" class="font-display font-medium tracking-tight mb-2.5 transition-all">
              Pack my box with five dozen liquor jugs.
            </h3>
            <p id="preview-body" class="text-sm max-w-lg leading-relaxed font-normal opacity-90 transition-all">
              This interactive test area renders live text colors over your selected background. Adjust sizes or select alternative compliance swatches below to test readability in real design situations.
            </p>
          </div>
        </div>

        <!-- Palette-Wide Auditing (Grid checking multiple foregrounds against 1 background) -->
        <div class="card-base flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <h3 class="font-display font-semibold text-sm text-primary uppercase tracking-wider flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-teal"></span> Multi-Color Palette Audit
            </h3>
            <p class="text-xs text-slate">Compare multiple project text colors against the background concurrently. Separate values by commas or spaces.</p>
          </div>
