---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Readability Score Checker";
const category = "developer";
const tier = "Developer & Text Utilities";
const description = "Analyze text reading levels using standard Flesch-Kincaid, Gunning Fog, and Flesch Reading Ease formulas with inline sentence-level highlighting.";
---

<Layout 
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
>
  <section class="max-w-[1280px] w-full mx-auto px-3 sm:px-4 md:px-8 py-4 sm:py-6 md:py-10 flex flex-col gap-4 sm:gap-6 animate-fade-in-up">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </div>
      <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-3 mt-1">
        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
          <h1 class="font-display font-medium text-2xl sm:text-3xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-xs py-1 px-3 rounded-full font-semibold uppercase">{tier}</span>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How readability checker works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
          
          <span class="hidden sm:inline text-stone mx-1">|</span>

          <!-- View Modes / Workspace Toggle -->
          <button
            id="btn-single-mode"
            class="pill-tab-active bg-primary text-canvas px-3 sm:px-4 py-1 sm:py-1.5 rounded-full text-[11px] sm:text-xs font-bold transition-all cursor-pointer border border-primary flex items-center gap-1"
          >
            <span class="sm:inline">📝 Analyzer Workspace</span>
            <span class="inline sm:hidden">📝 Workspace</span>
          </button>
          <button
            id="btn-compare-mode"
            class="pill-tab bg-canvas text-slate hover:text-primary hover:border-slate px-3 sm:px-4 py-1 sm:py-1.5 rounded-full text-[11px] sm:text-xs font-bold transition-all cursor-pointer border border-hairline flex items-center gap-1"
          >
            <span class="sm:inline">⚖ Compare Versions</span>
            <span class="inline sm:hidden">⚖ Compare</span>
          </button>
        </div>
      </div>
    </div>

    <!-- MAIN INTERACTIVE CONTAINER -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
      
      <!-- LEFT CONTAINER (Workspace, Editor & Highlights) -->
      <div class="lg:col-span-8 flex flex-col gap-6 w-full">
        
        <!-- Named Revisions / Quick Action Bar -->
        <div class="card-base p-3 sm:p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3 bg-surface-soft">
          <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-start">
            <span class="text-xs font-bold text-slate uppercase tracking-wider">Saved Drafts:</span>
            <div class="flex items-center gap-1.5">
              <select id="draft-select" class="filter-dropdown text-xs bg-canvas px-3 py-1.5 rounded-full border border-hairline-strong max-w-[180px] sm:max-w-[240px]">
                <option value="">-- Select Saved Draft --</option>
              </select>
              <button id="btn-delete-draft" class="text-stone hover:text-brand-coral p-1.5 rounded-full hover:bg-surface transition-all text-sm hidden" title="Delete selected draft">
                🗑
              </button>
            </div>
          </div>
          <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-start">
            <input type="text" id="draft-name-input" placeholder="Draft name (e.g. Email Copy v2)" class="text-xs text-input px-3 py-1.5 border border-hairline-strong rounded-lg bg-canvas flex-grow sm:flex-initial w-auto sm:w-48 h-8" />
            <button id="btn-save-draft" class="button-primary text-xs !py-1.5 !px-3 h-8 shadow-subtle hover:bg-charcoal transition-all whitespace-nowrap">
              Save Draft
            </button>
          </div>
        </div>

        <!-- Analyzer Area (Single Document Mode) -->
        <div id="single-analyzer-workspace" class="flex flex-col gap-4">
          <!-- Workspace Header -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-blue animate-pulse"></span>
              <h2 class="font-display font-semibold text-lg text-primary">Content Editor</h2>
            </div>
            <div class="flex items-center gap-2">
              <!-- Upload TXT/MD -->
              <label class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0l-4 4m4-4v12"></path>
                </svg>
                <span>Upload</span>
                <input type="file" id="file-uploader" class="hidden" accept=".txt,.md" />
              </label>

              <!-- Load Sample -->
              <button
                type="button"
                id="btn-load-sample"
                class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
                <span>Sample</span>
              </button>

              <!-- Clear -->
              <button
                type="button"
                id="btn-clear-text"
                class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-coral" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                <span>Clear</span>
              </button>
            </div>
          </div>

          <!-- Dual Edit / Preview Pane Container -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-stretch min-h-[350px] md:min-h-[460px]">
            <!-- Write Pane -->
            <div class="flex flex-col gap-2 h-full">
              <div class="flex justify-between items-center px-1">
                <span class="text-[10px] uppercase font-bold text-slate">Write/Paste Text</span>
                <span id="char-word-counter" class="text-[10px] font-mono text-slate">0 words | 0 chars</span>
              </div>
              <div class="flex-grow border border-hairline-strong rounded-xl bg-canvas flex flex-col h-full focus-within:border-brand-blue focus-within:ring-2 focus-within:ring-brand-blue/10 transition-all">
                <textarea
                  id="analyzer-input"
                  class="w-full flex-grow p-4 font-body text-sm bg-transparent text-primary resize-none outline-none leading-relaxed min-h-[250px] sm:min-h-[350px] md:min-h-[420px]"
                  placeholder="Paste your content here or start typing..."
                  aria-label="Readability Text Editor"
                ></textarea>
              </div>
            </div>

            <!-- Analysis / Highlight Pane -->
            <div class="flex flex-col gap-2 h-full" id="analysis-pane">
              <div class="flex justify-between items-center px-1">
                <span class="text-[10px] uppercase font-bold text-slate">Interactive Analysis</span>
                <span class="text-[10px] text-slate">Hover highlights for insights</span>
              </div>
              <div class="flex-grow border border-hairline-soft rounded-xl bg-surface-soft p-4 overflow-y-auto max-h-[400px] sm:max-h-[500px] md:max-h-[none] min-h-[250px] sm:min-h-[350px] md:min-h-[420px] shadow-inner relative leading-relaxed text-sm">
                <!-- Inline highlight target -->
                <div id="analyzer-highlight-view" class="text-primary prose max-w-none whitespace-pre-wrap select-text h-full empty:before:content-['Live_readability_analysis_will_appear_here_as_you_type...'] empty:before:text-muted empty:before:italic"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Compare Side-by-Side Area (Hidden by default) -->
        <div id="compare-workspace" class="hidden flex-col gap-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-yellow"></span>
              <h2 class="font-display font-semibold text-lg text-primary">Revision Comparison</h2>
            </div>
            <button id="btn-sync-compare" class="text-[11px] font-bold text-brand-blue hover:underline cursor-pointer">Compare Drafts</button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <!-- Version A -->
            <div class="card-base p-4 flex flex-col gap-3">
              <div class="flex justify-between items-center">
                <span class="text-xs font-bold text-primary">Version A (Original)</span>
                <span id="compare-stats-a" class="text-[10px] font-mono text-slate">0 words | Grade: --</span>
              </div>
              <textarea
                id="compare-input-a"
                class="w-full min-h-[150px] sm:min-h-[220px] p-3 text-sm border border-hairline-strong rounded-xl outline-none resize-none bg-canvas focus:border-brand-blue transition-all"
                placeholder="Paste original version..."
              ></textarea>
              <!-- Small metrics summary -->
              <div id="compare-metrics-a" class="grid grid-cols-3 gap-2 mt-2 text-center text-xs">
                <div class="p-2 bg-surface rounded-lg">
                  <div class="text-slate text-[9px] uppercase font-bold">FK Grade</div>
                  <div class="font-bold text-primary text-sm mt-0.5" id="comp-a-fk">--</div>
                </div>
                <div class="p-2 bg-surface rounded-lg">
                  <div class="text-slate text-[9px] uppercase font-bold">Flesch Ease</div>
                  <div class="font-bold text-primary text-sm mt-0.5" id="comp-a-fre">--</div>
                </div>
                <div class="p-2 bg-surface rounded-lg">
                  <div class="text-slate text-[9px] uppercase font-bold">Fog Index</div>
                  <div class="font-bold text-primary text-sm mt-0.5" id="comp-a-gfi">--</div>
                </div>
              </div>
            </div>

            <!-- Version B -->
            <div class="card-base p-4 flex flex-col gap-3">
              <div class="flex justify-between items-center">
                <span class="text-xs font-bold text-brand-blue">Version B (Revised)</span>
                <span id="compare-stats-b" class="text-[10px] font-mono text-slate">0 words | Grade: --</span>
              </div>
              <textarea
                id="compare-input-b"
                class="w-full min-h-[150px] sm:min-h-[220px] p-3 text-sm border border-hairline-strong rounded-xl outline-none resize-none bg-canvas focus:border-brand-blue transition-all"
                placeholder="Paste revised version..."
              ></textarea>
              <!-- Small metrics summary -->
              <div id="compare-metrics-b" class="grid grid-cols-3 gap-2 mt-2 text-center text-xs">
                <div class="p-2 bg-surface rounded-lg">
                  <div class="text-slate text-[9px] uppercase font-bold">FK Grade</div>
                  <div class="font-bold text-primary text-sm mt-0.5" id="comp-b-fk">--</div>
                </div>
                <div class="p-2 bg-surface rounded-lg">
                  <div class="text-slate text-[9px] uppercase font-bold">Flesch Ease</div>
                  <div class="font-bold text-primary text-sm mt-0.5" id="comp-b-fre">--</div>
                </div>
                <div class="p-2 bg-surface rounded-lg">
                  <div class="text-slate text-[9px] uppercase font-bold">Fog Index</div>
                  <div class="font-bold text-primary text-sm mt-0.5" id="comp-b-gfi">--</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Comparison Decision Verdict -->
          <div id="comparison-verdict" class="card-feature-teal p-5 hidden flex-col gap-2">
            <span class="badge-tag-purple bg-teal-light text-moss-dark self-start">DIAGNOSTIC VERDICT</span>
            <h3 class="font-display font-semibold text-base text-primary" id="verdict-title">Comparing Versions...</h3>
            <p class="text-xs text-slate leading-relaxed" id="verdict-desc"></p>
          </div>
        </div>

        <!-- Formula Explanations Accordion -->
        <div class="card-base flex flex-col gap-3">
          <h3 class="font-display font-semibold text-sm text-primary">Readability Formulas Explained</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-2">
            <div class="p-3.5 bg-surface rounded-xl flex flex-col gap-2">
              <span class="text-xs font-bold text-brand-blue">Flesch Reading Ease</span>
              <p class="text-[11px] text-slate leading-relaxed">
                Scores run from 0 to 100. Higher scores mean the text is easier to read. Standard documents score between 60 and 70 (readable by 13-15 year olds).
              </p>
              <div class="text-[9px] font-mono text-stone bg-canvas p-1.5 rounded border border-hairline mt-auto">
                Score = 206.835 - 1.015*(words/sentences) - 84.6*(syllables/words)
              </div>
            </div>

            <div class="p-3.5 bg-surface rounded-xl flex flex-col gap-2">
              <span class="text-xs font-bold text-brand-blue">Flesch-Kincaid Grade Level</span>
              <p class="text-[11px] text-slate leading-relaxed">
                Translates the score directly into United States grade school levels. A grade of 8.0 indicates the text is appropriate for an 8th-grade student.
              </p>
              <div class="text-[9px] font-mono text-stone bg-canvas p-1.5 rounded border border-hairline mt-auto">
                Grade = 0.39*(words/sentences) + 11.8*(syllables/words) - 15.59
              </div>
            </div>

            <div class="p-3.5 bg-surface rounded-xl flex flex-col gap-2">
              <span class="text-xs font-bold text-brand-blue">Gunning Fog Index</span>
              <p class="text-[11px] text-slate leading-relaxed">
                Estimates the grade level required to read the passage on first reading. Heavy weighting is placed on "complex words" of 3+ syllables.
              </p>
              <div class="text-[9px] font-mono text-stone bg-canvas p-1.5 rounded border border-hairline mt-auto">
                Index = 0.4 * [ (words/sentences) + 100*(complex_words/words) ]
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- RIGHT CONTAINER: GAUGE & READABILITY STATS PANEL (Sticky Sidebar / Collapsible Top on Mobile) -->
      <div class="lg:col-span-4 flex flex-col gap-6 w-full lg:sticky lg:top-4">
        
        <!-- Score Overview & Gauge Card (Collapsible Header on mobile) -->
        <div class="card-base flex flex-col gap-4 border-2 border-hairline-strong relative">
          <!-- Mobile Collapse Toggle -->
          <div class="flex items-center justify-between lg:pointer-events-none">
            <h3 class="font-display font-semibold text-base text-primary flex items-center gap-2">
              📊 Readability Gauge
            </h3>
            <button id="btn-toggle-stats-mobile" class="lg:hidden text-xs bg-surface border border-hairline px-2.5 py-1 rounded-full text-slate font-bold cursor-pointer">
              Hide Dashboard
            </button>
          </div>

          <div id="stats-collapsible-container" class="flex flex-col gap-4 transition-all duration-300">
            <!-- Animated Needle Gauge -->
            <div class="flex flex-col items-center py-4 relative">
              <svg class="w-48 h-28" viewBox="0 0 100 55">
                <!-- Gauge Background Arc -->
                <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="var(--color-hairline)" stroke-width="8" stroke-linecap="round"/>
                <!-- Gauge Color Segments -->
                <!-- Very Difficult to Fairly Difficult (Red) -->
                <path d="M 10 50 A 40 40 0 0 1 35 22" fill="none" stroke="var(--color-brand-red-dark)" stroke-width="8" stroke-linecap="round"/>
                <!-- Standard (Yellow) -->
                <path d="M 35 22 A 40 40 0 0 1 65 22" fill="none" stroke="var(--color-brand-yellow)" stroke-width="8"/>
                <!-- Easy (Green) -->
                <path d="M 65 22 A 40 40 0 0 1 90 50" fill="none" stroke="var(--color-success-accent)" stroke-width="8" stroke-linecap="round"/>
                
                <!-- Center point -->
                <circle cx="50" cy="50" r="3" fill="var(--color-ink)"/>
                
                <!-- Needle (Animated angle via JS transform) -->
                <line id="gauge-needle" x1="50" y1="50" x2="50" y2="15" stroke="var(--color-ink)" stroke-width="2.5" stroke-linecap="round" transform="rotate(-90 50 50)" class="transition-transform duration-700 ease-out origin-[50px_50px]"/>
              </svg>
              <!-- Score label inside gauge -->
              <div class="text-center mt-1">
                <div class="text-[10px] uppercase font-bold text-stone">Overall Grade Level</div>
                <div class="text-2xl font-display font-semibold text-primary" id="dashboard-overall-grade">--</div>
                <span class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-[10px] mt-1.5 inline-block" id="dashboard-overall-interpretation">No text analyzed</span>
              </div>
            </div>

            <div class="h-[1px] bg-hairline"></div>

            <!-- Numerical Readability Cards -->
            <div class="flex flex-col gap-3">
              <!-- Flesch Reading Ease -->
              <div class="flex items-center justify-between p-2.5 rounded-xl hover:bg-surface transition-all">
                <div class="flex flex-col">
                  <span class="text-xs font-semibold text-primary">Flesch Reading Ease</span>
                  <span class="text-[10px] text-stone" id="fre-lbl-interpretation">Waiting...</span>
                </div>
                <div class="text-right">
                  <span class="font-mono text-base font-bold text-primary" id="score-fre">0.0</span>
                </div>
              </div>

              <!-- Flesch-Kincaid Grade Level -->
              <div class="flex items-center justify-between p-2.5 rounded-xl hover:bg-surface transition-all">
                <div class="flex flex-col">
                  <span class="text-xs font-semibold text-primary">Flesch-Kincaid Grade</span>
                  <span class="text-[10px] text-stone" id="fk-lbl-interpretation">Waiting...</span>
                </div>
                <div class="text-right">
                  <span class="font-mono text-base font-bold text-primary" id="score-fk">0.0</span>
                </div>
              </div>

              <!-- Gunning Fog Index -->
              <div class="flex items-center justify-between p-2.5 rounded-xl hover:bg-surface transition-all">
                <div class="flex flex-col">
                  <span class="text-xs font-semibold text-primary">Gunning Fog Index</span>
                  <span class="text-[10px] text-stone" id="gfi-lbl-interpretation">Waiting...</span>
                </div>
                <div class="text-right">
                  <span class="font-mono text-base font-bold text-primary" id="score-gfi">0.0</span>
                </div>
              </div>
            </div>

            <!-- Hemingway Highlighter Legend -->
            <div class="h-[1px] bg-hairline"></div>
            <div class="flex flex-col gap-2">
              <span class="text-[10px] font-bold text-slate uppercase tracking-wider">Hemingway Highlight Legend</span>
              <div class="flex flex-col gap-1.5 text-xs">
                <div class="flex items-center gap-2">
                  <span class="w-3.5 h-3.5 rounded bg-brand-red opacity-80 border border-brand-red-dark shrink-0"></span>
                  <span class="text-slate">Very hard to read sentence (Red)</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-3.5 h-3.5 rounded bg-yellow-light opacity-80 border border-brand-yellow-deep shrink-0"></span>
                  <span class="text-slate">Hard to read sentence (Yellow)</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-3.5 h-3.5 rounded bg-blue-100 dark:bg-blue-900 border border-brand-blue shrink-0"></span>
                  <span class="text-slate">Adverb - try removing (Blue)</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-3.5 h-3.5 rounded bg-teal-light dark:bg-teal-950 border border-brand-teal shrink-0"></span>
                  <span class="text-slate">Passive voice occurrence (Green)</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-3.5 h-3.5 rounded bg-rose-light dark:bg-pink-950 border border-brand-pink shrink-0"></span>
                  <span class="text-slate">Complex word (Purple/Click for suggestions)</span>
                </div>
              </div>
            </div>

            <!-- General Statistics Box -->
            <div class="h-[1px] bg-hairline"></div>
            <div class="grid grid-cols-2 gap-2 text-center text-xs">
              <div class="p-2 bg-surface rounded-xl">
                <div class="text-[9px] uppercase font-semibold text-stone">Sentences</div>
                <div class="font-mono font-bold text-primary text-sm mt-0.5" id="stat-sentences">0</div>
              </div>
              <div class="p-2 bg-surface rounded-xl">
                <div class="text-[9px] uppercase font-semibold text-stone">Total Words</div>
