</Layout>

<script>
  // Simple Word Substitutions List for Complex Words
  const wordAlternatives: Record<string, string> = {
    "utilize": "use",
    "utilizes": "uses",
    "utilizing": "using",
    "facilitate": "help / ease",
    "facilitates": "helps",
    "subsequent": "later / next",
    "determine": "find / decide",
    "determines": "finds / decides",
    "approximately": "about",
    "initiate": "start",
    "initiates": "starts",
    "terminated": "ended / stopped",
    "terminate": "end / stop",
    "advise": "tell / recommend",
    "cognizant": "aware",
    "disseminate": "spread / share",
    "endeavor": "try",
    "erroneous": "wrong",
    "expedite": "speed up",
    "implement": "do / carry out",
    "methodology": "method",
    "objectives": "goals",
    "objective": "goal",
    "optimum": "best",
    "parameters": "rules / limits",
    "requirement": "need",
    "requirements": "needs",
    "unavailability": "lack",
    "virtually": "almost"
  };

  // Common adverb list to flag (not exhaustively, just helpful)
  const commonAdverbExclusions = new Set(["only", "family", "early", "ally", "holy", "ugly", "really", "very", "monthly", "weekly", "yearly", "daily"]);

  // Syllable Counter Helper
  function countWordSyllables(word: string): number {
    const w = word.toLowerCase().trim().replace(/[^a-z]/g, '');
    if (!w) return 0;
    if (w.length <= 2) return 1;

    let cleaned = w;
    // Strip trailing e
    if (cleaned.endsWith('e') && !cleaned.endsWith('le')) {
      cleaned = cleaned.slice(0, -1);
    }

    const vowelGroups = cleaned.match(/[aeiouy]+/g);
    let count = vowelGroups ? vowelGroups.length : 1;

    // Suffix rules adjustments
    if (w.endsWith('ed') && !/[td]ed$/.test(w)) count--;
    if (w.endsWith('es') && !/[csz]es$/.test(w)) count--;

    if (count <= 0) count = 1;
    return count;
  }

  // Calculate readability metrics for a given text
  interface MetricsResult {
    sentencesCount: number;
    wordsCount: number;
    syllablesCount: number;
    complexWordsCount: number;
    fre: number;
    fk: number;
    gfi: number;
  }

  function calculateMetrics(text: string): MetricsResult {
    if (!text.trim()) {
      return { sentencesCount: 0, wordsCount: 0, syllablesCount: 0, complexWordsCount: 0, fre: 0, fk: 0, gfi: 0 };
    }

    // Split sentences
    const sentences = text.split(/[.!?]+(?:\s+|$)/).filter(s => s.trim().length > 0);
    const sentencesCount = Math.max(1, sentences.length);

    // Words
    const rawWords = text.match(/\b[a-zA-Z']+\b/g) || [];
    const wordsCount = Math.max(1, rawWords.length);

    let syllablesCount = 0;
    let complexWordsCount = 0;

    rawWords.forEach(word => {
      const syls = countWordSyllables(word);
      syllablesCount += syls;
      if (syls >= 3) {
        complexWordsCount++;
      }
    });

    // Flesch Reading Ease
    let fre = 206.835 - 1.015 * (wordsCount / sentencesCount) - 84.6 * (syllablesCount / wordsCount);
    fre = Math.min(100, Math.max(0, parseFloat(fre.toFixed(1))));

    // Flesch-Kincaid Grade Level
    let fk = 0.39 * (wordsCount / sentencesCount) + 11.8 * (syllablesCount / wordsCount) - 15.59;
    fk = Math.max(0, parseFloat(fk.toFixed(1)));

    // Gunning Fog Index
    let gfi = 0.4 * ((wordsCount / sentencesCount) + 100 * (complexWordsCount / wordsCount));
    gfi = Math.max(0, parseFloat(gfi.toFixed(1)));

    return {
      sentencesCount,
      wordsCount,
      syllablesCount,
      complexWordsCount,
      fre,
      fk,
      gfi
    };
  }

  // Set interpretations
  function getFREInterpretation(score: number): string {
    if (score >= 90) return "Very Easy (5th grade)";
    if (score >= 80) return "Easy (6th grade)";
    if (score >= 70) return "Fairly Easy (7th grade)";
    if (score >= 60) return "Standard (8th - 9th grade)";
    if (score >= 50) return "Fairly Difficult (High School)";
    if (score >= 30) return "Difficult (College)";
    return "Very Difficult (University Graduate)";
  }

  function getFKInterpretation(grade: number): string {
    if (grade <= 4) return "Very Easy — Easily read by 4th graders";
    if (grade <= 6) return "Easy — 5th or 6th grade level";
    if (grade <= 8) return "Standard — 7th or 8th grade level";
    if (grade <= 10) return "Average — 9th or 10th grade level";
    if (grade <= 12) return "Fairly Difficult — High School level";
    if (grade <= 15) return "Difficult — College level";
    return "Very Difficult — Post-graduate level";
  }

  function getGFIInterpretation(index: number): string {
    if (index < 6) return "Easy (5th grade)";
    if (index < 8) return "Standard (7th grade)";
    if (index < 10) return "Standard (8th grade)";
    if (index < 12) return "High School (10th grade)";
    if (index < 14) return "High School Senior (12th grade)";
    if (index < 17) return "College level";
    return "Executive / Post-grad level";
  }

  // Interactive Highlighting Generator (Hemingway style)
  function generateHighlightedHTML(text: string): string {
    if (!text.trim()) return "";

    // Split text into lines/paragraphs first, to maintain spacing structure
    const paragraphs = text.split(/\n/);
    
    return paragraphs.map(para => {
      if (!para.trim()) return "";
      
      // Match sentences with their trailing punctuation and whitespace
      const sentenceRegex = /[^.!?]+(?:[.!?]+)?(?:\s+|$)/g;
      const sentences = para.match(sentenceRegex) || [para];

      return sentences.map(sentence => {
        if (!sentence.trim()) return sentence;

        const words = sentence.match(/\b[a-zA-Z']+\b/g) || [];
        const wordsCount = words.length;
        if (wordsCount === 0) return sentence;

        // Calculate sentence statistics
        let syllables = 0;
        words.forEach(w => syllables += countWordSyllables(w));
        const fkGrade = 0.39 * (wordsCount / 1) + 11.8 * (syllables / wordsCount) - 15.59;

        // Tiers for hard sentences
        const isVeryHard = wordsCount > 25 || fkGrade > 12;
        const isHard = !isVeryHard && (wordsCount > 18 || fkGrade > 9);

        // Parse individual words within sentence to inject word-level spans (passive, complex, adverbs)
        // We will reconstruct the sentence by tokenizing
        const tokens = sentence.split(/(\b[a-zA-Z']+\b)/g);
        let annotatedSentence = tokens.map((token) => {
          const isWord = /[a-zA-Z]+/.test(token);
          if (!isWord) return token;

          const wordLower = token.toLowerCase();

          // 1. Complex word check
          if (wordAlternatives[wordLower]) {
            const alternative = wordAlternatives[wordLower];
            return `<span class="bg-rose-light/70 dark:bg-pink-950/60 border-b border-brand-pink font-semibold cursor-help relative group" title="Alternative: ${alternative}">${token}<span class="absolute bottom-full left-1/2 transform -translate-x-1/2 bg-primary text-canvas text-[10px] py-1 px-2 rounded opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity whitespace-nowrap z-30">Try: ${alternative}</span></span>`;
          }

          // 2. Adverb check
          if (wordLower.endsWith('ly') && !commonAdverbExclusions.has(wordLower)) {
            return `<span class="bg-blue-100 dark:bg-blue-900/60 border-b border-brand-blue font-semibold cursor-help relative group" title="Adverb">${token}<span class="absolute bottom-full left-1/2 transform -translate-x-1/2 bg-primary text-canvas text-[10px] py-1 px-2 rounded opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity whitespace-nowrap z-30">Adverb</span></span>`;
          }

          return token;
        }).join('');

        // Try to identify passive voice
        const passiveRegex = /\b(am|is|are|was|were|be|been|being)\b\s+([a-z]+ed|done|written|seen|taken|known|made|built|given|chosen|kept|felt|heard|shown|paid|run|told)\b/gi;
        annotatedSentence = annotatedSentence.replace(passiveRegex, (match) => {
          return `<span class="bg-teal-light/80 dark:bg-teal-950/60 border-b border-brand-teal font-semibold cursor-help relative group" title="Passive voice">${match}<span class="absolute bottom-full left-1/2 transform -translate-x-1/2 bg-primary text-canvas text-[10px] py-1 px-2 rounded opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity whitespace-nowrap z-30">Passive Voice</span></span>`;
        });

        // Wrap sentence based on difficulty
        if (isVeryHard) {
          return `<span class="bg-brand-red/40 dark:bg-red-950/30 rounded p-0.5 transition-all duration-300 hover:bg-brand-red/60" title="Very hard to read sentence.">${annotatedSentence}</span>`;
        } else if (isHard) {
          return `<span class="bg-yellow-light/40 dark:bg-yellow-950/30 rounded p-0.5 transition-all duration-300 hover:bg-yellow-light/60" title="Hard to read sentence.">${annotatedSentence}</span>`;
        }

        return annotatedSentence;
      }).join('');
    }).map(p => `<p class="mb-3">${p}</p>`).join('');
  }

  // DOM Elements Setup
  document.addEventListener('DOMContentLoaded', () => {
    let activeMode = 'single';
    const analyzerInput = document.getElementById('analyzer-input') as HTMLTextAreaElement;
    const highlightView = document.getElementById('analyzer-highlight-view') as HTMLDivElement;
    const charWordCounter = document.getElementById('char-word-counter') as HTMLSpanElement;

    // Dashboard values
    const needle = document.getElementById('gauge-needle') as unknown as SVGLineElement;
    const overallGrade = document.getElementById('dashboard-overall-grade') as HTMLDivElement;
    const overallInterp = document.getElementById('dashboard-overall-interpretation') as HTMLSpanElement;

    const scoreFre = document.getElementById('score-fre') as HTMLSpanElement;
    const scoreFk = document.getElementById('score-fk') as HTMLSpanElement;
    const scoreGfi = document.getElementById('score-gfi') as HTMLSpanElement;

    const freInterp = document.getElementById('fre-lbl-interpretation') as HTMLSpanElement;
    const fkInterp = document.getElementById('fk-lbl-interpretation') as HTMLSpanElement;
    const gfiInterp = document.getElementById('gfi-lbl-interpretation') as HTMLSpanElement;

    const statSentences = document.getElementById('stat-sentences') as HTMLDivElement;
    const statWords = document.getElementById('stat-words') as HTMLDivElement;
    const statSyllables = document.getElementById('stat-syllables') as HTMLDivElement;
    const statComplex = document.getElementById('stat-complex') as HTMLDivElement;

    // View Modes
    const btnSingleMode = document.getElementById('btn-single-mode') as HTMLButtonElement;
    const btnCompareMode = document.getElementById('btn-compare-mode') as HTMLButtonElement;
    const singleWorkspace = document.getElementById('single-analyzer-workspace') as HTMLDivElement;
    const compareWorkspace = document.getElementById('compare-workspace') as HTMLDivElement;

    // Compare Elements
    const compareA = document.getElementById('compare-input-a') as HTMLTextAreaElement;
    const compareB = document.getElementById('compare-input-b') as HTMLTextAreaElement;
    const compStatsA = document.getElementById('compare-stats-a') as HTMLSpanElement;
    const compStatsB = document.getElementById('compare-stats-b') as HTMLSpanElement;
    const compAFk = document.getElementById('comp-a-fk') as HTMLDivElement;
    const compAFre = document.getElementById('comp-a-fre') as HTMLDivElement;
    const compAGfi = document.getElementById('comp-a-gfi') as HTMLDivElement;
    const compBFk = document.getElementById('comp-b-fk') as HTMLDivElement;
    const compBFre = document.getElementById('comp-b-fre') as HTMLDivElement;
    const compBGfi = document.getElementById('comp-b-gfi') as HTMLDivElement;
    const btnSyncCompare = document.getElementById('btn-sync-compare') as HTMLButtonElement;
    const comparisonVerdict = document.getElementById('comparison-verdict') as HTMLDivElement;
    const verdictTitle = document.getElementById('verdict-title') as HTMLHeadingElement;
    const verdictDesc = document.getElementById('verdict-desc') as HTMLParagraphElement;

    // Mobile stats toggling
    const btnToggleStats = document.getElementById('btn-toggle-stats-mobile') as HTMLButtonElement;
    const statsContainer = document.getElementById('stats-collapsible-container') as HTMLDivElement;

    // Load & Upload & Reset controls
    const btnLoadSample = document.getElementById('btn-load-sample') as HTMLButtonElement;
    const btnClearText = document.getElementById('btn-clear-text') as HTMLButtonElement;
    const fileUploader = document.getElementById('file-uploader') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
    const howItWorksBtn = document.getElementById('how-it-works-btn') as HTMLButtonElement;
    const howItWorksModal = document.getElementById('how-it-works-modal') as HTMLDivElement;
    const closeModalBtn = document.getElementById('close-modal-btn') as HTMLButtonElement;
    const modalOkBtn = document.getElementById('modal-ok-btn') as HTMLButtonElement;

    // Draft Management
    const draftSelect = document.getElementById('draft-select') as HTMLSelectElement;
    const draftNameInput = document.getElementById('draft-name-input') as HTMLInputElement;
    const btnSaveDraft = document.getElementById('btn-save-draft') as HTMLButtonElement;
    const btnDeleteDraft = document.getElementById('btn-delete-draft') as HTMLButtonElement;


    const sampleText = "The Readability Score Checker facilitates rapid analysis. If you utilize complex words, your message might become lost. Writing in the passive voice (such as 'the document was created by the developer') often hurts overall comprehension. Instead, initiations of direct communication with simple and short sentences are highly recommended to determine clarity. Try it today!";

    // Number Animating Function
    function animateValue(element: HTMLElement, start: number, end: number, duration: number, prefix: string = "", suffix: string = "") {
      if (isNaN(end)) return;
      let startTimestamp: number | null = null;
      const step = (timestamp: number) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const current = progress * (end - start) + start;
        element.innerHTML = `${prefix}${current.toFixed(1)}${suffix}`;
        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          element.innerHTML = `${prefix}${end.toFixed(1)}${suffix}`;
        }
      };
      window.requestAnimationFrame(step);
    }

    // Main Update Dashboard function
    function updateDashboard(metrics: MetricsResult) {
      if (metrics.wordsCount === 0) {
        overallGrade.innerText = "--";
        overallInterp.innerText = "No text analyzed";
        scoreFre.innerText = "0.0";
        scoreFk.innerText = "0.0";
        scoreGfi.innerText = "0.0";
        freInterp.innerText = "Waiting...";
        fkInterp.innerText = "Waiting...";
        gfiInterp.innerText = "Waiting...";
        statSentences.innerText = "0";
        statWords.innerText = "0";
        statSyllables.innerText = "0";
        statComplex.innerText = "0";
        needle.style.transform = `rotate(-90deg)`;
        return;
      }

      // Animate needle: FK grade 0 maps to -90deg, grade 18+ maps to 90deg
      // Formula: angle = -90 + (grade / 18) * 180
      const targetGrade = metrics.fk;
      const targetAngle = Math.min(90, Math.max(-90, -90 + (targetGrade / 18) * 180));
      needle.style.transform = `rotate(${targetAngle}deg)`;

      // Animate numerical labels
      animateValue(scoreFre, parseFloat(scoreFre.innerText) || 0, metrics.fre, 400);
      animateValue(scoreFk, parseFloat(scoreFk.innerText) || 0, metrics.fk, 400);
      animateValue(scoreGfi, parseFloat(scoreGfi.innerText) || 0, metrics.gfi, 400);

      overallGrade.innerText = `Grade ${Math.round(metrics.fk)}`;
      overallInterp.innerText = getFKInterpretation(metrics.fk);

      freInterp.innerText = getFREInterpretation(metrics.fre);
      fkInterp.innerText = getFKInterpretation(metrics.fk);
      gfiInterp.innerText = getGFIInterpretation(metrics.gfi);

      statSentences.innerText = metrics.sentencesCount.toString();
      statWords.innerText = metrics.wordsCount.toString();
      statSyllables.innerText = metrics.syllablesCount.toString();
      statComplex.innerText = metrics.complexWordsCount.toString();
    }

    // Trigger parsing & updates
    let debounceTimer: number;
    function processAnalysis() {
      const text = analyzerInput.value;
      
      // Update basic counters synchronously
      const words = text.match(/\b[a-zA-Z']+\b/g) || [];
      charWordCounter.innerText = `${words.length} words | ${text.length} chars`;

      // Save content locally
      localStorage.setItem('readability_last_text', text);

      // Debounce complex formatting & stats
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => {
        const metrics = calculateMetrics(text);
        updateDashboard(metrics);
        highlightView.innerHTML = generateHighlightedHTML(text);
      }, 200);
    }

    // Draft Management Functions
    interface Draft {
      name: string;
      text: string;
      timestamp: number;
    }

    function loadDraftOptions() {
      const draftsJson = localStorage.getItem('readability_saved_drafts');
      const drafts: Draft[] = draftsJson ? JSON.parse(draftsJson) : [];
      
      draftSelect.innerHTML = '<option value="">-- Select Saved Draft --</option>';
      drafts.forEach((draft, idx) => {
        const option = document.createElement('option');
        option.value = idx.toString();
        option.innerText = draft.name;
        draftSelect.appendChild(option);
      });
      btnDeleteDraft.classList.add('hidden');
    }

    function saveCurrentDraft() {
      const name = draftNameInput.value.trim();
      const text = analyzerInput.value;
      if (!name) {
        alert("Please enter a name for your draft.");
        return;
      }
      if (!text.trim()) {
        alert("Cannot save an empty draft.");
        return;
      }

      const draftsJson = localStorage.getItem('readability_saved_drafts');
      let drafts: Draft[] = draftsJson ? JSON.parse(draftsJson) : [];
      
      // Replace existing draft with same name or add new
      const existingIdx = drafts.findIndex(d => d.name.toLowerCase() === name.toLowerCase());
      if (existingIdx !== -1) {
        drafts[existingIdx] = { name, text, timestamp: Date.now() };
      } else {
        drafts.push({ name, text, timestamp: Date.now() });
      }

      localStorage.setItem('readability_saved_drafts', JSON.stringify(drafts));
      draftNameInput.value = "";
      loadDraftOptions();
      alert(`Draft "${name}" saved successfully!`);
    }

    // Version Comparison Engine
    function compareRevisions() {
      const textA = compareA.value;
      const textB = compareB.value;

      const metricsA = calculateMetrics(textA);
      const metricsB = calculateMetrics(textB);

      // Update small comparison metrics
      compStatsA.innerText = `${metricsA.wordsCount} words | Grade: ${metricsA.fk}`;
      compStatsB.innerText = `${metricsB.wordsCount} words | Grade: ${metricsB.fk}`;

      compAFk.innerText = textA ? metricsA.fk.toFixed(1) : "--";
      compAFre.innerText = textA ? metricsA.fre.toFixed(1) : "--";
      compAGfi.innerText = textA ? metricsA.gfi.toFixed(1) : "--";

      compBFk.innerText = textB ? metricsB.fk.toFixed(1) : "--";
      compBFre.innerText = textB ? metricsB.fre.toFixed(1) : "--";
      compBGfi.innerText = textB ? metricsB.gfi.toFixed(1) : "--";

      if (!textA || !textB) {
        comparisonVerdict.classList.add('hidden');
        comparisonVerdict.classList.remove('flex');
        return;
      }

      comparisonVerdict.classList.remove('hidden');
      comparisonVerdict.classList.add('flex');

      // Formulate Verdict
      const diffFk = metricsA.fk - metricsB.fk;
      const diffFre = metricsB.fre - metricsA.fre;

      if (Math.abs(diffFk) < 0.2) {
        verdictTitle.innerText = "Versions Read Similarly";
        verdictDesc.innerText = `Both Version A and Version B are written at around a Grade ${Math.round(metricsA.fk)} level. Consider further simplifying sentence structures in Version B.`;
      } else if (diffFk > 0) {
        verdictTitle.innerText = "Version B is Easier to Read!";
        verdictDesc.innerText = `Version B improved readability by lowering the grade level from ${metricsA.fk} to ${metricsB.fk} (a decrease of ${diffFk.toFixed(1)} grades) and raising Flesch Ease score by ${diffFre.toFixed(1)} points. Good job!`;
      } else {
        verdictTitle.innerText = "Version A is Easier to Read";
        verdictDesc.innerText = `Version B grade level rose from ${metricsA.fk} to ${metricsB.fk} (an increase of ${Math.abs(diffFk).toFixed(1)} grades), making it slightly harder to read. Review Version B to cut complex words or shorten long sentences.`;
      }
    }

    // File Uploader Setup
    fileUploader.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = (evt) => {
        const text = evt.target?.result as string;
        analyzerInput.value = text;
        processAnalysis();
      };
      reader.readAsText(file);
    });

    // Event Listeners
    analyzerInput.addEventListener('input', processAnalysis);
    compareA.addEventListener('input', compareRevisions);
    compareB.addEventListener('input', compareRevisions);

    btnSaveDraft.addEventListener('click', saveCurrentDraft);
    btnDeleteDraft.addEventListener('click', () => {
      const selectedIdx = draftSelect.value;
      if (!selectedIdx) return;
      
      const draftsJson = localStorage.getItem('readability_saved_drafts');
      if (draftsJson) {
        const drafts: Draft[] = JSON.parse(draftsJson);
        const name = drafts[parseInt(selectedIdx)].name;
        drafts.splice(parseInt(selectedIdx), 1);
        localStorage.setItem('readability_saved_drafts', JSON.stringify(drafts));
        loadDraftOptions();
        alert(`Draft "${name}" deleted.`);
      }
    });

    draftSelect.addEventListener('change', () => {
      const selectedIdx = draftSelect.value;
      if (!selectedIdx) {
        btnDeleteDraft.classList.add('hidden');
        return;
      }
      btnDeleteDraft.classList.remove('hidden');

      const draftsJson = localStorage.getItem('readability_saved_drafts');
      if (draftsJson) {
        const drafts: Draft[] = JSON.parse(draftsJson);
        const selectedDraft = drafts[parseInt(selectedIdx)];
        
        if (compareWorkspace.classList.contains('flex')) {
          // If in compare mode, load into B
          compareB.value = selectedDraft.text;
          compareRevisions();
        } else {
          analyzerInput.value = selectedDraft.text;
          processAnalysis();
        }
      }
    });

    // Mode Toggle Logic
    btnSingleMode.addEventListener('click', () => {
      activeMode = 'single';
      btnSingleMode.className = "pill-tab-active bg-primary text-canvas px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-primary flex items-center gap-1.5";
      btnCompareMode.className = "pill-tab bg-canvas text-slate hover:text-primary hover:border-slate px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-hairline flex items-center gap-1.5";
      singleWorkspace.classList.remove('hidden');
      singleWorkspace.classList.add('flex');
      compareWorkspace.classList.remove('flex');
      compareWorkspace.classList.add('hidden');
      processAnalysis();
    });

    btnCompareMode.addEventListener('click', () => {
      activeMode = 'compare';
      btnCompareMode.className = "pill-tab-active bg-primary text-canvas px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-primary flex items-center gap-1.5";
      btnSingleMode.className = "pill-tab bg-canvas text-slate hover:text-primary hover:border-slate px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-hairline flex items-center gap-1.5";
      singleWorkspace.classList.remove('flex');
      singleWorkspace.classList.add('hidden');
      compareWorkspace.classList.remove('hidden');
      compareWorkspace.classList.add('flex');
      
      // Auto-load Version A with current text if empty
      if (!compareA.value) {
        compareA.value = analyzerInput.value;
      }
      compareRevisions();
    });

    btnSyncCompare.addEventListener('click', compareRevisions);

    // Collapsible stats toggle for mobile screens
    btnToggleStats.addEventListener('click', () => {
      if (statsContainer.classList.contains('hidden')) {
        statsContainer.classList.remove('hidden');
        btnToggleStats.innerText = "Hide Dashboard";
      } else {
        statsContainer.classList.add('hidden');
        btnToggleStats.innerText = "Show Dashboard";
      }
    });

    btnLoadSample.addEventListener('click', () => {
      analyzerInput.value = sampleText;
      processAnalysis();
      scrollToOutput();
    });

    btnClearText.addEventListener('click', () => {
      analyzerInput.value = "";
      processAnalysis();
    });

    // Reset button handler
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        analyzerInput.value = "";
        compareA.value = "";
        compareB.value = "";
        processAnalysis();
        compareRevisions();
      });
    }

    // Modal event handlers
    if (howItWorksBtn && howItWorksModal && closeModalBtn && modalOkBtn) {
      howItWorksBtn.addEventListener('click', () => {
        howItWorksModal.classList.remove('hidden');
      });
      const hideModal = () => {
        howItWorksModal.classList.add('hidden');
      };
      closeModalBtn.addEventListener('click', hideModal);
      modalOkBtn.addEventListener('click', hideModal);
      howItWorksModal.addEventListener('click', (e) => {
        if (e.target === howItWorksModal) {
          hideModal();
        }
      });
    }

    // Auto-scroll logic on mobile
    function scrollToOutput() {
      if (window.innerWidth < 768) {
        const analysisPane = document.getElementById('analysis-pane');
        if (analysisPane) {
          analysisPane.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    }

    // Debounced auto-scroll during active typing
    let scrollDebounceTimer: number;
    analyzerInput.addEventListener('input', () => {
      clearTimeout(scrollDebounceTimer);
      scrollDebounceTimer = window.setTimeout(() => {
        if (analyzerInput.value.trim().length > 0) {
          scrollToOutput();
        }
      }, 1500);
    });

    // Also scroll immediately on upload / draft change
    fileUploader.addEventListener('change', () => {
      setTimeout(scrollToOutput, 100);
    });

    draftSelect.addEventListener('change', () => {
      if (draftSelect.value) {
        setTimeout(scrollToOutput, 100);
      }
    });

    // Top Share Button click
    const shareBtn = document.getElementById('share-btn');
    shareBtn?.addEventListener('click', () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("mode", activeMode);
      if (activeMode === 'single') {
        url.searchParams.set("text", analyzerInput.value);
      } else {
        url.searchParams.set("text-a", compareA.value);
        url.searchParams.set("text-b", compareB.value);
      }

      const shareData = {
        title: document.title || "Readability Checker",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    function handleUrlParams() {
      const urlParams = new URLSearchParams(window.location.search);
      const modeParam = urlParams.get('mode');
      const textParam = urlParams.get('text');
      const textAParam = urlParams.get('text-a');
      const textBParam = urlParams.get('text-b');

      if (textParam !== null) {
        analyzerInput.value = textParam;
      }
      if (textAParam !== null) {
        compareA.value = textAParam;
      }
      if (textBParam !== null) {
        compareB.value = textBParam;
      }

      if (modeParam === 'compare') {
        btnCompareMode.click();
      } else if (modeParam === 'single') {
        btnSingleMode.click();
      }
    }

    // Initialize state
    loadDraftOptions();
    
    // Load last text or sample
    const savedText = localStorage.getItem('readability_last_text');
    if (savedText) {
      analyzerInput.value = savedText;
    } else {
      analyzerInput.value = sampleText;
    }

    handleUrlParams();
    processAnalysis();

    // Adjust dashboard layout initially for screen size
    if (window.innerWidth < 1024) {
      statsContainer.classList.add('hidden');
      btnToggleStats.innerText = "Show Dashboard";
    }
  });
</script>
