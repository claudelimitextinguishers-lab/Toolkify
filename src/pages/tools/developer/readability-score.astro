    const btnSaveDraft = document.getElementById('btn-save-draft') as HTMLButtonElement;
    const btnDeleteDraft = document.getElementById('btn-delete-draft') as HTMLButtonElement;


    const sampleText = "The Readability Score Checker facilitates rapid analysis. If you utilize complex words, your message might become lost. Writing in the passive voice (such as 'the document was created by the developer') often hurts overall comprehension. Instead, initiations of direct communication with simple and short sentences are highly recommended to determine clarity. Try it today!";

    // Number Animating Function
    function animateValue(element: HTMLElement, start: number, end: number, duration: number, prefix: string = "", suffix: string = "") {
      if (isNaN(end)) return;
      let startTimestamp: number | null = null;
      const step = (timestamp: number) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const current = progress * (end - start) + start;
        element.innerHTML = `${prefix}${current.toFixed(1)}${suffix}`;
        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          element.innerHTML = `${prefix}${end.toFixed(1)}${suffix}`;
        }
      };
      window.requestAnimationFrame(step);
    }

    // Main Update Dashboard function
    function updateDashboard(metrics: MetricsResult) {
      if (metrics.wordsCount === 0) {
        overallGrade.innerText = "--";
        overallInterp.innerText = "No text analyzed";
        scoreFre.innerText = "0.0";
        scoreFk.innerText = "0.0";
        scoreGfi.innerText = "0.0";
        freInterp.innerText = "Waiting...";
        fkInterp.innerText = "Waiting...";
        gfiInterp.innerText = "Waiting...";
        statSentences.innerText = "0";
        statWords.innerText = "0";
        statSyllables.innerText = "0";
        statComplex.innerText = "0";
        needle.style.transform = `rotate(-90deg)`;
        return;
      }

      // Animate needle: FK grade 0 maps to -90deg, grade 18+ maps to 90deg
      // Formula: angle = -90 + (grade / 18) * 180
      const targetGrade = metrics.fk;
      const targetAngle = Math.min(90, Math.max(-90, -90 + (targetGrade / 18) * 180));
      needle.style.transform = `rotate(${targetAngle}deg)`;

      // Animate numerical labels
      animateValue(scoreFre, parseFloat(scoreFre.innerText) || 0, metrics.fre, 400);
      animateValue(scoreFk, parseFloat(scoreFk.innerText) || 0, metrics.fk, 400);
      animateValue(scoreGfi, parseFloat(scoreGfi.innerText) || 0, metrics.gfi, 400);

      overallGrade.innerText = `Grade ${Math.round(metrics.fk)}`;
      overallInterp.innerText = getFKInterpretation(metrics.fk);

      freInterp.innerText = getFREInterpretation(metrics.fre);
      fkInterp.innerText = getFKInterpretation(metrics.fk);
      gfiInterp.innerText = getGFIInterpretation(metrics.gfi);

      statSentences.innerText = metrics.sentencesCount.toString();
      statWords.innerText = metrics.wordsCount.toString();
      statSyllables.innerText = metrics.syllablesCount.toString();
      statComplex.innerText = metrics.complexWordsCount.toString();
    }

    // Trigger parsing & updates
    let debounceTimer: number;
    function processAnalysis() {
      const text = analyzerInput.value;
      
      // Update basic counters synchronously
      const words = text.match(/\b[a-zA-Z']+\b/g) || [];
      charWordCounter.innerText = `${words.length} words | ${text.length} chars`;

      // Save content locally
      localStorage.setItem('readability_last_text', text);

      // Debounce complex formatting & stats
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => {
        const metrics = calculateMetrics(text);
        updateDashboard(metrics);
        highlightView.innerHTML = generateHighlightedHTML(text);
      }, 200);
    }

    // Draft Management Functions
    interface Draft {
      name: string;
      text: string;
      timestamp: number;
    }

    function loadDraftOptions() {
      const draftsJson = localStorage.getItem('readability_saved_drafts');
      const drafts: Draft[] = draftsJson ? JSON.parse(draftsJson) : [];
      
      draftSelect.innerHTML = '<option value="">-- Select Saved Draft --</option>';
      drafts.forEach((draft, idx) => {
        const option = document.createElement('option');
        option.value = idx.toString();
        option.innerText = draft.name;
        draftSelect.appendChild(option);
      });
      btnDeleteDraft.classList.add('hidden');
    }

    function saveCurrentDraft() {
      const name = draftNameInput.value.trim();
      const text = analyzerInput.value;
      if (!name) {
        alert("Please enter a name for your draft.");
        return;
      }
      if (!text.trim()) {
        alert("Cannot save an empty draft.");
        return;
      }

      const draftsJson = localStorage.getItem('readability_saved_drafts');
      let drafts: Draft[] = draftsJson ? JSON.parse(draftsJson) : [];
      
      // Replace existing draft with same name or add new
      const existingIdx = drafts.findIndex(d => d.name.toLowerCase() === name.toLowerCase());
      if (existingIdx !== -1) {
        drafts[existingIdx] = { name, text, timestamp: Date.now() };
      } else {
        drafts.push({ name, text, timestamp: Date.now() });
      }

      localStorage.setItem('readability_saved_drafts', JSON.stringify(drafts));
      draftNameInput.value = "";
      loadDraftOptions();
      alert(`Draft "${name}" saved successfully!`);
    }

    // Version Comparison Engine
    function compareRevisions() {
      const textA = compareA.value;
      const textB = compareB.value;

      const metricsA = calculateMetrics(textA);
      const metricsB = calculateMetrics(textB);

      // Update small comparison metrics
      compStatsA.innerText = `${metricsA.wordsCount} words | Grade: ${metricsA.fk}`;
      compStatsB.innerText = `${metricsB.wordsCount} words | Grade: ${metricsB.fk}`;

      compAFk.innerText = textA ? metricsA.fk.toFixed(1) : "--";
      compAFre.innerText = textA ? metricsA.fre.toFixed(1) : "--";
      compAGfi.innerText = textA ? metricsA.gfi.toFixed(1) : "--";

      compBFk.innerText = textB ? metricsB.fk.toFixed(1) : "--";
      compBFre.innerText = textB ? metricsB.fre.toFixed(1) : "--";
      compBGfi.innerText = textB ? metricsB.gfi.toFixed(1) : "--";

      if (!textA || !textB) {
        comparisonVerdict.classList.add('hidden');
        comparisonVerdict.classList.remove('flex');
        return;
      }

      comparisonVerdict.classList.remove('hidden');
      comparisonVerdict.classList.add('flex');

      // Formulate Verdict
      const diffFk = metricsA.fk - metricsB.fk;
      const diffFre = metricsB.fre - metricsA.fre;

      if (Math.abs(diffFk) < 0.2) {
        verdictTitle.innerText = "Versions Read Similarly";
        verdictDesc.innerText = `Both Version A and Version B are written at around a Grade ${Math.round(metricsA.fk)} level. Consider further simplifying sentence structures in Version B.`;
      } else if (diffFk > 0) {
        verdictTitle.innerText = "Version B is Easier to Read!";
        verdictDesc.innerText = `Version B improved readability by lowering the grade level from ${metricsA.fk} to ${metricsB.fk} (a decrease of ${diffFk.toFixed(1)} grades) and raising Flesch Ease score by ${diffFre.toFixed(1)} points. Good job!`;
      } else {
        verdictTitle.innerText = "Version A is Easier to Read";
        verdictDesc.innerText = `Version B grade level rose from ${metricsA.fk} to ${metricsB.fk} (an increase of ${Math.abs(diffFk).toFixed(1)} grades), making it slightly harder to read. Review Version B to cut complex words or shorten long sentences.`;
      }
    }

    // File Uploader Setup
    fileUploader.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = (evt) => {
        const text = evt.target?.result as string;
        analyzerInput.value = text;
        processAnalysis();
      };
      reader.readAsText(file);
    });

    // Event Listeners
    analyzerInput.addEventListener('input', processAnalysis);
    compareA.addEventListener('input', compareRevisions);
    compareB.addEventListener('input', compareRevisions);

    btnSaveDraft.addEventListener('click', saveCurrentDraft);
    btnDeleteDraft.addEventListener('click', () => {
      const selectedIdx = draftSelect.value;
      if (!selectedIdx) return;
      
      const draftsJson = localStorage.getItem('readability_saved_drafts');
      if (draftsJson) {
        const drafts: Draft[] = JSON.parse(draftsJson);
        const name = drafts[parseInt(selectedIdx)].name;
        drafts.splice(parseInt(selectedIdx), 1);
        localStorage.setItem('readability_saved_drafts', JSON.stringify(drafts));
        loadDraftOptions();
        alert(`Draft "${name}" deleted.`);
      }
    });

    draftSelect.addEventListener('change', () => {
      const selectedIdx = draftSelect.value;
      if (!selectedIdx) {
        btnDeleteDraft.classList.add('hidden');
        return;
      }
      btnDeleteDraft.classList.remove('hidden');

      const draftsJson = localStorage.getItem('readability_saved_drafts');
      if (draftsJson) {
        const drafts: Draft[] = JSON.parse(draftsJson);
        const selectedDraft = drafts[parseInt(selectedIdx)];
        
        if (compareWorkspace.classList.contains('flex')) {
          // If in compare mode, load into B
          compareB.value = selectedDraft.text;
          compareRevisions();
        } else {
          analyzerInput.value = selectedDraft.text;
          processAnalysis();
        }
      }
    });

    // Mode Toggle Logic
    btnSingleMode.addEventListener('click', () => {
      activeMode = 'single';
      btnSingleMode.className = "pill-tab-active bg-primary text-canvas px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-primary flex items-center gap-1.5";
      btnCompareMode.className = "pill-tab bg-canvas text-slate hover:text-primary hover:border-slate px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-hairline flex items-center gap-1.5";
      singleWorkspace.classList.remove('hidden');
      singleWorkspace.classList.add('flex');
      compareWorkspace.classList.remove('flex');
      compareWorkspace.classList.add('hidden');
      processAnalysis();
    });

    btnCompareMode.addEventListener('click', () => {
      activeMode = 'compare';
      btnCompareMode.className = "pill-tab-active bg-primary text-canvas px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-primary flex items-center gap-1.5";
      btnSingleMode.className = "pill-tab bg-canvas text-slate hover:text-primary hover:border-slate px-4 py-1.5 rounded-full text-xs font-bold transition-all cursor-pointer border border-hairline flex items-center gap-1.5";
      singleWorkspace.classList.remove('flex');
      singleWorkspace.classList.add('hidden');
      compareWorkspace.classList.remove('hidden');
      compareWorkspace.classList.add('flex');
      
      // Auto-load Version A with current text if empty
      if (!compareA.value) {
        compareA.value = analyzerInput.value;
      }
      compareRevisions();
    });

    btnSyncCompare.addEventListener('click', compareRevisions);

    // Collapsible stats toggle for mobile screens
    btnToggleStats.addEventListener('click', () => {
      if (statsContainer.classList.contains('hidden')) {
        statsContainer.classList.remove('hidden');
        btnToggleStats.innerText = "Hide Dashboard";
