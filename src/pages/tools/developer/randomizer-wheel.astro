---
import Layout from "../../../layouts/Layout.astro";
import RelatedTools from "../../../components/RelatedTools.astro";

// Tool metadata
const name = "Randomizer Wheel";
const category = "developer";
const tier = "Developer & Text Utilities";

// SEO
const pageTitle = "Randomizer Wheel - Free Name, Number & Custom List Spinner";
const description = "Spin the ultimate free randomizer wheel spinner online. Create a custom list randomizer wheel, name randomizer wheel, number, food, color, or letter spinner with interactive physics.";
const canonicalUrl = "https://toolkify.app/tools/developer/randomizer-wheel";
const keywords = "randomizer wheel, name randomizer wheel, number randomizer wheel, color randomizer wheel, list randomizer wheel, randomizer wheel custom, country randomizer wheel, letter randomizer wheel, food randomizer wheel, animal randomizer wheel, randomizer wheel spinner, free randomizer wheel";
const ogImage = "/og/randomizer-wheel.png";
---

<Layout
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  hideBanner={true}
>
  <!-- SEO Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Randomizer Wheel",
      "url": "https://toolkify.app/tools/developer/randomizer-wheel",
      "description": "An interactive, client-side decision wheel featuring realistic physics, drag-to-spin, per-item weights, custom color palettes, and session logs.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Developer & Text Utilities",
          "item": "https://toolkify.app/#developer"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Randomizer Wheel",
          "item": "https://toolkify.app/tools/developer/randomizer-wheel"
        }
      ]
    }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How to use randomizer wheel?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Using our free randomizer wheel spinner is straightforward. Simply navigate to the input panel on the edit screen, type or paste your choices (one per line), and click the central \"SPIN\" button. You can also grab the wheel anywhere and flick it with your pointer to spin it manually using our realistic physics simulation. The wheel decelerates gradually and shows the winner in a celebration modal.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to add randomizer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To add options to the randomizer, locate the \"Edit Choices\" tab next to the wheel. Enter your custom entries—such as names to create a name randomizer wheel, numbers for a number randomizer wheel, or geographical names for a country randomizer wheel. You can also toggle \"Weighting Mode\" to adjust the relative probability of each choice, allowing some slices to be larger than others.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What to draw randomizer wheel?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>You can draw anything you like! Common use cases include drawing winners using a name randomizer wheel, picking raffle digits via a number randomizer wheel, generating colors using a color randomizer wheel, or choosing letters with a letter randomizer wheel. You can also populate a list randomizer wheel with restaurants for a food randomizer wheel, or wildlife options for an animal randomizer wheel.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to set up randomizer wheel?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Setting up your custom randomizer wheel is simple. Under the \"Settings\" tab, you can toggle audio effects on or off, select from curated themes (Pastel, Vibrant, Retro, Dark Forest), and view your spin history. When you are happy with the setup, name and save it as a local preset or generate a shareable URL to share your custom configuration with others.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1280px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">
            {tier}
          </span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How randomizer wheel works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset wheel settings and list"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 items-stretch relative">
      
      <!-- Left Column: Canvas Wheel view (Col 7) -->
      <div class="lg:col-span-7 card-base p-4 sm:p-6 flex flex-col items-center justify-between gap-4 relative min-h-[450px]">
        <!-- Sound indicator and Reduced motion settings badge -->
        <div class="w-full flex items-center justify-between text-[11px] text-slate px-1">
          <span class="flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-success-accent animate-pulse"></span>
            100% Browser-Based Secure Spin
          </span>
          <div class="flex items-center gap-2">
            <span id="motion-badge" class="hidden bg-surface-yellow text-yellow-dark px-1.5 py-0.5 rounded font-mono text-[9px]">Reduced Motion Active</span>
            <span id="choices-count-badge" class="font-mono bg-surface border border-hairline px-1.5 py-0.5 rounded text-[10px]">0 choices</span>
          </div>
        </div>

        <!-- Wheel Container -->
        <div class="relative w-full max-w-[420px] aspect-square flex items-center justify-center select-none" id="wheel-interactive-area">
          <canvas id="wheel-canvas" class="w-full h-full cursor-grab active:cursor-grabbing transition-transform duration-100"></canvas>
          
          <!-- Outer Selector Peg / Indicator Arrow -->
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-10 filter drop-shadow-md">
            <svg width="24" height="28" viewBox="0 0 24 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 28L0 4C0 4 6 0 12 0C18 0 24 4 24 4L12 28Z" fill="#1c1c1e" />
              <path d="M12 22L4 5C4 5 8 2 12 2C16 2 20 5 20 5L12 22Z" fill="#ffd02f" />
            </svg>
          </div>

          <!-- Absolute Center Spin button with Glow/Pulse (pauses when spinning) -->
          <button
            type="button"
            id="center-spin-btn"
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-primary text-canvas border-4 border-canvas shadow-lg flex flex-col items-center justify-center cursor-pointer transition-all hover:scale-105 active:scale-95 group focus:outline-none focus:ring-4 focus:ring-brand-blue/30 z-20"
            aria-label="Spin the wheel"
          >
            <!-- Pulse Glow Rings (CSS Animation) -->
            <span class="absolute inset-0 rounded-full bg-primary/20 scale-110 animate-ping group-hover:duration-700" id="pulse-ring"></span>
            
            <span class="font-display font-bold text-xs sm:text-sm tracking-widest uppercase">Spin</span>
          </button>
        </div>

        <!-- Winner Announcement Modal / Panel Overlay (Springy entry) -->
        <div
          id="winner-panel"
          class="hidden absolute inset-0 z-30 bg-primary/10 backdrop-blur-md flex flex-col items-center justify-center p-6 text-center"
        >
          <div class="bg-canvas rounded-2xl max-w-md w-full p-6 border-2 border-primary shadow-modal flex flex-col gap-4 transform transition-all duration-300 scale-90 translate-y-4" id="winner-box">
            <span class="text-3xl">🎉 WINNER! 🎉</span>
            <div class="h-[1px] bg-hairline"></div>
            <h2 id="winner-name" class="font-display font-medium text-2xl sm:text-3xl text-primary break-words px-2 py-4 bg-surface rounded-xl border border-hairline-soft font-bold">
              Name
            </h2>
            <div class="flex gap-2.5 mt-2 justify-center">
              <button
                type="button"
                id="winner-close-btn"
                class="button-secondary text-xs py-2.5 px-4 !rounded-full font-bold cursor-pointer hover:bg-surface"
              >
                Keep Choice
              </button>
              <button
                type="button"
                id="winner-remove-btn"
                class="button-primary text-xs py-2.5 px-4 !rounded-full font-bold cursor-pointer"
              >
                Remove & Re-Spin
              </button>
            </div>
          </div>
        </div>

        <!-- Canvas for Confetti Overlay -->
        <canvas id="confetti-canvas" class="absolute inset-0 pointer-events-none z-45 w-full h-full"></canvas>
      </div>

      <!-- Right Column: Settings / Options Panel (Col 5) -->
      <div class="lg:col-span-5 flex flex-col gap-4">
        
        <!-- Tab Bar Selector -->
        <div class="flex rounded-full bg-surface p-0.5 border border-hairline w-full print:hidden">
          <button
            type="button"
            id="tab-edit-btn"
            class="flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
          >
            Edit Choices
          </button>
          <button
            type="button"
            id="tab-presets-btn"
            class="flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate"
          >
            Presets
          </button>
          <button
            type="button"
            id="tab-settings-btn"
            class="flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate"
          >
            Settings
          </button>
        </div>

        <!-- Pane 1: Edit Choices (Active by default) -->
        <div id="pane-edit" class="card-base p-4 sm:p-5 flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <h3 class="font-display font-semibold text-xs sm:text-sm text-primary flex items-center gap-1.5">
              Enter Choices (One per line)
            </h3>
            <span class="text-[10px] font-bold text-brand-blue" id="duplicate-warning"></span>
          </div>

          <textarea
            id="choices-input"
            class="w-full min-h-[140px] p-3 font-mono text-[12px] bg-surface-soft border border-hairline-strong rounded-xl text-primary resize-none outline-none leading-5 focus-within:border-brand-blue focus-within:ring-2 focus-within:ring-brand-blue/10"
            placeholder="Enter your options here&#10;Choice 1&#10;Choice 2&#10;Choice 3"
            spellcheck="false"
          ></textarea>

          <!-- Quick Templates Chips -->
          <div class="flex flex-col gap-1.5">
            <span class="text-[10px] font-semibold text-slate uppercase">Quick Templates</span>
            <div class="flex flex-wrap gap-1.5">
              <button type="button" class="template-chip text-[10px] font-bold bg-surface hover:bg-hairline text-slate hover:text-primary px-2.5 py-1 border border-hairline rounded-full cursor-pointer transition-colors" data-template="yesno">Yes / No</button>
              <button type="button" class="template-chip text-[10px] font-bold bg-surface hover:bg-hairline text-slate hover:text-primary px-2.5 py-1 border border-hairline rounded-full cursor-pointer transition-colors" data-template="numbers">1 - 10</button>
              <button type="button" class="template-chip text-[10px] font-bold bg-surface hover:bg-hairline text-slate hover:text-primary px-2.5 py-1 border border-hairline rounded-full cursor-pointer transition-colors" data-template="weekdays">Days of the Week</button>
              <button type="button" class="template-chip text-[10px] font-bold bg-surface hover:bg-hairline text-slate hover:text-primary px-2.5 py-1 border border-hairline rounded-full cursor-pointer transition-colors" data-template="team">Team Members</button>
            </div>
          </div>

          <!-- Weighting Mode Toggle & Input List -->
          <div class="flex flex-col gap-2.5 border-t border-hairline pt-3 mt-1">
            <div class="flex items-center justify-between">
              <label for="weighted-toggle" class="text-xs font-semibold text-slate cursor-pointer">Enable Weighting Mode</label>
              <input
                type="checkbox"
                id="weighted-toggle"
                class="w-4 h-4 cursor-pointer accent-brand-blue"
              />
            </div>
            
            <!-- Dynamic Weighted List (Scrollable) -->
            <div id="weights-container" class="hidden flex-col gap-1.5 max-h-[160px] overflow-y-auto pr-1">
              <!-- Rendered programmatically -->
            </div>
          </div>

          <!-- Share Link Button -->
          <button
            type="button"
            id="share-wheel-btn"
            class="button-secondary text-xs py-2 w-full !rounded-full transition-all cursor-pointer font-bold hover:bg-surface flex items-center justify-center gap-1.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.636-2.318M8.684 13.258l4.636 2.318M18 10a3 3 0 11-6 0 3 3 0 016 0zm-8 6a3 3 0 11-6 0 3 3 0 016 0zm8-12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Copy Shareable URL</span>
          </button>
        </div>

        <!-- Pane 2: Presets (Hidden initially) -->
        <div id="pane-presets" class="hidden card-base p-4 sm:p-5 flex flex-col gap-4">
          <h3 class="font-display font-semibold text-xs sm:text-sm text-primary">
            Save Current Wheel Configuration
          </h3>
          <div class="flex gap-2">
            <input
              type="text"
              id="preset-name-input"
              class="text-input flex-grow text-xs h-9 bg-surface-soft"
              placeholder="e.g. Lunch Decider"
            />
            <button
              type="button"
              id="preset-save-btn"
              class="button-primary text-xs h-9 py-0 px-4 !rounded-full font-bold cursor-pointer"
            >
              Save
            </button>
          </div>
          <div class="h-[1px] bg-hairline my-1"></div>
          <h4 class="text-[10px] font-semibold text-slate uppercase">Your Saved Wheels</h4>
          <div id="presets-list-container" class="flex flex-col gap-2 max-h-[220px] overflow-y-auto">
            <!-- Programmatically rendered list -->
            <span class="text-xs text-stone italic">No saved wheels yet.</span>
          </div>
        </div>

        <!-- Pane 3: Settings & History (Hidden initially) -->
        <div id="pane-settings" class="hidden card-base p-4 sm:p-5 flex flex-col gap-4">
          <!-- Audio Controls -->
          <div class="flex items-center justify-between pb-3 border-b border-hairline-soft">
            <span class="text-xs font-semibold text-slate">Enable Ticking & Fanfare Sound</span>
            <button
              type="button"
              id="sound-toggle-btn"
              class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer"
            >
              <span id="sound-icon">🔊</span>
              <span id="sound-status-text">On</span>
            </button>
          </div>

          <!-- Color Palette Picker -->
          <div class="flex flex-col gap-2 pb-3 border-b border-hairline-soft">
            <span class="text-xs font-semibold text-slate">Color Palette Theme</span>
            <div class="grid grid-cols-2 gap-2">
              <button type="button" class="palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-primary bg-surface" data-palette="pastel">
                <div class="flex gap-1 mb-1">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffd02f]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#0fbcb0]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ff9999]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffd8f4]"></span>
                </div>
                Pastel Board
              </button>
              <button type="button" class="palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-hairline" data-palette="vibrant">
                <div class="flex gap-1 mb-1">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#4262ff]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#0fbcb0]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ff9999]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffd02f]"></span>
                </div>
                Miro Signature
              </button>
              <button type="button" class="palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-hairline" data-palette="retro">
                <div class="flex gap-1 mb-1">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffd02f]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffe6cd]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffc6c6]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#fde0f0]"></span>
                </div>
                Warm Retro
              </button>
              <button type="button" class="palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-hairline" data-palette="forest">
                <div class="flex gap-1 mb-1">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#187574]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#c3faf5]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#fafbfc]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#1c1c1e]"></span>
                </div>
                Dark Forest
              </button>
            </div>
          </div>

          <!-- Spin History Log -->
          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-slate">Spin Session History</span>
              <button type="button" id="clear-history-btn" class="text-[10px] font-bold text-brand-coral hover:underline cursor-pointer">Clear Log</button>
            </div>
            <div id="history-log-container" class="flex flex-col gap-1.5 max-h-[140px] overflow-y-auto pr-1">
              <span class="text-xs text-stone italic">No history yet. Spin the wheel to record.</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <RelatedTools currentSlug="randomizer-wheel" />

  <!-- Toast Notification Wrapper (For Copy Actions & Undo Actions) -->
  <div id="toast-wrapper" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>

  <!-- How It Works Modal (Pattern 2 Close Match) -->
  <div
    id="how-it-works-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto">
      <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
        <h3 class="font-display font-semibold text-lg text-primary">
          Randomizer Wheel Guide
        </h3>
        <button
          type="button"
          id="close-modal-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >
          ✕
        </button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">1. Interactive Physics & Spinning</h4>
        <p>
          You can click the center <strong>SPIN</strong> button to spin with controlled deceleration, or grab the wheel anywhere and flick it with your mouse or finger to watch it rotate naturally based on release velocity and friction.
        </p>

        <h4 class="font-semibold text-primary">2. Secure Cryptographic Randomness</h4>
        <p>
          All spins utilize browser-native <code>window.crypto.getRandomValues</code> to ensure complete visual fairness. The visual deceleration is mathematically reconciled to align exactly with the cryptographically selected winner.
        </p>

        <h4 class="font-semibold text-primary">3. Custom Choice Weighting</h4>
        <p>
          Need some choices to have higher probability? Toggle <strong>Weighting Mode</strong> to assign custom numeric multipliers to individual choices, adjusting their segments dynamically.
        </p>

        <h4 class="font-semibold text-primary">4. Presets and Sharing</h4>
        <p>
          Save customized wheels locally so they load instantly on your next visit, or generate a shareable URL to share your custom list, weights, and color palette with friends.
        </p>
      </div>
      <button
        type="button"
        id="modal-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
