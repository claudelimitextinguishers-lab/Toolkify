  <!-- Client-side Logic Script -->
  <script>
    // Palettes matching DESIGN.md tokens
    const PALETTES = {
      pastel: ['#ffd02f', '#0fbcb0', '#ff9999', '#ffd8f4', '#ffe6cd', '#4262ff'],
      vibrant: ['#4262ff', '#0fbcb0', '#ff9999', '#ffd02f', '#5b76fe', '#ffd8f4'],
      retro: ['#ffd02f', '#ffe6cd', '#ffc6c6', '#fde0f0', '#c3faf5', '#ff9999'],
      forest: ['#187574', '#c3faf5', '#fafbfc', '#1c1c1e', '#e0e2e8', '#ffd02f']
    };

    interface ChoiceItem {
      text: string;
      weight: number;
    }

    interface WheelPreset {
      name: string;
      choices: ChoiceItem[];
      palette: keyof typeof PALETTES;
      weighted: boolean;
    }

    // State Variables
    let choices: ChoiceItem[] = [];
    let isWeightedMode = false;
    let selectedPalette: keyof typeof PALETTES = 'pastel';
    let isSoundEnabled = true;
    let spinHistory: { winner: string; timestamp: number }[] = [];
    let savedPresets: WheelPreset[] = [];

    // Physics Engine State
    let rotation = 0; // Current angle in radians
    let angularVelocity = 0; // Current rotation speed in rad/frame
    let isDragging = false;
    let lastDragAngle = 0;
    let dragTimes: number[] = [];
    let dragAngles: number[] = [];
    let animationFrameId: number | null = null;
    let isSpinningToTarget = false;
    let spinTargetAngle = 0;
    let startRotation = 0;
    let spinDuration = 0;
    let spinTimeElapsed = 0;
    let targetSegmentWinnerIndex = -1;

    // Undo toast state
    let lastClearedChoices: ChoiceItem[] = [];

    // DOM Elements
    const canvas = document.getElementById('wheel-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const choicesInput = document.getElementById('choices-input') as HTMLTextAreaElement;
    const duplicateWarning = document.getElementById('duplicate-warning') as HTMLSpanElement;
    const weightedToggle = document.getElementById('weighted-toggle') as HTMLInputElement;
    const weightsContainer = document.getElementById('weights-container') as HTMLDivElement;
    const choicesCountBadge = document.getElementById('choices-count-badge') as HTMLSpanElement;
    
    const centerSpinBtn = document.getElementById('center-spin-btn') as HTMLButtonElement;
    const pulseRing = document.getElementById('pulse-ring') as HTMLSpanElement;
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
    const howItWorksBtn = document.getElementById('how-it-works-btn') as HTMLButtonElement;
    const howItWorksModal = document.getElementById('how-it-works-modal') as HTMLDivElement;
    const closeModalBtn = document.getElementById('close-modal-btn') as HTMLButtonElement;
    const modalOkBtn = document.getElementById('modal-ok-btn') as HTMLButtonElement;

    // Tab buttons
    const tabEditBtn = document.getElementById('tab-edit-btn') as HTMLButtonElement;
    const tabPresetsBtn = document.getElementById('tab-presets-btn') as HTMLButtonElement;
    const tabSettingsBtn = document.getElementById('tab-settings-btn') as HTMLButtonElement;
    
    // Panes
    const paneEdit = document.getElementById('pane-edit') as HTMLDivElement;
    const panePresets = document.getElementById('pane-presets') as HTMLDivElement;
    const paneSettings = document.getElementById('pane-settings') as HTMLDivElement;

    // Presets elements
    const presetNameInput = document.getElementById('preset-name-input') as HTMLInputElement;
    const presetSaveBtn = document.getElementById('preset-save-btn') as HTMLButtonElement;
    const presetsListContainer = document.getElementById('presets-list-container') as HTMLDivElement;

    // Settings elements
    const soundToggleBtn = document.getElementById('sound-toggle-btn') as HTMLButtonElement;
    const soundStatusText = document.getElementById('sound-status-text') as HTMLSpanElement;
    const soundIcon = document.getElementById('sound-icon') as HTMLSpanElement;
    const clearHistoryBtn = document.getElementById('clear-history-btn') as HTMLButtonElement;
    const historyLogContainer = document.getElementById('history-log-container') as HTMLDivElement;
    const shareWheelBtn = document.getElementById('share-wheel-btn') as HTMLButtonElement;

    // Winner panel
    const winnerPanel = document.getElementById('winner-panel') as HTMLDivElement;
    const winnerBox = document.getElementById('winner-box') as HTMLDivElement;
    const winnerName = document.getElementById('winner-name') as HTMLHeadingElement;
    const winnerCloseBtn = document.getElementById('winner-close-btn') as HTMLButtonElement;
    const winnerRemoveBtn = document.getElementById('winner-remove-btn') as HTMLButtonElement;
    
    // Audio Context Setup (Lazy Loaded)
    let audioCtx: AudioContext | null = null;
    function getAudioContext() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      }
      return audioCtx;
    }

    // Audio Tick synthesis
    function playTickSound() {
      if (!isSoundEnabled) return;
      try {
        const actx = getAudioContext();
        const osc = actx.createOscillator();
        const gain = actx.createGain();
        osc.connect(gain);
        gain.connect(actx.destination);

        osc.type = 'triangle';
        osc.frequency.setValueAtTime(800, actx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(100, actx.currentTime + 0.015);

        gain.gain.setValueAtTime(0.08, actx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + 0.015);

        osc.start();
        osc.stop(actx.currentTime + 0.015);
      } catch (err) {
        console.warn(err);
      }
    }

    // Fanfare Winner sound synthesis
    function playFanfareSound() {
      if (!isSoundEnabled) return;
      try {
        const actx = getAudioContext();
        const notes = [261.63, 329.63, 392.00, 523.25]; // C4, E4, G4, C5 arpeggio
        notes.forEach((freq, i) => {
          const osc = actx.createOscillator();
          const gain = actx.createGain();
          osc.connect(gain);
          gain.connect(actx.destination);

          osc.type = 'sine';
          osc.frequency.value = freq;

          gain.gain.setValueAtTime(0, actx.currentTime + i * 0.1);
          gain.gain.linearRampToValueAtTime(0.12, actx.currentTime + i * 0.1 + 0.05);
          gain.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + i * 0.1 + 0.4);

          osc.start(actx.currentTime + i * 0.1);
          osc.stop(actx.currentTime + i * 0.1 + 0.4);
        });
      } catch (err) {
        console.warn(err);
      }
    }

    // Setup Canvas Resolution
    function resizeCanvas() {
      const parent = canvas.parentElement!;
      const dpr = window.devicePixelRatio || 1;
      const size = Math.min(parent.clientWidth, 420);
      canvas.width = size * dpr;
      canvas.height = size * dpr;
      canvas.style.width = `${size}px`;
      canvas.style.height = `${size}px`;
      drawWheel();
    }

    // Draw Randomizer Wheel
    function drawWheel() {
      if (!canvas.width || !canvas.height) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const dpr = window.devicePixelRatio || 1;
      const width = canvas.width;
      const height = canvas.height;
      const cx = width / 2;
      const cy = height / 2;
      const radius = (Math.min(width, height) / 2) - (8 * dpr);

      if (choices.length === 0) {
        // Draw Placeholder center
        ctx.beginPath();
        ctx.arc(cx, cy, radius, 0, 2 * Math.PI);
        ctx.fillStyle = '#f7f8fa';
        ctx.fill();
        ctx.strokeStyle = '#e0e2e8';
        ctx.lineWidth = 2 * dpr;
        ctx.stroke();

        ctx.font = `${Math.round(14 * dpr)}px Roobert PRO, sans-serif`;
        ctx.fillStyle = '#8e91a0';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('Enter choices to begin', cx, cy);
        return;
      }

      const totalWeight = choices.reduce((acc, c) => acc + (isWeightedMode ? c.weight : 1), 0);
      const palette = PALETTES[selectedPalette] || PALETTES.pastel;

      let startAngle = rotation;

      for (let i = 0; i < choices.length; i++) {
        const item = choices[i];
        const weight = isWeightedMode ? item.weight : 1;
        const sliceAngle = (weight / totalWeight) * 2 * Math.PI;

        // Draw Wedge Slice
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, radius, startAngle, startAngle + sliceAngle);
        ctx.closePath();
        ctx.fillStyle = palette[i % palette.length];
        ctx.fill();
        
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 1.5 * dpr;
        ctx.stroke();

        // Draw Label Text
        ctx.save();
        ctx.translate(cx, cy);
        ctx.rotate(startAngle + sliceAngle / 2);

        // Auto-shrink text behavior
        let fontSize = 14;
        if (choices.length > 30) fontSize = 8;
        else if (choices.length > 15) fontSize = 10;
        else if (choices.length > 8) fontSize = 12;

        ctx.font = `600 ${Math.round(fontSize * dpr)}px Roobert PRO, sans-serif`;
        ctx.fillStyle = '#1c1c1e';
        
        // Determine contrasting text color for dark slices
        const isDarkColor = ['#1c1c1e', '#187574'].includes(palette[i % palette.length]);
        if (isDarkColor) {
          ctx.fillStyle = '#ffffff';
        }

        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        
        const truncatedText = item.text.length > 15 ? item.text.substring(0, 13) + '..' : item.text;
        ctx.fillText(truncatedText, radius - 20 * dpr, 0);
        ctx.restore();

        startAngle += sliceAngle;
      }

      // Draw Center Pin Outer Ring
      ctx.beginPath();
      ctx.arc(cx, cy, 26 * dpr, 0, 2 * Math.PI);
      ctx.fillStyle = '#ffffff';
      ctx.fill();
      ctx.strokeStyle = '#e0e2e8';
      ctx.lineWidth = 1 * dpr;
      ctx.stroke();
    }

    // Get segment index pointing under the top peg
    function getWinnerIndex(currentRot: number): number {
      if (choices.length === 0) return -1;
      const totalWeight = choices.reduce((acc, c) => acc + (isWeightedMode ? c.weight : 1), 0);
      
      // The top peg is at angle -Math.PI / 2
      let normalizedAngle = (-currentRot - Math.PI / 2) % (2 * Math.PI);
      if (normalizedAngle < 0) {
        normalizedAngle += 2 * Math.PI;
      }

      let angleAccumulator = 0;
      for (let i = 0; i < choices.length; i++) {
        const item = choices[i];
        const weight = isWeightedMode ? item.weight : 1;
        const sliceAngle = (weight / totalWeight) * 2 * Math.PI;
        
        if (normalizedAngle >= angleAccumulator && normalizedAngle < angleAccumulator + sliceAngle) {
          return i;
        }
        angleAccumulator += sliceAngle;
      }
      return choices.length - 1;
    }

    // Custom Confetti Particle System
    const confCanvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
    const cctx = confCanvas.getContext('2d')!;
    let confettiParticles: any[] = [];
    let isConfettiRunning = false;

    function resizeConfettiCanvas() {
      confCanvas.width = confCanvas.parentElement!.clientWidth;
      confCanvas.height = confCanvas.parentElement!.clientHeight;
    }

    function spawnConfetti() {
      resizeConfettiCanvas();
      confettiParticles = [];
      const colors = ['#ffd02f', '#0fbcb0', '#ff9999', '#ffd8f4', '#4262ff'];
      for (let i = 0; i < 70; i++) {
        confettiParticles.push({
          x: confCanvas.width / 2,
          y: confCanvas.height / 2 - 20,
          vx: (Math.random() - 0.5) * 8,
          vy: (Math.random() - 0.8) * 8 - 3,
          color: colors[Math.floor(Math.random() * colors.length)],
          size: Math.random() * 6 + 4,
          rotation: Math.random() * 360,
          rotationSpeed: (Math.random() - 0.5) * 10,
          alpha: 1
        });
      }
      isConfettiRunning = true;
      animateConfetti();
    }

    function animateConfetti() {
      if (!isConfettiRunning) return;
      cctx.clearRect(0, 0, confCanvas.width, confCanvas.height);
      let active = false;

      confettiParticles.forEach((p) => {
        if (p.alpha <= 0) return;
        active = true;

        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.2; // Gravity
        p.vx *= 0.98; // Friction
        p.rotation += p.rotationSpeed;
        p.alpha -= 0.015;

        cctx.save();
        cctx.translate(p.x, p.y);
        cctx.rotate((p.rotation * Math.PI) / 180);
        cctx.fillStyle = p.color;
        cctx.globalAlpha = p.alpha;
        cctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
        cctx.restore();
      });

      if (active) {
        requestAnimationFrame(animateConfetti);
      } else {
        isConfettiRunning = false;
        cctx.clearRect(0, 0, confCanvas.width, confCanvas.height);
      }
    }

    // Check if user prefers reduced motion
    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const motionBadge = document.getElementById('motion-badge')!;
    function updateMotionPreference() {
      if (motionQuery.matches) {
        motionBadge.classList.remove('hidden');
      } else {
        motionBadge.classList.add('hidden');
      }
    }
    updateMotionPreference();
    motionQuery.addEventListener('change', updateMotionPreference);

    // Secure winner selection using window.crypto
    function selectSecureWinner(): number {
      const totalWeight = choices.reduce((acc, c) => acc + (isWeightedMode ? c.weight : 1), 0);
      const array = new Uint32Array(1);
      window.crypto.getRandomValues(array);
      const randomValue = array[0] / (0xffffffff + 1); // 0 to 1 uniform float

      let threshold = randomValue * totalWeight;
      let cumulativeWeight = 0;
      for (let i = 0; i < choices.length; i++) {
        const item = choices[i];
        const weight = isWeightedMode ? item.weight : 1;
        cumulativeWeight += weight;
        if (threshold <= cumulativeWeight) {
          return i;
        }
      }
      return choices.length - 1;
    }

    // Perform spin using math-reconciliation
    function startSpin() {
      if (choices.length === 0 || angularVelocity !== 0 || isSpinningToTarget) return;

      // Pulse Glow stops
      pulseRing.classList.remove('animate-ping');
      
      const winnerIdx = selectSecureWinner();
      targetSegmentWinnerIndex = winnerIdx;

      // Compute total weights and exact angle segment center for the winner
      const totalWeight = choices.reduce((acc, c) => acc + (isWeightedMode ? c.weight : 1), 0);
      let angleStart = 0;
      for (let i = 0; i < winnerIdx; i++) {
        const weight = isWeightedMode ? choices[i].weight : 1;
        angleStart += (weight / totalWeight) * 2 * Math.PI;
      }
      const itemWeight = isWeightedMode ? choices[winnerIdx].weight : 1;
      const sliceAngle = (itemWeight / totalWeight) * 2 * Math.PI;
      const targetCenterAngle = angleStart + sliceAngle / 2;

      // Desired rotation value to position winner exactly under the top indicator peg (at -Math.PI / 2)
      let targetRot = (-targetCenterAngle - Math.PI / 2);
      
      // Keep rotation positive and add 4-6 full spins
      const currentNorm = rotation % (2 * Math.PI);
      const fullSpins = (4 + Math.floor(Math.random() * 3)) * 2 * Math.PI;
      
      let targetAngleOffset = targetRot - currentNorm;
      if (targetAngleOffset < 0) targetAngleOffset += 2 * Math.PI;

      spinTargetAngle = rotation + targetAngleOffset + fullSpins;
      
      // Duration & physics fallback if reduced motion enabled
      if (motionQuery.matches) {
        // Fast snap
        rotation = spinTargetAngle;
        drawWheel();
        handleWinnerSelected(winnerIdx);
        return;
      }

      isSpinningToTarget = true;
      spinDuration = 180 + Math.floor(Math.random() * 60); // 3-4 seconds of rendering
      spinTimeElapsed = 0;
      startRotation = rotation;
      
      animateWheelSpin();
    }

    // Animation Loop
    let lastPlayedIdx = -1;
    function animateWheelSpin() {
      if (!isSpinningToTarget) return;

      spinTimeElapsed++;
      const progress = Math.min(spinTimeElapsed / spinDuration, 1);

      // Eased Deceleration Curve (cubic out style)
      const easeOut = 1 - Math.pow(1 - progress, 3.5);
      
      // Calculate rotation by interpolating from startRotation to spinTargetAngle
      rotation = startRotation + (spinTargetAngle - startRotation) * easeOut;

      const currentWinnerIdx = getWinnerIndex(rotation);
      if (currentWinnerIdx !== lastPlayedIdx) {
        playTickSound();
        lastPlayedIdx = currentWinnerIdx;
      }

      drawWheel();

      if (spinTimeElapsed >= spinDuration) {
        isSpinningToTarget = false;
        rotation = spinTargetAngle;
        drawWheel();
        handleWinnerSelected(targetSegmentWinnerIndex);
      } else {
        animationFrameId = requestAnimationFrame(animateWheelSpin);
      }
    }

    // Process Drag & Flick input physics
    function initPhysicsDrag() {
      let isPointerDown = false;

      function getAngle(x: number, y: number): number {
        const rect = canvas.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        return Math.atan2(y - cy, x - cx);
      }

      canvas.addEventListener('pointerdown', (e) => {
        if (choices.length === 0 || isSpinningToTarget) return;
        isPointerDown = true;
        isDragging = true;
        canvas.setPointerCapture(e.pointerId);

        // Cancel previous velocity calculation
        if (animationFrameId) {
          cancelAnimationFrame(animationFrameId);
          animationFrameId = null;
        }
        angularVelocity = 0;

        const angle = getAngle(e.clientX, e.clientY);
        lastDragAngle = angle;
        
        dragTimes = [Date.now()];
        dragAngles = [rotation];
      });

      canvas.addEventListener('pointermove', (e) => {
        if (!isPointerDown) return;
        const angle = getAngle(e.clientX, e.clientY);
        const delta = angle - lastDragAngle;
        
        // Handle wrap-around
        let actualDelta = Math.atan2(Math.sin(delta), Math.cos(delta));
        rotation += actualDelta;
        
        lastDragAngle = angle;
        drawWheel();

        // Track velocity points
        const now = Date.now();
        dragTimes.push(now);
        dragAngles.push(rotation);
        if (dragTimes.length > 5) {
          dragTimes.shift();
          dragAngles.shift();
        }
      });

      canvas.addEventListener('pointerup', (e) => {
        if (!isPointerDown) return;
        isPointerDown = false;
        isDragging = false;
        canvas.releasePointerCapture(e.pointerId);

        // Compute Flick velocity on release
        if (dragTimes.length >= 2) {
          const dt = dragTimes[dragTimes.length - 1] - dragTimes[0];
          const da = dragAngles[dragAngles.length - 1] - dragAngles[0];
          if (dt > 0) {
            angularVelocity = da / (dt / 16.666); // scale velocity to frame interval
          }
        }

        // Limit velocity to prevent extreme spins
        const maxVel = 0.8;
        if (angularVelocity > maxVel) angularVelocity = maxVel;
        if (angularVelocity < -maxVel) angularVelocity = -maxVel;

        if (Math.abs(angularVelocity) > 0.01) {
          pulseRing.classList.remove('animate-ping');
          animateFlickFriction();
        }
      });

      canvas.addEventListener('pointercancel', () => {
        isPointerDown = false;
        isDragging = false;
      });
    }

    function animateFlickFriction() {
      if (isDragging || isSpinningToTarget) return;

      rotation += angularVelocity;
      angularVelocity *= 0.985; // friction factor

      // play ticking audio
      const currentWinnerIdx = getWinnerIndex(rotation);
      if (currentWinnerIdx !== lastPlayedIdx) {
        playTickSound();
        lastPlayedIdx = currentWinnerIdx;
      }

      drawWheel();

      if (Math.abs(angularVelocity) < 0.001) {
        angularVelocity = 0;
        const winnerIdx = getWinnerIndex(rotation);
        handleWinnerSelected(winnerIdx);
      } else {
        animationFrameId = requestAnimationFrame(animateFlickFriction);
      }
    }

    // Trigger Winner announcement
    function handleWinnerSelected(winnerIdx: number) {
      if (winnerIdx < 0 || winnerIdx >= choices.length) return;
      const winner = choices[winnerIdx].text;
      
      // Update session history
      spinHistory.unshift({ winner, timestamp: Date.now() });
      updateHistoryUI();
      saveState();

      // Show Winner Panel & trigger audio fanfare / confetti
      winnerName.textContent = winner;
      winnerPanel.classList.remove('hidden');
      setTimeout(() => {
        winnerBox.classList.remove('scale-90', 'translate-y-4');
      }, 50);

      playFanfareSound();
      spawnConfetti();
    }

    // Reset button handler (Must fully reset choices, presets, inputs, state, and localStorage keys)
    function fullReset() {
      choices = [
        { text: 'Choice 1', weight: 1 },
        { text: 'Choice 2', weight: 1 },
        { text: 'Choice 3', weight: 1 }
      ];
      isWeightedMode = false;
      selectedPalette = 'pastel';
      isSoundEnabled = true;
      spinHistory = [];
      savedPresets = [];
      rotation = 0;
      angularVelocity = 0;
      
      // Clear localStorage keys in namespace
      localStorage.removeItem('toolkify:randomizer-wheel:choices');
      localStorage.removeItem('toolkify:randomizer-wheel:presets');
      localStorage.removeItem('toolkify:randomizer-wheel:sound-enabled');
      localStorage.removeItem('toolkify:randomizer-wheel:palette-id');
      localStorage.removeItem('toolkify:randomizer-wheel:weighted-mode');

      // Clear input views
      choicesInput.value = 'Choice 1\nChoice 2\nChoice 3';
      weightedToggle.checked = false;
      presetNameInput.value = '';

      updateSoundButtonUI();
      syncStateFromChoices();
      updatePresetsUI();
      updateHistoryUI();
      resizeCanvas();
      
      // Pulse ring reset
      pulseRing.classList.add('animate-ping');
      
      showToast('✓ Configuration and history reset successfully.');
    }

    // State Sync helpers
    function syncStateFromChoices() {
      // Build weights editor list
      weightsContainer.innerHTML = '';
      choices.forEach((item, index) => {
        const row = document.createElement('div');
        row.className = 'flex items-center justify-between gap-3 text-xs bg-surface p-1.5 rounded-lg border border-hairline-soft';
        row.innerHTML = `
          <span class="font-medium text-primary truncate max-w-[180px]">${item.text}</span>
          <div class="flex items-center gap-1">
            <span class="text-[10px] text-slate">Weight:</span>
            <input
              type="number"
              class="weight-input w-14 h-7 text-center rounded border border-hairline bg-canvas text-xs focus:border-brand-blue outline-none"
              data-index="${index}"
              min="1"
              max="100"
              value="${item.weight}"
            />
          </div>
        `;
        weightsContainer.appendChild(row);
      });

      // Update count badge
      choicesCountBadge.textContent = `${choices.length} choices`;

      // Warning rules
      if (choices.length > 50) {
        duplicateWarning.textContent = '⚠️ Long list makes labels hard to read';
        duplicateWarning.className = 'text-[9px] font-semibold text-yellow-dark';
      } else {
        // Duplicate detection
        const texts = choices.map(c => c.text.toLowerCase().trim());
        const hasDuplicates = texts.some((val, i) => texts.indexOf(val) !== i);
        if (hasDuplicates) {
          duplicateWarning.textContent = '⚠️ Duplicate item detected';
          duplicateWarning.className = 'text-[9px] font-semibold text-brand-coral';
        } else {
          duplicateWarning.textContent = '';
        }
      }

      drawWheel();
      saveState();
    }

    // Setup choice changes
    choicesInput.addEventListener('input', () => {
      const lines = choicesInput.value.split('\n')
        .map(l => l.trim())
        .filter(l => l !== '');

      const currentMap = new Map(choices.map(c => [c.text, c.weight]));
      choices = lines.map(line => ({
        text: line,
        weight: currentMap.get(line) || 1
      }));

      syncStateFromChoices();
    });

    // Handle single-item weight updates
    weightsContainer.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.classList.contains('weight-input')) {
        const idx = parseInt(target.getAttribute('data-index')!);
        const weight = Math.max(1, parseInt(target.value) || 1);
        choices[idx].weight = weight;
        drawWheel();
        saveState();
      }
    });

    // Weighted mode toggle
    weightedToggle.addEventListener('change', () => {
      isWeightedMode = weightedToggle.checked;
      if (isWeightedMode) {
        weightsContainer.classList.remove('hidden');
        weightsContainer.classList.add('flex');
      } else {
        weightsContainer.classList.remove('flex');
        weightsContainer.classList.add('hidden');
      }
      drawWheel();
      saveState();
    });

    // Save and load presets
    function savePreset() {
      const name = presetNameInput.value.trim();
      if (!name) {
        showToast('⚠️ Please enter a preset name');
        return;
      }
      if (choices.length === 0) return;

      const preset: WheelPreset = {
        name,
        choices: JSON.parse(JSON.stringify(choices)),
        palette: selectedPalette,
        weighted: isWeightedMode
      };

      savedPresets.unshift(preset);
      presetNameInput.value = '';
      updatePresetsUI();
      saveState();
      showToast(`✓ Preset "${name}" saved!`);
    }

    function updatePresetsUI() {
      presetsListContainer.innerHTML = '';
      if (savedPresets.length === 0) {
        presetsListContainer.innerHTML = '<span class="text-xs text-stone italic">No saved wheels yet.</span>';
        return;
      }

      savedPresets.forEach((p, idx) => {
        const row = document.createElement('div');
        row.className = 'flex items-center justify-between p-2 rounded-xl bg-surface border border-hairline-soft text-xs transition-all hover:border-hairline';
        row.innerHTML = `
          <div class="flex flex-col gap-0.5 truncate max-w-[200px]">
            <span class="font-bold text-primary truncate">${p.name}</span>
            <span class="text-[10px] text-slate">${p.choices.length} choices · ${p.weighted ? 'Weighted' : 'Equal'}</span>
          </div>
          <div class="flex gap-1">
            <button type="button" class="preset-load-btn bg-canvas hover:bg-hairline text-slate hover:text-primary px-2.5 py-1 border border-hairline rounded-full cursor-pointer transition-colors text-[10px] font-bold" data-index="${idx}">Load</button>
            <button type="button" class="preset-del-btn bg-canvas hover:bg-brand-red text-slate hover:text-coral-dark px-2.5 py-1 border border-hairline rounded-full cursor-pointer transition-colors text-[10px] font-bold" data-index="${idx}">Delete</button>
          </div>
        `;
        presetsListContainer.appendChild(row);
      });
    }

    presetsListContainer.addEventListener('click', (e) => {
      const target = e.target as HTMLButtonElement;
      if (target.classList.contains('preset-load-btn')) {
        const idx = parseInt(target.getAttribute('data-index')!);
        const preset = savedPresets[idx];
        
        choices = JSON.parse(JSON.stringify(preset.choices));
        isWeightedMode = preset.weighted;
        selectedPalette = preset.palette;
        
        weightedToggle.checked = isWeightedMode;
        if (isWeightedMode) {
          weightsContainer.classList.remove('hidden');
          weightsContainer.classList.add('flex');
        } else {
          weightsContainer.classList.remove('flex');
          weightsContainer.classList.add('hidden');
        }

        // Palette UI selector highlight
        document.querySelectorAll('.palette-picker-btn').forEach(btn => {
          if (btn.getAttribute('data-palette') === selectedPalette) {
            btn.className = 'palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-primary bg-surface';
          } else {
            btn.className = 'palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-hairline';
          }
        });

        // Set textarea content
        choicesInput.value = choices.map(c => c.text).join('\n');
        
        syncStateFromChoices();
        showToast(`✓ Loaded preset: ${preset.name}`);
        
        // Go back to edit tab
        tabEditBtn.click();
      } else if (target.classList.contains('preset-del-btn')) {
        const idx = parseInt(target.getAttribute('data-index')!);
        const name = savedPresets[idx].name;
        savedPresets.splice(idx, 1);
        updatePresetsUI();
        saveState();
        showToast(`Cleared preset: ${name}`);
      }
    });

    // State Serialization for shareable URL
    function generateShareUrl() {
      const config = {
        choices: choices.map(c => [c.text, c.weight]),
        palette: selectedPalette,
        weighted: isWeightedMode
      };

      try {
        const json = JSON.stringify(config);
        const encoded = btoa(unescape(encodeURIComponent(json)));
        const url = `${window.location.origin}${window.location.pathname}?wheel=${encoded}`;
        
        navigator.clipboard.writeText(url).then(() => {
          showToast('✓ Shareable URL copied to clipboard!');
        });
      } catch (err) {
        showToast('⚠️ Could not generate URL.');
      }
    }

    // Load from URL if present
    function loadFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const data = params.get('wheel');
      if (!data) return false;

      try {
        const decoded = decodeURIComponent(escape(atob(data)));
        const config = JSON.parse(decoded);
        
        choices = config.choices.map((c: any) => ({ text: c[0], weight: c[1] }));
        selectedPalette = config.palette || 'pastel';
        isWeightedMode = !!config.weighted;

        weightedToggle.checked = isWeightedMode;
        if (isWeightedMode) {
          weightsContainer.classList.remove('hidden');
          weightsContainer.classList.add('flex');
        }

        choicesInput.value = choices.map(c => c.text).join('\n');
        
        // Highlight active palette button
        document.querySelectorAll('.palette-picker-btn').forEach(btn => {
          if (btn.getAttribute('data-palette') === selectedPalette) {
            btn.className = 'palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-primary bg-surface';
          } else {
            btn.className = 'palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-hairline';
          }
        });

        syncStateFromChoices();
        return true;
      } catch (err) {
        console.warn('URL parse failure', err);
        return false;
      }
    }

    // Local Storage Helpers
    function saveState() {
      localStorage.setItem('toolkify:randomizer-wheel:choices', JSON.stringify(choices));
      localStorage.setItem('toolkify:randomizer-wheel:weighted-mode', JSON.stringify(isWeightedMode));
      localStorage.setItem('toolkify:randomizer-wheel:palette-id', selectedPalette);
      localStorage.setItem('toolkify:randomizer-wheel:sound-enabled', JSON.stringify(isSoundEnabled));
      localStorage.setItem('toolkify:randomizer-wheel:presets', JSON.stringify(savedPresets));
    }

    function loadState() {
      if (loadFromUrl()) return;

      const savedChoices = localStorage.getItem('toolkify:randomizer-wheel:choices');
      if (savedChoices) {
        try {
          choices = JSON.parse(savedChoices);
        } catch (e) {
          choices = [];
        }
      } else {
        choices = [
          { text: 'Yes', weight: 1 },
          { text: 'No', weight: 1 }
        ];
      }

      const savedWeighted = localStorage.getItem('toolkify:randomizer-wheel:weighted-mode');
      if (savedWeighted) {
        isWeightedMode = JSON.parse(savedWeighted);
        weightedToggle.checked = isWeightedMode;
        if (isWeightedMode) {
          weightsContainer.classList.remove('hidden');
          weightsContainer.classList.add('flex');
        }
      }

      const savedPalette = localStorage.getItem('toolkify:randomizer-wheel:palette-id');
      if (savedPalette) {
        selectedPalette = savedPalette as keyof typeof PALETTES;
      }

      const savedSound = localStorage.getItem('toolkify:randomizer-wheel:sound-enabled');
      if (savedSound) {
        isSoundEnabled = JSON.parse(savedSound);
      }

      const savedPresetsStr = localStorage.getItem('toolkify:randomizer-wheel:presets');
      if (savedPresetsStr) {
        try {
          savedPresets = JSON.parse(savedPresetsStr);
        } catch (e) {}
      }

      // Restore textarea value
      choicesInput.value = choices.map(c => c.text).join('\n');
      
      updateSoundButtonUI();
      syncStateFromChoices();
      updatePresetsUI();
    }

    // UI Toast messaging
    function showToast(message: string, isUndo = false) {
      const toastWrapper = document.getElementById('toast-wrapper')!;
      const toast = document.createElement('div');
      toast.className = 'bg-primary text-canvas text-xs font-semibold py-2 px-4 rounded-full shadow-lg flex items-center gap-3 transition-all duration-300 pointer-events-auto transform translate-y-2 opacity-0';
      
      let innerHTML = `<span>${message}</span>`;
      if (isUndo) {
        innerHTML += `<button type="button" id="undo-btn" class="text-brand-yellow font-bold uppercase hover:underline cursor-pointer">Undo</button>`;
      }
      toast.innerHTML = innerHTML;
      toastWrapper.appendChild(toast);

      // Trigger transition-in
      setTimeout(() => {
        toast.classList.remove('translate-y-2', 'opacity-0');
      }, 50);

      // Auto dismiss
      const dismissTimeout = setTimeout(() => {
        toast.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => {
          toast.remove();
        }, 300);
      }, 3500);

      // Bind Undo action if applicable
      if (isUndo) {
        const undoBtn = toast.querySelector('#undo-btn') as HTMLButtonElement;
        undoBtn.addEventListener('click', () => {
          if (lastClearedChoices.length > 0) {
            choices = JSON.parse(JSON.stringify(lastClearedChoices));
            choicesInput.value = choices.map(c => c.text).join('\n');
            syncStateFromChoices();
            showToast('✓ Cleared choices restored.');
          }
          clearTimeout(dismissTimeout);
          toast.remove();
        });
      }
    }

    // Settings Log & Toggles
    function updateSoundButtonUI() {
      if (isSoundEnabled) {
        soundStatusText.textContent = 'On';
        soundIcon.textContent = '🔊';
      } else {
        soundStatusText.textContent = 'Off';
        soundIcon.textContent = '🔇';
      }
    }

    soundToggleBtn.addEventListener('click', () => {
      isSoundEnabled = !isSoundEnabled;
      updateSoundButtonUI();
      saveState();
      showToast(isSoundEnabled ? '🔊 Sound effects enabled' : '🔇 Sound effects muted');
    });

    // History list UI
    function updateHistoryUI() {
      historyLogContainer.innerHTML = '';
      if (spinHistory.length === 0) {
        historyLogContainer.innerHTML = '<span class="text-xs text-stone italic">No history yet. Spin the wheel to record.</span>';
        return;
      }

      spinHistory.forEach((h) => {
        const timeStr = new Date(h.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const row = document.createElement('div');
        row.className = 'flex items-center justify-between text-xs py-1 px-2 bg-surface rounded border border-hairline-soft';
        row.innerHTML = `
          <span class="font-bold text-primary truncate max-w-[200px]">${h.winner}</span>
          <span class="text-[9px] text-stone font-mono">${timeStr}</span>
        `;
        historyLogContainer.appendChild(row);
      });
    }

    clearHistoryBtn.addEventListener('click', () => {
      spinHistory = [];
      updateHistoryUI();
      showToast('✓ Spin history log cleared.');
    });

    // Quick templates setup
    const TEMPLATES = {
      yesno: [{ text: 'Yes', weight: 1 }, { text: 'No', weight: 1 }],
      numbers: Array.from({ length: 10 }, (_, i) => ({ text: String(i + 1), weight: 1 })),
      weekdays: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'].map(d => ({ text: d, weight: 1 })),
      team: ['Alice', 'Bob', 'Charlie', 'Dana', 'Eli'].map(t => ({ text: t, weight: 1 }))
    };

    document.querySelectorAll('.template-chip').forEach(chip => {
      chip.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const type = target.getAttribute('data-template') as keyof typeof TEMPLATES;
        if (TEMPLATES[type]) {
          choices = JSON.parse(JSON.stringify(TEMPLATES[type]));
          choicesInput.value = choices.map(c => c.text).join('\n');
          syncStateFromChoices();
          showToast(`✓ Template loaded.`);
        }
      });
    });

    // Palette theme selectors
    document.querySelectorAll('.palette-picker-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const palette = target.getAttribute('data-palette')!;
        selectedPalette = palette as keyof typeof PALETTES;
        
        document.querySelectorAll('.palette-picker-btn').forEach(b => {
          b.className = 'palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-hairline';
        });
        target.className = 'palette-picker-btn text-left p-2 rounded-lg border text-[10px] font-bold cursor-pointer transition-all border-primary bg-surface';
        
        drawWheel();
        saveState();
        showToast(`✓ Palette changed to ${palette}`);
      });
    });

    // Tabs navigation logic
    function setTabActive(activeTab: HTMLButtonElement, inactiveTabs: HTMLButtonElement[], paneToShow: HTMLDivElement, panesToHide: HTMLDivElement[]) {
      activeTab.className = 'flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas';
      inactiveTabs.forEach(tab => {
        tab.className = 'flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate';
      });
      paneToShow.classList.remove('hidden');
      panesToHide.forEach(pane => {
        pane.classList.add('hidden');
      });
    }

    tabEditBtn.addEventListener('click', () => {
      setTabActive(tabEditBtn, [tabPresetsBtn, tabSettingsBtn], paneEdit, [panePresets, paneSettings]);
    });
    tabPresetsBtn.addEventListener('click', () => {
      setTabActive(tabPresetsBtn, [tabEditBtn, tabSettingsBtn], panePresets, [paneEdit, paneSettings]);
    });
    tabSettingsBtn.addEventListener('click', () => {
      setTabActive(tabSettingsBtn, [tabEditBtn, tabPresetsBtn], paneSettings, [paneEdit, panePresets]);
    });

    // Handle winner closing
    winnerCloseBtn.addEventListener('click', () => {
      winnerPanel.classList.add('hidden');
      winnerBox.classList.add('scale-90', 'translate-y-4');
      pulseRing.classList.add('animate-ping');
    });

    // Remove item and re-spin
    winnerRemoveBtn.addEventListener('click', () => {
      winnerPanel.classList.add('hidden');
      winnerBox.classList.add('scale-90', 'translate-y-4');
      pulseRing.classList.add('animate-ping');

      const nameToRemove = winnerName.textContent?.trim();
      const removeIndex = choices.findIndex(c => c.text === nameToRemove);
      if (removeIndex !== -1) {
        choices.splice(removeIndex, 1);
        choicesInput.value = choices.map(c => c.text).join('\n');
        syncStateFromChoices();
        showToast(`Removed choice: ${nameToRemove}`);
      }
    });

    // Clear all action with Undo Toast capability
    resetBtn.addEventListener('click', () => {
      if (choices.length > 0) {
        lastClearedChoices = JSON.parse(JSON.stringify(choices));
        fullReset();
        showToast('Wheel choices cleared.', true);
      } else {
        fullReset();
      }
    });

    // Preset save click
    presetSaveBtn.addEventListener('click', savePreset);

    // Copy share link button click
    shareWheelBtn.addEventListener('click', generateShareUrl);

    // Top Share Button click
    const shareBtn = document.getElementById('share-btn');
    shareBtn?.addEventListener('click', () => {
      const config = {
        choices: choices.map(c => [c.text, c.weight]),
        palette: selectedPalette,
        weighted: isWeightedMode
      };

      try {
        const json = JSON.stringify(config);
        const encoded = btoa(unescape(encodeURIComponent(json)));
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set("wheel", encoded);

        const shareData = {
          title: document.title || "Randomizer Wheel",
          url: url.toString()
        };

        if (navigator.share) {
          navigator.share(shareData).catch((err) => {
            if (err.name !== "AbortError") {
              copyToClipboard(url.toString());
            }
          });
        } else {
          copyToClipboard(url.toString());
        }
      } catch (err) {
        showToast('⚠️ Could not generate share URL.');
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Setup spin triggers
    centerSpinBtn.addEventListener('click', () => {
      startSpin();
    });

    // Modal Events
    howItWorksBtn.addEventListener('click', () => {
      howItWorksModal.classList.remove('hidden');
    });

    const hideHowItWorks = () => {
      howItWorksModal.classList.add('hidden');
    };

    closeModalBtn.addEventListener('click', hideHowItWorks);
    modalOkBtn.addEventListener('click', hideHowItWorks);
    howItWorksModal.addEventListener('click', (e) => {
      if (e.target === howItWorksModal) hideHowItWorks();
    });

    // Keyboard accessibility: spacebar/enter triggers spin when focus is on wheel/spin button
    window.addEventListener('keydown', (e) => {
      if (e.code === 'Space' || e.code === 'Enter') {
        const active = document.activeElement;
        const isEditing = active && (active.tagName === 'TEXTAREA' || active.tagName === 'INPUT');
        if (!isEditing && !isSpinningToTarget && !isDragging) {
          e.preventDefault();
          startSpin();
        }
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Lifecycle Init
    window.addEventListener('resize', resizeCanvas);
    
    // Page load init
    loadState();
    resizeCanvas();
    initPhysicsDrag();
  </script>
</Layout>
