---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Text Case Converter";
const category = "developer";
const tier = "Developer & Text Utilities";

// SEO metadata
const pageTitle = "Text Case Converter - Convert Case Online (Free Case Converter Tool)";
const description = "Free client-side Text Case Converter. Convert upper case to lower case, sentence case, title case, camel case, proper case, and more online instantly.";
const keywords = "Text Case Converter, case converter, title case converter, upper case converter, lower case converter, sentence case converter, capital case converter, case converter online, upper case to lower case converter, upper to lower case converter, lower case to upper case converter, online case converter, text case converter, case converter tool, letter case converter, camel case converter, cap case converter, proper case converter, universal case converter, word case converter";
const canonicalUrl = "https://boardtools.app/tools/developer/case-converter";
