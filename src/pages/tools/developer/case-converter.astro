  keywords={keywords}
  canonical={canonicalUrl}
  ogImage="/og/case-converter.png"
  ogType="website"
  hideBanner={true}
>
  <!-- SEO WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Text Case Converter",
      "url": "https://boardtools.app/tools/developer/case-converter",
      "description": "Convert text block casing instantly. Supports common cases (UPPERCASE, lowercase, Title Case, Sentence case) and developer-oriented formats (camelCase, PascalCase, snake_case, kebab-case, CONSTANT_CASE, dot.case) in single or bulk batch modes.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Support for 10 case styles including developer formats",
        "Smart Title Case handling small grammatical words properly",
        "Bulk/Batch processing mode converting line-by-line",
