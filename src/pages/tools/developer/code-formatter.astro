  <script>
    // State management
    interface SnippetHistoryItem {
      id: string;
      lang: string;
      label: string;
      content: string;
      timestamp: number;
    }

    let worker: Worker | null = null;
    let autoFormat = true;
    let selectedLanguage = 'auto';
    let detectedLanguage = 'javascript';
    let formatOptions = {
      printWidth: 80,
      tabWidth: 2,
      useTabs: false,
      semi: true,
      singleQuote: false,
      trailingComma: 'none'
    };

    // DOM References
    const codeInput = document.getElementById('code-input') as HTMLTextAreaElement;
    const inputLineNumbers = document.getElementById('input-line-numbers') as HTMLDivElement;
    const outputCode = document.getElementById('output-code') as HTMLElement;
    const charCounter = document.getElementById('char-counter') as HTMLSpanElement;
    
    // Config panel
    const languageSelect = document.getElementById('language-select') as HTMLSelectElement;
    const detectedBadge = document.getElementById('detected-badge') as HTMLSpanElement;
    const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;
    const quoteSelect = document.getElementById('quote-select') as HTMLSelectElement;
    const semiSelect = document.getElementById('semi-select') as HTMLSelectElement;
    const autoFormatCheck = document.getElementById('auto-format-check') as HTMLInputElement;
    
    // Status boards
    const statusBanner = document.getElementById('status-banner') as HTMLDivElement;
    const statusMsg = document.getElementById('status-msg') as HTMLSpanElement;
    const statusPerf = document.getElementById('status-perf') as HTMLSpanElement;
    const errorTracePanel = document.getElementById('error-trace-panel') as HTMLDivElement;
    const errorBrief = document.getElementById('error-brief') as HTMLSpanElement;
    const errorContext = document.getElementById('error-context') as HTMLPreElement;
    const loadingOverlay = document.getElementById('loading-overlay') as HTMLDivElement;
    const toastMessage = document.getElementById('toast-message') as HTMLDivElement;

    // Actions
    const btnFormat = document.getElementById('btn-format') as HTMLButtonElement;
    const btnClear = document.getElementById('reset-btn') as HTMLButtonElement;
    const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;
    const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;
    const btnShare = document.getElementById('btn-share') as HTMLButtonElement;
    const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
    const dropOverlay = document.getElementById('drop-overlay') as HTMLDivElement;
    const fileUploader = document.getElementById('file-uploader') as HTMLInputElement;
    const historyContainer = document.getElementById('history-container') as HTMLDivElement;

    // Modals & triggers
    const shortcutsBtn = document.getElementById('shortcuts-btn') as HTMLButtonElement;
    const shortcutsModal = document.getElementById('shortcuts-modal') as HTMLDivElement;
    const closeShortcutsBtn = document.getElementById('close-shortcuts-btn') as HTMLButtonElement;
    const howItWorksBtn = document.getElementById('how-it-works-btn');
    const howItWorksModal = document.getElementById('how-it-works-modal');
    const closeModalBtn = document.getElementById('close-modal-btn');
    const modalOkBtn = document.getElementById('modal-ok-btn');

    // Tab items (Mobile toggles)
    const tabInputBtn = document.getElementById('tab-input-btn') as HTMLButtonElement;
    const tabOutputBtn = document.getElementById('tab-output-btn') as HTMLButtonElement;
    const paneInput = document.getElementById('pane-input') as HTMLDivElement;
    const paneOutput = document.getElementById('pane-output') as HTMLDivElement;

    // Sample Snippets
    const SAMPLES = {
      javascript: `// JavaScript / ES6 Sample\nconst calculateStats = (data=[]) => {\n  let sum = 0;\n  for(let i=0;i<data.length;i++){\n    sum += data[i];\n  }\n  const avg = sum / data.length;\n  console.log("Calculated metrics:", { total: sum, average: avg });\n  return {\n    sum,\n    avg\n  }\n};\ncalculateStats([10, 20, 30, 45, 90]);`,
      html: `<!DOCTYPE html>\n<html>\n<head>\n<title>TOOLKIFY Demo Page</title>\n</head>\n<body>\n<main class="container">\n<h1 id="title">Sample Heading</h1>\n<p class="description">Lorem ipsum dolor sit amet,   consectetur adipiscing elit. </p>\n<ul>\n<li>Item 1</li>\n<li>Item 2</li>\n</ul>\n</main>\n</body>\n</html>`,
      css: `/* Layout Stylesheet */\nbody{\nmargin:0;padding:0;font-family:sans-serif;\n}\n.container{\nmax-width:1200px;\nwidth:100%;\nmargin:0 auto;\npadding:20px;\nbackground-color:#f9f9f9;\nborder-radius:8px;\n}`
    };

    // Worker code string
    const workerScript = `
      importScripts(
        'https://unpkg.com/prettier@3.3.3/standalone.js',
        'https://unpkg.com/prettier@3.3.3/plugins/estree.js',
        'https://unpkg.com/prettier@3.3.3/plugins/babel.js',
        'https://unpkg.com/prettier@3.3.3/plugins/html.js',
        'https://unpkg.com/prettier@3.3.3/plugins/postcss.js'
      );

      self.onmessage = async function(e) {
        const { code, language, options } = e.data;
        let parser = 'babel'; // fallback

        if (language === 'json') parser = 'json';
        else if (language === 'javascript' || language === 'js') parser = 'babel';
        else if (language === 'html') parser = 'html';
        else if (language === 'css') parser = 'css';

        try {
          const formatted = await prettier.format(code, {
            parser: parser,
            plugins: prettierPlugins,
            printWidth: options.printWidth,
            tabWidth: options.tabWidth,
            useTabs: options.useTabs,
            semi: options.semi,
            singleQuote: options.singleQuote,
            trailingComma: options.trailingComma
          });
          self.postMessage({ success: true, formatted });
        } catch (error) {
          self.postMessage({ success: false, error: error.message });
        }
      };
    `;

    // Initialize formatting worker
    function initWorker() {
      try {
        loadingOverlay.classList.remove('hidden');
        const blob = new Blob([workerScript], { type: 'application/javascript' });
        worker = new Worker(URL.createObjectURL(blob));
        
        worker.onmessage = function(e) {
          loadingOverlay.classList.add('hidden');
          const { success, formatted, error } = e.data;
          
          if (success) {
            handleFormatSuccess(formatted);
          } else {
            handleFormatError(error);
          }
        };

        worker.onerror = function(e) {
          console.error("Formatting engine worker error:", e);
          loadingOverlay.classList.add('hidden');
          updateBannerStatus('error', 'Formatting engine failed to load — check your connection');
        };
      } catch (err) {
        console.error("Could not spawn background formatter worker:", err);
        updateBannerStatus('error', 'Formatting Engine failed initialization. Local fallback active.');
        loadingOverlay.classList.add('hidden');
      }
    }

    // Initialize application properties and settings
    function init() {
      // Setup Web Worker
      initWorker();

      // Read local storage settings
      const savedLang = localStorage.getItem('bt-cf-lang');
      if (savedLang) {
        languageSelect.value = savedLang;
        selectedLanguage = savedLang;
      }
      const savedIndent = localStorage.getItem('bt-cf-indent');
      if (savedIndent) {
        indentSelect.value = savedIndent;
        formatOptions.tabWidth = savedIndent === 'tabs' ? 2 : Number(savedIndent);
        formatOptions.useTabs = savedIndent === 'tabs';
      }
      const savedQuote = localStorage.getItem('bt-cf-quote');
      if (savedQuote) {
        quoteSelect.value = savedQuote;
        formatOptions.singleQuote = savedQuote === 'single';
      }
      const savedSemi = localStorage.getItem('bt-cf-semi');
      if (savedSemi) {
        semiSelect.value = savedSemi;
        formatOptions.semi = savedSemi === 'true';
      }

      // Check Share URL params
      const urlParams = new URLSearchParams(window.location.search);
      const encodedCode = urlParams.get('code');
      const paramLang = urlParams.get('lang');
      if (encodedCode) {
        try {
          const decoded = atob(encodedCode);
          codeInput.value = decoded;
          if (paramLang) {
            languageSelect.value = paramLang;
            selectedLanguage = paramLang;
          }
          setTimeout(() => triggerFormatting(), 300);
        } catch (err) {
          console.warn("Could not decode share snippet parameter:", err);
        }
      } else {
        // Load default JS sample if workspace is clean
        codeInput.value = SAMPLES.javascript;
      }

      updateLineNumbers();
      updateCounters();
      updateHistoryList();
    }

    // Line counter helper
    function updateLineNumbers() {
      const lines = codeInput.value.split('\n');
      const count = Math.max(lines.length, 1);
      let numberString = '';
      for (let i = 1; i <= count; i++) {
        numberString += i + '<br/>';
      }
      inputLineNumbers.innerHTML = numberString;
    }

    function updateCounters() {
      const len = codeInput.value.length;
      const lines = codeInput.value.split('\n').length;
      charCounter.textContent = `${len} chars | ${lines} lines`;
    }

    // Auto-detect language lexer
    function autoDetectLanguage(code: string): string {
      const trimmed = code.trim();
      if (!trimmed) return 'javascript';
      
      // JSON syntax matches
      if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {
        try {
          JSON.parse(trimmed);
          return 'json';
        } catch (e) {}
      }

      // HTML syntax matches
      if (trimmed.startsWith('<') && (trimmed.includes('</html>') || trimmed.includes('<!DOCTYPE') || trimmed.includes('<div') || trimmed.includes('<body'))) {
        return 'html';
      }

      // CSS syntax matches
      if (trimmed.includes('{') && trimmed.includes('}') && !trimmed.includes('const ') && !trimmed.includes('let ') && !trimmed.includes('function')) {
        const properties = ['margin', 'padding', 'color', 'background', 'border', 'display', 'font'];
        if (properties.some(prop => trimmed.includes(`${prop}:`))) {
          return 'css';
        }
      }

      return 'javascript';
    }

    // Fire formatting request to background Worker
    let debounceTimer: number | null = null;
    function triggerFormatting(isRealtime = false) {
      if (isRealtime && !autoFormat) return;

      const code = codeInput.value;
      if (!code.trim()) {
        updateBannerStatus('idle', 'Ready. Waiting for syntax payload...');
        outputCode.textContent = '';
        errorTracePanel.classList.add('hidden');
        return;
      }

      // Resolve Language choice
      let targetLang = selectedLanguage;
      if (targetLang === 'auto') {
        targetLang = autoDetectLanguage(code);
        detectedLanguage = targetLang;
        detectedBadge.textContent = `Auto: ${targetLang.toUpperCase()}`;
        detectedBadge.classList.remove('hidden');
        detectedBadge.classList.add('inline-flex');
      } else {
        detectedBadge.classList.add('hidden');
        detectedBadge.classList.remove('inline-flex');
      }

      updateBannerStatus('idle', 'Beautifying...');

      if (worker) {
        worker.postMessage({
          code,
          language: targetLang,
          options: formatOptions
        });
      } else {
        // Simple client side JSON format fallback if worker isn't loaded
        if (targetLang === 'json') {
          try {
            const parsed = JSON.parse(code);
            const spaces = formatOptions.useTabs ? '\t' : formatOptions.tabWidth;
            const res = JSON.stringify(parsed, null, spaces);
            handleFormatSuccess(res);
          } catch (e: any) {
            handleFormatError(e.message);
          }
        } else {
          updateBannerStatus('error', 'Browser Worker sandbox inactive. Manual formatting trigger needed.');
        }
      }
    }

    function handleFormatSuccess(formattedCode: string) {
      outputCode.className = `language-${selectedLanguage === 'auto' ? detectedLanguage : selectedLanguage}`;
      outputCode.textContent = formattedCode;
      
      // Perform code syntax coloring via Prism
      if ((window as any).Prism) {
        (window as any).Prism.highlightElement(outputCode);
      }

      updateBannerStatus('success', '✓ Format Successful');
      errorTracePanel.classList.add('hidden');
      
      // Save valid snippet to local history
      saveSnippetToHistory(codeInput.value);
      
      // Trigger settle fade animation on result block
      const resultContainer = outputCode.parentElement?.parentElement;
      if (resultContainer) {
        resultContainer.classList.add('animate-settle');
        setTimeout(() => resultContainer.classList.remove('animate-settle'), 600);
      }
    }

    function handleFormatError(error: string) {
      updateBannerStatus('error', '✗ Syntax/Validation Error');
      errorBrief.textContent = error;
      errorTracePanel.classList.remove('hidden');
      
      // Shake animation trigger
      errorTracePanel.classList.add('animate-shake');
      setTimeout(() => errorTracePanel.classList.remove('animate-shake'), 500);

      // Attempt context tracing
      const rawText = codeInput.value;
      const lines = rawText.split('\n');
      let targetLine = -1;
      let targetCol = -1;

      // Extract error position numbers: e.g. "at line 3, column 5" or "Unexpected token (4:12)"
      const parseMatches = error.match(/\((\d+):(\d+)\)/);
      const positionMatches = error.match(/line (\d+) column (\d+)/i);
      
      if (parseMatches) {
        targetLine = Number(parseMatches[1]);
        targetCol = Number(parseMatches[2]);
      } else if (positionMatches) {
        targetLine = Number(positionMatches[1]);
        targetCol = Number(positionMatches[2]);
      }

      if (targetLine > 0 && targetLine <= lines.length) {
        const start = Math.max(1, targetLine - 2);
        const end = Math.min(lines.length, targetLine + 2);
        let contextStr = '';
        for (let i = start; i <= end; i++) {
          const lineText = lines[i - 1];
          const isErrorLine = i === targetLine;
          const prefix = isErrorLine ? ' > ' : '   ';
          contextStr += `${prefix}${String(i).padStart(4)} | ${lineText}\n`;
          if (isErrorLine && targetCol > 0) {
            contextStr += `${' '.repeat(targetCol + 9)}^\n`;
          }
        }
        errorContext.textContent = contextStr;
      } else {
        errorContext.textContent = "Could not map exact location context. Verify line structures.";
      }
    }

    function updateBannerStatus(type: 'idle' | 'success' | 'error', msg: string) {
      statusBanner.className = `p-2.5 rounded-lg border flex items-center justify-between text-[11px] transition-all duration-300`;
      
      if (type === 'idle') {
        statusBanner.classList.add('bg-surface-yellow', 'border-yellow-light/80', 'text-yellow-dark');
        statusMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-yellow-dark animate-pulse"></span> ${msg}`;
        statusPerf.textContent = '';
      } else if (type === 'success') {
        statusBanner.classList.add('bg-success-accent/15', 'border-success-accent/40', 'text-moss-dark');
        statusMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-success-accent"></span> ${msg}`;
        statusPerf.textContent = `${formatBytes(codeInput.value.length)}`;
      } else if (type === 'error') {
        statusBanner.classList.add('bg-brand-red', 'border-brand-red-dark/30', 'text-coral-dark');
        statusMsg.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-brand-red-dark"></span> ${msg}`;
        statusPerf.textContent = '';
      }
    }

    function formatBytes(bytes: number): string {
      if (bytes === 0) return '0 B';
      const k = 1024;
      const sizes = ['B', 'KB', 'MB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }

    // Input Text Event listeners
    codeInput.addEventListener('input', () => {
      updateLineNumbers();
      updateCounters();
      
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        triggerFormatting(true);
      }, 400);
    });

    codeInput.addEventListener('scroll', () => {
      inputLineNumbers.scrollTop = codeInput.scrollTop;
    });

    // Control options events
    languageSelect.addEventListener('change', () => {
      selectedLanguage = languageSelect.value;
      localStorage.setItem('bt-cf-lang', selectedLanguage);
      triggerFormatting();
    });

    indentSelect.addEventListener('change', () => {
      const val = indentSelect.value;
      formatOptions.tabWidth = val === 'tabs' ? 2 : Number(val);
      formatOptions.useTabs = val === 'tabs';
      localStorage.setItem('bt-cf-indent', val);
      triggerFormatting();
    });

    quoteSelect.addEventListener('change', () => {
      const val = quoteSelect.value;
      formatOptions.singleQuote = val === 'single';
      localStorage.setItem('bt-cf-quote', val);
      triggerFormatting();
    });

    semiSelect.addEventListener('change', () => {
      const val = semiSelect.value;
      formatOptions.semi = val === 'true';
      localStorage.setItem('bt-cf-semi', val);
      triggerFormatting();
    });

    autoFormatCheck.addEventListener('change', () => {
      autoFormat = autoFormatCheck.checked;
      if (autoFormat) triggerFormatting();
    });

    // Load static samples
    document.getElementById('btn-load-js')?.addEventListener('click', () => {
      codeInput.value = SAMPLES.javascript;
      languageSelect.value = 'javascript';
      selectedLanguage = 'javascript';
      updateLineNumbers();
      updateCounters();
      triggerFormatting();
    });

    document.getElementById('btn-load-html')?.addEventListener('click', () => {
      codeInput.value = SAMPLES.html;
      languageSelect.value = 'html';
      selectedLanguage = 'html';
      updateLineNumbers();
      updateCounters();
      triggerFormatting();
    });

    document.getElementById('btn-load-css')?.addEventListener('click', () => {
      codeInput.value = SAMPLES.css;
      languageSelect.value = 'css';
      selectedLanguage = 'css';
      updateLineNumbers();
      updateCounters();
      triggerFormatting();
    });

    // Trigger buttons
    btnFormat.addEventListener('click', () => {
      triggerFormatting();
      btnFormat.classList.add('scale-95');
      setTimeout(() => btnFormat.classList.remove('scale-95'), 150);
    });

    btnClear.addEventListener('click', () => {
      codeInput.value = '';
      outputCode.textContent = '';
      updateLineNumbers();
      updateCounters();
      updateBannerStatus('idle', 'Ready. Waiting for syntax payload...');
      errorTracePanel.classList.add('hidden');
    });

    // Clipboard and Actions copy
    btnCopy.addEventListener('click', () => {
      const text = outputCode.textContent || codeInput.value;
      if (!text.trim()) return;

      navigator.clipboard.writeText(text).then(() => {
        showToast('✓ Copied Code');
        // Pulse animation effect
        btnCopy.classList.add('bg-success-accent/15', 'text-moss-dark', 'scale-105');
        setTimeout(() => {
          btnCopy.classList.remove('bg-success-accent/15', 'text-moss-dark', 'scale-105');
        }, 1000);
      });
    });

    // File downloader
    btnDownload.addEventListener('click', () => {
      const text = outputCode.textContent || codeInput.value;
      if (!text.trim()) return;

      let ext = 'js';
      const lang = selectedLanguage === 'auto' ? detectedLanguage : selectedLanguage;
      if (lang === 'html') ext = 'html';
      else if (lang === 'css') ext = 'css';
      else if (lang === 'json') ext = 'json';

      const blob = new Blob([text], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `formatted_code.${ext}`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      showToast('✓ Downloading Code File');
    });

    // Share state link URL helper
    btnShare.addEventListener('click', () => {
      const code = codeInput.value.trim();
      if (!code) return;

      try {
        const base = btoa(code);
        const lang = selectedLanguage === 'auto' ? detectedLanguage : selectedLanguage;
        const shareUrl = `${window.location.origin}${window.location.pathname}?code=${base}&lang=${lang}`;
        
        navigator.clipboard.writeText(shareUrl).then(() => {
          showToast('✓ Share URL copied to Clipboard');
        });
      } catch (err) {
        showToast('⚠️ Could not generate share URL');
      }
    });

    // Top Share Button Event
    const shareBtn = document.getElementById('share-btn');
    shareBtn?.addEventListener('click', () => {
      const code = codeInput.value.trim();
      if (!code) return;

      try {
        const base = btoa(code);
        const lang = selectedLanguage === 'auto' ? detectedLanguage : selectedLanguage;
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set("code", base);
        url.searchParams.set("lang", lang);

        const shareData = {
          title: document.title || "Code Formatter",
          url: url.toString()
        };

        if (navigator.share) {
          navigator.share(shareData).catch((err) => {
            if (err.name !== "AbortError") {
              copyToClipboard(url.toString());
            }
          });
        } else {
          copyToClipboard(url.toString());
        }
      } catch (err) {
        showToast('⚠️ Could not generate share URL');
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    function showToast(msg: string) {
      toastMessage.textContent = msg;
      toastMessage.classList.remove('opacity-0');
      toastMessage.classList.add('opacity-100');
      setTimeout(() => {
        toastMessage.classList.remove('opacity-100');
        toastMessage.classList.add('opacity-0');
      }, 2000);
    }

    // Drag and Drop Upload file logic
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropOverlay.classList.remove('opacity-0');
      dropOverlay.classList.add('opacity-100');
    });

    dropZone.addEventListener('dragleave', () => {
      dropOverlay.classList.remove('opacity-100');
      dropOverlay.classList.add('opacity-0');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropOverlay.classList.remove('opacity-100');
      dropOverlay.classList.add('opacity-0');
      
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) {
        handleUploadedFile(files[0]);
      }
    });

    fileUploader.addEventListener('change', () => {
      const files = fileUploader.files;
      if (files && files.length > 0) {
        handleUploadedFile(files[0]);
      }
    });

    function handleUploadedFile(file: File) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const text = e.target?.result as string;
        codeInput.value = text;
        
        // Auto-detect upload language mapping
        const nameLower = file.name.toLowerCase();
        if (nameLower.endsWith('.js') || nameLower.endsWith('.jsx')) {
          languageSelect.value = 'javascript';
        } else if (nameLower.endsWith('.html') || nameLower.endsWith('.htm')) {
          languageSelect.value = 'html';
        } else if (nameLower.endsWith('.css')) {
          languageSelect.value = 'css';
        } else if (nameLower.endsWith('.json')) {
          languageSelect.value = 'json';
        } else {
          languageSelect.value = 'auto';
        }
        
        selectedLanguage = languageSelect.value;
        updateLineNumbers();
        updateCounters();
        triggerFormatting();
      };
      reader.readAsText(file);
    }

    // Local Storage History Manager
    function saveSnippetToHistory(content: string) {
      try {
        const key = 'bt-cf-history';
        const rawHistory = localStorage.getItem(key);
        let history: SnippetHistoryItem[] = rawHistory ? JSON.parse(rawHistory) : [];

        // Avoid duplications
        if (history.length > 0 && history[0].content === content) return;

        const summary = content.substring(0, 30).replace(/\s+/g, ' ') + (content.length > 30 ? '...' : '');
        const item: SnippetHistoryItem = {
          id: Math.random().toString(36).substring(2, 9),
          lang: selectedLanguage === 'auto' ? detectedLanguage : selectedLanguage,
          label: summary,
          content,
          timestamp: Date.now()
        };

        history.unshift(item);
        if (history.length > 5) {
          history = history.slice(0, 5);
        }

        localStorage.setItem(key, JSON.stringify(history));
        updateHistoryList();
      } catch (err) {}
    }

    // Populate history panel list
    function updateHistoryList() {
      try {
        const key = 'bt-cf-history';
        const rawHistory = localStorage.getItem(key);
        if (!rawHistory) return;
        
        const history: SnippetHistoryItem[] = JSON.parse(rawHistory);
        if (history.length === 0) return;

        historyContainer.innerHTML = '';
        history.forEach((item) => {
          const btn = document.createElement('button');
          btn.className = 'inline-flex items-center gap-1.5 text-[10px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline hover:border-brand-blue rounded-full transition-all cursor-pointer truncate max-w-[200px] text-slate hover:text-primary';
          btn.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-brand-teal"></span> ${item.label}`;
          btn.title = `Format cached ${item.lang.toUpperCase()} snippet`;
          
          btn.addEventListener('click', () => {
            codeInput.value = item.content;
            languageSelect.value = item.lang;
            selectedLanguage = item.lang;
            updateLineNumbers();
            updateCounters();
            triggerFormatting();
          });
          historyContainer.appendChild(btn);
        });
      } catch (err) {}
    }

    // Mobile navigation switcher tabs
    tabInputBtn.addEventListener('click', () => {
      paneInput.classList.remove('hidden');
      paneOutput.classList.add('hidden');
      tabInputBtn.className = "flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabOutputBtn.className = "flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate";
    });

    tabOutputBtn.addEventListener('click', () => {
      paneInput.classList.add('hidden');
      paneOutput.classList.remove('hidden');
      paneOutput.classList.add('flex');
      tabOutputBtn.className = "flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas";
      tabInputBtn.className = "flex-1 text-center text-[11px] py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate";
    });

    // Keyboard Shortcuts Dialog
    shortcutsBtn?.addEventListener('click', () => {
      shortcutsModal?.classList.remove('hidden');
    });

    closeShortcutsBtn?.addEventListener('click', () => {
      shortcutsModal?.classList.add('hidden');
    });

    shortcutsModal?.addEventListener('click', (e) => {
      if (e.target === shortcutsModal) {
        shortcutsModal?.classList.add('hidden');
      }
    });

    // How it works modal interactions
    howItWorksBtn?.addEventListener('click', () => {
      howItWorksModal?.classList.remove('hidden');
    });
    closeModalBtn?.addEventListener('click', () => {
      howItWorksModal?.classList.add('hidden');
    });
    modalOkBtn?.addEventListener('click', () => {
      howItWorksModal?.classList.add('hidden');
    });
    howItWorksModal?.addEventListener('click', (e) => {
      if (e.target === howItWorksModal) {
        howItWorksModal?.classList.add('hidden');
      }
    });

    // Keyboard Hotkey handler
    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey && e.key === 'Enter') {
        e.preventDefault();
        triggerFormatting();
      } else if (e.ctrlKey && e.key === 'Escape') {
        e.preventDefault();
        btnClear.click();
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Execute page scripts
    init();
  </script>

  <!-- Prism styling overrides and Custom Animations -->
  <style is:global>
    /* Settle animation */
    @keyframes settleIn {
      0% { opacity: 0.6; transform: scale(0.995); }
      100% { opacity: 1; transform: scale(1); }
    }
    .animate-settle {
      animation: settleIn 0.4s ease-out forwards;
    }

    /* Error Shake animation */
    @keyframes shakeError {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-4px); }
      40%, 80% { transform: translateX(4px); }
    }
    .animate-shake {
      animation: shakeError 0.4s ease-in-out;
    }

    /* Prism.js Miro aesthetic theme overrides */
    pre code[class*="language-"] {
      color: #1c1c1e !important;
      text-shadow: none !important;
    }
    .token.comment,
    .token.prolog,
    .token.doctype,
    .token.cdata {
      color: #8e91a0 !important;
      font-style: italic;
    }
    .token.punctuation {
      color: #2c2c34 !important;
    }
    .token.property,
    .token.tag,
    .token.boolean,
    .token.number,
    .token.constant,
    .token.symbol,
    .token.deleted {
      color: #ff9999 !important; /* Coral tag style */
      font-weight: 600;
    }
    .token.selector,
    .token.attr-name,
    .token.string,
    .token.char,
    .token.builtin,
    .token.inserted {
      color: #0fbcb0 !important; /* Teal accent styles */
    }
    .token.operator,
    .token.entity,
    .token.url,
    .language-css .token.string,
    .style .token.string {
      color: #5b76fe !important;
    }
    .token.atrule,
    .token.attr-value,
    .token.keyword {
      color: #4262ff !important; /* Action Blue */
      font-weight: 500;
    }
    .token.function,
    .token.class-name {
      color: #1c1c1e !important;
      font-weight: 600;
    }
    .token.regex,
    .token.important,
    .token.variable {
      color: #e3c5c5 !important;
    }
  </style>
</Layout>
