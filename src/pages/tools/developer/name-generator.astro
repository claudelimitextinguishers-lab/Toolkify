---
import Layout from "../../../layouts/Layout.astro";

// Tool metadata
const name = "Name & Username Generator";
const category = "developer";
const tier = "Developer & Text Utilities";
const description =
  "Generate creative character names, brand/business names, and custom usernames with rich category filters, locks, and persistent favorites.";
const keywords =
  "name generator, username generator, business name generator, fantasy name generator, brand name generator, gamertag generator, character name generator, writer tools";
const canonicalUrl = "https://boardtools.app/tools/developer/name-generator";
---

<Layout
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
>
  <!-- SEO Structured Data Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Name & Username Generator",
      "url": "https://boardtools.app/tools/developer/name-generator",
      "description": "Procedurally generate creative, distinct names for fictional characters, brands/businesses, and social/gaming profiles. Lock favorite slots, shuffle options, and save persistent favorites list locally.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Multiple categories: Fictional Characters, Business/Brand Names, Usernames",
        "Deep filters: Gender, cultural origins, fantasy genres, brand styles, length, custom prefixes/suffixes",
        "Bulk generation: 10 or 20 names rendered instantly in scannable grids",
        "Individual locking: lock a slot to preserve names between global regenerations",
        "Individual slot shuffling: shuffle a single unlocked name",
        "Persistent favorites list saved to localStorage",
        "Export favorites as clean .txt or .csv files",
        "100% private client-side logic running entirely in the browser"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <style>
    /* Custom animations for the Name Generator */
    @keyframes fadeInUpStaggered {
      from {
        opacity: 0;
        transform: translateY(8px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes spinShuffle {
      0% {
        transform: rotate(0deg);
      }
      100% {
        transform: rotate(360deg);
      }
    }

    @keyframes lockPop {
      0% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.25);
      }
      100% {
        transform: scale(1);
      }
    }

    .animate-shuffle-spin {
      animation: spinShuffle 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    .animate-lock-pop {
      animation: lockPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    /* Staggered load animation delays */
    .stagger-item-0 {
      animation: fadeInUpStaggered 0.25s ease-out forwards;
    }
    .stagger-item-1 {
      animation: fadeInUpStaggered 0.25s ease-out 0.03s forwards;
      opacity: 0;
    }
    .stagger-item-2 {
      animation: fadeInUpStaggered 0.25s ease-out 0.06s forwards;
      opacity: 0;
    }
    .stagger-item-3 {
      animation: fadeInUpStaggered 0.25s ease-out 0.09s forwards;
      opacity: 0;
    }
    .stagger-item-4 {
      animation: fadeInUpStaggered 0.25s ease-out 0.12s forwards;
      opacity: 0;
    }
    .stagger-item-5 {
      animation: fadeInUpStaggered 0.25s ease-out 0.15s forwards;
      opacity: 0;
    }
    .stagger-item-6 {
      animation: fadeInUpStaggered 0.25s ease-out 0.18s forwards;
      opacity: 0;
    }
    .stagger-item-7 {
      animation: fadeInUpStaggered 0.25s ease-out 0.21s forwards;
      opacity: 0;
    }
    .stagger-item-8 {
      animation: fadeInUpStaggered 0.25s ease-out 0.24s forwards;
      opacity: 0;
    }
    .stagger-item-9 {
      animation: fadeInUpStaggered 0.25s ease-out 0.27s forwards;
      opacity: 0;
    }
    .stagger-item-10 {
      animation: fadeInUpStaggered 0.25s ease-out 0.3s forwards;
      opacity: 0;
    }
    .stagger-item-11 {
      animation: fadeInUpStaggered 0.25s ease-out 0.33s forwards;
      opacity: 0;
    }
    .stagger-item-12 {
      animation: fadeInUpStaggered 0.25s ease-out 0.36s forwards;
      opacity: 0;
    }
    .stagger-item-13 {
      animation: fadeInUpStaggered 0.25s ease-out 0.39s forwards;
      opacity: 0;
    }
    .stagger-item-14 {
      animation: fadeInUpStaggered 0.25s ease-out 0.42s forwards;
      opacity: 0;
    }
    .stagger-item-15 {
      animation: fadeInUpStaggered 0.25s ease-out 0.45s forwards;
      opacity: 0;
    }
    .stagger-item-16 {
      animation: fadeInUpStaggered 0.25s ease-out 0.48s forwards;
      opacity: 0;
    }
    .stagger-item-17 {
      animation: fadeInUpStaggered 0.25s ease-out 0.51s forwards;
      opacity: 0;
    }
    .stagger-item-18 {
      animation: fadeInUpStaggered 0.25s ease-out 0.54s forwards;
      opacity: 0;
    }
    .stagger-item-19 {
      animation: fadeInUpStaggered 0.25s ease-out 0.57s forwards;
      opacity: 0;
    }
  </style>

  <section
    class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-8 md:py-12 flex flex-col gap-6 animate-fade-in-up"
  >
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav
        class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mt-1"
      >
        <div class="flex items-center gap-3 flex-wrap">
          <h1
            class="font-display font-medium text-3xl sm:text-4xl tracking-tight text-primary"
          >
            {name}
          </h1>
          <span
            class="badge-tag-purple bg-surface-pricing-featured text-brand-blue text-[10px] py-1 px-3.5 rounded-full font-semibold uppercase whitespace-nowrap"
            >{tier}</span
          >
        </div>

        <div class="flex items-center gap-2 self-start sm:self-auto flex-wrap">
          <button
            type="button"
            id="generate-top-btn"
            class="button-primary inline-flex items-center gap-1.5 text-[11px] font-semibold px-3 py-1.5 !rounded-full hover:scale-105 active:scale-95 transition-all cursor-pointer shadow-subtle"
            aria-label="Generate names"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"
              ></path>
            </svg>
            <span>Generate</span>
          </button>

          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How name generator works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-all-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Clear all options and locks"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
      <p class="text-sm text-slate max-w-xl leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Category Selector Tabs -->
    <div class="flex rounded-full bg-surface p-0.5 sm:p-1 border border-hairline w-full max-w-lg shadow-subtle">
      <button
        type="button"
        id="tab-char-btn"
        class="flex-1 text-center text-[10px] sm:text-xs py-1.5 sm:py-2 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
        role="tab"
        aria-selected="true"
      >
        <span class="hidden sm:inline">Character Names</span>
        <span class="inline sm:hidden">Characters</span>
      </button>
      <button
        type="button"
        id="tab-brand-btn"
        class="flex-1 text-center text-[10px] sm:text-xs py-1.5 sm:py-2 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-ink"
        role="tab"
        aria-selected="false"
      >
        <span class="hidden sm:inline">Brands & Businesses</span>
        <span class="inline sm:hidden">Brands</span>
      </button>
      <button
        type="button"
        id="tab-user-btn"
        class="flex-1 text-center text-[10px] sm:text-xs py-1.5 sm:py-2 rounded-full font-bold transition-all cursor-pointer text-slate hover:text-ink"
        role="tab"
        aria-selected="false"
      >
        <span class="hidden sm:inline">Usernames & Profiles</span>
        <span class="inline sm:hidden">Usernames</span>
      </button>
    </div>

    <!-- Main Workspace Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
      <!-- LEFT COLUMN: Filters / Configuration Sidebar -->
      <div class="lg:col-span-4 flex flex-col gap-6 order-2 lg:order-1">
        <div
          class="card-base bg-surface-soft border border-hairline-strong flex flex-col gap-5 relative overflow-hidden"
        >
          <div
            class="absolute inset-0 dot-grid opacity-[0.03] pointer-events-none"
          >
          </div>

          <div class="flex items-center gap-2 relative z-10">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-yellow"></span>
            <h2 class="font-display font-medium text-sm text-primary">
              Generator Options
            </h2>
          </div>

          <!-- Configuration Panel Form -->
          <form
            id="generator-options-form"
            class="flex flex-col gap-4 relative z-10"
            onsubmit="event.preventDefault();"
          >
            <!-- Dynamic Category Filter Blocks -->
            <!-- 1. Character Filter Group -->
            <div id="filter-group-char" class="flex flex-col gap-4">
              <div class="flex flex-col gap-1.5">
                <label
                  for="char-genre"
                  class="text-[10px] font-bold text-slate uppercase"
                  >Character Genre / Race</label
                >
                <select
                  id="char-genre"
                  class="text-input py-1.5 px-3 text-xs h-10 cursor-pointer border border-hairline-strong bg-canvas rounded-md w-full"
                >
                  <optgroup label="Fantasy Races">
                    <option value="elf" selected>Elf (Ethereal & Poetic)</option
                    >
                    <option value="dwarf">Dwarf (Rugged & Runed)</option>
                    <option value="orc">Orc (Harsh & Powerful)</option>
                    <option value="noble">Noble / Medieval Human</option>
                  </optgroup>
                  <optgroup label="Sci-Fi / Cyberpunk">
                    <option value="space-alien"
                      >Alien (Futuristic Syllables)</option
                    >
                    <option value="cyber-space"
                      >Space/Cyber (Tech & Neo-Noir)</option
                    >
                    <option value="cyborg">Cyborg (Numerical Code-Names)</option
                    >
                  </optgroup>
                  <optgroup label="Real-World Cultures">
                    <option value="culture-english">English / Anglo</option>
                    <option value="culture-norse">Norse / Scandinavian</option>
                    <option value="culture-celtic">Celtic / Gaelic</option>
                    <option value="culture-japanese">Japanese</option>
                    <option value="culture-hispanic">Hispanic / Spanish</option>
                  </optgroup>
                </select>
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="text-[10px] font-bold text-slate uppercase"
                  >Name Style / Gender</label
                >
                <div class="flex gap-2">
                  <label
                    class="flex-1 flex items-center justify-center gap-1.5 py-2 border border-hairline-strong bg-canvas rounded-lg text-xs font-semibold cursor-pointer text-slate hover:text-primary"
                  >
                    <input
                      type="radio"
                      name="char-gender"
                      value="male"
                      class="sr-only"
                    />
                    <span>Male</span>
                  </label>
                  <label
                    class="flex-1 flex items-center justify-center gap-1.5 py-2 border border-hairline-strong bg-canvas rounded-lg text-xs font-semibold cursor-pointer text-slate hover:text-primary"
                  >
                    <input
                      type="radio"
                      name="char-gender"
                      value="female"
                      class="sr-only"
                    />
                    <span>Female</span>
                  </label>
                  <label
                    class="flex-1 flex items-center justify-center gap-1.5 py-2 border border-primary bg-primary text-canvas rounded-lg text-xs font-semibold cursor-pointer"
                  >
                    <input
                      type="radio"
                      name="char-gender"
                      value="neutral"
                      class="sr-only"
                      checked
                    />
                    <span>Neutral</span>
                  </label>
                </div>
              </div>
            </div>

            <!-- 2. Business/Brand Filter Group (Hidden initially) -->
            <div id="filter-group-brand" class="hidden flex flex-col gap-4">
              <div class="flex flex-col gap-1.5">
                <label
                  for="brand-industry"
                  class="text-[10px] font-bold text-slate uppercase"
                  >Industry Theme</label
                >
                <select
                  id="brand-industry"
                  class="text-input py-1.5 px-3 text-xs h-10 cursor-pointer border border-hairline-strong bg-canvas rounded-md w-full"
                >
                  <option value="tech" selected
                    >Technology / Software / AI</option
                  >
                  <option value="creative">Creative Studio / Agency</option>
                  <option value="finance">Finance / Consulting / Trust</option>
                  <option value="health"
                    >Health / Wellness / Life Science</option
                  >
                </select>
              </div>

              <div class="flex flex-col gap-1.5">
                <label
                  for="brand-style"
                  class="text-[10px] font-bold text-slate uppercase"
                  >Brand Name Style</label
                >
                <select
                  id="brand-style"
                  class="text-input py-1.5 px-3 text-xs h-10 cursor-pointer border border-hairline-strong bg-canvas rounded-md w-full"
                >
                  <option value="modern" selected
                    >Modern & Coined (e.g., Apexify)</option
                  >
                  <option value="playful"
                    >Playful Compounds (e.g., BytePanda)</option
                  >
                  <option value="professional"
                    >Corporate Classic (e.g., Prime Group)</option
                  >
                </select>
              </div>

              <div class="flex flex-col gap-1.5">
                <label
                  for="brand-keyword"
                  class="text-[10px] font-bold text-slate uppercase"
                  >Custom Keyword Seed (Optional)</label
                >
                <input
                  type="text"
                  id="brand-keyword"
                  placeholder="e.g. cloud, smart, wave"
                  maxlength="15"
                  class="text-input text-xs h-10 px-3 border border-hairline-strong bg-canvas rounded-md w-full outline-none"
                />
              </div>
            </div>

            <!-- 3. Username/Profile Filter Group (Hidden initially) -->
            <div id="filter-group-user" class="hidden flex flex-col gap-4">
              <div class="flex flex-col gap-1.5">
                <label
                  for="user-theme"
                  class="text-[10px] font-bold text-slate uppercase"
                  >Profile Theme</label
                >
                <select
                  id="user-theme"
                  class="text-input py-1.5 px-3 text-xs h-10 cursor-pointer border border-hairline-strong bg-canvas rounded-md w-full"
                >
                  <option value="gaming" selected>Gaming / Clan Tags</option>
                  <option value="tech">Tech / Developer</option>
                  <option value="fantasy">Fantasy / Magic</option>
                  <option value="aesthetic">Minimal / Aesthetic</option>
                </select>
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="text-[10px] font-bold text-slate uppercase"
                  >Addons & Structure</label
                >
                <div class="flex flex-col gap-2.5 mt-1">
                  <label
                    class="flex items-center gap-2 text-xs text-slate cursor-pointer"
                  >
                    <input
                      type="checkbox"
                      id="user-nums"
                      class="w-4 h-4 rounded border-hairline-strong text-brand-blue"
                      checked
                    />
                    <span>Include Numbers (e.g., _99, 404)</span>
                  </label>
                  <label
                    class="flex items-center gap-2 text-xs text-slate cursor-pointer"
                  >
                    <input
                      type="checkbox"
                      id="user-chars"
                      class="w-4 h-4 rounded border-hairline-strong text-brand-blue"
                    />
                    <span>Include Special Symbols (., _, xX)</span>
                  </label>
                </div>
              </div>
            </div>

            <!-- Global Quantity Selector -->
            <div class="flex flex-col gap-1.5 pt-2 border-t border-hairline">
              <label
                for="names-qty"
                class="text-[10px] font-bold text-slate uppercase"
                >Names to Generate</label
              >
              <div class="flex gap-2">
                <button
                  type="button"
                  data-qty="10"
                  class="btn-qty flex-1 py-1.5 border border-primary bg-primary text-canvas text-xs font-semibold rounded-full cursor-pointer transition-all"
                >
                  10 Names
                </button>
                <button
                  type="button"
                  data-qty="20"
                  class="btn-qty flex-1 py-1.5 border border-hairline-strong bg-canvas text-slate text-xs font-semibold rounded-full cursor-pointer hover:text-primary hover:border-primary transition-all"
                >
                  20 Names
                </button>
              </div>
            </div>

            <!-- MAIN CTA Button -->
            <button
              type="button"
              id="generate-btn"
              class="button-primary w-full h-11 text-sm font-semibold tracking-wide shadow-card cursor-pointer hover:button-primary-active mt-2"
            >
              Generate Names
            </button>
          </form>
        </div>

        <!-- Privacy & Local Execution Notice -->
        <div
          class="card-feature-teal hidden lg:flex flex-col gap-2 relative overflow-hidden"
        >
          <span
            class="badge-tag-yellow bg-teal-light text-moss-dark self-start text-[10px]"
            >LOCAL SANDBOX</span
          >
          <h3 class="font-display font-semibold text-sm text-primary">
            Private Generation
          </h3>
          <p class="text-xs text-moss-dark/85 leading-relaxed">
            All name-generation combinatorial math is computed locally in your
            browser. None of your keywords, filters, or saved names are sent to
            any external server.
          </p>
        </div>
      </div>

      <!-- RIGHT COLUMN: Output Workspace / Result Grid & Favorites Drawer -->
      <div class="lg:col-span-8 flex flex-col gap-6 order-1 lg:order-2">
        <!-- Results Container Card -->
        <div
          class="card-base flex flex-col gap-4 relative overflow-hidden min-h-[400px]"
        >
          <div
            class="absolute inset-0 dot-grid opacity-[0.02] pointer-events-none"
          >
          </div>

          <!-- Result Header Controls -->
          <div
            class="flex justify-between items-center border-b border-hairline pb-3 relative z-10 flex-wrap gap-2"
          >
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
              <h3 class="font-display font-medium text-sm text-primary">
                Generated Options
              </h3>
              <span
                id="results-count"
                class="text-[10px] bg-surface font-bold text-slate px-2 py-0.5 rounded-full"
                >10 total</span
              >
            </div>

            <div class="flex gap-2">
              <button
                type="button"
                id="lock-all-btn"
                class="text-[10px] font-bold text-slate hover:text-primary flex items-center gap-1 px-2.5 py-1 bg-surface rounded-full border border-hairline cursor-pointer transition-all"
                title="Lock all current names"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-3 h-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                  ></path>
                </svg>
                Lock All
              </button>
              <button
                type="button"
                id="unlock-all-btn"
                class="text-[10px] font-bold text-slate hover:text-primary flex items-center gap-1 px-2.5 py-1 bg-surface rounded-full border border-hairline cursor-pointer transition-all"
                title="Unlock all slots"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-3 h-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"
                  ></path>
                </svg>
                Unlock All
              </button>
            </div>
          </div>

          <!-- Name List Grid -->
          <div
            id="names-grid"
            class="grid grid-cols-1 sm:grid-cols-2 gap-3 relative z-10"
          >
            <!-- Dynamically populated name cards -->
          </div>

          <!-- Empty State (Fallback) -->
          <div
            id="names-empty-state"
