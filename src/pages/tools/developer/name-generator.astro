          "Fire_",
          "Storm_",
          "Myth_",
        ],
        aesthetic: [
          "soft.",
          "dreamy_",
          "ethereal.",
          "cozy_",
          "silent_",
          "pale_",
          "golden_",
          "velvet_",
        ],
      },
      nouns: {
        gaming: [
          "Viper",
          "Phantom",
          "Rogue",
          "Titan",
          "Wraith",
          "Spectre",
          "Glitch",
          "Kombat",
          "Frag",
          "Beast",
          "Reaper",
        ],
        tech: [
          "Byte",
          "Compiler",
          "SaaS",
          "Syntax",
          "Logic",
          "Vector",
          "Node",
          "Kernel",
          "Script",
          "Cyber",
          "Daemon",
        ],
        fantasy: [
          "Knight",
          "Sorcerer",
          "Grier",
          "Gnome",
          "Pixie",
          "Fae",
          "Brier",
          "Phoenix",
          "Centaur",
          "Wyvern",
          "Golem",
        ],
        aesthetic: [
          "moss",
          "rain",
          "veil",
          "dusk",
          "dawn",
          "cloud",
          "bloom",
          "haze",
          "mist",
          "dew",
          "fern",
        ],
      },
    },
  };

  // Helper function to pick a random array item
  const randomPick = (arr: string[]) =>
    arr[Math.floor(Math.random() * arr.length)];

  // State Management
  let activeTab = "char"; // "char", "brand", "user"
  let quantity = 10;
  let generatedNames: { name: string; locked: boolean }[] = [];
  let favorites: string[] = [];

  // ==================== PROCEDURAL GENERATOR LOGIC ====================

  function generateName(category: string, filters: any): string {
    switch (category) {
      case "char": {
        const genre = filters.genre;
        const gender = filters.gender;

        if (genre === "elf") {
          const pref = randomPick(DATASET.elf.prefixes);
          const inf = randomPick(DATASET.elf.infixes);
          const suff =
            gender === "male"
              ? randomPick(DATASET.elf.suffixesMale)
              : gender === "female"
                ? randomPick(DATASET.elf.suffixesFemale)
                : randomPick([
                    ...DATASET.elf.suffixesMale,
                    ...DATASET.elf.suffixesFemale,
                  ]);

          const firstName = pref + inf + suff;
          const surPref = randomPick(DATASET.elf.surnamePrefix);
          const surSuff = randomPick(DATASET.elf.surnameSuffix);
          return `${firstName} ${surPref}${surSuff}`;
        }

        if (genre === "dwarf") {
          const pref = randomPick(DATASET.dwarf.prefixes);
          const suff =
            gender === "male"
              ? randomPick(DATASET.dwarf.suffixesMale)
              : gender === "female"
                ? randomPick(DATASET.dwarf.suffixesFemale)
                : randomPick([
                    ...DATASET.dwarf.suffixesMale,
                    ...DATASET.dwarf.suffixesFemale,
                  ]);

          const firstName = pref + suff;
          const surPref = randomPick(DATASET.dwarf.surnamePrefix);
          const surSuff = randomPick(DATASET.dwarf.surnameSuffix);
          return `${firstName} ${surPref}${surSuff}`;
        }

        if (genre === "orc") {
          const pref = randomPick(DATASET.orc.prefixes);
          const suff = randomPick(DATASET.orc.suffixes);
          return pref + suff;
        }

        if (genre === "noble") {
          const firstNameList =
            gender === "male"
              ? DATASET.noble.male
              : gender === "female"
                ? DATASET.noble.female
                : [...DATASET.noble.male, ...DATASET.noble.female];
          const firstName = randomPick(firstNameList);
          const lastName = randomPick(DATASET.noble.surnames);
          return `${firstName} ${lastName}`;
        }

        if (genre === "space-alien") {
          const s1 = randomPick(DATASET.scifiAlien);
          const s2 = randomPick(DATASET.scifiAlien);
          const separator = randomPick(["'", "-", " "]);
          return `${s1}${separator}${s2.toLowerCase()}`;
        }

        if (genre === "cyber-space") {
          const term = randomPick(DATASET.scifiCyber);
          const second = randomPick([
            "Runner",
            "Grid",
            "Apex",
            "Nova",
            "Cipher",
            "Agent",
            "Net",
            "Ghost",
            "Flux",
          ]);
          return `${term} ${second}`;
        }

        if (genre === "cyborg") {
          const human = randomPick([
            "Jax",
            "Echo",
            "Kira",
            "Cy",
            "Steel",
            "Val",
            "Nova",
            "Nyx",
            "Lex",
            "Borg",
          ]);
          const num = Math.floor(10 + Math.random() * 900);
          const code = randomPick(["X", "Z", "Alpha", "Omega", "V", "R", "D"]);
          return `${human}-${num}${code}`;
        }

        if (genre.startsWith("culture-")) {
          const cult = genre.replace("culture-", "");
          // @ts-ignore
          const pool = DATASET.cultures[cult];
          if (pool) {
            const firstNameList =
              gender === "male"
                ? pool.male
                : gender === "female"
                  ? pool.female
                  : [...pool.male, ...pool.female];
            const firstName = randomPick(firstNameList);
            const lastName = randomPick(pool.surnames);
            return `${firstName} ${lastName}`;
          }
        }
        return "Jane Doe";
      }

      case "brand": {
        const industry = filters.industry;
        const style = filters.style;
        const keyword = (filters.keyword || "").trim();

        if (style === "modern") {
          // Coined/Blended word
          let root = "";
          if (keyword.length > 2) {
            root =
              keyword.charAt(0).toUpperCase() + keyword.slice(1).toLowerCase();
          } else {
            // Pick based on industry
            const roots =
              industry === "tech"
                ? DATASET.business.techRoots
                : industry === "creative"
                  ? DATASET.business.creativeRoots
                  : industry === "finance"
                    ? DATASET.business.financeRoots
                    : DATASET.business.healthRoots;
            root = randomPick(roots);
          }
          const suffixes =
            industry === "tech"
              ? DATASET.business.techSuffixes
              : industry === "creative"
                ? DATASET.business.creativeSuffixes
                : industry === "finance"
                  ? DATASET.business.financeSuffixes
                  : DATASET.business.healthSuffixes;
          return `${root}${randomPick(suffixes)}`;
        }

        if (style === "playful") {
          let modifier = "";
          let noun = "";
          if (keyword.length > 2) {
            modifier =
              keyword.charAt(0).toUpperCase() + keyword.slice(1).toLowerCase();
            noun = randomPick(DATASET.business.playfulNouns);
          } else {
            modifier = randomPick(DATASET.business.playfulModifiers);
            noun = randomPick(DATASET.business.playfulNouns);
          }
          return `${modifier}${noun}`;
        }

        if (style === "professional") {
          let root = "";
          if (keyword.length > 2) {
            root =
              keyword.charAt(0).toUpperCase() + keyword.slice(1).toLowerCase();
          } else {
            const roots =
              industry === "tech"
                ? DATASET.business.techRoots
                : industry === "creative"
                  ? DATASET.business.creativeRoots
                  : industry === "finance"
                    ? DATASET.business.financeRoots
                    : DATASET.business.healthRoots;
            root = randomPick(roots);
          }
          const suffixes =
            industry === "tech"
              ? ["Systems", "Technologies", "Labs", "Digital"]
              : industry === "creative"
                ? ["Studios", "Design", "Agency", "Creative"]
                : industry === "finance"
                  ? ["Capital", "Holdings", "Group", "Partners"]
                  : ["Wellness", "Health", "Spring", "Life"];
          return `${root} ${randomPick(suffixes)}`;
        }
        return "Apex Corp";
      }

      case "user": {
        const theme = filters.theme;
        const includeNums = filters.includeNums;
        const includeSymbols = filters.includeSymbols;

        // @ts-ignore
        const pref = randomPick(DATASET.username.prefixes[theme]);
        // @ts-ignore
        const noun = randomPick(DATASET.username.nouns[theme]);

        let username = `${pref}${noun}`;

        if (includeNums) {
          const num = Math.floor(Math.random() * 999);
          username += num;
        }

        if (includeSymbols) {
          const sym = randomPick([".", "_", "xX"]);
          if (sym === "xX") {
            username = `xX_${username}_Xx`;
          } else {
            username = username.replaceAll("_", sym).replaceAll(".", sym);
          }
        }
        return username;
      }

      default:
        return "Unknown Option";
    }
  }

  // ==================== RENDERING & EVENT BINDINGS ====================

  const namesGrid = document.getElementById("names-grid") as HTMLDivElement;
  const namesEmptyState = document.getElementById(
    "names-empty-state",
  ) as HTMLDivElement;
  const generateBtn = document.getElementById(
    "generate-btn",
  ) as HTMLButtonElement;
  const resultsCount = document.getElementById(
    "results-count",
  ) as HTMLSpanElement;

  const favsContainer = document.getElementById(
    "favs-container",
  ) as HTMLDivElement;
  const favsEmptyState = document.getElementById(
    "favs-empty-state",
  ) as HTMLDivElement;
  const favsCount = document.getElementById("favs-count") as HTMLSpanElement;
  const favsActions = document.getElementById("favs-actions") as HTMLDivElement;

  // Read UI Form State
  function getFilters() {
    let gender = "neutral";
    const genderInput = document.querySelector(
      'input[name="char-gender"]:checked',
    ) as HTMLInputElement;
    if (genderInput) gender = genderInput.value;

    return {
      genre: (document.getElementById("char-genre") as HTMLSelectElement).value,
      gender: gender,
      industry: (document.getElementById("brand-industry") as HTMLSelectElement)
        .value,
      style: (document.getElementById("brand-style") as HTMLSelectElement)
        .value,
      keyword: (document.getElementById("brand-keyword") as HTMLInputElement)
        .value,
      theme: (document.getElementById("user-theme") as HTMLSelectElement).value,
      includeNums: (document.getElementById("user-nums") as HTMLInputElement)
        .checked,
      includeSymbols: (
        document.getElementById("user-chars") as HTMLInputElement
      ).checked,
    };
  }

  // Generate / Regenerate Action
  function performGeneration(isInitial = false) {
    const filters = getFilters();

    // Build or update generatedNames list preserving locks
    const newNames: { name: string; locked: boolean }[] = [];

    for (let i = 0; i < quantity; i++) {
      if (generatedNames[i] && generatedNames[i].locked) {
        newNames.push(generatedNames[i]);
      } else {
        newNames.push({
          name: generateName(activeTab, filters),
          locked: false,
        });
      }
    }

    generatedNames = newNames;
    renderResults();
  }

  // Single Slot Shuffle
  function shuffleSlot(index: number) {
    const filters = getFilters();
    generatedNames[index].name = generateName(activeTab, filters);

    // Render only the specific card to preserve visual states
    renderResults(index);
  }

  // Toggle Lock
  function toggleLock(index: number) {
    generatedNames[index].locked = !generatedNames[index].locked;
    renderResults(index);
  }

  // Render Results Grid
  function renderResults(singleIndexUpdate: number | null = null) {
    if (generatedNames.length === 0) {
      namesGrid.classList.add("hidden");
      namesEmptyState.classList.remove("hidden");
      return;
    }

    namesGrid.classList.remove("hidden");
    namesEmptyState.classList.add("hidden");
    resultsCount.textContent = `${generatedNames.length} total`;

    // Full render or partial updates
    if (singleIndexUpdate !== null) {
      const card = document.querySelector(
        `[data-index="${singleIndexUpdate}"]`,
      );
      if (card) {
        const item = generatedNames[singleIndexUpdate];

        // Update locked styles
        const lockBtn = card.querySelector(".lock-btn") as HTMLButtonElement;
        const nameText = card.querySelector(".name-text") as HTMLDivElement;

        nameText.textContent = item.name;

        if (item.locked) {
          card.classList.remove("bg-canvas", "border-hairline-soft");
          card.classList.add("bg-surface-yellow", "border-brand-yellow-deep");
          lockBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-yellow-deep animate-lock-pop" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 00-5.25 5.25v3a3 3 0 00-3 3v6.75a3 3 0 003 3h10.5a3 3 0 003-3v-6.75a3 3 0 00-3-3v-3c0-2.9-2.35-5.25-5.25-5.25zm3.75 8.25v-3a3.75 3.75 0 10-7.5 0v3h7.5z" clip-rule="evenodd" />
            </svg>
          `;
          lockBtn.title = "Unlock Name";
        } else {
          card.classList.remove(
            "bg-surface-yellow",
            "border-brand-yellow-deep",
          );
          card.classList.add("bg-canvas", "border-hairline-soft");
          lockBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
            </svg>
          `;
          lockBtn.title = "Lock Name";
        }
      }
      return;
    }

    // Build entire list
    namesGrid.innerHTML = "";
    generatedNames.forEach((item, index) => {
      const isFav = favorites.includes(item.name);
      const card = document.createElement("div");
      card.dataset.index = index.toString();
      card.className = `flex items-center justify-between p-3.5 border rounded-xl shadow-subtle transition-all duration-300 relative group overflow-hidden ${
        item.locked
          ? "bg-surface-yellow border-brand-yellow-deep"
          : "bg-canvas border-hairline-soft hover:shadow-card hover:border-hairline-strong"
      } stagger-item-${index}`;

      card.innerHTML = `
        <div class="flex flex-col gap-0.5 max-w-[70%]">
          <div class="name-text font-display font-medium text-base text-primary select-all break-all tracking-tight leading-snug">
            ${item.name}
          </div>
        </div>

        <div class="flex items-center gap-1">
          <!-- Copy Button -->
          <button
            type="button"
            class="copy-btn w-8 h-8 rounded-full flex items-center justify-center bg-surface border border-hairline hover:bg-canvas text-slate hover:text-primary transition-all cursor-pointer"
            title="Copy to clipboard"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
          </button>

          <!-- Shuffle Button -->
          <button
            type="button"
            class="shuffle-btn w-8 h-8 rounded-full flex items-center justify-center bg-surface border border-hairline hover:bg-canvas text-slate hover:text-primary transition-all cursor-pointer ${item.locked ? "opacity-40 pointer-events-none" : ""}"
            title="Shuffle this name"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </button>

          <!-- Lock Button -->
          <button
            type="button"
            class="lock-btn w-8 h-8 rounded-full flex items-center justify-center bg-surface border border-hairline hover:bg-canvas cursor-pointer"
            title="${item.locked ? "Unlock Name" : "Lock Name"}"
          >
            ${
              item.locked
                ? `
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-yellow-deep" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 00-5.25 5.25v3a3 3 0 00-3 3v6.75a3 3 0 003 3h10.5a3 3 0 003-3v-6.75a3 3 0 00-3-3v-3c0-2.9-2.35-5.25-5.25-5.25zm3.75 8.25v-3a3.75 3.75 0 10-7.5 0v3h7.5z" clip-rule="evenodd" />
                </svg>
              `
                : `
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
                </svg>
              `
            }
          </button>

          <!-- Favorite/Pin Button -->
          <button
            type="button"
            class="fav-btn w-8 h-8 rounded-full flex items-center justify-center bg-surface border border-hairline hover:bg-canvas cursor-pointer"
            title="${isFav ? "Remove from Favorites" : "Add to Favorites"}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-all ${isFav ? "text-brand-coral fill-current" : "text-slate hover:text-brand-coral"}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </button>
        </div>
      `;

      // Bind button events inside the card
      card.querySelector(".copy-btn")?.addEventListener("click", () => {
        navigator.clipboard.writeText(item.name);
        const iconBtn = card.querySelector(".copy-btn") as HTMLButtonElement;
        iconBtn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        `;
        setTimeout(() => {
          iconBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
          `;
        }, 1200);
      });

      card.querySelector(".shuffle-btn")?.addEventListener("click", (e) => {
        const iconSvg = (e.currentTarget as HTMLButtonElement).querySelector(
          "svg",
        );
        iconSvg?.classList.add("animate-shuffle-spin");
        setTimeout(() => {
          shuffleSlot(index);
        }, 200);
      });

      card.querySelector(".lock-btn")?.addEventListener("click", () => {
        toggleLock(index);
      });

      card.querySelector(".fav-btn")?.addEventListener("click", () => {
        toggleFavorite(item.name);
      });

      namesGrid.appendChild(card);
    });
  }

  // ==================== FAVORITES LOGIC ====================

  function loadFavorites() {
    const stored = localStorage.getItem("board_name_favs");
    if (stored) {
      favorites = JSON.parse(stored);
    }
    renderFavorites();
  }

  function saveFavorites() {
    localStorage.setItem("board_name_favs", JSON.stringify(favorites));
    renderFavorites();
    // Refresh items to toggle active heart icon status
    renderResults();
  }

  function toggleFavorite(name: string) {
    if (favorites.includes(name)) {
      favorites = favorites.filter((n) => n !== name);
    } else {
      favorites.push(name);
    }
    saveFavorites();
  }

  function renderFavorites() {
    favsCount.textContent = favorites.length.toString();

    if (favorites.length === 0) {
      favsContainer.innerHTML = "";
      favsEmptyState.classList.remove("hidden");
      favsActions.classList.add("hidden");
      return;
    }

    favsEmptyState.classList.add("hidden");
    favsActions.classList.remove("hidden");
    favsContainer.innerHTML = "";

    favorites.forEach((name) => {
      const pill = document.createElement("div");
      pill.className =
        "flex items-center gap-1.5 px-3 py-1.5 bg-surface border border-hairline rounded-full text-xs font-semibold text-primary transition-all hover:border-brand-coral";
      pill.innerHTML = `
        <span class="cursor-pointer select-all">${name}</span>
        <button type="button" class="remove-fav-btn text-slate hover:text-brand-coral focus:outline-none cursor-pointer" title="Remove">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      `;

      pill.querySelector("span")?.addEventListener("click", () => {
        navigator.clipboard.writeText(name);
        // Show temporary visual feedback
        const originalText = name;
        const textSpan = pill.querySelector("span") as HTMLSpanElement;
        textSpan.textContent = "Copied!";
        setTimeout(() => {
          textSpan.textContent = originalText;
        }, 1000);
      });

      pill.querySelector(".remove-fav-btn")?.addEventListener("click", () => {
        toggleFavorite(name);
      });

      favsContainer.appendChild(pill);
    });
  }

  // ==================== TABS & OPTIONS CONTROLLERS ====================

  function switchTab(tab: string) {
    activeTab = tab;

    // Tabs DOM highlight updates
    const tabs = [
      { id: "tab-char-btn", name: "char" },
      { id: "tab-brand-btn", name: "brand" },
      { id: "tab-user-btn", name: "user" },
    ];

    tabs.forEach((t) => {
      const btn = document.getElementById(t.id) as HTMLButtonElement;
      if (t.name === tab) {
        btn.classList.add("bg-primary", "text-canvas");
        btn.classList.remove("text-slate", "hover:text-ink");
        btn.setAttribute("aria-selected", "true");
      } else {
        btn.classList.remove("bg-primary", "text-canvas");
        btn.classList.add("text-slate", "hover:text-ink");
        btn.setAttribute("aria-selected", "false");
      }
    });

    // Form Filter Group visibility updates
    const filterChar = document.getElementById(
      "filter-group-char",
    ) as HTMLDivElement;
    const filterBrand = document.getElementById(
      "filter-group-brand",
    ) as HTMLDivElement;
    const filterUser = document.getElementById(
      "filter-group-user",
    ) as HTMLDivElement;

    filterChar.classList.add("hidden");
    filterBrand.classList.add("hidden");
    filterUser.classList.add("hidden");

    if (tab === "char") filterChar.classList.remove("hidden");
    if (tab === "brand") filterBrand.classList.remove("hidden");
    if (tab === "user") filterUser.classList.remove("hidden");

    // Perform default generation for new tab
    performGeneration();
  }

  // Set quantity selection styling
  function setQuantity(qty: number) {
    quantity = qty;
    const qtyButtons = document.querySelectorAll(".btn-qty");
    qtyButtons.forEach((btn) => {
      const btnQty = parseInt(btn.getAttribute("data-qty") || "10");
      if (btnQty === qty) {
        btn.classList.add("bg-primary", "text-canvas");
        btn.classList.remove(
          "text-slate",
          "border-hairline-strong",
          "bg-canvas",
        );
      } else {
        btn.classList.remove("bg-primary", "text-canvas");
        btn.classList.add("text-slate", "border-hairline-strong", "bg-canvas");
      }
    });

    performGeneration();
  }

  // ==================== EXPORTS ====================

  function exportFavorites(format: "txt" | "csv") {
    if (favorites.length === 0) return;

    let content = "";
    let mimeType = "text/plain";
    let filename = `boardtools_names_export_${Date.now()}`;

    if (format === "txt") {
      content = favorites.join("\r\n");
      filename += ".txt";
    } else {
      content =
        "Name\r\n" +
        favorites.map((n) => `"${n.replace(/"/g, '""')}"`).join("\r\n");
      mimeType = "text/csv";
      filename += ".csv";
    }

    const blob = new Blob([content], { type: mimeType });
    const link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.download = filename;
    link.click();
    URL.revokeObjectURL(link.href);
  }

  // ==================== INITIALIZATION & BINDING ====================

  document.addEventListener("DOMContentLoaded", () => {
    // Bind Tab Switching
    document
      .getElementById("tab-char-btn")
      ?.addEventListener("click", () => switchTab("char"));
    document
      .getElementById("tab-brand-btn")
      ?.addEventListener("click", () => switchTab("brand"));
    document
      .getElementById("tab-user-btn")
      ?.addEventListener("click", () => switchTab("user"));

    // Bind Quantity Selecting
    document.querySelectorAll(".btn-qty").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const qty = parseInt(
          (e.currentTarget as HTMLButtonElement).getAttribute("data-qty") ||
            "10",
        );
        setQuantity(qty);
      });
    });

    // Bind Gender selection styling helper
    const genderLabels = document.querySelectorAll('input[name="char-gender"]');
    genderLabels.forEach((rad) => {
      rad.addEventListener("change", (e) => {
        const target = e.target as HTMLInputElement;
        const parentLabels = document.querySelectorAll(
          'input[name="char-gender"]',
        );
        parentLabels.forEach((p) => {
          const lbl = p.closest("label") as HTMLLabelElement;
          lbl.classList.remove("bg-primary", "text-canvas", "border-primary");
          lbl.classList.add(
            "text-slate",
            "bg-canvas",
            "border-hairline-strong",
          );
        });
        const activeLbl = target.closest("label") as HTMLLabelElement;
        activeLbl.classList.remove(
          "text-slate",
          "bg-canvas",
          "border-hairline-strong",
        );
        activeLbl.classList.add("bg-primary", "text-canvas", "border-primary");
        performGeneration();
      });
    });

    // Option triggers for instant changes
    document
      .getElementById("char-genre")
      ?.addEventListener("change", () => performGeneration());
    document
      .getElementById("brand-industry")
      ?.addEventListener("change", () => performGeneration());
    document
      .getElementById("brand-style")
      ?.addEventListener("change", () => performGeneration());
    document
      .getElementById("brand-keyword")
      ?.addEventListener("input", () => performGeneration());
    document
      .getElementById("user-theme")
      ?.addEventListener("change", () => performGeneration());
    document
      .getElementById("user-nums")
      ?.addEventListener("change", () => performGeneration());
    document
      .getElementById("user-chars")
      ?.addEventListener("change", () => performGeneration());

    // Generate CTA button
    generateBtn.addEventListener("click", () => performGeneration());
    document
      .getElementById("generate-top-btn")
      ?.addEventListener("click", () => performGeneration());

    // Global Lock / Unlock
    document.getElementById("lock-all-btn")?.addEventListener("click", () => {
      generatedNames.forEach((item) => (item.locked = true));
      renderResults();
    });
    document.getElementById("unlock-all-btn")?.addEventListener("click", () => {
      generatedNames.forEach((item) => (item.locked = false));
      renderResults();
    });

    // Reset Defaults
    document.getElementById("reset-all-btn")?.addEventListener("click", () => {
      // Character Defaults
      (document.getElementById("char-genre") as HTMLSelectElement).value =
        "elf";
      const neutralRadio = document.querySelector(
        'input[name="char-gender"][value="neutral"]',
      ) as HTMLInputElement;
      if (neutralRadio) {
        neutralRadio.checked = true;
        // Trigger event
        neutralRadio.dispatchEvent(new Event("change"));
      }

      // Brand Defaults
      (document.getElementById("brand-industry") as HTMLSelectElement).value =
        "tech";
      (document.getElementById("brand-style") as HTMLSelectElement).value =
        "modern";
      (document.getElementById("brand-keyword") as HTMLInputElement).value = "";

      // Username Defaults
      (document.getElementById("user-theme") as HTMLSelectElement).value =
        "gaming";
      (document.getElementById("user-nums") as HTMLInputElement).checked = true;
      (document.getElementById("user-chars") as HTMLInputElement).checked =
        false;

      // Lock resets
      generatedNames.forEach((item) => (item.locked = false));

      setQuantity(10);
    });

    // Favorites Export
    document
      .getElementById("export-txt-btn")
      ?.addEventListener("click", () => exportFavorites("txt"));
    document
      .getElementById("export-csv-btn")
      ?.addEventListener("click", () => exportFavorites("csv"));
    document.getElementById("clear-favs-btn")?.addEventListener("click", () => {
      if (confirm("Are you sure you want to clear your saved favorites?")) {
        favorites = [];
        saveFavorites();
      }
    });

    // How it works modal
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    if (howItWorksBtn && howItWorksModal) {
      howItWorksBtn.addEventListener("click", () => {
        howItWorksModal.classList.remove("hidden");
      });
    }
    const hideModal = () => {
      howItWorksModal?.classList.add("hidden");
    };
    closeModalBtn?.addEventListener("click", hideModal);
    modalOkBtn?.addEventListener("click", hideModal);
    howItWorksModal?.addEventListener("click", (e) => {
      if (e.target === howItWorksModal) hideModal();
    });

    // Top Share Button Event
    const shareBtn = document.getElementById("share-btn");
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("tab", activeTab);

      if (activeTab === "char") {
        const genre = (document.getElementById("char-genre") as HTMLSelectElement).value;
        url.searchParams.set("char-genre", genre);
        const gender = (document.querySelector('input[name="char-gender"]:checked') as HTMLInputElement)?.value;
        if (gender) url.searchParams.set("char-gender", gender);
      } else if (activeTab === "brand") {
        const industry = (document.getElementById("brand-industry") as HTMLSelectElement).value;
        const style = (document.getElementById("brand-style") as HTMLSelectElement).value;
        const keyword = (document.getElementById("brand-keyword") as HTMLInputElement).value;
        url.searchParams.set("brand-industry", industry);
        url.searchParams.set("brand-style", style);
        if (keyword) url.searchParams.set("brand-keyword", keyword);
      } else if (activeTab === "user") {
        const theme = (document.getElementById("user-theme") as HTMLSelectElement).value;
        const nums = (document.getElementById("user-nums") as HTMLInputElement).checked;
        const chars = (document.getElementById("user-chars") as HTMLInputElement).checked;
        url.searchParams.set("user-theme", theme);
        url.searchParams.set("user-nums", nums.toString());
        url.searchParams.set("user-chars", chars.toString());
      }

      const shareData = {
        title: document.title || "Name Generator",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    function handleUrlParams() {
      const params = new URLSearchParams(window.location.search);
      const tabParam = params.get('tab');
      if (tabParam) {
        switchTab(tabParam);
      }
      
      const charGenre = params.get('char-genre');
      if (charGenre) {
        (document.getElementById("char-genre") as HTMLSelectElement).value = charGenre;
      }
      const charGender = params.get('char-gender');
      if (charGender) {
        const radio = document.querySelector(`input[name="char-gender"][value="${charGender}"]`) as HTMLInputElement;
        if (radio) {
          radio.checked = true;
          radio.dispatchEvent(new Event("change"));
        }
      }
      
      const brandIndustry = params.get('brand-industry');
      if (brandIndustry) {
        (document.getElementById("brand-industry") as HTMLSelectElement).value = brandIndustry;
      }
      const brandStyle = params.get('brand-style');
      if (brandStyle) {
        (document.getElementById("brand-style") as HTMLSelectElement).value = brandStyle;
      }
      const brandKeyword = params.get('brand-keyword');
      if (brandKeyword) {
        (document.getElementById("brand-keyword") as HTMLInputElement).value = brandKeyword;
      }
      
      const userTheme = params.get('user-theme');
      if (userTheme) {
        (document.getElementById("user-theme") as HTMLSelectElement).value = userTheme;
      }
      const userNums = params.get('user-nums');
      if (userNums) {
        (document.getElementById("user-nums") as HTMLInputElement).checked = (userNums === 'true');
      }
      const userChars = params.get('user-chars');
      if (userChars) {
        (document.getElementById("user-chars") as HTMLInputElement).checked = (userChars === 'true');
      }
    }

    // Load Favorites & Run Initial Generation
    loadFavorites();
    handleUrlParams();
    performGeneration(true);
  });
</script>
