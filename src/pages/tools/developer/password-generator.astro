---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Password Generator";
const category = "developer";
const tier = "Security & Text Utilities";
const description = "Generate cryptographically secure passwords or memorable passphrases entirely client-side. Keep your accounts safe with honest strength estimation.";

// SEO metadata
const pageTitle = "Secure Password & Passphrase Generator - BoardTools";
const metaDescription = "Free client-side password generator using secure Web Crypto API. Generate random characters or memorable passphrases with real-time entropy and crack time estimates.";
const keywords = "password generator, secure passwords, passphrase generator, correct horse battery staple, client-side password, random password generator, password entropy, web crypto api";
const canonicalUrl = "https://boardtools.app/tools/developer/password-generator";
---

<Layout 
  title={pageTitle}
  description={metaDescription}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage="/og/password-generator.png"
  ogType="website"
  hideBanner={true}
>
  <!-- SEO Schema for WebApplication -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Secure Password Generator",
      "url": "https://boardtools.app/tools/developer/password-generator",
      "description": "Generate strong, cryptographically secure passwords or readable word-based passphrases offline in your browser.",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Cryptographically secure randomness via Web Crypto API",
        "Random character mode with custom lengths and character pools",
        "Memorable passphrase mode (EFF style word combinations)",
        "Real-time Shannon entropy and crack-time diagnostics",
        "Automatic client-side clipboard clearing option",
        "Batch password generation for multiple credentials",
        "100% private - runs strictly local, zero network requests"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1280px] w-full mx-auto px-3 sm:px-4 md:px-8 py-4 sm:py-10 flex flex-col gap-4 sm:gap-6 animate-fade-in-up pb-12 sm:pb-16">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1.5">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-3">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <!-- Reset Button - styled like JSON Formatter -->
          <button
            type="button"
            id="btn-reset-defaults"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset all password generator settings to defaults"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
            </svg>
            <span>Reset</span>
          </button>

          <!-- How it works Button -->
          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How password generator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>How it works</span>
          </button>

          <!-- Security Badge -->
          <span class="inline-flex items-center gap-1 text-[10px] font-bold text-success-accent bg-success-accent/10 px-2.5 py-1 rounded-full uppercase">
            <span class="w-1.5 h-1.5 rounded-full bg-success-accent animate-ping"></span>
            100% Offline
          </span>
        </div>
      </div>
    </div>

    <!-- Main Workspace Area -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
      <!-- Left Column: Password Display & Main Configurations -->
      <div class="lg:col-span-8 flex flex-col gap-6">
        
        <!-- Display Card containing password and copy actions -->
        <div id="password-result-section" class="card-base p-3 sm:p-5 sm:p-6 bg-canvas border border-hairline rounded-xl flex flex-col gap-3 sm:gap-4 relative overflow-hidden shadow-subtle">
          <div class="absolute inset-0 dot-grid opacity-[0.03] pointer-events-none"></div>
          
          <div class="flex items-center justify-between relative z-10">
            <span class="text-[10px] font-bold text-slate uppercase tracking-wider">Your Secure Password</span>
            <!-- Clipboard Action timer notification -->
            <div id="clipboard-timer-badge" class="hidden text-[10px] bg-brand-coral/10 text-coral-dark font-bold px-2 py-0.5 rounded-full">
              Clipboard clears in <span id="clipboard-countdown">30</span>s
            </div>
          </div>

          <!-- Length / Word Count Selector (placed on top of the generated password) -->
          <div class="relative z-10 flex flex-col gap-2 bg-surface-soft p-3 sm:p-4 rounded-lg border border-hairline">
            <!-- Password Length Slider (for Char mode) -->
            <div id="display-char-length-container" class="flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <label for="char-length" class="text-[10px] font-bold text-slate uppercase">Password Length</label>
                <div class="flex items-center gap-1.5">
                  <input 
                    type="number" 
                    id="char-length-num" 
                    min="6" 
                    max="128" 
                    value="16" 
                    class="w-14 text-center text-xs font-mono font-semibold py-1 px-1.5 border border-hairline rounded bg-canvas text-primary"
                  />
                  <span class="text-[10px] text-stone">chars</span>
                </div>
              </div>
              <input 
                type="range" 
                id="char-length" 
                min="6" 
                max="128" 
                value="16" 
                class="w-full accent-primary cursor-pointer h-2 bg-canvas rounded-full border border-hairline" 
              />
            </div>
            <!-- Word Count Slider (for Passphrase mode) -->
            <div id="display-passphrase-words-container" class="hidden flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <label for="passphrase-words" class="text-[10px] font-bold text-slate uppercase">Number of Words</label>
                <div class="flex items-center gap-1">
                  <span id="passphrase-words-val" class="text-xs font-mono font-bold bg-canvas px-2 py-0.5 border border-hairline rounded text-primary">4</span>
                  <span class="text-[10px] text-stone">words</span>
                </div>
              </div>
              <input 
                type="range" 
                id="passphrase-words" 
                min="3" 
                max="10" 
                value="4" 
                class="w-full accent-primary cursor-pointer h-2 bg-canvas rounded-full border border-hairline" 
              />
            </div>
          </div>

          <!-- Password Display box -->
          <div class="relative z-10 flex items-center justify-between bg-surface border border-hairline rounded-lg p-3 sm:p-4 min-h-[56px] sm:min-h-[72px] gap-3 sm:gap-4 group">
            <div 
              id="password-display" 
              class="font-mono text-sm sm:text-base sm:text-lg font-bold text-primary break-all select-all select-none cursor-pointer tracking-wide flex-1 focus:outline-none"
              tabindex="0"
              title="Click to copy, press space to regenerate"
            >
              Generating...
            </div>
            
            <div class="flex items-center gap-2 shrink-0">
              <!-- Regenerate Icon Button (Refresh CW Symbol) -->
              <button 
                type="button" 
                id="btn-regenerate" 
                class="w-10 h-10 bg-canvas hover:bg-surface border border-hairline rounded-full flex items-center justify-center text-slate hover:text-primary transition-all shadow-subtle hover:scale-105 active:scale-95 cursor-pointer relative"
                title="Regenerate Password (Spacebar)"
                aria-label="Regenerate Password"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300" id="regenerate-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                  <path d="M3 3v5h5" />
                  <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
                  <path d="M16 16h5v5" />
                </svg>
              </button>

              <!-- Copy Button -->
              <button 
                type="button" 
                id="btn-copy" 
                class="button-primary text-xs font-bold py-2.5 px-4 !rounded-full shadow-subtle flex items-center gap-1.5 hover:scale-[1.02] active:scale-[0.98] transition-all cursor-pointer"
                aria-label="Copy password to clipboard"
              >
                <span id="copy-btn-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                  </svg>
                </span>
                <span id="copy-btn-text">Copy</span>
              </button>
            </div>
          </div>

          <!-- Toast Alert overlay -->
          <div id="copy-toast" class="hidden absolute top-4 right-4 bg-success-accent text-canvas text-[10px] font-bold py-1 px-2.5 rounded-full shadow-subtle animate-scale-in">
            ✓ Copied to clipboard!
          </div>

          <!-- Dynamic Strength Diagnostics -->
          <div class="flex flex-col gap-2 mt-1 sm:mt-2 bg-surface-soft p-3 sm:p-4 rounded-lg border border-hairline">
            <div class="flex items-center justify-between text-xs">
              <div class="flex items-center gap-1.5 font-bold">
                <span class="text-slate">Strength:</span>
                <span id="strength-label" class="text-brand-coral uppercase tracking-wide">Weak</span>
              </div>
              <span id="entropy-label" class="font-mono text-stone text-[11px]">0.0 bits of entropy</span>
            </div>

            <!-- Custom Transition Progress Bar -->
            <div class="w-full bg-hairline rounded-full h-2.5 overflow-hidden relative">
              <div id="strength-bar" class="h-2.5 rounded-full bg-brand-coral transition-all duration-500 ease-out" style="width: 0%"></div>
            </div>

            <!-- Crack time estimate panel -->
            <div class="text-[11px] text-slate/90 leading-relaxed flex flex-col gap-1 mt-0.5">
              <span class="flex items-center gap-1">
                ⏱️ Estimated Crack Time: <strong id="crack-time-val" class="text-primary font-semibold">Instant</strong>
              </span>
              <p class="text-[10px] text-stone">
                Calculated using simulated hardware clusters executing 100 trillion attempts per second.
              </p>
            </div>
          </div>
        </div>

        <!-- Generation Configuration Panels -->
        <div class="card-base p-3 sm:p-5 sm:p-6 flex flex-col gap-4 sm:gap-5 border border-hairline shadow-subtle bg-canvas">
          <!-- Toggle Modes (Tabs) -->
          <div class="flex rounded-full bg-surface p-0.5 border border-hairline w-full max-w-sm">
            <button
              type="button"
              id="tab-char"
              class="flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
              role="tab"
              aria-selected="true"
            >
              Random Characters
            </button>
            <button
              type="button"
              id="tab-passphrase"
              class="flex-1 text-center text-xs py-1.5 rounded-full font-bold transition-all cursor-pointer text-slate"
              role="tab"
              aria-selected="false"
            >
              Memorable Passphrase
            </button>
          </div>

          <!-- Section A: Character Configuration -->
          <div id="config-char-panel" class="flex flex-col gap-5">
            <!-- Pool Switches -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 pt-2">
              <!-- Uppercase -->
              <label class="flex items-center gap-2 p-2.5 bg-surface-soft hover:bg-surface border border-hairline rounded-lg cursor-pointer select-none transition-colors">
                <input type="checkbox" id="chk-uppercase" checked class="w-4 h-4 rounded text-primary border-hairline-strong focus:ring-primary cursor-pointer" />
                <span class="text-xs font-semibold text-primary">A-Z (ABC)</span>
              </label>

              <!-- Lowercase -->
              <label class="flex items-center gap-2 p-2.5 bg-surface-soft hover:bg-surface border border-hairline rounded-lg cursor-pointer select-none transition-colors">
                <input type="checkbox" id="chk-lowercase" checked class="w-4 h-4 rounded text-primary border-hairline-strong focus:ring-primary cursor-pointer" />
                <span class="text-xs font-semibold text-primary">a-z (abc)</span>
              </label>

              <!-- Numbers -->
              <label class="flex items-center gap-2 p-2.5 bg-surface-soft hover:bg-surface border border-hairline rounded-lg cursor-pointer select-none transition-colors">
                <input type="checkbox" id="chk-numbers" checked class="w-4 h-4 rounded text-primary border-hairline-strong focus:ring-primary cursor-pointer" />
                <span class="text-xs font-semibold text-primary">0-9 (123)</span>
              </label>

              <!-- Symbols -->
              <label class="flex items-center gap-2 p-2.5 bg-surface-soft hover:bg-surface border border-hairline rounded-lg cursor-pointer select-none transition-colors">
                <input type="checkbox" id="chk-symbols" checked class="w-4 h-4 rounded text-primary border-hairline-strong focus:ring-primary cursor-pointer" />
                <span class="text-xs font-semibold text-primary">#$& (@#%)</span>
              </label>
            </div>

            <!-- Exclude Ambiguous Option -->
            <div class="p-3 bg-surface-soft border border-hairline rounded-lg flex items-center justify-between">
              <div class="flex flex-col gap-0.5">
                <span class="text-xs font-bold text-primary">Exclude Ambiguous Characters</span>
                <span class="text-[10px] text-stone">Avoids visually identical characters: 0, O, o, I, i, l, 1</span>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="chk-exclude-ambig" class="sr-only peer" />
                <div class="w-9 h-5 bg-hairline-strong peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
              </label>
            </div>
          </div>

          <!-- Section B: Passphrase Configuration -->
          <div id="config-passphrase-panel" class="hidden flex flex-col gap-5">
            <!-- Separator Type -->
            <div class="flex flex-col gap-1.5">
              <label for="passphrase-separator" class="text-[10px] font-bold text-slate uppercase">Word Separator</label>
              <select id="passphrase-separator" class="text-input py-1 px-3 text-xs h-9 cursor-pointer border border-hairline-strong bg-canvas rounded-md">
                <option value="-" selected>Hyphen (correct-horse-battery-staple)</option>
                <option value=" ">Space (correct horse battery staple)</option>
                <option value="_">Underscore (correct_horse_battery_staple)</option>
                <option value=".">Period (correct.horse.battery.staple)</option>
                <option value="">None (correcthorsebatterystaple)</option>
              </select>
            </div>
          </div>

          <!-- Common Security Configuration (Auto-clear, etc) -->
          <div class="pt-4 border-t border-hairline flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div class="flex flex-col gap-0.5">
              <label for="security-clipboard-clear" class="text-[10px] font-bold text-slate uppercase">Clipboard Safety Net</label>
              <span class="text-[10px] text-stone">Automatically wipes clipboard to prevent leakage</span>
            </div>
            <select id="security-clipboard-clear" class="text-input py-1 px-3 pr-8 text-xs h-9 border border-hairline-strong bg-canvas text-primary rounded-md cursor-pointer w-full sm:w-52">
              <option value="0" selected>Never Clear Clipboard</option>
              <option value="15">Clear after 15 seconds</option>
              <option value="30">Clear after 30 seconds</option>
              <option value="60">Clear after 60 seconds</option>
              <option value="120">Clear after 2 minutes</option>
            </select>
          </div>
        </div>

      </div>

      <!-- Right Column: Batch Mode & Info Sidebar -->
      <div class="lg:col-span-4 flex flex-col gap-6">
        
        <!-- Batch Generator Widget — hidden on mobile for compact UX -->
        <div class="hidden lg:flex card-base p-5 border border-hairline bg-canvas rounded-xl shadow-subtle flex-col gap-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-rose"></span>
              <h3 class="font-display font-medium text-sm text-primary">Generate Batch</h3>
            </div>
            <button 
              type="button" 
              id="btn-copy-batch" 
              class="text-[10px] font-bold text-brand-blue hover:underline cursor-pointer"
            >
              Copy All List
            </button>
          </div>

          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between text-[10px] text-stone">
              <span>Quantity:</span>
              <div class="flex gap-1.5">
                <button type="button" class="btn-batch-qty px-2 py-0.5 bg-surface border border-hairline rounded font-bold hover:bg-hairline cursor-pointer text-primary" data-qty="5">5</button>
                <button type="button" class="btn-batch-qty px-2 py-0.5 bg-primary text-canvas border border-primary rounded font-bold hover:bg-charcoal cursor-pointer" data-qty="10">10</button>
                <button type="button" class="btn-batch-qty px-2 py-0.5 bg-surface border border-hairline rounded font-bold hover:bg-hairline cursor-pointer text-primary" data-qty="20">20</button>
              </div>
            </div>

            <!-- List box -->
            <div class="bg-surface border border-hairline rounded-lg p-2.5 min-h-[180px] max-h-[240px] overflow-y-auto">
              <ul id="batch-list" class="flex flex-col gap-1.5 font-mono text-[11px] text-primary divide-y divide-hairline-soft">
                <!-- Batch passwords rendered dynamically -->
              </ul>
            </div>
            
            <p class="text-[9px] text-stone leading-relaxed">
              Batch mode uses the exact settings selected on the left panel. Great for setting up multiple databases or configurations.
            </p>
          </div>
        </div>

        <!-- Privacy & Security Statement (Pastel Accent) -->
        <div class="card-feature-teal flex flex-col gap-3.5 relative overflow-hidden">
          <div class="absolute inset-0 dot-grid opacity-[0.03] pointer-events-none"></div>
          <span class="badge-tag-purple bg-teal-light text-moss-dark self-start">ZERO TRUST SECURITY</span>
          <h3 class="font-display font-semibold text-sm text-primary">100% Private Local Execution</h3>
          <p class="text-xs leading-relaxed text-moss-dark/95">
            Passwords are generated offline using browser-level cryptographic functions. Zero bytes leave your machine. No APIs, telemetry, or server logging exist in this workflow.
          </p>
          <div class="h-[1px] bg-brand-teal/20"></div>
          <p class="text-[10px] leading-relaxed text-moss-dark/85">
            We employ the <code>window.crypto.getRandomValues</code> API which binds straight to the operating system entropy pool for maximum security.
          </p>
        </div>

        <!-- Last Used Preference Indicator -->
        <div class="hidden lg:block text-[10px] text-stone text-center bg-surface-soft border border-hairline p-2.5 rounded-lg">
          ⚙️ Preferences saved to local memory for your next visit.
        </div>

      </div>
    </div>
  </section>


  <!-- Educational Article -->
  <section class="max-w-[760px] w-full mx-auto px-4 pb-20 flex flex-col gap-8 text-slate" aria-labelledby="about-tool-heading">
    <article class="flex flex-col gap-4">
      <h2 id="about-tool-heading" class="font-display font-semibold text-xl sm:text-2xl text-primary tracking-tight">
        Understanding Password Security, Shannon Entropy, & Brute-Force Estimates
      </h2>
      <p class="text-sm leading-relaxed">
        Modern credential security requires a shift away from hard-to-remember password requirements (like replacing "a" with "@") toward higher <strong>Shannon entropy</strong>. Entropy measures the randomness of a password based on its characters' mathematical pool size and overall length.
      </p>

      <h3 class="font-display font-semibold text-base text-primary mt-2">
        Random Characters vs. Memorable Passphrases
      </h3>
      <p class="text-sm leading-relaxed">
        <strong>Random Character</strong> passwords pool letters, digits, and symbols to form high-density entropy strings. A 16-character alphanumeric password offers roughly 95 bits of entropy, which is secure enough to repel offline brute-force cracking attempts for centuries.
      </p>
      <p class="text-sm leading-relaxed">
        <strong>Memorable Passphrases</strong> use random combinations of real dictionary words (like the famous <em>correct-horse-battery-staple</em> concept). Since each word in our dictionary adds 9 bits of entropy, a 5-word passphrase holds 45 bits of entropy. A 6 to 8-word passphrase holds extremely resilient entropy, and is much simpler for humans to type without copy-pasting.
      </p>

      <h3 class="font-display font-semibold text-base text-primary mt-2">
        How We Calculate Crack Time Estimates
      </h3>
      <p class="text-sm leading-relaxed">
        Many tools present fake, optimistic estimations (e.g., claiming "Millions of years" for basic passwords). Our calculator assumes standard supercomputers or GPU clusters running optimized brute-force attacks at 100 trillion guesses per second. 
      </p>
      <ul class="list-disc pl-5 text-xs text-slate flex flex-col gap-1.5">
        <li><strong>Weak (&lt; 36 bits):</strong> Vulnerable to consumer-grade computing hardware. Cracked in minutes or hours.</li>
        <li><strong>Moderate (36–59 bits):</strong> Resilient to basic attacks. Can require weeks to years for dedicated setups to recover.</li>
        <li><strong>Strong (60–99 bits):</strong> Highly secure. Requires millions of dollars in compute budget or state-level hardware arrays to make computational progress.</li>
        <li><strong>Very Strong (&ge; 100 bits):</strong> Computationally unfeasible. Outlasts the lifespan of our physical universe.</li>
      </ul>
    </article>
  </section>
  <!-- Mobile Sticky Password Bar — always visible at bottom on mobile after first generation -->
  <div id="mobile-sticky-bar" class="lg:hidden fixed bottom-0 left-0 right-0 bg-canvas/95 backdrop-blur-md border-t border-hairline shadow-modal p-3 z-40 transition-all duration-300 transform translate-y-full">
    <div class="flex items-center gap-3 max-w-[1280px] mx-auto">
      <div class="flex-1 min-w-0">
        <div class="text-[9px] font-bold text-slate uppercase tracking-wider mb-0.5">Generated Password</div>
        <div id="mobile-sticky-password" class="font-mono text-sm font-bold text-primary truncate">—</div>
      </div>
      <button
        type="button"
        id="mobile-sticky-copy"
        class="button-primary text-xs font-bold py-2 px-4 !rounded-full shrink-0 flex items-center gap-1.5"
        aria-label="Copy generated password to clipboard"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
