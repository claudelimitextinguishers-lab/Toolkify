  // --- CRYPTOGRAPHICALLY SECURE RANDOM SOURCE ---
  // Exclusive usage of crypto.getRandomValues API
  function secureRandomInt(max: number): number {
    const array = new Uint32Array(1);
    window.crypto.getRandomValues(array);
    // Safe modulo operation avoiding bias
    return array[0] % max;
  }

  // Generate a secure random password character string
  function generateRandomPassword(): string {
    const uppercasePool = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const lowercasePool = "abcdefghijklmnopqrstuvwxyz";
    const numbersPool = "0123456789";
    const symbolsPool = "!@#$%^&*()_+-=[]{}|;:,.<>?";
    const ambiguousChars = /[0Oo1lIi]/g;

    let charset = "";
    if (state.uppercase) charset += uppercasePool;
    if (state.lowercase) charset += lowercasePool;
    if (state.numbers) charset += numbersPool;
    if (state.symbols) charset += symbolsPool;

    if (state.excludeAmbiguous) {
      charset = charset.replace(ambiguousChars, "");
    }

    if (charset.length === 0) {
      return "Select complexity pool";
    }

    let password = "";
    for (let i = 0; i < state.length; i++) {
      const randomIndex = secureRandomInt(charset.length);
      password += charset[randomIndex];
    }
    return password;
  }

  // Generate a secure random passphrase using the Wordlist
  function generatePassphrase(): string {
    if (WORDLIST.length === 0) return "Dictionary Empty";
    
    const words: string[] = [];
    for (let i = 0; i < state.wordCount; i++) {
      const wordIndex = secureRandomInt(WORDLIST.length);
      words.push(WORDLIST[wordIndex]);
    }
    return words.join(state.separator);
  }

  // Animation character scramble settles
  function animateGeneratedPassword(password: string) {
    if (!passwordDisplay) return;
    
    // Quick spin visual effect
    if (regenerateIcon) {
      regenerateIcon.classList.add('rotate-180');
      setTimeout(() => {
        regenerateIcon.classList.remove('rotate-180');
      }, 300);
    }

    let iterations = 0;
    const maxIterations = 8;
    const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+";
    const len = password.length;

    const interval = setInterval(() => {
      passwordDisplay.textContent = password
        .split("")
        .map((char, index) => {
          if (char === '-' || char === ' ' || char === '_' || char === '.') return char;
          if (index < (iterations * (len / maxIterations))) {
            return char;
          }
          return chars[Math.floor(Math.random() * chars.length)];
        })
        .join("");

      if (iterations >= maxIterations) {
        passwordDisplay.textContent = password;
        clearInterval(interval);
      }
      iterations++;
    }, 20);
  }

  // Shannon Entropy and honest brute-force math
  function calculateDiagnostics(password: string) {
    let entropy = 0;

    if (state.mode === 'char') {
      const uppercasePool = 26;
      const lowercasePool = 26;
      const numbersPool = 10;
      const symbolsPool = 26; // common ASCII symbols

      let poolSize = 0;
      if (state.uppercase) poolSize += uppercasePool;
      if (state.lowercase) poolSize += lowercasePool;
      if (state.numbers) poolSize += numbersPool;
      if (state.symbols) poolSize += symbolsPool;

      if (state.excludeAmbiguous) {
        // Exclude '0', 'O', 'o', '1', 'l', 'I', 'i'
        if (state.uppercase) poolSize -= 2; // O, I
        if (state.lowercase) poolSize -= 3; // o, l, i
        if (state.numbers) poolSize -= 2;    // 0, 1
      }

      if (poolSize > 0) {
        entropy = password.length * Math.log2(poolSize);
      }
    } else {
      // Passphrase mode: 512 words in dictionary -> 9 bits of entropy per word choice
      entropy = state.wordCount * Math.log2(512);
    }

    // Entropy label update
    entropyLabel.textContent = `${entropy.toFixed(1)} bits of entropy`;

    // Visual Strength Indicators & Colors
    let label = "Very Weak";
    let colorClass = "bg-brand-coral";
    let textClass = "text-coral-dark";
    let width = "15%";

    if (entropy >= 100) {
      label = "Very Strong (Ultra Secure)";
      colorClass = "bg-success-accent";
      textClass = "text-success-accent";
      width = "100%";
    } else if (entropy >= 64) {
      label = "Strong (Secure)";
      colorClass = "bg-brand-teal";
      textClass = "text-moss-dark";
      width = "75%";
    } else if (entropy >= 40) {
      label = "Moderate";
      colorClass = "bg-brand-yellow-deep";
      textClass = "text-yellow-dark";
      width = "50%";
    } else if (entropy >= 28) {
      label = "Weak";
      colorClass = "bg-brand-coral";
      textClass = "text-coral-dark";
      width = "30%";
    }

    // Set colors & labels
    strengthLabel.textContent = label;
    strengthLabel.className = `${textClass} uppercase tracking-wide`;
    strengthBar.className = `h-2.5 rounded-full ${colorClass} transition-all duration-500 ease-out`;
    strengthBar.style.width = width;

    // Crack-time estimates calculations
    // Attack model: GPU clusters doing 100 trillion (10^14) guesses per second
    const guessesPerSec = 100000000000000;
    const totalCombinations = Math.pow(2, entropy);
    const secondsToCrack = totalCombinations / guessesPerSec;

    let crackString = "Instant";
    if (secondsToCrack < 0.1) {
      crackString = "Instant (< 1 second)";
    } else if (secondsToCrack < 60) {
      crackString = `${secondsToCrack.toFixed(1)} seconds`;
    } else if (secondsToCrack < 3600) {
      crackString = `${(secondsToCrack / 60).toFixed(0)} minutes`;
    } else if (secondsToCrack < 86400) {
      crackString = `${(secondsToCrack / 3600).toFixed(0)} hours`;
    } else if (secondsToCrack < 31536000) {
      crackString = `${(secondsToCrack / 86400).toFixed(0)} days`;
    } else if (secondsToCrack < 31536000000) {
      crackString = `${(secondsToCrack / 31536000).toFixed(0)} years`;
    } else if (secondsToCrack < 31536000000000) {
      crackString = `${(secondsToCrack / 31536000000).toFixed(0)} centuries`;
    } else {
      crackString = "Unfeasible (Eons)";
    }

    crackTimeVal.textContent = crackString;
  }

  // Generate Batch Panel lists
  function updateBatchGenerator() {
    batchList.innerHTML = "";
    
    for (let i = 0; i < state.batchQty; i++) {
      const val = state.mode === 'char' ? generateRandomPassword() : generatePassphrase();
      const li = document.createElement('li');
      li.className = "py-1.5 flex items-center justify-between group/item cursor-pointer hover:bg-surface transition-colors";
      
      const textSpan = document.createElement('span');
      textSpan.className = "select-all tracking-wide break-all flex-1 pr-4";
      textSpan.textContent = val;
      
      const copyBtn = document.createElement('button');
      copyBtn.type = "button";
      copyBtn.className = "text-[9px] text-brand-blue font-bold opacity-0 group-hover/item:opacity-100 transition-opacity hover:underline shrink-0";
      copyBtn.textContent = "Copy";
      copyBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        navigator.clipboard.writeText(val);
        copyBtn.textContent = "✓ Saved";
        setTimeout(() => { copyBtn.textContent = "Copy"; }, 1500);
      });

      li.appendChild(textSpan);
      li.appendChild(copyBtn);
      
      // Clicking the li itself copies
      li.addEventListener('click', () => {
        navigator.clipboard.writeText(val);
        const prevText = textSpan.textContent;
        textSpan.textContent = "✓ Copied to clipboard!";
        textSpan.classList.add("text-success-accent");
        setTimeout(() => {
          textSpan.textContent = prevText;
          textSpan.classList.remove("text-success-accent");
        }, 1200);
      });

      batchList.appendChild(li);
    }
  }

  // Clipboard Auto-Clear Logic
  function handleClipboardClearTracking(passwordText: string) {
    if (clipboardClearTimer) clearTimeout(clipboardClearTimer);
    if (clipboardClearInterval) clearInterval(clipboardClearInterval);
    
    clipboardTimerBadge.classList.add('hidden');

    if (state.clipboardClearTimeout <= 0) return;

    let countdown = state.clipboardClearTimeout;
    clipboardTimerBadge.classList.remove('hidden');
    clipboardCountdown.textContent = countdown.toString();

    // Visual warning tick
    clipboardClearInterval = setInterval(() => {
      countdown--;
      clipboardCountdown.textContent = countdown.toString();
      if (countdown <= 0) {
        clearInterval(clipboardClearInterval!);
      }
    }, 1000) as unknown as number;

    // Clipboard override clearing action
    clipboardClearTimer = setTimeout(async () => {
      try {
        const currentClipboard = await navigator.clipboard.readText();
        // Only clear if the user hasn't copied anything else in the meantime
        if (currentClipboard === passwordText) {
          await navigator.clipboard.writeText("");
          clipboardTimerBadge.classList.add('hidden');
          
          // Flash clean confirmation tooltip
          copyToast.textContent = "Clipboard securely cleared!";
          copyToast.classList.remove('hidden');
          setTimeout(() => { copyToast.classList.add('hidden'); }, 2000);
        }
      } catch (e) {
        // Fallback: overwrite clipboard without validation if read permission is blocked
        await navigator.clipboard.writeText("");
        clipboardTimerBadge.classList.add('hidden');
      }
    }, state.clipboardClearTimeout * 1000) as unknown as number;
  }

  // Update mobile sticky bar with current password
  function updateMobileStickyBar(password: string) {
    if (mobileStickyPassword) {
      mobileStickyPassword.textContent = password;
    }
    if (mobileStickyBar) {
      mobileStickyBar.classList.remove('translate-y-full');
    }
  }

  // Master Generator runner
  function runGenerator(scrollToResult = false) {
    const password = state.mode === 'char' ? generateRandomPassword() : generatePassphrase();
    state.currentPassword = password;
    
    animateGeneratedPassword(password);
    calculateDiagnostics(password);
    updateBatchGenerator();
    updateMobileStickyBar(password);

    // On mobile: scroll to the password result section when explicitly triggered
    if (scrollToResult) {
      const resultSection = document.getElementById('password-result-section');
      if (resultSection) {
        // Small delay to let animation start first
        setTimeout(() => {
          resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
      }
    }
  }

  // Fallback copy method for non-secure contexts or permission blocks
  function fallbackCopyTextToClipboard(text: string) {
    const textArea = document.createElement("textarea");
    textArea.value = text;
    textArea.style.top = "0";
    textArea.style.left = "0";
    textArea.style.position = "fixed";
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();
    try {
      document.execCommand('copy');
    } catch (err) {
      console.warn('Fallback copy failed', err);
    }
    document.body.removeChild(textArea);
  }

  // Clipboard copying
  async function copyToClipboard() {
    const psw = state.currentPassword;
    if (!psw || psw === "Generating..." || psw.includes("Complexity")) return;

    try {
      try {
        await navigator.clipboard.writeText(psw);
      } catch (clipboardErr) {
        fallbackCopyTextToClipboard(psw);
      }
      
      // Update Copy button state to success
      const textSpan = document.getElementById('copy-btn-text');
      const iconSpan = document.getElementById('copy-btn-icon');
      if (textSpan && iconSpan) {
        textSpan.textContent = "Copied!";
        iconSpan.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>`;
      }

      // Flash quick popup
      copyToast.textContent = "✓ Copied to clipboard!";
      copyToast.classList.remove('hidden');
      
      setTimeout(() => {
        if (textSpan && iconSpan) {
          textSpan.textContent = "Copy";
          iconSpan.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" /></svg>`;
        }
        copyToast.classList.add('hidden');
      }, 1500);

      // Start security clipboard wiping routines
      handleClipboardClearTracking(psw);

    } catch (e) {
      alert("Failed to copy password. Please select and copy manually.");
    }
  }

  // --- EVENT LISTENERS REGISTRATION ---

  // Tab selections
  tabChar.addEventListener('click', () => {
    state.mode = 'char';
    saveStateToStorage();
    syncDOMFromState();
    runGenerator();
  });

  tabPassphrase.addEventListener('click', () => {
    state.mode = 'passphrase';
    saveStateToStorage();
    syncDOMFromState();
    runGenerator();
  });

  // Length slider and number input synchronization
  charLength.addEventListener('input', () => {
    state.length = parseInt(charLength.value);
    charLengthNum.value = charLength.value;
    saveStateToStorage();
    runGenerator();
  });

  charLengthNum.addEventListener('change', () => {
    let val = parseInt(charLengthNum.value);
    if (isNaN(val) || val < 6) val = 6;
    if (val > 128) val = 128;
    charLengthNum.value = val.toString();
    state.length = val;
    charLength.value = val.toString();
    saveStateToStorage();
    runGenerator();
  });

  // Checkbox pool triggers
  const checkboxes = [
    { el: chkUppercase, key: 'uppercase' },
    { el: chkLowercase, key: 'lowercase' },
    { el: chkNumbers, key: 'numbers' },
    { el: chkSymbols, key: 'symbols' },
    { el: chkExcludeAmbig, key: 'excludeAmbiguous' }
  ];

  checkboxes.forEach(chk => {
    chk.el.addEventListener('change', () => {
      // Prevent unselecting all major character pools
      if (chk.key !== 'excludeAmbiguous') {
        const anyChecked = chkUppercase.checked || chkLowercase.checked || chkNumbers.checked || chkSymbols.checked;
        if (!anyChecked) {
          chk.el.checked = true; // force keep checked
          return;
        }
      }
      
      (state as any)[chk.key] = chk.el.checked;
      saveStateToStorage();
      runGenerator();
    });
  });

  // Passphrase word count
  passphraseWords.addEventListener('input', () => {
    state.wordCount = parseInt(passphraseWords.value);
    passphraseWordsVal.textContent = passphraseWords.value;
    saveStateToStorage();
    runGenerator();
  });

  // Separator selection
  passphraseSeparator.addEventListener('change', () => {
    state.separator = passphraseSeparator.value;
    saveStateToStorage();
    runGenerator();
  });

  // Clipboard safety timer
  securityClipboardClear.addEventListener('change', () => {
    state.clipboardClearTimeout = parseInt(securityClipboardClear.value);
    saveStateToStorage();
    // Reset timer state immediately
    if (clipboardClearTimer) clearTimeout(clipboardClearTimer);
    if (clipboardClearInterval) clearInterval(clipboardClearInterval);
    clipboardTimerBadge.classList.add('hidden');
  });

  // Batch quantity triggers
  document.querySelectorAll('.btn-batch-qty').forEach(btn => {
    btn.addEventListener('click', () => {
      state.batchQty = parseInt(btn.getAttribute('data-qty') || '10');
      saveStateToStorage();
      syncDOMFromState();
      updateBatchGenerator();
    });
  });

  // Copy Batch List action
  btnCopyBatch.addEventListener('click', () => {
    const listItems = Array.from(batchList.querySelectorAll('li span')).map(span => span.textContent);
    if (listItems.length === 0) return;
    
    const blockText = listItems.join('\n');
    navigator.clipboard.writeText(blockText);
    
    const prevText = btnCopyBatch.textContent;
    btnCopyBatch.textContent = "✓ Copied List!";
    setTimeout(() => {
      btnCopyBatch.textContent = prevText;
    }, 1500);
  });

  // Action listeners — pass scrollToResult=true for explicit user-triggered generation
  btnRegenerate.addEventListener('click', () => runGenerator(true));
  btnCopy.addEventListener('click', copyToClipboard);

  // How it works modal
  const howItWorksBtn = document.getElementById('how-it-works-btn');
  const howItWorksModal = document.getElementById('how-it-works-modal');
  const closeHowItWorksBtn = document.getElementById('close-how-it-works-btn');
  const howItWorksOkBtn = document.getElementById('how-it-works-ok-btn');

  howItWorksBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.remove('hidden');
  });
  closeHowItWorksBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  howItWorksOkBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  howItWorksModal?.addEventListener('click', (e) => {
    if (e.target === howItWorksModal) {
      howItWorksModal.classList.add('hidden');
    }
  });

  // Click on generated display block copies
  passwordDisplay.addEventListener('click', copyToClipboard);

  // Mobile sticky copy button
  mobileStickyBtn?.addEventListener('click', copyToClipboard);

  // Accessible keyboards support (Spacebar regenerates, Enter copies when password display is focused)
  passwordDisplay.addEventListener('keydown', (e) => {
    if (e.key === ' ') {
      e.preventDefault(); // prevent default scroll down
      runGenerator(true);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      copyToClipboard();
    }
  });

  // Global spacebar listener on document (when focus is on body/non-input elements)
  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    const isInput = target.tagName === 'INPUT' || target.tagName === 'SELECT' || target.tagName === 'TEXTAREA' || target.isContentEditable;
    
    if (e.key === ' ' && !isInput) {
      e.preventDefault();
      runGenerator(true);
    }
  });

  // Reset to defaults
  btnResetDefaults.addEventListener('click', () => {
    // Reset all state fields to defaults
    state.mode = DEFAULT_STATE.mode;
    state.length = DEFAULT_STATE.length;
    state.uppercase = DEFAULT_STATE.uppercase;
    state.lowercase = DEFAULT_STATE.lowercase;
    state.numbers = DEFAULT_STATE.numbers;
    state.symbols = DEFAULT_STATE.symbols;
    state.excludeAmbiguous = DEFAULT_STATE.excludeAmbiguous;
    state.wordCount = DEFAULT_STATE.wordCount;
    state.separator = DEFAULT_STATE.separator;
    state.clipboardClearTimeout = DEFAULT_STATE.clipboardClearTimeout;
    state.batchQty = DEFAULT_STATE.batchQty;

    // Clear clipboard timer if active
    if (clipboardClearTimer) clearTimeout(clipboardClearTimer);
    if (clipboardClearInterval) clearInterval(clipboardClearInterval);
    clipboardTimerBadge.classList.add('hidden');

    // Clear localStorage
    try {
      localStorage.removeItem('boardtools_password_generator_state');
    } catch (e) {}

    // Sync DOM and regenerate
    syncDOMFromState();
    runGenerator(true);
  });

  // Run on mount
  loadPersistedState();
  syncDOMFromState();
  runGenerator();
</script>
