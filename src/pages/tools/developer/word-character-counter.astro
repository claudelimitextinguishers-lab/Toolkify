    'out', 'over', 'own', 'same', 'shant', 'she', 'shed', 'shell', 'shes', 'should', 'shouldnt', 'so', 'some', 'such',
    'than', 'that', 'thats', 'the', 'their', 'theirs', 'them', 'themselves', 'then', 'there', 'theres', 'these', 'they',
    'theyd', 'theyll', 'theyre', 'theyve', 'this', 'those', 'through', 'to', 'too', 'under', 'until', 'up', 'very',
    'was', 'wasnt', 'we', 'wed', 'well', 'were', 'weve', 'werent', 'what', 'whats', 'when', 'whens', 'where', 'wheres',
    'which', 'while', 'who', 'whos', 'whom', 'why', 'whys', 'with', 'wont', 'would', 'wouldnt', 'you', 'youd', 'youll',
    'youre', 'youve', 'your', 'yours', 'yourself', 'yourselves'
  ]);

  // CJK detection pattern (Chinese, Japanese, Korean characters)
  const cjkRegex = /[\u4e00-\u9faf\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af\u2f00-\u2fdf\u3005\u3007\u3011\u3012\u3013\u301c\u30fc]/g;

  // Default platform limit presets
  interface PlatformLimit {
    id: string;
    name: string;
    maxChars: number;
    pinned: boolean;
    custom?: boolean;
  }

  let platformLimits: PlatformLimit[] = [
    { id: 'twitter', name: 'Twitter/X Post', maxChars: 280, pinned: true },
    { id: 'sms', name: 'Standard SMS', maxChars: 160, pinned: true },
    { id: 'seo_meta', name: 'Meta Description', maxChars: 155, pinned: true },
    { id: 'seo_title', name: 'SEO Page Title', maxChars: 60, pinned: false },
    { id: 'reddit_title', name: 'Reddit Title', maxChars: 300, pinned: false },
    { id: 'linkedin_post', name: 'LinkedIn Post', maxChars: 3000, pinned: false }
  ];

  // WPM Configurations
  let wpmRead = 200;
  let wpmSpeak = 130;

  // State
  let lastText = "";

  // DOM elements
  const counterInput = document.getElementById('counter-input') as HTMLTextAreaElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  const fileUpload = document.getElementById('file-upload') as HTMLInputElement;
  const btnCopySummary = document.getElementById('btn-copy-summary') as HTMLButtonElement;
  const toastNotify = document.getElementById('toast-notify') as HTMLDivElement;
  const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
  const dragOverlay = document.getElementById('drag-overlay') as HTMLDivElement;

  // How it works modal
  const howItWorksBtn = document.getElementById('how-it-works-btn');
  const howItWorksModal = document.getElementById('how-it-works-modal');
  const closeModalBtn = document.getElementById('close-modal-btn');
  const modalOkBtn = document.getElementById('modal-ok-btn');

  // Sliders
  const sliderReadWpm = document.getElementById('slider-read-wpm') as HTMLInputElement;
  const sliderSpeakWpm = document.getElementById('slider-speak-wpm') as HTMLInputElement;
  const readWpmLabel = document.getElementById('read-wpm-label') as HTMLElement;
  const speakWpmLabel = document.getElementById('speak-wpm-label') as HTMLElement;

  // Counters / Stats
  const statWords = document.getElementById('stat-words') as HTMLElement;
  const statCharsAll = document.getElementById('stat-chars-all') as HTMLElement;
  const statCharsNoSpace = document.getElementById('stat-chars-no-space') as HTMLElement;
  const statSentences = document.getElementById('stat-sentences') as HTMLElement;
  const statParagraphs = document.getElementById('stat-paragraphs') as HTMLElement;
  const timeReading = document.getElementById('time-reading') as HTMLElement;
  const timeSpeaking = document.getElementById('time-speaking') as HTMLElement;

  // Sticky Bar Elements
  const stickyBar = document.getElementById('sticky-bar') as HTMLDivElement;
  const stickyWords = document.getElementById('sticky-words') as HTMLElement;
  const stickyChars = document.getElementById('sticky-chars') as HTMLElement;
  const stickyRead = document.getElementById('sticky-read') as HTMLElement;

  // Limits Container
  const limitsContainer = document.getElementById('limits-container') as HTMLDivElement;
  const customLimitName = document.getElementById('custom-limit-name') as HTMLInputElement;
  const customLimitVal = document.getElementById('custom-limit-val') as HTMLInputElement;
  const btnAddCustomLimit = document.getElementById('btn-add-custom-limit') as HTMLButtonElement;

  // Keyword Density
  const chkExcludeStopwords = document.getElementById('chk-exclude-stopwords') as HTMLInputElement;
  const keywordList = document.getElementById('keyword-list') as HTMLDivElement;

  // Animation values map for smooth tick tracking
  const currentTickerValues = {
    words: 0,
    charsAll: 0,
    charsNoSpace: 0,
    sentences: 0,
    paragraphs: 0
  };

  let limitsRendered = false;

  // Safe character count ignoring emoji representation bugs
  function getSafeCharCount(str: string): number {
    return Array.from(str).length;
  }

  // Count words with CJK convention
  function calculateWordCount(str: string): number {
    const trimmed = str.trim();
    if (!trimmed) return 0;
    
    // CJK character count
    const cjkMatches = trimmed.match(cjkRegex);
    const cjkCount = cjkMatches ? cjkMatches.length : 0;
    
    // Strip CJK to count non-CJK words
    const stripped = trimmed.replace(cjkRegex, ' ');
    const nonCjkWords = stripped.split(/\s+/).filter(w => w.length > 0).length;
    
    return cjkCount + nonCjkWords;
  }

  // Paragraph counting
  function calculateParagraphCount(str: string): number {
    if (!str.trim()) return 0;
    return str.split(/\n+/).filter(p => p.trim().length > 0).length;
  }

  // Sentence counting (supports English/CJK punctuation)
  function calculateSentenceCount(str: string): number {
    if (!str.trim()) return 0;
    // Standard English/CJK sentence regex fallback
    const standardMatches = str.match(/[^.!?ã€‚ï¼ï¼Ÿ\s][^.!?ã€‚ï¼ï¼Ÿ]*(?:[.!?ã€‚ï¼ï¼Ÿ]|\s*$)/g);
    return standardMatches ? standardMatches.length : 0;
  }

  // Load from Local Storage
  function loadState() {
    const savedText = localStorage.getItem('bt-wc-text');
    if (savedText) {
      counterInput.value = savedText;
      lastText = savedText;
    }

    const savedWpms = localStorage.getItem('bt-wc-wpms');
    if (savedWpms) {
      try {
        const { read, speak } = JSON.parse(savedWpms);
        wpmRead = read || 200;
        wpmSpeak = speak || 130;
        
        sliderReadWpm.value = wpmRead.toString();
        sliderSpeakWpm.value = wpmSpeak.toString();
        readWpmLabel.textContent = wpmRead.toString();
        speakWpmLabel.textContent = wpmSpeak.toString();
      } catch (e) {}
    }

    const savedLimits = localStorage.getItem('bt-wc-limits');
    if (savedLimits) {
      try {
        platformLimits = JSON.parse(savedLimits);
      } catch (e) {}
    }
  }

  function saveState() {
    localStorage.setItem('bt-wc-text', counterInput.value);
    localStorage.setItem('bt-wc-wpms', JSON.stringify({ read: wpmRead, speak: wpmSpeak }));
    localStorage.setItem('bt-wc-limits', JSON.stringify(platformLimits));
  }

  // Formatting utility for time duration
  function formatTime(seconds: number): string {
    if (seconds < 60) {
      return `${Math.ceil(seconds)}s`;
    }
    const mins = Math.floor(seconds / 60);
    const secs = Math.ceil(seconds % 60);
    return `${mins}m ${secs}s`;
  }

  // Linear interpolation tick animation for counter numbers
  function animateValue(targetId: string, endVal: number, key: keyof typeof currentTickerValues) {
    const startVal = currentTickerValues[key];
    if (startVal === endVal) return;
    
    const duration = 200; // ms
    const startTime = performance.now();

    function update(timestamp: number) {
      const elapsed = timestamp - startTime;
      const progress = Math.min(elapsed / duration, 1);
      // Ease out quad
      const ease = progress * (2 - progress);
      const current = Math.round(startVal + (endVal - startVal) * ease);
      
      const el = document.getElementById(targetId);
      if (el) el.textContent = current.toString();

      if (progress < 1) {
        requestAnimationFrame(update);
      } else {
        currentTickerValues[key] = endVal;
        if (el) el.textContent = endVal.toString();
      }
    }
    requestAnimationFrame(update);
  }

  // Render static structure for platform limits only when structure changes
  function renderPlatformLimitsStructure() {
    // Sort limits: pinned first, then by id/creation
    const sorted = [...platformLimits].sort((a, b) => {
      if (a.pinned && !b.pinned) return -1;
      if (!a.pinned && b.pinned) return 1;
      return 0;
    });

    limitsContainer.innerHTML = '';
    sorted.forEach(l => {
      const item = document.createElement('div');
      item.id = `limit-item-${l.id}`;
      item.className = 'p-2.5 sm:p-3 bg-canvas border border-hairline-soft rounded-lg flex flex-col gap-2 transition-all duration-300';
      item.innerHTML = `
        <div class="flex items-center justify-between">
          <div class="flex flex-col">
            <span class="text-[11px] font-bold text-primary">${l.name}</span>
            <span class="text-[9px] text-stone">Limit: ${l.maxChars} chars</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="limit-counter-val text-[10px] font-bold text-slate">
              0 / ${l.maxChars}
            </span>
            <button 
              type="button" 
              class="pin-limit-btn text-xs focus:outline-none hover:scale-115 transition-transform ${l.pinned ? 'text-brand-yellow font-bold' : 'text-stone opacity-40'}" 
              data-id="${l.id}"
              title="${l.pinned ? 'Unpin' : 'Pin'}"
            >
              â˜…
            </button>
            ${l.custom ? `
              <button 
                type="button" 
                class="delete-limit-btn text-[10px] text-stone hover:text-brand-coral cursor-pointer"
                data-id="${l.id}"
                title="Delete"
              >
                âœ•
              </button>
            ` : ''}
          </div>
        </div>
        <div class="w-full bg-surface-soft border border-hairline rounded-full h-2 overflow-hidden">
          <div class="limit-progress-bar bg-brand-blue h-full transition-all duration-300" style="width: 0%"></div>
        </div>
      `;

      // Event handlers
      const pinBtn = item.querySelector('.pin-limit-btn') as HTMLButtonElement;
      pinBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        l.pinned = !l.pinned;
        saveState();
        renderPlatformLimitsStructure();
        updatePlatformLimitsValues();
      });

      if (l.custom) {
        const delBtn = item.querySelector('.delete-limit-btn') as HTMLButtonElement;
        delBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          platformLimits = platformLimits.filter(p => p.id !== l.id);
          saveState();
          renderPlatformLimitsStructure();
          updatePlatformLimitsValues();
        });
      }

      limitsContainer.appendChild(item);
    });

    limitsRendered = true;
  }

  // Update existing platform limits in place to avoid lag
  function updatePlatformLimitsValues() {
    if (!limitsRendered) {
      renderPlatformLimitsStructure();
    }

    const currentCharCount = getSafeCharCount(counterInput.value);

    platformLimits.forEach(l => {
      const item = document.getElementById(`limit-item-${l.id}`);
      if (!item) return;

      const percentage = Math.min((currentCharCount / l.maxChars) * 100, 100);
      const nearLimit = currentCharCount >= l.maxChars * 0.85;
      const overLimit = currentCharCount > l.maxChars;

      // Update text
      const valSpan = item.querySelector('.limit-counter-val') as HTMLSpanElement;
      if (valSpan) {
        valSpan.textContent = `${currentCharCount} / ${l.maxChars}`;
        valSpan.className = `limit-counter-val text-[10px] font-bold ${overLimit ? 'text-brand-coral' : 'text-slate'}`;
      }

      // Update progress bar
      const progBar = item.querySelector('.limit-progress-bar') as HTMLDivElement;
      if (progBar) {
        progBar.style.width = `${percentage}%`;
        progBar.className = 'limit-progress-bar h-full transition-all duration-300';
        if (overLimit) {
          progBar.classList.add('bg-brand-coral');
        } else if (nearLimit) {
          progBar.classList.add('bg-brand-yellow-deep');
        } else {
          progBar.classList.add('bg-brand-blue');
        }
      }

      // Update item border class
      item.className = `p-2.5 sm:p-3 bg-canvas border rounded-lg flex flex-col gap-2 transition-all duration-300 ${overLimit ? 'border-brand-coral limit-pulse' : 'border-hairline-soft'}`;
    });
  }

  // Calculate Keyword Density
  function updateKeywordDensity() {
    const text = counterInput.value.toLowerCase();
    
    // Split on non-word characters while handling Unicode
    const words = text.match(/[\p{L}\p{N}]+/gu) || [];
    const counts: Record<string, number> = {};
    const excludeStopwords = chkExcludeStopwords.checked;

    let totalValids = 0;
    words.forEach(w => {
      if (w.length < 2) return;
      if (excludeStopwords && STOPWORDS.has(w)) return;
      
      counts[w] = (counts[w] || 0) + 1;
      totalValids++;
    });

    // Sort desc
    const sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]).slice(0, 8);

    keywordList.innerHTML = '';
    
    if (sorted.length === 0) {
      keywordList.innerHTML = `<p class="text-xs text-stone italic text-center py-6">Start typing to view word frequency...</p>`;
      return;
    }

    const maxFreq = sorted[0][1];

    sorted.forEach(([word, count]) => {
      const percentOfMax = (count / maxFreq) * 100;
      const densityPercent = ((count / (totalValids || 1)) * 100).toFixed(1);

      const bar = document.createElement('div');
      bar.className = "flex flex-col gap-1 text-[11px] animate-fade-in";
      bar.innerHTML = `
        <div class="flex items-center justify-between text-slate">
          <span class="font-mono text-primary font-semibold">${word}</span>
          <span>${count} times (${densityPercent}%)</span>
        </div>
        <div class="w-full bg-surface border border-hairline rounded-full h-1.5 overflow-hidden">
          <div class="bg-brand-teal h-full rounded-full transition-all duration-500" style="width: ${percentOfMax}%"></div>
        </div>
      `;
      keywordList.appendChild(bar);
    });
  }

  // Debounced Keyword Density to optimize typing speed
  let densityTimeout: any = null;
  function debouncedUpdateKeywordDensity() {
    clearTimeout(densityTimeout);
    densityTimeout = setTimeout(updateKeywordDensity, 150);
  }

  // Live Count cycle
  function runCalculation() {
    const text = counterInput.value;
    
    // 1. Basic Stats
    const countWords = calculateWordCount(text);
    const countCharsAll = getSafeCharCount(text);
    const countCharsNoSpace = getSafeCharCount(text.replace(/\s/g, ''));
    const countSentences = calculateSentenceCount(text);
    const countParagraphs = calculateParagraphCount(text);

    // 2. Animate counter values
    animateValue('stat-words', countWords, 'words');
    animateValue('stat-chars-all', countCharsAll, 'charsAll');
    animateValue('stat-chars-no-space', countCharsNoSpace, 'charsNoSpace');
    animateValue('stat-sentences', countSentences, 'sentences');
    animateValue('stat-paragraphs', countParagraphs, 'paragraphs');

    // 3. Time Estimations
    const readSecs = countWords > 0 ? (countWords / wpmRead) * 60 : 0;
    const speakSecs = countWords > 0 ? (countWords / wpmSpeak) * 60 : 0;
    timeReading.textContent = formatTime(readSecs);
    timeSpeaking.textContent = formatTime(speakSecs);

    // 4. Update Mobile Sticky bar
    stickyWords.textContent = countWords.toString();
    stickyChars.textContent = countCharsAll.toString();
    stickyRead.textContent = formatTime(readSecs);

    // Show/hide sticky bar based on input presence and screen size
    if (text.length > 0) {
      stickyBar.classList.remove('translate-y-full');
    } else {
      stickyBar.classList.add('translate-y-full');
    }

    // 5. Update Limits and Keywords
    updatePlatformLimitsValues();
    debouncedUpdateKeywordDensity();
    
    // Save draft
    saveState();
  }

  // Event listener hook for input
  counterInput.addEventListener('input', runCalculation);

  // WPM Slider events
  sliderReadWpm.addEventListener('input', () => {
    wpmRead = parseInt(sliderReadWpm.value);
    readWpmLabel.textContent = wpmRead.toString();
    runCalculation();
  });

  sliderSpeakWpm.addEventListener('input', () => {
    wpmSpeak = parseInt(sliderSpeakWpm.value);
    speakWpmLabel.textContent = wpmSpeak.toString();
    runCalculation();
  });

  // Reset inputs and state
  resetBtn.addEventListener('click', () => {
    counterInput.value = '';
    
    // Reset Speed Sliders
    wpmRead = 200;
    wpmSpeak = 130;
    sliderReadWpm.value = '200';
    sliderSpeakWpm.value = '130';
    readWpmLabel.textContent = '200';
    speakWpmLabel.textContent = '130';

    runCalculation();
    counterInput.focus();
  });

  // How it works modal interactions
  howItWorksBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.remove('hidden');
  });
  closeModalBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  modalOkBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  howItWorksModal?.addEventListener('click', (e) => {
    if (e.target === howItWorksModal) {
      howItWorksModal.classList.add('hidden');
    }
  });

  // Mobile Auto-Scroll on paste
  counterInput.addEventListener('paste', () => {
    if (window.innerWidth < 1024) {
      setTimeout(() => {
        const analysisPanel = document.getElementById('analysis-panel');
        if (analysisPanel) {
          analysisPanel.scrollIntoView({ behavior: 'smooth' });
        }
      }, 100);
    }
  });

  // Usability key bindings for custom limits
  customLimitName.addEventListener('keyup', (e) => {
    if (e.key === 'Enter') {
      customLimitVal.focus();
    }
  });
  customLimitVal.addEventListener('keyup', (e) => {
    if (e.key === 'Enter') {
      btnAddCustomLimit.click();
    }
  });

  // Copy Summary utility
  btnCopySummary.addEventListener('click', () => {
    const text = counterInput.value;
    const words = calculateWordCount(text);
    const charsAll = getSafeCharCount(text);
    const charsNoSpace = getSafeCharCount(text.replace(/\s/g, ''));
    const sentences = calculateSentenceCount(text);
    const paragraphs = calculateParagraphCount(text);
    const readSecs = words > 0 ? (words / wpmRead) * 60 : 0;
    const speakSecs = words > 0 ? (words / wpmSpeak) * 60 : 0;

    const summary = `--- Word & Character Analysis Report ---
Words: ${words}
Characters (with spaces): ${charsAll}
Characters (no spaces): ${charsNoSpace}
Sentences: ${sentences}
Paragraphs: ${paragraphs}
Estimated Reading Time: ${formatTime(readSecs)} (at ${wpmRead} WPM)
Estimated Speaking Time: ${formatTime(speakSecs)} (at ${wpmSpeak} WPM)
----------------------------------------`;

    navigator.clipboard.writeText(summary).then(() => {
      showToast('Summary report copied!');
    });
  });

  function showToast(msg: string) {
    toastNotify.textContent = msg;
    toastNotify.classList.add('opacity-100');
    setTimeout(() => {
      toastNotify.classList.remove('opacity-100');
    }, 2000);
  }

  // Exclude Stopwords Toggle event
  chkExcludeStopwords.addEventListener('change', debouncedUpdateKeywordDensity);

  // Add Custom limit handler
  btnAddCustomLimit.addEventListener('click', () => {
    const nameVal = customLimitName.value.trim();
    const maxVal = parseInt(customLimitVal.value);

    if (!nameVal || isNaN(maxVal) || maxVal <= 0) return;

    const newLimit: PlatformLimit = {
      id: 'custom_' + Date.now(),
      name: nameVal,
      maxChars: maxVal,
      pinned: true,
      custom: true
    };

    platformLimits.push(newLimit);
    customLimitName.value = '';
    customLimitVal.value = '';
    saveState();
    renderPlatformLimitsStructure();
    updatePlatformLimitsValues();
  });

  // File loading helper
  function handleUploadedFile(file: File) {
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      if (e.target && typeof e.target.result === 'string') {
        counterInput.value = e.target.result;
        runCalculation();
      }
    };
    reader.readAsText(file);
  }

  fileUpload.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.files && target.files[0]) {
      handleUploadedFile(target.files[0]);
    }
  });

  // Drag and Drop
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dragOverlay.classList.remove('opacity-0');
  });

  dropZone.addEventListener('dragleave', () => {
    dragOverlay.classList.add('opacity-0');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dragOverlay.classList.add('opacity-0');
    if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0]) {
      handleUploadedFile(e.dataTransfer.files[0]);
    }
  });

  // Top Share Button Event
  const shareBtn = document.getElementById('share-btn');
  shareBtn?.addEventListener('click', () => {
    const url = new URL(window.location.origin + window.location.pathname);
    if (counterInput.value) {
      url.searchParams.set("text", counterInput.value);
    }

    const shareData = {
      title: document.title || "Word & Character Counter",
      url: url.toString()
    };

    if (navigator.share) {
      navigator.share(shareData).catch((err) => {
        if (err.name !== "AbortError") {
          copyToClipboard(url.toString());
        }
      });
    } else {
      copyToClipboard(url.toString());
    }

    function copyToClipboard(text: string) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
      } else {
        fallbackCopy(text);
      }
    }

    function fallbackCopy(text: string) {
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      textArea.style.opacity = "0";
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand("copy");
        showSuccess();
      } catch (err) {
        console.error(err);
      }
      document.body.removeChild(textArea);
    }

    function showSuccess() {
      if (shareBtn) {
        const span = shareBtn.querySelector("span");
        if (span) {
          const originalText = span.textContent || "Share";
          span.textContent = "Link Copied!";
          shareBtn.classList.add("text-success-accent", "border-success-accent");
          setTimeout(() => {
            span.textContent = originalText;
            shareBtn.classList.remove("text-success-accent", "border-success-accent");
          }, 2000);
        }
      }
    }
  });

  function handleUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const text = params.get('text') || params.get('q');
    if (text !== null) {
      counterInput.value = text;
    }
  }

  // FAQ Accordion Toggle Interaction
  const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
  faqToggleButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      
      // Close other open accordions
      faqToggleButtons.forEach((otherBtn) => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute("aria-expanded", "false");
          const otherContent = otherBtn.nextElementSibling;
          if (otherContent) otherContent.classList.add("hidden");
          otherBtn.querySelector("svg")?.classList.remove("rotate-180");
        }
      });

      // Toggle current accordion
      btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
      const content = btn.nextElementSibling;
      if (content) {
        content.classList.toggle("hidden");
      }
      btn.querySelector("svg")?.classList.toggle("rotate-180");
    });
  });

  // Bootstrap
  loadState();
  handleUrlParams();
  renderPlatformLimitsStructure();
  runCalculation();
</script>
