---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Word / Character Counter";
const category = "developer";
const tier = "Developer & Text Utilities";

// SEO metadata
const pageTitle = "Word / Character Counter - Free Online Word & Character Counter";
const description = "Free online word / character counter tool. Count words, characters (with & without spaces), sentences, and paragraphs in real-time. Perfect for essays and platform character limits.";
const keywords = "Word / Character Counter, word counter, word counter online, word counter free, word counter tool, free word counter, online word counter, essay word counter, text word counter, word counter website, word counter., word counter for essays, free online word counter, website word counter, character counter, character counter online, online character counter, twitter character counter, macos character counter, chinese character counter, character counter tool, character counter with spaces, text character counter, free character counter, online character counter tool, chinese character counter free";
const canonicalUrl = "https://toolkify.com/tools/developer/word-character-counter";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage="/og/word-character-counter.png"
  ogType="website"
  hideBanner={true}
>
  <!-- FAQ Page JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How many words can this word counter process?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>This online word counter runs entirely in your web browser, meaning there are no server-side limitations. It can easily process documents containing tens of thousands of words in real-time, providing immediate results as you type or paste your text.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is the best free online word counter tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The best free online word counter tool is one that operates securely, in real-time, and offers multiple metrics. Our tool is client-side, meaning your text is never sent to a server. It provides word count, character count (with and without spaces), reading/speaking time estimates, and keyword density analytics without charge.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does the word counter mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A word counter is a text processing tool that analyzes a block of text and counts how many distinct words, characters, sentences, and paragraphs it contains. It helps writers meet specific length guidelines for publications, essays, social posts, or search engine snippets.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is word counter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A word counter is a digital utility that calculates the total number of words in a document or text input. It parses the spacing and punctuation to identify word divisions and updates its metrics instantly as changes are made.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is the best character counter tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The best character counter tool is one that is fast, accurate, handles emojis correctly, and has built-in presets for platform limits. Our tool is optimized to track character counts for Twitter, SMS, and SEO tags, keeping you compliant with all online character limits.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How many character counter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A character counter calculates the total count of all individual letters, numbers, punctuation marks, symbols, and spaces in a text string. Our character counter tracks both characters with spaces and characters without spaces to satisfy different counting guidelines.</p>"
          }
        }
      ]
    }
  </script>

  <!-- SEO WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Word & Character Counter",
      "url": "https://toolkify.com/tools/developer/word-character-counter",
      "description": "Analyze text in real-time. Get detailed statistics, speaking/reading times, keyword density, and platform limit indicators completely in your local browser sandbox.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Real-time word, character, sentence, and paragraph counting",
        "CJK character-aware counting conventions",
        "Emoji and unicode-safe character counts",
        "Adjustable reading and speaking time estimations",
        "Keyword density analysis with customizable stopword filter",
        "Interactive platform character limit meters (Twitter/X, SMS, SEO meta tag)",
        "Local auto-save draft recovery",
        "Text and markdown file upload support"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1240px] w-full mx-auto px-3 sm:px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>
        
        <div class="flex items-center gap-2">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How Word and Character Counter works"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and output"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3 h-3"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"
              ></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-3.5 sm:gap-5 items-start">
      
      <!-- Left Column: Input Field & Core Controls -->
      <div class="lg:col-span-8 flex flex-col gap-3 sm:gap-4">
        
        <div class="card-base p-3 sm:p-5 flex flex-col gap-4 relative overflow-hidden">
          <div class="absolute inset-0 dot-grid opacity-[0.04] pointer-events-none rounded-xl"></div>
          
          <div class="relative z-10 flex flex-col gap-4">
            <!-- Toolbar: Upload / Copy Summary -->
            <div class="flex flex-wrap items-center justify-between gap-3 pb-2 border-b border-hairline-soft">
              
              <!-- File Operations -->
              <div class="flex items-center gap-2">
                <label 
                  for="file-upload" 
                  class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-3 py-1.5 bg-surface hover:bg-hairline-soft border border-hairline rounded-full cursor-pointer transition-all text-charcoal"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                  </svg>
                  <span>Upload Document</span>
                </label>
                <input 
                  type="file" 
                  id="file-upload" 
                  accept=".txt,.md" 
                  class="hidden" 
                />
                <span class="text-[10px] text-stone hidden sm:inline">Supports .txt, .md (or drag & drop below)</span>
              </div>

              <!-- Action Utilities -->
              <div class="flex items-center gap-2">
                <button
                  type="button"
                  id="btn-copy-summary"
                  class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline rounded-full cursor-pointer transition-all text-brand-blue"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                  </svg>
                  <span>Copy Report</span>
                </button>
              </div>
            </div>

            <!-- Text Input Container -->
            <div 
              id="drop-zone"
              class="relative flex flex-col border border-hairline-strong rounded-xl bg-surface-soft focus-within:border-brand-blue focus-within:ring-2 focus-within:ring-brand-blue/10 transition-all duration-200"
            >
              <textarea
                id="counter-input"
                class="w-full min-h-[160px] sm:min-h-[320px] p-3 sm:p-4 font-mono text-sm bg-transparent text-primary resize-y outline-none leading-relaxed"
                placeholder="Type, paste, or drop your document here..."
                spellcheck="true"
                autofocus
              ></textarea>
              
              <!-- Drag overlay message -->
              <div id="drag-overlay" class="absolute inset-0 bg-brand-yellow/90 flex flex-col items-center justify-center gap-2 rounded-xl opacity-0 pointer-events-none transition-all duration-200 z-30">
                <span class="text-3xl">ðŸ“¥</span>
                <span class="font-display font-bold text-sm text-primary">Drop to load text file</span>
              </div>
              
              <div id="toast-notify" class="absolute top-3 right-3 bg-success-accent text-canvas text-[10px] font-bold py-1 px-2.5 rounded-md shadow-subtle opacity-0 transition-opacity duration-300 pointer-events-none z-20">
                Summary copied!
              </div>
            </div>
          </div>
        </div>

        <!-- Speaking & Reading Speed Customization Card -->
        <div class="card-base p-3 sm:p-5 flex flex-col gap-4">
