  document.addEventListener('click', () => {
    exportDropdown.classList.add('hidden');
  });

  // Share URL logic
  btnExportShare.addEventListener('click', () => {
    const orig = encodeURIComponent(originalTextarea.value);
    const chg = encodeURIComponent(changedTextarea.value);
