    statusText.textContent = "Markdown copied to clipboard!";
    setTimeout(() => statusText.textContent = "Calculated", 2000);
  });

  // Helper: Generates a standard unified diff header and diff structure
  function createDiffPatch(fileNameA, fileNameB, contentA, contentB) {
    const linesA = contentA.split(/\r?\n/);
    const linesB = contentB.split(/\r?\n/);
    let patch = `--- ${fileNameA}\n+++ ${fileNameB}\n@@ -1,${linesA.length} +1,${linesB.length} @@\n`;

    // Simple line differences for patch export
    let i = 0, j = 0;
    while (i < linesA.length || j < linesB.length) {
      if (i < linesA.length && j < linesB.length && linesA[i] === linesB[j]) {
        patch += `  ${linesA[i]}\n`;
        i++;
        j++;
      } else if (i < linesA.length && (j >= linesB.length || !linesB.includes(linesA[i]))) {
        patch += `-${linesA[i]}\n`;
        i++;
      } else if (j < linesB.length) {
        patch += `+${linesB[j]}\n`;
        j++;
      }
    }
    return patch;
  }

  // ----------------------------------------------------
  // COMPUTING & RENDERING DIFF
  // ----------------------------------------------------
  let debounceTimeout = null;

  function triggerDiff() {
    if (debounceTimeout) clearTimeout(debounceTimeout);
    
    // Show visual calculation indicator
    loadingOverlay.classList.remove('hidden');
    diffOutput.classList.add('animate-sweep');
    statusText.textContent = "Typing...";

    debounceTimeout = setTimeout(() => {
      const originalVal = originalTextarea.value;
      const changedVal = changedTextarea.value;

      // Save input texts & settings locally
      localStorage.setItem('diff-checker-original', originalVal);
      localStorage.setItem('diff-checker-changed', changedVal);
      localStorage.setItem('diff-checker-granularity', currentGranularity);
      localStorage.setItem('diff-checker-ignore-whitespace', ignoreWhitespaceCheckbox.checked);
      localStorage.setItem('diff-checker-ignore-case', ignoreCaseCheckbox.checked);

      if (!originalVal && !changedVal) {
        renderPlaceholder();
        loadingOverlay.classList.add('hidden');
        diffOutput.classList.remove('animate-sweep');
        updateStats(0, 0, 0);
        statusText.textContent = "Empty";
        return;
      }

      if (!worker) {
        initWorker();
      }

      // Post params to Web Worker
      worker.postMessage({
        original: originalVal,
        changed: changedVal,
        granularity: currentGranularity,
        ignoreWhitespace: ignoreWhitespaceCheckbox.checked,
        ignoreCase: ignoreCaseCheckbox.checked
      });

      worker.onmessage = function(e) {
        const { finalDiff } = e.data;
        renderDiff(finalDiff);
        loadingOverlay.classList.add('hidden');
        diffOutput.classList.remove('animate-sweep');
        statusText.textContent = "Calculated";
      };
    }, 150); // Small debounce for smooth typing experience
  }

  // Render placeholder message
  function renderPlaceholder() {
    diffOutput.innerHTML = `
      <div class="p-6 text-center text-slate h-full flex flex-col items-center justify-center gap-1.5">
        <span class="text-2xl">⚡</span>
        <p class="font-medium text-charcoal">Waiting for changes...</p>
        <p class="text-[10px] text-slate max-w-xs leading-relaxed">Enter content in the panels above to see real-time, high-contrast structural differences.</p>
      </div>
    `;
  }

  // Statistics updating
  function updateStats(addedCount, removedCount, unchangedCount) {
    statRemoved.textContent = removedCount;
    statAdded.textContent = addedCount;
    statUnchanged.textContent = unchangedCount;

    // Trigger update pulse animation
    statsPanel.classList.remove('pulse-active');
    void statsPanel.offsetWidth; // Trigger reflow
    statsPanel.classList.add('pulse-active');
  }

  // Render calculated diffs
  function renderDiff(diffList) {
    diffOutput.innerHTML = '';
    
    let addedCount = 0;
    let removedCount = 0;
    let unchangedCount = 0;

    // Collect stats depending on format
    diffList.forEach(item => {
      if (item.type === 'added' || item.type === 'added_with_sub') addedCount++;
      else if (item.type === 'removed' || item.type === 'removed_with_sub') removedCount++;
      else if (item.type === 'unchanged') unchangedCount++;
    });

    updateStats(addedCount, removedCount, unchangedCount);

    if (currentView === 'inline' || currentGranularity !== 'line') {
      // Inline Flow or Non-Line-Level Flow (Render single stream)
      const listContainer = document.createElement('div');
      listContainer.className = 'py-2 flex flex-col w-full';

      let lineNum = 1;
      
      if (currentGranularity === 'line') {
        diffList.forEach(item => {
          const row = document.createElement('div');
          
          if (item.type === 'removed_with_sub') {
            row.className = 'diff-line diff-line-removed';
            row.innerHTML = `<span class="diff-num">-</span><span class="diff-content">${renderIntraLineDiff(item.subDiff, 'removed')}</span>`;
          } else if (item.type === 'added_with_sub') {
            row.className = 'diff-line diff-line-added';
            row.innerHTML = `<span class="diff-num">+</span><span class="diff-content">${renderIntraLineDiff(item.subDiff, 'added')}</span>`;
          } else if (item.type === 'removed') {
            row.className = 'diff-line diff-line-removed';
            row.innerHTML = `<span class="diff-num">-</span><span class="diff-content">${escapeHTML(item.value)}</span>`;
          } else if (item.type === 'added') {
            row.className = 'diff-line diff-line-added';
            row.innerHTML = `<span class="diff-num">+</span><span class="diff-content">${escapeHTML(item.value)}</span>`;
          } else {
            row.className = 'diff-line';
            row.innerHTML = `<span class="diff-num">${lineNum++}</span><span class="diff-content">${escapeHTML(item.value)}</span>`;
          }
          listContainer.appendChild(row);
        });
      } else {
        // Word or Character inline stream rendering
        const contentArea = document.createElement('div');
        contentArea.className = 'p-4 whitespace-pre-wrap word-break';
        
        diffList.forEach(item => {
          const span = document.createElement('span');
          if (item.type === 'added') {
            span.className = 'diff-word-added px-0.5 rounded-sm';
            span.textContent = item.value;
          } else if (item.type === 'removed') {
            span.className = 'diff-word-removed px-0.5 rounded-sm';
            span.textContent = item.value;
          } else {
            span.className = 'text-slate';
            span.textContent = item.value;
          }
          contentArea.appendChild(span);
        });
        listContainer.appendChild(contentArea);
      }

      diffOutput.appendChild(listContainer);
    } else {
      // Side-by-Side (Split) Line Comparison layout
      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-2 divide-x divide-hairline-strong w-full min-w-[700px]';

      const leftSide = document.createElement('div');
      leftSide.className = 'flex flex-col';
      const rightSide = document.createElement('div');
      rightSide.className = 'flex flex-col';

      let leftLineNum = 1;
      let rightLineNum = 1;

      // Myers aligned display
      let i = 0;
      while (i < diffList.length) {
        const item = diffList[i];

        if (item.type === 'removed_with_sub') {
          // Look ahead to check if the next is an added line
          const nextItem = diffList[i + 1];
          if (nextItem && nextItem.type === 'added_with_sub') {
            const leftRow = createDiffRow('-', renderIntraLineDiff(item.subDiff, 'removed'), 'diff-line-removed');
            const rightRow = createDiffRow('+', renderIntraLineDiff(nextItem.subDiff, 'added'), 'diff-line-added');
            leftSide.appendChild(leftRow);
            rightSide.appendChild(rightRow);
            i += 2;
          } else {
            const leftRow = createDiffRow('-', escapeHTML(item.value), 'diff-line-removed');
            const rightRow = createEmptyRow();
            leftSide.appendChild(leftRow);
            rightSide.appendChild(rightRow);
            i++;
          }
        } else if (item.type === 'removed') {
          const leftRow = createDiffRow('-', escapeHTML(item.value), 'diff-line-removed');
          const rightRow = createEmptyRow();
          leftSide.appendChild(leftRow);
          rightSide.appendChild(rightRow);
          i++;
        } else if (item.type === 'added_with_sub') {
          const leftRow = createEmptyRow();
          const rightRow = createDiffRow('+', renderIntraLineDiff(item.subDiff, 'added'), 'diff-line-added');
          leftSide.appendChild(leftRow);
          rightSide.appendChild(rightRow);
          i++;
        } else if (item.type === 'added') {
          const leftRow = createEmptyRow();
          const rightRow = createDiffRow('+', escapeHTML(item.value), 'diff-line-added');
          leftSide.appendChild(leftRow);
          rightSide.appendChild(rightRow);
          i++;
        } else {
          // Unchanged
          const leftRow = createDiffRow(leftLineNum++, escapeHTML(item.value));
          const rightRow = createDiffRow(rightLineNum++, escapeHTML(item.value));
          leftSide.appendChild(leftRow);
          rightSide.appendChild(rightRow);
          i++;
        }
      }

      grid.appendChild(leftSide);
      grid.appendChild(rightSide);
      diffOutput.appendChild(grid);
    }
  }

  // Create an aligned side-by-side cell row
  function createDiffRow(lineLabel, innerHtml, className = '') {
    const row = document.createElement('div');
    row.className = `diff-line ${className}`;
    row.innerHTML = `<span class="diff-num">${lineLabel}</span><span class="diff-content">${innerHtml}</span>`;
    return row;
  }

  // Create empty balance block
  function createEmptyRow() {
    const row = document.createElement('div');
    row.className = 'diff-line diff-line-empty';
    row.innerHTML = `<span class="diff-num">&nbsp;</span><span class="diff-content">&nbsp;</span>`;
    return row;
  }

  // Highlight word modifications within a line
  function renderIntraLineDiff(wordDiffList, type) {
    let result = '';
    wordDiffList.forEach(w => {
      if (w.type === 'unchanged') {
        result += escapeHTML(w.value);
      } else if (w.type === type) {
        const spanClass = type === 'added' ? 'diff-word-added' : 'diff-word-removed';
        result += `<span class="${spanClass}">${escapeHTML(w.value)}</span>`;
      }
    });
    return result;
  }

  // Escape HTML tags to prevent custom injected markup issues
  function escapeHTML(str) {
    if (!str) return '';
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  // ----------------------------------------------------
  // RESTORE SAVED STATE (LOCAL STORAGE / HASH PARSER)
  // ----------------------------------------------------
  function restoreState() {
    // Check URL Hash first (shareable links)
    const hash = window.location.hash;
    if (hash && hash.startsWith('#diff-')) {
      try {
        const parts = hash.split('-');
        if (parts.length >= 5) {
          const granularity = parts[1];
          const view = parts[2];
          
          // Reconstruct the rest as encoded values
          // Hash schema: #diff-[granularity]-[view]-[orig]-[chg]
          const origIdx = hash.indexOf(`-${view}-`) + view.length + 2;
          const remaining = hash.substring(origIdx);
          const splitPoint = remaining.indexOf('-%25'); // search separator
          
          let origEncoded = remaining;
          let chgEncoded = '';
          
          // We can parse splitting by URL decoding
          const decodedRemaining = decodeURIComponent(remaining);
          
          // Safer fallback split
          const partsDecoded = decodedRemaining.split('-');
          if (partsDecoded.length >= 2) {
            const halfLength = Math.floor(partsDecoded.length / 2);
            originalTextarea.value = partsDecoded.slice(0, halfLength).join('-');
            changedTextarea.value = partsDecoded.slice(halfLength).join('-');
          } else {
            originalTextarea.value = decodeURIComponent(parts[3] || '');
            changedTextarea.value = decodeURIComponent(parts[4] || '');
          }

          currentGranularity = granularity;
          currentView = view;
          
          // Style active tab
          granularityTabs.forEach(t => {
            if (t.getAttribute('data-granularity') === currentGranularity) {
              t.classList.add('bg-primary', 'text-canvas', 'shadow-sm');
              t.classList.remove('text-slate', 'hover:text-primary');
            } else {
              t.classList.remove('bg-primary', 'text-canvas', 'shadow-sm');
              t.classList.add('text-slate', 'hover:text-primary');
            }
          });
          updateViewTabStyles();
          triggerDiff();
          return;
        }
      } catch (err) {
        console.error("Failed to parse shareable link URL hash parameters", err);
      }
    }

    // Fallback: Restore from Local Storage
    const savedOriginal = localStorage.getItem('diff-checker-original');
    const savedChanged = localStorage.getItem('diff-checker-changed');
    const savedGranularity = localStorage.getItem('diff-checker-granularity');
    const savedIgnoreWhitespace = localStorage.getItem('diff-checker-ignore-whitespace');
    const savedIgnoreCase = localStorage.getItem('diff-checker-ignore-case');

    if (savedOriginal !== null) originalTextarea.value = savedOriginal;
    if (savedChanged !== null) changedTextarea.value = savedChanged;
    if (savedGranularity !== null) {
      currentGranularity = savedGranularity;
      granularityTabs.forEach(t => {
        if (t.getAttribute('data-granularity') === currentGranularity) {
          t.classList.add('bg-primary', 'text-canvas', 'shadow-sm');
          t.classList.remove('text-slate', 'hover:text-primary');
        } else {
          t.classList.remove('bg-primary', 'text-canvas', 'shadow-sm');
          t.classList.add('text-slate', 'hover:text-primary');
        }
      });
    }
    if (savedIgnoreWhitespace !== null) ignoreWhitespaceCheckbox.checked = (savedIgnoreWhitespace === 'true');
    if (savedIgnoreCase !== null) ignoreCaseCheckbox.checked = (savedIgnoreCase === 'true');

    // Default sample texts if completely empty
    if (!originalTextarea.value && !changedTextarea.value) {
      originalTextarea.value = SAMPLES.original;
      changedTextarea.value = SAMPLES.changed;
    }

    triggerDiff();
  }

  // ----------------------------------------------------
  // HOW IT WORKS MODAL
  // ----------------------------------------------------
  const howItWorksBtn = document.getElementById('how-it-works-btn');
  const howItWorksModal = document.getElementById('how-it-works-modal');
  const closeHowItWorksBtn = document.getElementById('close-how-it-works-btn');
  const howItWorksOkBtn = document.getElementById('how-it-works-ok-btn');

  howItWorksBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.remove('hidden');
  });
  closeHowItWorksBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  howItWorksOkBtn?.addEventListener('click', () => {
    howItWorksModal?.classList.add('hidden');
  });
  howItWorksModal?.addEventListener('click', (e) => {
    if (e.target === howItWorksModal) {
      howItWorksModal.classList.add('hidden');
    }
  });

  // ----------------------------------------------------
  // AUTO-SCROLL TO DIFF OUTPUT
  // Scrolls to the diff output section once both inputs have content,
  // with scroll-margin-top offset to prevent content hiding behind navbar.
  // ----------------------------------------------------
  let hasAutoScrolled = false;

  function maybeAutoScroll() {
    const hasOriginal = originalTextarea.value.trim().length > 0;
    const hasChanged = changedTextarea.value.trim().length > 0;

    if (hasOriginal && hasChanged && !hasAutoScrolled) {
      hasAutoScrolled = true;
      // Use a small delay so the diff output has rendered first
      setTimeout(() => {
        const target = document.getElementById('diff-output-section');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }, 200);
    }

    // Reset the flag if both inputs are cleared so it can scroll again next time
    if (!hasOriginal && !hasChanged) {
      hasAutoScrolled = false;
    }
  }

  originalTextarea.addEventListener('input', maybeAutoScroll);
  changedTextarea.addEventListener('input', maybeAutoScroll);

  // Start state restoration on page load
  restoreState();
</script>
