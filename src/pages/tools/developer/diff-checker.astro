  // Copy Markdown format
  btnExportMd.addEventListener('click', () => {
    const orig = originalTextarea.value;
    const chg = changedTextarea.value;
    const md = `### Text Diff Comparison\n\n**Deletions**\n\`\`\`diff\n- ${orig.split('\n').join('\n- ')}\n\`\`\`\n\n**Insertions**\n\`\`\`diff\n+ ${chg.split('\n').join('\n+ ')}\n\`\`\``;
