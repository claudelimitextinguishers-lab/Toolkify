  // File uploading readers
  fileOriginal.addEventListener('change', (e) => handleFileUpload(e, originalTextarea));
  fileChanged.addEventListener('change', (e) => handleFileUpload(e, changedTextarea));

  function handleFileUpload(e, textarea) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (evt) => {
      textarea.value = evt.target.result;
      triggerDiff();
