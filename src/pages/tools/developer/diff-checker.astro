---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Text Diff Checker";
const category = "developer";
const tier = "Developer & Text Utilities";
const description = "Compare two texts or files side-by-side or inline. Highlight character, word, or line-level changes instantly with 100% private client-side diffing.";

// SEO Metadata
const pageTitle = "Text Diff Checker - Side-by-Side File & Text Comparison";
const keywords = "diff checker, text compare, compare files, side by side diff, online diff, word diff, line diff, character diff, text comparator, file diff, web diff tool";
const canonicalUrl = "https://boardtools.app/tools/developer/diff-checker";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  hideBanner={true}
>
  <!-- SEO JSON-LD WebApplication Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Text Diff Checker",
      "alternateName": "Client-Side Diff & File Comparator",
      "url": "https://boardtools.app/tools/developer/diff-checker",
      "description": "Free online client-side text diff checker. Compare two text files or strings side-by-side or inline with character, word, and line level highlights.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript.",
      "featureList": [
        "Side-by-side and inline comparison views",
        "Granular diffing: character, word, and line level highlights",
        "Drag & drop upload of text, JSON, Markdown, CSV files",
        "Ignore whitespace and letter-case toggles",
        "Instant swap inputs button",
        "Generates standard .diff/.patch files and shareable links",
        "100% secure client-side processing using Web Workers"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1400px] w-full mx-auto px-4 md:px-8 py-6 flex flex-col gap-6 animate-fade-in pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="btn-reset"
            class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset inputs and clear diff"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
            </svg>
            <span>Reset</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How Diff Checker works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>How it works</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Main Diff Workspace -->
    <div class="card-base p-4 sm:p-6 flex flex-col gap-6 bg-canvas border border-hairline-soft shadow-sm rounded-xl">
      <!-- Toolbar / Settings Controls -->
      <div class="flex flex-col gap-3 pb-4 border-b border-hairline-soft">
        <!-- Row 1: Granularity + Diff Modifiers -->
        <div class="flex flex-wrap items-center gap-3">
          <!-- Granularity Tabs -->
          <div class="flex rounded-full bg-surface p-1 border border-hairline shrink-0">
            <button
              type="button"
              data-granularity="line"
              class="granularity-tab px-3 py-1 text-xs rounded-full font-medium transition-all cursor-pointer bg-primary text-canvas shadow-sm"
            >
              Line
            </button>
            <button
              type="button"
              data-granularity="word"
              class="granularity-tab px-3 py-1 text-xs rounded-full font-medium transition-all cursor-pointer text-slate hover:text-primary"
            >
              Word
            </button>
            <button
              type="button"
              data-granularity="char"
              class="granularity-tab px-3 py-1 text-xs rounded-full font-medium transition-all cursor-pointer text-slate hover:text-primary"
            >
              Char
            </button>
          </div>

          <!-- Diff Modifiers -->
          <div class="flex flex-wrap items-center gap-3 text-xs font-medium text-slate">
            <label class="flex items-center gap-1.5 cursor-pointer select-none">
              <input type="checkbox" id="chk-whitespace" class="rounded border-hairline-strong text-brand-blue focus:ring-brand-blue w-3.5 h-3.5" checked />
              <span>Ignore Whitespace</span>
            </label>
            <label class="flex items-center gap-1.5 cursor-pointer select-none">
              <input type="checkbox" id="chk-case" class="rounded border-hairline-strong text-brand-blue focus:ring-brand-blue w-3.5 h-3.5" />
              <span>Ignore Case</span>
            </label>
          </div>
        </div>

        <!-- Row 2: View Toggle + Export (full-width on mobile, right-aligned on desktop) -->
        <div class="flex flex-wrap items-center gap-2 sm:justify-end">
          <!-- View Tabs -->
          <div class="flex rounded-full bg-surface p-1 border border-hairline shrink-0">
            <button
              type="button"
              id="btn-view-split"
              class="view-tab px-3 py-1 text-xs rounded-full font-medium transition-all cursor-pointer bg-primary text-canvas shadow-sm"
            >
              Side-by-Side
            </button>
            <button
              type="button"
              id="btn-view-inline"
              class="view-tab px-3 py-1 text-xs rounded-full font-medium transition-all cursor-pointer text-slate hover:text-primary"
            >
              Inline
            </button>
          </div>

          <!-- Export & Share dropdown -->
          <div class="relative shrink-0" id="export-container">
            <button
              type="button"
              id="btn-export-dropdown"
              class="inline-flex items-center gap-1 text-xs font-semibold px-3 py-1.5 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-sm whitespace-nowrap"
            >
              <span>Export & Share ▼</span>
            </button>
            <div id="export-dropdown" class="hidden absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-canvas border border-hairline ring-1 ring-black/5 z-10">
              <div class="py-1" role="menu">
                <button id="btn-export-share" class="w-full text-left px-4 py-2 text-xs text-slate hover:bg-surface hover:text-primary font-medium" role="menuitem">🔗 Copy Shareable Link</button>
                <button id="btn-export-patch" class="w-full text-left px-4 py-2 text-xs text-slate hover:bg-surface hover:text-primary font-medium" role="menuitem">💾 Download .diff Patch</button>
                <button id="btn-export-md" class="w-full text-left px-4 py-2 text-xs text-slate hover:bg-surface hover:text-primary font-medium" role="menuitem">📝 Copy as Markdown</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Comparison Input Panels -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="input-panels-container">
        <!-- Original Side -->
        <div class="flex flex-col gap-2 relative">
          <div class="flex items-center justify-between text-xs font-semibold text-charcoal">
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-brand-coral"></span>
              Original Text (Left)
            </span>
            <div class="flex items-center gap-2">
              <button id="btn-sample-1" class="text-[10px] text-brand-blue hover:underline cursor-pointer">Load Sample</button>
              <label class="text-[10px] text-brand-blue hover:underline cursor-pointer">
                Upload File
                <input type="file" id="file-original" class="hidden" accept=".txt,.md,.json,.csv,.xml,.js,.ts,.html,.css" />
              </label>
            </div>
          </div>
          <div class="relative drop-zone group" id="drop-zone-original">
            <textarea
              id="txt-original"
              class="w-full min-h-[180px] md:min-h-[260px] p-3 text-xs bg-canvas text-ink border border-hairline-strong rounded-lg font-mono focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue leading-relaxed resize-y"
              placeholder="Paste original content or drag file here..."
            ></textarea>
            <div class="pointer-events-none absolute inset-0 bg-brand-blue/5 border-2 border-dashed border-brand-blue rounded-lg flex items-center justify-center opacity-0 group-[.dragover]:opacity-100 transition-opacity">
              <span class="text-xs font-bold text-brand-blue">Drop file here!</span>
            </div>
          </div>
        </div>

        <!-- Changed Side -->
        <div class="flex flex-col gap-2 relative">
          <div class="flex items-center justify-between text-xs font-semibold text-charcoal">
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-success-accent"></span>
              Modified Text (Right)
            </span>
            <div class="flex items-center gap-2">
              <button id="btn-sample-2" class="text-[10px] text-brand-blue hover:underline cursor-pointer">Load Sample</button>
              <label class="text-[10px] text-brand-blue hover:underline cursor-pointer">
                Upload File
                <input type="file" id="file-changed" class="hidden" accept=".txt,.md,.json,.csv,.xml,.js,.ts,.html,.css" />
              </label>
            </div>
          </div>
          <div class="relative drop-zone group" id="drop-zone-changed">
            <textarea
              id="txt-changed"
              class="w-full min-h-[180px] md:min-h-[260px] p-3 text-xs bg-canvas text-ink border border-hairline-strong rounded-lg font-mono focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue leading-relaxed resize-y"
              placeholder="Paste changed content or drag file here..."
            ></textarea>
            <div class="pointer-events-none absolute inset-0 bg-brand-blue/5 border-2 border-dashed border-brand-blue rounded-lg flex items-center justify-center opacity-0 group-[.dragover]:opacity-100 transition-opacity">
              <span class="text-xs font-bold text-brand-blue">Drop file here!</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats Summary -->
      <div id="stats-panel" class="grid grid-cols-3 gap-3 p-3 bg-surface rounded-lg border border-hairline transition-all">
        <div class="flex flex-col items-center justify-center py-2 text-center">
          <span class="text-[10px] font-bold text-slate uppercase tracking-wider">Deletions</span>
          <span id="stat-removed" class="text-lg font-display font-semibold text-coral-dark mt-0.5">0</span>
        </div>
        <div class="flex flex-col items-center justify-center py-2 text-center border-x border-hairline">
          <span class="text-[10px] font-bold text-slate uppercase tracking-wider">Insertions</span>
          <span id="stat-added" class="text-lg font-display font-semibold text-moss-dark mt-0.5">0</span>
        </div>
        <div class="flex flex-col items-center justify-center py-2 text-center">
          <span class="text-[10px] font-bold text-slate uppercase tracking-wider">Unchanged</span>
          <span id="stat-unchanged" class="text-lg font-display font-semibold text-slate mt-0.5">0</span>
        </div>
      </div>

      <!-- Diff Output Result View -->
      <div class="flex flex-col gap-2" id="diff-output-section">
        <div class="flex items-center justify-between text-xs font-semibold text-charcoal">
          <span>Diff Output</span>
          <span id="status-text" class="text-[10px] text-slate font-medium">Ready</span>
        </div>
        <div class="relative rounded-lg overflow-hidden border border-hairline-strong bg-surface-soft min-h-[160px] flex flex-col">
          <!-- Loading Sweep Overlay -->
          <div id="loading-overlay" class="hidden absolute inset-0 bg-canvas/60 z-10 flex items-center justify-center">
            <div class="flex flex-col items-center gap-2">
              <div class="w-6 h-6 border-2 border-brand-blue border-t-transparent rounded-full animate-spin"></div>
              <span class="text-[10px] font-semibold text-slate">Calculating diffs...</span>
            </div>
          </div>
          
          <!-- Code view wrapper -->
          <div class="overflow-x-auto w-full flex-grow font-mono text-xs leading-relaxed select-text" id="diff-output-container">
            <!-- Populated via script -->
            <div class="p-6 text-center text-slate h-full flex flex-col items-center justify-center gap-1.5">
              <span class="text-2xl">⚡</span>
              <p class="font-medium text-charcoal">Waiting for changes...</p>
              <p class="text-[10px] text-slate max-w-xs leading-relaxed">Enter content in the panels above to see real-time, high-contrast structural differences.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </section>
  <!-- How it Works Modal -->
  <div
    id="how-it-works-modal"
    class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
  >
    <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto">
      <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
        <h3 class="font-display font-semibold text-lg text-primary">Text Diff Checker Guide</h3>
        <button
          type="button"
          id="close-how-it-works-btn"
          class="text-stone hover:text-primary transition-all text-lg cursor-pointer"
        >✕</button>
      </div>

      <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
        <h4 class="font-semibold text-primary">1. How does it work?</h4>
        <p>
          This tool runs <strong>entirely inside your browser</strong> using a Web Worker sandbox. Your text is never sent to any server — all diffing is computed locally, making it safe for private code, configs, and sensitive documents.
        </p>

        <h4 class="font-semibold text-primary">2. Diff Granularity</h4>
        <ul class="list-disc pl-4 flex flex-col gap-1.5 mt-1">
          <li><strong>Line</strong>: Highlights entire lines that were added, removed, or changed. Shows intra-line word highlights for modified lines.</li>
          <li><strong>Word</strong>: Streams all tokens and highlights individual word-level insertions and deletions inline.</li>
          <li><strong>Character</strong>: Highlights every individual character change for maximum precision.</li>
        </ul>

        <h4 class="font-semibold text-primary">3. View Modes</h4>
        <p>
          Use <strong>Side-by-Side</strong> on desktop for a classic visual layout comparison. Switch to <strong>Inline</strong> mode on mobile or when you want a single unified diff stream with +/- markers.
        </p>

        <h4 class="font-semibold text-primary">4. Export & Share</h4>
        <p>
          Use the <strong>Export & Share</strong> menu to copy a shareable URL (encodes both texts into the browser hash), download a standard <code>.diff</code> patch file, or copy the diff as Markdown.
        </p>
      </div>

      <button
        type="button"
        id="how-it-works-ok-btn"
        class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
      >
        Got it
      </button>
    </div>
  </div>

</Layout>

<style is:global>
  /* Custom Highlighting Styles */
  .diff-line {
    display: flex;
    width: 100%;
    min-width: max-content;
  }
  .diff-num {
    width: 3.5rem;
    flex-shrink: 0;
    text-align: right;
    padding-right: 0.75rem;
    color: var(--color-stone, #8e91a0);
    user-select: none;
    border-right: 1px solid var(--color-hairline, #e0e2e8);
    font-size: 11px;
    background-color: var(--color-surface, #f7f8fa);
  }
  .diff-content {
    flex-grow: 1;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    white-space: pre-wrap;
    word-break: break-all;
  }
  
  /* Added Lines */
  .diff-line-added {
    background-color: rgba(0, 180, 115, 0.08);
  }
  .diff-line-added .diff-num {
    background-color: rgba(0, 180, 115, 0.12);
    color: #137333;
    border-right-color: rgba(0, 180, 115, 0.2);
  }
  .diff-word-added {
    background-color: rgba(0, 180, 115, 0.22);
    border-bottom: 1px dashed rgba(0, 180, 115, 0.5);
    color: #0b5f2a;
    font-weight: 500;
  }

  /* Removed Lines */
  .diff-line-removed {
    background-color: rgba(255, 153, 153, 0.08);
  }
  .diff-line-removed .diff-num {
    background-color: rgba(255, 153, 153, 0.12);
    color: #a82020;
    border-right-color: rgba(255, 153, 153, 0.2);
  }
  .diff-word-removed {
    background-color: rgba(255, 153, 153, 0.22);
    text-decoration: line-through;
    color: #7a1515;
    font-weight: 500;
  }

  /* Empty placeholder lines to balance side-by-side */
  .diff-line-empty {
    background-color: var(--color-hairline-soft, #eef0f3);
    opacity: 0.5;
  }
  .diff-line-empty .diff-num {
    background-color: var(--color-hairline-soft, #eef0f3);
    border-right-color: var(--color-hairline, #e0e2e8);
  }

  /* Sweep calculation effect */
  @keyframes sweep {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }
  .animate-sweep::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(to bottom, transparent, rgba(66, 98, 255, 0.1) 50%, transparent);
    animation: sweep 1.5s ease-in-out infinite;
    pointer-events: none;
  }

  /* Pulse for stats */
  @keyframes stats-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); background-color: var(--color-surface-yellow, #fff8e0); }
  }
  .pulse-active {
    animation: stats-pulse 0.4s ease-out;
  }

  /* Ensure auto-scroll target clears the sticky navbar */
  #diff-output-section {
    scroll-margin-top: 4.5rem;
  }
</style>

<script is:inline>
  // ----------------------------------------------------
  // INLINE WEB WORKER DEFINITION (Myers' algorithm & tokenizer)
  // ----------------------------------------------------
  const workerBlobCode = `
    self.onmessage = function(e) {
      const { original, changed, granularity, ignoreWhitespace, ignoreCase } = e.data;

      // Normalize comparison string based on settings
      function normalize(str) {
        let s = str || '';
        if (ignoreWhitespace) {
          s = s.trim().replace(/\\s+/g, ' ');
        }
        if (ignoreCase) {
          s = s.toLowerCase();
        }
        return s;
      }

      function compare(a, b) {
        return normalize(a) === normalize(b);
      }

      // Tokenizer
      function tokenize(text, mode) {
        if (mode === 'char') {
          return Array.from(text);
        } else if (mode === 'word') {
          // Tokenize words, punctuation, spaces
          return text.match(/[\\w\\d\\u00C0-\\u00FF]+|[^\\w\\d\\s\\u00C0-\\u00FF]+|\\s+/g) || [];
        } else {
          // Split by line (keeping newlines inside tokens is not needed since we work line-by-line)
          return text.split(/\\r?\\n/);
        }
      }

      // Fast Myers' Diff Algorithm with common prefix/suffix optimization
      function getDiff(A, B) {
        // Strip common prefix
        let start = 0;
        while (start < A.length && start < B.length && compare(A[start], B[start])) {
          start++;
        }

        // Strip common suffix
        let endA = A.length - 1;
        let endB = B.length - 1;
        while (endA >= start && endB >= start && compare(A[endA], B[endB])) {
          endA--;
          endB--;
        }

        const prefix = A.slice(0, start).map(val => ({ value: val, type: 'unchanged' }));
        const suffix = A.slice(endA + 1).map(val => ({ value: val, type: 'unchanged' }));

        const subA = A.slice(start, endA + 1);
        const subB = B.slice(start, endB + 1);

        const core = myersDiffSub(subA, subB);

        return [...prefix, ...core, ...suffix];
      }

      function myersDiffSub(A, B) {
        const N = A.length;
        const M = B.length;

        if (N === 0) return B.map(val => ({ value: val, type: 'added' }));
        if (M === 0) return A.map(val => ({ value: val, type: 'removed' }));

        const MAX = N + M;
        // Cap MAX distance to prevent hangs on extremely divergent large inputs
        const limitD = Math.min(MAX, 1200);

        const V = new Int32Array(2 * limitD + 1);
        const offset = limitD;
        V[offset + 1] = 0;

        const paths = [];
        let found = false;
        let x = 0;
        let y = 0;

        outer: for (let d = 0; d <= limitD; d++) {
          paths.push(new Int32Array(V));

          for (let k = -d; k <= d; k += 2) {
            const idx = offset + k;
            if (k === -d || (k !== d && V[idx - 1] < V[idx + 1])) {
              x = V[idx + 1];
            } else {
              x = V[idx - 1] + 1;
            }
            y = x - k;

            while (x < N && y < M && compare(A[x], B[y])) {
              x++;
              y++;
            }

            V[idx] = x;

            if (x >= N && y >= M) {
              found = true;
              break outer;
            }
          }
        }

        if (!found) {
          // Fallback if limit was reached: mark all A as deleted, all B as added
          return [
            ...A.map(val => ({ value: val, type: 'removed' })),
            ...B.map(val => ({ value: val, type: 'added' }))
          ];
        }

        // Reconstruct path
        const result = [];
        let currX = N;
        let currY = M;

        for (let d = paths.length - 1; d >= 0; d--) {
          const V_d = paths[d];
          const k = currX - currY;
          const idx = offset + k;

          let prevK;
          if (k === -d || (k !== d && V_d[idx - 1] < V_d[idx + 1])) {
            prevK = k + 1;
          } else {
            prevK = k - 1;
          }

          const prevX = V_d[offset + prevK];
          const prevY = prevX - prevK;

          while (currX > prevX && currY > prevY) {
            result.push({ value: A[currX - 1], type: 'unchanged' });
            currX--;
            currY--;
          }

          if (currX > prevX) {
            result.push({ value: A[currX - 1], type: 'removed' });
            currX--;
          } else if (currY > prevY) {
            result.push({ value: B[currY - 1], type: 'added' });
            currY--;
          }
        }

        return result.reverse();
      }

      // Perform computation
      const tokensA = tokenize(original, granularity);
      const tokensB = tokenize(changed, granularity);
      const rawDiff = getDiff(tokensA, tokensB);

      // Perform intra-line character/word highlight alignment if granularity is 'line'
      let finalDiff = rawDiff;
      if (granularity === 'line') {
        finalDiff = [];
        let i = 0;
        while (i < rawDiff.length) {
          // Look for adjacent pairs of (removed, added) lines to show internal word diffs
          if (i < rawDiff.length - 1 && rawDiff[i].type === 'removed' && rawDiff[i+1].type === 'added') {
            const lineDel = rawDiff[i].value;
            const lineAdd = rawDiff[i+1].value;

            // Compute sub-diff inside this pair at the word level
            const subTokensDel = tokenize(lineDel, 'word');
            const subTokensAdd = tokenize(lineAdd, 'word');

            // Strip prefix/suffix for speed
            let sStart = 0;
            while (sStart < subTokensDel.length && sStart < subTokensAdd.length && subTokensDel[sStart] === subTokensAdd[sStart]) {
              sStart++;
            }
            let sEndDel = subTokensDel.length - 1;
            let sEndAdd = subTokensAdd.length - 1;
            while (sEndDel >= sStart && sEndAdd >= sStart && subTokensDel[sEndDel] === subTokensAdd[sEndAdd]) {
              sEndDel--;
              sEndAdd--;
            }

            const prefix = subTokensDel.slice(0, sStart).map(v => ({ value: v, type: 'unchanged' }));
            const suffix = subTokensDel.slice(sEndDel + 1).map(v => ({ value: v, type: 'unchanged' }));
            const delWords = subTokensDel.slice(sStart, sEndDel + 1);
            const addWords = subTokensAdd.slice(sStart, sEndAdd + 1);
            
            const centerWords = myersDiffSub(delWords, addWords);
            const wordDiff = [...prefix, ...centerWords, ...suffix];

            finalDiff.push({
              type: 'removed_with_sub',
              value: lineDel,
              subDiff: wordDiff
            });
            finalDiff.push({
              type: 'added_with_sub',
              value: lineAdd,
              subDiff: wordDiff
            });

            i += 2;
          } else {
            finalDiff.push(rawDiff[i]);
            i++;
          }
        }
      }

      self.postMessage({ finalDiff });
    };
  `;

  // Instantiate worker
  let worker = null;
  function initWorker() {
    try {
      const blob = new Blob([workerBlobCode], { type: 'application/javascript' });
      worker = new Worker(URL.createObjectURL(blob));
    } catch (err) {
      console.error('Failed to initialize Web Worker:', err);
    }
  }
  initWorker();

  // ----------------------------------------------------
  // SAMPLES & INITIAL STATE
  // ----------------------------------------------------
  const SAMPLES = {
    original: `function computeMetrics(data) {
  // Compute sum
  let sum = 0;
  for (let i = 0; i < data.length; i++) {
    sum += data[i];
  }

  const average = sum / data.length;
  console.log("Calculated avg: " + average);
  return { sum, average };
}`,
    changed: `function computeMetrics(data) {
  if (!data || data.length === 0) {
    return { sum: 0, average: 0 };
  }

  // Calculate sum using reduce
  const sum = data.reduce((acc, val) => acc + val, 0);

  const average = sum / data.length;
  console.warn("Calculated average: " + average);
  return { sum, average, count: data.length };
}`
  };

  // State elements
  const originalTextarea = document.getElementById('txt-original');
  const changedTextarea = document.getElementById('txt-changed');
  const ignoreWhitespaceCheckbox = document.getElementById('chk-whitespace');
  const ignoreCaseCheckbox = document.getElementById('chk-case');
  const diffOutput = document.getElementById('diff-output-container');
  const statusText = document.getElementById('status-text');
  const loadingOverlay = document.getElementById('loading-overlay');
  
  // Stats elements
  const statRemoved = document.getElementById('stat-removed');
  const statAdded = document.getElementById('stat-added');
  const statUnchanged = document.getElementById('stat-unchanged');
  const statsPanel = document.getElementById('stats-panel');

  // Control tabs & buttons
  const granularityTabs = document.querySelectorAll('.granularity-tab');
  const viewSplitBtn = document.getElementById('btn-view-split');
  const viewInlineBtn = document.getElementById('btn-view-inline');
  const resetBtn = document.getElementById('btn-reset');

  // Files
  const fileOriginal = document.getElementById('file-original');
  const fileChanged = document.getElementById('file-changed');

  // Export
  const btnExportDropdown = document.getElementById('btn-export-dropdown');
  const exportDropdown = document.getElementById('export-dropdown');
  const btnExportShare = document.getElementById('btn-export-share');
  const btnExportPatch = document.getElementById('btn-export-patch');
  const btnExportMd = document.getElementById('btn-export-md');

  // Current UI Settings State
  let currentGranularity = 'line'; // 'line' | 'word' | 'char'
  let currentView = 'split'; // 'split' | 'inline'
  let isMobile = window.innerWidth < 768;

  // Auto-switch view to inline on mobile initially
  if (isMobile) {
    currentView = 'inline';
    updateViewTabStyles();
  }

  // ----------------------------------------------------
  // EVENT LISTENERS
  // ----------------------------------------------------

  // Real-time calculation on input change
  originalTextarea.addEventListener('input', triggerDiff);
  changedTextarea.addEventListener('input', triggerDiff);
  ignoreWhitespaceCheckbox.addEventListener('change', triggerDiff);
  ignoreCaseCheckbox.addEventListener('change', triggerDiff);

  // Granularity change
  granularityTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      granularityTabs.forEach(t => {
        t.classList.remove('bg-primary', 'text-canvas', 'shadow-sm');
