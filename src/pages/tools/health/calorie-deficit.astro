          <!-- Macro Distribution splits -->
          <div class="border border-hairline rounded-xl p-3 bg-surface-soft flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <span class="text-[10px] uppercase font-bold text-slate">Macronutrient Targets</span>
              <div class="flex rounded-full bg-surface p-0.5 border border-hairline">
                <button type="button" class="macro-preset-btn text-[8px] px-2 py-0.5 rounded-full font-bold bg-primary text-canvas" data-type="balanced">Balanced</button>
