            <div class="flex flex-col gap-2 pt-1.5">
              <!-- Protein -->
              <div class="flex flex-col gap-1">
                <div class="flex justify-between text-[10px] font-bold">
                  <span class="text-charcoal">Protein</span>
                  <span id="macro-protein-display" class="font-mono text-primary">150g (600 kcal)</span>
                </div>
                <div class="w-full h-2 bg-hairline rounded-full overflow-hidden">
                  <div id="macro-protein-bar" class="h-full bg-brand-blue" style="width: 30%;"></div>
                </div>
