---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Calorie Deficit Calculator";
const category = "health";
const tier = "Health & Fitness";
const description = "Calculate your maintenance calories (TDEE) and determine a safe, sustainable daily calorie deficit to reach your target weight.";
---

<Layout 
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Calorie Deficit Calculator",
      "url": "https://boardtools.app/tools/health/calorie-deficit",
      "description": "Interactive client-side calorie deficit calculator with body fat adjustment, BMR/TDEE tracking, weight loss projection timelines, macro splits, and medical safety floors.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex items-center justify-between mt-0.5 gap-4">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>
        <button
          type="button"
          id="reset-btn"
          class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
          aria-label="Reset calculator inputs"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
          </svg>
          <span>Reset</span>
        </button>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col gap-3">
          <!-- Unit Toggle (Miro Pill Style) -->
          <div class="flex flex-col gap-1">
            <label class="text-[11px] font-semibold text-charcoal">Measurement Unit</label>
            <div class="flex rounded-full bg-surface p-0.5 border border-hairline self-start">
              <button
                type="button"
                id="unit-metric-btn"
                class="text-[11px] px-4 py-1 rounded-full font-bold transition-all cursor-pointer text-slate"
              >
                Metric (cm/kg)
              </button>
              <button
                type="button"
                id="unit-imperial-btn"
                class="text-[11px] px-4 py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
              >
                Imperial (ft-in/lb)
              </button>
            </div>
          </div>

          <!-- Sex & Age Inputs -->
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1">
              <label for="sex-select" class="text-[11px] font-semibold text-charcoal">Biological Sex</label>
              <select
                id="sex-select"
                class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                aria-label="Biological Sex Select"
              >
                <option value="male" selected>Male</option>
                <option value="female">Female</option>
              </select>
            </div>
            <div class="flex flex-col gap-1">
              <label for="age-input" class="text-[11px] font-semibold text-charcoal">Age</label>
              <div class="relative">
                <input
                  type="number"
                  id="age-input"
                  min="15"
                  max="80"
                  value="30"
                  class="text-input py-1 text-xs font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">yrs</span>
              </div>
            </div>
          </div>

          <!-- Height Inputs -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal flex justify-between">
              <span>Height</span>
              <span id="height-label" class="font-mono text-stone font-semibold">5 ft 9 in</span>
            </label>

            <!-- Metric Height (CM) -->
            <div id="metric-height-container" class="flex items-center gap-2 hidden">
              <input
                type="range"
                id="height-metric-range"
                min="100"
                max="230"
                value="175"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Height in Centimeters Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="height-metric-input"
                  min="100"
                  max="230"
                  value="175"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">cm</span>
              </div>
            </div>

            <!-- Imperial Height (Feet + Inches) -->
            <div id="imperial-height-container" class="grid grid-cols-2 gap-2">
              <div class="relative">
                <input
                  type="number"
                  id="height-ft-input"
                  min="3"
                  max="7"
                  value="5"
                  class="text-input pr-6 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                  placeholder="ft"
                  aria-label="Height feet"
                />
                <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">ft</span>
              </div>
              <div class="relative">
                <input
                  type="number"
                  id="height-in-input"
                  min="0"
                  max="11"
                  value="9"
                  class="text-input pr-6 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                  placeholder="in"
                  aria-label="Height inches"
                />
                <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">in</span>
              </div>
            </div>
          </div>

          <!-- Weight Inputs -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal flex justify-between">
              <span>Weight</span>
              <span id="weight-label" class="font-mono text-stone font-semibold">176 lb</span>
            </label>

            <!-- Metric Weight (KG) -->
            <div id="metric-weight-container" class="flex items-center gap-2 hidden">
              <input
                type="range"
                id="weight-metric-range"
                min="35"
                max="200"
                value="80"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Weight in Kilograms Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="weight-metric-input"
                  min="35"
                  max="200"
                  value="80"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">kg</span>
              </div>
            </div>

            <!-- Imperial Weight (LBS) -->
            <div id="imperial-weight-container" class="flex items-center gap-2">
              <input
                type="range"
                id="weight-lbs-range"
                min="80"
                max="450"
                value="176"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Weight in Pounds Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="weight-lbs-input"
                  min="80"
                  max="450"
                  value="176"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">lb</span>
              </div>
            </div>
          </div>

          <script type="text/javascript" is:inline>
            (function() {
              const savedUnit = localStorage.getItem("calorie-unit") || "imperial";
              if (savedUnit === "metric") {
                document.getElementById("metric-height-container")?.classList.remove("hidden");
                document.getElementById("imperial-height-container")?.classList.add("hidden");
                document.getElementById("metric-weight-container")?.classList.remove("hidden");
                document.getElementById("imperial-weight-container")?.classList.add("hidden");
                
                const metricBtn = document.getElementById("unit-metric-btn");
                const imperialBtn = document.getElementById("unit-imperial-btn");
                if (metricBtn && imperialBtn) {
                  metricBtn.classList.add("bg-primary", "text-canvas");
                  metricBtn.classList.remove("text-slate");
                  imperialBtn.classList.remove("bg-primary", "text-canvas");
                  imperialBtn.classList.add("text-slate");
                }
                const labelH = document.getElementById("height-label");
                if (labelH) labelH.textContent = "175 cm";
                const labelW = document.getElementById("weight-label");
                if (labelW) labelW.textContent = "80 kg";
                const targetWUnit = document.getElementById("targetweight-unit");
                if (targetWUnit) targetWUnit.textContent = "kg";
              }
            })();
          </script>

          <!-- Activity Level -->
          <div class="flex flex-col gap-1">
            <label for="activity-select" class="text-[11px] font-semibold text-charcoal">Activity Level</label>
            <select
              id="activity-select"
              class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
            >
              <option value="1.2">Sedentary (Little to no exercise)</option>
              <option value="1.375" selected>Lightly Active (Exercise 1-3 days/week)</option>
              <option value="1.55">Moderately Active (Exercise 3-5 days/week)</option>
              <option value="1.725">Very Active (Hard exercise 6-7 days/week)</option>
              <option value="1.9">Extra Active (Very intense physical job / twice-daily workouts)</option>
            </select>
          </div>

          <!-- Target / Goal Tiers -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal">Target Goal</label>
            <div class="grid grid-cols-2 gap-2" id="goal-container">
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-deficit="0">
                <span class="block text-xs font-bold text-primary">Maintain</span>
                <span class="block text-[9px] text-stone mt-0.5">TDEE level</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-brand-blue/30 rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative active" data-deficit="500">
                <span class="block text-xs font-bold text-primary">Moderate Deficit</span>
                <span class="block text-[9px] text-stone mt-0.5">~0.5 kg/week loss</span>
                <span class="absolute top-1.5 right-1.5 bg-success-accent text-canvas text-[8px] font-bold px-1.5 py-0.5 rounded-full">Recommended</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-deficit="250">
                <span class="block text-xs font-bold text-primary">Mild Deficit</span>
                <span class="block text-[9px] text-stone mt-0.5">~0.25 kg/week loss</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-deficit="1000">
                <span class="block text-xs font-bold text-primary">Aggressive Deficit</span>
                <span class="block text-[9px] text-stone mt-0.5">~1.0 kg/week loss</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-deficit="-250">
                <span class="block text-xs font-bold text-primary">Mild Surplus</span>
                <span class="block text-[9px] text-stone mt-0.5">~0.25 kg/week gain</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-deficit="-500">
                <span class="block text-xs font-bold text-primary">Moderate Surplus</span>
                <span class="block text-[9px] text-stone mt-0.5">~0.5 kg/week gain</span>
              </button>
            </div>
          </div>

          <!-- Advanced Options Collapsible -->
          <div class="border-t border-hairline-soft pt-2 mt-1">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-[11px] font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1">
                ⚙ Advanced Parameters (Body Fat %, Custom Target)
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-3.5 h-3.5 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="advanced-panel" class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-3 mt-1.5">
              <div class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft/50">
                <!-- Body Fat -->
                <div class="flex flex-col gap-1">
                  <label for="bodyfat-input" class="text-[10px] font-semibold text-slate">Body Fat % (Optional)</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="bodyfat-input"
                      min="3"
                      max="50"
                      placeholder="e.g. 18"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
                  </div>
                  <span class="text-[8px] text-stone leading-tight">Enables Katch-McArdle formula for lean body mass.</span>
                </div>

                <!-- Custom Target Weight -->
                <div class="flex flex-col gap-1">
                  <label for="targetweight-input" class="text-[10px] font-semibold text-slate">Target Weight (Optional)</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="targetweight-input"
                      placeholder="e.g. 75"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span id="targetweight-unit" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">lb</span>
                  </div>
                </div>
              </div>

              <!-- Custom Target Date -->
              <div class="flex flex-col gap-1">
                <label for="targetdate-input" class="text-[10px] font-semibold text-slate">Target Date (Optional)</label>
                <input
                  type="date"
                  id="targetdate-input"
                  class="text-input py-1 text-xs font-mono h-8 w-full cursor-pointer bg-canvas"
                />
                <span class="text-[8px] text-stone leading-tight">Calculates custom daily deficit needed dynamically to hit target weight by date.</span>
              </div>

              <div class="flex items-center justify-end mt-1">
                <button
                  type="button"
                  id="advanced-view-result-btn"
                  class="inline-flex items-center gap-1 text-[10px] font-semibold px-3 py-1 bg-primary hover:bg-charcoal text-canvas rounded-full transition-all cursor-pointer shadow-subtle"
                >
                  View Result &darr;
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Pane: Outputs & Dashboard Card -->
        <div id="results-card" class="card-feature-teal flex flex-col justify-between p-4 sm:p-5 relative overflow-hidden rounded-xl border border-moss-dark/10">
          <div class="absolute top-0 right-0 w-32 h-32 bg-teal-light/35 rounded-full blur-2xl pointer-events-none"></div>
          
          <div class="flex flex-col gap-3.5 z-10 w-full">
            <!-- Results Header -->
            <div class="flex items-center justify-between border-b border-moss-dark/10 pb-2">
              <span class="text-[10px] uppercase font-extrabold text-moss-dark/70 tracking-widest">Energy Balance & Target</span>
              <span class="flex h-2 w-2 relative">
                <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-accent opacity-75"></span>
                <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-success-accent"></span>
              </span>
            </div>

            <!-- Warning/Caution Banner (Hidden by default) -->
            <div id="safety-alert" class="hidden p-2 rounded-lg bg-brand-rose border border-brand-red text-[10px] text-coral-dark leading-normal flex flex-col gap-0.5">
              <span class="font-bold flex items-center gap-1">⚠️ Safety Warning: Calorie Target Below Floor</span>
              <p id="safety-alert-msg">Your target daily calories fall below recommended medically safe limits (1200 kcal/day for females, 1500 kcal/day for males).</p>
            </div>

            <!-- Core Dashboard Numbers -->
            <div class="flex flex-col gap-3">
              <div>
                <span class="text-[10px] uppercase font-bold text-slate block">Recommended Daily Target</span>
                <div class="flex items-baseline gap-1">
                  <span id="output-target-calories" class="font-display font-black text-3xl sm:text-4xl text-primary font-mono tracking-tight leading-none">2,000</span>
                  <span class="text-xs font-semibold text-stone">kcal/day</span>
                </div>
              </div>

              <!-- Energy Level Breakdown -->
              <div class="grid grid-cols-2 gap-3 border-t border-moss-dark/10 pt-3">
                <div class="flex flex-col">
                  <span class="text-[9px] uppercase font-extrabold text-moss-dark/70">Basal Metabolic Rate (BMR)</span>
                  <span id="output-bmr" class="font-display font-bold text-sm text-primary font-mono">1,650 kcal</span>
                  <span class="text-[8px] text-stone">Energy burned at rest</span>
                </div>
                <div class="flex flex-col">
                  <span class="text-[9px] uppercase font-extrabold text-moss-dark/70">Maintenance (TDEE)</span>
                  <span id="output-tdee" class="font-display font-bold text-sm text-primary font-mono">2,500 kcal</span>
                  <span class="text-[8px] text-stone">Burned with daily activity</span>
                </div>
              </div>
            </div>

            <!-- Dynamic Gauge Compare bar -->
            <div class="flex flex-col gap-1 border-t border-moss-dark/10 pt-3">
              <span class="text-[9px] uppercase font-bold text-slate">Daily Target vs TDEE Comparison</span>
              <div class="w-full h-4 bg-canvas/60 dark:bg-canvas/10 backdrop-blur-md rounded-full overflow-hidden flex relative border border-hairline">
                <div id="gauge-bmr-bar" class="h-full bg-brand-blue" style="width: 50%;"></div>
                <div id="gauge-deficit-bar" class="h-full bg-success-accent" style="width: 30%;"></div>
                <div id="gauge-gap-bar" class="h-full bg-slate/15 dark:bg-slate/30" style="width: 20%;"></div>
              </div>
              <div class="flex justify-between text-[8px] font-bold text-stone">
                <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-brand-blue"></span>BMR</span>
                <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-success-accent"></span>Target Intake</span>
                <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-slate/30"></span>Deficit</span>
              </div>
            </div>

            <!-- Contextual Text -->
            <div id="advice-box" class="text-[11px] text-moss-dark leading-relaxed pt-2 border-t border-moss-dark/5">
              <p id="advice-text">
                Your BMR is estimated at <strong>1,650 kcal</strong>, and your maintenance calories at <strong>2,500 kcal</strong>. Consuming 2,000 kcal daily sets a safe 500 kcal deficit, aiming for ~0.5 kg weight loss per week.
              </p>
            </div>
          </div>
        </div>

      </div>

      <!-- Action Button directly beneath input workspace -->
      <div class="flex justify-center pt-2">
        <button
          type="button"
          id="toggle-breakdown-btn"
          class="button-primary text-xs py-2 px-6 !rounded-full shadow-subtle hover:scale-105 active:scale-95 transition-all cursor-pointer flex items-center gap-1.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <span>View Detailed Breakdown & Analysis</span>
        </button>
      </div>
    </div>

    <!-- Detailed Breakdown & Analysis Section (Same Page) -->
    <div id="breakdown-section" class="max-h-0 overflow-hidden transition-all duration-500 flex flex-col gap-4">
      <div class="card-base p-4 sm:p-5 flex flex-col gap-4 mt-2">
        <div class="flex items-center justify-between border-b border-hairline pb-2">
          <h2 class="font-display font-semibold text-sm sm:text-base text-primary flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 3.055A9.003 9.003 0 1020.945 13H11V3.055z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
            </svg>
            Personalized Calorie & Nutrition Forecast
          </h2>
          <button
            type="button"
            id="export-pdf-btn"
            class="inline-flex items-center gap-1 text-[10px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Export report to PDF"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span>Export Report</span>
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- 12-Week Weight Projection Line Chart -->
          <div class="border border-hairline rounded-xl p-3 bg-surface-soft flex flex-col gap-2">
            <span class="text-[10px] uppercase font-bold text-slate">12-Week Weight Projection</span>
            <div class="w-full h-44 relative bg-canvas rounded-lg border border-hairline flex items-center justify-center p-2">
              <svg id="weight-chart-svg" class="w-full h-full" viewBox="0 0 100 50" preserveAspectRatio="none">
                <!-- SVG Grid Lines & Labels rendered via JS -->
              </svg>
