  <!-- Client-side script module -->
  <script>
    // State variables
    let currentMethod = "lmp"; // lmp | conception | ivf | ultrasound
    let lmpDate = "";
    let conceptionDate = "";
    let ivfDate = "";
    let ivfEmbryo = "5"; // 5 | 3
    let ultrasoundSubtype = "known-due-date"; // known-due-date | scan-dating
    let knownDueDate = "";
    let scanDate = "";
    let scanWeeks = 8;
    let scanDays = 0;
    
    // Advanced options
    let cycleLength = 28;



    // DOM Elements
    const btnLmp = document.getElementById("method-lmp");
    const btnConception = document.getElementById("method-conception");
    const btnIvf = document.getElementById("method-ivf");
    const btnUltrasound = document.getElementById("method-ultrasound");

    const groupLmp = document.getElementById("input-group-lmp");
    const groupConception = document.getElementById("input-group-conception");
    const groupIvf = document.getElementById("input-group-ivf");
    const groupUltrasound = document.getElementById("input-group-ultrasound");

    const inputLmpDate = document.getElementById("input-lmp-date") as HTMLInputElement;
    const inputConceptionDate = document.getElementById("input-conception-date") as HTMLInputElement;
    const inputIvfDate = document.getElementById("input-ivf-date") as HTMLInputElement;
    const inputIvfEmbryo = document.getElementById("input-ivf-embryo") as HTMLSelectElement;
    const selectUltrasoundSubtype = document.getElementById("ultrasound-subtype") as HTMLSelectElement;
    
    const subGroupDueDate = document.getElementById("sub-group-due-date");
    const subGroupScanDating = document.getElementById("sub-group-scan-dating");
    const inputDueDate = document.getElementById("input-due-date") as HTMLInputElement;
    const inputScanDate = document.getElementById("input-scan-date") as HTMLInputElement;
    const inputScanWeeks = document.getElementById("input-scan-weeks") as HTMLInputElement;
    const inputScanDays = document.getElementById("input-scan-days") as HTMLInputElement;

    // Advanced drawer
    const advancedToggleBtn = document.getElementById("advanced-toggle-btn");
    const advancedPanel = document.getElementById("advanced-panel");
    const advancedChevron = document.getElementById("advanced-chevron");
    const inputCycleLength = document.getElementById("input-cycle-length") as HTMLInputElement;
    const advancedViewResultBtn = document.getElementById("advanced-view-result-btn");

    // Output displays
    const outputDueDateDisplay = document.getElementById("output-due-date");
    const outputDaysRemaining = document.getElementById("output-days-remaining");
    const outputGestationalAge = document.getElementById("output-gestational-age");
    const outputProgressPercent = document.getElementById("output-progress-percent");
    const outputTrimesterName = document.getElementById("output-trimester-name");
    const outputTrimesterTag = document.getElementById("output-trimester-tag");
    const progressBarFill = document.getElementById("progress-bar-fill");
    const adviceText = document.getElementById("advice-text");

    // Breakdown Pane
    const toggleBreakdownBtn = document.getElementById("toggle-breakdown-btn");
    const breakdownSection = document.getElementById("breakdown-section");
    const exportPdfBtn = document.getElementById("export-pdf-btn");

    // Breakdown Elements
    const rangeTrimester1 = document.getElementById("range-trimester-1");
    const rangeTrimester2 = document.getElementById("range-trimester-2");
    const rangeTrimester3 = document.getElementById("range-trimester-3");
    
    const barTrimester1 = document.getElementById("bar-trimester-1");
    const barTrimester2 = document.getElementById("bar-trimester-2");
    const barTrimester3 = document.getElementById("bar-trimester-3");

    const valImplantation = document.getElementById("val-milestone-implantation");
    const valHeartbeat = document.getElementById("val-milestone-heartbeat");
    const valFetus = document.getElementById("val-milestone-fetus");
    const valAnatomy = document.getElementById("val-milestone-anatomy");
    const valViability = document.getElementById("val-milestone-viability");
    const valTerm = document.getElementById("val-milestone-term");
    const weeklyMarkersContainer = document.getElementById("weekly-markers-container");
    const weeklyProgressFill = document.getElementById("weekly-progress-fill");
    const analysisSummaryPara = document.getElementById("analysis-summary-para");

    const resetBtn = document.getElementById("reset-btn");

    // Scroll control
    window.addEventListener("beforeunload", () => {
      window.scrollTo(0, 0);
    });

    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }

    // Helper functions for dates
    function formatLocalDate(date: Date): string {
      return date.toLocaleDateString(undefined, {
        weekday: 'short',
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });
    }

    function addDays(date: Date, days: number): Date {
      const result = new Date(date.getTime());
      result.setDate(result.getDate() + days);
      return result;
    }

    function diffDays(d1: Date, d2: Date): number {
      const oneDay = 24 * 60 * 60 * 1000;
      return Math.round((d1.getTime() - d2.getTime()) / oneDay);
    }

    // Set default dates
    function initDefaultDates() {
      const todayStr = new Date().toISOString().split("T")[0];
      
      lmpDate = todayStr;
      conceptionDate = todayStr;
      ivfDate = todayStr;
      
      const standardDue = addDays(new Date(), 280);
      knownDueDate = standardDue.toISOString().split("T")[0];
      scanDate = todayStr;

      if (inputLmpDate) inputLmpDate.value = lmpDate;
      if (inputConceptionDate) inputConceptionDate.value = conceptionDate;
      if (inputIvfDate) inputIvfDate.value = ivfDate;
      if (inputDueDate) inputDueDate.value = knownDueDate;
      if (inputScanDate) inputScanDate.value = scanDate;
    }

    // Switch active method tabs
    function switchMethod(method: string) {
      currentMethod = method;
      
      const buttons = [
        { key: 'lmp', btn: btnLmp, group: groupLmp },
        { key: 'conception', btn: btnConception, group: groupConception },
        { key: 'ivf', btn: btnIvf, group: groupIvf },
        { key: 'ultrasound', btn: btnUltrasound, group: groupUltrasound }
      ];

      buttons.forEach(item => {
        if (item.key === method) {
          item.btn?.classList.add("bg-primary", "text-canvas");
          item.btn?.classList.remove("text-slate");
          item.group?.classList.remove("hidden");
        } else {
          item.btn?.classList.remove("bg-primary", "text-canvas");
          item.btn?.classList.add("text-slate");
          item.group?.classList.add("hidden");
        }
      });

      saveState();
      calculate();
    }

    // Main logic calculations
    function calculate() {
      let estDueDate = new Date();
      let startPregnancyDate = new Date();

      const today = new Date();
      today.setHours(0,0,0,0);

      if (currentMethod === "lmp") {
        if (!inputLmpDate.value) return;
        const lmp = new Date(inputLmpDate.value + "T00:00:00");
        // Naegele's rule adjusted for cycle length: 280 days + (cycleLength - 28)
        const cycleAdjustment = cycleLength - 28;
        estDueDate = addDays(lmp, 280 + cycleAdjustment);
        startPregnancyDate = lmp;
      } 
      else if (currentMethod === "conception") {
        if (!inputConceptionDate.value) return;
        const conception = new Date(inputConceptionDate.value + "T00:00:00");
        estDueDate = addDays(conception, 266);
        startPregnancyDate = addDays(conception, -14);
      } 
      else if (currentMethod === "ivf") {
        if (!inputIvfDate.value) return;
        const transfer = new Date(inputIvfDate.value + "T00:00:00");
        if (ivfEmbryo === "5") {
          estDueDate = addDays(transfer, 261);
        } else {
          estDueDate = addDays(transfer, 263);
        }
        startPregnancyDate = addDays(estDueDate, -280);
      } 
      else if (currentMethod === "ultrasound") {
        if (ultrasoundSubtype === "known-due-date") {
          if (!inputDueDate.value) return;
          estDueDate = new Date(inputDueDate.value + "T00:00:00");
          startPregnancyDate = addDays(estDueDate, -280);
        } else {
          if (!inputScanDate.value) return;
          const scan = new Date(inputScanDate.value + "T00:00:00");
          const totalDaysAtScan = (scanWeeks * 7) + scanDays;
          startPregnancyDate = addDays(scan, -totalDaysAtScan);
          estDueDate = addDays(startPregnancyDate, 280);
        }
      }

      estDueDate.setHours(0,0,0,0);
      startPregnancyDate.setHours(0,0,0,0);

      // Calculations relative to today
      const totalPregnancyDays = 280;
      const daysElapsed = diffDays(today, startPregnancyDate);
      const daysRemaining = diffDays(estDueDate, today);

      let gestationalAgeDays = daysElapsed;
      if (gestationalAgeDays < 0) gestationalAgeDays = 0;
      if (gestationalAgeDays > 294) gestationalAgeDays = 294; // Cap standard tracking at 42 weeks

      const weeks = Math.floor(gestationalAgeDays / 7);
      const days = gestationalAgeDays % 7;

      const progressPercent = Math.min(100, Math.max(0, Math.round((gestationalAgeDays / totalPregnancyDays) * 100)));

      // Milestones
      const dateImplantation = addDays(startPregnancyDate, 21); // ~3 weeks
      const dateHeartbeat = addDays(startPregnancyDate, 42); // 6 weeks
      const dateFetus = addDays(startPregnancyDate, 70); // 10 weeks
      const dateAnatomy = addDays(startPregnancyDate, 140); // 20 weeks
      const dateViability = addDays(startPregnancyDate, 168); // 24 weeks
      const dateTerm = addDays(startPregnancyDate, 259); // 37 weeks

      // Trimester intervals
      const tri1End = addDays(startPregnancyDate, 97); // 13 weeks 6 days
      const tri2Start = addDays(startPregnancyDate, 98); // 14 weeks 0 days
      const tri2End = addDays(startPregnancyDate, 195); // 27 weeks 6 days
      const tri3Start = addDays(startPregnancyDate, 196); // 28 weeks 0 days

      let currentTrimesterNum = 1;
      if (gestationalAgeDays >= 196) {
        currentTrimesterNum = 3;
      } else if (gestationalAgeDays >= 98) {
        currentTrimesterNum = 2;
      }

      // Update UI Panel elements
      if (outputDueDateDisplay) outputDueDateDisplay.textContent = formatLocalDate(estDueDate);
      
      if (outputDaysRemaining) {
        if (daysRemaining > 0) {
          outputDaysRemaining.textContent = `${daysRemaining} days remaining until estimated due date`;
        } else if (daysRemaining === 0) {
          outputDaysRemaining.textContent = `Today is your estimated due date!`;
        } else {
          outputDaysRemaining.textContent = `${Math.abs(daysRemaining)} days post estimated due date`;
        }
      }

      if (outputGestationalAge) {
        outputGestationalAge.textContent = `${weeks} Weeks, ${days} Days`;
      }

      if (outputProgressPercent) {
        outputProgressPercent.textContent = `${progressPercent}% Complete`;
      }

      if (progressBarFill) {
        progressBarFill.style.width = `${progressPercent}%`;
      }

      // Trimester UI
      if (outputTrimesterName) {
        if (currentTrimesterNum === 1) {
          outputTrimesterName.textContent = "First Trimester (Early Development)";
        } else if (currentTrimesterNum === 2) {
          outputTrimesterName.textContent = "Second Trimester (Growth & Movement)";
        } else {
          outputTrimesterName.textContent = "Third Trimester (Final Preparation)";
        }
      }

      if (outputTrimesterTag) {
        outputTrimesterTag.textContent = `TRIMESTER ${currentTrimesterNum}`;
      }

      // Advice / context
      if (adviceText) {
        adviceText.innerHTML = `Your pregnancy is estimated to be at <strong>${weeks} weeks and ${days} days</strong>. Most births occur within two weeks before or after the estimated due date.`;
      }

      // Breakdown Detail lists
      if (rangeTrimester1) {
        rangeTrimester1.textContent = `${formatLocalDate(startPregnancyDate)} - ${formatLocalDate(tri1End)}`;
      }
      if (rangeTrimester2) {
        rangeTrimester2.textContent = `${formatLocalDate(tri2Start)} - ${formatLocalDate(tri2End)}`;
      }
      if (rangeTrimester3) {
        rangeTrimester3.textContent = `${formatLocalDate(tri3Start)} - ${formatLocalDate(estDueDate)}`;
      }

      // Progress bars for trimesters in breakdown
      if (barTrimester1) {
        const tri1Progress = Math.min(100, Math.max(0, Math.round((Math.min(gestationalAgeDays, 97) / 97) * 100)));
        barTrimester1.style.width = `${tri1Progress}%`;
      }
      if (barTrimester2) {
        const tri2Elapsed = Math.max(0, gestationalAgeDays - 98);
        const tri2Progress = Math.min(100, Math.max(0, Math.round((Math.min(tri2Elapsed, 97) / 97) * 100)));
        barTrimester2.style.width = `${tri2Progress}%`;
      }
      if (barTrimester3) {
        const tri3Elapsed = Math.max(0, gestationalAgeDays - 196);
        const tri3Progress = Math.min(100, Math.max(0, Math.round((Math.min(tri3Elapsed, 84) / 84) * 100)));
        barTrimester3.style.width = `${tri3Progress}%`;
      }

      // Milestones UI values
      if (valImplantation) valImplantation.textContent = formatLocalDate(dateImplantation);
      if (valHeartbeat) valHeartbeat.textContent = formatLocalDate(dateHeartbeat);
      if (valFetus) valFetus.textContent = formatLocalDate(dateFetus);
      if (valAnatomy) valAnatomy.textContent = formatLocalDate(dateAnatomy);
      if (valViability) valViability.textContent = formatLocalDate(dateViability);
      if (valTerm) valTerm.textContent = formatLocalDate(dateTerm);

      // Render milestones highlights
      const milestoneItems = [
        { id: "milestone-implantation", target: dateImplantation },
        { id: "milestone-heartbeat", target: dateHeartbeat },
        { id: "milestone-fetus", target: dateFetus },
        { id: "milestone-anatomy", target: dateAnatomy },
        { id: "milestone-viability", target: dateViability },
        { id: "milestone-term", target: dateTerm }
      ];

      milestoneItems.forEach(item => {
        const element = document.getElementById(item.id);
        if (element) {
          if (today >= item.target) {
            element.classList.add("opacity-60", "line-through");
          } else {
            element.classList.remove("opacity-60", "line-through");
          }
        }
      });

      // Render Weekly markers dynamically
      if (weeklyMarkersContainer) {
        weeklyMarkersContainer.innerHTML = "";

        // Calculate progress percentage
        // Total range is from 2 weeks (start) to 40 weeks (due date) -> 38 weeks total span
        const currentProgressPercent = Math.min(100, Math.max(0, ((weeks - 2) / 38) * 100));
        if (weeklyProgressFill) {
          weeklyProgressFill.style.width = `${currentProgressPercent}%`;
        }

        // Draw weekly intervals
        for (let i = 2; i <= 40; i += 4) {
          const xPercent = ((i - 2) / 38) * 100;
          
          // Create marker container
          const marker = document.createElement("div");
          marker.className = "absolute -translate-x-1/2 -translate-y-1/2 flex flex-col items-center gap-1";
          marker.style.left = `${xPercent}%`;
          marker.style.top = "50%";

          // Create circle
          const circle = document.createElement("div");
          circle.className = `w-3 h-3 rounded-full border-2 transition-all duration-300 ${
            weeks >= i
              ? "bg-brand-blue border-brand-blue"
              : "bg-canvas border-hairline-strong"
          }`;

          // Create label
          const label = document.createElement("span");
          label.className = "text-[9px] font-mono font-bold text-stone mt-1 select-none";
          label.textContent = `${i}`;

          marker.appendChild(circle);
          marker.appendChild(label);
          weeklyMarkersContainer.appendChild(marker);
        }

        // Add active/current marker if within range
        const activeMarker = document.createElement("div");
        activeMarker.className = "absolute -translate-x-1/2 -translate-y-1/2 z-10 flex flex-col items-center gap-1 pointer-events-none";
        const activeX = Math.min(100, Math.max(0, ((weeks - 2) / 38) * 100));
        activeMarker.style.left = `${activeX}%`;
        activeMarker.style.top = "50%";

        const activeCircle = document.createElement("div");
        activeCircle.className = "w-4 h-4 rounded-full bg-success-accent border-2 border-canvas shadow-md animate-pulse";
        
        const activeLabel = document.createElement("span");
        activeLabel.className = "text-[9px] font-mono font-black text-success-accent mt-0.5";
        activeLabel.textContent = `W${weeks}`;

        activeMarker.appendChild(activeCircle);
        activeMarker.appendChild(activeLabel);
        weeklyMarkersContainer.appendChild(activeMarker);
      }

      // Written medical stage summary paragraph
      if (analysisSummaryPara) {
        let developmentalNote = "";
        if (weeks < 4) {
          developmentalNote = "Early cellular division and implantation are taking place. The blastocyst settles into the uterine lining.";
        } else if (weeks < 8) {
          developmentalNote = "Fetal heart and neural tube are forming. The cardiovascular network begins functioning, and basic limb buds appear.";
        } else if (weeks < 12) {
          developmentalNote = "Essential organ systems have initialized. Muscle tissues begin twitching, and facial features gain definition.";
        } else if (weeks < 16) {
          developmentalNote = "The skeleton begins mineralizing. Tiny movements emerge, and early kidney structures start circulating fluid.";
        } else if (weeks < 20) {
          developmentalNote = "The vocal cords and hearing mechanisms mature. A fine protective hair layer (lanugo) covers the skin.";
        } else if (weeks < 24) {
          developmentalNote = "Quickening (movements felt by the carrier) is common. Lungs prepare for atmospheric gas exchange, producing early surfactant.";
        } else if (weeks < 28) {
          developmentalNote = "Visual cells mature, and sleep-wake cycles normalize. The brain experiences rapid neurological pathways connection.";
        } else if (weeks < 32) {
          developmentalNote = "Weight gain accelerates. Protective fat deposits build under the skin, and lung structures finish basic maturation.";
        } else if (weeks < 37) {
          developmentalNote = "The brain increases in volume, and the head position typically shifts downward to prepare for delivery.";
        } else {
          developmentalNote = "Early term maturation is complete. The system waits for physical birth signals as pulmonary surfactant peaks.";
        }

        analysisSummaryPara.innerHTML = `Your calculated due date is <strong>${formatLocalDate(estDueDate)}</strong>. Based on standard gestational metrics, you are currently at <strong>Week ${weeks}</strong> of gestation. ${developmentalNote}`;
      }
    }

    // Toggle Advanced Panel
    if (advancedToggleBtn) {
      advancedToggleBtn.addEventListener("click", () => {
        if (advancedPanel) {
          const isCollapsed = advancedPanel.classList.contains("max-h-0");
          if (isCollapsed) {
            advancedPanel.classList.remove("max-h-0", "overflow-hidden");
            advancedPanel.classList.add("max-h-[300px]", "overflow-visible");
            advancedChevron?.classList.add("rotate-180");
          } else {
            advancedPanel.classList.remove("max-h-[300px]", "overflow-visible");
            advancedPanel.classList.add("max-h-0", "overflow-hidden");
            advancedChevron?.classList.remove("rotate-180");
          }
        }
      });
    }

    if (advancedViewResultBtn) {
      advancedViewResultBtn.addEventListener("click", () => {
        const resultsEl = document.getElementById("results-card");
        if (resultsEl) {
          resultsEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    }

    // Toggle Detailed Analysis
    if (toggleBreakdownBtn) {
      toggleBreakdownBtn.addEventListener("click", () => {
        if (breakdownSection) {
          const isCollapsed = breakdownSection.classList.contains("max-h-0");
          const label = document.getElementById("toggle-breakdown-label");
          if (isCollapsed) {
            breakdownSection.classList.remove("max-h-0");
            breakdownSection.classList.add("max-h-[2000px]");
            if (label) label.textContent = "Hide Detailed Breakdown";
            setTimeout(() => {
              scrollToElementWithOffset("breakdown-section", 60);
            }, 100);
          } else {
            breakdownSection.classList.remove("max-h-[2000px]");
            breakdownSection.classList.add("max-h-0");
            if (label) label.textContent = "View Detailed Breakdown & Analysis";
          }
        }
      });
    }

    // Export PDF / Print function
    if (exportPdfBtn) {
      exportPdfBtn.addEventListener("click", () => {
        if (breakdownSection && breakdownSection.classList.contains("max-h-0")) {
          breakdownSection.classList.remove("max-h-0");
          breakdownSection.classList.add("max-h-[2000px]");
          const label = document.getElementById("toggle-breakdown-label");
          if (label) label.textContent = "Hide Detailed Breakdown";
        }
        window.print();
      });
    }

    // Help / How it works Guide Overlay Modal HTML injection
    const modalHtml = `
      <div
        id="how-it-works-modal"
        class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
      >
        <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto">
          <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
            <h3 class="font-display font-semibold text-lg text-primary font-medium">How the Pregnancy Due Date Calculator Works</h3>
            <button
              type="button"
              id="close-modal-btn"
              class="text-stone hover:text-primary transition-all text-lg cursor-pointer bg-transparent border-none"
            >
              ✕
            </button>
          </div>

          <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
            <h4 class="font-semibold text-primary">1. Calculating from Last Menstrual Period (LMP)</h4>
            <p>
              According to Naegele's rule, the estimated due date is calculated by adding 280 days (40 weeks) to the first day of your last period, assuming a standard 28-day menstrual cycle. If your cycles are longer or shorter, the formula adjusts accordingly.
            </p>

            <h4 class="font-semibold text-primary">2. Conception & IVF Settings</h4>
            <p>
              If you know the conception date, the due date is calculated by adding 266 days (38 weeks). For IVF treatments, calculations are based on the embryo transfer date (factoring in whether it was a day 3 or day 5 transfer).
            </p>

            <h4 class="font-semibold text-primary">3. Gestational Age & Milestones</h4>
            <p>
              The gestational age is measured in weeks and days from the start of pregnancy. Key pregnancy milestones (like heartbeat, anatomical scan, viability, and full term) are projected chronologically.
            </p>
          </div>
          <button
            type="button"
            id="modal-ok-btn"
            class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
          >
            Got it
          </button>
        </div>
      </div>
    `;
    document.body.insertAdjacentHTML("beforeend", modalHtml);

    const shareBtn = document.getElementById("share-btn");
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    // Modal Events
    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    // Share Event
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("method", currentMethod);
      if (inputLmpDate?.value) url.searchParams.set("lmp", inputLmpDate.value);
      if (inputConceptionDate?.value) url.searchParams.set("conception", inputConceptionDate.value);
      if (inputIvfDate?.value) url.searchParams.set("ivf", inputIvfDate.value);
      if (inputIvfEmbryo) url.searchParams.set("ivf-embryo", inputIvfEmbryo.value);
      if (selectUltrasoundSubtype) url.searchParams.set("subtype", selectUltrasoundSubtype.value);
      if (inputDueDate?.value) url.searchParams.set("known", inputDueDate.value);
      if (inputScanDate?.value) url.searchParams.set("scan", inputScanDate.value);
      if (inputScanWeeks) url.searchParams.set("scan-w", inputScanWeeks.value);
      if (inputScanDays) url.searchParams.set("scan-d", inputScanDays.value);
      if (inputCycleLength) url.searchParams.set("cycle", inputCycleLength.value);

      const shareData = {
        title: document.title || "Pregnancy Due Date Calculator",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // State Loading & Saving
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      // get(lsKey, urlKey): URL params always take priority over localStorage
      const get = (lsKey: string, urlKey: string): string | null => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        if (typeof localStorage === 'undefined') return null;
        try { return localStorage.getItem(lsKey); } catch (e) { return null; }
      };

      try {
        const savedMethod = get("due-method", "method");
        const savedLmp = get("due-lmp", "lmp");
        const savedConception = get("due-conception", "conception");
        const savedIvf = get("due-ivf", "ivf");
        const savedIvfEmbryo = get("due-ivf-embryo", "ivf-embryo");
        const savedSubtype = get("due-subtype", "subtype");
        const savedDue = get("due-known", "known");
        const savedScan = get("due-scan", "scan");
        const savedScanW = get("due-scan-w", "scan-w");
        const savedScanD = get("due-scan-d", "scan-d");
        const savedCycle = get("due-cycle", "cycle");

        if (savedMethod) currentMethod = savedMethod;
        if (savedLmp) lmpDate = savedLmp;
        if (savedConception) conceptionDate = savedConception;
        if (savedIvf) ivfDate = savedIvf;
        if (savedIvfEmbryo) ivfEmbryo = savedIvfEmbryo;
        if (savedSubtype) ultrasoundSubtype = savedSubtype;
        if (savedDue) knownDueDate = savedDue;
        if (savedScan) scanDate = savedScan;
        if (savedScanW) scanWeeks = parseInt(savedScanW, 10);
        if (savedScanD) scanDays = parseInt(savedScanD, 10);
        if (savedCycle) cycleLength = parseInt(savedCycle, 10);

        // Apply back to inputs
        if (inputLmpDate && lmpDate) inputLmpDate.value = lmpDate;
        if (inputConceptionDate && conceptionDate) inputConceptionDate.value = conceptionDate;
        if (inputIvfDate && ivfDate) inputIvfDate.value = ivfDate;
        if (inputIvfEmbryo && ivfEmbryo) inputIvfEmbryo.value = ivfEmbryo;
        if (selectUltrasoundSubtype && ultrasoundSubtype) selectUltrasoundSubtype.value = ultrasoundSubtype;
        if (inputDueDate && knownDueDate) inputDueDate.value = knownDueDate;
        if (inputScanDate && scanDate) inputScanDate.value = scanDate;
        if (inputScanWeeks) inputScanWeeks.value = scanWeeks.toString();
        if (inputScanDays) inputScanDays.value = scanDays.toString();
        if (inputCycleLength) inputCycleLength.value = cycleLength.toString();

      } catch (e) {
        console.warn("Could not load state:", e);
      }
      
      // Update Tab CSS
      switchMethod(currentMethod);
      updateSubtypeUI();
      calculate();
    }

    function saveState() {
      try {
        localStorage.setItem("due-method", currentMethod);
        localStorage.setItem("due-lmp", inputLmpDate.value);
        localStorage.setItem("due-conception", inputConceptionDate.value);
        localStorage.setItem("due-ivf", inputIvfDate.value);
        localStorage.setItem("due-ivf-embryo", inputIvfEmbryo.value);
        localStorage.setItem("due-subtype", selectUltrasoundSubtype.value);
        localStorage.setItem("due-known", inputDueDate.value);
        localStorage.setItem("due-scan", inputScanDate.value);
        localStorage.setItem("due-scan-w", inputScanWeeks.value);
        localStorage.setItem("due-scan-d", inputScanDays.value);
        localStorage.setItem("due-cycle", inputCycleLength.value);
      } catch (e) {
        console.warn("Could not save state to localStorage:", e);
      }
    }

    function updateSubtypeUI() {
      if (ultrasoundSubtype === "known-due-date") {
        subGroupDueDate?.classList.remove("hidden");
        subGroupScanDating?.classList.add("hidden");
      } else {
        subGroupDueDate?.classList.add("hidden");
        subGroupScanDating?.classList.remove("hidden");
      }
    }

    // Listeners for Live updates
    [inputLmpDate, inputConceptionDate, inputIvfDate, inputDueDate, inputScanDate].forEach(input => {
      input?.addEventListener("change", () => {
        saveState();
        calculate();
      });
    });

    [inputIvfEmbryo, selectUltrasoundSubtype].forEach(select => {
      select?.addEventListener("change", () => {
        if (select === selectUltrasoundSubtype) {
          ultrasoundSubtype = selectUltrasoundSubtype.value;
          updateSubtypeUI();
        } else if (select === inputIvfEmbryo) {
          ivfEmbryo = inputIvfEmbryo.value;
        }
        saveState();
        calculate();
      });
    });

    [inputScanWeeks, inputScanDays, inputCycleLength].forEach(input => {
      input?.addEventListener("input", () => {
        // Enforce boundaries
        if (input === inputScanWeeks) {
          scanWeeks = Math.max(0, Math.min(42, parseInt(inputScanWeeks.value, 10) || 0));
        } else if (input === inputScanDays) {
          scanDays = Math.max(0, Math.min(6, parseInt(inputScanDays.value, 10) || 0));
        } else if (input === inputCycleLength) {
          cycleLength = Math.max(21, Math.min(45, parseInt(inputCycleLength.value, 10) || 28));
        }
        saveState();
        calculate();
      });
    });

    // Reset button
    if (resetBtn) {
      resetBtn.addEventListener("click", () => {
        // Clear URL parameters
        if (window.history.pushState) {
          const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
          window.history.pushState({path:newurl}, '', newurl);
        }

        const keys = [
          "due-method",
          "due-lmp",
          "due-conception",
          "due-ivf",
          "due-ivf-embryo",
          "due-subtype",
          "due-known",
          "due-scan",
          "due-scan-w",
          "due-scan-d",
          "due-cycle"
        ];
        keys.forEach(key => localStorage.removeItem(key));
        initDefaultDates();
        currentMethod = "lmp";
        ivfEmbryo = "5";
        ultrasoundSubtype = "known-due-date";
        cycleLength = 28;
        scanWeeks = 8;
        scanDays = 0;
        
        if (inputIvfEmbryo) inputIvfEmbryo.value = "5";
        if (selectUltrasoundSubtype) selectUltrasoundSubtype.value = "known-due-date";
        if (inputScanWeeks) inputScanWeeks.value = "8";
        if (inputScanDays) inputScanDays.value = "0";
        if (inputCycleLength) inputCycleLength.value = "28";

        switchMethod("lmp");
        updateSubtypeUI();
        calculate();
      });
    }

    // Tab buttons
    btnLmp?.addEventListener("click", () => switchMethod("lmp"));
    btnConception?.addEventListener("click", () => switchMethod("conception"));
    btnIvf?.addEventListener("click", () => switchMethod("ivf"));
    btnUltrasound?.addEventListener("click", () => switchMethod("ultrasound"));

    // Init Page state
    initDefaultDates();
    loadState();
  </script>
</Layout>
