---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Pregnancy Due Date Calculator";
const category = "health";
const tier = "Health & Fitness";
const description = "Calculate your estimated due date, current gestational age, and key pregnancy milestones using multiple dating methods.";

// SEO metadata (On-Page SEO)
const seoTitle = "Pregnancy Due Date Calculator - Free & Accurate EDD | BoardTools";
const seoDescription = "Free pregnancy due date calculator to find your estimated due date by LMP, conception date, IVF transfer, or ultrasound. Get accurate week-by-week results instantly.";
const seoKeywords = "pregnancy due date calculator, month pregnancy due date calculator, american pregnancy due date calculator, due date calculator, baby due date calculator, estimated due date calculator, accurate due date calculator, due date calculator conception, due date calculator based on conception, due date calculator conception date, pregnancy calculator, pregnancy calculator week by week, pregnancy calculator due date, due date pregnancy calculator, week to week pregnancy calculator, pregnancy calculator by due date, week by week pregnancy calculator";
const canonicalUrl = "https://boardtools.app/tools/health/pregnancy-due-date";
const ogImage = "https://boardtools.app/og-default.png";
---

<Layout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Pregnancy Due Date & Gestational Calculator",
      "url": "https://boardtools.app/tools/health/pregnancy-due-date",
      "description": "Interactive client-side pregnancy due date calculator supporting LMP, conception date, IVF transfer, and ultrasound dating with comprehensive trimester breakdowns.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- SEO FAQ Schema (FAQPage) -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does the pregnancy due date calculator work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our pregnancy due date calculator estimates your due date using Naegele's rule. It adds 280 days (40 weeks) to the first day of your last menstrual period (LMP). You can also calculate your estimated due date based on your conception date, IVF transfer date, or an ultrasound scan for a more accurate result."
          }
        },
        {
          "@type": "Question",
          "name": "How accurate is the estimated due date calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An estimated due date is a projection, not a guarantee. Only about 4% of babies are born on their exact due date, and most arrive within two weeks before or after it. Using ultrasound dating or a known conception date generally produces a more accurate due date than LMP alone."
          }
        },
        {
          "@type": "Question",
          "name": "Can I use the due date calculator based on conception date?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Select the conception method and enter your conception date. The due date calculator adds 266 days (38 weeks) from the conception date to estimate your due date, which is useful if you know the exact day of ovulation or fertilization."
          }
        },
        {
          "@type": "Question",
          "name": "Does this work as a week by week pregnancy calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Beyond the due date, this pregnancy calculator shows your current gestational age in weeks and days, your trimester, a week-by-week progress timeline, and key milestones such as the heartbeat, anatomy scan, viability, and full term."
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>
        
        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How pregnancy due date calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 print:border-none print:shadow-none print:bg-transparent print:p-0">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col gap-3 print:hidden">
          <!-- Method Selection Tabs -->
          <div class="flex flex-col gap-1">
            <label class="text-[11px] font-semibold text-charcoal">Calculation Method</label>
            <div class="flex flex-wrap gap-1 bg-surface p-1 border border-hairline rounded-lg">
              <button
                type="button"
                id="method-lmp"
                class="flex-1 text-[10px] sm:text-[11px] py-1 px-2 rounded font-bold transition-all cursor-pointer bg-primary text-canvas text-center whitespace-nowrap"
              >
                LMP
              </button>
              <button
                type="button"
                id="method-conception"
                class="flex-1 text-[10px] sm:text-[11px] py-1 px-2 rounded font-bold transition-all cursor-pointer text-slate text-center whitespace-nowrap"
              >
                Conception Date
              </button>
              <button
                type="button"
                id="method-ivf"
                class="flex-1 text-[10px] sm:text-[11px] py-1 px-2 rounded font-bold transition-all cursor-pointer text-slate text-center whitespace-nowrap"
              >
                IVF Transfer
              </button>
              <button
                type="button"
                id="method-ultrasound"
                class="flex-1 text-[10px] sm:text-[11px] py-1 px-2 rounded font-bold transition-all cursor-pointer text-slate text-center whitespace-nowrap"
              >
                Ultrasound / Due Date
              </button>
            </div>
          </div>

          <!-- Dynamic Input Containers based on Method -->
          <div class="flex flex-col gap-3">
            <!-- LMP Inputs -->
            <div id="input-group-lmp" class="flex flex-col gap-1">
              <label for="input-lmp-date" class="text-[11px] font-semibold text-charcoal">First Day of Last Period (LMP)</label>
              <input
                type="date"
                id="input-lmp-date"
                class="text-input py-1 text-xs font-mono h-8 w-full cursor-text bg-canvas"
              />
            </div>

            <!-- Conception Inputs -->
            <div id="input-group-conception" class="flex flex-col gap-1 hidden">
              <label for="input-conception-date" class="text-[11px] font-semibold text-charcoal">Date of Conception</label>
              <input
                type="date"
                id="input-conception-date"
                class="text-input py-1 text-xs font-mono h-8 w-full cursor-text bg-canvas"
              />
            </div>

            <!-- IVF Inputs -->
            <div id="input-group-ivf" class="flex flex-col gap-3 hidden">
              <div class="flex flex-col gap-1">
                <label for="input-ivf-date" class="text-[11px] font-semibold text-charcoal">IVF Transfer Date</label>
                <input
                  type="date"
                  id="input-ivf-date"
                  class="text-input py-1 text-xs font-mono h-8 w-full cursor-text bg-canvas"
                />
              </div>
              <div class="flex flex-col gap-1">
                <label for="input-ivf-embryo" class="text-[11px] font-semibold text-charcoal">Embryo Age</label>
                <select
                  id="input-ivf-embryo"
                  class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                >
                  <option value="5" selected>Day 5 Embryo Transfer</option>
                  <option value="3">Day 3 Embryo Transfer</option>
                </select>
              </div>
            </div>

            <!-- Ultrasound / Known Due Date Inputs -->
            <div id="input-group-ultrasound" class="flex flex-col gap-3 hidden">
              <div class="flex flex-col gap-1">
                <label for="ultrasound-subtype" class="text-[11px] font-semibold text-charcoal">Input Mode</label>
                <select
                  id="ultrasound-subtype"
                  class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                >
                  <option value="known-due-date" selected>Known Due Date directly</option>
                  <option value="scan-dating">Ultrasound scan measurements</option>
                </select>
              </div>

              <!-- Subtype: Known Due Date -->
              <div id="sub-group-due-date" class="flex flex-col gap-1">
                <label for="input-due-date" class="text-[11px] font-semibold text-charcoal">Estimated Due Date</label>
                <input
                  type="date"
                  id="input-due-date"
                  class="text-input py-1 text-xs font-mono h-8 w-full cursor-text bg-canvas"
                />
              </div>

              <!-- Subtype: Scan Dating -->
              <div id="sub-group-scan-dating" class="flex flex-col gap-3 hidden">
                <div class="flex flex-col gap-1">
                  <label for="input-scan-date" class="text-[11px] font-semibold text-charcoal">Date of Ultrasound Scan</label>
                  <input
                    type="date"
                    id="input-scan-date"
                    class="text-input py-1 text-xs font-mono h-8 w-full cursor-text bg-canvas"
                  />
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div class="flex flex-col gap-1">
                    <label for="input-scan-weeks" class="text-[10px] font-semibold text-charcoal">Gestational Age: Weeks</label>
                    <input
                      type="number"
                      id="input-scan-weeks"
                      min="0"
                      max="40"
                      value="8"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                  </div>
                  <div class="flex flex-col gap-1">
                    <label for="input-scan-days" class="text-[10px] font-semibold text-charcoal">Days</label>
                    <input
                      type="number"
                      id="input-scan-days"
                      min="0"
                      max="6"
                      value="0"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Advanced Options Drawer -->
          <div class="border-t border-hairline-soft pt-2 mt-1">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-[11px] font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1">
                ⚙ Advanced Options (Cycle Length, Clinical Adjustment)
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-3.5 h-3.5 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="advanced-panel" class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-3 mt-1.5">
              <div class="flex flex-col gap-2 pt-2 border-t border-hairline-soft/50">
                <div class="flex flex-col gap-1">
                  <label for="input-cycle-length" class="text-[10px] font-semibold text-slate">Average Cycle Length (Days)</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="input-cycle-length"
                      min="21"
                      max="45"
                      value="28"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">days</span>
                  </div>
                  <span class="text-[8px] text-stone leading-tight">Only used to adjust LMP calculations. Standard default is 28 days.</span>
                </div>
              </div>

              <div class="flex items-center justify-end mt-1">
                <button
                  type="button"
                  id="advanced-view-result-btn"
                  class="inline-flex items-center gap-1 text-[10px] font-semibold px-3 py-1 bg-primary hover:bg-charcoal text-canvas rounded-full transition-all cursor-pointer shadow-subtle"
                >
                  View Result &darr;
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Pane: Main Output Panel -->
        <div id="results-card" class="card-feature-rose flex flex-col justify-between p-4 sm:p-5 relative overflow-hidden rounded-xl border border-coral-dark/10 print:border-none print:shadow-none print:p-0">
          <div class="absolute top-0 right-0 w-32 h-32 bg-coral-light/25 rounded-full blur-2xl pointer-events-none print:hidden"></div>
          
          <div class="flex flex-col gap-3.5 z-10 w-full">
            <!-- Results Header -->
            <div class="flex items-center justify-between border-b border-coral-dark/10 dark:border-brand-coral/20 pb-2">
              <span class="text-[10px] uppercase font-extrabold text-coral-dark/70 dark:text-brand-coral/80 tracking-widest">Pregnancy Gestational Timeline</span>
              <span class="flex h-2 w-2 relative print:hidden">
                <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-accent opacity-75"></span>
                <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-success-accent"></span>
              </span>
            </div>

            <!-- Target Output -->
            <div class="flex flex-col gap-3">
              <div class="flex justify-between items-start">
                <div>
                  <span class="text-[10px] uppercase font-bold text-slate block">Estimated Due Date (EDD)</span>
                  <span id="output-due-date" class="font-display font-black text-2xl sm:text-3xl text-primary font-mono tracking-tight leading-none">-</span>
                  <span id="output-days-remaining" class="block text-[10px] font-semibold text-stone mt-1">-</span>
                </div>
                <div class="text-right">
                  <span class="text-[10px] uppercase font-bold text-slate block">Gestational Age</span>
                  <span id="output-gestational-age" class="font-display font-bold text-base sm:text-lg text-primary font-mono block">-</span>
                  <span id="output-progress-percent" class="text-[10px] font-semibold text-stone font-mono">-</span>
                </div>
              </div>

              <!-- Trimester Badge & Range -->
              <div class="flex items-center justify-between bg-canvas/40 backdrop-blur-md p-2 rounded-lg border border-hairline-soft/80">
                <div>
                  <span class="text-[9px] uppercase font-bold text-slate block">Current Trimester</span>
                  <span id="output-trimester-name" class="text-xs font-bold text-primary">-</span>
                </div>
                <span id="output-trimester-tag" class="badge-tag-purple text-[9px] font-extrabold px-2 py-0.5 rounded-full">-</span>
              </div>
            </div>

            <!-- Simple Timeline Progress Bar -->
            <div class="flex flex-col gap-1 border-t border-coral-dark/10 dark:border-brand-coral/20 pt-3">
              <span class="text-[9px] uppercase font-bold text-slate">Pregnancy Journey Progress</span>
              <div class="w-full h-4 bg-canvas/60 dark:bg-canvas/10 backdrop-blur-md rounded-full overflow-hidden flex relative border border-hairline">
                <div id="progress-bar-fill" class="h-full bg-brand-blue" style="width: 0%;"></div>
                <!-- Milestones Markers Overlayed -->
                <div class="absolute left-0 top-0 bottom-0 flex justify-between w-full px-2 items-center pointer-events-none">
                  <span class="text-[7px] font-bold text-stone">Conception</span>
                  <span class="text-[7px] font-bold text-stone">Viability</span>
                  <span class="text-[7px] font-bold text-stone">Full Term</span>
                </div>
              </div>
              <div class="flex justify-between text-[8px] font-bold text-stone">
                <span>0 Weeks</span>
                <span>24 Weeks</span>
                <span>37 Weeks</span>
                <span>40 Weeks</span>
              </div>
            </div>

            <!-- Short Support / Advice Box -->
            <div id="advice-box" class="text-[11px] text-coral-dark leading-relaxed pt-2 border-t border-coral-dark/5 dark:border-brand-coral/10">
              <p id="advice-text">
                Enter your dates on the left to estimate due date milestones and view gestational tracking details.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Button directly beneath input workspace -->
      <div class="flex justify-center pt-2 print:hidden">
        <button
          type="button"
          id="toggle-breakdown-btn"
          class="button-primary text-xs py-2 px-6 !rounded-full shadow-subtle hover:scale-105 active:scale-95 transition-all cursor-pointer flex items-center gap-1.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <span><span id="toggle-breakdown-label">View Detailed Breakdown & Analysis</span></span>
        </button>
      </div>
    </div>

    <!-- Detailed Breakdown & Analysis Section (Same Page) -->
    <div id="breakdown-section" class="max-h-0 overflow-hidden transition-all duration-500 flex flex-col gap-4 print:max-h-none print:overflow-visible">
      <div class="card-base p-4 sm:p-5 flex flex-col gap-4 mt-2 print:border-none print:shadow-none print:p-0">
        <div class="flex items-center justify-between border-b border-hairline pb-2">
          <h2 class="font-display font-semibold text-sm sm:text-base text-primary flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 3.055A9.003 9.003 0 1020.945 13H11V3.055z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
            </svg>
            Personalized Pregnancy Timeline & Analysis
          </h2>
          <button
            type="button"
            id="export-pdf-btn"
            class="inline-flex items-center gap-1 text-[10px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle print:hidden"
            aria-label="Export report to PDF"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span>Export Report</span>
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Trimester Ranges Detail Card -->
          <div class="border border-hairline rounded-xl p-3 bg-surface-soft flex flex-col gap-2 print:border-none print:bg-transparent">
            <span class="text-[10px] uppercase font-bold text-slate">Trimester Intervals</span>
            <div class="flex flex-col gap-2.5 pt-1.5">
              <!-- First Trimester -->
              <div class="flex flex-col gap-1">
                <div class="flex justify-between text-[10px] font-bold">
                  <span class="text-charcoal flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-rose"></span>First Trimester
                  </span>
                  <span id="range-trimester-1" class="font-mono text-stone">-</span>
                </div>
                <div class="w-full h-1.5 bg-hairline rounded-full overflow-hidden">
                  <div id="bar-trimester-1" class="h-full bg-brand-rose" style="width: 0%;"></div>
                </div>
                <span class="text-[8px] text-stone">Week 1 to end of Week 13 (0 to 13 weeks 6 days)</span>
              </div>
              <!-- Second Trimester -->
              <div class="flex flex-col gap-1">
                <div class="flex justify-between text-[10px] font-bold">
                  <span class="text-charcoal flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-teal"></span>Second Trimester
                  </span>
                  <span id="range-trimester-2" class="font-mono text-stone">-</span>
                </div>
                <div class="w-full h-1.5 bg-hairline rounded-full overflow-hidden">
                  <div id="bar-trimester-2" class="h-full bg-brand-teal" style="width: 0%;"></div>
                </div>
                <span class="text-[8px] text-stone">Week 14 to end of Week 27 (14 weeks 0 days to 27 weeks 6 days)</span>
              </div>
              <!-- Third Trimester -->
              <div class="flex flex-col gap-1">
                <div class="flex justify-between text-[10px] font-bold">
                  <span class="text-charcoal flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-yellow-deep"></span>Third Trimester
