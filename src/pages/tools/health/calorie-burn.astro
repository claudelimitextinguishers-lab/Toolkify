        unitMetricBtn?.classList.remove("bg-primary", "text-canvas");
        unitMetricBtn?.classList.add("text-slate");

        imperialWeightContainer?.classList.remove("hidden");
        metricWeightContainer?.classList.add("hidden");

        if (weightLabel) weightLabel.textContent = `${weightLbs} lb`;
        if (heightUnitLbl) heightUnitLbl.textContent = "in";
      }
    }

    function updateActivityList() {
      if (!activityList) return;
      activityList.innerHTML = "";

      const query = activitySearch ? activitySearch.value.toLowerCase() : "";
      const cat = categoryFilter ? categoryFilter.value : "all";

      const filtered = ACTIVITIES.filter(act => {
        const matchesQuery = act.name.toLowerCase().includes(query) || act.desc.toLowerCase().includes(query);
        const matchesCategory = cat === "all" || act.category === cat;
        return matchesQuery && matchesCategory;
      });

      filtered.forEach(act => {
        const item = document.createElement("button");
        item.type = "button";
        const isActive = act.id === activeActivityId;

        let itemStyle = "border-hairline bg-canvas hover:bg-surface text-slate";
        if (isActive) {
          itemStyle = "border-brand-blue bg-surface shadow-[0_0_8px_rgba(66,98,255,0.12)] ring-1 ring-brand-blue/20 text-primary font-semibold";
        }

        item.className = `flex flex-col p-2 border rounded-md text-left transition-all cursor-pointer relative w-full ${itemStyle}`;
        item.innerHTML = `
          <span class="text-[10px] font-bold text-primary block">${act.name}</span>
          <span class="text-[8px] text-stone font-medium leading-tight mt-0.5">${act.desc}</span>
        `;

        item.addEventListener("click", () => {
          activeActivityId = act.id;
          saveState();
          updateActivityList();
          calculate();
        });

        activityList.appendChild(item);
      });
    }

    function calculate() {
      const selectedActivity = ACTIVITIES.find(act => act.id === activeActivityId) || ACTIVITIES[0];
      
      // Determine MET rate
      let metVal = 1.0;
      if (customMetOverride !== null && !isNaN(customMetOverride)) {
        metVal = customMetOverride;
      } else {
        const intensities = selectedActivity.mets;
        metVal = intensities[activeIntensity] || intensities.moderate;
      }

      // Update Intensity toggle visibility
      if (selectedActivity.hasIntensity && customMetOverride === null) {
        intensityContainer?.classList.remove("hidden");
        // highlight active intensity button
        [intensityLight, intensityModerate, intensityVigorous].forEach(btn => {
          btn?.classList.remove("bg-primary", "text-canvas");
          btn?.classList.add("text-slate");
        });
        let activeBtn = intensityModerate;
        if (activeIntensity === "light") activeBtn = intensityLight;
        if (activeIntensity === "vigorous") activeBtn = intensityVigorous;
        activeBtn?.classList.add("bg-primary", "text-canvas");
        activeBtn?.classList.remove("text-slate");
      } else {
        intensityContainer?.classList.add("hidden");
      }

      // Compute weight in kg
      const finalWeightKg = currentUnit === "metric" ? weightKg : weightLbs / 2.20462;
      const durationHours = durationMins / 60;

      // Calories Burned formula: Calories = MET * weight (kg) * duration (hours)
      const caloriesBurned = Math.round(metVal * finalWeightKg * durationHours);

      // Update basic result card text
      if (exerciseNameLbl) {
        if (customMetOverride !== null) {
          exerciseNameLbl.textContent = `Custom Activity (MET: ${metVal})`;
        } else {
          exerciseNameLbl.textContent = `${selectedActivity.name} (${activeIntensity} intensity)`;
        }
      }
      if (outputCalories) outputCalories.textContent = caloriesBurned.toLocaleString();
      if (outputMet) outputMet.textContent = `${metVal.toFixed(1)} METs`;
      if (outputRatio) outputRatio.textContent = `${metVal.toFixed(1)}x rest`;

      // Status indicator pulse adjustment
      if (statusPulse && statusDot) {
        let pulseColor = "bg-success-accent";
        if (metVal >= 8.0) {
          pulseColor = "bg-brand-coral";
        } else if (metVal >= 4.0) {
          pulseColor = "bg-brand-yellow-deep";
        }
        statusPulse.className = `animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${pulseColor}`;
        statusDot.className = `relative inline-flex rounded-full h-2 w-2 ${pulseColor}`;
      }

      // Food Equivalents percentage updates
      const bananaKcal = 100;
      const pizzaKcal = 280;

      const bananaPct = Math.min(100, Math.round((caloriesBurned / bananaKcal) * 100));
      const pizzaPct = Math.min(100, Math.round((caloriesBurned / pizzaKcal) * 100));

      if (eqBananaPct) eqBananaPct.textContent = `${Math.round((caloriesBurned / bananaKcal) * 10) / 10}x Bananas`;
      if (eqBananaBar) eqBananaBar.style.width = `${bananaPct}%`;

      if (eqPizzaPct) eqPizzaPct.textContent = `${Math.round((caloriesBurned / pizzaKcal) * 10) / 10}x Slice`;
      if (eqPizzaBar) eqPizzaBar.style.width = `${pizzaPct}%`;

      // Detailed Breakdown Update
      updateBreakdown(caloriesBurned, metVal, finalWeightKg);
      
      saveState();
    }

    function updateBreakdown(totalBurn: number, metVal: number, finalWeightKg: number) {
      if (!timeChartSvg || !comparisonChartSvg || !analysisSummaryPara) return;

      // Update projections
      const burn1x = Math.round(totalBurn);
      const burn3x = Math.round(totalBurn * 3);
      const burn5x = Math.round(totalBurn * 5);

      if (proj1x) proj1x.textContent = `${burn1x.toLocaleString()} kcal`;
      if (proj1xFat) proj1xFat.textContent = `~${(burn1x / 7700).toFixed(2)} kg fat loss equivalent`;
      if (proj3x) proj3x.textContent = `${burn3x.toLocaleString()} kcal`;
      if (proj3xFat) proj3xFat.textContent = `~${(burn3x / 7700).toFixed(2)} kg fat loss equivalent`;
      if (proj5x) proj5x.textContent = `${burn5x.toLocaleString()} kcal`;
      if (proj5xFat) proj5xFat.textContent = `~${(burn5x / 7700).toFixed(2)} kg fat loss equivalent`;

      // Generate Line Chart: Burn Over Duration
      // We project for durations: 0, 15m, 30m, 45m, 60m, 90m
      const chartDurations = [0, 15, 30, 45, 60, 90];
      const burnValues = chartDurations.map(dur => (metVal * finalWeightKg * (dur / 60)));
      const maxBurnVal = Math.max(...burnValues, 100);

      // SVG coordinates (viewBox 0 0 100 50)
      let pathData = "M 0 50";
      chartDurations.forEach((dur, idx) => {
        const x = (dur / 90) * 100;
        const y = 50 - ((burnValues[idx] / maxBurnVal) * 45); // offset from top
        pathData += ` L ${x.toFixed(1)} ${y.toFixed(1)}`;
      });

      timeChartSvg.innerHTML = `
        <line x1="0" y1="5" x2="100" y2="5" stroke="var(--color-hairline-soft)" stroke-width="0.5" stroke-dasharray="1 1" />
        <line x1="0" y1="20" x2="100" y2="20" stroke="var(--color-hairline-soft)" stroke-width="0.5" stroke-dasharray="1 1" />
        <line x1="0" y1="35" x2="100" y2="35" stroke="var(--color-hairline-soft)" stroke-width="0.5" stroke-dasharray="1 1" />
        <path d="${pathData}" fill="none" stroke="var(--color-brand-blue)" stroke-width="2.5" />
        <path d="${pathData} L 100 50 L 0 50 Z" fill="url(#blue-grad)" opacity="0.15" />
        <defs>
          <linearGradient id="blue-grad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="var(--color-brand-blue)" />
            <stop offset="100%" stop-color="var(--color-brand-blue)" stop-opacity="0" />
          </linearGradient>
        </defs>
      `;

      if (chartLblQuarter) chartLblQuarter.textContent = "15m";
      if (chartLblHalf) chartLblHalf.textContent = "45m";
      if (chartLblFull) chartLblFull.textContent = "90m";

      // Generate Comparison Bar Chart: selected activity vs standard reference points
      // reference METs: Walk (3.5), Run (9.8), Cycle (7.5) vs selected (metVal)
      const refActivities = [
        { name: "Walking", met: 3.5 },
        { name: "Running", met: 9.8 },
        { name: "Cycling", met: 7.5 },
        { name: "Selected", met: metVal }
      ];

      const refBurns = refActivities.map(ref => Math.round(ref.met * finalWeightKg * (durationMins / 60)));
      const maxRefBurn = Math.max(...refBurns, 100);

      let barHtml = "";
      refBurns.forEach((burn, idx) => {
        const barWidth = 14;
        const spacing = 10;
        const x = 6 + idx * (barWidth + spacing);
        const barHeight = (burn / maxRefBurn) * 40;
        const y = 45 - barHeight;
        
        let barColor = "var(--color-brand-teal)";
        if (idx === 3) barColor = "var(--color-brand-blue)"; // selected exercise gets brand blue
        if (refActivities[idx].name === "Running") barColor = "var(--color-brand-coral)";

        barHtml += `
          <rect x="${x}" y="${y}" width="${barWidth}" height="${barHeight}" rx="2" fill="${barColor}" opacity="0.85" />
          <text x="${x + barWidth/2}" y="${y - 2}" text-anchor="middle" font-size="3" font-family="var(--font-body)" font-weight="bold" fill="var(--color-primary)">${burn}</text>
        `;
      });

      comparisonChartSvg.innerHTML = `
        <line x1="0" y1="45" x2="100" y2="45" stroke="var(--color-hairline)" stroke-width="0.5" />
        ${barHtml}
      `;

      // Update text explanation BMR context
      let height = parseInt(heightInput?.value || "175", 10);
      if (isNaN(height)) {
        height = currentUnit === "metric" ? 175 : 69;
      }
      let biologicalSex = sexSelect?.value || "male";
      let userAge = parseInt(ageInput?.value || "30", 10);
      if (isNaN(userAge)) {
        userAge = 30;
      }

      // Estimate rest metabolic rate for same duration
      // BMR estimate via Mifflin-St Jeor:
      // Male: 10 * weight (kg) + 6.25 * height (cm) - 5 * age + 5
      // Female: 10 * weight (kg) + 6.25 * height (cm) - 5 * age - 161
      let finalHeightCm = height;
      if (currentUnit === "imperial") {
        finalHeightCm = height * 2.54;
      }
      
      let baseBmrDaily = 10 * finalWeightKg + 6.25 * finalHeightCm - 5 * userAge;
      let isUnspecifiedSex = (biologicalSex !== "male" && biologicalSex !== "female");
      if (biologicalSex === "male") {
        baseBmrDaily += 5;
      } else if (biologicalSex === "female") {
        baseBmrDaily -= 161;
      } else {
        baseBmrDaily -= 78; // average of male (+5) and female (-161) Mifflin-St Jeor offsets
      }

      const bmrKcalForDuration = Math.round((baseBmrDaily / 24) * (durationMins / 60));
      const netCalorieBurn = Math.max(0, totalBurn - bmrKcalForDuration);

      if (analysisSummaryPara) {
        let bmrText = `For context, your body would have burned roughly <strong>${bmrKcalForDuration} calories</strong> just resting during this same window.`;
        if (isUnspecifiedSex) {
          bmrText = `For context, your body would have burned roughly <strong>${bmrKcalForDuration} calories</strong> resting during this same window (using an average of male and female baseline metrics for unspecified sex).`;
        }

        analysisSummaryPara.innerHTML = `
          <p class="mb-2">
            Based on your body profile, you expended approximately <strong>${totalBurn.toLocaleString()} gross calories</strong> during this ${durationMins}-minute session. 
            ${bmrText} 
            This results in a <strong>net exercise burn of ${netCalorieBurn.toLocaleString()} calories</strong> directly attributable to your activity effort.
          </p>
          <p>
            If you perform this routine 3 times a week, you'll accumulate a weekly deficit of <strong>${burn3x.toLocaleString()} calories</strong>, which equals a fat-loss equivalent of <strong>${(burn3x / 7700).toFixed(2)} kg</strong> per week, assuming your diet remains at baseline maintenance level.
          </p>
        `;
      }
    }

    // Toggle detailed breakdown animation
    toggleBreakdownBtn?.addEventListener("click", () => {
      if (breakdownSection) {
        const isCollapsed = breakdownSection.classList.contains("max-h-0");
        if (isCollapsed) {
          breakdownSection.classList.remove("max-h-0");
          breakdownSection.classList.add("max-h-[2000px]");
          setTimeout(() => {
            scrollToElementWithOffset("breakdown-section", 60);
          }, 100);
        } else {
          breakdownSection.classList.remove("max-h-[2000px]");
          breakdownSection.classList.add("max-h-0");
        }
      }
    });

    // Advanced options panel toggle
    advancedToggleBtn?.addEventListener("click", () => {
      if (advancedPanel && advancedChevron) {
        const isCollapsed = advancedPanel.style.maxHeight === "0px" || !advancedPanel.style.maxHeight;
        if (isCollapsed) {
          advancedPanel.style.maxHeight = advancedPanel.scrollHeight + "px";
          advancedChevron.classList.add("rotate-180");
        } else {
          advancedPanel.style.maxHeight = "0px";
          advancedChevron.classList.remove("rotate-180");
        }
      }
    });

    // View result smooth scroll from advanced panel
    advancedViewResultBtn?.addEventListener("click", () => {
      scrollToElementWithOffset("results-card", 80);
    });

    // Unit toggle button bindings
    unitMetricBtn?.addEventListener("click", () => {
      if (currentUnit !== "metric") {
        currentUnit = "metric";
        // Convert weight values
        weightKg = Math.round(weightLbs / 2.20462);
        updateInputsFromState();
        updateUnitUI();
        calculate();
      }
    });

    unitImperialBtn?.addEventListener("click", () => {
      if (currentUnit !== "imperial") {
        currentUnit = "imperial";
        // Convert weight values
        weightLbs = Math.round(weightKg * 2.20462);
        updateInputsFromState();
        updateUnitUI();
        calculate();
      }
    });

    // Weight range / input connections
    weightMetricRange?.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        weightKg = parseInt(target.value, 10);
        if (weightMetricInput) weightMetricInput.value = weightKg.toString();
        if (weightLabel) weightLabel.textContent = `${weightKg} kg`;
        calculate();
      }
    });

    weightMetricInput?.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        let val = parseInt(target.value, 10);
        if (isNaN(val) || val < 30) val = 30;
        if (val > 200) val = 200;
        weightKg = val;
        if (weightMetricRange) weightMetricRange.value = weightKg.toString();
        target.value = weightKg.toString();
        if (weightLabel) weightLabel.textContent = `${weightKg} kg`;
        calculate();
      }
    });

    weightLbsRange?.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        weightLbs = parseInt(target.value, 10);
        if (weightLbsInput) weightLbsInput.value = weightLbs.toString();
        if (weightLabel) weightLabel.textContent = `${weightLbs} lb`;
        calculate();
      }
    });

    weightLbsInput?.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        let val = parseInt(target.value, 10);
        if (isNaN(val) || val < 60) val = 60;
        if (val > 450) val = 450;
        weightLbs = val;
        if (weightLbsRange) weightLbsRange.value = weightLbs.toString();
        target.value = weightLbs.toString();
        if (weightLabel) weightLabel.textContent = `${weightLbs} lb`;
        calculate();
      }
    });

    // Duration inputs connection
    durationRange?.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        durationMins = parseInt(target.value, 10);
        if (durationInput) durationInput.value = durationMins.toString();
        if (durationLabel) durationLabel.textContent = `${durationMins} mins`;
        calculate();
      }
    });

    durationInput?.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        let val = parseInt(target.value, 10);
        if (isNaN(val) || val < 1) val = 1;
        if (val > 300) val = 300;
        durationMins = val;
        if (durationRange) durationRange.value = durationMins.toString();
        target.value = durationMins.toString();
        if (durationLabel) durationLabel.textContent = `${durationMins} mins`;
        calculate();
      }
    });

    // Activity list filtering & search
    activitySearch?.addEventListener("input", updateActivityList);
    categoryFilter?.addEventListener("change", updateActivityList);

    // Intensity buttons bindings
    intensityLight?.addEventListener("click", () => {
      activeIntensity = "light";
      calculate();
    });
    intensityModerate?.addEventListener("click", () => {
      activeIntensity = "moderate";
      calculate();
    });
    intensityVigorous?.addEventListener("click", () => {
      activeIntensity = "vigorous";
      calculate();
    });

    // BMR Advanced options change
    sexSelect?.addEventListener("change", calculate);
    ageInput?.addEventListener("change", () => {
      if (ageInput) {
        let val = parseInt(ageInput.value, 10);
        if (isNaN(val) || val < 10) val = 10;
        if (val > 100) val = 100;
        ageInput.value = val.toString();
        calculate();
      }
    });
    heightInput?.addEventListener("change", () => {
      if (heightInput) {
        let val = parseInt(heightInput.value, 10);
        if (currentUnit === "metric") {
          if (isNaN(val) || val < 80) val = 80;
          if (val > 250) val = 250;
          heightCm = val;
        } else {
          if (isNaN(val) || val < 30) val = 30;
          if (val > 100) val = 100;
          heightCm = Math.round(val * 2.54);
        }
        heightInput.value = (currentUnit === "metric" ? heightCm : Math.round(heightCm / 2.54)).toString();
        calculate();
      }
    });

    customMetInput?.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        const val = parseFloat(target.value);
        if (!isNaN(val) && val > 0) {
          customMetOverride = val;
        } else {
          customMetOverride = null;
        }
        calculate();
      }
    });

    // Export / Print PDF handler
    exportPdfBtn?.addEventListener("click", () => {
      if (breakdownSection && breakdownSection.classList.contains("max-h-0")) {
        breakdownSection.classList.remove("max-h-0");
        breakdownSection.classList.add("max-h-[2000px]");
        setTimeout(() => {
          window.print();
        }, 350);
      } else {
        window.print();
      }
    });

    // Reset button
    resetBtn?.addEventListener("click", () => {
      // Clear URL parameters
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({path:newurl}, '', newurl);
      }

      const keys = [
        "calorie-burn-unit",
        "calorie-burn-wkg",
        "calorie-burn-wlbs",
        "calorie-burn-dur",
        "calorie-burn-act",
        "calorie-burn-int",
        "calorie-burn-sex",
        "calorie-burn-age",
        "calorie-burn-custom-met",
        "calorie-burn-h-cm"
      ];
      keys.forEach(k => localStorage.removeItem(k));

      currentUnit = "imperial";
      weightKg = 70;
      weightLbs = 154;
      durationMins = 30;
      activeActivityId = "walking";
      activeIntensity = "moderate";
      customMetOverride = null;
      heightCm = 175;

      if (sexSelect) sexSelect.value = "male";
      if (ageInput) ageInput.value = "30";
      if (customMetInput) customMetInput.value = "";
      if (heightInput) heightInput.value = "175";
      if (activitySearch) activitySearch.value = "";
      if (categoryFilter) categoryFilter.value = "all";

      // Hide breakdown
      if (breakdownSection) {
        breakdownSection.classList.remove("max-h-[2000px]");
        breakdownSection.classList.add("max-h-0");
      }

      // Hide advanced drawer
      if (advancedPanel && advancedChevron) {
        advancedPanel.style.maxHeight = "0px";
        advancedChevron.classList.remove("rotate-180");
      }

      updateInputsFromState();
      updateUnitUI();
      updateActivityList();
      calculate();
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Initial load
    loadState();
  </script>
</Layout>

<style>
  /* Premium print overrides for PDF exports */
  @media print {
    body * {
      visibility: hidden;
    }
    #breakdown-section, #breakdown-section * {
      visibility: visible;
    }
    #breakdown-section {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
    }
    #export-pdf-btn {
      display: none;
    }
  }

  /* Compact styling for scrollbars */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
