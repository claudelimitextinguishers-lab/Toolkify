    // Helper functions for parsing and updating
    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }

