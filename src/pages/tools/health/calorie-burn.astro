    // Share Event
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("unit", currentUnit);
      url.searchParams.set("wkg", weightKg.toString());
      url.searchParams.set("wlbs", weightLbs.toString());
      url.searchParams.set("dur", durationMins.toString());
      url.searchParams.set("act", activeActivityId);
      url.searchParams.set("int", activeIntensity);
      if (sexSelect) url.searchParams.set("sex", sexSelect.value);
      if (ageInput) url.searchParams.set("age", ageInput.value);
      if (customMetInput) url.searchParams.set("custom-met", customMetInput.value);
      url.searchParams.set("h-cm", heightCm.toString());

      const shareData = {
        title: document.title || "Calorie Burn Calculator",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Load state from localStorage or URL
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      // get(lsKey, urlKey): URL params always take priority over localStorage
      const get = (lsKey: string, urlKey: string): string | null => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        if (typeof localStorage === 'undefined') return null;
        try { return localStorage.getItem(lsKey); } catch (e) { return null; }
      };

      try {
        const savedUnit = get("calorie-burn-unit", "unit");
        const savedWeightKg = get("calorie-burn-wkg", "wkg");
        const savedWeightLbs = get("calorie-burn-wlbs", "wlbs");
        const savedDuration = get("calorie-burn-dur", "dur");
        const savedActivity = get("calorie-burn-act", "act");
        const savedIntensity = get("calorie-burn-int", "int");
        const savedSex = get("calorie-burn-sex", "sex");
        const savedAge = get("calorie-burn-age", "age");
        const savedCustomMet = get("calorie-burn-custom-met", "custom-met");
        const savedHeightCm = get("calorie-burn-h-cm", "h-cm");

        if (savedUnit) currentUnit = savedUnit;
        if (savedWeightKg) weightKg = parseInt(savedWeightKg, 10);
        if (savedWeightLbs) weightLbs = parseInt(savedWeightLbs, 10);
        if (savedDuration) durationMins = parseInt(savedDuration, 10);
        if (savedActivity) activeActivityId = savedActivity;
        if (savedIntensity && (savedIntensity === "light" || savedIntensity === "moderate" || savedIntensity === "vigorous")) {
          activeIntensity = savedIntensity;
        }
        
        if (savedSex && sexSelect) sexSelect.value = savedSex;
        if (savedAge && ageInput) ageInput.value = savedAge;
        if (savedCustomMet && customMetInput) {
          customMetInput.value = savedCustomMet;
          customMetOverride = parseFloat(savedCustomMet);
        }
        if (savedHeightCm) {
          heightCm = parseInt(savedHeightCm, 10);
        } else {
          // fallback to reading height-input if preset
          const hVal = heightInput ? parseInt(heightInput.value, 10) : 175;
          if (currentUnit === "metric") {
            heightCm = hVal;
          } else {
            heightCm = Math.round(hVal * 2.54);
          }
        }

      } catch (e) {
        console.warn("Failed loading local state:", e);
      }
      updateInputsFromState();
      updateUnitUI();
      updateActivityList();
      calculate();
    }

    // Save state to localStorage
    function saveState() {
      try {
        localStorage.setItem("calorie-burn-unit", currentUnit);
        localStorage.setItem("calorie-burn-wkg", weightKg.toString());
        localStorage.setItem("calorie-burn-wlbs", weightLbs.toString());
        localStorage.setItem("calorie-burn-dur", durationMins.toString());
        localStorage.setItem("calorie-burn-act", activeActivityId);
        localStorage.setItem("calorie-burn-int", activeIntensity);
        localStorage.setItem("calorie-burn-sex", sexSelect?.value || "male");
        localStorage.setItem("calorie-burn-age", ageInput?.value || "30");
        localStorage.setItem("calorie-burn-custom-met", customMetInput?.value || "");
        localStorage.setItem("calorie-burn-h-cm", heightCm.toString());
      } catch (e) {
        console.warn("Failed saving state:", e);
      }
    }

    function updateInputsFromState() {
      if (durationRange) durationRange.value = durationMins.toString();
      if (durationInput) durationInput.value = durationMins.toString();
      if (weightMetricRange) weightMetricRange.value = weightKg.toString();
      if (weightMetricInput) weightMetricInput.value = weightKg.toString();
      if (weightLbsRange) weightLbsRange.value = weightLbs.toString();
      if (weightLbsInput) weightLbsInput.value = weightLbs.toString();
      
      // Update height input min, max, value
      if (heightInput) {
        if (currentUnit === "metric") {
          heightInput.min = "80";
          heightInput.max = "250";
          heightInput.value = heightCm.toString();
        } else {
          heightInput.min = "30";
          heightInput.max = "100";
          heightInput.value = Math.round(heightCm / 2.54).toString();
