  <!-- Client-side script module -->
  <script>
    // State variables
    let currentUnit = "imperial"; // metric | imperial
    let weightKg = 72;
    let weightLbs = 160;
    let activityLevel = "light"; // sedentary, light, moderate, very, extra
    let climate = "temperate"; // temperate, warm, hot, dry
    let isPregnant = false;
    let isBreastfeeding = false;

    // Advanced parameters
    let hasCustomWorkout = false;
    let workoutDuration = 0;
    let workoutIntensity = "moderate";
    let altitude = "sea"; // sea, high
    let dietStyle = "standard"; // standard, water-rich, dry-processed
    let caffeineCups = 0;
    let alcoholDrinks = 0;

    let targetLiters = 2.8;

    // DOM Elements
    const unitMetricBtn = document.getElementById("unit-metric-btn");
    const unitImperialBtn = document.getElementById("unit-imperial-btn");
    const weightLabel = document.getElementById("weight-label");

    const metricWeightContainer = document.getElementById("metric-weight-container");
    const imperialWeightContainer = document.getElementById("imperial-weight-container");
    const weightMetricRange = document.getElementById("weight-metric-range") as HTMLInputElement;
    const weightMetricInput = document.getElementById("weight-metric-input") as HTMLInputElement;
    const weightLbsRange = document.getElementById("weight-lbs-range") as HTMLInputElement;
    const weightLbsInput = document.getElementById("weight-lbs-input") as HTMLInputElement;

    const activitySelect = document.getElementById("activity-select") as HTMLSelectElement;
    const climateSelect = document.getElementById("climate-select") as HTMLSelectElement;

    const pregnantBtn = document.getElementById("pregnant-btn");
    const breastfeedingBtn = document.getElementById("breastfeeding-btn");

    // Advanced Options Elements
    const advancedToggleBtn = document.getElementById("advanced-toggle-btn");
    const advancedPanel = document.getElementById("advanced-panel");
    const advancedChevron = document.getElementById("advanced-chevron");
    const workoutDurationInput = document.getElementById("workout-duration") as HTMLInputElement;
    const workoutIntensitySelect = document.getElementById("workout-intensity") as HTMLSelectElement;
    const altitudeSelect = document.getElementById("altitude-select") as HTMLSelectElement;
    const dietSelect = document.getElementById("diet-select") as HTMLSelectElement;
    const caffeineInput = document.getElementById("caffeine-drinks") as HTMLInputElement;
    const alcoholInput = document.getElementById("alcohol-drinks") as HTMLInputElement;
    const advancedViewResultBtn = document.getElementById("advanced-view-result-btn");

    // Output Displays
    const outputLiters = document.getElementById("output-water-liters");
    const outputOunces = document.getElementById("output-water-ounces");
    const waterFill = document.getElementById("water-fill");
    const waterWave = document.getElementById("water-wave");
    const glassPercent = document.getElementById("glass-percent");
    const glassesCountLabel = document.getElementById("glasses-count-label");
    const glassesGrid = document.getElementById("glasses-grid");
    const adviceText = document.getElementById("advice-text");
    const medicalAdviceBanner = document.getElementById("medical-advice-banner");

    // Breakdown Elements
    const toggleBreakdownBtn = document.getElementById("toggle-breakdown-btn");
    const breakdownSection = document.getElementById("breakdown-section");
    const exportPdfBtn = document.getElementById("export-pdf-btn");

    // Contribution displays
    const contribBaselineVal = document.getElementById("contrib-baseline-val");
    const contribActivityVal = document.getElementById("contrib-activity-val");
    const contribClimateVal = document.getElementById("contrib-climate-val");
    const contribOtherVal = document.getElementById("contrib-other-val");

    const contribBaselineBar = document.getElementById("contrib-baseline-bar");
    const contribActivityBar = document.getElementById("contrib-activity-bar");
    const contribClimateBar = document.getElementById("contrib-climate-bar");
    const contribOtherBar = document.getElementById("contrib-other-bar");

    // Hourly Schedule displays
    const schedWake = document.getElementById("sched-wake");
    const schedMidmorning = document.getElementById("sched-midmorning");
    const schedLunch = document.getElementById("sched-lunch");
    const schedAfternoon = document.getElementById("sched-afternoon");
    const schedDinner = document.getElementById("sched-dinner");
    const schedEvening = document.getElementById("sched-evening");
    const schedWorkout = document.getElementById("sched-workout");
    const workoutScheduleRow = document.getElementById("workout-schedule-row");

    const analysisSummaryPara = document.getElementById("analysis-summary-para");
    const resetBtn = document.getElementById("reset-btn");

    // How it works modal injection
    const modalHtml = `
      <div
        id="how-it-works-modal"
        class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
      >
        <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto">
          <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
            <h3 class="font-display font-semibold text-lg text-primary">How the Water Intake Calculator Works</h3>
            <button type="button" id="close-modal-btn" class="text-stone hover:text-primary transition-all text-lg cursor-pointer bg-transparent border-none">&#x2715;</button>
          </div>
          <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
            <h4 class="font-semibold text-primary">1. Baseline by Body Weight</h4>
            <p>The calculator starts with approximately 35 ml of water per kilogram of body weight. This is the medically recommended baseline for a sedentary adult in a temperate climate.</p>
            <h4 class="font-semibold text-primary">2. Activity & Climate Adjustments</h4>
            <p>Physical activity and hot or dry climates significantly increase sweat loss. Workout duration and intensity are used to calculate precise sweat-related adjustments, on top of the general activity multiplier.</p>
            <h4 class="font-semibold text-primary">3. Special Conditions & Diuretics</h4>
            <p>Pregnancy adds ~350 ml/day and breastfeeding adds ~800 ml/day. High altitude, dry diet, and diuretics (caffeine and alcohol) are also factored in to give a holistic, personalised daily water target.</p>
          </div>
          <button type="button" id="modal-ok-btn" class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer">Got it</button>
        </div>
      </div>
    `;
    document.body.insertAdjacentHTML("beforeend", modalHtml);

    const shareBtn = document.getElementById("share-btn");
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("unit", currentUnit);
      url.searchParams.set("wkg", weightKg.toString());
      url.searchParams.set("wlbs", weightLbs.toString());
      url.searchParams.set("act", activityLevel);
      url.searchParams.set("climate", climate);
      url.searchParams.set("preg", isPregnant.toString());
      url.searchParams.set("bf", isBreastfeeding.toString());
      url.searchParams.set("wdur", workoutDuration.toString());
      url.searchParams.set("wint", workoutIntensity);
      url.searchParams.set("alt", altitude);
      url.searchParams.set("diet", dietStyle);
      url.searchParams.set("caff", caffeineCups.toString());
      url.searchParams.set("alc", alcoholDrinks.toString());

      const shareData = { title: document.title || "Water Intake Calculator", url: url.toString() };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") copyToClipboard(url.toString());
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard?.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else fallbackCopy(text);
      }
      function fallbackCopy(text: string) {
        const ta = document.createElement("textarea");
        ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
        document.body.appendChild(ta); ta.select();
        try { document.execCommand("copy"); showSuccess(); } catch(e) {}
        document.body.removeChild(ta);
      }
      function showSuccess() {
        if (!shareBtn) return;
        const span = shareBtn.querySelector("span");
        if (!span) return;
        const orig = span.textContent || "Share";
        span.textContent = "Link Copied!";
        shareBtn.classList.add("text-success-accent", "border-success-accent");
        setTimeout(() => { span.textContent = orig; shareBtn.classList.remove("text-success-accent", "border-success-accent"); }, 2000);
      }
    });

    // Load state from localStorage or URL params
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const get = (lsKey: string, urlKey: string): string | null => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        try { return localStorage.getItem(lsKey); } catch(e) { return null; }
      };

      try {
        const savedUnit = get("water-unit", "unit");
        const savedWeightKg = get("water-weight-kg", "wkg");
        const savedWeightLbs = get("water-weight-lbs", "wlbs");
        const savedActivity = get("water-activity", "act");
        const savedClimate = get("water-climate", "climate");
        const savedPregnant = get("water-pregnant", "preg");
        const savedBreastfeeding = get("water-breastfeeding", "bf");
        const savedWorkoutDur = get("water-workout-dur", "wdur");
        const savedWorkoutInt = get("water-workout-int", "wint");
        const savedAltitude = get("water-altitude", "alt");
        const savedDiet = get("water-diet", "diet");
        const savedCaffeine = get("water-caffeine", "caff");
        const savedAlcohol = get("water-alcohol", "alc");

        if (savedUnit) currentUnit = savedUnit;
        if (savedWeightKg) weightKg = parseInt(savedWeightKg, 10);
        if (savedWeightLbs) weightLbs = parseInt(savedWeightLbs, 10);
        if (savedActivity) activityLevel = savedActivity;
        if (savedClimate) climate = savedClimate;
        if (savedPregnant) isPregnant = savedPregnant === "true";
        if (savedBreastfeeding) isBreastfeeding = savedBreastfeeding === "true";

        if (savedWorkoutDur) workoutDuration = parseInt(savedWorkoutDur, 10);
        if (savedWorkoutInt) workoutIntensity = savedWorkoutInt;
        if (savedAltitude) altitude = savedAltitude;
        if (savedDiet) dietStyle = savedDiet;
        if (savedCaffeine) caffeineCups = parseInt(savedCaffeine, 10);
        if (savedAlcohol) alcoholDrinks = parseInt(savedAlcohol, 10);

        // Apply to DOM fields
        if (activitySelect) activitySelect.value = activityLevel;
        if (climateSelect) climateSelect.value = climate;

        if (workoutDurationInput) workoutDurationInput.value = workoutDuration > 0 ? workoutDuration.toString() : "";
        if (workoutIntensitySelect) workoutIntensitySelect.value = workoutIntensity;
        if (altitudeSelect) altitudeSelect.value = altitude;
        if (dietSelect) dietSelect.value = dietStyle;
        if (caffeineInput) caffeineInput.value = caffeineCups.toString();
        if (alcoholInput) alcoholInput.value = alcoholDrinks.toString();

      } catch (e) {
        console.warn("Failed loading state:", e);
      }
      updateInputsFromState();
      updateUnitUI();
      updateLabels();
      calculate();
    }



    function saveState() {
      try {
        localStorage.setItem("water-unit", currentUnit);
        localStorage.setItem("water-weight-kg", weightKg.toString());
        localStorage.setItem("water-weight-lbs", weightLbs.toString());
        localStorage.setItem("water-activity", activityLevel);
        localStorage.setItem("water-climate", climate);
        localStorage.setItem("water-pregnant", isPregnant.toString());
        localStorage.setItem("water-breastfeeding", isBreastfeeding.toString());
        localStorage.setItem("water-workout-dur", workoutDuration.toString());
        localStorage.setItem("water-workout-int", workoutIntensity);
        localStorage.setItem("water-altitude", altitude);
        localStorage.setItem("water-diet", dietStyle);
        localStorage.setItem("water-caffeine", caffeineCups.toString());
        localStorage.setItem("water-alcohol", alcoholDrinks.toString());
      } catch (e) {
        console.warn("Failed saving state to localStorage:", e);
      }
    }

    function updateInputsFromState() {
      if (weightMetricRange) weightMetricRange.value = weightKg.toString();
      if (weightMetricInput) weightMetricInput.value = weightKg.toString();
      if (weightLbsRange) weightLbsRange.value = weightLbs.toString();
      if (weightLbsInput) weightLbsInput.value = weightLbs.toString();

      // Pregnancy/Breastfeeding button states
      updateSpecialConditionUI();
    }

    function updateSpecialConditionUI() {
      if (pregnantBtn) {
        const checkbox = pregnantBtn.querySelector("div > span");
        if (isPregnant) {
          pregnantBtn.classList.add("border-brand-blue", "bg-surface-pricing-featured");
          pregnantBtn.classList.remove("border-hairline", "bg-canvas");
          checkbox?.classList.remove("hidden");
        } else {
          pregnantBtn.classList.remove("border-brand-blue", "bg-surface-pricing-featured");
          pregnantBtn.classList.add("border-hairline", "bg-canvas");
          checkbox?.classList.add("hidden");
        }
      }

      if (breastfeedingBtn) {
        const checkbox = breastfeedingBtn.querySelector("div > span");
        if (isBreastfeeding) {
          breastfeedingBtn.classList.add("border-brand-blue", "bg-surface-pricing-featured");
          breastfeedingBtn.classList.remove("border-hairline", "bg-canvas");
          checkbox?.classList.remove("hidden");
        } else {
          breastfeedingBtn.classList.remove("border-brand-blue", "bg-surface-pricing-featured");
          breastfeedingBtn.classList.add("border-hairline", "bg-canvas");
          checkbox?.classList.add("hidden");
        }
      }
    }

    function updateUnitUI() {
      if (currentUnit === "metric") {
        unitMetricBtn?.classList.add("bg-primary", "text-canvas");
        unitMetricBtn?.classList.remove("text-slate");
        unitImperialBtn?.classList.remove("bg-primary", "text-canvas");
        unitImperialBtn?.classList.add("text-slate");

        metricWeightContainer?.classList.remove("hidden");
        imperialWeightContainer?.classList.add("hidden");
      } else {
        unitImperialBtn?.classList.add("bg-primary", "text-canvas");
        unitImperialBtn?.classList.remove("text-slate");
        unitMetricBtn?.classList.remove("bg-primary", "text-canvas");
        unitMetricBtn?.classList.add("text-slate");

        imperialWeightContainer?.classList.remove("hidden");
        metricWeightContainer?.classList.add("hidden");
      }
    }

    function updateLabels() {
      if (weightLabel) {
        if (currentUnit === "metric") {
          weightLabel.textContent = `${weightKg} kg`;
        } else {
          weightLabel.textContent = `${weightLbs} lb`;
        }
      }
    }

    // Core Calculation Logic
    function calculate() {
      // 1. Get active weight in kilograms for baseline
      const activeWeightKg = currentUnit === "metric" ? weightKg : weightLbs / 2.20462;
      
      // Baseline calculation: 35 ml per kg of body weight
      const baselineMl = activeWeightKg * 35;

      // 2. Activity Adjustment
      let activityMl = 0;
      hasCustomWorkout = workoutDuration > 0;

      if (hasCustomWorkout) {
        // Specific minutes overrides the general selector
        let factor = 12; // moderate = 12 ml per minute
        if (workoutIntensity === "low") factor = 7;
        else if (workoutIntensity === "high") factor = 17;

        activityMl = workoutDuration * factor;
      } else {
        // Fallback to general activity selector
        if (activityLevel === "light") activityMl = 350;
        else if (activityLevel === "moderate") activityMl = 700;
        else if (activityLevel === "very") activityMl = 1050;
        else if (activityLevel === "extra") activityMl = 1400;
      }

      // 3. Climate Adjustment
      let climateMl = 0;
      if (climate === "warm") climateMl = 250;
      else if (climate === "hot") climateMl = 600;
      else if (climate === "dry") climateMl = 400;

      // 4. Special Pregnancy / Breastfeeding factors
      let specialMl = 0;
      if (isPregnant) specialMl += 350;
      if (isBreastfeeding) specialMl += 800;

      // 5. Advanced Factors
      let advancedMl = 0;
      // Altitude
      if (altitude === "high") advancedMl += 500;
      // Diet moisture
      if (dietStyle === "water-rich") advancedMl -= 300;
      else if (dietStyle === "dry-processed") advancedMl += 200;
      // Diuretics
      advancedMl += caffeineCups * 150;
      advancedMl += alcoholDrinks * 250;

      // Calculate final target volume
      const totalMl = Math.max(1200, baselineMl + activityMl + climateMl + specialMl + advancedMl);
      targetLiters = parseFloat((totalMl / 1000).toFixed(1));
      const targetOunces = Math.round(totalMl * 0.033814);

      // Update text outputs
      if (outputLiters) outputLiters.textContent = targetLiters.toFixed(1);
      if (outputOunces) outputOunces.textContent = targetOunces.toString();

      // Dynamic Glass Fill percentage based on max capacity of 5.5 Liters
      const maxLiters = 5.5;
      const fillPercentage = Math.min(100, Math.max(20, Math.round((targetLiters / maxLiters) * 100)));
      if (waterFill) {
        // SVG coordinate Y goes from 0 (top) to 100 (bottom)
        const yValue = 92 - ((fillPercentage / 100) * 77); // boundaries: glass base is ~92, rim is ~15
        waterFill.setAttribute("y", yValue.toString());
        waterFill.setAttribute("height", (92 - yValue).toString());
      }
      if (waterWave) {
        const yValue = 92 - ((fillPercentage / 100) * 77);
        waterWave.setAttribute("d", `M 0 ${yValue} Q 25 ${yValue - 4}, 50 ${yValue} T 100 ${yValue} L 100 100 L 0 100 Z`);
      }
      if (glassPercent) {
        glassPercent.textContent = `${fillPercentage}%`;
      }

      // Glass Grid Display (250ml / 8oz cups count)
      const exactGlasses = totalMl / 250;
      if (glassesCountLabel) {
        glassesCountLabel.textContent = `${exactGlasses.toFixed(1)} Glasses (250ml / 8oz each)`;
      }

      if (glassesGrid) {
        glassesGrid.innerHTML = "";
        const maxCupsToRender = 16;
        const activeCups = Math.min(maxCupsToRender, Math.round(exactGlasses));
        
        for (let i = 1; i <= maxCupsToRender; i++) {
          const cup = document.createElement("div");
          cup.className = `w-7 h-8 flex flex-col justify-end p-0.5 rounded-b-md border transition-all duration-300 relative ${
            i <= activeCups 
              ? "bg-brand-blue/90 border-brand-blue text-canvas shadow-subtle scale-105" 
              : "bg-canvas border-hairline text-slate/30"
          }`;
          cup.setAttribute("title", `Glass ${i}`);
          
          // Inner wave overlay
          cup.innerHTML = `
            <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[8px] font-bold select-none ${
              i <= activeCups ? "text-canvas" : "text-stone"
            }">${i}</span>
            <div class="w-full h-1/2 bg-canvas/30 rounded-b-sm"></div>
          `;
          glassesGrid.appendChild(cup);
        }
      }

      // Doctor/Medical condition warnings
      if (isPregnant || isBreastfeeding) {
        medicalAdviceBanner?.classList.remove("hidden");
      } else {
        medicalAdviceBanner?.classList.add("hidden");
      }

      // Dynamic summary advice box text
      if (adviceText) {
        adviceText.innerHTML = `
          Your estimated hydration baseline is <strong>${(baselineMl / 1000).toFixed(1)} Liters</strong>. 
          ${activityMl > 0 ? `Physical activity adjustments add <strong>+${(activityMl / 1000).toFixed(2)}L</strong>.` : ""} 
          ${climateMl > 0 ? `Climate temperature adjustments add <strong>+${(climateMl / 1000).toFixed(2)}L</strong>.` : ""} 
          ${specialMl > 0 ? `Pregnancy/maternity adjustments add <strong>+${(specialMl / 1000).toFixed(2)}L</strong>.` : ""} 
          ${advancedMl !== 0 ? `Other factors (altitude, diet, diuretics) modify target by <strong>${advancedMl > 0 ? "+" : ""}${(advancedMl / 1000).toFixed(2)}L</strong>.` : ""}
          Your recommended daily intake is <strong>${targetLiters.toFixed(1)} Liters</strong>.
        `;
      }

      // Update Breakdown details
      updateBreakdownUI(baselineMl, activityMl, climateMl, specialMl + advancedMl, totalMl);
      
      saveState();
    }

    function updateBreakdownUI(baseline: number, activity: number, climateVol: number, otherVol: number, total: number) {
      // Contribution Values text
      if (contribBaselineVal) contribBaselineVal.textContent = `${Math.round(baseline)} ml`;
      if (contribActivityVal) contribActivityVal.textContent = `${Math.round(activity)} ml`;
      if (contribClimateVal) contribClimateVal.textContent = `${Math.round(climateVol)} ml`;
      
      const otherLabel = otherVol < 0 ? `-${Math.round(Math.abs(otherVol))} ml` : `${Math.round(otherVol)} ml`;
      if (contribOtherVal) contribOtherVal.textContent = otherLabel;

      // Contribution Percentages bar widths
      const pBaseline = Math.round((baseline / total) * 100);
      const pActivity = Math.round((activity / total) * 100);
      const pClimate = Math.round((climateVol / total) * 100);
      const pOther = Math.max(0, Math.round((otherVol / total) * 100)); // clamp to 0 if negative

      if (contribBaselineBar) contribBaselineBar.style.width = `${pBaseline}%`;
      if (contribActivityBar) contribActivityBar.style.width = `${pActivity}%`;
      if (contribClimateBar) contribClimateBar.style.width = `${pClimate}%`;
      if (contribOtherBar) contribOtherBar.style.width = `${pOther}%`;

      // Hourly Schedule Timeline estimates (Spread total over waking hours)
      // Waking day timeline allocation:

      let baseWakingTotal = total;
      const isWorkoutShown = hasCustomWorkout || activityLevel !== "sedentary";
      if (isWorkoutShown) {
        // Show workout row
        workoutScheduleRow?.classList.remove("hidden");
        const workoutVol = Math.round(total * 0.15);
        baseWakingTotal = total - workoutVol;
        if (schedWorkout) schedWorkout.textContent = `${workoutVol} ml / ${Math.round(workoutVol * 0.033814)} oz`;
      } else {
        workoutScheduleRow?.classList.add("hidden");
        baseWakingTotal = total;
      }

      const wakeVol = Math.round(baseWakingTotal * 0.18);
      const midmVol = Math.round(baseWakingTotal * 0.16);
      const lunchVol = Math.round(baseWakingTotal * 0.16);
      const afternoonVol = Math.round(baseWakingTotal * 0.18);
      const dinnerVol = Math.round(baseWakingTotal * 0.16);
      const eveningVol = Math.round(baseWakingTotal * 0.16);

      if (schedWake) schedWake.textContent = `${wakeVol} ml / ${Math.round(wakeVol * 0.033814)} oz`;
      if (schedMidmorning) schedMidmorning.textContent = `${midmVol} ml / ${Math.round(midmVol * 0.033814)} oz`;
      if (schedLunch) schedLunch.textContent = `${lunchVol} ml / ${Math.round(lunchVol * 0.033814)} oz`;
      if (schedAfternoon) schedAfternoon.textContent = `${afternoonVol} ml / ${Math.round(afternoonVol * 0.033814)} oz`;
      if (schedDinner) schedDinner.textContent = `${dinnerVol} ml / ${Math.round(dinnerVol * 0.033814)} oz`;
      if (schedEvening) schedEvening.textContent = `${eveningVol} ml / ${Math.round(eveningVol * 0.033814)} oz`;

      // Written Summary text
      if (analysisSummaryPara) {
        let conditionText = "";
        if (isPregnant) conditionText = " Because of pregnancy status, your baseline hydration needs are elevated to maintain amniotic fluid volumes and maternal vascular levels.";
        if (isBreastfeeding) conditionText = " Breastfeeding requires high daily fluid volume to sustain healthy lactation without dehydrating maternal tissues.";

        let climateText = " Your temperate environment is ideal for standard sweat rates.";
        if (climate === "warm" || climate === "hot") climateText = " Due to hot temperatures, significant fluid is lost via sweating. Drinking consistently keeps your core body temperature regulated.";
        else if (climate === "dry") climateText = " In arid regions, sweat evaporates almost instantly, making dehydration a hidden risk.";

        analysisSummaryPara.innerHTML = `
          Based on your weight of <strong>${currentUnit === 'metric' ? weightKg + ' kg' : weightLbs + ' lb'}</strong>, your minimum baseline need to sustain cellular function is <strong>${(baseline / 1000).toFixed(2)} liters</strong> daily.${conditionText}${climateText} 
          Your final target is estimated at <strong>${targetLiters.toFixed(1)} liters</strong>. Keep a water bottle handy and sip throughout the day to avoid sudden thirst indicators.
        `;
      }
    }

    // Input Events listeners
    if (weightMetricRange && weightMetricInput) {
      weightMetricRange.addEventListener("input", () => {
        weightKg = parseInt(weightMetricRange.value, 10);
        weightMetricInput.value = weightKg.toString();
        // keep lbs in sync
        weightLbs = Math.round(weightKg * 2.20462);
        if (weightLbsRange) weightLbsRange.value = weightLbs.toString();
        if (weightLbsInput) weightLbsInput.value = weightLbs.toString();
        updateLabels();
        calculate();
      });

      weightMetricInput.addEventListener("input", () => {
        let val = parseInt(weightMetricInput.value, 10) || 0;
        val = Math.max(30, Math.min(250, val));
        weightKg = val;
        weightMetricRange.value = weightKg.toString();
        // keep lbs in sync
        weightLbs = Math.round(weightKg * 2.20462);
        if (weightLbsRange) weightLbsRange.value = weightLbs.toString();
        if (weightLbsInput) weightLbsInput.value = weightLbs.toString();
        updateLabels();
        calculate();
      });
    }

    if (weightLbsRange && weightLbsInput) {
      weightLbsRange.addEventListener("input", () => {
        weightLbs = parseInt(weightLbsRange.value, 10);
        weightLbsInput.value = weightLbs.toString();
        // keep kg in sync
        weightKg = Math.round(weightLbs / 2.20462);
        if (weightMetricRange) weightMetricRange.value = weightKg.toString();
        if (weightMetricInput) weightMetricInput.value = weightKg.toString();
        updateLabels();
        calculate();
      });

      weightLbsInput.addEventListener("input", () => {
        let val = parseInt(weightLbsInput.value, 10) || 0;
        val = Math.max(65, Math.min(550, val));
        weightLbs = val;
        weightLbsRange.value = weightLbs.toString();
        // keep kg in sync
        weightKg = Math.round(weightLbs / 2.20462);
        if (weightMetricRange) weightMetricRange.value = weightKg.toString();
        if (weightMetricInput) weightMetricInput.value = weightKg.toString();
        updateLabels();
        calculate();
      });
    }

    // Units buttons
    unitMetricBtn?.addEventListener("click", () => {
      currentUnit = "metric";
      updateUnitUI();
      updateLabels();
      calculate();
    });

    unitImperialBtn?.addEventListener("click", () => {
      currentUnit = "imperial";
      updateUnitUI();
      updateLabels();
      calculate();
    });

    // Selects
    activitySelect?.addEventListener("change", () => {
      activityLevel = activitySelect.value;
      calculate();
    });

    climateSelect?.addEventListener("change", () => {
      climate = climateSelect.value;
      calculate();
    });

    // Pregnancy / Breastfeeding toggles
    pregnantBtn?.addEventListener("click", () => {
      isPregnant = !isPregnant;
      updateSpecialConditionUI();
      calculate();
    });

    breastfeedingBtn?.addEventListener("click", () => {
      isBreastfeeding = !isBreastfeeding;
      updateSpecialConditionUI();
      calculate();
    });

    // Advanced toggle
    advancedToggleBtn?.addEventListener("click", () => {
      if (advancedPanel) {
        const isCollapsed = advancedPanel.classList.contains("max-h-0");
        if (isCollapsed) {
          advancedPanel.classList.remove("max-h-0", "overflow-hidden");
          advancedPanel.classList.add("max-h-[500px]", "overflow-visible");
          advancedChevron?.classList.add("rotate-180");
        } else {
          advancedPanel.classList.remove("max-h-[500px]", "overflow-visible");
          advancedPanel.classList.add("max-h-0", "overflow-hidden");
          advancedChevron?.classList.remove("rotate-180");
        }
      }
    });

    // Scroll function helper
    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }

    // Advanced inputs
    workoutDurationInput?.addEventListener("input", () => {
      const val = parseInt(workoutDurationInput.value, 10) || 0;
      workoutDuration = Math.max(0, Math.min(360, val));
      calculate();
    });

    workoutDurationInput?.addEventListener("blur", () => {
      const val = parseInt(workoutDurationInput.value, 10);
      if (workoutDurationInput.value === "" || isNaN(val)) {
        workoutDuration = 0;
        workoutDurationInput.value = "";
      } else {
        workoutDuration = Math.max(0, Math.min(360, val));
        workoutDurationInput.value = workoutDuration.toString();
      }
      calculate();
    });

    workoutIntensitySelect?.addEventListener("change", () => {
      workoutIntensity = workoutIntensitySelect.value;
      calculate();
    });

    altitudeSelect?.addEventListener("change", () => {
      altitude = altitudeSelect.value;
      calculate();
    });

    dietSelect?.addEventListener("change", () => {
      dietStyle = dietSelect.value;
      calculate();
    });

    caffeineInput?.addEventListener("input", () => {
      caffeineCups = parseInt(caffeineInput.value, 10) || 0;
      calculate();
    });

    alcoholInput?.addEventListener("input", () => {
      alcoholDrinks = parseInt(alcoholInput.value, 10) || 0;
      calculate();
    });

    // View result smooth scrolls
    advancedViewResultBtn?.addEventListener("click", () => {
      const resultsCard = document.getElementById("results-card");
      if (resultsCard) {
        resultsCard.scrollIntoView({ behavior: "smooth", block: "center" });
        resultsCard.classList.add("ring-2", "ring-brand-blue");
        setTimeout(() => {
          resultsCard.classList.remove("ring-2", "ring-brand-blue");
        }, 1500);
      }
    });

    // Detailed Breakdown toggle
    toggleBreakdownBtn?.addEventListener("click", () => {
      if (breakdownSection) {
        const isCollapsed = breakdownSection.classList.contains("max-h-0");
        if (isCollapsed) {
          breakdownSection.classList.remove("max-h-0");
          breakdownSection.classList.add("max-h-[2000px]");
          setTimeout(() => {
            scrollToElementWithOffset("breakdown-section", 60);
          }, 100);
        } else {
          breakdownSection.classList.remove("max-h-[2000px]");
          breakdownSection.classList.add("max-h-0");
        }
      }
    });

    // Export PDF
    exportPdfBtn?.addEventListener("click", () => {
      if (breakdownSection && breakdownSection.classList.contains("max-h-0")) {
        breakdownSection.classList.remove("max-h-0");
        breakdownSection.classList.add("max-h-[2000px]");
      }
      window.print();
    });

    // Reset button
    resetBtn?.addEventListener("click", () => {
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({ path: newurl }, "", newurl);
      }

      const keys = [
        "water-unit",
        "water-weight-kg",
        "water-weight-lbs",
        "water-activity",
        "water-climate",
        "water-pregnant",
        "water-breastfeeding",
        "water-workout-dur",
        "water-workout-int",
        "water-altitude",
        "water-diet",
        "water-caffeine",
        "water-alcohol"
      ];
      keys.forEach(k => localStorage.removeItem(k));

      currentUnit = "imperial";
      weightKg = 72;
      weightLbs = 160;
      activityLevel = "light";
      climate = "temperate";
      isPregnant = false;
      isBreastfeeding = false;
      workoutDuration = 0;
      workoutIntensity = "moderate";
      altitude = "sea";
      dietStyle = "standard";
      caffeineCups = 0;
      alcoholDrinks = 0;

      if (activitySelect) activitySelect.value = "light";
      if (climateSelect) climateSelect.value = "temperate";
      if (workoutDurationInput) workoutDurationInput.value = "";
      if (workoutIntensitySelect) workoutIntensitySelect.value = "moderate";
      if (altitudeSelect) altitudeSelect.value = "sea";
      if (dietSelect) dietSelect.value = "standard";
      if (caffeineInput) caffeineInput.value = "0";
      if (alcoholInput) alcoholInput.value = "0";

      updateInputsFromState();
      updateUnitUI();
      updateLabels();
      calculate();

      // close sections
      if (advancedPanel) {
        advancedPanel.classList.remove("max-h-[500px]", "overflow-visible");
        advancedPanel.classList.add("max-h-0", "overflow-hidden");
      }
      advancedChevron?.classList.remove("rotate-180");
      if (breakdownSection) {
        breakdownSection.classList.remove("max-h-[2000px]");
        breakdownSection.classList.add("max-h-0");
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Initialize state
    loadState();
  </script>
</Layout>
