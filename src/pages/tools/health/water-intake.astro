---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Water Intake Calculator";
const category = "health";
const tier = "Health & Fitness";

// On-page SEO metadata
const pageTitle =
  "Water Intake Calculator - Free Daily Water Calculator";
const description =
  "Free water intake calculator to find your daily water intake by weight in kg or litres. Best online water calculator for women, muscle gain and bodybuilding.";
const canonicalUrl = "https://toolkify.app/tools/health/water-intake";
const ogImage = "/og/water-intake.png";
const keywords =
  "water intake calculator, free water intake calculator, best water intake calculator, water intake calculator free, water intake calculator for women, bodybuilding water intake calculator, online water intake calculator, water intake calculator for muscle gain, water intake calculator women, daily water intake calculator, water intake calculator by weight, water intake calculator kg litre, water calculator, water calculator intake, volume of water calculator";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Water Intake Calculator",
      "alternateName": "Daily Water Intake Calculator by Weight",
      "url": "https://toolkify.app/tools/health/water-intake",
      "description": "Free online water intake calculator with personalized adjustments for body weight (kg or litres), activity, climate, altitude, pregnancy, diet, and diuretic consumption. Best for women, muscle gain, and bodybuilding hydration planning.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Daily water intake calculator by body weight in kg or pounds",
        "Free online water calculator with metric (kg/litre) and imperial units",
        "Water intake calculator for women, pregnancy, and breastfeeding",
        "Bodybuilding and muscle gain water intake adjustments by activity level",
        "Climate, altitude, diet, caffeine, and alcohol hydration adjustments",
        "Hourly hydration schedule and glasses-per-day breakdown",
        "100% private, client-side calculations"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.app/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Health",
          "item": "https://toolkify.app/tools/health/water-intake"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Water Intake Calculator",
          "item": "https://toolkify.app/tools/health/water-intake"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is water intake?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Water intake refers to the total volume of water consumed through liquids (such as plain water, milk, and juices) and moisture-rich foods (like fruits and vegetables) to maintain the body's hydration levels.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much water to drink a day?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>On average, healthy adults should aim for about 2.7 liters (91 ounces) for women and 3.7 liters (125 ounces) for men per day from all beverages and foods. However, individual requirements vary based on weight, activity, and climate.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much water should I drink?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Your exact fluid needs depend heavily on your body weight, activity levels, climate, and health. A common guideline is to drink about 30 to 40 ml of water per kilogram of body weight daily, adjusted upward if you exercise or live in a hot region.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much water should I drink on creatine?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>When taking creatine, your muscle cells pull and store additional water. To prevent dehydration, maintain electrolyte balance, and maximize creatine's effectiveness, you should drink an extra 500 to 1,000 ml (16 to 32 ounces) of water daily above your baseline target.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much water to drink to lose weight?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Drinking water can aid weight loss by boosting metabolism and promoting satiety. Aiming for 2 to 3 liters of water per day, particularly drinking a glass before meals, is a widely recommended strategy to support weight management goals.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What should my water intake be?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Your water intake should match your body's specific metabolic demands. Use our online hydration calculator to estimate a personalized target based on your weight, activity levels, environment, and diet factors.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How much water intake per day?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A healthy daily water intake is typically around 11.5 cups (2.7 liters) of fluids for women and 15.5 cups (3.7 liters) for men. This includes all fluids consumed from drinking water, other beverages, and food moisture.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does coffee count as water intake?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, coffee counts toward your daily fluid intake. Although caffeine is a mild diuretic, the water contained in coffee still provides a net positive contribution to your overall daily hydration levels.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does tea count as water intake?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, tea contributes to your water intake. Both caffeinated and herbal teas are composed mostly of water and help meet your daily hydration requirements effectively.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does sparkling water count as water intake?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, sparkling water counts fully as water intake. Plain carbonated water is just as hydrating as still water and serves as an excellent, healthy alternative to sugary sodas.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does herbal tea count as water intake?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Yes, herbal tea is caffeine-free and counts 100% toward your daily water intake. It is an excellent way to enjoy flavored warm or cold beverages while staying properly hydrated.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "Does beer count as water intake?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>No, beer does not count as water intake. Alcohol is a strong diuretic that causes your body to excrete more fluid than the beverage provides, leading to dehydration rather than hydration.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How water intake calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 print:border-none print:shadow-none print:bg-transparent print:p-0">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col gap-3 print:hidden">
          <!-- Unit Toggle (Miro Pill Style) -->
          <div class="flex flex-col gap-1">
            <label class="text-[11px] font-semibold text-charcoal">Measurement Unit</label>
            <div class="flex rounded-full bg-surface p-0.5 border border-hairline self-start">
              <button
                type="button"
                id="unit-metric-btn"
                class="text-[11px] px-4 py-1 rounded-full font-bold transition-all cursor-pointer text-slate"
              >
                Metric (kg)
              </button>
              <button
                type="button"
                id="unit-imperial-btn"
                class="text-[11px] px-4 py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
              >
                Imperial (lb)
              </button>
            </div>
          </div>

          <!-- Weight Inputs -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal flex justify-between">
              <span>Body Weight</span>
              <span id="weight-label" class="font-mono text-stone font-semibold">160 lb</span>
            </label>

            <!-- Metric Weight (KG) -->
            <div id="metric-weight-container" class="flex items-center gap-2 hidden">
              <input
                type="range"
                id="weight-metric-range"
                min="30"
                max="250"
                value="70"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Weight in Kilograms Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="weight-metric-input"
                  min="30"
                  max="250"
                  value="70"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">kg</span>
              </div>
            </div>

            <!-- Imperial Weight (LBS) -->
            <div id="imperial-weight-container" class="flex items-center gap-2">
              <input
                type="range"
                id="weight-lbs-range"
                min="65"
                max="550"
                value="160"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Weight in Pounds Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="weight-lbs-input"
                  min="65"
                  max="550"
                  value="160"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">lb</span>
              </div>
            </div>
          </div>

          <!-- Activity Level Selector -->
          <div class="flex flex-col gap-1">
            <label for="activity-select" class="text-[11px] font-semibold text-charcoal">Daily Activity Level</label>
            <select
              id="activity-select"
              class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
            >
              <option value="sedentary">Sedentary (No exercise, desk job)</option>
              <option value="light" selected>Lightly Active (Exercise 1-3 days/week, ~30 mins)</option>
              <option value="moderate">Moderately Active (Exercise 3-5 days/week, ~60 mins)</option>
              <option value="very">Very Active (Hard exercise daily, physical job)</option>
              <option value="extra">Extra Active (Intense training/athletic workouts)</option>
            </select>
          </div>

          <!-- Climate/Environment Selector -->
          <div class="flex flex-col gap-1">
            <label for="climate-select" class="text-[11px] font-semibold text-charcoal">Climate & Environment</label>
            <select
              id="climate-select"
              class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
            >
              <option value="temperate" selected>Temperate / Cold (Normal indoor/outdoor temp)</option>
              <option value="warm">Warm / Mildly Humid (Warmer weather or active heat)</option>
              <option value="hot">Hot / Extremely Humid (Summer heat, high sweat environment)</option>
              <option value="dry">Dry / Arid (Dry high desert, low humidity)</option>
            </select>
          </div>

          <!-- Pregnancy/Breastfeeding Checkbox -->
          <div class="flex flex-col gap-1.5 pt-1.5 border-t border-hairline-soft/50">
            <label class="text-[11px] font-semibold text-charcoal">Special Condition Adjustments (Optional)</label>
            <div class="grid grid-cols-2 gap-2">
              <button
                type="button"
                id="pregnant-btn"
                class="flex items-center gap-1.5 p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative"
              >
                <div class="w-3.5 h-3.5 rounded border border-hairline-strong flex items-center justify-center bg-canvas shrink-0">
                  <span class="hidden text-brand-blue font-bold text-[9px]">&#10003;</span>
                </div>
                <div>
                  <span class="block text-[11px] font-bold text-primary leading-tight">Pregnancy</span>
                  <span class="block text-[8px] text-stone mt-0.5">+350ml / 12oz</span>
                </div>
              </button>

              <button
                type="button"
                id="breastfeeding-btn"
                class="flex items-center gap-1.5 p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative"
              >
                <div class="w-3.5 h-3.5 rounded border border-hairline-strong flex items-center justify-center bg-canvas shrink-0">
                  <span class="hidden text-brand-blue font-bold text-[9px]">&#10003;</span>
                </div>
                <div>
                  <span class="block text-[11px] font-bold text-primary leading-tight">Breastfeeding</span>
                  <span class="block text-[8px] text-stone mt-0.5">+800ml / 27oz</span>
                </div>
              </button>
            </div>
          </div>

          <!-- Advanced Options Drawer -->
          <div class="border-t border-hairline-soft pt-2 mt-1">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-[11px] font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1">
                ⚙ Advanced Hydration Parameters (Altitude, Diuretics, Diet)
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-3.5 h-3.5 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="advanced-panel" class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-3 mt-1.5">
              
              <!-- Exercise Overrides -->
              <div class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft/50">
                <div class="flex flex-col gap-1">
                  <label for="workout-duration" class="text-[10px] font-semibold text-slate">Specific Workout Duration</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="workout-duration"
                      min="0"
                      max="360"
                      placeholder="e.g. 45"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">min</span>
                  </div>
                </div>

                <div class="flex flex-col gap-1">
                  <label for="workout-intensity" class="text-[10px] font-semibold text-slate">Workout Intensity</label>
                  <select
                    id="workout-intensity"
                    class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                  >
                    <option value="low">Low (Yoga, Stretching)</option>
                    <option value="moderate" selected>Moderate (Jogging, Weights)</option>
                    <option value="high">High (HIIT, Running, Spinning)</option>
                  </select>
                </div>
              </div>

              <!-- Altitude & Diet Option -->
              <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                  <label for="altitude-select" class="text-[10px] font-semibold text-slate">Altitude Level</label>
                  <select
                    id="altitude-select"
                    class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                  >
                    <option value="sea" selected>Low Altitude (&lt; 5,000 ft / 1,500m)</option>
                    <option value="high">High Altitude (> 5,000 ft / 1,500m)</option>
                  </select>
                </div>

                <div class="flex flex-col gap-1">
                  <label for="diet-select" class="text-[10px] font-semibold text-slate">Dietary Moisture</label>
                  <select
                    id="diet-select"
                    class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                  >
                    <option value="standard" selected>Standard (Avg fruits & veggies)</option>
                    <option value="water-rich">Water-Rich (High fruit/veg intake)</option>
                    <option value="dry-processed">Dry Foods (Mostly grains & processed)</option>
                  </select>
                </div>
              </div>

              <!-- Diuretic Adjustments -->
              <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                  <label for="caffeine-drinks" class="text-[10px] font-semibold text-slate">Caffeinated Drinks (Daily)</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="caffeine-drinks"
                      min="0"
                      max="15"
                      value="0"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">cups</span>
                  </div>
                </div>

                <div class="flex flex-col gap-1">
                  <label for="alcohol-drinks" class="text-[10px] font-semibold text-slate">Alcoholic Drinks (Daily)</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="alcohol-drinks"
                      min="0"
                      max="10"
                      value="0"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">glasses</span>
                  </div>
                </div>
              </div>

              <div class="flex items-center justify-end mt-1">
                <button
                  type="button"
                  id="advanced-view-result-btn"
                  class="inline-flex items-center gap-1 text-[10px] font-semibold px-3 py-1 bg-primary hover:bg-charcoal text-canvas rounded-full transition-all cursor-pointer shadow-subtle"
                >
                  View Result &darr;
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Pane: Outputs & Interactive Water Visual -->
        <div id="results-card" class="card-feature-teal flex flex-col justify-between p-4 sm:p-5 relative overflow-hidden rounded-xl border border-moss-dark/10 print:border-none print:shadow-none print:p-0">
          <div class="absolute top-0 right-0 w-32 h-32 bg-teal-light/35 rounded-full blur-2xl pointer-events-none print:hidden"></div>
          
          <div class="flex flex-col gap-3.5 z-10 w-full">
            <!-- Results Header -->
            <div class="flex items-center justify-between border-b border-moss-dark/10 pb-2">
              <span class="text-[10px] uppercase font-extrabold text-moss-dark/70 tracking-widest">Recommended Fluid Target</span>
              <span class="flex h-2 w-2 relative print:hidden">
                <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-accent opacity-75"></span>
                <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-success-accent"></span>
              </span>
            </div>

            <!-- Warning/Doctor Advice Banner (Hidden by default) -->
            <div id="medical-advice-banner" class="hidden p-2 rounded-lg bg-brand-rose border border-brand-red text-[10px] text-coral-dark leading-normal flex flex-col gap-0.5">
              <span class="font-bold flex items-center gap-1">⚠️ Medical Disclaimer & Guidance</span>
              <p id="medical-advice-msg">For special medical conditions (kidney disease, congestive heart failure, pregnancy complications), do not rely on automated calculators. Please consult your physician directly for hydration plans.</p>
            </div>

            <!-- Target Output -->
            <div class="flex items-stretch justify-between gap-4">
              <div class="flex flex-col justify-center">
                <span class="text-[10px] uppercase font-bold text-slate block">Daily Hydration Target</span>
                <div class="flex items-baseline gap-1 mt-1">
                  <span id="output-water-liters" class="font-display font-black text-3.5xl sm:text-4xl text-primary font-mono tracking-tight leading-none">2.8</span>
                  <span class="text-xs font-semibold text-stone">Liters / day</span>
                </div>
                <div class="text-[11px] font-mono text-stone font-semibold mt-1">
                  &asymp; <span id="output-water-ounces">95</span> fl oz
                </div>
              </div>

              <!-- Interactive Floating Glass Fill Graphic -->
              <div class="w-24 h-24 sm:w-28 sm:h-28 shrink-0 flex items-center justify-center relative select-none">
                <!-- SVG Water Glass Outline & Fill -->
                <svg class="w-full h-full" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
