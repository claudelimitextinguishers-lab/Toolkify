    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    // Share Event
    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("unit", currentUnit);
      url.searchParams.set("sex", sex);
      url.searchParams.set("age", age.toString());
      url.searchParams.set("h-cm", heightCm.toString());
      url.searchParams.set("h-ft", heightFt.toString());
      url.searchParams.set("h-in", heightIn.toString());
      url.searchParams.set("w-kg", weightKg.toString());
      url.searchParams.set("w-lbs", weightLbs.toString());
      url.searchParams.set("act", activityMultiplier.toString());
      url.searchParams.set("goal", selectedGoal);
      url.searchParams.set("diet", selectedDiet);
      if (bodyfatInput) url.searchParams.set("bf", bodyfatInput.value);
      if (mealSelect) url.searchParams.set("meals", mealSelect.value);
      url.searchParams.set("cust-mode", customMode);
      url.searchParams.set("cust-p", customP.toString());
      url.searchParams.set("cust-c", customC.toString());
      url.searchParams.set("cust-f", customF.toString());

      const shareData = {
        title: document.title || "Macro Calculator",
        url: url.toString()
      };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") {
            copyToClipboard(url.toString());
          }
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else {
          fallbackCopy(text);
        }
      }

      function fallbackCopy(text: string) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          showSuccess();
        } catch (err) {
          console.error(err);
        }
        document.body.removeChild(textArea);
      }

      function showSuccess() {
        if (shareBtn) {
          const span = shareBtn.querySelector("span");
          if (span) {
            const originalText = span.textContent || "Share";
            span.textContent = "Link Copied!";
            shareBtn.classList.add("text-success-accent", "border-success-accent");
            setTimeout(() => {
              span.textContent = originalText;
              shareBtn.classList.remove("text-success-accent", "border-success-accent");
            }, 2000);
          }
        }
      }
    });

    // Load state from localStorage or URL
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      // get(lsKey, urlKey): URL params always take priority over localStorage
      const get = (lsKey: string, urlKey: string): string | null => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        if (typeof localStorage === 'undefined') return null;
        try { return localStorage.getItem(lsKey); } catch (e) { return null; }
      };

      try {
        const savedUnit = get("macro-unit", "unit");
        const savedSex = get("macro-sex", "sex");
        const savedAge = get("macro-age", "age");
        const savedHeightCm = get("macro-height-cm", "h-cm");
        const savedHeightFt = get("macro-height-ft", "h-ft");
        const savedHeightIn = get("macro-height-in", "h-in");
        const savedWeightKg = get("macro-weight-kg", "w-kg");
        const savedWeightLbs = get("macro-weight-lbs", "w-lbs");
        const savedActivity = get("macro-activity", "act");
        const savedGoal = get("macro-goal", "goal");
        const savedDiet = get("macro-diet", "diet");
        const savedBodyFat = get("macro-bodyfat", "bf");
        const savedMealCount = get("macro-meals", "meals");
        
        const savedCustomMode = get("macro-custom-mode", "cust-mode");
        const savedCustomP = get("macro-custom-p", "cust-p");
        const savedCustomC = get("macro-custom-c", "cust-c");
        const savedCustomF = get("macro-custom-f", "cust-f");

        if (savedUnit) currentUnit = savedUnit;
        if (savedSex) sex = savedSex;
        if (savedAge) age = parseInt(savedAge, 10);
        if (savedHeightCm) heightCm = parseInt(savedHeightCm, 10);
        if (savedHeightFt) heightFt = parseInt(savedHeightFt, 10);
        if (savedHeightIn) heightIn = parseInt(savedHeightIn, 10);
        if (savedWeightKg) weightKg = parseInt(savedWeightKg, 10);
        if (savedWeightLbs) weightLbs = parseInt(savedWeightLbs, 10);
        if (savedActivity) activityMultiplier = parseFloat(savedActivity);
        if (savedGoal) selectedGoal = savedGoal;
        if (savedDiet) selectedDiet = savedDiet;

        if (sexSelect) sexSelect.value = sex;
        if (ageInput) ageInput.value = age.toString();
        if (activitySelect) activitySelect.value = activityMultiplier.toString();

        if (savedBodyFat && bodyfatInput) bodyfatInput.value = savedBodyFat;
        if (savedMealCount && mealSelect) mealSelect.value = savedMealCount;

        if (savedCustomMode) customMode = savedCustomMode;
        if (savedCustomP) customP = parseFloat(savedCustomP);
        if (savedCustomC) customC = parseFloat(savedCustomC);
        if (savedCustomF) customF = parseFloat(savedCustomF);

        if (customProteinInput) customProteinInput.value = customP.toString();
        if (customCarbsInput) customCarbsInput.value = customC.toString();
        if (customFatsInput) customFatsInput.value = customF.toString();

        // Apply active button styles
        goalButtons.forEach(btn => {
          if (btn.getAttribute("data-goal") === selectedGoal) {
            btn.classList.add("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.remove("border-hairline", "border-brand-blue/30");
          } else {
            btn.classList.remove("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.add("border-hairline");
          }
        });

        dietButtons.forEach(btn => {
          if (btn.getAttribute("data-diet") === selectedDiet) {
            btn.classList.add("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.remove("border-hairline", "border-brand-blue/30");
          } else {
            btn.classList.remove("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.add("border-hairline");
          }
        });

      } catch (e) {
        console.warn("Failed loading state:", e);
      }
      updateInputsFromState();
      updateUnitUI();
      updateLabels();
      toggleCustomOverrideDisplay();
      calculate();
    }

    resetBtn?.addEventListener("click", () => {
