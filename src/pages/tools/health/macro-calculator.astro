    // Custom Override Elements
    const customOverrideContainer = document.getElementById("custom-override-container");
    const customModePctBtn = document.getElementById("custom-mode-pct-btn");
    const customModeGBtn = document.getElementById("custom-mode-g-btn");
    const customProteinInput = document.getElementById("custom-protein") as HTMLInputElement;
    const customCarbsInput = document.getElementById("custom-carbs") as HTMLInputElement;
    const customFatsInput = document.getElementById("custom-fats") as HTMLInputElement;
    const customPUnit = document.getElementById("custom-p-unit");
    const customCUnit = document.getElementById("custom-c-unit");
    const customFUnit = document.getElementById("custom-f-unit");
    const customSumDisplay = document.getElementById("custom-sum-display");
    const customValidationMsg = document.getElementById("custom-validation-msg");

    // Output DOM Elements
    const outputTargetCalories = document.getElementById("output-target-calories");
    const outputBmr = document.getElementById("output-bmr");
    const outputTdee = document.getElementById("output-tdee");
    const adviceText = document.getElementById("advice-text");
    const safetyAlert = document.getElementById("safety-alert");
    const safetyAlertMsg = document.getElementById("safety-alert-msg");
    const statusPulse = document.getElementById("status-pulse");
    const statusDot = document.getElementById("status-dot");

    // Compare bar components
    const gaugeBmrBar = document.getElementById("gauge-bmr-bar");
    const gaugeSurplusBar = document.getElementById("gauge-surplus-bar");
    const gaugeDeficitGapBar = document.getElementById("gauge-deficit-gap-bar");
    const gaugeGapLegend = document.getElementById("gauge-gap-legend");

    // Card Numeric Value Outputs
    const cardProteinG = document.getElementById("card-protein-g");
    const cardProteinKcal = document.getElementById("card-protein-kcal");
    const cardCarbsG = document.getElementById("card-carbs-g");
    const cardCarbsKcal = document.getElementById("card-carbs-kcal");
    const cardFatsG = document.getElementById("card-fats-g");
    const cardFatsKcal = document.getElementById("card-fats-kcal");

    // Breakdown Section DOM
    const toggleBreakdownBtn = document.getElementById("toggle-breakdown-btn");
    const breakdownSection = document.getElementById("breakdown-section");
    const exportPdfBtn = document.getElementById("export-pdf-btn");
    
    // Donut SVG elements
    const donutCenterCal = document.getElementById("donut-center-cal");
    const donutP = document.getElementById("donut-p");
    const donutC = document.getElementById("donut-c");
    const donutF = document.getElementById("donut-f");
    const pctP = document.getElementById("pct-p");
    const pctC = document.getElementById("pct-c");
    const pctF = document.getElementById("pct-f");

    // Bar chart elements
    const barPCal = document.getElementById("bar-p-cal");
    const barPWidth = document.getElementById("bar-p-width");
    const barCCal = document.getElementById("bar-c-cal");
    const barCWidth = document.getElementById("bar-c-width");
    const barFCal = document.getElementById("bar-f-cal");
    const barFWidth = document.getElementById("bar-f-width");

    // Meal distribution
    const distributionMealCount = document.getElementById("distribution-meal-count");
    const mealDistributionTableBody = document.getElementById("meal-distribution-table-body");
    const analysisSummaryPara = document.getElementById("analysis-summary-para");

    const resetBtn = document.getElementById("reset-btn");

    // Enforce scrolling to top on refresh/load
    window.addEventListener("beforeunload", () => {
      window.scrollTo(0, 0);
    });

    // Help / How it works Guide Overlay Modal HTML injection
    const modalHtml = `
      <div
        id="how-it-works-modal"
        class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all duration-300 hidden"
      >
        <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto">
          <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
            <h3 class="font-display font-semibold text-lg text-primary font-medium">How the Macro Calculator Works</h3>
            <button
              type="button"
              id="close-modal-btn"
              class="text-stone hover:text-primary transition-all text-lg cursor-pointer bg-transparent border-none"
            >
              ✕
            </button>
          </div>

          <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
            <h4 class="font-semibold text-primary">1. Caloric Target Definition</h4>
            <p>
              Your TDEE is computed based on your BMR (Mifflin-St Jeor or Katch-McArdle) and activity level. Depending on your chosen goal (fat loss, muscle gain, or recomposition), a caloric deficit or surplus is applied to establish your daily target.
            </p>

            <h4 class="font-semibold text-primary">2. Diet Presets & Ratio Splits</h4>
            <p>
              Your target calories are distributed into Protein, Carbohydrates, and Fats according to standard science-backed macronutrient templates (e.g. Balanced 30/40/30, High Protein 40/30/30, Low Carb 25/15/60, or a Custom percentage/gram setup).
            </p>

            <h4 class="font-semibold text-primary">3. Meal Distribution</h4>
            <p>
              The calculated daily macros are broken down evenly across your preferred number of meals to plan your daily nutrition scheduling efficiently.
            </p>
          </div>
          <button
            type="button"
            id="modal-ok-btn"
            class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer"
          >
            Got it
          </button>
        </div>
      </div>
    `;
    document.body.insertAdjacentHTML("beforeend", modalHtml);

    // Load state from localStorage
    function loadState() {
      try {
        const savedUnit = localStorage.getItem("macro-unit");
        const savedSex = localStorage.getItem("macro-sex");
        const savedAge = localStorage.getItem("macro-age");
        const savedHeightCm = localStorage.getItem("macro-height-cm");
        const savedHeightFt = localStorage.getItem("macro-height-ft");
        const savedHeightIn = localStorage.getItem("macro-height-in");
        const savedWeightKg = localStorage.getItem("macro-weight-kg");
        const savedWeightLbs = localStorage.getItem("macro-weight-lbs");
        const savedActivity = localStorage.getItem("macro-activity");
        const savedGoal = localStorage.getItem("macro-goal");
        const savedDiet = localStorage.getItem("macro-diet");
        const savedBodyFat = localStorage.getItem("macro-bodyfat");
        const savedMealCount = localStorage.getItem("macro-meals");
        
        const savedCustomMode = localStorage.getItem("macro-custom-mode");
        const savedCustomP = localStorage.getItem("macro-custom-p");
        const savedCustomC = localStorage.getItem("macro-custom-c");
        const savedCustomF = localStorage.getItem("macro-custom-f");

        if (savedUnit) currentUnit = savedUnit;
        if (savedSex) sex = savedSex;
        if (savedAge) age = parseInt(savedAge, 10);
        if (savedHeightCm) heightCm = parseInt(savedHeightCm, 10);
        if (savedHeightFt) heightFt = parseInt(savedHeightFt, 10);
        if (savedHeightIn) heightIn = parseInt(savedHeightIn, 10);
        if (savedWeightKg) weightKg = parseInt(savedWeightKg, 10);
        if (savedWeightLbs) weightLbs = parseInt(savedWeightLbs, 10);
        if (savedActivity) activityMultiplier = parseFloat(savedActivity);
        if (savedGoal) selectedGoal = savedGoal;
        if (savedDiet) selectedDiet = savedDiet;

        if (sexSelect) sexSelect.value = sex;
        if (ageInput) ageInput.value = age.toString();
        if (activitySelect) activitySelect.value = activityMultiplier.toString();

        if (savedBodyFat && bodyfatInput) bodyfatInput.value = savedBodyFat;
        if (savedMealCount && mealSelect) mealSelect.value = savedMealCount;

        if (savedCustomMode) customMode = savedCustomMode;
        if (savedCustomP) customP = parseFloat(savedCustomP);
        if (savedCustomC) customC = parseFloat(savedCustomC);
        if (savedCustomF) customF = parseFloat(savedCustomF);

        if (customProteinInput) customProteinInput.value = customP.toString();
        if (customCarbsInput) customCarbsInput.value = customC.toString();
        if (customFatsInput) customFatsInput.value = customF.toString();

        // Apply active button styles
        goalButtons.forEach(btn => {
          if (btn.getAttribute("data-goal") === selectedGoal) {
            btn.classList.add("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.remove("border-hairline", "border-brand-blue/30");
          } else {
            btn.classList.remove("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.add("border-hairline");
          }
        });

        dietButtons.forEach(btn => {
          if (btn.getAttribute("data-diet") === selectedDiet) {
            btn.classList.add("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.remove("border-hairline", "border-brand-blue/30");
          } else {
            btn.classList.remove("ring-2", "ring-brand-blue", "border-transparent", "active");
            btn.classList.add("border-hairline");
          }
        });

      } catch (e) {
        console.warn("Failed loading state:", e);
      }
      updateInputsFromState();
      updateUnitUI();
      updateLabels();
      toggleCustomOverrideDisplay();
      calculate();
    }

    function saveState() {
      try {
        localStorage.setItem("macro-unit", currentUnit);
        localStorage.setItem("macro-sex", sex);
        localStorage.setItem("macro-age", age.toString());
        localStorage.setItem("macro-height-cm", heightCm.toString());
        localStorage.setItem("macro-height-ft", heightFt.toString());
        localStorage.setItem("macro-height-in", heightIn.toString());
        localStorage.setItem("macro-weight-kg", weightKg.toString());
        localStorage.setItem("macro-weight-lbs", weightLbs.toString());
        localStorage.setItem("macro-activity", activityMultiplier.toString());
        localStorage.setItem("macro-goal", selectedGoal);
        localStorage.setItem("macro-diet", selectedDiet);
        if (bodyfatInput) localStorage.setItem("macro-bodyfat", bodyfatInput.value);
        if (mealSelect) localStorage.setItem("macro-meals", mealSelect.value);

        localStorage.setItem("macro-custom-mode", customMode);
        localStorage.setItem("macro-custom-p", customP.toString());
        localStorage.setItem("macro-custom-c", customC.toString());
        localStorage.setItem("macro-custom-f", customF.toString());
      } catch (e) {
        console.warn("Failed saving state:", e);
      }
    }

    function updateInputsFromState() {
      if (heightMetricRange) heightMetricRange.value = heightCm.toString();
      if (heightMetricInput) heightMetricInput.value = heightCm.toString();
      if (heightFtInput) heightFtInput.value = heightFt.toString();
      if (heightInInput) heightInInput.value = heightIn.toString();

      if (weightMetricRange) weightMetricRange.value = weightKg.toString();
      if (weightMetricInput) weightMetricInput.value = weightKg.toString();
      if (weightLbsRange) weightLbsRange.value = weightLbs.toString();
      if (weightLbsInput) weightLbsInput.value = weightLbs.toString();
    }

    function updateUnitUI() {
      if (currentUnit === "metric") {
        unitMetricBtn?.classList.add("bg-primary", "text-canvas");
        unitMetricBtn?.classList.remove("text-slate");
        unitImperialBtn?.classList.remove("bg-primary", "text-canvas");
        unitImperialBtn?.classList.add("text-slate");

        metricHeightContainer?.classList.remove("hidden");
        imperialHeightContainer?.classList.add("hidden");
        metricWeightContainer?.classList.remove("hidden");
        imperialWeightContainer?.classList.add("hidden");
      } else {
        unitImperialBtn?.classList.add("bg-primary", "text-canvas");
        unitImperialBtn?.classList.remove("text-slate");
        unitMetricBtn?.classList.remove("bg-primary", "text-canvas");
        unitMetricBtn?.classList.add("text-slate");

        imperialHeightContainer?.classList.remove("hidden");
        metricHeightContainer?.classList.add("hidden");
        imperialWeightContainer?.classList.remove("hidden");
        metricWeightContainer?.classList.add("hidden");
      }
    }

    function updateLabels() {
      if (heightLabel) {
        if (currentUnit === "metric") {
          heightLabel.textContent = `${heightCm} cm`;
        } else {
          heightLabel.textContent = `${heightFt} ft ${heightIn} in`;
        }
      }
      if (weightLabel) {
        if (currentUnit === "metric") {
          weightLabel.textContent = `${weightKg} kg`;
        } else {
          weightLabel.textContent = `${weightLbs} lb`;
        }
      }
    }

    function toggleCustomOverrideDisplay() {
      if (selectedDiet === "custom") {
        customOverrideContainer?.classList.remove("hidden");
        customOverrideContainer?.classList.add("flex");
      } else {
        customOverrideContainer?.classList.add("hidden");
        customOverrideContainer?.classList.remove("flex");
      }
    }

    // Core Calculation Engine
    function calculate() {
      let activeWeightKg = weightKg;
      let activeHeightCm = heightCm;

      if (currentUnit === "imperial") {
        activeWeightKg = weightLbs / 2.20462;
        const totalInches = (heightFt * 12) + heightIn;
        activeHeightCm = totalInches * 2.54;
      }

      // Calculate BMR
      let bmr = 0;
      let bmrFormulaName = "Mifflin-St Jeor";
      const bodyFatVal = bodyfatInput ? parseFloat(bodyfatInput.value) : NaN;

      if (!isNaN(bodyFatVal) && bodyFatVal > 0) {
        // Use Katch-McArdle BMR formula
        const lbm = activeWeightKg * (1 - (bodyFatVal / 100));
        bmr = 370 + (21.6 * lbm);
        bmrFormulaName = "Katch-McArdle";
      } else {
        // Use Mifflin-St Jeor formula
        if (sex === "male") {
          bmr = (10 * activeWeightKg) + (6.25 * activeHeightCm) - (5 * age) + 5;
        } else if (sex === "female") {
          bmr = (10 * activeWeightKg) + (6.25 * activeHeightCm) - (5 * age) - 161;
        } else {
          // Average of Male (+5) and Female (-161) constants
          bmr = (10 * activeWeightKg) + (6.25 * activeHeightCm) - (5 * age) - 78;
        }
      }

      bmr = Math.round(bmr);
      const tdee = Math.round(bmr * activityMultiplier);

      // Determine Calorie Goal Target
      let calorieTarget = tdee;
      let goalActionName = "maintenance";

      if (selectedGoal === "fat-loss") {
        calorieTarget = tdee - 500;
        goalActionName = "fat loss deficit";
      } else if (selectedGoal === "muscle-gain") {
        calorieTarget = tdee + 300;
        goalActionName = "lean muscle gain surplus";
      } else if (selectedGoal === "body-recomp") {
        calorieTarget = tdee - 250;
        goalActionName = "body recomposition minor deficit";
      }
      let skipDonutBarUpdates = false;

      // Update basic output displays
      if (outputTargetCalories) outputTargetCalories.textContent = calorieTarget.toLocaleString();
      if (outputBmr) outputBmr.textContent = `${bmr.toLocaleString()} kcal`;
      if (outputTdee) outputTdee.textContent = `${tdee.toLocaleString()} kcal`;

      // Update Compare Bar gauge widths
      if (gaugeBmrBar && gaugeSurplusBar && gaugeDeficitGapBar && gaugeGapLegend) {
        const bmrPercent = Math.min(100, Math.max(0, (bmr / tdee) * 100));
        let intakePercent = Math.min(100, Math.max(0, (calorieTarget / tdee) * 100));
        let gapPercent = 100 - intakePercent;

        if (calorieTarget > tdee) {
          // Surplus mode
          intakePercent = 100;
          gapPercent = 0;
          gaugeGapLegend.classList.add("hidden");
          
          const surplusVal = calorieTarget - tdee;
          const surplusPct = Math.min(30, (surplusVal / tdee) * 100);
          
          gaugeBmrBar.style.width = `${bmrPercent}%`;
          gaugeSurplusBar.style.width = `${100 - bmrPercent}%`;
          // Use green highlight or similar for surplus representation
          gaugeSurplusBar.className = "h-full bg-success-accent";
        } else {
          // Deficit / Maintenance
          gaugeGapLegend.classList.remove("hidden");
          gaugeBmrBar.style.width = `${Math.min(bmrPercent, intakePercent)}%`;
          gaugeSurplusBar.style.width = `${Math.max(0, intakePercent - bmrPercent)}%`;
          gaugeSurplusBar.className = "h-full bg-success-accent";
          gaugeDeficitGapBar.style.width = `${gapPercent}%`;
        }
      }

      // Macro Distribution Splitting Logic
      let pRatio = 0.3;
      let cRatio = 0.4;
      let fRatio = 0.3;

      let pGrams = 0;
      let cGrams = 0;
      let fGrams = 0;

      let pKcal = 0;
      let cKcal = 0;
      let fKcal = 0;

      if (selectedDiet === "balanced") {
        pRatio = 0.3;
        cRatio = 0.4;
        fRatio = 0.3;
        pKcal = calorieTarget * pRatio;
        cKcal = calorieTarget * cRatio;
        fKcal = calorieTarget * fRatio;
        pGrams = Math.round(pKcal / 4);
        cGrams = Math.round(cKcal / 4);
        fGrams = Math.round(fKcal / 9);
      } else if (selectedDiet === "high-protein") {
        pRatio = 0.4;
        cRatio = 0.3;
        fRatio = 0.3;
        pKcal = calorieTarget * pRatio;
        cKcal = calorieTarget * cRatio;
        fKcal = calorieTarget * fRatio;
        pGrams = Math.round(pKcal / 4);
        cGrams = Math.round(cKcal / 4);
        fGrams = Math.round(fKcal / 9);
      } else if (selectedDiet === "low-carb") {
        pRatio = 0.25;
        cRatio = 0.1;
        fRatio = 0.65;
        pKcal = calorieTarget * pRatio;
        cKcal = calorieTarget * cRatio;
        fKcal = calorieTarget * fRatio;
        pGrams = Math.round(pKcal / 4);
        cGrams = Math.round(cKcal / 4);
        fGrams = Math.round(fKcal / 9);
      } else if (selectedDiet === "custom") {
        // Read custom overrides
        if (customMode === "pct") {
          const totalPct = customP + customC + customF;
          if (customSumDisplay) {
            customSumDisplay.textContent = `${totalPct}%`;
          }
          if (totalPct === 100) {
            customValidationMsg?.classList.remove("text-brand-coral");
            customValidationMsg?.classList.add("text-stone");
          } else {
            customValidationMsg?.classList.remove("text-stone");
            customValidationMsg?.classList.add("text-brand-coral");
          }

          pRatio = customP / 100;
          cRatio = customC / 100;
          fRatio = customF / 100;

          pKcal = calorieTarget * pRatio;
          cKcal = calorieTarget * cRatio;
          fKcal = calorieTarget * fRatio;

          pGrams = Math.round(pKcal / 4);
          cGrams = Math.round(cKcal / 4);
          fGrams = Math.round(fKcal / 9);
        } else {
          // Gram mode
          pGrams = customP;
          cGrams = customC;
          fGrams = customF;

          pKcal = pGrams * 4;
          cKcal = cGrams * 4;
          fKcal = fGrams * 9;

          const totalKcalOverride = pKcal + cKcal + fKcal;
          if (customSumDisplay) {
            customSumDisplay.textContent = `${totalKcalOverride} kcal`;
          }
          // Adapt target calories to match custom gram overrides sum
          calorieTarget = totalKcalOverride;
          if (outputTargetCalories) outputTargetCalories.textContent = calorieTarget.toLocaleString();

          if (calorieTarget === 0) {
            pRatio = 0;
            cRatio = 0;
            fRatio = 0;
            skipDonutBarUpdates = true;
          } else {
            pRatio = pKcal / calorieTarget || 0;
            cRatio = cKcal / calorieTarget || 0;
            fRatio = fKcal / calorieTarget || 0;
          }
        }
      }

      // Check safety floors (Medically recognized standard: 1200 kcal for females, 1500 kcal for males, 1350 kcal for other)
      const floor = sex === "male" ? 1500 : (sex === "female" ? 1200 : 1350);
      let isSafe = true;

      if (calorieTarget < floor) {
        isSafe = false;
        if (safetyAlert) {
          safetyAlert.classList.remove("hidden");
          if (safetyAlertMsg) {
            const sexLabel = sex === "male" ? "males" : (sex === "female" ? "females" : "other");
            safetyAlertMsg.innerHTML = `Consuming <strong>${calorieTarget} kcal/day</strong> drops below the safe physiological threshold of <strong>${floor} kcal/day</strong> for ${sexLabel}. Eating below this level increases risks of nutrient deficiency and metabolic slowdown.`;
          }
        }
        if (statusPulse && statusDot) {
          statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-coral opacity-75";
          statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-brand-coral";
        }
      } else {
        if (safetyAlert) safetyAlert.classList.add("hidden");
        if (statusPulse && statusDot) {
          statusPulse.className = "animate-ping absolute inline-flex h-full w-full rounded-full bg-success-accent opacity-75";
          statusDot.className = "relative inline-flex rounded-full h-2 w-2 bg-success-accent";
        }
      }

      // Update Card Visuals
      if (cardProteinG) cardProteinG.textContent = `${pGrams}g`;
      if (cardProteinKcal) cardProteinKcal.textContent = `${Math.round(pKcal)} kcal`;
      if (cardCarbsG) cardCarbsG.textContent = `${cGrams}g`;
      if (cardCarbsKcal) cardCarbsKcal.textContent = `${Math.round(cKcal)} kcal`;
      if (cardFatsG) cardFatsG.textContent = `${fGrams}g`;
      if (cardFatsKcal) cardFatsKcal.textContent = `${Math.round(fKcal)} kcal`;

      // Update Donut Chart & Bars if not skipping
      let pPercent = 0;
      let cPercent = 0;
      let fPercent = 0;

      if (!skipDonutBarUpdates) {
        if (donutCenterCal) donutCenterCal.textContent = calorieTarget.toLocaleString();
        
        pPercent = Math.round(pRatio * 100);
        cPercent = Math.round(cRatio * 100);
        fPercent = Math.round(fRatio * 100);

        const remainder = 100 - (pPercent + cPercent + fPercent);
        if (remainder !== 0) {
          if (pPercent >= cPercent && pPercent >= fPercent) {
            pPercent += remainder;
          } else if (cPercent >= pPercent && cPercent >= fPercent) {
            cPercent += remainder;
          } else {
            fPercent += remainder;
          }
        }

        if (pctP) pctP.textContent = pPercent.toString();
        if (pctC) pctC.textContent = cPercent.toString();
        if (pctF) pctF.textContent = fPercent.toString();

        // Donut circumference is 100 (2 * pi * r = 2 * 3.1415 * 15.915 = 100)
        if (donutP && donutC && donutF) {
          const circ = 2 * Math.PI * 15.915;
          const pDash = (pPercent / 100) * circ;
          const cDash = (cPercent / 100) * circ;
          const fDash = (fPercent / 100) * circ;

          donutP.setAttribute("stroke-dasharray", `${pDash} ${circ - pDash}`);
          donutP.setAttribute("stroke-dashoffset", "0");

          donutC.setAttribute("stroke-dasharray", `${cDash} ${circ - cDash}`);
          donutC.setAttribute("stroke-dashoffset", `-${pDash}`);

          donutF.setAttribute("stroke-dasharray", `${fDash} ${circ - fDash}`);
          donutF.setAttribute("stroke-dashoffset", `-${pDash + cDash}`);
        }

        // Update Calories from each macro bars
        if (barPCal) barPCal.textContent = `${Math.round(pKcal)} kcal`;
        if (barPWidth) barPWidth.style.width = `${pRatio * 100}%`;
        if (barCCal) barCCal.textContent = `${Math.round(cKcal)} kcal`;
        if (barCWidth) barCWidth.style.width = `${cRatio * 100}%`;
        if (barFCal) barFCal.textContent = `${Math.round(fKcal)} kcal`;
        if (barFWidth) barFWidth.style.width = `${fRatio * 100}%`;
      }

      // Meal splitting table rendering
      const mealCount = parseInt(mealSelect?.value || "4", 10);
      if (distributionMealCount) distributionMealCount.textContent = mealCount.toString();
      
      if (mealDistributionTableBody) {
        mealDistributionTableBody.innerHTML = "";
        for (let i = 1; i <= mealCount; i++) {
          let mealLabel = `Meal ${i}`;
          if (mealCount === 3) {
            if (i === 1) mealLabel = "Breakfast";
            if (i === 2) mealLabel = "Lunch";
            if (i === 3) mealLabel = "Dinner";
          } else if (mealCount === 4) {
            if (i === 1) mealLabel = "Breakfast";
            if (i === 2) mealLabel = "Lunch";
            if (i === 3) mealLabel = "Snack";
            if (i === 4) mealLabel = "Dinner";
          } else if (mealCount === 5) {
            if (i === 1) mealLabel = "Breakfast";
            if (i === 2) mealLabel = "Mid-Morning Snack";
            if (i === 3) mealLabel = "Lunch";
            if (i === 4) mealLabel = "Afternoon Snack";
            if (i === 5) mealLabel = "Dinner";
          } else if (mealCount === 6) {
            if (i === 1) mealLabel = "Breakfast";
            if (i === 2) mealLabel = "Mid-Morning Snack";
            if (i === 3) mealLabel = "Lunch";
            if (i === 4) mealLabel = "Afternoon Snack";
            if (i === 5) mealLabel = "Dinner";
            if (i === 6) mealLabel = "Evening Snack";
          }

          const mKcal = Math.round(calorieTarget / mealCount);
          const mP = Math.round(pGrams / mealCount);
          const mC = Math.round(cGrams / mealCount);
          const mF = Math.round(fGrams / mealCount);

          const row = document.createElement("tr");
          row.className = "border-b border-hairline-soft/50 hover:bg-canvas/50";
          row.innerHTML = `
            <td class="py-2 font-bold text-primary">${mealLabel}</td>
            <td class="py-2 text-right font-mono font-medium">${mKcal} kcal</td>
            <td class="py-2 text-right font-mono">${mP}g</td>
            <td class="py-2 text-right font-mono">${mC}g</td>
            <td class="py-2 text-right font-mono">${mF}g</td>
          `;
          mealDistributionTableBody.appendChild(row);
        }
      }

      // Advice / Description text updates
      if (adviceText) {
        adviceText.innerHTML = `Calculated using the <strong>${bmrFormulaName}</strong> BMR formula. Your basal metabolic rate is <strong>${bmr} kcal</strong>, and with your activity level, maintaining current weight requires <strong>${tdee} kcal</strong>. To support your <strong>${goalActionName}</strong>, your daily target is set at <strong>${calorieTarget} kcal</strong> distributed in a <strong>${selectedDiet}</strong> split.`;
      }

      if (analysisSummaryPara) {
        analysisSummaryPara.innerHTML = `Based on your biological characteristics, your estimated base metabolic activity requires <strong>${bmr} calories</strong> a day just to keep vital functions operational. To sustain your physical active lifestyle requires an average energy pool of <strong>${tdee} calories</strong>. Your chosen goal maps to <strong>${calorieTarget} calories</strong> daily, structured as <strong>${pPercent}% Protein, ${cPercent}% Carbohydrates, and ${fPercent}% Fats</strong>.`;
      }

      saveState();
    }

    // Scroll helper
