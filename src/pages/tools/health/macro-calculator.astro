---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Macro Calculator";
const category = "health";
const tier = "Health & Fitness";

// On-page SEO metadata
const pageTitle =
  "Macro Calculator - Free Macro Calculator for Weight Loss & Muscle Gain";
const description =
  "Free macro calculator for weight loss, muscle gain, and maintenance. Calculate your daily protein, carbs, and fat targets from your TDEE with this best free online macro calculator for women and men.";
const canonicalUrl = "https://boardtools.app/tools/health/macro-calculator";
const ogImage = "/og/macro-calculator.png";
const keywords =
  "macro calculator, free macro calculator, macro calculator for weight loss, best macro calculator, macro calculator free, macro calculator for women, bodybuilding macro calculator, calorie and macro calculator, food macro calculator, free macro calculator for weight loss, online macro calculator, macro calculator for muscle gain, macro calculator women, macro calculator for weight loss female";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Macro Calculator",
      "alternateName": "Free Macro Calculator for Weight Loss & Muscle Gain",
      "url": "https://boardtools.app/tools/health/macro-calculator",
      "description": "Free online macro calculator that computes daily protein, carbohydrate, and fat targets from your TDEE using Mifflin-St Jeor and Katch-McArdle formulas, with custom ratios/grams, dynamic visual macro breakdowns, meal splitting, and medical safety floors.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "Free macro calculator for weight loss, muscle gain, and maintenance",
        "Calorie and macro calculator using Mifflin-St Jeor and Katch-McArdle formulas",
        "Macro calculator for women and men with biological sex and body fat inputs",
        "Bodybuilding macro presets: balanced, high-protein, low-carb/keto, and custom",
        "Per-meal macro distribution and visual protein/carb/fat breakdown",
        "Metric (cm/kg) and imperial (ft-in/lb) units",
        "100% private, client-side calculations"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a macro calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A macro calculator works out how many grams of protein, carbohydrates, and fat you should eat each day to hit a calorie goal. This free macro calculator first estimates your TDEE (total daily energy expenditure), adjusts it for your goal, then splits those calories into macronutrient targets based on your chosen diet style."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use a macro calculator for weight loss?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Enter your age, sex, height, weight, and activity level, then select the Fat Loss goal. This macro calculator for weight loss applies a calorie deficit to your TDEE and prioritises higher protein to preserve muscle while you lose fat. It works as a macro calculator for weight loss for both female and male users."
          }
        },
        {
          "@type": "Question",
          "name": "Is this a good macro calculator for muscle gain?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Choose the Muscle Gain goal and the calculator adds a lean bulking surplus on top of your TDEE, then sets a high-protein split. It doubles as a bodybuilding macro calculator with custom gram and percentage overrides for advanced programming."
          }
        },
        {
          "@type": "Question",
          "name": "Does the macro calculator work for women?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. This macro calculator for women uses the correct Mifflin-St Jeor constants for female metabolism and applies a medically recognised safety floor so weight-loss targets stay in a healthy range. Simply set sex to female to get tailored macro and calorie numbers."
          }
        },
        {
          "@type": "Question",
          "name": "Is this macro calculator free and private?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. It is a 100% free online macro calculator that runs entirely in your browser. There is no sign-up, and your height, weight, age, and goals never leave your device."
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>
        
        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How macro calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col gap-3">
          <!-- Unit Toggle (Miro Pill Style) -->
          <div class="flex flex-col gap-1">
            <label class="text-[11px] font-semibold text-charcoal">Measurement Unit</label>
            <div class="flex rounded-full bg-surface p-0.5 border border-hairline self-start">
              <button
                type="button"
                id="unit-metric-btn"
                class="text-[11px] px-4 py-1 rounded-full font-bold transition-all cursor-pointer text-slate"
              >
                Metric (cm/kg)
              </button>
              <button
                type="button"
                id="unit-imperial-btn"
                class="text-[11px] px-4 py-1 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas"
              >
                Imperial (ft-in/lb)
              </button>
            </div>
          </div>

          <!-- Sex & Age Inputs -->
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1">
              <label for="sex-select" class="text-[11px] font-semibold text-charcoal">Sex</label>
              <select
                id="sex-select"
                class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                aria-label="Biological Sex Select"
              >
                <option value="male" selected>Male</option>
                <option value="female">Female</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="flex flex-col gap-1">
              <label for="age-input" class="text-[11px] font-semibold text-charcoal">Age</label>
              <div class="relative">
                <input
                  type="number"
                  id="age-input"
                  min="15"
                  max="80"
                  value="30"
                  class="text-input py-1 text-xs font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">yrs</span>
              </div>
            </div>
          </div>

          <!-- Height Inputs -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal flex justify-between">
              <span>Height</span>
              <span id="height-label" class="font-mono text-stone font-semibold">5 ft 9 in</span>
            </label>

            <!-- Metric Height (CM) -->
            <div id="metric-height-container" class="flex items-center gap-2 hidden">
              <input
                type="range"
                id="height-metric-range"
                min="100"
                max="230"
                value="175"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Height in Centimeters Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="height-metric-input"
                  min="100"
                  max="230"
                  value="175"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">cm</span>
              </div>
            </div>

            <!-- Imperial Height (Feet + Inches) -->
            <div id="imperial-height-container" class="grid grid-cols-2 gap-2">
              <div class="relative">
                <input
                  type="number"
                  id="height-ft-input"
                  min="3"
                  max="7"
                  value="5"
                  class="text-input pr-6 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                  placeholder="ft"
                  aria-label="Height feet"
                />
                <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">ft</span>
              </div>
              <div class="relative">
                <input
                  type="number"
                  id="height-in-input"
                  min="0"
                  max="11"
                  value="9"
                  class="text-input pr-6 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                  placeholder="in"
                  aria-label="Height inches"
                />
                <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">in</span>
              </div>
            </div>
          </div>

          <!-- Weight Inputs -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-charcoal flex justify-between">
              <span>Weight</span>
              <span id="weight-label" class="font-mono text-stone font-semibold">176 lb</span>
            </label>

            <!-- Metric Weight (KG) -->
            <div id="metric-weight-container" class="flex items-center gap-2 hidden">
              <input
                type="range"
                id="weight-metric-range"
                min="35"
                max="200"
                value="80"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Weight in Kilograms Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="weight-metric-input"
                  min="35"
                  max="200"
                  value="80"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">kg</span>
              </div>
            </div>

            <!-- Imperial Weight (LBS) -->
            <div id="imperial-weight-container" class="flex items-center gap-2">
              <input
                type="range"
                id="weight-lbs-range"
                min="80"
                max="450"
                value="176"
                step="1"
                class="w-full cursor-pointer accent-brand-blue"
                aria-label="Weight in Pounds Slider"
              />
              <div class="relative w-20 shrink-0">
                <input
                  type="number"
                  id="weight-lbs-input"
                  min="80"
                  max="450"
                  value="176"
                  class="text-input pr-7 py-1 text-xs text-center font-mono h-8"
                  inputmode="numeric"
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-stone text-[10px]">lb</span>
              </div>
            </div>
          </div>

          <script type="text/javascript" is:inline>
            (function() {
              const savedUnit = localStorage.getItem("macro-unit") || "imperial";
              if (savedUnit === "metric") {
                document.getElementById("metric-height-container")?.classList.remove("hidden");
                document.getElementById("imperial-height-container")?.classList.add("hidden");
                document.getElementById("metric-weight-container")?.classList.remove("hidden");
                document.getElementById("imperial-weight-container")?.classList.add("hidden");
                
                const metricBtn = document.getElementById("unit-metric-btn");
                const imperialBtn = document.getElementById("unit-imperial-btn");
                if (metricBtn && imperialBtn) {
                  metricBtn.classList.add("bg-primary", "text-canvas");
                  metricBtn.classList.remove("text-slate");
                  imperialBtn.classList.remove("bg-primary", "text-canvas");
                  imperialBtn.classList.add("text-slate");
                }
                const labelH = document.getElementById("height-label");
                if (labelH) labelH.textContent = "175 cm";
                const labelW = document.getElementById("weight-label");
                if (labelW) labelW.textContent = "80 kg";
              }
            })();
          </script>

          <!-- Activity Level -->
          <div class="flex flex-col gap-1">
            <label for="activity-select" class="text-[11px] font-semibold text-charcoal">Activity Level</label>
            <select
              id="activity-select"
              class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
            >
              <option value="1.2">Sedentary (Little to no exercise)</option>
              <option value="1.375" selected>Lightly Active (Exercise 1-3 days/week)</option>
              <option value="1.55">Moderately Active (Exercise 3-5 days/week)</option>
              <option value="1.725">Very Active (Hard exercise 6-7 days/week)</option>
              <option value="1.9">Extra Active (Very intense physical job / twice-daily workouts)</option>
            </select>
          </div>

          <!-- Goal selector -->
          <div class="flex flex-col gap-1">
            <label class="text-[11px] font-semibold text-charcoal">Fitness Goal</label>
            <div class="grid grid-cols-2 gap-2" id="goal-container">
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-goal="maintenance">
                <span class="block text-xs font-bold text-primary">Maintenance</span>
                <span class="block text-[9px] text-stone mt-0.5">TDEE level calories</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-goal="fat-loss">
                <span class="block text-xs font-bold text-primary">Fat Loss</span>
                <span class="block text-[9px] text-stone mt-0.5">~0.5 kg/week target loss</span>
                <span class="absolute top-1.5 right-1.5 bg-success-accent text-canvas text-[8px] font-bold px-1.5 py-0.5 rounded-full">Recommended</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-goal="muscle-gain">
                <span class="block text-xs font-bold text-primary">Muscle Gain</span>
                <span class="block text-[9px] text-stone mt-0.5">Clean bulk surplus</span>
              </button>
              <button type="button" class="goal-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-goal="body-recomp">
                <span class="block text-xs font-bold text-primary">Body Recomposition</span>
                <span class="block text-[9px] text-stone mt-0.5">Lose fat & gain muscle</span>
              </button>
            </div>
          </div>

          <!-- Diet Style Selector -->
          <div class="flex flex-col gap-1">
            <label class="text-[11px] font-semibold text-charcoal">Diet Style / Macro Split Preset</label>
            <div class="grid grid-cols-2 gap-2" id="diet-container">
              <button type="button" class="diet-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-diet="balanced">
                <span class="block text-xs font-bold text-primary">Balanced (30/40/30)</span>
                <span class="block text-[9px] text-stone mt-0.5">Balanced protein/carbs/fats</span>
              </button>
              <button type="button" class="diet-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-diet="high-protein">
                <span class="block text-xs font-bold text-primary">High Protein (40/30/30)</span>
                <span class="block text-[9px] text-stone mt-0.5">Build & preserve muscle</span>
              </button>
              <button type="button" class="diet-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-diet="low-carb">
                <span class="block text-xs font-bold text-primary">Low Carb/Keto (25/10/65)</span>
                <span class="block text-[9px] text-stone mt-0.5">Fat-adapted ketogenic split</span>
              </button>
              <button type="button" class="diet-btn p-2 border border-hairline rounded-lg text-left transition-all bg-canvas hover:bg-surface select-none relative" data-diet="custom">
                <span class="block text-xs font-bold text-primary">Custom Split</span>
                <span class="block text-[9px] text-stone mt-0.5">Set custom ratios or grams</span>
              </button>
            </div>
          </div>

          <!-- Advanced Options Collapsible -->
          <div class="border-t border-hairline-soft pt-2 mt-1">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-[11px] font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1">
                ⚙ Advanced Parameters (Body Fat %, Meal Split, Custom Override)
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-3.5 h-3.5 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="advanced-panel" class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-3 mt-1.5">
              <div class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft/50">
                <!-- Body Fat -->
                <div class="flex flex-col gap-1">
                  <label for="bodyfat-input" class="text-[10px] font-semibold text-slate">Body Fat % (Optional)</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="bodyfat-input"
                      min="3"
                      max="50"
                      placeholder="e.g. 18"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">%</span>
                  </div>
                  <span class="text-[8px] text-stone leading-tight">Enables Katch-McArdle formula for lean body mass.</span>
                </div>

                <!-- Meal Count Selector -->
                <div class="flex flex-col gap-1">
                  <label for="meal-select" class="text-[10px] font-semibold text-slate">Daily Meal Distribution</label>
                  <select
                    id="meal-select"
                    class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                  >
                    <option value="3">3 meals (Breakfast, Lunch, Dinner)</option>
                    <option value="4" selected>4 meals (3 Meals + 1 Snack)</option>
                    <option value="5">5 meals (3 Meals + 2 Snacks)</option>
                    <option value="6">6 meals (Athletic frequency)</option>
                  </select>
                </div>
              </div>

              <!-- Custom Override Fields (Visible always but editable/functional when Diet Split is Custom) -->
              <div id="custom-override-container" class="p-3 bg-surface border border-hairline rounded-lg hidden flex-col gap-2">
                <div class="flex justify-between items-center">
                  <span class="text-[10px] font-bold text-primary">Custom Split Target Config</span>
                  <div class="flex rounded-full bg-canvas p-0.5 border border-hairline">
                    <button type="button" id="custom-mode-pct-btn" class="text-[8px] px-2 py-0.5 rounded-full font-bold bg-primary text-canvas">Percentage (%)</button>
                    <button type="button" id="custom-mode-g-btn" class="text-[8px] px-2 py-0.5 rounded-full font-bold text-slate">Grams (g)</button>
                  </div>
                </div>
                <div class="grid grid-cols-3 gap-2">
                  <div class="flex flex-col gap-1">
                    <label for="custom-protein" class="text-[9px] font-semibold text-charcoal">Protein</label>
                    <div class="relative">
                      <input type="number" id="custom-protein" class="text-input text-xs font-mono h-8 px-2" value="30" />
                      <span id="custom-p-unit" class="absolute right-1.5 top-1/2 -translate-y-1/2 text-stone text-[9px]">%</span>
                    </div>
                  </div>
                  <div class="flex flex-col gap-1">
                    <label for="custom-carbs" class="text-[9px] font-semibold text-charcoal">Carbs</label>
                    <div class="relative">
                      <input type="number" id="custom-carbs" class="text-input text-xs font-mono h-8 px-2" value="40" />
                      <span id="custom-c-unit" class="absolute right-1.5 top-1/2 -translate-y-1/2 text-stone text-[9px]">%</span>
                    </div>
                  </div>
                  <div class="flex flex-col gap-1">
                    <label for="custom-fats" class="text-[9px] font-semibold text-charcoal">Fats</label>
                    <div class="relative">
                      <input type="number" id="custom-fats" class="text-input text-xs font-mono h-8 px-2" value="30" />
                      <span id="custom-f-unit" class="absolute right-1.5 top-1/2 -translate-y-1/2 text-stone text-[9px]">%</span>
                    </div>
                  </div>
                </div>
                <div id="custom-validation-msg" class="text-[9px] font-semibold text-stone">
                  Values must sum to exactly 100%. Currently: <span id="custom-sum-display" class="font-mono text-primary">100%</span>
                </div>
              </div>

              <div class="flex items-center justify-end mt-1">
                <button
                  type="button"
