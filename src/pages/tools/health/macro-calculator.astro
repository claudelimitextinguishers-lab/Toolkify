    const activitySelect = document.getElementById("activity-select") as HTMLSelectElement;
    const goalButtons = document.querySelectorAll("#goal-container .goal-btn");
    const dietButtons = document.querySelectorAll("#diet-container .diet-btn");

    // Advanced Panel DOM Elements
    const advancedToggleBtn = document.getElementById("advanced-toggle-btn");
