    // Custom overrides state
    let customMode = "pct"; // pct | g
    let customP = 30;
    let customC = 40;
    let customF = 30;

    // DOM Elements
    const unitMetricBtn = document.getElementById("unit-metric-btn");
    const unitImperialBtn = document.getElementById("unit-imperial-btn");
    const sexSelect = document.getElementById("sex-select") as HTMLSelectElement;
    const ageInput = document.getElementById("age-input") as HTMLInputElement;

