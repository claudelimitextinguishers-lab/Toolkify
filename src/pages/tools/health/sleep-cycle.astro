---
import Layout from '../../../layouts/Layout.astro';

// Tool metadata
const name = "Sleep Cycle Calculator";
const category = "health";
const tier = "Health & Fitness";
const description = "Optimize your bedtime and wake-up times based on 90-minute sleep cycles and personalized circadian rhythm buffers.";
---

<Layout 
  title={`${name} - BoardTools`}
  description={description}
  toolName={name}
  toolCategory={category}
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Sleep Cycle Calculator",
      "url": "https://boardtools.app/tools/health/sleep-cycle",
      "description": "Interactive client-side sleep cycle calculator based on circadian rhythms. Find the best times to fall asleep or wake up, customize sleep cycle lengths, and visualize sleep stages.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <section class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex items-center justify-between mt-0.5 gap-4">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>
        <button
          type="button"
          id="reset-btn"
          class="inline-flex items-center gap-1 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
          aria-label="Reset calculator inputs"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
          </svg>
          <span>Reset</span>
        </button>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 print:border-none print:shadow-none print:bg-transparent print:p-0">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col justify-between gap-3 print:hidden">
          <div class="flex flex-col gap-3">
            <!-- Calculation Direction Tab Switcher -->
            <div class="flex flex-col gap-1">
              <label class="text-[11px] font-semibold text-charcoal">I want to...</label>
              <div class="flex rounded-full bg-surface p-0.5 border border-hairline self-start w-full">
                <button
                  type="button"
                  id="dir-wake-btn"
                  class="flex-1 text-[11px] py-1.5 px-2 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas text-center sm:whitespace-nowrap"
                >
                  <span class="block sm:hidden">Wake Up Time</span>
                  <span class="hidden sm:block">Wake up at a specific time</span>
                </button>
                <button
                  type="button"
                  id="dir-sleep-btn"
                  class="flex-1 text-[11px] py-1.5 px-2 rounded-full font-bold transition-all cursor-pointer text-slate text-center sm:whitespace-nowrap"
                >
                  <span class="block sm:hidden">Bedtime</span>
                  <span class="hidden sm:block">Go to sleep now / chosen time</span>
                </button>
              </div>
            </div>

            <!-- Target Time Input Selection -->
            <div class="flex flex-col gap-2">
              <div id="target-wake-container" class="flex flex-col gap-1">
                <label for="input-wake-time" class="text-[11px] font-semibold text-charcoal">What time do you need to wake up?</label>
                <input
                  type="time"
                  id="input-wake-time"
                  value="07:00"
                  class="text-input py-1 text-xs font-mono h-8 w-full cursor-text bg-canvas"
                />
              </div>

              <div id="target-sleep-container" class="flex flex-col gap-2 hidden">
                <label for="input-sleep-time" class="text-[11px] font-semibold text-charcoal">When are you going to bed?</label>
                <div class="flex gap-2">
                  <input
                    type="time"
                    id="input-sleep-time"
                    value="22:00"
                    class="text-input py-1 text-xs font-mono h-8 flex-1 cursor-text bg-canvas"
                  />
                  <button
                    type="button"
                    id="btn-sleep-now"
                    class="inline-flex items-center justify-center text-[10px] font-bold px-3 py-1 bg-surface-pricing-featured border border-brand-blue/30 text-brand-blue hover:bg-brand-blue hover:text-canvas rounded-lg transition-all cursor-pointer whitespace-nowrap shrink-0"
                  >
                    ⏰ Sleep Now
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Advanced Options drawer -->
          <div class="border-t border-hairline-soft pt-2 mt-1">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-[11px] font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1">
                ⚙ Advanced Sleep Settings
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-3.5 h-3.5 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="advanced-panel" class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-3 mt-1.5">
              <div class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft/50">
                <!-- Custom Cycle Length -->
                <div class="flex flex-col gap-1">
                  <label for="input-cycle-length" class="text-[10px] font-semibold text-slate">Sleep Cycle Length</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="input-cycle-length"
                      min="70"
                      max="110"
                      value="90"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">mins</span>
                  </div>
                  <span class="text-[8px] text-stone leading-tight">Average adult cycle is ~90 minutes.</span>
                </div>

                <!-- Custom fall-asleep buffer -->
                <div class="flex flex-col gap-1">
                  <label for="input-fall-asleep" class="text-[10px] font-semibold text-slate">Fall-Asleep Buffer</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="input-fall-asleep"
                      min="0"
                      max="60"
                      value="15"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">mins</span>
                  </div>
                  <span class="text-[8px] text-stone leading-tight">Time needed to drift to sleep.</span>
                </div>
              </div>

              <!-- Age based sleep guidance drop-down -->
              <div class="flex flex-col gap-1">
                <label for="input-age-group" class="text-[10px] font-semibold text-slate">Age Group Recommended Sleep</label>
                <select
                  id="input-age-group"
                  class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                >
                  <option value="adult" selected>Adult (18-64 yrs) — 7 to 9 hours</option>
                  <option value="older-adult">Older Adult (65+ yrs) — 7 to 8 hours</option>
                  <option value="teen">Teenager (13-17 yrs) — 8 to 10 hours</option>
                  <option value="child">School Child (6-12 yrs) — 9 to 11 hours</option>
                  <option value="toddler">Toddler (1-5 yrs) — 10 to 14 hours</option>
                </select>
              </div>

              <div class="flex items-center justify-end mt-1">
                <button
                  type="button"
                  id="advanced-view-result-btn"
                  class="inline-flex items-center gap-1 text-[10px] font-semibold px-3 py-1 bg-primary hover:bg-charcoal text-canvas rounded-full transition-all cursor-pointer shadow-subtle"
                >
                  View Result &darr;
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Pane: Main Output Dashboard -->
        <div id="results-card" class="card-feature-teal flex flex-col justify-between p-4 sm:p-5 relative overflow-hidden rounded-xl border border-moss-dark/10 print:border-none print:shadow-none print:p-0">
          <div class="absolute top-0 right-0 w-32 h-32 bg-teal-light/25 rounded-full blur-2xl pointer-events-none print:hidden"></div>
          
          <div class="flex flex-col gap-3.5 z-10 w-full">
            <!-- Results Header -->
            <div class="flex items-center justify-between border-b border-moss-dark/10 pb-2">
              <span class="text-[10px] uppercase font-extrabold text-moss-dark/70 tracking-widest" id="results-header-title">Optimal Sleep Intervals</span>
              <span class="flex h-2 w-2 relative print:hidden">
                <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-accent opacity-75"></span>
                <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-success-accent"></span>
              </span>
            </div>

            <!-- List of Recommended Times -->
            <div class="flex flex-col gap-2">
              <span class="text-[10px] uppercase font-bold text-slate block" id="recommended-intro-lbl">Suggested bedtimes (Wake up at 7:00 AM)</span>
              
              <div id="times-list-container" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                <!-- Injected dynamically via JS: cards representing each recommendation -->
              </div>
            </div>

            <!-- Sleep Cycle Night Timeline Visualizer -->
            <div class="flex flex-col gap-1.5 border-t border-moss-dark/10 pt-3">
              <div class="flex justify-between items-center text-[9px] uppercase font-bold text-slate">
                <span>Visual Sleep Cycles Timeline (Selected Target)</span>
                <span id="timeline-duration-lbl" class="font-mono text-stone font-semibold">-</span>
              </div>
              <div class="w-full h-6 bg-canvas/60 dark:bg-canvas/10 backdrop-blur-md rounded-lg overflow-hidden flex relative border border-hairline" id="timeline-visual-bar">
                <!-- Segment elements injected via Javascript -->
              </div>
              <div class="flex justify-between text-[8px] font-bold text-stone px-0.5">
                <span id="timeline-start-time">-</span>
                <span id="timeline-end-time">-</span>
              </div>
            </div>

            <!-- Support Advice / Short Explanation Box -->
            <div id="advice-box" class="text-[11px] text-moss-dark leading-relaxed pt-2 border-t border-moss-dark/5">
              <p id="advice-text">
                Enter your target wake-up time on the left. The calculator recommends sleeping schedules aligned to standard 90-minute circadian periods, avoiding groggy mid-cycle wakeups.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Button directly beneath input workspace -->
      <div class="flex justify-center pt-2 print:hidden">
        <button
          type="button"
          id="toggle-breakdown-btn"
          class="button-primary text-xs py-2 px-6 !rounded-full shadow-subtle hover:scale-105 active:scale-95 transition-all cursor-pointer flex items-center gap-1.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <span>View Detailed Breakdown & Analysis</span>
        </button>
      </div>
    </div>

    <!-- Detailed Breakdown & Analysis Section (Same Page) -->
    <div id="breakdown-section" class="max-h-0 overflow-hidden transition-all duration-500 flex flex-col gap-4 print:max-h-none print:overflow-visible">
      <div class="card-base p-4 sm:p-5 flex flex-col gap-4 mt-2 print:border-none print:shadow-none print:p-0">
        <div class="flex items-center justify-between border-b border-hairline pb-2">
          <h2 class="font-display font-semibold text-sm sm:text-base text-primary flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 3.055A9.003 9.003 0 1020.945 13H11V3.055z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
            </svg>
            Personalized Circadian Cycle Breakdown
          </h2>
          <button
            type="button"
            id="export-pdf-btn"
            class="inline-flex items-center gap-1 text-[10px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle print:hidden"
            aria-label="Export report to PDF"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span>Export Report</span>
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Cycles Duration Comparison Chart -->
          <div class="border border-hairline rounded-xl p-3 bg-surface-soft flex flex-col gap-2 print:border-none print:bg-transparent">
            <span class="text-[10px] uppercase font-bold text-slate">Sleep Duration & Efficiency Comparison</span>
            <div class="flex flex-col gap-2.5 pt-1.5" id="breakdown-chart-list">
              <!-- Dynamically populated comparative list of sleep cycle counts -->
            </div>
          </div>

          <!-- Sleep Stages & Quality Breakdown -->
          <div class="border border-hairline rounded-xl p-3 bg-surface-soft flex flex-col gap-2 print:border-none print:bg-transparent">
            <span class="text-[10px] uppercase font-bold text-slate">Stages of a Single Sleep Cycle (~90m)</span>
            <div class="flex flex-col gap-2 text-[10px] font-medium text-charcoal">
              <div class="flex justify-between py-1 border-b border-hairline-soft/50">
                <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded bg-indigo-300"></span>Light Sleep (N1 + N2)</span>
                <span class="font-bold font-mono">~55% (~50 mins)</span>
              </div>
              <div class="flex justify-between py-1 border-b border-hairline-soft/50">
                <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded bg-indigo-600"></span>Deep Sleep (N3)</span>
                <span class="font-bold font-mono">~20% (~18 mins)</span>
              </div>
              <div class="flex justify-between py-1 border-b border-hairline-soft/50">
                <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded bg-teal-400"></span>REM Sleep (Dreaming)</span>
                <span class="font-bold font-mono">~25% (~22 mins)</span>
              </div>
              <p class="text-[9px] leading-relaxed text-stone pt-1">
                Note: Cycle stages fluctuate dynamically across the night. Deep sleep is dominant in earlier cycles, whereas REM periods expand during later cycles closer to waking.
              </p>
            </div>
          </div>
        </div>

        <!-- Scientific Analysis Commentary Box -->
        <div id="scientific-analysis-box" class="text-[11px] text-slate leading-relaxed border-t border-hairline pt-3 mt-1 flex flex-col gap-2">
          <p id="analysis-summary-para">
            Loading sleep cycle analysis based on your target schedules...
          </p>
        </div>
      </div>
    </div>

    <!-- Science and limitations educational banner -->
    <div class="card-base flex flex-col gap-4 p-4 sm:p-5 mt-2 print:border-none print:shadow-none print:p-0">
      <h3 class="font-display font-semibold text-sm sm:text-base text-primary flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        The Science Behind Sleep Cycles & Circadian Rhythms
      </h3>
      <div class="text-[11px] sm:text-xs text-slate leading-relaxed flex flex-col gap-2.5">
        <p>
          Your body does not sleep in a flat state; instead, it progresses through structured, recurring <strong>sleep cycles</strong>. Each cycle comprises distinct stages that play different biological roles:
        </p>
        <ul class="list-disc pl-4 flex flex-col gap-1 text-slate font-medium">
          <li><strong>Light Sleep (N1 & N2):</strong> The transition phase from wakefulness. Muscle activity slows down, brain waves decrease in frequency, and core temperature falls. Waking up during light sleep is easy and leaves you feeling refreshed.</li>
          <li><strong>Deep Sleep (N3):</strong> Also known as slow-wave sleep. Blood flow transitions toward muscle recovery, cellular repairs commence, and growth hormones release. Waking during deep sleep triggers <em>sleep inertia</em>, causing disorientation, grogginess, and fatigue.</li>
          <li><strong>REM (Rapid Eye Movement) Sleep:</strong> The active dreaming phase. Brain waves spike, eyes dart, and muscle paralysis occurs. This stage is crucial for cognitive consolidation, emotional processing, and memory organization.</li>
        </ul>
        <p>
          <strong>The 90-Minute Rule:</strong> While 90 minutes is the standard model, individual cycles typically range from 70 to 110 minutes and change as you age. Consistently waking up at the completion of a full sleep cycle helps align with your body's biological clock.
        </p>
        <p class="text-[10px] text-stone mt-1">
          Disclaimer: This calculator is provided for educational and illustrative purposes only. All calculated dates and cycles are estimates. It does not constitute medical advice and is not a substitute for clinical care or assessment. Seek advice from a physician or sleep specialist for persistent insomnia or sleep disorders.
        </p>
      </div>
    </div>

    <!-- Security & Privacy Guard Footer Tag -->
    <div class="flex items-center justify-between text-[10px] text-slate px-1 print:hidden">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        100% Private, Client-Side Calculations
      </span>
      <span>v1.0.0</span>
    </div>
  </section>

  <!-- Client-side script module -->
  <script>
    // State variables
    let currentDirection = "wake"; // wake | sleep
    let cycleLength = 90; // default 90 mins
    let fallAsleepBuffer = 15; // default 15 mins
    let ageGroup = "adult"; // toddler, child, teen, adult, older-adult
    let selectedOptionIndex = 3; // index of the active option highlighted in timeline (default 6 cycles)

    // DOM Elements
    const dirWakeBtn = document.getElementById("dir-wake-btn");
    const dirSleepBtn = document.getElementById("dir-sleep-btn");
    const targetWakeContainer = document.getElementById("target-wake-container");
    const targetSleepContainer = document.getElementById("target-sleep-container");

    const inputWakeTime = document.getElementById("input-wake-time") as HTMLInputElement;
    const inputSleepTime = document.getElementById("input-sleep-time") as HTMLInputElement;
    const btnSleepNow = document.getElementById("btn-sleep-now");

    const advancedToggleBtn = document.getElementById("advanced-toggle-btn");
    const advancedPanel = document.getElementById("advanced-panel");
    const advancedChevron = document.getElementById("advanced-chevron");
    const inputCycleLength = document.getElementById("input-cycle-length") as HTMLInputElement;
    const inputFallAsleep = document.getElementById("input-fall-asleep") as HTMLInputElement;
    const inputAgeGroup = document.getElementById("input-age-group") as HTMLSelectElement;
    const advancedViewResultBtn = document.getElementById("advanced-view-result-btn");

    const resultsHeaderTitle = document.getElementById("results-header-title");
    const recommendedIntroLbl = document.getElementById("recommended-intro-lbl");
    const timesListContainer = document.getElementById("times-list-container");

    const timelineDurationLbl = document.getElementById("timeline-duration-lbl");
    const timelineVisualBar = document.getElementById("timeline-visual-bar");
    const timelineStartTime = document.getElementById("timeline-start-time");
    const timelineEndTime = document.getElementById("timeline-end-time");
    const adviceText = document.getElementById("advice-text");

    const statusPulse = document.getElementById("status-pulse");
    const statusDot = document.getElementById("status-dot");

    // Breakdown DOM Elements
    const toggleBreakdownBtn = document.getElementById("toggle-breakdown-btn");
    const breakdownSection = document.getElementById("breakdown-section");
    const exportPdfBtn = document.getElementById("export-pdf-btn");
    const breakdownChartList = document.getElementById("breakdown-chart-list");
    const analysisSummaryPara = document.getElementById("analysis-summary-para");

    const resetBtn = document.getElementById("reset-btn");

    // Enforce scrolling to top on refresh
    window.addEventListener("beforeunload", () => {
      window.scrollTo(0, 0);
    });

    function scrollToElementWithOffset(elementId: string, offset = 80) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const elementPosition = element.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth"
      });
    }

    // Helper functions for parsing and formatting times
    function parseTimeString(timeStr: string): Date {
      const today = new Date();
      const [hours, minutes] = timeStr.split(":").map(Number);
      today.setHours(hours, minutes, 0, 0);
      return today;
    }

    function formatTimeString(date: Date): string {
      return date.toLocaleTimeString(undefined, {
        hour: '2-digit',
        minute: '2-digit',
        hour12: true
      });
    }

    function addMinutes(date: Date, minutes: number): Date {
      return new Date(date.getTime() + minutes * 60 * 1000);
    }

    // Recommended sleep duration ranges by age group
    interface AgeRecommendation {
      minMins: number;
      maxMins: number;
      idealCycles: number[];
      label: string;
    }

    const AGE_RECOMMENDATIONS: Record<string, AgeRecommendation> = {
      toddler: { minMins: 600, maxMins: 840, idealCycles: [7, 8, 9], label: "Toddler (1-5 yrs)" },
      child: { minMins: 540, maxMins: 660, idealCycles: [6, 7], label: "School Child (6-12 yrs)" },
      teen: { minMins: 480, maxMins: 600, idealCycles: [5, 6, 7], label: "Teenager (13-17 yrs)" },
      adult: { minMins: 420, maxMins: 540, idealCycles: [5, 6], label: "Adult (18-64 yrs)" },
      "older-adult": { minMins: 420, maxMins: 480, idealCycles: [5], label: "Older Adult (65+ yrs)" }
    };

    // Load state from localStorage
    function loadState() {
      try {
        const savedDirection = localStorage.getItem("sleep-cycle-direction");
        const savedTargetWake = localStorage.getItem("sleep-cycle-target-wake");
        const savedTargetSleep = localStorage.getItem("sleep-cycle-target-sleep");
        const savedLength = localStorage.getItem("sleep-cycle-length");
        const savedBuffer = localStorage.getItem("sleep-cycle-buffer");
        const savedAge = localStorage.getItem("sleep-cycle-age");
        const savedIndex = localStorage.getItem("sleep-cycle-selected-index");

        if (savedDirection) currentDirection = savedDirection;
        if (savedTargetWake && inputWakeTime) inputWakeTime.value = savedTargetWake;
        if (savedTargetSleep && inputSleepTime) inputSleepTime.value = savedTargetSleep;
        if (savedLength && inputCycleLength) {
          cycleLength = parseInt(savedLength, 10);
          inputCycleLength.value = savedLength;
        }
        if (savedBuffer && inputFallAsleep) {
          fallAsleepBuffer = parseInt(savedBuffer, 10);
          inputFallAsleep.value = savedBuffer;
        }
        if (savedAge && inputAgeGroup) {
          ageGroup = savedAge;
          inputAgeGroup.value = savedAge;
        }
        if (savedIndex) {
          selectedOptionIndex = parseInt(savedIndex, 10);
        }
      } catch (e) {
        console.warn("Failed to load state from localStorage:", e);
      }
      updateDirectionUI();
      calculate();
    }

    // Save state to localStorage
    function saveState() {
      try {
        localStorage.setItem("sleep-cycle-direction", currentDirection);
        localStorage.setItem("sleep-cycle-target-wake", inputWakeTime.value);
        localStorage.setItem("sleep-cycle-target-sleep", inputSleepTime.value);
        localStorage.setItem("sleep-cycle-length", cycleLength.toString());
        localStorage.setItem("sleep-cycle-buffer", fallAsleepBuffer.toString());
        localStorage.setItem("sleep-cycle-age", ageGroup);
        localStorage.setItem("sleep-cycle-selected-index", selectedOptionIndex.toString());
      } catch (e) {
        console.warn("Failed to save state to localStorage:", e);
      }
    }

    // Toggle Direction panel
    function updateDirectionUI() {
      if (currentDirection === "wake") {
        dirWakeBtn?.classList.add("bg-primary", "text-canvas");
        dirWakeBtn?.classList.remove("text-slate");
        dirSleepBtn?.classList.remove("bg-primary", "text-canvas");
        dirSleepBtn?.classList.add("text-slate");

        targetWakeContainer?.classList.remove("hidden");
        targetSleepContainer?.classList.add("hidden");
      } else {
        dirSleepBtn?.classList.add("bg-primary", "text-canvas");
        dirSleepBtn?.classList.remove("text-slate");
        dirWakeBtn?.classList.remove("bg-primary", "text-canvas");
        dirWakeBtn?.classList.add("text-slate");

        targetSleepContainer?.classList.remove("hidden");
        targetWakeContainer?.classList.add("hidden");
      }
    }

    // Calculate options
    interface SleepOption {
      time: Date;
      cycles: number;
      durationMins: number;
      isRecommended: boolean;
    }

    function calculate() {
      const today = new Date();
      let targetDate = new Date();
      
      if (currentDirection === "wake") {
        targetDate = parseTimeString(inputWakeTime.value);
        if (recommendedIntroLbl) {
          recommendedIntroLbl.textContent = `Suggested Bedtimes (Wake up at ${formatTimeString(targetDate)})`;
        }
        if (resultsHeaderTitle) {
          resultsHeaderTitle.textContent = "Optimal Bedtimes";
        }
      } else {
        targetDate = parseTimeString(inputSleepTime.value);
        if (recommendedIntroLbl) {
          recommendedIntroLbl.textContent = `Suggested Wake-up times (Go to bed at ${formatTimeString(targetDate)})`;
        }
        if (resultsHeaderTitle) {
          resultsHeaderTitle.textContent = "Optimal Wake-up Times";
        }
      }

      const rec = AGE_RECOMMENDATIONS[ageGroup] || AGE_RECOMMENDATIONS.adult;
      const options: SleepOption[] = [];

      // We calculate 3 to 9 sleep cycles
      for (let cycles = 3; cycles <= 9; cycles++) {
        const sleepDurationMins = cycles * cycleLength;
        const totalOffsetMins = sleepDurationMins + fallAsleepBuffer;

        let calculatedTime: Date;
        if (currentDirection === "wake") {
          // Subtract cycle time and fall-asleep buffer to find when to lie down
          calculatedTime = addMinutes(targetDate, -totalOffsetMins);
        } else {
          // Add fall-asleep buffer and cycle time to find when to wake up
          calculatedTime = addMinutes(targetDate, totalOffsetMins);
        }

        const isRecommended = rec.idealCycles.includes(cycles);
        options.push({
          time: calculatedTime,
          cycles,
          durationMins: sleepDurationMins,
          isRecommended
        });
      }

      // If we are looking for bedtimes, we reverse or show them in chronological order
      // For wake directions: we want to show bedtimes that are earliest to latest.
      // E.g., if waking at 7 AM:
      // 9 cycles -> 9:15 PM bedtime
      // 6 cycles -> 9:45 PM bedtime
      // 5 cycles -> 11:15 PM bedtime
      // 4 cycles -> 12:45 AM bedtime
      // 3 cycles -> 2:15 AM bedtime
      // Let's filter or sort them so we display the most relevant ones.
      // We will display cycles 3, 4, 5, 6, 7, 8 (typically 6 options).
      
      // Let's render the list of cards
      if (timesListContainer) {
        timesListContainer.innerHTML = "";
        
        options.forEach((opt, idx) => {
          const card = document.createElement("button");
          card.type = "button";
          
          let recBadge = "";
          let cardStyle = "border-hairline hover:border-brand-blue/30";
          if (opt.isRecommended) {
            recBadge = `<span class="absolute top-1.5 right-2.5 bg-success-accent text-canvas text-[8px] font-bold px-1.5 py-0.5 rounded-full">Recommended</span>`;
          }

          if (idx === selectedOptionIndex) {
            cardStyle = "border-brand-blue bg-surface shadow-[0_0_12px_rgba(66,98,255,0.15)] ring-2 ring-brand-blue/30";
          }

          const hrs = Math.floor(opt.durationMins / 60);
          const mins = opt.durationMins % 60;
          
          card.className = `flex flex-col p-2.5 border rounded-lg text-left transition-all bg-canvas hover:bg-surface cursor-pointer relative ${cardStyle}`;
          card.innerHTML = `
            ${recBadge}
            <span class="block text-sm font-black text-primary font-mono">${formatTimeString(opt.time)}</span>
            <span class="block text-[9px] text-stone mt-0.5 font-semibold">${opt.cycles} Cycles (${hrs}h ${mins}m sleep)</span>
          `;

          card.addEventListener("click", () => {
            selectedOptionIndex = idx;
            saveState();
            calculate(); // refresh with updated selected card highlight
          });
          
          timesListContainer.appendChild(card);
        });
      }

      // Draw timeline for the currently selected option
      const selectedOpt = options[selectedOptionIndex] ?? options[3] ?? options[0];
      updateTimeline(selectedOpt, targetDate);

      // Generate Breakdown
      updateBreakdown(options, selectedOpt, rec, targetDate);
      
      saveState();
    }

    // Update sleep cycle visual representation
    function updateTimeline(opt: SleepOption, targetDate: Date) {
      if (!timelineVisualBar || !timelineStartTime || !timelineEndTime || !timelineDurationLbl) return;

      timelineVisualBar.innerHTML = "";

      let startTime: Date;
      let endTime: Date;

      if (currentDirection === "wake") {
        startTime = opt.time;
        endTime = targetDate;
      } else {
        startTime = targetDate;
        endTime = opt.time;
      }

      timelineStartTime.textContent = formatTimeString(startTime);
      timelineEndTime.textContent = formatTimeString(endTime);

      const totalMins = opt.durationMins + fallAsleepBuffer;
      const hrs = Math.floor(totalMins / 60);
      const mins = totalMins % 60;
      timelineDurationLbl.textContent = `${hrs}h ${mins}m total period`;

      // 1. Fall Asleep Buffer Segment (gray)
      const bufferPct = (fallAsleepBuffer / totalMins) * 100;
      const bufferSeg = document.createElement("div");
      bufferSeg.className = "h-full bg-stone/20 dark:bg-stone/30 flex items-center justify-center text-[7px] font-bold text-stone whitespace-nowrap overflow-hidden px-1 border-r border-hairline-strong/20";
      bufferSeg.style.width = `${bufferPct}%`;
      bufferSeg.title = `Fall Asleep Buffer: ${fallAsleepBuffer} mins`;
      bufferSeg.innerHTML = `<span class="sr-only">Buffer</span>💤`;
      timelineVisualBar.appendChild(bufferSeg);

      // 2. Cycle Segments
      const totalCycles = opt.cycles;
      const cyclePct = ((totalMins - fallAsleepBuffer) / totalCycles / totalMins) * 100;

      for (let c = 1; c <= totalCycles; c++) {
        const cycleSeg = document.createElement("div");
        cycleSeg.className = "h-full flex relative border-r border-hairline-strong/30 last:border-0";
        cycleSeg.style.width = `${cyclePct}%`;
        cycleSeg.title = `Cycle ${c}`;

        // Subdivide cycle into standard stages: Light Sleep (55%), Deep Sleep (20%), REM (25%)
        const lightSeg = document.createElement("div");
        lightSeg.className = "h-full bg-indigo-300/60 dark:bg-indigo-300/35 hover:bg-indigo-300 transition-colors";
        lightSeg.style.width = "55%";
        lightSeg.title = `Cycle ${c} - Light Sleep (~${Math.round(cycleLength * 0.55)} mins)`;
        
        const deepSeg = document.createElement("div");
        deepSeg.className = "h-full bg-indigo-600/60 dark:bg-indigo-600/35 hover:bg-indigo-600 transition-colors";
        deepSeg.style.width = "20%";
        deepSeg.title = `Cycle ${c} - Deep Sleep (~${Math.round(cycleLength * 0.20)} mins)`;

        const remSeg = document.createElement("div");
        remSeg.className = "h-full bg-teal-400/60 dark:bg-teal-400/35 hover:bg-teal-400 transition-colors";
        remSeg.style.width = "25%";
        remSeg.title = `Cycle ${c} - REM Sleep (~${Math.round(cycleLength * 0.25)} mins)`;

        // Cycle text overlay
        const labelText = document.createElement("span");
        labelText.className = "absolute inset-0 flex items-center justify-center text-[8px] font-black text-primary pointer-events-none select-none";
        labelText.textContent = `C${c}`;

        cycleSeg.appendChild(lightSeg);
        cycleSeg.appendChild(deepSeg);
        cycleSeg.appendChild(remSeg);
        cycleSeg.appendChild(labelText);
        
        timelineVisualBar.appendChild(cycleSeg);
      }

      // Update pulse colors based on sleep cycle recommendation
      let statusColor = "bg-success-accent";
      if (opt.cycles < 4) {
        statusColor = "bg-brand-coral";
      } else if (opt.cycles >= 4 && opt.cycles < 5) {
        statusColor = "bg-brand-yellow-deep";
      }

      if (statusPulse && statusDot) {
        statusPulse.className = `animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${statusColor}`;
        statusDot.className = `relative inline-flex rounded-full h-2 w-2 ${statusColor}`;
      }
    }

    // Populate Detailed Breakdown elements
    function updateBreakdown(options: SleepOption[], selectedOpt: SleepOption, rec: AgeRecommendation, targetDate: Date) {
      if (!breakdownChartList || !analysisSummaryPara || !adviceText) return;

      breakdownChartList.innerHTML = "";

      // We render a comparative list showing all options with a bar indicating sleep duration relative to the maximum (9 cycles)
      const maxDuration = 9 * cycleLength;
      
      options.forEach((opt, idx) => {
        const pct = (opt.durationMins / maxDuration) * 100;
        const hrs = Math.floor(opt.durationMins / 60);
        const mins = opt.durationMins % 60;
        
        // Rating calculation
        let ratingStr = "Deprived";
        let ratingColor = "text-brand-coral bg-brand-coral/10";
        if (rec.idealCycles.includes(opt.cycles)) {
          ratingStr = "Optimal";
          ratingColor = "text-success-accent bg-success-accent/10";
        } else if (opt.cycles > Math.max(...rec.idealCycles)) {
          ratingStr = "Excessive";
          ratingColor = "text-brand-blue bg-brand-blue/10";
        } else if (opt.cycles >= Math.min(...rec.idealCycles) - 1) {
          ratingStr = "Sufficient";
          ratingColor = "text-brand-yellow-deep bg-brand-yellow-deep/10";
        }

        const barClass = idx === selectedOptionIndex ? "bg-brand-blue" : "bg-brand-blue/50";
        const textWeight = idx === selectedOptionIndex ? "font-bold text-primary" : "text-slate";

        const row = document.createElement("div");
        row.className = "flex flex-col gap-1";
        row.innerHTML = `
          <div class="flex justify-between items-center text-[10px] ${textWeight}">
            <span class="flex items-center gap-1">
              <strong>${opt.cycles} Cycles</strong> (${hrs}h ${mins}m)
            </span>
            <span class="px-2 py-0.5 rounded text-[8px] font-extrabold uppercase ${ratingColor}">${ratingStr}</span>
          </div>
          <div class="w-full h-2 bg-hairline rounded-full overflow-hidden">
            <div class="h-full ${barClass} transition-all duration-500" style="width: ${pct}%;"></div>
          </div>
        `;
        breakdownChartList.appendChild(row);
      });

      // Populate Written Analysis Paragraph
      const selectedHrs = Math.floor(selectedOpt.durationMins / 60);
      const selectedMins = selectedOpt.durationMins % 60;
      
      let analysisText = "";
      if (selectedOpt.cycles >= 5 && selectedOpt.cycles <= 6) {
        analysisText = `Selecting <strong>${selectedOpt.cycles} cycles</strong> (${selectedHrs}h ${selectedMins}m of sleep) aligns perfectly with the recommended sleep range for an average <strong>${rec.label}</strong>. This duration allows your body to complete healthy cycles of deep slow-wave physical recovery and REM cognitive consolidation. You are likely to wake up feeling refreshed.`;
      } else if (selectedOpt.cycles >= 7) {
        analysisText = `A sleep period of <strong>${selectedOpt.cycles} cycles</strong> (${selectedHrs}h ${selectedMins}m) provides an extended rest. This is highly suitable for recovery after high cognitive or physical stress, or for younger age demographics. Be mindful that oversleeping past 9 cycles can sometimes cause grogginess due to prolonged light sleep states.`;
      } else {
        analysisText = `Sleeping for <strong>${selectedOpt.cycles} cycles</strong> (${selectedHrs}h ${selectedMins}m) is below the recommended daily sleep baseline of 7 hours. While waking at the end of this cycle minimizes sleep inertia, a recurring short sleep duration will build up a "sleep debt," impacting immune function, cardiovascular health, and mental focus.`;
      }

      analysisSummaryPara.innerHTML = `
        <p class="mb-2">${analysisText}</p>
        <p><strong>Circadian Rhythm Recommendation:</strong> Waking up at <strong>${formatTimeString(selectedOpt.time)}</strong> (or bedtime at this time) is ideal. Be sure to turn off glowing screens 30-60 minutes prior, maintain a cool, dark room, and limit caffeine intake in the afternoon to optimize your natural melatonin production.</p>
      `;

      // Update advice box text
      const directionWord = currentDirection === "wake" ? "go to sleep" : "wake up";
      const targetTimeWord = currentDirection === "wake" ? "wake up" : "go to bed";
      
      adviceText.innerHTML = `To ${targetTimeWord} at <strong>${formatTimeString(targetDate)}</strong>, you should aim to ${directionWord} at <strong>${formatTimeString(selectedOpt.time)}</strong>. This allocates exactly <strong>${selectedOpt.cycles} full sleep cycles</strong> (${selectedHrs}h ${selectedMins}m) plus a <strong>${fallAsleepBuffer}-minute buffer</strong>.`;
    }

    // Tab Switch Listener
    dirWakeBtn?.addEventListener("click", () => {
      currentDirection = "wake";
      selectedOptionIndex = 3; // Reset to default 6 cycles card
      updateDirectionUI();
      calculate();
    });

    dirSleepBtn?.addEventListener("click", () => {
      currentDirection = "sleep";
      selectedOptionIndex = 3; // Reset to default 6 cycles card
      updateDirectionUI();
      calculate();
    });

    // Time input change listeners
    inputWakeTime?.addEventListener("input", calculate);
    inputSleepTime?.addEventListener("input", calculate);

    // Sleep Now shortcut
    btnSleepNow?.addEventListener("click", () => {
      const now = new Date();
      const hrs = String(now.getHours()).padStart(2, '0');
      const mins = String(now.getMinutes()).padStart(2, '0');
      inputSleepTime.value = `${hrs}:${mins}`;
      calculate();
    });

    // Advanced options toggle
    advancedToggleBtn?.addEventListener("click", () => {
      if (advancedPanel) {
        const isCollapsed = advancedPanel.classList.contains("max-h-0");
        if (isCollapsed) {
          advancedPanel.classList.remove("max-h-0", "overflow-hidden");
          advancedPanel.classList.add("max-h-[500px]", "overflow-visible");
          advancedChevron?.classList.add("rotate-180");
        } else {
          advancedPanel.classList.remove("max-h-[500px]", "overflow-visible");
          advancedPanel.classList.add("max-h-0", "overflow-hidden");
          advancedChevron?.classList.remove("rotate-180");
        }
      }
    });

    // Advanced input listeners
    inputCycleLength?.addEventListener("input", () => {
      const val = parseInt(inputCycleLength.value, 10);
      if (!isNaN(val)) {
        cycleLength = Math.max(70, Math.min(110, val));
        calculate();
      }
    });

    inputCycleLength?.addEventListener("blur", () => {
      inputCycleLength.value = cycleLength.toString();
    });

    inputFallAsleep?.addEventListener("input", () => {
      const val = parseInt(inputFallAsleep.value, 10);
      if (!isNaN(val)) {
        fallAsleepBuffer = Math.max(0, Math.min(60, val));
        calculate();
      }
    });

    inputFallAsleep?.addEventListener("blur", () => {
      inputFallAsleep.value = fallAsleepBuffer.toString();
    });

    inputAgeGroup?.addEventListener("change", () => {
      ageGroup = inputAgeGroup.value;
      calculate();
    });

    // View result smooth scrolls
    advancedViewResultBtn?.addEventListener("click", () => {
      scrollToElementWithOffset("results-card", 80);
    });

    // Detailed Breakdown toggle
    toggleBreakdownBtn?.addEventListener("click", () => {
      if (breakdownSection) {
        const isCollapsed = breakdownSection.classList.contains("max-h-0");
        if (isCollapsed) {
          breakdownSection.classList.remove("max-h-0");
          breakdownSection.classList.add("max-h-[2000px]");
          setTimeout(() => {
            scrollToElementWithOffset("breakdown-section", 60);
          }, 100);
        } else {
          breakdownSection.classList.remove("max-h-[2000px]");
          breakdownSection.classList.add("max-h-0");
        }
      }
    });

    // Export PDF Print event
    exportPdfBtn?.addEventListener("click", () => {
      if (breakdownSection && breakdownSection.classList.contains("max-h-0")) {
        breakdownSection.classList.remove("max-h-0");
        breakdownSection.classList.add("max-h-[2000px]");
      }
      window.print();
    });

    // Reset button listener
    resetBtn?.addEventListener("click", () => {
      const keys = [
        "sleep-cycle-direction",
        "sleep-cycle-target-wake",
        "sleep-cycle-target-sleep",
        "sleep-cycle-length",
        "sleep-cycle-buffer",
        "sleep-cycle-age",
        "sleep-cycle-selected-index"
      ];
      keys.forEach(k => localStorage.removeItem(k));

      // Reset values
      currentDirection = "wake";
      cycleLength = 90;
      fallAsleepBuffer = 15;
      ageGroup = "adult";
      selectedOptionIndex = 3;

      if (inputWakeTime) inputWakeTime.value = "07:00";
      if (inputSleepTime) inputSleepTime.value = "22:00";
      if (inputCycleLength) inputCycleLength.value = "90";
      if (inputFallAsleep) inputFallAsleep.value = "15";
      if (inputAgeGroup) inputAgeGroup.value = "adult";

      updateDirectionUI();
      calculate();

      // close sections
      if (advancedPanel) {
        advancedPanel.classList.remove("max-h-[500px]", "overflow-visible");
        advancedPanel.classList.add("max-h-0", "overflow-hidden");
      }
      advancedChevron?.classList.remove("rotate-180");
      if (breakdownSection) {
        breakdownSection.classList.remove("max-h-[2000px]");
        breakdownSection.classList.add("max-h-0");
      }
    });

    // Load initial state
    loadState();
  </script>
</Layout>

<style>
  /* Premium print overrides for PDF exports */
  @media print {
    body * {
      visibility: hidden;
    }
    #breakdown-section, #breakdown-section * {
      visibility: visible;
    }
    #breakdown-section {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
    }
    #export-pdf-btn {
      display: none;
    }
  }

  /* Custom input classes matching standard boardtools theme */
  .text-input {
    background-color: var(--color-canvas, #ffffff);
    color: var(--color-ink, #1c1c1e);
    border: 1px solid var(--color-hairline-strong, #c7cad5);
    border-radius: var(--rounded-md, 8px);
    padding: 0 12px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
  }
  .text-input:focus {
    border-color: var(--color-brand-blue, #4262ff);
    border-width: 2px;
  }
</style>
