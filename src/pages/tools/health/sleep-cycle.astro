      >
        <div class="bg-canvas rounded-2xl max-w-lg w-full p-6 border border-hairline shadow-modal flex flex-col gap-4 animate-scale-in max-h-[85vh] overflow-y-auto">
          <div class="flex justify-between items-center pb-2 border-b border-hairline-soft">
            <h3 class="font-display font-semibold text-lg text-primary">How the Sleep Cycle Calculator Works</h3>
            <button type="button" id="close-modal-btn" class="text-stone hover:text-primary transition-all text-lg cursor-pointer bg-transparent border-none">&#x2715;</button>
          </div>
          <div class="text-xs text-slate leading-relaxed flex flex-col gap-3">
            <h4 class="font-semibold text-primary">1. The 90-Minute Sleep Cycle</h4>
            <p>The average human sleep cycle lasts about 90 minutes, passing through light sleep, deep slow-wave sleep, and REM sleep. Waking at the natural end of a cycle â€” rather than mid-cycle â€” dramatically reduces grogginess (sleep inertia).</p>
            <h4 class="font-semibold text-primary">2. Fall-Asleep Buffer</h4>
            <p>It typically takes 10â€“20 minutes to fall asleep after lying down. The calculator adds this buffer (default 15 min) so your recommended bedtime or wake-up time accounts for real-world sleep onset, not just the moment you close your eyes.</p>
            <h4 class="font-semibold text-primary">3. Age-Based Recommendations</h4>
            <p>The number of ideal sleep cycles varies by age. Adults need 5â€“6 cycles (~7.5â€“9 hrs), while children and teens need 6â€“9 cycles. The calculator highlights the optimal range for your selected age group.</p>
          </div>
          <button type="button" id="modal-ok-btn" class="button-primary text-xs py-2 px-5 mt-2 self-end cursor-pointer">Got it</button>
        </div>
      </div>
    `;
    document.body.insertAdjacentHTML("beforeend", modalHtml);

    const shareBtn = document.getElementById("share-btn");
    const howItWorksBtn = document.getElementById("how-it-works-btn");
    const howItWorksModal = document.getElementById("how-it-works-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const modalOkBtn = document.getElementById("modal-ok-btn");

    howItWorksBtn?.addEventListener("click", () => howItWorksModal?.classList.remove("hidden"));
    closeModalBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));
    modalOkBtn?.addEventListener("click", () => howItWorksModal?.classList.add("hidden"));

    shareBtn?.addEventListener("click", () => {
      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set("dir", currentDirection);
      url.searchParams.set("wake", inputWakeTime?.value || "07:00");
      url.searchParams.set("sleep", inputSleepTime?.value || "22:00");
      url.searchParams.set("len", cycleLength.toString());
      url.searchParams.set("buf", fallAsleepBuffer.toString());
      url.searchParams.set("age", ageGroup);
      url.searchParams.set("idx", selectedOptionIndex.toString());

      const shareData = { title: document.title || "Sleep Cycle Calculator", url: url.toString() };

      if (navigator.share) {
        navigator.share(shareData).catch((err) => {
          if (err.name !== "AbortError") copyToClipboard(url.toString());
        });
      } else {
        copyToClipboard(url.toString());
      }

      function copyToClipboard(text: string) {
        if (navigator.clipboard?.writeText) {
          navigator.clipboard.writeText(text).then(showSuccess).catch(() => fallbackCopy(text));
        } else fallbackCopy(text);
      }
      function fallbackCopy(text: string) {
        const ta = document.createElement("textarea");
        ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
        document.body.appendChild(ta); ta.select();
        try { document.execCommand("copy"); showSuccess(); } catch(e) {}
        document.body.removeChild(ta);
      }
      function showSuccess() {
        if (!shareBtn) return;
        const span = shareBtn.querySelector("span");
        if (!span) return;
        const orig = span.textContent || "Share";
        span.textContent = "Link Copied!";
        shareBtn.classList.add("text-success-accent", "border-success-accent");
        setTimeout(() => { span.textContent = orig; shareBtn.classList.remove("text-success-accent", "border-success-accent"); }, 2000);
      }
    });

    // Load state from localStorage or URL params
    function loadState() {
      const urlParams = new URLSearchParams(window.location.search);
      const get = (lsKey: string, urlKey: string): string | null => {
        if (urlParams.has(urlKey)) return urlParams.get(urlKey);
        try { return localStorage.getItem(lsKey); } catch(e) { return null; }
      };

      try {
        const savedDirection = get("sleep-cycle-direction", "dir");
        const savedTargetWake = get("sleep-cycle-target-wake", "wake");
        const savedTargetSleep = get("sleep-cycle-target-sleep", "sleep");
        const savedLength = get("sleep-cycle-length", "len");
        const savedBuffer = get("sleep-cycle-buffer", "buf");
        const savedAge = get("sleep-cycle-age", "age");
        const savedIndex = get("sleep-cycle-selected-index", "idx");

        if (savedDirection) currentDirection = savedDirection;
        if (savedTargetWake && inputWakeTime) inputWakeTime.value = savedTargetWake;
        if (savedTargetSleep && inputSleepTime) inputSleepTime.value = savedTargetSleep;
        if (savedLength && inputCycleLength) {
          cycleLength = parseInt(savedLength, 10);
          inputCycleLength.value = savedLength;
        }
        if (savedBuffer && inputFallAsleep) {
          fallAsleepBuffer = parseInt(savedBuffer, 10);
          inputFallAsleep.value = savedBuffer;
        }
        if (savedAge && inputAgeGroup) {
          ageGroup = savedAge;
          inputAgeGroup.value = savedAge;
        }
        if (savedIndex) selectedOptionIndex = parseInt(savedIndex, 10);
      } catch (e) {
        console.warn("Failed to load state:", e);
      }
      updateDirectionUI();
      calculate();
    }

    // Save state to localStorage
    function saveState() {
      try {
        localStorage.setItem("sleep-cycle-direction", currentDirection);
        localStorage.setItem("sleep-cycle-target-wake", inputWakeTime.value);
        localStorage.setItem("sleep-cycle-target-sleep", inputSleepTime.value);
        localStorage.setItem("sleep-cycle-length", cycleLength.toString());
        localStorage.setItem("sleep-cycle-buffer", fallAsleepBuffer.toString());
        localStorage.setItem("sleep-cycle-age", ageGroup);
        localStorage.setItem("sleep-cycle-selected-index", selectedOptionIndex.toString());
      } catch (e) {
        console.warn("Failed to save state to localStorage:", e);
      }
    }

    // Toggle Direction panel
    function updateDirectionUI() {
      if (currentDirection === "wake") {
        dirWakeBtn?.classList.add("bg-primary", "text-canvas");
        dirWakeBtn?.classList.remove("text-slate");
        dirSleepBtn?.classList.remove("bg-primary", "text-canvas");
        dirSleepBtn?.classList.add("text-slate");

        targetWakeContainer?.classList.remove("hidden");
        targetSleepContainer?.classList.add("hidden");
      } else {
        dirSleepBtn?.classList.add("bg-primary", "text-canvas");
        dirSleepBtn?.classList.remove("text-slate");
        dirWakeBtn?.classList.remove("bg-primary", "text-canvas");
        dirWakeBtn?.classList.add("text-slate");

        targetSleepContainer?.classList.remove("hidden");
        targetWakeContainer?.classList.add("hidden");
      }
    }

    // Calculate options
    interface SleepOption {
      time: Date;
      cycles: number;
      durationMins: number;
      isRecommended: boolean;
    }

    function calculate() {
      const today = new Date();
      let targetDate = new Date();
      
      if (currentDirection === "wake") {
        targetDate = parseTimeString(inputWakeTime.value);
        if (recommendedIntroLbl) {
          recommendedIntroLbl.textContent = `Suggested Bedtimes (Wake up at ${formatTimeString(targetDate)})`;
        }
        if (resultsHeaderTitle) {
          resultsHeaderTitle.textContent = "Optimal Bedtimes";
        }
      } else {
        targetDate = parseTimeString(inputSleepTime.value);
        if (recommendedIntroLbl) {
          recommendedIntroLbl.textContent = `Suggested Wake-up times (Go to bed at ${formatTimeString(targetDate)})`;
        }
        if (resultsHeaderTitle) {
          resultsHeaderTitle.textContent = "Optimal Wake-up Times";
        }
      }

      const rec = AGE_RECOMMENDATIONS[ageGroup] || AGE_RECOMMENDATIONS.adult;
      const options: SleepOption[] = [];

      // We calculate 3 to 9 sleep cycles
      for (let cycles = 3; cycles <= 9; cycles++) {
        const sleepDurationMins = cycles * cycleLength;
        const totalOffsetMins = sleepDurationMins + fallAsleepBuffer;

        let calculatedTime: Date;
        if (currentDirection === "wake") {
          // Subtract cycle time and fall-asleep buffer to find when to lie down
          calculatedTime = addMinutes(targetDate, -totalOffsetMins);
        } else {
          // Add fall-asleep buffer and cycle time to find when to wake up
          calculatedTime = addMinutes(targetDate, totalOffsetMins);
        }

        const isRecommended = rec.idealCycles.includes(cycles);
        options.push({
          time: calculatedTime,
          cycles,
          durationMins: sleepDurationMins,
          isRecommended
        });
      }

      // If we are looking for bedtimes, we reverse or show them in chronological order
      // For wake directions: we want to show bedtimes that are earliest to latest.
      // E.g., if waking at 7 AM:
      // 9 cycles -> 9:15 PM bedtime
      // 6 cycles -> 9:45 PM bedtime
      // 5 cycles -> 11:15 PM bedtime
      // 4 cycles -> 12:45 AM bedtime
      // 3 cycles -> 2:15 AM bedtime
      // Let's filter or sort them so we display the most relevant ones.
      // We will display cycles 3, 4, 5, 6, 7, 8 (typically 6 options).
      
      // Let's render the list of cards
      if (timesListContainer) {
        timesListContainer.innerHTML = "";
        
        options.forEach((opt, idx) => {
          const card = document.createElement("button");
          card.type = "button";
          
          let recBadge = "";
          let cardStyle = "border-hairline hover:border-brand-blue/30";
          if (opt.isRecommended) {
            recBadge = `<span class="absolute top-1.5 right-2.5 bg-success-accent text-canvas text-[8px] font-bold px-1.5 py-0.5 rounded-full">Recommended</span>`;
          }

          if (idx === selectedOptionIndex) {
            cardStyle = "border-brand-blue bg-surface shadow-[0_0_12px_rgba(66,98,255,0.15)] ring-2 ring-brand-blue/30";
          }

          const hrs = Math.floor(opt.durationMins / 60);
          const mins = opt.durationMins % 60;
          
          card.className = `flex flex-col p-2.5 border rounded-lg text-left transition-all bg-canvas hover:bg-surface cursor-pointer relative ${cardStyle}`;
          card.innerHTML = `
            ${recBadge}
            <span class="block text-sm font-black text-primary font-mono">${formatTimeString(opt.time)}</span>
            <span class="block text-[9px] text-stone mt-0.5 font-semibold">${opt.cycles} Cycles (${hrs}h ${mins}m sleep)</span>
          `;

          card.addEventListener("click", () => {
            selectedOptionIndex = idx;
            saveState();
            calculate(); // refresh with updated selected card highlight
          });
          
          timesListContainer.appendChild(card);
        });
      }

      // Draw timeline for the currently selected option
      const selectedOpt = options[selectedOptionIndex] ?? options[3] ?? options[0];
      updateTimeline(selectedOpt, targetDate);

      // Generate Breakdown
      updateBreakdown(options, selectedOpt, rec, targetDate);
      
      saveState();
    }

    // Update sleep cycle visual representation
    function updateTimeline(opt: SleepOption, targetDate: Date) {
      if (!timelineVisualBar || !timelineStartTime || !timelineEndTime || !timelineDurationLbl) return;

      timelineVisualBar.innerHTML = "";

      let startTime: Date;
      let endTime: Date;

      if (currentDirection === "wake") {
        startTime = opt.time;
        endTime = targetDate;
      } else {
        startTime = targetDate;
        endTime = opt.time;
      }

      timelineStartTime.textContent = formatTimeString(startTime);
      timelineEndTime.textContent = formatTimeString(endTime);

      const totalMins = opt.durationMins + fallAsleepBuffer;
      const hrs = Math.floor(totalMins / 60);
      const mins = totalMins % 60;
      timelineDurationLbl.textContent = `${hrs}h ${mins}m total period`;

      // 1. Fall Asleep Buffer Segment (gray)
      const bufferPct = (fallAsleepBuffer / totalMins) * 100;
      const bufferSeg = document.createElement("div");
      bufferSeg.className = "h-full bg-stone/20 dark:bg-stone/30 flex items-center justify-center text-[7px] font-bold text-stone whitespace-nowrap overflow-hidden px-1 border-r border-hairline-strong/20";
      bufferSeg.style.width = `${bufferPct}%`;
      bufferSeg.title = `Fall Asleep Buffer: ${fallAsleepBuffer} mins`;
      bufferSeg.innerHTML = `<span class="sr-only">Buffer</span>ðŸ’¤`;
      timelineVisualBar.appendChild(bufferSeg);

      // 2. Cycle Segments
      const totalCycles = opt.cycles;
      const cyclePct = ((totalMins - fallAsleepBuffer) / totalCycles / totalMins) * 100;

      for (let c = 1; c <= totalCycles; c++) {
        const cycleSeg = document.createElement("div");
        cycleSeg.className = "h-full flex relative border-r border-hairline-strong/30 last:border-0";
        cycleSeg.style.width = `${cyclePct}%`;
        cycleSeg.title = `Cycle ${c}`;

        // Subdivide cycle into standard stages: Light Sleep (55%), Deep Sleep (20%), REM (25%)
        const lightSeg = document.createElement("div");
        lightSeg.className = "h-full bg-indigo-300/60 dark:bg-indigo-300/35 hover:bg-indigo-300 transition-colors";
        lightSeg.style.width = "55%";
        lightSeg.title = `Cycle ${c} - Light Sleep (~${Math.round(cycleLength * 0.55)} mins)`;
        
        const deepSeg = document.createElement("div");
        deepSeg.className = "h-full bg-indigo-600/60 dark:bg-indigo-600/35 hover:bg-indigo-600 transition-colors";
        deepSeg.style.width = "20%";
        deepSeg.title = `Cycle ${c} - Deep Sleep (~${Math.round(cycleLength * 0.20)} mins)`;

        const remSeg = document.createElement("div");
        remSeg.className = "h-full bg-teal-400/60 dark:bg-teal-400/35 hover:bg-teal-400 transition-colors";
        remSeg.style.width = "25%";
        remSeg.title = `Cycle ${c} - REM Sleep (~${Math.round(cycleLength * 0.25)} mins)`;

        // Cycle text overlay
        const labelText = document.createElement("span");
        labelText.className = "absolute inset-0 flex items-center justify-center text-[8px] font-black text-primary pointer-events-none select-none";
        labelText.textContent = `C${c}`;

        cycleSeg.appendChild(lightSeg);
        cycleSeg.appendChild(deepSeg);
        cycleSeg.appendChild(remSeg);
        cycleSeg.appendChild(labelText);
        
        timelineVisualBar.appendChild(cycleSeg);
      }

      // Update pulse colors based on sleep cycle recommendation
      let statusColor = "bg-success-accent";
      if (opt.cycles < 4) {
        statusColor = "bg-brand-coral";
      } else if (opt.cycles >= 4 && opt.cycles < 5) {
        statusColor = "bg-brand-yellow-deep";
      }

      if (statusPulse && statusDot) {
        statusPulse.className = `animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${statusColor}`;
        statusDot.className = `relative inline-flex rounded-full h-2 w-2 ${statusColor}`;
      }
    }

    // Populate Detailed Breakdown elements
    function updateBreakdown(options: SleepOption[], selectedOpt: SleepOption, rec: AgeRecommendation, targetDate: Date) {
      if (!breakdownChartList || !analysisSummaryPara || !adviceText) return;

      breakdownChartList.innerHTML = "";

      // We render a comparative list showing all options with a bar indicating sleep duration relative to the maximum (9 cycles)
      const maxDuration = 9 * cycleLength;
      
      options.forEach((opt, idx) => {
        const pct = (opt.durationMins / maxDuration) * 100;
        const hrs = Math.floor(opt.durationMins / 60);
        const mins = opt.durationMins % 60;
        
        // Rating calculation
        let ratingStr = "Deprived";
        let ratingColor = "text-brand-coral bg-brand-coral/10";
        if (rec.idealCycles.includes(opt.cycles)) {
          ratingStr = "Optimal";
          ratingColor = "text-success-accent bg-success-accent/10";
        } else if (opt.cycles > Math.max(...rec.idealCycles)) {
          ratingStr = "Excessive";
          ratingColor = "text-brand-blue bg-brand-blue/10";
        } else if (opt.cycles >= Math.min(...rec.idealCycles) - 1) {
          ratingStr = "Sufficient";
          ratingColor = "text-brand-yellow-deep bg-brand-yellow-deep/10";
        }

        const barClass = idx === selectedOptionIndex ? "bg-brand-blue" : "bg-brand-blue/50";
        const textWeight = idx === selectedOptionIndex ? "font-bold text-primary" : "text-slate";

        const row = document.createElement("div");
        row.className = "flex flex-col gap-1";
        row.innerHTML = `
          <div class="flex justify-between items-center text-[10px] ${textWeight}">
            <span class="flex items-center gap-1">
              <strong>${opt.cycles} Cycles</strong> (${hrs}h ${mins}m)
            </span>
            <span class="px-2 py-0.5 rounded text-[8px] font-extrabold uppercase ${ratingColor}">${ratingStr}</span>
          </div>
          <div class="w-full h-2 bg-hairline rounded-full overflow-hidden">
            <div class="h-full ${barClass} transition-all duration-500" style="width: ${pct}%;"></div>
          </div>
        `;
        breakdownChartList.appendChild(row);
      });

      // Populate Written Analysis Paragraph
      const selectedHrs = Math.floor(selectedOpt.durationMins / 60);
      const selectedMins = selectedOpt.durationMins % 60;
      
      let analysisText = "";
      if (selectedOpt.cycles >= 5 && selectedOpt.cycles <= 6) {
        analysisText = `Selecting <strong>${selectedOpt.cycles} cycles</strong> (${selectedHrs}h ${selectedMins}m of sleep) aligns perfectly with the recommended sleep range for an average <strong>${rec.label}</strong>. This duration allows your body to complete healthy cycles of deep slow-wave physical recovery and REM cognitive consolidation. You are likely to wake up feeling refreshed.`;
      } else if (selectedOpt.cycles >= 7) {
        analysisText = `A sleep period of <strong>${selectedOpt.cycles} cycles</strong> (${selectedHrs}h ${selectedMins}m) provides an extended rest. This is highly suitable for recovery after high cognitive or physical stress, or for younger age demographics. Be mindful that oversleeping past 9 cycles can sometimes cause grogginess due to prolonged light sleep states.`;
      } else {
        analysisText = `Sleeping for <strong>${selectedOpt.cycles} cycles</strong> (${selectedHrs}h ${selectedMins}m) is below the recommended daily sleep baseline of 7 hours. While waking at the end of this cycle minimizes sleep inertia, a recurring short sleep duration will build up a "sleep debt," impacting immune function, cardiovascular health, and mental focus.`;
      }

      analysisSummaryPara.innerHTML = `
        <p class="mb-2">${analysisText}</p>
        <p><strong>Circadian Rhythm Recommendation:</strong> Waking up at <strong>${formatTimeString(selectedOpt.time)}</strong> (or bedtime at this time) is ideal. Be sure to turn off glowing screens 30-60 minutes prior, maintain a cool, dark room, and limit caffeine intake in the afternoon to optimize your natural melatonin production.</p>
      `;

      // Update advice box text
      const directionWord = currentDirection === "wake" ? "go to sleep" : "wake up";
      const targetTimeWord = currentDirection === "wake" ? "wake up" : "go to bed";
      
      adviceText.innerHTML = `To ${targetTimeWord} at <strong>${formatTimeString(targetDate)}</strong>, you should aim to ${directionWord} at <strong>${formatTimeString(selectedOpt.time)}</strong>. This allocates exactly <strong>${selectedOpt.cycles} full sleep cycles</strong> (${selectedHrs}h ${selectedMins}m) plus a <strong>${fallAsleepBuffer}-minute buffer</strong>.`;
    }

    // Tab Switch Listener
    dirWakeBtn?.addEventListener("click", () => {
      currentDirection = "wake";
      selectedOptionIndex = 3; // Reset to default 6 cycles card
      updateDirectionUI();
      calculate();
    });

    dirSleepBtn?.addEventListener("click", () => {
      currentDirection = "sleep";
      selectedOptionIndex = 3; // Reset to default 6 cycles card
      updateDirectionUI();
      calculate();
    });

    // Time input change listeners
    inputWakeTime?.addEventListener("input", calculate);
    inputSleepTime?.addEventListener("input", calculate);

    // Sleep Now shortcut
    btnSleepNow?.addEventListener("click", () => {
      const now = new Date();
      const hrs = String(now.getHours()).padStart(2, '0');
      const mins = String(now.getMinutes()).padStart(2, '0');
      inputSleepTime.value = `${hrs}:${mins}`;
      calculate();
    });

    // Advanced options toggle
    advancedToggleBtn?.addEventListener("click", () => {
      if (advancedPanel) {
        const isCollapsed = advancedPanel.classList.contains("max-h-0");
        if (isCollapsed) {
          advancedPanel.classList.remove("max-h-0", "overflow-hidden");
          advancedPanel.classList.add("max-h-[500px]", "overflow-visible");
          advancedChevron?.classList.add("rotate-180");
        } else {
          advancedPanel.classList.remove("max-h-[500px]", "overflow-visible");
          advancedPanel.classList.add("max-h-0", "overflow-hidden");
          advancedChevron?.classList.remove("rotate-180");
        }
      }
    });

    // Advanced input listeners
    inputCycleLength?.addEventListener("input", () => {
      const val = parseInt(inputCycleLength.value, 10);
      if (!isNaN(val)) {
        cycleLength = Math.max(70, Math.min(110, val));
        calculate();
      }
    });

    inputCycleLength?.addEventListener("blur", () => {
      inputCycleLength.value = cycleLength.toString();
    });

    inputFallAsleep?.addEventListener("input", () => {
      const val = parseInt(inputFallAsleep.value, 10);
      if (!isNaN(val)) {
        fallAsleepBuffer = Math.max(0, Math.min(60, val));
        calculate();
      }
    });

    inputFallAsleep?.addEventListener("blur", () => {
      inputFallAsleep.value = fallAsleepBuffer.toString();
    });

    inputAgeGroup?.addEventListener("change", () => {
      ageGroup = inputAgeGroup.value;
      calculate();
    });

    // View result smooth scrolls
    advancedViewResultBtn?.addEventListener("click", () => {
      scrollToElementWithOffset("results-card", 80);
    });

    // Detailed Breakdown toggle
    toggleBreakdownBtn?.addEventListener("click", () => {
      if (breakdownSection) {
        const isCollapsed = breakdownSection.classList.contains("max-h-0");
        if (isCollapsed) {
          breakdownSection.classList.remove("max-h-0");
          breakdownSection.classList.add("max-h-[2000px]");
          setTimeout(() => {
            scrollToElementWithOffset("breakdown-section", 60);
          }, 100);
        } else {
          breakdownSection.classList.remove("max-h-[2000px]");
          breakdownSection.classList.add("max-h-0");
        }
      }
    });

    // Export PDF Print event
    exportPdfBtn?.addEventListener("click", () => {
      if (breakdownSection && breakdownSection.classList.contains("max-h-0")) {
        breakdownSection.classList.remove("max-h-0");
        breakdownSection.classList.add("max-h-[2000px]");
      }
      window.print();
    });

    // Reset button listener
    resetBtn?.addEventListener("click", () => {
      if (window.history.pushState) {
        const newurl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.pushState({ path: newurl }, "", newurl);
      }

      const keys = [
        "sleep-cycle-direction",
        "sleep-cycle-target-wake",
        "sleep-cycle-target-sleep",
        "sleep-cycle-length",
        "sleep-cycle-buffer",
        "sleep-cycle-age",
        "sleep-cycle-selected-index"
      ];
      keys.forEach(k => localStorage.removeItem(k));

      currentDirection = "wake";
      cycleLength = 90;
      fallAsleepBuffer = 15;
      ageGroup = "adult";
      selectedOptionIndex = 3;

      if (inputWakeTime) inputWakeTime.value = "07:00";
      if (inputSleepTime) inputSleepTime.value = "22:00";
      if (inputCycleLength) inputCycleLength.value = "90";
      if (inputFallAsleep) inputFallAsleep.value = "15";
      if (inputAgeGroup) inputAgeGroup.value = "adult";

      updateDirectionUI();
      calculate();

      if (advancedPanel) {
        advancedPanel.classList.remove("max-h-[500px]", "overflow-visible");
        advancedPanel.classList.add("max-h-0", "overflow-hidden");
      }
      advancedChevron?.classList.remove("rotate-180");
      if (breakdownSection) {
        breakdownSection.classList.remove("max-h-[2000px]");
        breakdownSection.classList.add("max-h-0");
      }
    });

    // FAQ Accordion Toggle Interaction
    const faqToggleButtons = document.querySelectorAll(".faq-toggle-btn");
    faqToggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        // Close other open accordions
        faqToggleButtons.forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute("aria-expanded", "false");
            const otherContent = otherBtn.nextElementSibling;
            if (otherContent) otherContent.classList.add("hidden");
            otherBtn.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        // Toggle current accordion
        btn.setAttribute("aria-expanded", !expanded ? "true" : "false");
        const content = btn.nextElementSibling;
        if (content) {
          content.classList.toggle("hidden");
        }
        btn.querySelector("svg")?.classList.toggle("rotate-180");
      });
    });

    // Load initial state
    loadState();
  </script>
</Layout>

<style>
  /* Premium print overrides for PDF exports */
  @media print {
    body * {
      visibility: hidden;
    }
    #breakdown-section, #breakdown-section * {
      visibility: visible;
    }
    #breakdown-section {
      position: absolute;
      left: 0;
