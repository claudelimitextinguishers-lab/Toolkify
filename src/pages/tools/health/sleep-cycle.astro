---
import Layout from '../../../layouts/Layout.astro';
import RelatedTools from '../../../components/RelatedTools.astro';

// Tool metadata
const name = "Sleep Cycle Calculator";
const category = "health";
const tier = "Health & Fitness";

// On-page SEO metadata
const pageTitle =
  "Sleep Cycle Calculator - 90 Minute Sleep Calculator by Age";
const description =
  "Free 90 minute sleep cycle calculator to find the best time to sleep or wake up. Online sleep calculator by age that times bedtime and wake-up to full sleep cycles.";
const canonicalUrl = "https://toolkify.com/tools/health/sleep-cycle";
const ogImage = "/og/sleep-cycle.png";
const keywords =
  "sleep cycle calculator, 90 minute sleep cycle calculator, sleep cycle calculator age, 90 minutes sleep cycle calculator, 90-minute sleep cycle calculator, sleep cycle calculator online, sleep cycle calculator app, sleep calculator, sleep calculator by age, hours of sleep calculator, sleep calculator app, 90 minute sleep cycle";
---

<Layout 
  title={pageTitle}
  description={description}
  toolName={name}
  toolCategory={category}
  keywords={keywords}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="website"
  hideBanner={true}
>
  <!-- SEO JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Sleep Cycle Calculator",
      "alternateName": "90 Minute Sleep Cycle Calculator by Age",
      "url": "https://toolkify.com/tools/health/sleep-cycle",
      "description": "Free online 90 minute sleep cycle calculator that finds the best time to go to sleep or wake up. This sleep calculator by age times your bedtime and wake-up to complete 90-minute sleep cycles, helping you avoid grogginess and wake up refreshed.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "featureList": [
        "90 minute sleep cycle calculator for bedtime and wake-up times",
        "Sleep calculator by age for adults, teens, children, and toddlers",
        "Hours of sleep calculator showing full sleep cycles and total rest",
        "Customizable sleep cycle length and fall-asleep buffer",
        "Visual sleep cycle timeline with light, deep, and REM stages",
        "Works as an online sleep cycle calculator app on mobile and desktop",
        "100% private, client-side calculations"
      ],
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    }
  </script>

  <!-- Breadcrumb JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://toolkify.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Health",
          "item": "https://toolkify.com/tools/health/sleep-cycle"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Sleep Cycle Calculator",
          "item": "https://toolkify.com/tools/health/sleep-cycle"
        }
      ]
    }
  </script>

  <!-- FAQ JSON-LD Schema -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How long is one sleep cycle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>For most healthy adults, one sleep cycle lasts approximately 90 minutes. However, individual cycle lengths can range from 70 to 110 minutes, varying naturally between individuals and changing slightly throughout the night.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How long is a full sleep cycle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A full sleep cycle typically lasts between 90 and 110 minutes. It starts with light sleep, transitions into deep slow-wave sleep, and ends with Rapid Eye Movement (REM) sleep before the cycle repeats.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How long is each sleep cycle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>Each sleep cycle is about 90 minutes long on average. In the early part of the night, cycles contain more deep NREM sleep, while later cycles toward morning have longer REM (dreaming) sleep periods.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What is a sleep cycle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A sleep cycle is a continuous progression through the four stages of sleep: Stage N1 (light transition), Stage N2 (light sleep), Stage N3 (deep slow-wave sleep), and REM sleep (rapid eye movement/dreaming). An average night consists of 4 to 6 of these cycles.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How long does a sleep cycle last?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A sleep cycle typically lasts between 90 and 110 minutes. The duration is influenced by factors such as age, sleep history, genetics, and whether you have consumed alcohol, caffeine, or certain medications before bed.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What does a normal sleep cycle look like?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>A normal sleep cycle begins with NREM Stage 1 (very light sleep), moves into NREM Stage 2 (deeper light sleep with sleep spindles), advances into NREM Stage 3 (restorative deep sleep), returns to Stage 2 briefly, and then enters REM sleep (active brain dreaming stage) before starting over.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "What part of the brain controls sleep-wake cycle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The sleep-wake cycle is primarily controlled by the <strong>hypothalamus</strong>, specifically the suprachiasmatic nucleus (SCN). The SCN acts as the body's master pacemaker, receiving light cues from the eyes to regulate melatonin production by the pineal gland.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How long is a rem sleep cycle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>The REM stage within each sleep cycle changes in length throughout the night. The first REM period of the night may last only 10 minutes, whereas later REM periods in the final cycles of sleep can last up to an hour.</p>"
          }
        },
        {
          "@type": "Question",
          "name": "How to fix your sleep cycle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<p>To fix your sleep cycle, establish a consistent wake-up and bedtime schedule (even on weekends), expose yourself to bright sunlight first thing in the morning, avoid blue light and screens for 1-2 hours before bed, keep your bedroom cool and dark, and avoid heavy meals, caffeine, and alcohol close to bedtime.</p>"
          }
        }
      ]
    }
  </script>

  <section class="max-w-[1000px] w-full mx-auto px-4 py-3 sm:py-6 flex flex-col gap-3 sm:gap-4 animate-fade-in-up pb-16 print:p-0">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-1 print:hidden">
      <nav class="flex items-center gap-1.5 text-[10px] font-semibold text-slate uppercase" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/" class="hover:text-primary transition-colors">Tools</a>
        <span>/</span>
        <span class="text-brand-blue capitalize">{category}</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between mt-0.5 gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="font-display font-medium text-xl sm:text-2xl tracking-tight text-primary">
            {name}
          </h1>
          <span class="bg-surface-pricing-featured text-brand-blue text-[10px] py-0.5 px-2 rounded-full font-semibold uppercase whitespace-nowrap shrink-0">{tier}</span>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button
            type="button"
            id="share-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Share tool link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.028-2.513m0 7.544l-5.028-2.513M18 8a3 3 0 11-6 0 3 3 0 016 0zm-6 8a3 3 0 11-6 0 3 3 0 016 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Share</span>
          </button>

          <button
            type="button"
            id="how-it-works-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="How sleep cycle calculator works"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>How it works</span>
          </button>

          <button
            type="button"
            id="reset-btn"
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-brand-coral hover:border-brand-coral rounded-full transition-all cursor-pointer shadow-subtle"
            aria-label="Reset calculator inputs"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12"></path>
            </svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Workspace Container (Zero-Scroll Compact Layout) -->
    <div class="card-base p-4 sm:p-5 flex flex-col gap-4 print:border-none print:shadow-none print:bg-transparent print:p-0">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-stretch">
        
        <!-- Left Pane: Inputs -->
        <div class="flex flex-col justify-between gap-3 print:hidden">
          <div class="flex flex-col gap-3">
            <!-- Calculation Direction Tab Switcher -->
            <div class="flex flex-col gap-1">
              <label class="text-[11px] font-semibold text-charcoal">I want to...</label>
              <div class="flex rounded-full bg-surface p-0.5 border border-hairline self-start w-full">
                <button
                  type="button"
                  id="dir-wake-btn"
                  class="flex-1 text-[11px] py-1.5 px-2 rounded-full font-bold transition-all cursor-pointer bg-primary text-canvas text-center sm:whitespace-nowrap"
                >
                  <span class="block sm:hidden">Wake Up Time</span>
                  <span class="hidden sm:block">Wake up at a specific time</span>
                </button>
                <button
                  type="button"
                  id="dir-sleep-btn"
                  class="flex-1 text-[11px] py-1.5 px-2 rounded-full font-bold transition-all cursor-pointer text-slate text-center sm:whitespace-nowrap"
                >
                  <span class="block sm:hidden">Bedtime</span>
                  <span class="hidden sm:block">Go to sleep now / chosen time</span>
                </button>
              </div>
            </div>

            <!-- Target Time Input Selection -->
            <div class="flex flex-col gap-2">
              <div id="target-wake-container" class="flex flex-col gap-1">
                <label for="input-wake-time" class="text-[11px] font-semibold text-charcoal">What time do you need to wake up?</label>
                <input
                  type="time"
                  id="input-wake-time"
                  value="07:00"
                  class="text-input py-1 text-xs font-mono h-8 w-full cursor-text bg-canvas"
                />
              </div>

              <div id="target-sleep-container" class="flex flex-col gap-2 hidden">
                <label for="input-sleep-time" class="text-[11px] font-semibold text-charcoal">When are you going to bed?</label>
                <div class="flex gap-2">
                  <input
                    type="time"
                    id="input-sleep-time"
                    value="22:00"
                    class="text-input py-1 text-xs font-mono h-8 flex-1 cursor-text bg-canvas"
                  />
                  <button
                    type="button"
                    id="btn-sleep-now"
                    class="inline-flex items-center justify-center text-[10px] font-bold px-3 py-1 bg-surface-pricing-featured border border-brand-blue/30 text-brand-blue hover:bg-brand-blue hover:text-canvas rounded-lg transition-all cursor-pointer whitespace-nowrap shrink-0"
                  >
                    â° Sleep Now
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Advanced Options drawer -->
          <div class="border-t border-hairline-soft pt-2 mt-1">
            <button
              type="button"
              id="advanced-toggle-btn"
              class="w-full flex items-center justify-between text-[11px] font-bold text-slate hover:text-primary transition-all cursor-pointer py-1"
            >
              <span class="flex items-center gap-1">
                âš™ Advanced Sleep Settings
              </span>
              <svg
                id="advanced-chevron"
                xmlns="http://www.w3.org/2000/svg"
                class="w-3.5 h-3.5 text-stone transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="advanced-panel" class="max-h-0 overflow-hidden transition-all duration-300 flex flex-col gap-3 mt-1.5">
              <div class="grid grid-cols-2 gap-3 pt-2 border-t border-hairline-soft/50">
                <!-- Custom Cycle Length -->
                <div class="flex flex-col gap-1">
                  <label for="input-cycle-length" class="text-[10px] font-semibold text-slate">Sleep Cycle Length</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="input-cycle-length"
                      min="70"
                      max="110"
                      value="90"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">mins</span>
                  </div>
                  <span class="text-[8px] text-stone leading-tight">Average adult cycle is ~90 minutes.</span>
                </div>

                <!-- Custom fall-asleep buffer -->
                <div class="flex flex-col gap-1">
                  <label for="input-fall-asleep" class="text-[10px] font-semibold text-slate">Fall-Asleep Buffer</label>
                  <div class="relative">
                    <input
                      type="number"
                      id="input-fall-asleep"
                      min="0"
                      max="60"
                      value="15"
                      class="text-input py-1 text-xs font-mono h-8"
                      inputmode="numeric"
                    />
                    <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone text-[10px]">mins</span>
                  </div>
                  <span class="text-[8px] text-stone leading-tight">Time needed to drift to sleep.</span>
                </div>
              </div>

              <!-- Age based sleep guidance drop-down -->
              <div class="flex flex-col gap-1">
                <label for="input-age-group" class="text-[10px] font-semibold text-slate">Age Group Recommended Sleep</label>
                <select
                  id="input-age-group"
                  class="text-input py-1 text-xs h-8 cursor-pointer border border-hairline-strong bg-canvas"
                >
                  <option value="adult" selected>Adult (18-64 yrs) â€” 7 to 9 hours</option>
                  <option value="older-adult">Older Adult (65+ yrs) â€” 7 to 8 hours</option>
                  <option value="teen">Teenager (13-17 yrs) â€” 8 to 10 hours</option>
                  <option value="child">School Child (6-12 yrs) â€” 9 to 11 hours</option>
                  <option value="toddler">Toddler (1-5 yrs) â€” 10 to 14 hours</option>
                </select>
              </div>

              <div class="flex items-center justify-end mt-1">
                <button
                  type="button"
                  id="advanced-view-result-btn"
                  class="inline-flex items-center gap-1 text-[10px] font-semibold px-3 py-1 bg-primary hover:bg-charcoal text-canvas rounded-full transition-all cursor-pointer shadow-subtle"
                >
                  View Result &darr;
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Pane: Main Output Dashboard -->
        <div id="results-card" class="card-feature-teal flex flex-col justify-between p-4 sm:p-5 relative overflow-hidden rounded-xl border border-moss-dark/10 print:border-none print:shadow-none print:p-0">
          <div class="absolute top-0 right-0 w-32 h-32 bg-teal-light/25 rounded-full blur-2xl pointer-events-none print:hidden"></div>
          
          <div class="flex flex-col gap-3.5 z-10 w-full">
            <!-- Results Header -->
            <div class="flex items-center justify-between border-b border-moss-dark/10 pb-2">
              <span class="text-[10px] uppercase font-extrabold text-moss-dark/70 tracking-widest" id="results-header-title">Optimal Sleep Intervals</span>
              <span class="flex h-2 w-2 relative print:hidden">
                <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success-accent opacity-75"></span>
                <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-success-accent"></span>
              </span>
            </div>

            <!-- List of Recommended Times -->
            <div class="flex flex-col gap-2">
              <span class="text-[10px] uppercase font-bold text-slate block" id="recommended-intro-lbl">Suggested bedtimes (Wake up at 7:00 AM)</span>
              
              <div id="times-list-container" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                <!-- Injected dynamically via JS: cards representing each recommendation -->
              </div>
            </div>

            <!-- Sleep Cycle Night Timeline Visualizer -->
            <div class="flex flex-col gap-1.5 border-t border-moss-dark/10 pt-3">
              <div class="flex justify-between items-center text-[9px] uppercase font-bold text-slate">
                <span>Visual Sleep Cycles Timeline (Selected Target)</span>
                <span id="timeline-duration-lbl" class="font-mono text-stone font-semibold">-</span>
              </div>
              <div class="w-full h-6 bg-canvas/60 dark:bg-canvas/10 backdrop-blur-md rounded-lg overflow-hidden flex relative border border-hairline" id="timeline-visual-bar">
                <!-- Segment elements injected via Javascript -->
              </div>
              <div class="flex justify-between text-[8px] font-bold text-stone px-0.5">
                <span id="timeline-start-time">-</span>
                <span id="timeline-end-time">-</span>
              </div>
            </div>

            <!-- Support Advice / Short Explanation Box -->
            <div id="advice-box" class="text-[11px] text-moss-dark leading-relaxed pt-2 border-t border-moss-dark/5">
              <p id="advice-text">
                Enter your target wake-up time on the left. The calculator recommends sleeping schedules aligned to standard 90-minute circadian periods, avoiding groggy mid-cycle wakeups.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Button directly beneath input workspace -->
      <div class="flex justify-center pt-2 print:hidden">
        <button
          type="button"
          id="toggle-breakdown-btn"
          class="button-primary text-xs py-2 px-6 !rounded-full shadow-subtle hover:scale-105 active:scale-95 transition-all cursor-pointer flex items-center gap-1.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <span>View Detailed Breakdown & Analysis</span>
        </button>
      </div>
    </div>

    <!-- Detailed Breakdown & Analysis Section (Same Page) -->
    <div id="breakdown-section" class="max-h-0 overflow-hidden transition-all duration-500 flex flex-col gap-4 print:max-h-none print:overflow-visible">
      <div class="card-base p-4 sm:p-5 flex flex-col gap-4 mt-2 print:border-none print:shadow-none print:p-0">
        <div class="flex items-center justify-between border-b border-hairline pb-2">
          <h2 class="font-display font-semibold text-sm sm:text-base text-primary flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 3.055A9.003 9.003 0 1020.945 13H11V3.055z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
            </svg>
            Personalized Circadian Cycle Breakdown
          </h2>
          <button
            type="button"
            id="export-pdf-btn"
            class="inline-flex items-center gap-1 text-[10px] font-semibold px-2.5 py-1 bg-canvas hover:bg-surface border border-hairline text-slate hover:text-primary rounded-full transition-all cursor-pointer shadow-subtle print:hidden"
            aria-label="Export report to PDF"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span>Export Report</span>
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Cycles Duration Comparison Chart -->
          <div class="border border-hairline rounded-xl p-3 bg-surface-soft flex flex-col gap-2 print:border-none print:bg-transparent">
            <span class="text-[10px] uppercase font-bold text-slate">Sleep Duration & Efficiency Comparison</span>
            <div class="flex flex-col gap-2.5 pt-1.5" id="breakdown-chart-list">
              <!-- Dynamically populated comparative list of sleep cycle counts -->
            </div>
          </div>

          <!-- Sleep Stages & Quality Breakdown -->
          <div class="border border-hairline rounded-xl p-3 bg-surface-soft flex flex-col gap-2 print:border-none print:bg-transparent">
            <span class="text-[10px] uppercase font-bold text-slate">Stages of a Single Sleep Cycle (~90m)</span>
            <div class="flex flex-col gap-2 text-[10px] font-medium text-charcoal">
              <div class="flex justify-between py-1 border-b border-hairline-soft/50">
                <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded bg-indigo-300"></span>Light Sleep (N1 + N2)</span>
                <span class="font-bold font-mono">~55% (~50 mins)</span>
              </div>
              <div class="flex justify-between py-1 border-b border-hairline-soft/50">
                <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded bg-indigo-600"></span>Deep Sleep (N3)</span>
                <span class="font-bold font-mono">~20% (~18 mins)</span>
              </div>
              <div class="flex justify-between py-1 border-b border-hairline-soft/50">
                <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded bg-teal-400"></span>REM Sleep (Dreaming)</span>
                <span class="font-bold font-mono">~25% (~22 mins)</span>
              </div>
              <p class="text-[9px] leading-relaxed text-stone pt-1">
                Note: Cycle stages fluctuate dynamically across the night. Deep sleep is dominant in earlier cycles, whereas REM periods expand during later cycles closer to waking.
              </p>
            </div>
          </div>
        </div>

        <!-- Scientific Analysis Commentary Box -->
        <div id="scientific-analysis-box" class="text-[11px] text-slate leading-relaxed border-t border-hairline pt-3 mt-1 flex flex-col gap-2">
          <p id="analysis-summary-para">
            Loading sleep cycle analysis based on your target schedules...
          </p>
        </div>
