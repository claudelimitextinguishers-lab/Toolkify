      >
        <div
          class="w-10 h-10 rounded-full bg-surface-pricing-featured border border-hairline text-brand-blue flex items-center justify-center font-bold text-sm select-none"
        >
          💾
        </div>
        <div class="flex flex-col">
          <span class="text-xs font-semibold text-primary"
