---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="bg-canvas border-b border-hairline py-16 md:py-24 px-4">
    <div class="max-w-[800px] mx-auto text-center flex flex-col items-center gap-6">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface-yellow border border-yellow-light text-yellow-dark rounded-full text-xs font-semibold">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-yellow-deep animate-ping"></span>
        Zero Server Overhead &bull; 100% Private Sandbox
      </div>
      
      <h1 class="font-display font-medium text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.1] text-primary">
        See how teams get great done, <span class="bg-brand-yellow px-1 rounded-sm">tool by tool.</span>
      </h1>
      
      <p class="font-display text-base md:text-lg text-slate max-w-xl leading-relaxed">
        An interactive, private-by-design utility sandbox for developers and designers. Drag sticky notes, format code, and optimize graphics in seconds.
      </p>

      <!-- Instant Filter / Search Pill -->
      <div class="w-full max-w-lg mt-4">
        <div class="relative flex items-center">
          <input 
            type="text" 
            id="tool-search" 
            placeholder="Search tools (e.g. JSON, Whiteboard, UUID...)" 
            class="text-input w-full pr-12 focus:border-brand-blue"
          />
          <div class="absolute right-4 text-stone pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Pill Tabs for Category Filter -->
      <div class="flex flex-wrap justify-center gap-2.5 mt-2" id="filter-tabs-container">
        <button class="pill-tab pill-tab-active" data-category="all">All Tools</button>
        <button class="pill-tab" data-category="collaboration">Collaboration</button>
        <button class="pill-tab" data-category="developer">Developer</button>
        <button class="pill-tab" data-category="design">Design</button>
      </div>
    </div>
  </section>

  <!-- Featured Workspace Section -->
  <section class="bg-surface py-16 px-4">
    <div class="max-w-[1280px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Description -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="badge-tag-yellow self-start">FEATURED WORKSPACE</div>
        <h2 class="font-display font-medium text-3xl md:text-4xl text-primary tracking-tight leading-tight">
          Visual Board: Collaborative Mockups & Wireframes
        </h2>
        <p class="text-sm md:text-base text-slate leading-relaxed">
          Create sticky notes, sketch vectors, draw flows, and lay out designs on a zoomable, infinitely flexible board. Runs fully offline and exports to PNG locally.
        </p>
        <div class="flex flex-col gap-3 text-sm text-slate">
          <div class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Pastel Sticky notes with full-text editing</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Freehand sketching, lines, and boxes</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-success-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Instant local download of boards</span>
          </div>
        </div>
        <a href="/tools/whiteboard" class="button-primary self-start mt-2">
          Open Whiteboard &rarr;
        </a>
      </div>

      <!-- Preview Card -->
      <div class="lg:col-span-7">
        <div class="whiteboard-mockup overflow-hidden aspect-[16/10] flex flex-col relative group">
          <!-- Canvas Top Menu -->
          <div class="h-10 border-b border-hairline bg-surface/50 flex items-center px-4 justify-between select-none">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-brand-red"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-brand-yellow"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-success-accent"></span>
            </div>
            <span class="text-xs text-stone font-medium">BoardTools Visual Canvas (Demo)</span>
          </div>
          <!-- Canvas Grid Mockup -->
          <div class="flex-grow bg-canvas dot-grid relative overflow-hidden flex items-center justify-center p-8 select-none">
            <!-- Draw mockup notes and lines -->
            <div class="absolute top-[20%] left-[15%] w-24 h-24 bg-brand-yellow shadow-card rounded-sm rotate-[-3deg] p-2 flex flex-col justify-between font-display text-[10px] text-primary">
              <span class="font-medium">Define MVP</span>
              <span class="text-stone text-[8px] self-end">#yellow</span>
            </div>
            <div class="absolute top-[40%] right-[20%] w-24 h-24 bg-brand-teal text-primary shadow-card rounded-sm rotate-[5deg] p-2 flex flex-col justify-between font-display text-[10px]">
              <span class="font-medium">Design System!</span>
              <span class="text-moss-dark text-[8px] self-end">#teal</span>
            </div>
            <div class="absolute bottom-[20%] left-[30%] w-24 h-24 bg-brand-rose shadow-card rounded-sm rotate-[-1deg] p-2 flex flex-col justify-between font-display text-[10px] text-primary">
              <span class="font-medium">SEO Audit</span>
              <span class="text-stone text-[8px] self-end">#rose</span>
            </div>
            
            <svg class="absolute w-full h-full pointer-events-none stroke-brand-blue" fill="none" stroke-width="2">
              <path d="M 180 140 Q 250 180 320 180" stroke-dasharray="4" />
              <path d="M 380 200 L 420 220" />
            </svg>
            
            <!-- Floating prompt -->
            <div class="absolute bottom-4 right-4 bg-primary text-canvas px-3 py-1.5 rounded-full text-xs font-medium shadow-modal flex items-center gap-1.5 group-hover:scale-105 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-yellow" viewBox="0 0 20 20" fill="currentColor"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" /></svg>
              Double click anywhere to draw
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Directory Section -->
  <section class="bg-canvas py-16 px-4 border-b border-hairline">
    <div class="max-w-[1280px] mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-baseline gap-4 mb-10">
        <div>
          <span class="text-xs font-semibold text-brand-blue uppercase tracking-wider">All Sandbox Tools</span>
          <h2 class="font-display font-medium text-3xl text-primary tracking-tight mt-1">Select a Workspace</h2>
        </div>
        <p class="text-sm text-slate max-w-md">
          Format input strings, run accessibility color contrast audits, compile SVG code, and draw. Instant results.
        </p>
      </div>

      <!-- Tool Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="tools-grid">
        <!-- Whiteboard Card -->
        <div class="tool-card card-feature-yellow flex flex-col justify-between gap-8 group cursor-pointer" data-category="collaboration" data-title="Whiteboard Sketchpad Canvas Sticky Notes">
          <div class="flex flex-col gap-3">
            <span class="badge-tag-yellow bg-yellow-light text-yellow-dark self-start">COLLABORATION</span>
            <h3 class="font-display font-medium text-2xl text-primary tracking-tight">Visual Whiteboard</h3>
            <p class="text-sm text-yellow-dark/90 leading-relaxed">
              Draggable sticky notes, drawing boards, and flow diagram layout workspace. Custom colors and download.
            </p>
          </div>
          <a href="/tools/whiteboard" class="font-display font-medium text-sm text-primary flex items-center gap-1 group-hover:translate-x-1.5 transition-transform">
            Launch Canvas &rarr;
          </a>
        </div>

        <!-- JSON Formatter Card -->
        <div class="tool-card card-feature-teal flex flex-col justify-between gap-8 group cursor-pointer" data-category="developer" data-title="JSON Formatter Validator Parser Format Minify Beautify">
          <div class="flex flex-col gap-3">
            <span class="badge-tag-purple bg-teal-light text-moss-dark self-start">DEVELOPER</span>
            <h3 class="font-display font-medium text-2xl text-primary tracking-tight">JSON Formatter</h3>
            <p class="text-sm text-moss-dark/90 leading-relaxed">
              Format, validate, beautify, and compress JSON files instantly. Highlights syntax errors, matching brackets, and paths.
            </p>
          </div>
          <a href="/tools/json-formatter" class="font-display font-medium text-sm text-primary flex items-center gap-1 group-hover:translate-x-1.5 transition-transform">
            Beautify JSON &rarr;
          </a>
        </div>

        <!-- Base64 Card -->
        <div class="tool-card card-feature-coral flex flex-col justify-between gap-8 group cursor-pointer" data-category="developer" data-title="Base64 URL Encoder Decoder Converter text">
          <div class="flex flex-col gap-3">
            <span class="badge-tag-coral bg-coral-light text-coral-dark self-start">DEVELOPER</span>
            <h3 class="font-display font-medium text-2xl text-primary tracking-tight">Base64 & URL Tool</h3>
            <p class="text-sm text-coral-dark/90 leading-relaxed">
              Quickly encode and decode strings to and from Base64 or standard URL format. Side-by-side verification panels.
            </p>
          </div>
          <a href="/tools/base64-url" class="font-display font-medium text-sm text-primary flex items-center gap-1 group-hover:translate-x-1.5 transition-transform">
            Convert String &rarr;
          </a>
        </div>

        <!-- UUID & Hash Card -->
        <div class="tool-card card-feature-rose flex flex-col justify-between gap-8 group cursor-pointer" data-category="developer" data-title="UUID Hash Generator MD5 SHA-1 SHA-256 Bulk ID text">
          <div class="flex flex-col gap-3">
            <span class="badge-tag-purple bg-rose-light text-primary self-start">DEVELOPER</span>
            <h3 class="font-display font-medium text-2xl text-primary tracking-tight">UUID & Hash Gen</h3>
            <p class="text-sm text-slate leading-relaxed font-normal">
              Bulk generate secure UUID v4 tokens or hash target input strings using MD5, SHA-1, or SHA-256 engines locally.
            </p>
          </div>
          <a href="/tools/uuid-hash" class="font-display font-medium text-sm text-primary flex items-center gap-1 group-hover:translate-x-1.5 transition-transform">
            Generate IDs &rarr;
          </a>
        </div>

        <!-- Contrast Checker Card -->
        <div class="tool-card card-feature-teal flex flex-col justify-between gap-8 group cursor-pointer" data-category="design" data-title="Contrast Checker WCAG Accessibility color palette AA AAA">
          <div class="flex flex-col gap-3">
            <span class="badge-tag-yellow bg-teal-light text-moss-dark self-start">DESIGN</span>
            <h3 class="font-display font-medium text-2xl text-primary tracking-tight">Contrast Checker</h3>
            <p class="text-sm text-moss-dark/90 leading-relaxed">
              Verify color contrast ratios of text overlay backgrounds. Test against standard WCAG 2.1 AA/AAA accessibility checks.
            </p>
          </div>
          <a href="/tools/contrast-checker" class="font-display font-medium text-sm text-primary flex items-center gap-1 group-hover:translate-x-1.5 transition-transform">
            Check Contrast &rarr;
          </a>
        </div>

        <!-- SVG Previewer Card -->
        <div class="tool-card card-feature-coral flex flex-col justify-between gap-8 group cursor-pointer" data-category="design" data-title="SVG Optimizer Previewer Editor XML scale sanitization">
          <div class="flex flex-col gap-3">
            <span class="badge-tag-coral bg-coral-light text-coral-dark self-start">DESIGN</span>
            <h3 class="font-display font-medium text-2xl text-primary tracking-tight">SVG Optimizer</h3>
            <p class="text-sm text-coral-dark/90 leading-relaxed">
              Preview vector graphics in real time, sanitize inline CSS styles, adjust layout viewboxes, and export clean markup.
            </p>
          </div>
          <a href="/tools/svg-previewer" class="font-display font-medium text-sm text-primary flex items-center gap-1 group-hover:translate-x-1.5 transition-transform">
            Optimize SVG &rarr;
          </a>
        </div>
      </div>
      
      <!-- Empty state when no search matches -->
      <div id="empty-state" class="hidden text-center py-16 border border-dashed border-hairline rounded-xl mt-6">
        <p class="text-slate font-medium">No tools found matching your criteria.</p>
        <button id="clear-search-btn" class="button-ghost text-brand-blue text-sm mt-2 font-medium">Clear search queries</button>
      </div>
    </div>
  </section>

  <!-- FAQ Accordion Section -->
  <section class="bg-surface py-16 px-4">
    <div class="max-w-[800px] mx-auto">
      <div class="text-center mb-12">
        <span class="text-xs font-semibold text-brand-blue uppercase tracking-wider">Frequently Asked Questions</span>
        <h2 class="font-display font-medium text-3xl text-primary mt-1 tracking-tight">Security & Operation</h2>
      </div>

      <div class="flex flex-col border border-hairline rounded-lg overflow-hidden bg-canvas">
        <!-- Q1 -->
        <details class="group/faq border-b border-hairline cursor-pointer" open>
          <summary class="flex justify-between items-center p-6 text-base font-semibold text-primary font-display list-none">
            Is my data safe? Do you store any inputs?
            <span class="text-slate group-open/faq:rotate-180 transition-transform">&darr;</span>
          </summary>
          <div class="px-6 pb-6 text-sm text-slate leading-relaxed">
            Yes, your data is 100% safe. BoardTools is built as a fully static website. All operations, conversions, computations, and image rendering happen entirely inside your local browser. No data, files, or strings are ever transmitted to any external servers.
          </div>
        </details>
        
        <!-- Q2 -->
        <details class="group/faq border-b border-hairline cursor-pointer">
          <summary class="flex justify-between items-center p-6 text-base font-semibold text-primary font-display list-none">
            How does the canvas whiteboard save its state?
            <span class="text-slate group-open/faq:rotate-180 transition-transform">&darr;</span>
          </summary>
          <div class="px-6 pb-6 text-sm text-slate leading-relaxed">
            The whiteboard saves its sketches and sticky notes content directly to your local browser storage (`localStorage`). If you refresh or close the tab, your draft will be preserved. You can also click the "Export PNG" button to download a static snapshot to your computer.
          </div>
        </details>

        <!-- Q3 -->
        <details class="group/faq cursor-pointer">
          <summary class="flex justify-between items-center p-6 text-base font-semibold text-primary font-display list-none">
            Are these tools completely free to use?
            <span class="text-slate group-open/faq:rotate-180 transition-transform">&darr;</span>
          </summary>
          <div class="px-6 pb-6 text-sm text-slate leading-relaxed">
            Yes, BoardTools is completely free, open-source, and does not require registration or account login. Our goal is to provide a smooth, aesthetic, and helpful toolkit for creators.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Banner Dark -->
  <section class="bg-canvas py-16 px-4">
    <div class="max-w-[1280px] mx-auto bg-primary text-canvas rounded-3xl p-12 text-center flex flex-col items-center gap-6 shadow-mockup">
      <span class="text-brand-yellow font-display text-sm font-semibold tracking-wider uppercase">Visual Workflow Suite</span>
      <h2 class="font-display font-medium text-3xl md:text-4xl text-canvas max-w-xl tracking-tight leading-tight">
        Build better web interfaces visually. Launch BoardTools.
      </h2>
      <p class="text-xs md:text-sm text-on-dark-muted max-w-md">
        Instant loading, zero tracker cookies, offline capability, completely local sandbox.
      </p>
      <a href="/tools/whiteboard" class="button-on-dark px-8 py-3 !rounded-full mt-2">
        Launch Sandbox Whiteboard
      </a>
    </div>
  </section>
</Layout>

<script>
  // Add live filter search capability
  const searchInput = document.getElementById('tool-search') as HTMLInputElement | null;
  const filterTabs = document.querySelectorAll('#filter-tabs-container button');
  const toolCards = document.querySelectorAll('.tool-card');
  const emptyState = document.getElementById('empty-state');
  const clearBtn = document.getElementById('clear-search-btn');

  let activeCategory = 'all';
  let searchQuery = '';

  function filterTools() {
    let visibleCount = 0;
    
    toolCards.forEach(card => {
      const element = card as HTMLElement;
      const category = element.dataset.category || '';
      const titleText = element.dataset.title || '';
      
      const categoryMatch = activeCategory === 'all' || category === activeCategory;
      const searchMatch = searchQuery === '' || titleText.toLowerCase().includes(searchQuery.toLowerCase());
      
      if (categoryMatch && searchMatch) {
        element.style.display = 'flex';
        visibleCount++;
      } else {
        element.style.display = 'none';
      }
    });

    if (emptyState) {
      if (visibleCount === 0) {
        emptyState.classList.remove('hidden');
      } else {
        emptyState.classList.add('hidden');
      }
    }
  }

  // Handle Search Input Change
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value;
      filterTools();
    });
  }

  // Handle Category Pill clicks
  filterTabs.forEach(btn => {
    btn.addEventListener('click', (e) => {
      // Remove active from all tabs
      filterTabs.forEach(t => t.classList.remove('pill-tab-active'));
      // Add active to current click
      const current = e.currentTarget as HTMLButtonElement;
      current.classList.add('pill-tab-active');
      activeCategory = current.dataset.category || 'all';
      filterTools();
    });
  });

  // Handle Clear button
  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      if (searchInput) {
        searchInput.value = '';
      }
      searchQuery = '';
      activeCategory = 'all';
      filterTabs.forEach(t => {
        if ((t as HTMLElement).dataset.category === 'all') {
          t.classList.add('pill-tab-active');
        } else {
          t.classList.remove('pill-tab-active');
        }
      });
      filterTools();
    });
  }

  // Make whole card clickable to navigate to link inside
  toolCards.forEach(card => {
    card.addEventListener('click', (e) => {
      const link = card.querySelector('a');
      if (link && e.target !== link) {
        window.location.href = link.getAttribute('href') || '/';
      }
    });
  });
</script>
