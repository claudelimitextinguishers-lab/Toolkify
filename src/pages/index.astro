<script>
  // ============================================
  // GRID REQUEST A TOOL FORM LOGIC
  // ============================================
  const gridForm = document.getElementById(
    "grid-request-form",
  ) as HTMLFormElement | null;
  const gridSuccess = document.getElementById("grid-request-success");

  if (gridForm && gridSuccess) {
    gridForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const emailVal = (
        document.getElementById("grid-request-email") as HTMLInputElement | null
      )?.value;
      const toolVal = (
        document.getElementById("grid-request-desc") as HTMLInputElement | null
      )?.value;

      if (emailVal && toolVal) {
        const submission = {
          email: emailVal,
          tool: toolVal,
          timestamp: Date.now(),
          source: "grid",
        };

        try {
          const existing = JSON.parse(
            localStorage.getItem("requested_tools") || "[]",
          );
          existing.push(submission);
          localStorage.setItem("requested_tools", JSON.stringify(existing));
        } catch (err) {}

        gridForm.classList.add("hidden");
        gridSuccess.classList.remove("hidden");
        gridSuccess.classList.add("flex");
      }
    });
  }

  // ============================================
  // HOMEPAGE DYNAMIC REVIEWS FEED LOGIC
  // ============================================
  const homepageReviewsGrid = document.getElementById("homepage-reviews-grid");
  if (homepageReviewsGrid) {
    try {
      const localReviews = JSON.parse(
        localStorage.getItem("user_reviews") || "[]",
      );
      if (localReviews.length > 0) {
        const pastelClasses = [
          "bg-surface-yellow border border-yellow-light text-yellow-dark",
          "bg-teal-light border border-hairline text-moss-dark",
          "bg-coral-light border border-hairline text-coral-dark",
          "bg-rose-light border border-hairline text-primary",
        ];

        localReviews.slice(0, 3).forEach((item: any, index: number) => {
          const colorClass = pastelClasses[index % pastelClasses.length];
          const starsHTML =
            "★".repeat(item.rating) + "☆".repeat(5 - item.rating);

          const card = document.createElement("div");
          card.className = `flex flex-col justify-between gap-4 p-6 rounded-2xl ${colorClass} shadow-subtle animate-fade-in-up`;

          const initials = (item.name || "U")
            .split(" ")
            .map((n: string) => n[0])
            .join("")
            .substring(0, 2)
            .toUpperCase();

          card.innerHTML = `
            <div class="flex flex-col gap-3">
              <div class="flex justify-between items-start">
                <span class="text-xs font-bold text-brand-yellow-deep">${starsHTML}</span>
                <span class="bg-success-accent/15 text-success-accent border border-success-accent/25 text-[8px] font-bold px-1.5 py-0.5 rounded-full">New</span>
              </div>
              <p class="text-xs leading-relaxed opacity-95 italic font-sans font-normal">
                "${item.review}"
              </p>
            </div>
            <div class="flex items-center gap-3 mt-2">
              <div class="w-8 h-8 rounded-full ${colorClass} filter brightness-95 flex items-center justify-center font-bold text-xs select-none border border-black/10 text-primary">
                ${initials}
              </div>
              <div class="flex flex-col">
                <span class="text-xs font-bold text-primary">${item.name}</span>
                <span class="text-[9px] opacity-75">${item.title || "User"}</span>
              </div>
            </div>
          `;
          homepageReviewsGrid.insertBefore(
            card,
            homepageReviewsGrid.firstChild,
          );
        });
      }
    } catch (e) {
      console.error(e);
    }
  }

  // ============================================
  // TOOL FILTER & SEARCH LOGIC + HERO DROPDOWN
  // ============================================
  const searchInput = document.getElementById(
    "tool-search",
  ) as HTMLInputElement | null;
  const filterTabs = document.querySelectorAll("#filter-tabs-container button");
  const toolCards = document.querySelectorAll(".tool-card");
  const emptyState = document.getElementById("empty-state");
  const clearBtn = document.getElementById("clear-search-btn");
  const heroDropdown = document.getElementById("hero-search-dropdown");
  const heroDropdownResults = document.getElementById("hero-dropdown-results");
  const heroDropdownEmpty = document.getElementById("hero-dropdown-empty");
  const heroRequestBtn = document.getElementById("hero-request-tool-btn");
  const heroSearchWrapper = document.getElementById("hero-search-wrapper");

  // Get tools index from SearchOverlay (shared data)
  const heroSearchTools: Array<{
    id: string;
    name: string;
    desc: string;
    category: string;
    path: string;
    icon: string;
    keywords: string;
  }> = (window as any).__BOARDTOOLS_SEARCH_INDEX__ || [];

  let activeCategory = "all";
  let searchQuery = "";
  let heroActiveIdx = -1;
  let heroVisibleItems: HTMLElement[] = [];

  function filterTools() {
    let visibleCount = 0;

    toolCards.forEach((card) => {
      const element = card as HTMLElement;
      const category = element.dataset.category || "";
      const titleText = element.dataset.title || "";

      const categoryMatch =
        activeCategory === "all" || category === activeCategory;
      const searchMatch =
        searchQuery === "" ||
        titleText.toLowerCase().includes(searchQuery.toLowerCase());

      if (categoryMatch && searchMatch) {
        element.style.display = "flex";
        visibleCount++;
      } else {
        element.style.display = "none";
      }
    });

    if (emptyState) {
      if (visibleCount === 0) {
        emptyState.classList.remove("hidden");
      } else {
        emptyState.classList.add("hidden");
      }
    }
  }

  function heroHighlightText(text: string, query: string): string {
    if (!query) return text;
    const safeQ = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    return text.replace(
      new RegExp(`(${safeQ})`, "gi"),
      '<mark class="bg-brand-yellow/40 text-primary rounded-sm px-0.5">$1</mark>',
    );
  }

  function showHeroDropdown(query: string) {
    if (!heroDropdown || !heroDropdownResults || !heroDropdownEmpty) return;

    const q = query.toLowerCase().trim();
    if (!q) {
      heroDropdown.classList.add("hidden");
      heroActiveIdx = -1;
      heroVisibleItems = [];
      return;
    }

    const matches = heroSearchTools.filter(
      (t) =>
        t.name.toLowerCase().includes(q) ||
        t.keywords.toLowerCase().includes(q) ||
        t.desc.toLowerCase().includes(q) ||
        t.category.toLowerCase().includes(q),
    );

    heroDropdown.classList.remove("hidden");

    if (matches.length > 0) {
      heroDropdownEmpty.classList.add("hidden");
      heroDropdownResults.classList.remove("hidden");

      // Group by category
      const grouped: Record<string, typeof matches> = {};
      matches.forEach((m) => {
        if (!grouped[m.category]) grouped[m.category] = [];
        grouped[m.category].push(m);
      });

      let html = "";
      for (const [cat, items] of Object.entries(grouped)) {
        html += `<div class="px-4 pt-3 pb-1"><span class="text-[10px] font-bold text-stone uppercase tracking-wider">${cat}</span></div>`;
        items.forEach((item) => {
          html += `
            <a href="${item.path}" class="hero-dropdown-item flex items-center gap-3 px-4 py-2.5 hover:bg-surface transition-colors cursor-pointer group" data-path="${item.path}">
              <span class="w-7 h-7 rounded-lg bg-surface border border-hairline flex items-center justify-center text-xs shrink-0 group-hover:border-brand-blue/30 transition-colors">${item.icon}</span>
              <div class="flex-1 min-w-0">
                <span class="text-sm font-display font-medium text-primary block truncate">${heroHighlightText(item.name, query)}</span>
                <span class="text-[10px] text-stone block truncate">${heroHighlightText(item.desc, query)}</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-hairline-strong group-hover:text-brand-blue shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>`;
        });
      }

      html += `<div class="px-4 py-2.5 border-t border-hairline flex items-center justify-between">
        <span class="text-[10px] text-stone">${matches.length} tool${matches.length !== 1 ? "s" : ""} found</span>
        <span class="text-[9px] text-stone flex items-center gap-1">
          <kbd class="bg-surface border border-hairline rounded px-1 py-0.5 font-mono text-[8px]">↑↓</kbd> navigate
          <kbd class="bg-surface border border-hairline rounded px-1 py-0.5 font-mono text-[8px] ml-1">↵</kbd> select
        </span>
      </div>`;

      heroDropdownResults.innerHTML = html;
      heroVisibleItems = Array.from(
        heroDropdownResults.querySelectorAll(".hero-dropdown-item"),
      );
      heroActiveIdx = -1;
    } else {
      heroDropdownResults.classList.add("hidden");
      heroDropdownResults.innerHTML = "";
      heroDropdownEmpty.classList.remove("hidden");
      heroVisibleItems = [];
      heroActiveIdx = -1;
    }
  }

  function updateHeroHighlight() {
    heroVisibleItems.forEach((el, i) => {
      if (i === heroActiveIdx) {
        el.classList.add("bg-surface");
        el.scrollIntoView({ block: "nearest" });
      } else {
        el.classList.remove("bg-surface");
      }
    });
  }

  // Handle Search Input Change — filters grid + shows dropdown
  if (searchInput) {
    searchInput.addEventListener("input", (e) => {
      searchQuery = (e.target as HTMLInputElement).value;
      filterTools();
      showHeroDropdown(searchQuery);
    });

    // Handle focus to show dropdown if query exists
    searchInput.addEventListener("focus", () => {
      if (searchQuery.trim()) {
        showHeroDropdown(searchQuery);
      }
    });

    // Keyboard navigation in hero dropdown
    searchInput.addEventListener("keydown", (e) => {
      if (heroDropdown?.classList.contains("hidden")) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        if (heroVisibleItems.length > 0) {
          heroActiveIdx = Math.min(
            heroActiveIdx + 1,
            heroVisibleItems.length - 1,
          );
          updateHeroHighlight();
        }
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (heroVisibleItems.length > 0) {
          heroActiveIdx = Math.max(heroActiveIdx - 1, 0);
          updateHeroHighlight();
        }
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (heroActiveIdx >= 0 && heroVisibleItems[heroActiveIdx]) {
          const href =
            heroVisibleItems[heroActiveIdx].getAttribute("href") ||
            heroVisibleItems[heroActiveIdx].dataset.path;
          if (href) window.location.href = href;
        }
      } else if (e.key === "Escape") {
        heroDropdown?.classList.add("hidden");
        heroActiveIdx = -1;
      }
    });
  }

  // Close hero dropdown on outside click
  document.addEventListener("click", (e) => {
    if (
      heroSearchWrapper &&
      heroDropdown &&
      !heroSearchWrapper.contains(e.target as Node)
    ) {
      heroDropdown.classList.add("hidden");
      heroActiveIdx = -1;
    }
  });

  // Hero "Request a Tool" button → triggers the floating RequestToolPopup
  if (heroRequestBtn) {
    heroRequestBtn.addEventListener("click", () => {
      heroDropdown?.classList.add("hidden");
      const requestContainer = document.getElementById(
        "floating-request-container",
      );
      const requestCollapsed = document.getElementById(
        "request-collapsed-bubble",
      );
      const requestExpanded = document.getElementById("request-expanded-card");
      if (requestContainer && requestCollapsed && requestExpanded) {
        requestContainer.classList.remove("hidden");
        requestContainer.classList.add("flex");
        requestCollapsed.classList.add("hidden");
        requestExpanded.classList.remove("hidden");
        requestExpanded.classList.add("flex");
      }
    });
  }

  // Handle Category Pill clicks
  filterTabs.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      // Remove active from all tabs
      filterTabs.forEach((t) => t.classList.remove("pill-tab-active"));
      // Add active to current click
      const current = e.currentTarget as HTMLButtonElement;
      current.classList.add("pill-tab-active");
      activeCategory = current.dataset.category || "all";
      filterTools();

      // Smoothly scroll to the Select a Workspace section
      const targetSection = document.getElementById("select-workspace-section");
      if (targetSection) {
        targetSection.scrollIntoView({ behavior: "smooth" });
      }
    });
  });

  // Handle Clear button
  if (clearBtn) {
    clearBtn.addEventListener("click", () => {
      if (searchInput) {
        searchInput.value = "";
      }
      searchQuery = "";
      activeCategory = "all";
      filterTabs.forEach((t) => {
        if ((t as HTMLElement).dataset.category === "all") {
          t.classList.add("pill-tab-active");
        } else {
          t.classList.remove("pill-tab-active");
        }
      });
      filterTools();
      heroDropdown?.classList.add("hidden");
    });
  }

  // Make whole card clickable to navigate to link inside
  toolCards.forEach((card) => {
    card.addEventListener("click", (e) => {
      const link = card.querySelector("a");
      if (link && e.target !== link) {
        window.location.href = link.getAttribute("href") || "/";
      }
    });
  });

  // Handle Category query parameter on load
  const urlParams = new URLSearchParams(window.location.search);
  const categoryParam = urlParams.get("category");
  if (categoryParam) {
    const targetTab = Array.from(filterTabs).find(
      (t) => (t as HTMLElement).dataset.category === categoryParam,
    );
    if (targetTab) {
      filterTabs.forEach((t) => t.classList.remove("pill-tab-active"));
      targetTab.classList.add("pill-tab-active");
      activeCategory = categoryParam;
      filterTools();

      // Smoothly scroll to the directory section on page load with a slight delay
      setTimeout(() => {
        const targetSection = document.getElementById("select-workspace-section");
        if (targetSection) {
          targetSection.scrollIntoView({ behavior: "smooth" });
        }
      }, 150);
    }
  }

  // ============================================
  // IMMERSIVE HERO WHITEBOARD SANDBOX
  // ============================================
  const homeCanvas = document.getElementById(
    "home-board-canvas",
  ) as HTMLElement | null;
  const notesContainer = document.getElementById("home-notes-container");
  const heroPenBtn = document.getElementById("hero-tool-pen");
  const heroStickyBtn = document.getElementById("hero-tool-sticky");
  const heroSketchCanvas = document.getElementById(
    "home-sketch-canvas",
  ) as HTMLCanvasElement | null;
  const heroCtx = heroSketchCanvas?.getContext("2d");

  let activeHeroTool: "pen" | "sticky" = "sticky";
  let isDrawingHero = false;
  let lastHeroX = 0;
  let lastHeroY = 0;
  let heroNotes: Array<{ id: string; el: HTMLElement; type: string }> = [];

  function setHeroTool(tool: "pen" | "sticky") {
    activeHeroTool = tool;
    if (tool === "pen") {
      heroPenBtn?.classList.add("bg-primary", "text-canvas");
      heroPenBtn?.classList.remove("bg-surface", "text-slate");
      heroStickyBtn?.classList.remove("bg-primary", "text-canvas");
      heroStickyBtn?.classList.add("bg-surface", "text-slate");
      if (heroSketchCanvas) {
        heroSketchCanvas.style.pointerEvents = "auto"; // allow drawing
        heroSketchCanvas.style.cursor = "crosshair";
      }
    } else {
      heroStickyBtn?.classList.add("bg-primary", "text-canvas");
      heroStickyBtn?.classList.remove("bg-surface", "text-slate");
      heroPenBtn?.classList.remove("bg-primary", "text-canvas");
      heroPenBtn?.classList.add("bg-surface", "text-slate");
      if (heroSketchCanvas) {
        heroSketchCanvas.style.pointerEvents = "none"; // click through to drag notes
        heroSketchCanvas.style.cursor = "default";
      }
    }
  }

  // Draw Line Connector SVG paths between note-1 -> note-2 -> note-3
  function updateLines() {
    const canvasEl = document.getElementById("home-board-canvas");
    const n1 = canvasEl?.querySelector(
      '[data-id="note-1"]',
    ) as HTMLElement | null;
    const n2 = canvasEl?.querySelector(
      '[data-id="note-2"]',
    ) as HTMLElement | null;
    const n3 = canvasEl?.querySelector(
      '[data-id="note-3"]',
    ) as HTMLElement | null;
    const path1 = document.getElementById("home-path-1");
    const path2 = document.getElementById("home-path-2");

    if (canvasEl && n1 && n2 && path1) {
      const r1 = {
        x: n1.offsetLeft + n1.offsetWidth / 2,
        y: n1.offsetTop + n1.offsetHeight / 2,
      };
      const r2 = {
        x: n2.offsetLeft + n2.offsetWidth / 2,
        y: n2.offsetTop + n2.offsetHeight / 2,
      };
      path1.setAttribute(
        "d",
        `M ${r1.x} ${r1.y} Q ${(r1.x + r2.x) / 2} ${(r1.y + r2.y) / 2 - 30} ${r2.x} ${r2.y}`,
      );
    }

    if (canvasEl && n2 && n3 && path2) {
      const r2 = {
        x: n2.offsetLeft + n2.offsetWidth / 2,
        y: n2.offsetTop + n2.offsetHeight / 2,
      };
      const r3 = {
        x: n3.offsetLeft + n3.offsetWidth / 2,
        y: n3.offsetTop + n3.offsetHeight / 2,
      };
      path2.setAttribute(
        "d",
        `M ${r2.x} ${r2.y} Q ${(r2.x + r3.x) / 2} ${(r2.y + r3.y) / 2 + 30} ${r3.x} ${r3.y}`,
      );
    }
  }

  function initStickyDrag(el: HTMLElement) {
    let isMoving = false;
    let startOffsetX = 0;
    let startOffsetY = 0;

    el.addEventListener("mousedown", (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === "TEXTAREA" || target.tagName === "INPUT") return;
      isMoving = true;
      const rect = el.getBoundingClientRect();
      startOffsetX = e.clientX - rect.left;
      startOffsetY = e.clientY - rect.top;
      el.style.zIndex = "30";
    });

    document.addEventListener("mousemove", (e) => {
      if (!isMoving) return;
      const canvasEl = document.getElementById("home-board-canvas");
      if (canvasEl) {
        const rect = canvasEl.getBoundingClientRect();
        let x = e.clientX - rect.left - startOffsetX;
        let y = e.clientY - rect.top - startOffsetY;

        x = Math.max(0, Math.min(x, rect.width - el.offsetWidth));
        y = Math.max(0, Math.min(y, rect.height - el.offsetHeight));

        el.style.left = `${x}px`;
        el.style.top = `${y}px`;
        updateLines();
      }
    });

    document.addEventListener("mouseup", () => {
      if (isMoving) {
        isMoving = false;
        el.style.zIndex = "";
      }
    });

    // Touch support for dragging
    el.addEventListener("touchstart", (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === "TEXTAREA" || target.tagName === "INPUT") return;
      isMoving = true;
      const rect = el.getBoundingClientRect();
      startOffsetX = e.touches[0].clientX - rect.left;
      startOffsetY = e.touches[0].clientY - rect.top;
      el.style.zIndex = "30";
    });

    document.addEventListener("touchmove", (e) => {
      if (!isMoving) return;
      const canvasEl = document.getElementById("home-board-canvas");
      if (canvasEl) {
        const rect = canvasEl.getBoundingClientRect();
        let x = e.touches[0].clientX - rect.left - startOffsetX;
        let y = e.touches[0].clientY - rect.top - startOffsetY;

        x = Math.max(0, Math.min(x, rect.width - el.offsetWidth));
        y = Math.max(0, Math.min(y, rect.height - el.offsetHeight));

        el.style.left = `${x}px`;
        el.style.top = `${y}px`;
        updateLines();
      }
    });

    document.addEventListener("touchend", () => {
      if (isMoving) {
        isMoving = false;
        el.style.zIndex = "";
      }
    });
  }

  function spawnHeroNote(
    id: string,
    x: number,
    y: number,
    text: string,
    color: string,
    type = "normal",
  ) {
    if (!notesContainer) return;

    const note = document.createElement("div");
    note.id = id;
    note.dataset.id = id;
    note.style.left = `${x}px`;
    note.style.top = `${y}px`;
    note.style.backgroundColor = color;

    let textColor = "#1c1c1e";
    let subText = "#yellow";
    if (color === "#0fbcb0") {
      textColor = "#050038";
      subText = "#teal";
    } else if (color === "#ff9999") {
      textColor = "#600000";
      subText = "#coral";
    } else if (color === "#ffd8f4") {
      textColor = "#1c1c1e";
      subText = "#rose";
    }

    note.className =
      "absolute w-24 h-24 shadow-card rounded-sm p-2 flex flex-col justify-between font-display text-[10px] cursor-grab active:cursor-grabbing select-none pointer-events-auto transition-shadow hover:shadow-mockup";
    note.style.transform = `rotate(${(Math.random() * 6 - 3).toFixed(1)}deg)`;
    note.style.color = textColor;

    if (type === "uuid") {
      note.innerHTML = `
        <div class="flex flex-col gap-1 w-full h-[62px] pointer-events-auto">
          <span class="font-bold text-[8px] uppercase text-brand-blue tracking-wide select-none">UUID v4 Token</span>
          <textarea readonly class="w-full h-full bg-transparent border-none outline-none resize-none font-mono text-[8px] select-all leading-tight text-primary">${text}</textarea>
        </div>
        <span class="text-[8px] opacity-70 self-end pointer-events-none">#uuid</span>
      `;
    } else if (type === "base64") {
      note.innerHTML = `
        <div class="flex flex-col gap-1 w-full h-[62px] pointer-events-auto">
          <input type="text" placeholder="Type..." class="w-full bg-canvas/60 border border-black/15 rounded px-1 text-[8px] font-sans outline-none h-4 text-primary base64-input-box" />
          <textarea readonly placeholder="Result..." class="w-full h-[38px] bg-transparent border-none outline-none resize-none font-mono text-[7px] select-all leading-tight text-primary base64-output-box"></textarea>
        </div>
        <span class="text-[8px] opacity-70 self-end pointer-events-none">#base64</span>
      `;
      // Attach encoder listener
      setTimeout(() => {
        const inp = note.querySelector(
          ".base64-input-box",
        ) as HTMLInputElement | null;
        const out = note.querySelector(
          ".base64-output-box",
        ) as HTMLTextAreaElement | null;
        if (inp && out) {
          inp.addEventListener("input", () => {
            try {
              out.value = inp.value
                ? btoa(unescape(encodeURIComponent(inp.value)))
                : "";
            } catch (e) {
              out.value = "Error...";
            }
          });
        }
      }, 50);
    } else {
      note.innerHTML = `
        <textarea class="font-medium bg-transparent border-none outline-none resize-none h-[62px] select-text overflow-hidden text-primary" style="font-size:10px; line-height:1.25; color: ${textColor}">${text}</textarea>
        <span class="text-[8px] opacity-70 self-end pointer-events-none">${subText}</span>
      `;
    }

    notesContainer.appendChild(note);
    heroNotes.push({ id, el: note, type });
    initStickyDrag(note);
    updateLines();
  }

  // Spawn initial starting sticky notes
  spawnHeroNote(
    "note-1",
    40,
    30,
    "Define MVP & Workspaces",
    "#ffd02f",
    "normal",
  );
  spawnHeroNote(
    "note-2",
    240,
    90,
    "Refine Brand Guidelines",
    "#0fbcb0",
    "normal",
  );
  spawnHeroNote(
    "note-3",
    110,
    160,
    "Local SEO & Speed Audit",
    "#ffd8f4",
    "normal",
  );

  // Sketch Drawing Listeners
  function resizeHeroCanvas() {
    if (heroSketchCanvas && heroSketchCanvas.parentElement) {
      const temp = document.createElement("canvas");
      temp.width = heroSketchCanvas.width;
      temp.height = heroSketchCanvas.height;
      const tCtx = temp.getContext("2d");
      if (tCtx) tCtx.drawImage(heroSketchCanvas, 0, 0);

      heroSketchCanvas.width = heroSketchCanvas.parentElement.clientWidth;
      heroSketchCanvas.height = heroSketchCanvas.parentElement.clientHeight;

      if (heroCtx) {
        heroCtx.lineCap = "round";
        heroCtx.lineJoin = "round";
        heroCtx.strokeStyle = document.documentElement.classList.contains(
          "dark",
        )
          ? "#ffffff"
          : "#1c1c1e";
        heroCtx.lineWidth = 4;
        heroCtx.drawImage(temp, 0, 0);
      }
    }
  }

  if (heroSketchCanvas && heroCtx) {
    resizeHeroCanvas();
    window.addEventListener("resize", resizeHeroCanvas);

    heroSketchCanvas.addEventListener("mousedown", (e) => {
      if (activeHeroTool !== "pen") return;
      isDrawingHero = true;
      const rect = heroSketchCanvas.getBoundingClientRect();
      lastHeroX = e.clientX - rect.left;
      lastHeroY = e.clientY - rect.top;
    });

    heroSketchCanvas.addEventListener("mousemove", (e) => {
      if (!isDrawingHero || !heroCtx) return;
      const rect = heroSketchCanvas.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      heroCtx.beginPath();
      heroCtx.moveTo(lastHeroX, lastHeroY);
      heroCtx.lineTo(x, y);
      heroCtx.strokeStyle = document.documentElement.classList.contains("dark")
        ? "#ffffff"
        : "#1c1c1e";
      heroCtx.stroke();

      lastHeroX = x;
      lastHeroY = y;
    });

    heroSketchCanvas.addEventListener("mouseup", () => {
      isDrawingHero = false;
    });
    heroSketchCanvas.addEventListener("mouseout", () => {
      isDrawingHero = false;
    });

    // Touch support for sketching
    heroSketchCanvas.addEventListener("touchstart", (e) => {
      if (activeHeroTool !== "pen") return;
      isDrawingHero = true;
      const rect = heroSketchCanvas.getBoundingClientRect();
      lastHeroX = e.touches[0].clientX - rect.left;
      lastHeroY = e.touches[0].clientY - rect.top;
    });

    heroSketchCanvas.addEventListener("touchmove", (e) => {
      if (!isDrawingHero || !heroCtx) return;
      const rect = heroSketchCanvas.getBoundingClientRect();
      const x = e.touches[0].clientX - rect.left;
      const y = e.touches[0].clientY - rect.top;

      heroCtx.beginPath();
      heroCtx.moveTo(lastHeroX, lastHeroY);
      heroCtx.lineTo(x, y);
      heroCtx.strokeStyle = document.documentElement.classList.contains("dark")
        ? "#ffffff"
        : "#1c1c1e";
      heroCtx.stroke();

      lastHeroX = x;
      lastHeroY = y;
    });

    heroSketchCanvas.addEventListener("touchend", () => {
      isDrawingHero = false;
    });
  }

  // Tool Bar Switches
  if (heroPenBtn)
    heroPenBtn.addEventListener("click", () => setHeroTool("pen"));
  if (heroStickyBtn)
    heroStickyBtn.addEventListener("click", () => setHeroTool("sticky"));

  setHeroTool("sticky"); // Default state is dragging notes

  // Clear drawings layer
  const heroClearBtn = document.getElementById("hero-tool-clear");
  if (heroClearBtn && heroSketchCanvas && heroCtx) {
    heroClearBtn.addEventListener("click", () => {
      heroCtx.clearRect(0, 0, heroSketchCanvas.width, heroSketchCanvas.height);
    });
  }

  // Quick Action - Spawn UUID Sticky Note
  const heroUuidBtn = document.getElementById("hero-tool-uuid");
  if (heroUuidBtn) {
    heroUuidBtn.addEventListener("click", () => {
      const uuid = crypto.randomUUID
        ? crypto.randomUUID()
        : "xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx".replace(/[xy]/g, (c) => {
            const r = (Math.random() * 16) | 0;
            const v = c === "x" ? r : (r & 0x3) | 0x8;
            return v.toString(16);
          });
      const canvasEl = document.getElementById("home-board-canvas");
      const w = canvasEl?.clientWidth || 400;
      const h = canvasEl?.clientHeight || 250;
      spawnHeroNote(
        "uuid_" + Date.now(),
        w / 2 - 48,
        h / 2 - 48,
        uuid,
        "#ffd8f4",
        "uuid",
      );
      setHeroTool("sticky");
    });
  }

  // Quick Action - Spawn Base64 Sticky Note
  const heroBase64Btn = document.getElementById("hero-tool-base64");
  if (heroBase64Btn) {
    heroBase64Btn.addEventListener("click", () => {
      const canvasEl = document.getElementById("home-board-canvas");
      const w = canvasEl?.clientWidth || 400;
      const h = canvasEl?.clientHeight || 250;
      spawnHeroNote(
        "b64_" + Date.now(),
        w / 2 - 48,
        h / 2 - 48,
        "",
        "#ff9999",
        "base64",
      );
      setHeroTool("sticky");
    });
  }

  // Double click canvas to add note
  if (homeCanvas) {
    homeCanvas.addEventListener("dblclick", (e) => {
      if (e.target !== homeCanvas && e.target !== heroSketchCanvas) return;
      const rect = homeCanvas.getBoundingClientRect();
      const x = e.clientX - rect.left - 48;
      const y = e.clientY - rect.top - 48;

      const colors = ["#ffd02f", "#ff9999", "#0fbcb0", "#ffd8f4"];
      const randomColor = colors[Math.floor(Math.random() * colors.length)];
      spawnHeroNote(
        "note_" + Date.now(),
        x,
        y,
        "Double click to edit",
        randomColor,
        "normal",
      );
    });
  }

  // ============================================
  // MULTIPLAYER SIMULATOR LOGIC
  // ============================================
  let multiplayerInterval: any = null;
  let multiplayerActive = false;
  const simCursorsContainer = document.getElementById("simulated-cursors");
  const toggleMultiplayerBtn = document.getElementById("toggle-multiplayer");
  const mpDot = document.getElementById("multiplayer-dot");

  const simulatedUsers = [
    {
      name: "Jaina 🎨",
      color: "#ff9999",
      cursorColor: "#ff9999",
      textColor: "#600000",
      x: 20,
      y: 30,
    },
    {
      name: "Claude 🤖",
      color: "#0fbcb0",
      cursorColor: "#0fbcb0",
      textColor: "#050038",
      x: 80,
      y: 20,
    },
    {
      name: "Astro 🚀",
      color: "#ffd02f",
      cursorColor: "#ffd02f",
      textColor: "#1c1c1e",
      x: 50,
      y: 70,
    },
  ];

  function setupSimulatedCursors() {
    if (!simCursorsContainer) return;
    simCursorsContainer.innerHTML = "";

    simulatedUsers.forEach((user, idx) => {
      const cursorDiv = document.createElement("div");
      cursorDiv.id = `sim-user-${idx}`;
      cursorDiv.className =
        "absolute pointer-events-none z-30 flex items-center gap-1";
      cursorDiv.style.left = `${user.x}%`;
      cursorDiv.style.top = `${user.y}%`;
      cursorDiv.style.transition =
        "left 1.5s cubic-bezier(0.25, 1, 0.5, 1), top 1.5s cubic-bezier(0.25, 1, 0.5, 1)";

      cursorDiv.innerHTML = `
        <svg class="w-4 h-4 filter drop-shadow" style="color: ${user.cursorColor}" viewBox="0 0 24 24" fill="currentColor">
          <path d="M4 3l16 9-6.5 1.5L20 20l-3 1.5-6.5-6.5L4 18V3z" />
        </svg>
        <span class="text-[8px] text-white font-bold px-1.5 py-0.5 rounded-full whitespace-nowrap shadow" style="background-color: ${user.color}; color: ${user.textColor}">
          ${user.name}
        </span>
      `;
      simCursorsContainer.appendChild(cursorDiv);
    });
  }

  function moveSimulatedCursors() {
    simulatedUsers.forEach((user, idx) => {
      const cursor = document.getElementById(`sim-user-${idx}`);
      if (cursor) {
        const newX = Math.floor(Math.random() * 70) + 10;
        const newY = Math.floor(Math.random() * 70) + 10;
        cursor.style.left = `${newX}%`;
        cursor.style.top = `${newY}%`;

        if (Math.random() > 0.8) {
          const label = cursor.querySelector("span");
          if (label) {
            const origText = label.textContent;
            label.textContent = `${user.name} (editing...)`;
            setTimeout(() => {
              label.textContent = origText;
            }, 1000);
          }
        }
      }
    });
  }

  if (toggleMultiplayerBtn && mpDot) {
    toggleMultiplayerBtn.addEventListener("click", () => {
      multiplayerActive = !multiplayerActive;
      if (multiplayerActive) {
        toggleMultiplayerBtn.classList.add(
          "bg-primary",
          "text-canvas",
          "border-primary",
        );
        toggleMultiplayerBtn.classList.remove("bg-surface", "text-slate");
        mpDot.classList.add("bg-success-accent");
        mpDot.classList.remove("bg-stone");
        setupSimulatedCursors();
        moveSimulatedCursors();
        multiplayerInterval = setInterval(moveSimulatedCursors, 2200);
      } else {
        toggleMultiplayerBtn.classList.remove(
          "bg-primary",
          "text-canvas",
          "border-primary",
        );
        toggleMultiplayerBtn.classList.add("bg-surface", "text-slate");
        mpDot.classList.remove("bg-success-accent");
        mpDot.classList.add("bg-stone");
        clearInterval(multiplayerInterval);
        if (simCursorsContainer) simCursorsContainer.innerHTML = "";
      }
    });
  }

  // ============================================
  // WORKSPACE HISTORY RENDER
  // ============================================
  const recentSection = document.getElementById("recent-workspaces-section");
  const recentList = document.getElementById("recent-workspaces-list");

  if (recentSection && recentList) {
    try {
      const recents = JSON.parse(localStorage.getItem("recent_tools") || "[]");
      if (recents.length > 0) {
        recentSection.classList.remove("hidden");
        recentList.innerHTML = "";

        recents.forEach((item: any) => {
          let bgClass =
            "bg-surface-yellow border border-yellow-light text-yellow-dark";
          let iconChar = "W";
          if (item.category === "developer") {
            bgClass =
              "bg-surface-pricing-featured border border-hairline text-brand-blue";
            iconChar = "D";
          } else if (item.category === "design") {
            bgClass = "bg-teal-light border border-hairline text-moss-dark";
            iconChar = "S";
          } else if (item.category === "collaboration") {
            bgClass =
              "bg-surface-yellow border border-yellow-light text-yellow-dark";
            iconChar = "W";
          }

          const card = document.createElement("a");
          card.href = item.path;
          card.className =
            "flex items-center gap-3 p-3.5 bg-canvas/60 border border-hairline rounded-xl hover:-translate-y-1 hover:shadow-subtle transition-all duration-200 group";
          
          let displayName = item.name || "";
          if (displayName.startsWith("Universal ")) {
            displayName = displayName.replace(/^Universal\s+/, "");
          }

          card.innerHTML = `
            <div class="w-8 h-8 rounded-lg flex items-center justify-center font-display font-bold text-xs ${bgClass} select-none">
              ${iconChar}
            </div>
            <div class="flex flex-col">
              <span class="text-xs font-semibold text-primary group-hover:text-brand-blue transition-colors">${displayName}</span>
              <span class="text-[10px] text-stone uppercase tracking-wide font-semibold mt-0.5">${item.category}</span>
            </div>
          `;
          recentList.appendChild(card);
        });
      }
    } catch (e) {
      console.error(e);
    }
  }
</script>
