      "aspect ratio check dimensions layout viewport resolution scale pixel math",
  },
  {
    id: "scroll-wheel",
    name: "Scroll Wheel Test",
    desc: "Verify scroll wheel ticks, direction velocities, and scroll track sensitivity.",
    category: "display",
    path: "/tools/display/scroll-wheel",
    badgeText: "DISPLAY",
    badgeClass: "badge-tag-yellow bg-yellow-light text-yellow-dark",
    cardClass: "card-feature-yellow",
    actionText: "Test Scroll",
    searchKeywords:
      "scroll wheel test mouse wheel scrolling speed track sensitivity double lines",
  },
  {
    id: "polling-rate",
    name: "Polling Rate Test",
    desc: "Track mouse report polling frequencies and verify data coordinate throughput rates.",
    category: "display",
    path: "/tools/display/polling-rate",
    badgeText: "DISPLAY",
    badgeClass: "badge-tag-yellow bg-yellow-light text-yellow-dark",
    cardClass: "card-feature-yellow",
    actionText: "Check Polling Rate",
    searchKeywords:
      "polling rate test report frequency rate hz mouse tracking coordinates latency",
  },
  {
    id: "double-click",
    name: "Double Click Test",
    desc: "Audit and detect mechanical mouse switch double-click issues on primary inputs.",
    category: "display",
    path: "/tools/display/double-click",
    badgeText: "DISPLAY",
    badgeClass: "badge-tag-yellow bg-yellow-light text-yellow-dark",
    cardClass: "card-feature-yellow",
    actionText: "Start Mouse Test",
    searchKeywords:
      "double click test mouse switches click detection gaming diagnostic mechanical issues",
  },
  {
    id: "key-repeat",
    name: "Key Repeat Test",
    desc: "Test keyboard repeat rates, input bounce delays, and keystroke logs.",
    category: "display",
    path: "/tools/display/key-repeat",
    badgeText: "DISPLAY",
    badgeClass: "badge-tag-yellow bg-yellow-light text-yellow-dark",
    cardClass: "card-feature-yellow",
    actionText: "Test Key Repeat",
    searchKeywords:
      "key repeat test delay speed typing latency bounce rate keypress log",
  },
  {
    id: "caps-lock",
    name: "Caps Lock Test",
    desc: "Check Caps Lock activation states, keystroke indicators, and warnings.",
    category: "display",
    path: "/tools/display/caps-lock",
    badgeText: "DISPLAY",
    badgeClass: "badge-tag-yellow bg-yellow-light text-yellow-dark",
    cardClass: "card-feature-yellow",
    actionText: "Test Caps Lock",
    searchKeywords:
      "caps lock test status checker keyboard active status indicators warnings",
  },
  {
    id: "keyboard-latency",
    name: "Keyboard Latency Test",
    desc: "Test keyboard press latencies and measure input-to-screen response times.",
    category: "display",
    path: "/tools/display/keyboard-latency",
    badgeText: "DISPLAY",
    badgeClass: "badge-tag-yellow bg-yellow-light text-yellow-dark",
    cardClass: "card-feature-yellow",
    actionText: "Check Latency",
    searchKeywords:
      "keyboard latency test keypress ms delay reaction speed input response",
  },

  // TIER 8 - General
  {
    id: "time-zone-converter",
    name: "Time Zone Converter",
    desc: "Convert and compare calendar dates and times across global time zones.",
    category: "general",
    path: "/tools/general/time-zone-converter",
    badgeText: "EVERYDAY",
    badgeClass: "badge-tag-yellow bg-teal-light text-moss-dark",
    cardClass: "card-feature-teal",
    actionText: "Convert Time",
    searchKeywords:
      "time zone converter clock comparison calendar utc local world schedules",
  },
  {
    id: "currency-converter",
    name: "Currency Converter",
    desc: "Convert standard currencies using localized static conversion rates.",
    category: "general",
    path: "/tools/general/currency-converter",
    badgeText: "EVERYDAY",
    badgeClass: "badge-tag-yellow bg-teal-light text-moss-dark",
    cardClass: "card-feature-teal",
    actionText: "Convert Currency",
    searchKeywords:
      "currency converter money conversion dollar euro pound rates static calculations",
  },
  {
    id: "speedometer",
    name: "Speedometer",
    desc: "Calculate real-time geographic velocities using browser GPS location updates.",
    category: "general",
    path: "/tools/general/speedometer",
    badgeText: "EVERYDAY",
    badgeClass: "badge-tag-yellow bg-teal-light text-moss-dark",
    cardClass: "card-feature-teal",
    actionText: "Check Speed",
    searchKeywords:
      "speedometer gps velocity coordinates tracking movement geographic travel",
  },
  {
    id: "screen-dead-pixel",
    name: "Screen Dead Pixel Checker",
    desc: "Scan and identify dead pixels on your monitor screen using solid backgrounds.",
    category: "general",
    path: "/tools/general/screen-dead-pixel",
    badgeText: "EVERYDAY",
    badgeClass: "badge-tag-yellow bg-teal-light text-moss-dark",
    cardClass: "card-feature-teal",
    actionText: "Scan Screen",
    searchKeywords:
      "dead pixel screen monitor background check solid pixels checker diagnostic",
  },
  {
    id: "color-picker",
    name: "Color Picker",
    desc: "Extract HSL, hex, and RGB values from canvas coordinates or input ranges.",
    category: "general",
    path: "/tools/general/color-picker",
    badgeText: "EVERYDAY",
    badgeClass: "badge-tag-yellow bg-teal-light text-moss-dark",
    cardClass: "card-feature-teal",
    actionText: "Pick Colors",
    searchKeywords:
      "color picker canvas cursor hex rgb hsl colors palettes checks extract",
  },
];
---

<Layout>
  <!-- Hero Section -->
  <section
    class="bg-canvas border-b border-hairline py-16 lg:py-24 px-4 overflow-hidden relative"
  >
    <!-- Vibrant background grid pattern -->
    <div class="absolute inset-0 dot-grid opacity-25 pointer-events-none"></div>

    <div
      class="max-w-[1280px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10"
    >
      <!-- Left Hero Content -->
      <div
        class="lg:col-span-6 flex flex-col gap-6 items-start text-left animate-fade-in-up"
      >
        <div
          class="inline-flex items-center gap-2 px-3 py-1 bg-surface-yellow border border-yellow-light text-yellow-dark rounded-full text-xs font-semibold"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-brand-yellow-deep animate-ping"
          ></span>
          Zero Server Overhead &bull; 100% Private Sandbox
        </div>

        <h1
          class="font-display font-medium text-5xl sm:text-6xl md:text-7xl lg:text-[76px] tracking-[-2.5px] leading-[1.05] text-primary"
        >
          See how teams get great done, <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue via-brand-teal to-brand-coral font-bold font-display select-none"
            >computation by computation.</span
          >
        </h1>

        <p
          class="font-display text-base md:text-lg text-slate max-w-xl leading-relaxed"
        >
          An interactive multi-tool suite containing 56 calculators,
          diagnostics, and text tools. Calculate finances, optimize health
          parameters, run input tests, and sketch ideas on a local whiteboard
          canvas.
        </p>

        <!-- Instant Filter / Search Pill with Live Dropdown -->
        <div class="w-full max-w-lg mt-2 relative" id="hero-search-wrapper">
          <div class="relative flex items-center">
            <div class="absolute left-4 text-stone pointer-events-none">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4.5 h-4.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <input
              type="text"
              id="tool-search"
              placeholder="Search tools (e.g. JSON, Whiteboard, UUID...)"
              class="text-input w-full pl-11 pr-20 focus:border-brand-blue"
              autocomplete="off"
              spellcheck="false"
            />
            <div class="absolute right-3 flex items-center gap-1.5">
              <span
                class="text-[9px] font-bold text-stone bg-surface border border-hairline rounded px-1.5 py-0.5 select-none hidden sm:inline"
                >Ctrl+K</span
              >
            </div>
          </div>

          <!-- Hero Search Dropdown -->
          <div
            id="hero-search-dropdown"
            class="absolute top-full left-0 w-full mt-2 bg-canvas border border-hairline rounded-xl shadow-modal z-50 overflow-hidden hidden"
          >
            <!-- Results list -->
            <div
              id="hero-dropdown-results"
              class="max-h-[340px] overflow-y-auto"
            >
            </div>

            <!-- No Results + Request Tool CTA -->
            <div id="hero-dropdown-empty" class="hidden px-5 py-6 text-center">
              <div
                class="w-10 h-10 mx-auto rounded-full bg-surface-yellow border border-yellow-light flex items-center justify-center text-base mb-2.5"
              >
                🔍
              </div>
              <p class="text-sm font-display font-medium text-primary mb-1">
                No matching tools found
              </p>
              <p class="text-xs text-slate mb-3">
                Can't find what you need? Request it and we'll build it!
              </p>
              <button
                id="hero-request-tool-btn"
                class="button-primary !py-2 !px-5 !text-xs inline-flex items-center gap-1.5 cursor-pointer"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 4v16m8-8H4"></path>
                </svg>
                Request a Tool
              </button>
            </div>
          </div>
        </div>

        <!-- Pill Tabs for Category Filter -->
        <div class="flex flex-wrap gap-2.5 mt-2" id="filter-tabs-container">
          <button class="pill-tab pill-tab-active" data-category="all"
            >All Tools</button
          >
          <button class="pill-tab" data-category="collaboration"
            >Collaboration</button
          >
          <button class="pill-tab" data-category="finance">Finance & Tax</button
          >
          <button class="pill-tab" data-category="health"
            >Health & Fitness</button
          >
          <button class="pill-tab" data-category="engagement">Engagement</button
          >
          <button class="pill-tab" data-category="developer"
            >Developer & Text</button
          >
          <button class="pill-tab" data-category="audio">Audio Utilities</button
          >
          <button class="pill-tab" data-category="mobile">Mobile Sensors</button
          >
          <button class="pill-tab" data-category="display"
            >Display & Input</button
          >
          <button class="pill-tab" data-category="general"
            >Everyday Tools</button
          >
        </div>
      </div>

      <!-- Right Immersive Interactive Sandbox Widget -->
      <div class="lg:col-span-6 w-full animate-fade-in-up delay-200">
        <div
          class="whiteboard-mockup overflow-hidden aspect-[16/10] flex flex-col relative shadow-mockup glow-border-card animate-float-slow"
          id="home-board-container"
        >
          <!-- Canvas Top Menu Toolbar -->
          <div
            class="h-11 border-b border-hairline bg-surface/85 backdrop-blur-md flex items-center px-4 justify-between select-none"
          >
            <!-- Left tools -->
            <div class="flex items-center gap-1.5">
              <button
                id="hero-tool-pen"
                class="p-1.5 rounded-md bg-surface border border-hairline-strong text-primary cursor-pointer hover:bg-hairline transition-colors"
                title="Sketch Pen"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
                  ></path>
                </svg>
              </button>
              <button
                id="hero-tool-sticky"
                class="p-1.5 rounded-md hover:bg-surface text-slate cursor-pointer transition-colors"
                title="Add Note"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                  ></path>
                </svg>
              </button>
              <div class="w-[1px] h-4 bg-hairline"></div>
              <button
                id="hero-tool-uuid"
                class="px-2 py-0.5 rounded bg-surface hover:bg-hairline border border-hairline text-[9px] font-bold text-brand-blue cursor-pointer transition-colors"
                title="Add UUID Note">+ UUID Note</button
              >
              <button
                id="hero-tool-base64"
                class="px-2 py-0.5 rounded bg-surface hover:bg-hairline border border-hairline text-[9px] font-bold text-brand-teal cursor-pointer transition-colors"
                title="Add Base64 Note">+ Base64 Note</button
              >
            </div>

            <!-- Right side controls -->
            <div class="flex items-center gap-1.5">
              <button
                id="toggle-multiplayer"
                class="px-2 py-0.5 rounded-full bg-surface hover:bg-hairline text-[9px] font-semibold text-slate border border-hairline flex items-center gap-1 cursor-pointer transition-colors"
              >
                <span
                  class="w-1.5 h-1.5 rounded-full bg-stone"
                  id="multiplayer-dot"></span>
                <span>Cursors</span>
              </button>
              <button
                id="hero-tool-clear"
                class="p-1.5 rounded hover:bg-surface text-stone cursor-pointer transition-colors"
                title="Clear drawings"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                  ></path>
                </svg>
              </button>
            </div>
          </div>

          <!-- Canvas & Notes Area -->
          <div
            class="flex-grow bg-canvas dot-grid relative overflow-hidden"
            id="home-board-canvas"
          >
            <!-- Simulated cursors layer -->
            <div
              id="simulated-cursors"
              class="absolute inset-0 pointer-events-none z-35"
            >
            </div>

            <!-- Notes layer -->
            <div
              id="home-notes-container"
              class="absolute inset-0 pointer-events-none z-10"
            >
            </div>

            <!-- Drawings Canvas -->
            <canvas
              id="home-sketch-canvas"
              class="absolute top-0 left-0 w-full h-full cursor-crosshair z-20"
            ></canvas>

            <!-- SVG curves that connect notes dynamically -->
            <svg
              class="absolute inset-0 pointer-events-none stroke-brand-blue animate-pulse z-0"
              fill="none"
              stroke-width="1.5"
              id="home-connecting-lines"
              style="width:100%; height:100%;"
            >
              <path d="M 0 0" stroke-dasharray="4" id="home-path-1"></path>
              <path
                d="M 0 0"
                stroke-dasharray="4"
                id="home-path-2"
                class="stroke-brand-teal"></path>
            </svg>

            <!-- Floating tip -->
            <div
              class="absolute bottom-3 right-3 bg-primary text-canvas px-2.5 py-1.2 rounded-full text-[9px] font-medium shadow-modal flex items-center gap-1 select-none pointer-events-none opacity-80 z-40"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-3 h-3 text-brand-yellow"
                viewBox="0 0 20 20"
                fill="currentColor"
                ><path
                  d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"
                ></path></svg
              >
              Drag sticky notes or sketch with pen tool!
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Directory Section -->
  <section
    id="tools-directory-section"
    class="bg-canvas py-16 px-4 border-b border-hairline scroll-mt-20"
  >
    <div class="max-w-[1280px] mx-auto">
      <!-- Recent History Workspaces Container (Dynamically populated) -->
      <div
        id="recent-workspaces-section"
        class="hidden mb-12 animate-fade-in-up delay-75"
      >
        <span
          class="text-xs font-semibold text-brand-blue uppercase tracking-wider block mb-3.5 select-none"
          >Quick Jump Back</span
        >
        <div
          id="recent-workspaces-list"
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4"
        >
          <!-- Dynamic nodes -->
        </div>
        <div class="h-[1px] bg-hairline mt-12"></div>
      </div>

      <div
        id="select-workspace-section"
        class="scroll-mt-20 flex flex-col md:flex-row justify-between items-baseline gap-4 mb-10"
      >
        <div>
          <span
            class="text-xs font-semibold text-brand-blue uppercase tracking-wider"
            >All Sandbox Tools</span
          >
          <h2
            class="font-display font-medium text-3xl text-primary tracking-tight mt-1"
          >
            Select a Workspace
          </h2>
        </div>
        <p class="text-sm text-slate max-w-md">
          Format input strings, run accessibility audits, compile SVG code, and
          draw. Instant results.
        </p>
      </div>

      <!-- Tool Grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
        id="tools-grid"
      >
        {
          tools.map((tool, index) => {
            let delayClass = "delay-75";
            if (index % 4 === 1) delayClass = "delay-100";
            else if (index % 4 === 2) delayClass = "delay-150";
            else if (index % 4 === 3) delayClass = "delay-200";

            return (
              <div
                class={`tool-card ${tool.cardClass} flex flex-col justify-between gap-8 group cursor-pointer card-hover-effect animate-fade-in-up ${delayClass}`}
                data-category={tool.category}
                data-title={tool.searchKeywords}
              >
                <div class="flex flex-col gap-3">
                  <span class={tool.badgeClass} style="align-self: start;">
                    {tool.badgeText}
                  </span>
                  <h3 class="font-display font-medium text-2xl text-primary tracking-tight">
                    {tool.name}
                  </h3>
                  <p
                    class={`text-sm leading-relaxed ${tool.cardClass === "card-feature-yellow" ? "text-yellow-dark/90" : tool.cardClass === "card-feature-teal" ? "text-moss-dark/90" : tool.cardClass === "card-feature-coral" ? "text-coral-dark/90" : "text-slate font-sans font-normal"}`}
                  >
                    {tool.desc}
                  </p>
                </div>
                <a
                  href={tool.path}
                  class="font-display font-medium text-sm text-primary flex items-center gap-1 group-hover:translate-x-1.5 transition-transform"
                >
                  {tool.actionText} &rarr;
                </a>
              </div>
            );
          })
        }

        <!-- Request a Tool Grid Card -->
        <div
          class="card-base border-dashed border-2 border-hairline-strong flex flex-col justify-between gap-4 p-6 hover:shadow-mockup transition-all group animate-fade-in-up delay-300 select-text"
          id="request-grid-card"
        >
          <div class="flex flex-col gap-3">
            <span
              class="badge-tag-purple bg-surface-pricing-featured text-brand-blue self-start"
              >SUGGEST</span
            >
            <h3
              class="font-display font-medium text-xl text-primary tracking-tight"
            >
              Request a Tool
            </h3>
            <p class="text-xs text-slate leading-relaxed font-sans font-normal">
              Need a custom calculator, audio generator, or sensor reader?
              Request it here! We build our utilities completely client-side.
            </p>
          </div>

          <form
            id="grid-request-form"
            class="flex flex-col gap-2 pointer-events-auto"
          >
            <input
              type="email"
              id="grid-request-email"
              required
              placeholder="Enter email address"
              class="text-input !h-9 !py-1 !text-xs focus:border-brand-blue"
            />
            <input
              type="text"
              id="grid-request-desc"
              required
              placeholder="What tool do you want next?"
              class="text-input !h-9 !py-1 !text-xs focus:border-brand-blue"
            />
            <button
              type="submit"
              class="button-primary w-full !py-2 !text-xs hover:button-primary-active mt-1"
            >
              Submit Idea
            </button>
          </form>

          <div
            id="grid-request-success"
            class="hidden flex-col items-center justify-center text-center py-4 gap-2"
          >
            <span
              class="w-8 h-8 rounded-full bg-success-accent/25 border border-success-accent text-success-accent flex items-center justify-center font-bold text-sm"
              >✓</span
            >
            <span class="text-xs font-semibold text-primary"
              >Idea Submitted!</span
            >
            <span class="text-[10px] text-slate font-medium"
              >Thanks! We've saved your request.</span
            >
          </div>
        </div>
      </div>

      <!-- Empty state when no search matches -->
      <div
        id="empty-state"
        class="hidden text-center py-16 border border-dashed border-hairline rounded-xl mt-6"
      >
        <p class="text-slate font-medium">
          No tools found matching your criteria.
        </p>
        <button
          id="clear-search-btn"
          class="button-ghost text-brand-blue text-sm mt-2 font-medium"
          >Clear search queries</button
        >
      </div>
    </div>
  </section>

  <!-- User Reviews & Testimonials Section -->
  <section class="bg-canvas py-16 px-4 border-t border-hairline relative z-10">
    <div class="max-w-[1280px] mx-auto">
      <div class="text-center mb-12 flex flex-col gap-2">
        <span
          class="text-xs font-semibold text-brand-blue uppercase tracking-wider"
          >User Reviews</span
        >
        <h2
          class="font-display font-medium text-3xl text-primary tracking-tight"
        >
          What Creators Say About BoardTools
        </h2>
        <p class="text-sm text-slate max-w-md mx-auto">
          Read testimonials from developers and designers who build interfaces
          using our secure client-side sandbox.
        </p>
      </div>

      <!-- Reviews Feed Grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-6"
        id="homepage-reviews-grid"
      >
        <!-- Static review 1 -->
        <div
          class="flex flex-col justify-between gap-4 p-6 rounded-2xl bg-surface-yellow border border-yellow-light text-yellow-dark shadow-subtle"
        >
          <p class="text-xs leading-relaxed opacity-95 italic">
            "Absolutely loving the interactive whiteboard widget on the
            homepage! I was able to sketch out a wireframe flow while
            simultaneously using the UUID and Base64 cards."
          </p>
          <div class="flex items-center gap-3 mt-2">
            <div
              class="w-8 h-8 rounded-full bg-yellow-light border border-yellow-dark/20 flex items-center justify-center font-bold text-xs select-none"
            >
              DV
            </div>
            <div class="flex flex-col">
              <span class="text-xs font-bold text-primary">Darnell Vance</span>
              <span class="text-[9px] opacity-75">Senior Product Designer</span>
            </div>
          </div>
        </div>

        <!-- Static review 2 -->
        <div
          class="flex flex-col justify-between gap-4 p-6 rounded-2xl bg-teal-light border border-hairline text-moss-dark shadow-subtle"
        >
          <p class="text-xs leading-relaxed opacity-95 italic">
