      class="max-w-[1280px] mx-auto bg-primary text-canvas rounded-3xl p-12 text-center flex flex-col items-center gap-6 shadow-mockup"
    >
      <span
        class="text-brand-yellow font-display text-sm font-semibold tracking-wider uppercase"
        >Visual Workflow Suite</span
      >
      <h2
        class="font-display font-medium text-3xl md:text-4xl text-canvas max-w-xl tracking-tight leading-tight"
      >
        Build better web interfaces visually. Launch BoardTools.
      </h2>
      <p class="text-xs md:text-sm text-on-dark-muted max-w-md">
        Instant loading, zero tracker cookies, offline capability, completely
        local sandbox.
      </p>
      <a
        href="/tools/whiteboard"
        class="button-on-dark px-8 py-3 !rounded-full mt-2"
      >
        Launch Sandbox Whiteboard
