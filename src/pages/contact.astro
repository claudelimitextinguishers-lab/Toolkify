---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us - TOOLKIFY"
  description="Get in touch with the TOOLKIFY team. Reach out via email to protect your privacy and data security."
>
  <section class="max-w-[1000px] w-full mx-auto px-4 md:px-8 py-12 md:py-24 flex-grow flex flex-col justify-center gap-12 animate-fade-in-up">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
        <a href="/" class="hover:text-primary">Home</a>
        <span>/</span>
        <span class="text-brand-blue">Contact Us</span>
      </div>
      <h1 class="font-display font-medium text-4xl sm:text-6xl tracking-tight text-primary mt-1">
        Contact Our Team
      </h1>
      <p class="text-lg text-slate max-w-2xl">
        We would love to hear your feedback, suggestions, or reports. Reach out to us directly via email.
      </p>
    </div>

    <!-- Contact Info Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
      <!-- Left Card: Mail Us Action -->
      <div class="card-feature-teal flex flex-col justify-between p-8 sm:p-10 rounded-xxxl min-h-[320px]">
        <div class="flex flex-col gap-4">
          <span class="badge-tag-purple bg-white text-brand-blue self-start">DIRECT INQUIRIES</span>
          <h2 class="font-display font-semibold text-2xl text-primary">Get in Touch</h2>
          <p class="text-sm text-slate leading-relaxed">
            Have a tool request, spotted a bug, or want to share feedback? Send us an email directly from your device.
          </p>
        </div>

        <div class="mt-8">
          <a 
            href="mailto:claudelimitextinguishers@gmail.com" 
            class="inline-block button-primary text-center w-full sm:w-auto py-3 px-8 text-base shadow-sm hover:scale-[1.02] active:scale-[0.98] transition-transform"
          >
            Mail Us (Click Here)
          </a>
        </div>
      </div>

      <!-- Right Card: Why we do this (Privacy Policy explanation) -->
      <div class="card-feature-rose flex flex-col justify-between p-8 sm:p-10 rounded-xxxl min-h-[320px]">
        <div class="flex flex-col gap-4">
          <span class="badge-tag-coral bg-white text-coral-dark self-start">PRIVACY & SECURITY</span>
          <h2 class="font-display font-semibold text-2xl text-primary">Why We Use Email Only</h2>
          <p class="text-sm text-slate leading-relaxed">
            Because of privacy and our policy of keeping everything secure and safe, we do not host contact forms or database systems that process or store message logs on our servers.
          </p>
          <p class="text-sm text-slate leading-relaxed">
            TOOLKIFY is built to run 100% on the user's device with zero data transmission to any external server. Using your local email client guarantees that your communication remains completely secure and within your control.
          </p>
        </div>

        <div class="mt-6 flex items-center gap-2 text-xs font-semibold text-slate">
          <span>🔒</span>
          <span>100% Local Device Privacy Shield</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
