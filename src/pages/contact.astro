---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us - BoardTools"
  description="Get in touch with the BoardTools team. Leave feedback, report utility issues, or suggest new tool features."
>
  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-12 flex flex-col gap-8 animate-fade-in-up">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
        <a href="/" class="hover:text-primary">Home</a>
        <span>/</span>
        <span class="text-brand-blue">Contact Us</span>
      </div>
      <h1 class="font-display font-medium text-4xl sm:text-5xl tracking-tight text-primary mt-1">
        Contact Our Team
      </h1>
      <p class="text-base text-slate max-w-xl">
        Have questions about privacy? Spot a bug in a formatting tool? Drop us a line below and we will get back to you.
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      <!-- Left: Contact Form Card -->
      <div class="lg:col-span-7 card-base flex flex-col gap-6" id="form-container">
        <h2 class="font-display font-semibold text-xl text-primary flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-brand-blue"></span>
          Send a Message
        </h2>

        <form id="contact-form" class="flex flex-col gap-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="contact-name" class="text-xs font-semibold text-slate">Your Name</label>
              <input 
                type="text" 
                id="contact-name" 
                name="name" 
                required 
                placeholder="Alex Smith" 
                class="text-input focus:border-brand-blue" 
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="contact-email" class="text-xs font-semibold text-slate">Email Address</label>
              <input 
                type="email" 
                id="contact-email" 
                name="email" 
                required 
                placeholder="alex@example.com" 
                class="text-input focus:border-brand-blue" 
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="contact-subject" class="text-xs font-semibold text-slate">Subject</label>
            <input 
              type="text" 
              id="contact-subject" 
              name="subject" 
              required 
              placeholder="How can we help?" 
              class="text-input focus:border-brand-blue" 
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="contact-message" class="text-xs font-semibold text-slate">Message Details</label>
            <textarea 
              id="contact-message" 
              name="message" 
              required 
              rows="5" 
              placeholder="Write your query details here..." 
              class="w-full p-3 font-sans text-sm bg-surface-soft border border-hairline-strong rounded-lg outline-none focus:border-brand-blue transition-all"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="button-primary self-start py-2.5 px-6 text-sm hover:button-primary-active mt-2"
          >
            Submit Message
          </button>
        </form>
      </div>

      <!-- Success State Card (hidden by default) -->
      <div class="lg:col-span-7 card-base hidden flex-col items-center justify-center text-center p-12 gap-5" id="success-container">
        <div class="w-16 h-16 rounded-full bg-success-accent/20 border border-success-accent text-success-accent flex items-center justify-center font-bold text-2xl animate-scale-in">
          ✓
        </div>
        <div class="flex flex-col gap-2">
          <h2 class="font-display font-medium text-2xl text-primary">Message Sent Successfully!</h2>
          <p class="text-sm text-slate max-w-sm">
            Thank you for reaching out. Since BoardTools runs locally, we have saved your message to your local inbox file.
          </p>
        </div>
        <button 
          id="btn-send-another" 
          class="button-secondary py-2 px-5 text-xs !rounded-full hover:bg-surface cursor-pointer mt-2"
        >
          Send Another Message
        </button>
      </div>

      <!-- Right: Channel & Info Sidebar -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <!-- Direct Channels Card -->
        <div class="card-base bg-surface-soft flex flex-col gap-4">
          <h3 class="font-display font-semibold text-base text-primary">Direct Channels</h3>
          
          <div class="flex flex-col gap-4 text-sm">
            <div class="flex gap-3">
              <span class="text-lg">📧</span>
              <div class="flex flex-col">
                <span class="font-semibold text-primary">General Inquiries</span>
                <span class="text-xs text-slate">hello@boardtools.io (Simulated)</span>
              </div>
            </div>

            <div class="flex gap-3">
              <span class="text-lg">🐞</span>
              <div class="flex flex-col">
                <span class="font-semibold text-primary">Bug Reports & Fixes</span>
                <span class="text-xs text-slate">Open a PR on GitHub</span>
              </div>
            </div>

            <div class="flex gap-3">
              <span class="text-lg">💬</span>
              <div class="flex flex-col">
                <span class="font-semibold text-primary">Community Support</span>
                <span class="text-xs text-slate">Join our Discord Developer island</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Security Notice Card (Pastel Accent) -->
        <div class="card-feature-rose flex flex-col gap-3">
          <span class="badge-tag-purple bg-rose-light text-primary self-start">ZERO COMPROMISE</span>
          <h3 class="font-display font-semibold text-base text-primary">No tracking cookies</h3>
          <p class="text-xs text-slate leading-relaxed">
            Your form inputs are never tracked, stored, or resold to third-party ad networks. We build tools that respects our users.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const formContainer = document.getElementById('form-container');
  const successContainer = document.getElementById('success-container');
  const btnSendAnother = document.getElementById('btn-send-another');

  if (form && formContainer && successContainer) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const submission = {
        name: formData.get('name'),
        email: formData.get('email'),
        subject: formData.get('subject'),
        message: formData.get('message'),
        timestamp: Date.now()
      };

      // Store in localStorage list of messages
      try {
        const existing = JSON.parse(localStorage.getItem('contact_messages') || '[]');
        existing.push(submission);
        localStorage.setItem('contact_messages', JSON.stringify(existing));
      } catch (err) {}

      // Swap containers
      formContainer.classList.add('hidden');
      successContainer.classList.remove('hidden');
      successContainer.classList.add('flex');
    });
  }

  if (btnSendAnother && form && formContainer && successContainer) {
    btnSendAnother.addEventListener('click', () => {
      form.reset();
      successContainer.classList.remove('flex');
      successContainer.classList.add('hidden');
      formContainer.classList.remove('hidden');
    });
  }
</script>
