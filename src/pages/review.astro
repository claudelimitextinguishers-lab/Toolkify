---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Review Our Website - TOOLKIFY"
  description="Help us make TOOLKIFY better. Write a review, rate your workspace experience, and read reviews left by other developers."
>
  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-12 flex flex-col gap-10 animate-fade-in-up">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
        <a href="/" class="hover:text-primary">Home</a>
        <span>/</span>
        <span class="text-brand-blue">Reviews</span>
      </div>
      <h1 class="font-display font-medium text-4xl sm:text-5xl tracking-tight text-primary mt-1">
        Review Our Website
      </h1>
      <p class="text-sm text-slate max-w-xl">
        Share your experience, suggest layout refinements, or rate our client-side utilities. 
        You can submit a review by filling out the form below or emailing us directly at 
        <a href="#" id="direct-email-link" class="text-brand-blue hover:underline font-bold">claudelimitextinguishers@gmail.com</a>. 
        Approved reviews will be added to the live site within 1 week.
      </p>
    </div>

    <!-- Review Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left: Email Callout -->
      <div class="lg:col-span-5 card-base flex flex-col gap-6 bg-surface-yellow border-2 border-brand-yellow-deep p-6 sm:p-8 rounded-2xl relative overflow-hidden group hover:shadow-lg transition-all duration-300">
        <div class="absolute -top-12 -right-12 w-36 h-36 bg-brand-yellow/15 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
        
        <div class="flex items-center gap-3">
          <span class="text-3xl animate-pulse">âœ‰ï¸</span>
          <h2 class="font-display font-semibold text-xl text-primary tracking-tight">
            Share Your Experience
          </h2>
        </div>
        
        <p class="text-sm text-slate leading-relaxed">
          We want to make TOOLKIFY the absolute best visual workspace. Share your reviews, feedback, or rating with us directly.
        </p>
        
        <!-- Highlight Box -->
        <div class="bg-canvas border border-yellow-light p-6 rounded-xl shadow-subtle flex flex-col gap-3 relative z-10">
          <p class="text-base text-primary font-medium leading-relaxed">
            To email us, <a href="#" id="direct-email-link-highlight" class="text-brand-blue hover:text-blue-pressed underline decoration-2 underline-offset-4 font-bold transition-all inline-block hover:scale-105 active:scale-95">Click here</a>.
          </p>
          <p class="text-xs text-slate mt-1">
            Opening your email client will allow you to rate your experience and write a quick review.
          </p>
        </div>

        <div class="text-[11px] text-slate/85 bg-surface-soft p-3.5 rounded-lg border border-hairline italic mt-1">
          Note: Submitted reviews will be verified and posted on this page within 1 week.
        </div>
      </div>

      <!-- Right: Live Reviews Feed -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="flex items-baseline justify-between">
          <h2 class="font-display font-semibold text-xl text-primary">Community Feedback</h2>
          <span class="text-xs text-slate" id="review-count">Loading reviews...</span>
        </div>

        <!-- Target Reviews Container -->
        <div class="flex flex-col gap-4" id="reviews-feed">
          <!-- Dynamic reviews injected here -->
        </div>
      </div>
    </div>

    <!-- Permission Confirmation Modal -->
    <div id="permission-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm hidden animate-fade-in">
      <div class="card-base max-w-md w-full flex flex-col gap-5 p-6 border border-hairline-strong bg-canvas shadow-2xl animate-scale-up">
        <div class="flex items-center gap-3 text-brand-blue">
          <span class="text-2xl">âœ‰</span>
          <h3 class="font-display font-semibold text-lg text-primary">Open Mail Application?</h3>
        </div>
        <p class="text-xs text-slate leading-relaxed">
          We will open your default email service to send this review to <span class="font-bold text-brand-blue select-all">claudelimitextinguishers@gmail.com</span>. 
          Your email will contain your name, job title, rating, and review text.
        </p>
        <p class="text-[11px] text-slate/80 bg-surface-soft p-3 rounded-lg border border-hairline italic">
          Note: Your review will be moderated and added to the website's community feedback section within 1 week.
        </p>
        <div class="flex items-center justify-end gap-3 mt-2">
          <button type="button" id="modal-cancel-btn" class="button-ghost py-2 px-4 text-xs font-semibold text-slate hover:bg-surface-soft rounded-lg cursor-pointer">
            Cancel
          </button>
          <button type="button" id="modal-confirm-btn" class="button-primary py-2 px-4 text-xs font-semibold hover:button-primary-active cursor-pointer">
            Yes, Open Mail Client
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Pre-seed default reviews to make page look rich out-of-the-box
  const defaultReviews = [
    {
      name: "Darnell Vance",
      title: "Senior Product Designer",
      rating: 5,
      review: "Absolutely loving the interactive whiteboard widget on the homepage! I was able to sketch out a wireframe flow while simultaneously using the UUID and Base64 cards. Perfect toolset.",
      color: "bg-surface-yellow border border-yellow-light text-yellow-dark",
      timestamp: Date.now() - 3600000 * 24 * 3 // 3 days ago
    },
    {
      name: "Aisha Rahman",
      title: "Full Stack Developer",
      rating: 5,
      review: "The fact that this tool runs 100% locally is a lifesaver. Our company has extremely strict policies about pasting credentials or data into third-party sites, but TOOLKIFY' V8 sandboxing completely solves that.",
      color: "bg-teal-light border border-hairline text-moss-dark",
      timestamp: Date.now() - 3600000 * 24 // 1 day ago
    },
    {
      name: "Marcus Cheng",
      title: "UI Engineer",
      rating: 4,
      review: "Clean aesthetic, very Miro-esque. The Contrast Checker works flawlessly for auditing AA/AAA scores. I'd love to see a JWT decoder added in a future update!",
      color: "bg-coral-light border border-hairline text-coral-dark",
      timestamp: Date.now() - 3600000 * 6 // 6 hours ago
    }
  ];

  // Colors mapping for dynamically submitted cards
  const pastelClasses = [
    "bg-surface-yellow border border-yellow-light text-yellow-dark",
    "bg-teal-light border border-hairline text-moss-dark",
    "bg-coral-light border border-hairline text-coral-dark",
    "bg-rose-light border border-hairline text-primary"
  ];

  // Interactive Stars Logic
  const stars = document.querySelectorAll('.star-btn');
  const ratingInput = document.getElementById('review-rating-value') as HTMLInputElement | null;
  const ratingLabel = document.getElementById('rating-label');

  let selectedRating = 0;

  const labels: Record<number, string> = {
    1: 'Needs Improvement ðŸ˜ ',
    2: 'Below Average ðŸ˜',
    3: 'Average ðŸ™‚',
    4: 'Great! ðŸ˜€',
    5: 'Excellent! ðŸ¤©'
  };

  stars.forEach((star, idx) => {
    // Hover effect
    star.addEventListener('mouseenter', () => {
      highlightStars(idx + 1);
    });

    star.addEventListener('mouseleave', () => {
      highlightStars(selectedRating);
    });

    // Click selection
    star.addEventListener('click', () => {
      selectedRating = idx + 1;
      if (ratingInput) ratingInput.value = String(selectedRating);
      if (ratingLabel) ratingLabel.textContent = labels[selectedRating] || 'Select Rating';
      highlightStars(selectedRating);
    });
  });

  function highlightStars(count: number) {
    stars.forEach((star, i) => {
      if (i < count) {
        star.classList.remove('text-stone');
        star.classList.add('text-brand-yellow-deep');
      } else {
        star.classList.add('text-stone');
        star.classList.remove('text-brand-yellow-deep');
      }
    });
  }

  // Reviews Render Logic
  const feed = document.getElementById('reviews-feed');
  const countLabel = document.getElementById('review-count');

  function renderReviews() {
    if (!feed) return;
    feed.innerHTML = '';

    // Retrieve from LocalStorage
    let local: any[] = [];
    try {
      local = JSON.parse(localStorage.getItem('user_reviews') || '[]');
    } catch(e) {}

    const all = [...local, ...defaultReviews];
    if (countLabel) countLabel.textContent = `${all.length} reviews`;

    all.forEach((item, index) => {
      const card = document.createElement('div');
      
      // Determine card coloring: Local submissions get a rotated pastel color index
      let colorClass = item.color;
      if (!colorClass) {
        colorClass = pastelClasses[index % pastelClasses.length];
      }

      // Format stars
      const starsHTML = 'â˜…'.repeat(item.rating) + 'â˜†'.repeat(5 - item.rating);
      
      card.className = `flex flex-col gap-3 p-5 rounded-2xl ${colorClass} shadow-subtle animate-fade-in-up`;
      card.innerHTML = `
        <div class="flex items-start justify-between">
          <div class="flex flex-col">
            <span class="font-display font-semibold text-sm text-primary">${item.name}</span>
            <span class="text-[10px] opacity-75">${item.title || 'User'}</span>
          </div>
          <span class="text-xs font-bold text-brand-yellow-deep tracking-wider">${starsHTML}</span>
        </div>
        <p class="text-xs leading-relaxed opacity-90">${item.review}</p>
        <div class="flex justify-between items-center mt-1">
          ${!item.color ? '<span class="text-[8px] bg-slate/10 px-1.5 py-0.5 rounded font-semibold text-slate">Local Preview (Pending approval)</span>' : '<span></span>'}
          <span class="text-[9px] opacity-60">${new Date(item.timestamp).toLocaleDateString()}</span>
        </div>
      `;
      feed.appendChild(card);
    });
  }

  // Modal elements
  const modal = document.getElementById('permission-modal');
  const modalCancel = document.getElementById('modal-cancel-btn');
  const modalConfirm = document.getElementById('modal-confirm-btn');
  let pendingMailto = '';
  let pendingReviewData: any = null;

  function showModal(mailtoUrl: string, reviewData?: any) {
    pendingMailto = mailtoUrl;
    pendingReviewData = reviewData || null;
    if (modal) {
      modal.classList.remove('hidden');
    }
  }

  function hideModal() {
    if (modal) {
      modal.classList.add('hidden');
    }
    pendingMailto = '';
    pendingReviewData = null;
  }

  if (modalCancel) {
    modalCancel.addEventListener('click', hideModal);
  }

  if (modalConfirm) {
    modalConfirm.addEventListener('click', () => {
      if (pendingMailto) {
        window.location.href = pendingMailto;
      }
      
      // If we had review data from the form, save to local storage for local preview
      if (pendingReviewData) {
        try {
          const local = JSON.parse(localStorage.getItem('user_reviews') || '[]');
          local.unshift(pendingReviewData);
          localStorage.setItem('user_reviews', JSON.stringify(local));
        } catch(err) {}
        renderReviews();
      }

      // Reset form if it exists
      if (form) {
        form.reset();
        selectedRating = 0;
        if (ratingInput) ratingInput.value = '';
        if (ratingLabel) ratingLabel.textContent = 'Select Rating';
        highlightStars(0);
      }

      hideModal();
    });
  }

  // Handle Form Submission
  const form = document.getElementById('review-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (selectedRating === 0) {
        alert('Please select a star rating first.');
        return;
      }

      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const title = formData.get('title') as string || 'User';
      const rating = Number(formData.get('rating'));
      const reviewText = formData.get('review') as string;

      const reviewData = {
        name,
        title,
        rating,
        review: reviewText,
        timestamp: Date.now()
      };

      const subject = encodeURIComponent(`TOOLKIFY Site Review - ${rating} Stars`);
      const body = encodeURIComponent(
        `Name: ${name}\n` +
        `Title: ${title}\n` +
        `Rating: ${rating}/5 Stars\n\n` +
        `Review:\n${reviewText}\n\n` +
        `---\n` +
        `Sent via TOOLKIFY Review composer. Review will be approved and added to the website within 1 week.`
      );
      const mailtoUrl = `mailto:claudelimitextinguishers@gmail.com?subject=${subject}&body=${body}`;

      showModal(mailtoUrl, reviewData);
    });
  }

  // Handle direct click on email links
  const emailLinks = ['direct-email-link', 'direct-email-link-highlight'];
  emailLinks.forEach(id => {
    const link = document.getElementById(id);
    if (link) {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const subject = encodeURIComponent(`TOOLKIFY Site Review`);
        const body = encodeURIComponent(
          `Please rate us (1-5 stars):\n` +
          `Stars: \n\n` +
          `Your Review:\n` +
          `\n\n` +
          `Your Name & Title:\n`
        );
        const mailtoUrl = `mailto:claudelimitextinguishers@gmail.com?subject=${subject}&body=${body}`;
        showModal(mailtoUrl);
      });
    }
  });

  // Initial load
  renderReviews();
</script>
