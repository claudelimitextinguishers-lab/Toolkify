---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Review Our Website - BoardTools"
  description="Help us make BoardTools better. Write a review, rate your workspace experience, and read reviews left by other developers."
>
  <section class="max-w-[1280px] w-full mx-auto px-4 md:px-8 py-12 flex flex-col gap-10 animate-fade-in-up">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-xs font-semibold text-slate uppercase">
        <a href="/" class="hover:text-primary">Home</a>
        <span>/</span>
        <span class="text-brand-blue">Reviews</span>
      </div>
      <h1 class="font-display font-medium text-4xl sm:text-5xl tracking-tight text-primary mt-1">
        Review Our Website
      </h1>
      <p class="text-base text-slate max-w-xl">
        Share your experience, suggest layout refinements, or rate our client-side utilities. We read all community logs!
      </p>
    </div>

    <!-- Review Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left: Create Review Form -->
      <div class="lg:col-span-5 card-base flex flex-col gap-6">
        <h2 class="font-display font-semibold text-lg text-primary flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-brand-yellow-deep"></span>
          Write a Review
        </h2>

        <form id="review-form" class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="review-name" class="text-xs font-semibold text-slate">Full Name</label>
            <input 
              type="text" 
              id="review-name" 
              name="name" 
              required 
              placeholder="e.g. Sarah Jenkins" 
              class="text-input focus:border-brand-blue" 
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="review-title" class="text-xs font-semibold text-slate">Job Title / Company</label>
            <input 
              type="text" 
              id="review-title" 
              name="title" 
              placeholder="e.g. Lead Frontend Engineer at Vercel" 
              class="text-input focus:border-brand-blue" 
            />
          </div>

          <!-- Interactive Star Rating -->
          <div class="flex flex-col gap-2">
            <span class="text-xs font-semibold text-slate">Your Rating</span>
            <div class="flex items-center gap-2">
              <div class="flex gap-1" id="star-rating-container">
                <button type="button" data-value="1" class="star-btn text-2xl text-stone hover:scale-110 transition-transform cursor-pointer" aria-label="1 star">★</button>
                <button type="button" data-value="2" class="star-btn text-2xl text-stone hover:scale-110 transition-transform cursor-pointer" aria-label="2 stars">★</button>
                <button type="button" data-value="3" class="star-btn text-2xl text-stone hover:scale-110 transition-transform cursor-pointer" aria-label="3 stars">★</button>
                <button type="button" data-value="4" class="star-btn text-2xl text-stone hover:scale-110 transition-transform cursor-pointer" aria-label="4 stars">★</button>
                <button type="button" data-value="5" class="star-btn text-2xl text-stone hover:scale-110 transition-transform cursor-pointer" aria-label="5 stars">★</button>
              </div>
              <span id="rating-label" class="text-xs font-semibold text-brand-yellow-deep">Select Rating</span>
            </div>
            <input type="hidden" name="rating" id="review-rating-value" required />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="review-text" class="text-xs font-semibold text-slate">Your Review</label>
            <textarea 
              id="review-text" 
              name="review" 
              required 
              rows="4" 
              placeholder="What do you think of our offline-first tools, the whiteboard layout, or the dark mode?" 
              class="w-full p-3 font-sans text-sm bg-surface-soft border border-hairline-strong rounded-lg outline-none focus:border-brand-blue transition-all"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="button-primary self-start py-2.5 px-6 text-sm hover:button-primary-active mt-2"
          >
            Submit Review
          </button>
        </form>
      </div>

      <!-- Right: Live Reviews Feed -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="flex items-baseline justify-between">
          <h2 class="font-display font-semibold text-xl text-primary">Community Feedback</h2>
          <span class="text-xs text-slate" id="review-count">Loading reviews...</span>
        </div>

        <!-- Target Reviews Container -->
        <div class="flex flex-col gap-4" id="reviews-feed">
          <!-- Dynamic reviews injected here -->
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Pre-seed default reviews to make page look rich out-of-the-box
  const defaultReviews = [
    {
      name: "Darnell Vance",
      title: "Senior Product Designer",
      rating: 5,
      review: "Absolutely loving the interactive whiteboard widget on the homepage! I was able to sketch out a wireframe flow while simultaneously using the UUID and Base64 cards. Perfect toolset.",
      color: "bg-surface-yellow border border-yellow-light text-yellow-dark",
      timestamp: Date.now() - 3600000 * 24 * 3 // 3 days ago
    },
    {
      name: "Aisha Rahman",
      title: "Full Stack Developer",
      rating: 5,
      review: "The fact that this tool runs 100% locally is a lifesaver. Our company has extremely strict policies about pasting credentials or data into third-party sites, but BoardTools' V8 sandboxing completely solves that.",
      color: "bg-teal-light border border-hairline text-moss-dark",
      timestamp: Date.now() - 3600000 * 24 // 1 day ago
    },
    {
      name: "Marcus Cheng",
      title: "UI Engineer",
      rating: 4,
      review: "Clean aesthetic, very Miro-esque. The Contrast Checker works flawlessly for auditing AA/AAA scores. I'd love to see a JWT decoder added in a future update!",
      color: "bg-coral-light border border-hairline text-coral-dark",
      timestamp: Date.now() - 3600000 * 6 // 6 hours ago
    }
  ];

  // Colors mapping for dynamically submitted cards
  const pastelClasses = [
    "bg-surface-yellow border border-yellow-light text-yellow-dark",
    "bg-teal-light border border-hairline text-moss-dark",
    "bg-coral-light border border-hairline text-coral-dark",
    "bg-rose-light border border-hairline text-primary"
  ];

  // Interactive Stars Logic
  const stars = document.querySelectorAll('.star-btn');
  const ratingInput = document.getElementById('review-rating-value') as HTMLInputElement | null;
  const ratingLabel = document.getElementById('rating-label');

  let selectedRating = 0;

  const labels: Record<number, string> = {
    1: 'Needs Improvement 😠',
    2: 'Below Average 😐',
    3: 'Average 🙂',
    4: 'Great! 😀',
    5: 'Excellent! 🤩'
  };

  stars.forEach((star, idx) => {
    // Hover effect
    star.addEventListener('mouseenter', () => {
      highlightStars(idx + 1);
    });

    star.addEventListener('mouseleave', () => {
      highlightStars(selectedRating);
    });

    // Click selection
    star.addEventListener('click', () => {
      selectedRating = idx + 1;
      if (ratingInput) ratingInput.value = String(selectedRating);
      if (ratingLabel) ratingLabel.textContent = labels[selectedRating] || 'Select Rating';
      highlightStars(selectedRating);
    });
  });

  function highlightStars(count: number) {
    stars.forEach((star, i) => {
      if (i < count) {
        star.classList.remove('text-stone');
        star.classList.add('text-brand-yellow-deep');
      } else {
        star.classList.add('text-stone');
        star.classList.remove('text-brand-yellow-deep');
      }
    });
  }

  // Reviews Render Logic
  const feed = document.getElementById('reviews-feed');
  const countLabel = document.getElementById('review-count');

  function renderReviews() {
    if (!feed) return;
    feed.innerHTML = '';

    // Retrieve from LocalStorage
    let local: any[] = [];
    try {
      local = JSON.parse(localStorage.getItem('user_reviews') || '[]');
    } catch(e) {}

    const all = [...local, ...defaultReviews];
    if (countLabel) countLabel.textContent = `${all.length} reviews`;

    all.forEach((item, index) => {
      const card = document.createElement('div');
      
      // Determine card coloring: Local submissions get a rotated pastel color index
      let colorClass = item.color;
      if (!colorClass) {
        colorClass = pastelClasses[index % pastelClasses.length];
      }

      // Format stars
      const starsHTML = '★'.repeat(item.rating) + '☆'.repeat(5 - item.rating);
      
      card.className = `flex flex-col gap-3 p-5 rounded-2xl ${colorClass} shadow-subtle animate-fade-in-up`;
      card.innerHTML = `
        <div class="flex items-start justify-between">
          <div class="flex flex-col">
            <span class="font-display font-semibold text-sm text-primary">${item.name}</span>
            <span class="text-[10px] opacity-75">${item.title || 'User'}</span>
          </div>
          <span class="text-xs font-bold text-brand-yellow-deep tracking-wider">${starsHTML}</span>
        </div>
        <p class="text-xs leading-relaxed opacity-90">${item.review}</p>
        <span class="text-[9px] opacity-60 self-end">${new Date(item.timestamp).toLocaleDateString()}</span>
      `;
      feed.appendChild(card);
    });
  }

  // Handle Form Submission
  const form = document.getElementById('review-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (selectedRating === 0) {
        alert('Please select a star rating first.');
        return;
      }

      const formData = new FormData(form);
      const newReview = {
        name: formData.get('name'),
        title: formData.get('title'),
        rating: Number(formData.get('rating')),
        review: formData.get('review'),
        timestamp: Date.now()
      };

      try {
        const local = JSON.parse(localStorage.getItem('user_reviews') || '[]');
        local.unshift(newReview); // Prepend to show immediately
        localStorage.setItem('user_reviews', JSON.stringify(local));
      } catch(err) {}

      // Reset
      form.reset();
      selectedRating = 0;
      if (ratingInput) ratingInput.value = '';
      if (ratingLabel) ratingLabel.textContent = 'Select Rating';
      highlightStars(0);

      // Re-render
      renderReviews();
    });
  }

  // Initial load
  renderReviews();
</script>
